                                            "88:1":  {
                                                         "id":  5968
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp\u003eتفسير سورة الغاشية وهي مكية .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eقد تقدم عن النعمان بن بشير : أن رسول الله - صلى الله عليه وسلم - كان يقرأ ب \u003cspan class=\"red\"\u003e\" سبح اسم ربك الأعلى \"\u003c/span\u003e والغاشية في صلاة العيد ويوم الجمعة .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eوقال الإمام مالك ، عن ضمرة بن سعيد ،\u003cspan class=\"blue\"\u003e عن عبيد الله بن عبد الله :\u003c/span\u003e أن الضحاك بن قيس سأل النعمان بن بشير : بم كان رسول الله - صلى الله عليه وسلم - يقرأ في الجمعة مع سورة الجمعة ؟\u003cspan class=\"blue\"\u003e قال :\u003c/span\u003e \u003cspan class=\"red\"\u003e\" هل أتاك حديث الغاشية \"\u003c/span\u003e .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eرواه أبو داود عن القعنبي ، والنسائي عن قتيبة ، كلاهما عن مالك به ، ورواه مسلم وابن ماجه ، من حديث سفيان بن عيينة ، عن ضمرة بن سعيد ، به .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eالغاشية : من أسماء يوم القيامة . قاله ابن عباس ، وقتادة ، وابن زيد ; لأنها تغشى الناس وتعمهم .\u003cspan class=\"blue\"\u003e وقد قال ابن أبي حاتم :\u003c/span\u003e\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eحدثنا أبي ، حدثنا علي بن محمد الطنافسي ، حدثنا أبو بكر بن عياش ، عن أبي إسحاق ،\u003cspan class=\"blue\"\u003e عن عمرو بن ميمون قال :\u003c/span\u003e مر النبي - صلى الله عليه وسلم -\u003cspan class=\"blue\"\u003e على امرأة تقرأ :\u003c/span\u003e \u003cspan class=\"arabic qpc-hafs\"\u003e( هل أتاك حديث الغاشية )\u003c/span\u003e فقام يستمع ويقول : \u003cspan class=\"red\"\u003e\" نعم ، قد جاءني \"\u003c/span\u003e .\u003c/p\u003e"
                         },
                   "2":  {
                             "verses":  {
                                            "88:2":  {
                                                         "id":  5969
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp\u003eأي ذليلة قاله قتادة وقال ابن عباس تخشع ولا ينفعها عملها.\u003c/p\u003e"
                         },
                   "3":  {
                             "verses":  {
                                            "88:3":  {
                                                         "id":  5970
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eوقوله : \u003cspan class=\"arabic qpc-hafs\"\u003e( عاملة ناصبة )\u003c/span\u003e أي : قد عملت عملا كثيرا ، ونصبت فيه ، وصليت يوم القيامة نارا حامية .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eوقال الحافظ أبو بكر البرقاني : حدثنا إبراهيم بن محمد المزكى ، حدثنا محمد بن إسحاق السراج ، حدثنا هارون بن عبد الله ،\u003cspan class=\"blue\"\u003e حدثنا سيار حدثنا جعفر قال :\u003c/span\u003e سمعت أبا عمران الجوني يقول : مر عمر بن الخطاب ، رضي الله عنه ، بدير راهب ،\u003cspan class=\"blue\"\u003e قال :\u003c/span\u003e فناداه : يا راهب \u003cspan class=\"reference brown\"\u003e[ يا راهب ]\u003c/span\u003e فأشرف .\u003cspan class=\"blue\"\u003e قال :\u003c/span\u003e فجعل عمر ينظر إليه ويبكي .\u003cspan class=\"blue\"\u003e فقيل له :\u003c/span\u003e يا أمير المؤمنين ، ما يبكيك من هذا ؟\u003cspan class=\"blue\"\u003e قال :\u003c/span\u003e ذكرت قول الله ، - عز وجل -\u003cspan class=\"blue\"\u003e في كتابه :\u003c/span\u003e \u003cspan class=\"arabic qpc-hafs\"\u003e( عاملة ناصبة تصلى نارا حامية )\u003c/span\u003e فذاك الذي أبكاني .\u003c/p\u003e\u003cp\u003eوقال البخاري : قال ابن عباس : \u003cspan class=\"arabic qpc-hafs\"\u003e( عاملة ناصبة )\u003c/span\u003e النصارى .\u003c/p\u003e\u003cp\u003eوعن عكرمة ،\u003cspan class=\"blue\"\u003e والسدي :\u003c/span\u003e \u003cspan class=\"arabic qpc-hafs\"\u003e( عاملة )\u003c/span\u003e في الدنيا بالمعاصي \u003cspan class=\"arabic qpc-hafs\"\u003e( ناصبة )\u003c/span\u003e في النار بالعذاب والأغلال .\u003c/p\u003e"
                         },
                   "4":  {
                             "verses":  {
                                            "88:4":  {
                                                         "id":  5971
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp\u003eقال ابن عباس والحسن وقتادة\u003cspan class=\"red\"\u003e\" تصلى نارا حامية\"\u003c/span\u003e أي حارة شديدة الحر.\u003c/p\u003e"
                         },
                   "5":  {
                             "verses":  {
                                            "88:5":  {
                                                         "id":  5972
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp\u003eأي قد انتهى حرها وغليانها قاله ابن عباس ومجاهد والحسن والسدي.\u003c/p\u003e"
                         },
                   "6":  {
                             "verses":  {
                                            "88:6":  {
                                                         "id":  5973
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp\u003eوقوله : \u003cspan class=\"arabic qpc-hafs\"\u003e( ليس لهم طعام إلا من ضريع )\u003c/span\u003e قال علي بن أبي طلحة ،\u003cspan class=\"blue\"\u003e عن ابن عباس :\u003c/span\u003e شجر من نار .\u003c/p\u003e\u003cp\u003eوقال سعيد بن جبير : هو الزقوم .\u003cspan class=\"blue\"\u003e وعنه :\u003c/span\u003e أنها الحجارة .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eوقال ابن عباس ، ومجاهد ، وعكرمة ، وأبو الجوزاء ،\u003cspan class=\"blue\"\u003e وقتادة :\u003c/span\u003e هو الشبرق .\u003cspan class=\"blue\"\u003e قال قتادة :\u003c/span\u003e قريش تسميه في الربيع الشبرق ، وفي الصيف الضريع .\u003cspan class=\"blue\"\u003e قال عكرمة :\u003c/span\u003e وهو شجرة ذات شوك لاطئة بالأرض .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eوقال البخاري : قال مجاهد : الضريع نبت يقال له : الشبرق ، يسميه أهل الحجاز الضريع إذا يبس ، وهو سم .\u003c/p\u003e\u003cp\u003eوقال معمر ،\u003cspan class=\"blue\"\u003e عن قتادة :\u003c/span\u003e \u003cspan class=\"arabic qpc-hafs\"\u003e( إلا من ضريع )\u003c/span\u003e هو الشبرق ، إذا يبس سمي الضريع .\u003c/p\u003e\u003cp\u003eوقال سعيد ،\u003cspan class=\"blue\"\u003e عن قتادة :\u003c/span\u003e \u003cspan class=\"arabic qpc-hafs\"\u003e( ليس لهم طعام إلا من ضريع )\u003c/span\u003e من شر الطعام وأبشعه وأخبثه .\u003c/p\u003e"
                         },
                   "7":  {
                             "verses":  {
                                            "88:7":  {
                                                         "id":  5974
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp\u003eيعني لا يحصل به مقصود ولا يندفع به محذور.\u003c/p\u003e"
                         },
                   "8":  {
                             "verses":  {
                                            "88:8":  {
                                                         "id":  5975
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eلما ذكر حال الأشقياء ثنى بذكر السعداء فقال \u003cspan class=\"red\"\u003e\"وجوه يومئذ\"\u003c/span\u003e أي يوم القيامة \u003cspan class=\"red\"\u003e\"ناعمة\"\u003c/span\u003e أي يعرف النعيم فيها وإنما حصل لها ذلك بسعيها.\u003c/p\u003e"
                         },
                   "9":  {
                             "verses":  {
                                            "88:9":  {
                                                         "id":  5976
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp\u003eوقال سفيان لسعيها راضية قد رضيت عملها.\u003c/p\u003e"
                         },
                   "10":  {
                              "verses":  {
                                             "88:10":  {
                                                           "id":  5977
                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp\u003eأي رفيعة بهية في الغرفات آمنون.\u003c/p\u003e"
                          },
                   "11":  {
                              "verses":  {
                                             "88:11":  {
                                                           "id":  5978
                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003e\u003cspan class=\"arabic qpc-hafs\"\u003e( لا تسمع فيها لاغية )\u003c/span\u003e أي : لا يسمع في الجنة التي هم فيها كلمة لغو .\u003cspan class=\"blue\"\u003e كما قال :\u003c/span\u003e \u003cspan class=\"arabic qpc-hafs\"\u003e( لا يسمعون فيها لغوا إلا سلاما )\u003c/span\u003e \u003cspan class=\"reference brown\"\u003e[ مريم : 62 ]\u003c/span\u003e وقال : \u003cspan class=\"arabic qpc-hafs\"\u003e( لا لغو فيها ولا تأثيم )\u003c/span\u003e \u003cspan class=\"reference brown\"\u003e[ الطور : 23 ]\u003c/span\u003e وقال : \u003cspan class=\"arabic qpc-hafs\"\u003e( لا يسمعون فيها لغوا ولا تأثيما إلا قيلا سلاما سلاما )\u003c/span\u003e \u003cspan class=\"reference brown\"\u003e[ الواقعة : 25 ، 26 ]\u003c/span\u003e\u003c/p\u003e"
                          },
                   "12":  {
                              "verses":  {
                                             "88:12":  {
                                                           "id":  5979
                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003e\u003cspan class=\"arabic qpc-hafs\"\u003e( فيها عين جارية )\u003c/span\u003e أي : سارحة . وهذه نكرة في سياق الإثبات ، وليس المراد بها عينا واحدة ، وإنما هذا جنس ،\u003cspan class=\"blue\"\u003e يعني :\u003c/span\u003e فيها عيون جاريات .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eوقال ابن أبي حاتم : قرئ على الربيع بن سليمان : حدثنا أسد بن موسى ، حدثنا ابن ثوبان ، عن عطاء بن قرة ، عن عبد الله بن ضمرة ،\u003cspan class=\"blue\"\u003e عن أبي هريرة قال :\u003c/span\u003e قال النبي - صلى الله عليه وسلم -\u003cspan class=\"blue\"\u003e :\u003c/span\u003e \u003cspan class=\"red\"\u003e\" أنهار الجنة تفجر من تحت تلال -\u003cspan class=\"blue\"\u003e أو :\u003c/span\u003e من تحت جبال - المسك \"\u003c/span\u003e .\u003c/p\u003e"
                          },
                   "13":  {
                              "verses":  {
                                             "88:13":  {
                                                           "id":  5980
                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eأي عالية ناعمة كثيرة الفرش مرتفعة السمك عليها الحور العين قالوا فإذا أراد ولي الله أن يجلس على تلك السرر العالية تواضعت له.\u003c/p\u003e"
                          },
                   "14":  {
                              "verses":  {
                                             "88:14":  {
                                                           "id":  5981
                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp\u003eيعني أواني الشرب معدة مرصدة لمن أرادها من أربابها.\u003c/p\u003e"
                          },
                   "15":  {
                              "verses":  {
                                             "88:15":  {
                                                           "id":  5982
                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eقال ابن عباس النمارق الوسائد وكذا قال عكرمة وقتادة والضحاك والسدى والثوري وغيرهم.\u003c/p\u003e"
                          },
