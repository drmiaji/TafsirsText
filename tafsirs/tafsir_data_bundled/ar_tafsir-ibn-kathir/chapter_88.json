                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp\u003eولهذا قال : \u003cspan class=\"arabic qpc-hafs\"\u003e( فيعذبه الله العذاب الأكبر )\u003c/span\u003e قال الإمام أحمد :\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eحدثنا قتيبة ، حدثنا ليث ، عن سعيد بن أبي هلال ، عن علي بن خالد أن أبا أمامة الباهلي مر على خالد بن يزيد بن معاوية ، فسأله عن ألين كلمة سمعها من رسول الله - صلى الله عليه وسلم -\u003cspan class=\"blue\"\u003e فقال :\u003c/span\u003e سمعت رسول الله - صلى الله عليه وسلم -\u003cspan class=\"blue\"\u003e يقول :\u003c/span\u003e \u003cspan class=\"red\"\u003e\" ألا كلكم يدخل الجنة ، إلا من شرد على الله شراد البعير على أهله \"\u003c/span\u003e .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eتفرد بإخراجه الإمام أحمد وعلي بن خالد هذا ذكره ابن أبي حاتم عن أبيه ،\u003cspan class=\"blue\"\u003e ولم يزد على ما هاهنا :\u003c/span\u003e \u003cspan class=\"red\"\u003e\" روى عن أبي أمامة ، وعنه سعيد بن أبي هلال \"\u003c/span\u003e .\u003c/p\u003e"
                          },
