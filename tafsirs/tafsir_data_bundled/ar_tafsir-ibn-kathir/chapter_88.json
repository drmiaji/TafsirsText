                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eيقول تعالى آمرا عباده بالنظر في مخلوقاته الدالة على قدرته وعظمته : \u003cspan class=\"arabic qpc-hafs\"\u003e( أفلا ينظرون إلى الإبل كيف خلقت )\u003c/span\u003e ؟ فإنها خلق عجيب ، وتركيبها غريب ، فإنها في غاية القوة والشدة ، وهي مع ذلك تلين للحمل الثقيل ، وتنقاد للقائد الضعيف ، وتؤكل ، وينتفع بوبرها ، ويشرب لبنها . ونبهوا بذلك لأن العرب غالب دوابهم كانت الإبل ،\u003cspan class=\"blue\"\u003e وكان شريح القاضي يقول :\u003c/span\u003e اخرجوا بنا حتى ننظر إلى الإبل كيف خلقت ،\u003c/p\u003e"
                          },
                   "18":  {
                              "verses":  {
                                             "88:18":  {
                                                           "id":  5985
                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eوإلى السماء كيف رفعت ؟\u003cspan class=\"blue\"\u003e أي :\u003c/span\u003e كيف رفعها الله ، - عز وجل - عن الأرض هذا الرفع العظيم ،\u003cspan class=\"blue\"\u003e كما قال تعالى :\u003c/span\u003e \u003cspan class=\"arabic qpc-hafs\"\u003e( أفلم ينظروا إلى السماء فوقهم كيف بنيناها وزيناها وما لها من فروج )\u003c/span\u003e \u003cspan class=\"reference brown\"\u003e[ ق : 6 ]\u003c/span\u003e\u003c/p\u003e"
                          },
                   "19":  {
                              "verses":  {
                                             "88:19":  {
