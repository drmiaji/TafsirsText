                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003e\u003cspan class=\"red\"\u003e\"ثم فسر ذلك بقوله \"\u003c/span\u003eيوم يكون الناس كالفراش المبثوث\u003cspan class=\"red\"\u003e\" أي في انتشارهم وتفرقهم وذهابهم ومجيئهم من حيرتهم مما هم فيه كأنهم فراش مبثوث كما قال تعالى في الآية الأخرى \"\u003c/span\u003eكأنهم جراد منتشر\".\u003c/p\u003e"
                         },
                   "5":  {
                             "verses":  {
                                            "101:5":  {
                                                          "id":  6162
                                                      }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eيعني قد صارت كأنها الصوف المنفوش الذي قد شرع في الذهاب والتمزق قال مجاهد وعكرمة وسعيد بن جبير والحسن وقتادة وعطاء الخراساني والضحاك والسدي \u003cspan class=\"red\"\u003e\" العهن \"\u003c/span\u003e الصوف ثم أخبر تعالى عما يئول آليه عمل العاملين وما يصيرون إليه من الكرامة والإهانة بحسب أعماله فقال.\u003c/p\u003e"
                         },
                   "6":  {
                             "verses":  {
                                            "101:6":  {
