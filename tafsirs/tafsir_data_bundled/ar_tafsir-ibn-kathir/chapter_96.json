                              "text":  "\u003cp\u003eأَرَأَيْتَ إِن كَذَّبَ وَتَوَلَّىٰ\u003c/p\u003e"
                          },
                   "14":  {
                              "verses":  {
                                             "96:14":  {
                                                           "id":  6120
                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eولهذا قال \u003cspan class=\"red\"\u003e\"ألم يعلم بأن الله يرى\"\u003c/span\u003e أي أما علم هذا الناهي لهذا المهتدي أن الله يراه ويسمع كلامه وسيجازيه على فعله أتم الجزاء.\u003c/p\u003e"
                          },
                   "15":  {
                              "verses":  {
                                             "96:15":  {
                                                           "id":  6121
                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eثم قال تعالى متوعدا ومتهددا \u003cspan class=\"red\"\u003e\"كلا لئن لم ينته\"\u003c/span\u003e أي لئن لم يرجع عما هو فيه من الشقاق والعناد \u003cspan class=\"red\"\u003e\"لنسفعا بالناصية\"\u003c/span\u003e أي لنسمنها سوادا يوم القيامة.\u003c/p\u003e"
                          },
                   "16":  {
                              "verses":  {
                                             "96:16":  {
                                                           "id":  6122
                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eثم قال \u003cspan class=\"red\"\u003e\"ناصية كاذبة خاطئة\"\u003c/span\u003e يعني ناصية أبي جهل كاذبة في مقالها خاطئة في أفعالها.\u003c/p\u003e"
                          },
                   "17":  {
                              "verses":  {
                                             "96:17":  {
                                                           "id":  6123
                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp\u003e\u003cspan class=\"red\"\u003e\"فليدع ناديه\"\u003c/span\u003e أي قومه وعشيرته أي ليدعهم يستنصر بهم.\u003c/p\u003e"
                          },
                   "18":  {
                              "verses":  {
