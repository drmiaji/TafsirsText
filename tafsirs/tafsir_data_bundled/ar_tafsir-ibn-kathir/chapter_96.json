                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eمن كرمه تعالى أن علم الإنسان ما لم يعلم ، فشرفه وكرمه بالعلم ، وهو القدر الذي امتاز به أبو البرية آدم على الملائكة والعلم تارة يكون في الأذهان ، وتارة يكون في اللسان ، وتارة يكون في الكتابة بالبنان ، ذهني ولفظي ورسمي ، والرسمي يستلزمهما من غير عكس ،\u003cspan class=\"blue\"\u003e فلهذا قال :\u003c/span\u003e \u003cspan class=\"arabic qpc-hafs\"\u003e( اقرأ وربك الأكرم الذي علم بالقلم علم الإنسان ما لم يعلم )\u003c/span\u003e وفي الأثر : قيدوا العلم بالكتابة .\u003cspan class=\"blue\"\u003e وفيه أيضا :\u003c/span\u003e \" من عمل بما علم رزقه الله علم ما لم يكن \u003cspan class=\"reference brown\"\u003e[ يعلم ]\u003c/span\u003e .\u003c/p\u003e"
                         },
                   "6":  {
                             "verses":  {
                                            "96:6":  {
                                                         "id":  6112
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp\u003eيخبر تعالى عن الإنسان أنه ذو فرح وأشر وبطر وطغيان.\u003c/p\u003e"
                         },
                   "7":  {
                             "verses":  {
                                            "96:7":  {
                                                         "id":  6113
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp\u003eإذا رأى نفسه قد استغنى وكثر ماله ثم تهدده وتوعده ووعظه.\u003c/p\u003e"
                         },
                   "8":  {
                             "verses":  {
                                            "96:8":  {
                                                         "id":  6114
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eخبر تعالى عن الإنسان أنه ذو فرح وأشر وبطر وطغيان ، إذا رأى نفسه قد استغنى وكثر ماله .\u003cspan class=\"blue\"\u003e ثم تهدده وتوعده ووعظه فقال :\u003c/span\u003e \u003cspan class=\"arabic qpc-hafs\"\u003e( إن إلى ربك الرجعى )\u003c/span\u003e أي : إلى الله المصير والمرجع ،\u003cspan class=\"blue\"\u003e وسيحاسبك على مالك :\u003c/span\u003e من أين جمعته ؟ وفيم صرفته ؟\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eقال ابن أبي حاتم : حدثنا زيد بن إسماعيل الصائغ ، حدثنا جعفر بن عون ، حدثنا أبو عميس ، عن عون ،\u003cspan class=\"blue\"\u003e قال :\u003c/span\u003e قال عبد الله : منهومان لا يشبعان ، صاحب العلم وصاحب الدنيا ، ولا يستويان فأما صاحب العلم فيزداد رضا الرحمن ، وأما صاحب الدنيا فيتمادى في الطغيان .\u003cspan class=\"blue\"\u003e قال ثم قرأ عبد الله :\u003c/span\u003e \u003cspan class=\"arabic qpc-hafs\"\u003e( إن الإنسان ليطغى أن رآه استغنى )\u003c/span\u003e وقال للآخر : \u003cspan class=\"arabic qpc-hafs\"\u003e( إنما يخشى الله من عباده العلماء )\u003c/span\u003e \u003cspan class=\"reference brown\"\u003e[ فاطر : 28 ]\u003c/span\u003e .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eوقد روي هذا مرفوعا إلى رسول الله صلى الله عليه وسلم : \u003cspan class=\"red\"\u003e\" منهومان لا يشبعان : طالب علم ، وطالب دنيا \"\u003c/span\u003e .\u003c/p\u003e"
                         },
                   "9":  {
