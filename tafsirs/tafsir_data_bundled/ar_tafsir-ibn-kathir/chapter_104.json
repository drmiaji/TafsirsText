                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp\u003eفسير سورة ويل لكل همزة لمزة وهي مكية .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eالهماز : بالقول ،\u003cspan class=\"blue\"\u003e واللماز :\u003c/span\u003e بالفعل .\u003cspan class=\"blue\"\u003e يعني :\u003c/span\u003e يزدري بالناس وينتقص بهم .\u003cspan class=\"blue\"\u003e وقد تقدم بيان ذلك في قوله :\u003c/span\u003e \u003cspan class=\"arabic qpc-hafs\"\u003e( هماز مشاء بنميم )\u003c/span\u003e \u003cspan class=\"reference brown\"\u003e[ القلم : 11 ]\u003c/span\u003e .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eقال ابن عباس : \u003cspan class=\"arabic qpc-hafs\"\u003e( همزة لمزة )\u003c/span\u003e طعان معياب .\u003cspan class=\"blue\"\u003e وقال الربيع بن أنس :\u003c/span\u003e الهمزة ، يهمزه في وجه ، واللمزة من خلفه .\u003cspan class=\"blue\"\u003e وقال قتادة :\u003c/span\u003e يهمزه ويلمزه بلسانه وعينه ، ويأكل لحوم الناس ، ويطعن عليهم .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eوقال مجاهد : الهمزة : باليد والعين ،\u003cspan class=\"blue\"\u003e واللمزة :\u003c/span\u003e باللسان . وهكذا قال ابن زيد . وقال مالك ،\u003cspan class=\"blue\"\u003e عن زيد بن أسلم :\u003c/span\u003e همزة : لحوم الناس .\u003c/p\u003e\u003cp\u003eثم قال بعضهم : المراد بذلك الأخنس بن شريق . وقيل غيره .\u003cspan class=\"blue\"\u003e وقال مجاهد :\u003c/span\u003e هي عامة .\u003c/p\u003e"
                         },
                   "2":  {
                             "verses":  {
                                            "104:2":  {
                                                          "id":  6181
                                                      }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eوقوله : \u003cspan class=\"arabic qpc-hafs\"\u003e( الذي جمع مالا وعدده )\u003c/span\u003e أي : جمعه بعضه على بعض ،\u003cspan class=\"blue\"\u003e وأحصى عدده كقوله :\u003c/span\u003e \u003cspan class=\"arabic qpc-hafs\"\u003e( وجمع فأوعى )\u003c/span\u003e \u003cspan class=\"reference brown\"\u003e[ المعارج : 18 ]\u003c/span\u003e قاله السدي وابن جرير .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eوقال محمد بن كعب في قوله : \u003cspan class=\"arabic qpc-hafs\"\u003e( جمع مالا وعدده )\u003c/span\u003e ألهاه ماله بالنهار ، هذا إلى هذا ، فإذا كان الليل ، نام كأنه جيفة .\u003c/p\u003e"
                         },
                   "3":  {
                             "verses":  {
                                            "104:3":  {
                                                          "id":  6182
                                                      }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eوقوله : \u003cspan class=\"arabic qpc-hafs\"\u003e( يحسب أن ماله أخلده )\u003c/span\u003e أي : يظن أن جمعه المال يخلده في هذه الدار ؟ \u003cspan class=\"arabic qpc-hafs\"\u003e( كلا )\u003c/span\u003e أي : ليس الأمر كما زعم ولا كما حسب\u003c/p\u003e"
                         },
                   "4":  {
                             "verses":  {
                                            "104:4":  {
                                                          "id":  6183
                                                      }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eأي ليلقين هذا الذي جمع مالا فعدده في الحطمة وهي اسم طبقة من أسماء النار لأنها تحطم من فيها.\u003c/p\u003e"
                         },
                   "5":  {
                             "verses":  {
                                            "104:5":  {
                                                          "id":  6184
                                                      }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eقال \u003cspan class=\"red\"\u003e\"وما أدراك ما الحطمة نار الله الموقدة التي تطلع على الأفئدة\"\u003c/span\u003e قال ثابت البناني تحرقهم إلى الأفئدة وهم أحياء ثم يقول لقد بلغ منهم العذاب ثم يبكي وقال محمد بن كعب تأكل كل شيء من جسده حتى إذا بلغت فؤاده حذو حلقه ترجع على جسده.\u003c/p\u003e"
                         },
                   "6":  {
                             "verses":  {
                                            "104:6":  {
                                                          "id":  6185
                                                      }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp\u003eتأكل كل شيء من جسده حتى إذا بلغت فؤاده حذو حلقه ترجع على جسده.\u003c/p\u003e"
                         },
                   "7":  {
                             "verses":  {
                                            "104:7":  {
                                                          "id":  6186
                                                      }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eقال \u003cspan class=\"red\"\u003e\"وما أدراك ما الحطمة نار الله الموقدة التي تطلع على الأفئدة\"\u003c/span\u003e قال ثابت البناني تحرقهم إلى الأفئدة وهم أحياء ثم يقول لقد بلغ منهم العذاب ثم يبكي وقال محمد بن كعب تأكل كل شيء من جسده حتى إذا بلغت فؤاده حذو حلقه ترجع على جسده.\u003c/p\u003e"
                         },
                   "8":  {
                             "verses":  {
                                            "104:8":  {
                                                          "id":  6187
                                                      }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp\u003eوقوله : \u003cspan class=\"arabic qpc-hafs\"\u003e( إنها عليهم مؤصدة )\u003c/span\u003e أي : مطبقة كما تقدم تفسيره في سورة البلد .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eوقال ابن مردويه : حدثنا عبد الله بن محمد ، حدثنا علي بن سراج ، حدثنا عثمان بن خرزاذ ، حدثنا شجاع بن أشرس ، حدثنا شريك ، عن عاصم ، عن أبي صالح عن أبي هريرة ،\u003cspan class=\"blue\"\u003e عن النبي صلى الله عليه وسلم :\u003c/span\u003e \u003cspan class=\"arabic qpc-hafs\"\u003e( إنها عليهم مؤصدة )\u003c/span\u003e قال : \u003cspan class=\"red\"\u003e\" مطبقة \"\u003c/span\u003e .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eوقد رواه أبو بكر بن أبي شيبة ، عن عبد الله بن أسيد ، عن إسماعيل بن خالد ، عن أبي صالح ، قوله ، ولم يرفعه .\u003c/p\u003e"
                         },
                   "9":  {
                             "verses":  {
                                            "104:9":  {
                                                          "id":  6188
                                                      }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003e\u003cspan class=\"arabic qpc-hafs\"\u003e( في عمد ممددة )\u003c/span\u003e قال عطية العوفي : عمد من حديد .\u003cspan class=\"blue\"\u003e وقال السدي :\u003c/span\u003e من نار . وقال شبيب بن بشر ،\u003cspan class=\"blue\"\u003e عن عكرمة عن ابن عباس :\u003c/span\u003e \u003cspan class=\"arabic qpc-hafs\"\u003e( في عمد ممددة )\u003c/span\u003e يعني : الأبواب هي الممدوة .\u003c/p\u003e\u003cp\u003eوقال قتادة في قراءة عبد الله بن مسعود : إنها عليهم مؤصدة بعمد ممدة .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eوقال العوفي ،\u003cspan class=\"blue\"\u003e عن ابن عباس :\u003c/span\u003e أدخلهم في عمد فمدت عليهم بعماد ، وفي أعناقهم السلاسل فسدت بها الأبواب .\u003c/p\u003e\u003cp\u003eوقال قتادة : كنا نحدث أنهم يعذبون بعمد في النار . واختاره ابن جرير .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eوقال أبو صالح : \u003cspan class=\"arabic qpc-hafs\"\u003e( في عمد ممددة )\u003c/span\u003e يعني القيود الطوال . آخر تفسير سورة \u003cspan class=\"red\"\u003e\" ويل لكل همزة لمزة \"\u003c/span\u003e\u003c/p\u003e"
                         }
               }
}
