                              "slug":  "ru-tafseer-al-saddi",
                              "translated_name":  {
                                                      "name":  "Al-Sa\u0027di",
                                                      "language_name":  "english"
                                                  },
                              "text":  "Он подстерегает ослушников, дает им небольшую отсрочку, а затем хватает их могучей хваткой."
                          },
                   "15":  {
                              "verses":  {
