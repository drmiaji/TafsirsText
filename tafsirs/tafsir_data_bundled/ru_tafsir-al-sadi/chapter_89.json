                   "4":  {
                             "verses":  {
                                            "89:4":  {
                                                         "id":  5997
                                                     }
                                        },
                             "resource_id":  170,
                             "resource_name":  "Russian Tafseer Al Saddi",
                             "language_id":  138,
                             "slug":  "ru-tafseer-al-saddi",
                             "translated_name":  {
                                                     "name":  "Al-Sa\u0027di",
                                                     "language_name":  "english"
                                                 },
                             "text":  "По милости и мудрости Всевышнего ночь окутывает землю мглой и мраком, а люди утихают, успокаиваются и отправляются отдыхать."
                         },
                   "5":  {
                             "verses":  {
                                            "89:5":  {
                                                         "id":  5998
                                                     },
                                            "89:6":  {
                                                         "id":  5999
                                                     }
                                        },
                             "resource_id":  170,
                             "resource_name":  "Russian Tafseer Al Saddi",
                             "language_id":  138,
                             "slug":  "ru-tafseer-al-saddi",
                             "translated_name":  {
                                                     "name":  "Al-Sa\u0027di",
                                                     "language_name":  "english"
                                                 },
                             "text":  "Поистине, даже части их достаточно для тех, чья душа не мертва и кто внемлет своему Господу."
                         },
                   "6":  {
                             "verses":  {
                                            "89:5":  {
                                                         "id":  5998
                                                     },
                                            "89:6":  {
                                                         "id":  5999
                                                     }
                                        },
