                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp\u003eتفسير سورة والتين والزيتون وهي مكية .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eقال مالك وشعبة ، عن عدي بن ثابت ،\u003cspan class=\"blue\"\u003e عن البراء بن عازب :\u003c/span\u003e كان النبي صلى الله عليه وسلم يقرأ في سفر في إحدى الركعتين بالتين والزيتون ، فما سمعت أحدا أحسن صوتا أو قراءة منه . أخرجه الجماعة في كتبهم .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eاختلف المفسرون هاهنا على أقوال كثيرة فقيل : المراد بالتين مسجد دمشق .\u003cspan class=\"blue\"\u003e وقيل :\u003c/span\u003e هي نفسها .\u003cspan class=\"blue\"\u003e وقيل :\u003c/span\u003e الجبل الذي عندها .\u003c/p\u003e\u003cp\u003eوقال القرطبي : هو مسجد أصحاب الكهف .\u003c/p\u003e\u003cp\u003eوروى العوفي ،\u003cspan class=\"blue\"\u003e عن ابن عباس :\u003c/span\u003e أنه مسجد نوح الذي على الجودي .\u003c/p\u003e\u003cp\u003eوقال مجاهد : هو تينكم هذا .\u003c/p\u003e\u003cp\u003e\u003cspan class=\"arabic qpc-hafs\"\u003e( والزيتون )\u003c/span\u003e قال كعب الأحبار وقتادة وابن زيد ،\u003cspan class=\"blue\"\u003e وغيرهم :\u003c/span\u003e هو مسجد بيت المقدس .\u003c/p\u003e\u003cp\u003eوقال مجاهد وعكرمة : هو هذا الزيتون الذي تعصرون .\u003c/p\u003e"
                         },
                   "2":  {
                             "verses":  {
                                            "95:2":  {
                                                         "id":  6100
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp\u003eقال كعب الأحبار وغير واحد هو الجبل الذي كلم الله عليه موسى عليه السلام.\u003c/p\u003e"
                         },
                   "3":  {
                             "verses":  {
                                            "95:3":  {
                                                         "id":  6101
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003e\u003cspan class=\"arabic qpc-hafs\"\u003e( وهذا البلد الأمين )\u003c/span\u003e يعني : مكة . قاله ابن عباس ومجاهد وعكرمة والحسن وإبراهيم النخعي وابن زيد وكعب الأحبار . ولا خلاف في ذلك .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eوقال بعض الأئمة : هذه محال ثلاثة ، بعث الله في كل واحد منها نبيا مرسلا من أولي العزم أصحاب الشرائع الكبار ،\u003cspan class=\"blue\"\u003e فالأول :\u003c/span\u003e محلة التين والزيتون ، وهي بيت المقدس التي بعث الله فيها عيسى ابن مريم .\u003cspan class=\"blue\"\u003e والثاني :\u003c/span\u003e طور سينين ، وهو طور سيناء الذي كلم الله عليه موسى بن عمران .\u003cspan class=\"blue\"\u003e والثالث :\u003c/span\u003e مكة وهو البلد الأمين الذي من دخله كان آمنا ، وهو الذي أرسل فيه محمدا صلى الله عليه وسلم .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eقالوا : وفي آخر التوراة ذكر هذه الأماكن الثلاثة : جاء الله من طور سيناء - يعني الذي كلم الله عليه موسى \u003cspan class=\"reference brown\"\u003e[ بن عمران ]\u003c/span\u003e - وأشرق من ساعير - يعني بيت المقدس الذي بعث الله منه عيسى - واستعلن من جبال فاران -\u003cspan class=\"blue\"\u003e يعني :\u003c/span\u003e جبال مكة التي أرسل الله منها محمدا - فذكرهم على الترتيب الوجودي بحسب ترتيبهم في الزمان ، ولهذا أقسم بالأشرف ، ثم الأشرف منه ، ثم بالأشرف منهما .\u003c/p\u003e"
                         },
                   "4":  {
                             "verses":  {
                                            "95:4":  {
                                                         "id":  6102
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eهذا هو المقسم عليه وهو أنه تعالى خلق الإنسان في أحسن صورة وشكل منتصب القامة سوى الأعضاء حسنها.\u003c/p\u003e"
                         },
                   "5":  {
                             "verses":  {
                                            "95:5":  {
                                                         "id":  6103
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003e\u003cspan class=\"arabic qpc-hafs\"\u003e( ثم رددناه أسفل سافلين )\u003c/span\u003e أي : إلى النار . قاله مجاهد وأبو العالية والحسن وابن زيد ، وغيرهم .\u003cspan class=\"blue\"\u003e ثم بعد هذا الحسن والنضارة مصيره إلى النار إن لم يطع الله ويتبع الرسل ; ولهذا قال :\u003c/span\u003e\u003c/p\u003e"
                         },
                   "6":  {
                             "verses":  {
                                            "95:6":  {
                                                         "id":  6104
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp\u003e\u003cspan class=\"red\"\u003e\"إلا الذين آمنوا وعملوا الصالحات\"\u003c/span\u003e\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eوقال بعضهم : \u003cspan class=\"arabic qpc-hafs\"\u003e( ثم رددناه أسفل سافلين )\u003c/span\u003e أي : إلى أرذل العمر . روي هذا عن ابن عباس وعكرمة -\u003cspan class=\"blue\"\u003e حتى قال عكرمة :\u003c/span\u003e من جمع القرآن لم يرد إلى أرذل العمر . واختار ذلك ابن جرير . ولو كان هذا هو المراد لما حسن استثناء المؤمنين من ذلك ; لأن الهرم قد يصيب بعضهم ، وإنما المراد ما ذكرناه ،\u003cspan class=\"blue\"\u003e كقوله :\u003c/span\u003e \u003cspan class=\"arabic qpc-hafs\"\u003e( والعصر إن الإنسان لفي خسر إلا الذين آمنوا وعملوا الصالحات )\u003c/span\u003e \u003cspan class=\"reference brown\"\u003e[ العصر : 1 - 3 ]\u003c/span\u003e .\u003c/p\u003e\u003cp\u003eوقوله : \u003cspan class=\"arabic qpc-hafs\"\u003e( فلهم أجر غير ممنون )\u003c/span\u003e أي : غير مقطوع ، كما تقدم .\u003c/p\u003e"
                         },
                   "7":  {
                             "verses":  {
                                            "95:7":  {
                                                         "id":  6105
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eثم قال : \u003cspan class=\"arabic qpc-hafs\"\u003e( فما يكذبك )\u003c/span\u003e يعني : يا ابن آدم \u003cspan class=\"arabic qpc-hafs\"\u003e( بعد بالدين )\u003c/span\u003e ؟\u003cspan class=\"blue\"\u003e أي :\u003c/span\u003e بالجزاء في المعاد ، وقد علمت البدأة ، وعرفت أن من قدر على البدأة ، فهو قادر على الرجعة بطريق الأولى ، فأي شيء يحملك على التكذيب بالمعاد وقد عرفت هذا ؟\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eقال ابن أبي حاتم : حدثنا أحمد بن سنان ، حدثنا عبد الرحمن ،\u003cspan class=\"blue\"\u003e عن سفيان عن منصور قال :\u003c/span\u003e قلت لمجاهد : \u003cspan class=\"arabic qpc-hafs\"\u003e( فما يكذبك بعد بالدين )\u003c/span\u003e عنى به النبي صلى الله عليه وسلم قال : معاذ الله! عنى به الإنسان . وهكذا قال عكرمة وغيره .\u003c/p\u003e"
                         },
                   "8":  {
                             "verses":  {
                                            "95:8":  {
                                                         "id":  6106
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eوقوله : \u003cspan class=\"arabic qpc-hafs\"\u003e( أليس الله بأحكم الحاكمين )\u003c/span\u003e أي : أما هو أحكم الحاكمين ، الذي لا يجور ولا يظلم أحدا ، ومن عدله أن يقيم القيامة فينصف المظلوم في الدنيا ممن ظلمه .\u003cspan class=\"blue\"\u003e وقد قدمنا في حديث أبي هريرة مرفوعا :\u003c/span\u003e \u003cspan class=\"red\"\u003e\" فإذا قرأ أحدكم \u003cspan class=\"arabic qpc-hafs\"\u003e( والتين والزيتون )\u003c/span\u003e فأتى على آخرها : \u003cspan class=\"arabic qpc-hafs\"\u003e( أليس الله بأحكم الحاكمين )\u003c/span\u003e فليقل : بلى ، وأنا على ذلك من الشاهدين \"\u003c/span\u003e .\u003c/p\u003e\u003cp\u003eآخر تفسير \u003cspan class=\"reference brown\"\u003e[ سورة ]\u003c/span\u003e \u003cspan class=\"red\"\u003e\" والتين والزيتون \"\u003c/span\u003e ولله الحمد .\u003c/p\u003e"
                         }
               }
}
