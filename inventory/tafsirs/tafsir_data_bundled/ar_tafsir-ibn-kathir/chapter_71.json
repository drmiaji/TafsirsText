    "chapter":  71,
    "verses":  {
                   "1":  {
                             "verses":  {
                                            "71:1":  {
                                                         "id":  5420
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp\u003eتفسير سورة نوح وهي مكية .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eيقول تعالى مخبرا عن نوح عليه السلام ، أنه أرسله إلى قومه آمرا له أن ينذرهم بأس الله قبل حلوله بهم ،\u003cspan class=\"blue\"\u003e فإن تابوا وأنابوا رفع عنهم ; ولهذا قال :\u003c/span\u003e \u003cspan class=\"arabic qpc-hafs\"\u003e( أن أنذر قومك من قبل أن يأتيهم عذاب أليم )\u003c/span\u003e\u003c/p\u003e"
                         },
                   "2":  {
                             "verses":  {
                                            "71:2":  {
                                                         "id":  5421
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp\u003eأي : بين النذارة ، ظاهر الأمر واضحه .\u003c/p\u003e"
                         },
                   "3":  {
                             "verses":  {
                                            "71:3":  {
                                                         "id":  5422
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003e\u003cspan class=\"arabic qpc-hafs\"\u003e( أن اعبدوا الله واتقوه )\u003c/span\u003e أي : اتركوا محارمه واجتنبوا مآثمه ) وأطيعون ) فيما آمركم به وأنهاكم عنه .\u003c/p\u003e"
                         },
                   "4":  {
                             "verses":  {
                                            "71:4":  {
                                                         "id":  5423
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003e\u003cspan class=\"arabic qpc-hafs\"\u003e( يغفر لكم من ذنوبكم )\u003c/span\u003e أي : إذا فعلتم ما أمرتكم به وصدقتم ما أرسلت به إليكم ، غفر الله لكم ذنوبكم .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eو \u003cspan class=\"red\"\u003e\" من \"\u003c/span\u003e هاهنا قيل : إنها زائدة . ولكن القول بزيادتها في الإثبات قليل .\u003cspan class=\"blue\"\u003e ومنه قول بعض العرب :\u003c/span\u003e \u003cspan class=\"red\"\u003e\" قد كان من مطر \"\u003c/span\u003e .\u003cspan class=\"blue\"\u003e وقيل :\u003c/span\u003e إنها بمعنى \u003cspan class=\"red\"\u003e\" عن \"\u003c/span\u003e ،\u003cspan class=\"blue\"\u003e تقديره :\u003c/span\u003e يصفح لكم عن ذنوبكم . واختاره ابن جرير ،\u003cspan class=\"blue\"\u003e وقيل :\u003c/span\u003e إنها للتبعيض ، أي يغفر لكم الذنوب العظام التي وعدكم على ارتكابكم إياها الانتقام .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003e\u003cspan class=\"arabic qpc-hafs\"\u003e( ويؤخركم إلى أجل مسمى )\u003c/span\u003e أي : يمد في أعماركم ويدرأ عنكم العذاب الذي إن لم تنزجروا عما نهاكم عنه ، أوقعه بكم .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eوقد يستدل بهذه الآية من يقول : إن الطاعة والبر وصلة الرحم ،\u003cspan class=\"blue\"\u003e يزاد بها في العمر حقيقة ; كما ورد به الحديث :\u003c/span\u003e \u003cspan class=\"red\"\u003e\" صلة الرحم تزيد في العمر \"\u003c/span\u003e .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eوقوله : \u003cspan class=\"arabic qpc-hafs\"\u003e( إن أجل الله إذا جاء لا يؤخر لو كنتم تعلمون )\u003c/span\u003e أي : بادروا بالطاعة قبل حلول النقمة ، فإنه إذا أمر \u003cspan class=\"reference brown\"\u003e[ الله ]\u003c/span\u003e تعالى بكون ذلك لا يرد ولا يمانع ، فإنه العظيم الذي قهر كل شيء ، العزيز الذي دانت لعزته جميع المخلوقات .\u003c/p\u003e"
                         },
                   "5":  {
                             "verses":  {
                                            "71:5":  {
                                                         "id":  5424
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eيخبر تعالى عن عبده ورسوله نوح عليه السلام ، أنه اشتكى إلى ربه ، عز وجل ، ما لقي من قومه ، وما صبر عليهم في تلك المدة الطويلة التي هي ألف سنة إلا خمسين عاما ، وما بين لقومه ووضح لهم ودعاهم إلى الرشد والسبيل الأقوم ،\u003cspan class=\"blue\"\u003e فقال :\u003c/span\u003e \u003cspan class=\"arabic qpc-hafs\"\u003e( رب إني دعوت قومي ليلا ونهارا )\u003c/span\u003e أي : لم أترك دعاءهم في ليل ولا نهار ، امتثالا لأمرك وابتغاء لطاعتك\u003c/p\u003e"
                         },
                   "6":  {
                             "verses":  {
                                            "71:6":  {
                                                         "id":  5425
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003e\u003cspan class=\"arabic qpc-hafs\"\u003e( فلم يزدهم دعائي إلا فرارا )\u003c/span\u003e أي : كلما دعوتهم ليقتربوا من الحق فروا منه وحادوا عنه\u003c/p\u003e"
                         },
                   "7":  {
                             "verses":  {
                                            "71:7":  {
                                                         "id":  5426
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003e\u003cspan class=\"arabic qpc-hafs\"\u003e( وإني كلما دعوتهم لتغفر لهم جعلوا أصابعهم في آذانهم واستغشوا ثيابهم )\u003c/span\u003e أي : سدوا آذانهم لئلا يسمعوا ما أدعوهم إليه .\u003cspan class=\"blue\"\u003e كما أخبر تعالى عن كفار قريش :\u003c/span\u003e \u003cspan class=\"arabic qpc-hafs\"\u003e( وقال الذين كفروا لا تسمعوا لهذا القرآن والغوا فيه لعلكم تغلبون )\u003c/span\u003e \u003cspan class=\"reference brown\"\u003e[ فصلت : 26 ]\u003c/span\u003e .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003e\u003cspan class=\"arabic qpc-hafs\"\u003e( واستغشوا ثيابهم )\u003c/span\u003e قال ابن جريج ،\u003cspan class=\"blue\"\u003e عن ابن عباس :\u003c/span\u003e تنكروا له لئلا يعرفهم .\u003cspan class=\"blue\"\u003e وقال سعيد بن جبير والسدي :\u003c/span\u003e غطوا رءوسهم لئلا يسمعوا ما يقول .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003e\u003cspan class=\"arabic qpc-hafs\"\u003e( وأصروا )\u003c/span\u003e أي : استمروا على ما هم فيه من الشرك والكفر العظيم الفظيع ، \u003cspan class=\"arabic qpc-hafs\"\u003e( واستكبروا استكبارا )\u003c/span\u003e أي : واستنكفوا عن اتباع الحق والانقياد له .\u003c/p\u003e"
                         },
                   "8":  {
                             "verses":  {
                                            "71:8":  {
                                                         "id":  5427
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp\u003e\u003cspan class=\"arabic qpc-hafs\"\u003e( ثم إني دعوتهم جهارا )\u003c/span\u003e أي : جهرة بين الناس .\u003c/p\u003e"
                         },
                   "9":  {
                             "verses":  {
                                            "71:9":  {
                                                         "id":  5428
                                                     }
                                        },
                             "resource_id":  14,
                             "resource_name":  "ابن كثير",
                             "language_id":  9,
                             "slug":  "ar-tafsir-ibn-kathir",
                             "translated_name":  {
                                                     "name":  "Tafsir Ibn Kathir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003e\u003cspan class=\"arabic qpc-hafs\"\u003e( ثم إني أعلنت لهم )\u003c/span\u003e أي : كلاما ظاهرا بصوت عال ، \u003cspan class=\"arabic qpc-hafs\"\u003e( وأسررت لهم إسرارا )\u003c/span\u003e أي : فيما بيني وبينهم ، عليهم الدعوة لتكون أنجع فيهم .\u003c/p\u003e"
                         },
                   "10":  {
                              "verses":  {
                                             "71:10":  {
                                                           "id":  5429
                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003e\u003cspan class=\"arabic qpc-hafs\"\u003e( فقلت استغفروا ربكم إنه كان غفارا )\u003c/span\u003e أي : ارجعوا إليه وارجعوا عما أنتم فيه وتوبوا إليه من قريب ، فإنه من تاب إليه تاب عليه ، ولو كانت ذنوبه مهما كانت في الكفر والشرك ؛\u003cspan class=\"blue\"\u003e ولهذا قال :\u003c/span\u003e \u003cspan class=\"arabic qpc-hafs\"\u003e( فقلت استغفروا ربكم إنه كان غفارا يرسل السماء عليكم مدرارا )\u003c/span\u003e أي : متواصلة الأمطار . ولهذا تستحب قراءة هذه السورة في صلاة الاستسقاء لأجل هذه الآية .\u003cspan class=\"blue\"\u003e وهكذا روي عن أمير المؤمنين عمر بن الخطاب :\u003c/span\u003e أنه صعد المنبر ليستسقي ، فلم يزد على الاستغفار ، وقرأ الآيات في الاستغفار . ومنها هذه الآية \u003cspan class=\"arabic qpc-hafs\"\u003e( فقلت استغفروا ربكم إنه كان غفارا)\u003c/span\u003e\u003c/p\u003e"
                          },
                   "11":  {
                              "verses":  {
                                             "71:11":  {
                                                           "id":  5430
                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp\u003eثم قال : لقد طلبت الغيث بمجاديح السماء التي ستنزل بها المطر .\u003c/p\u003e\u003cp\u003eوقال ابن عباس وغيره : يتبع بعضه بعضا .\u003c/p\u003e"
                          },
                   "12":  {
                              "verses":  {
                                             "71:12":  {
                                                           "id":  5431
                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eوقوله : \u003cspan class=\"arabic qpc-hafs\"\u003e( ويمددكم بأموال وبنين ويجعل لكم جنات ويجعل لكم أنهارا )\u003c/span\u003e أي : إذا تبتم إلى الله واستغفرتموه وأطعتموه ، كثر الرزق عليكم ، وأسقاكم من بركات السماء ، وأنبت لكم من بركات الأرض ، وأنبت لكم الزرع ، وأدر لكم الضرع ، وأمدكم بأموال وبنين ،\u003cspan class=\"blue\"\u003e أي :\u003c/span\u003e أعطاكم الأموال والأولاد ، وجعل لكم جنات فيها أنواع الثمار ، وخللها بالأنهار الجارية بينها .\u003c/p\u003e"
                          },
                   "13":  {
                              "verses":  {
                                             "71:13":  {
                                                           "id":  5432
                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eهذا مقام الدعوة بالترغيب ،\u003cspan class=\"blue\"\u003e ثم عدل بهم إلى دعوتهم بالترهيب فقال :\u003c/span\u003e \u003cspan class=\"arabic qpc-hafs\"\u003e( ما لكم لا ترجون لله وقارا )\u003c/span\u003e أي : عظمة ،\u003cspan class=\"blue\"\u003e قال ابن عباس ومجاهد والضحاك وقال ابن عباس :\u003c/span\u003e لا تعظمون الله حق عظمته ،\u003cspan class=\"blue\"\u003e أي :\u003c/span\u003e لا تخافون من بأسه ونقمته .\u003c/p\u003e"
                          },
                   "14":  {
                              "verses":  {
                                             "71:14":  {
                                                           "id":  5433
                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003e\u003cspan class=\"arabic qpc-hafs\"\u003e( وقد خلقكم أطوارا )\u003c/span\u003e قيل : معناه من نطفة ، ثم من علقة ، ثم من مضغة . قاله ابن عباس ، وعكرمة ، وقتادة ، ويحيى بن رافع ، والسدي ، وابن زيد .\u003c/p\u003e"
                          },
                   "15":  {
                              "verses":  {
                                             "71:15":  {
                                                           "id":  5434
                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eوقوله : \u003cspan class=\"arabic qpc-hafs\"\u003e( ألم تروا كيف خلق الله سبع سماوات طباقا )\u003c/span\u003e ؟\u003cspan class=\"blue\"\u003e أي :\u003c/span\u003e واحدة فوق واحدة ، وهل هذا يتلقى من جهة السمع فقط ؟ أو هي من الأمور المدركة بالحس ، مما علم من التسيير والكسوفات ، فإن الكواكب السبعة السيارة يكسف بعضها بعضا ، فأدناها القمر في السماء الدنيا وهو يكسف ما فوقه ، وعطارد في الثانية ، والزهرة في الثالثة ، والشمس في الرابعة ، والمريخ في الخامسة ، والمشتري في السادسة ، وزحل في السابعة . وأما بقية الكواكب - وهي الثوابت - ففي فلك ثامن يسمونه فلك الثوابت .\u003cspan class=\"blue\"\u003e والمتشرعون منهم يقولون :\u003c/span\u003e هو الكرسي ، والفلك التاسع ، وهو الأطلس ، والأثير عندهم الذي حركته على خلاف حركة سائر الأفلاك ، وذلك أن حركته مبدأ الحركات ، وهي من المغرب إلى المشرق ; وسائر الأفلاك عكسه من المشرق إلى المغرب ، ومعها يدور سائر الكواكب تبعا ، ولكن للسيارة حركة معاكسة لحركة أفلاكها ، فإنها تسير من المغرب إلى المشرق . وكل يقطع فلكه بحسبه ، فالقمر يقطع فلكه في كل شهر مرة ، والشمس في كل سنة مرة ، وزحل في كل ثلاثين سنة مرة ، وذلك بحسب اتساع أفلاكها وإن كانت حركة الجمع في السرعة متناسبة ، هذا ملخص ما يقولونه في هذا المقام ، على اختلاف بينهم في مواضع كثيرة ، لسنا بصدد بيانها ،\u003cspan class=\"blue\"\u003e وإنما المقصود أن الله سبحانه :\u003c/span\u003e \u003cspan class=\"arabic qpc-hafs\"\u003e( خلق الله سبع سماوات طباقا)\u003c/span\u003e\u003c/p\u003e"
                          },
