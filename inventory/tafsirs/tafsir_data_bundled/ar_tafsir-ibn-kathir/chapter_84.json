                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp\u003eأي فماذا يمنعهم من الإيمان بالله ورسوله واليوم.\u003c/p\u003e"
                          },
                   "21":  {
                              "verses":  {
                                             "84:21":  {
                                                           "id":  5905
                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eوما لهم إذا قرئت عليهم آيات الله وكلامه وهو هذا القرآن لا يسجدون إعظاما وإكراما واحتراما؟.\u003c/p\u003e"
                          },
                   "22":  {
