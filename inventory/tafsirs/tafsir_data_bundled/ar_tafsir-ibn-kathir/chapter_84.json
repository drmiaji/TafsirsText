                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp\u003eأي فأخبرهم يا محمد بأن الله عز وجل قد أعد لهم عذابا أليما.\u003c/p\u003e"
                          },
                   "25":  {
                              "verses":  {
                                             "84:25":  {
                                                           "id":  5909
                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eوقوله \u003cspan class=\"arabic qpc-hafs\"\u003e( إلا الذين آمنوا وعملوا الصالحات )\u003c/span\u003e هذا استثناء منقطع يعني لكن الذين آمنوا - أي بقلوبهم وعملوا الصالحات بجوارحهم \u003cspan class=\"arabic qpc-hafs\"\u003e( لهم أجر )\u003c/span\u003e أي في الدار الآخرة\u003c/p\u003e\u003cp\u003e\u003cspan class=\"arabic qpc-hafs\"\u003e( غير ممنون )\u003c/span\u003e قال ابن عباس غير منقوص وقال مجاهد والضحاك غير محسوب\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eوحاصل قولهما أنه غير مقطوع كما قال تعالى \u003cspan class=\"arabic qpc-hafs\"\u003e( عطاء غير مجذوذ )\u003c/span\u003e هود 108 وقال السدي قال بعضهم \u003cspan class=\"arabic qpc-hafs\"\u003e( غير ممنون )\u003c/span\u003e غير منقوص وقال بعضهم \u003cspan class=\"arabic qpc-hafs\"\u003e( غير ممنون )\u003c/span\u003e عليهم .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eوهذا القول الآخر عن بعضهم قد أنكره غير واحد فإن الله عز وجل له المنة على أهل الجنة في كل حال وآن ولحظة وإنما دخلوها بفضله ورحمته لا بأعمالهم فله عليهم المنة دائما سرمدا والحمد لله وحده أبدا ولهذا يلهمون تسبيحه وتحميده كما يلهمون النفس \u003cspan class=\"arabic qpc-hafs\"\u003e( وآخر دعواهم أن الحمد لله رب العالمين )\u003c/span\u003e يونس : 10\u003c/p\u003e\u003cp\u003eآخر تفسير سورة الانشقاق ولله الحمد\u003c/p\u003e"
                          }
               }
