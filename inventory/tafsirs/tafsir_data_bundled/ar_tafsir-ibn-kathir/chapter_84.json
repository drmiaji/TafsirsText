                          },
                   "13":  {
                              "verses":  {
                                             "84:13":  {
                                                           "id":  5897
                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eأي فرحا لا يفكر في العواقب ولا يخاف مما أمامه فأعقبه ذلك الفرح اليسير الحزن الطويل.\u003c/p\u003e"
                          },
                   "14":  {
                              "verses":  {
                                             "84:14":  {
                                                           "id":  5898
                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eأي كان يعتقد أنه لا يرجع إلى الله ولا يعيده بعد موته قاله ابن عباس وقتادة وغيرهما والحور هو الرجوع.\u003c/p\u003e"
                          },
                   "15":  {
                              "verses":  {
                                             "84:15":  {
                                                           "id":  5899
                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eيعني بلى سيعيده الله كما بدأه ويجازيه على أعماله خيرها وشرها فإنه \u003cspan class=\"arabic qpc-hafs\"\u003e(كان به بصيرا)\u003c/span\u003e أي عليما خبيرا.\u003c/p\u003e"
                          },
                   "16":  {
                              "verses":  {
                                             "84:16":  {
                                                           "id":  5900
                                                       }
                                         },
                              "resource_id":  14,
                              "resource_name":  "ابن كثير",
                              "language_id":  9,
                              "slug":  "ar-tafsir-ibn-kathir",
                              "translated_name":  {
                                                      "name":  "Tafsir Ibn Kathir",
                                                      "language_name":  "english"
                                                  },
                              "text":  "\u003cp lang=\"ar\" class=\"ar \"\u003eروي عن علي وابن عباس وعبادة بن الصامت وأبي هريرة وشداد بن أوس وابن عمر ومحمد بن علي بن الحسين ومكحول وبكر بن عبد الله المزني وبكير بن الأشج ومالك وابن أبي ذئب وعبد العزيز بن أبي سلمة الماجشون أنهم قالوا الشفق : الحمرة\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eوقال عبد الرزاق عن معمر عن ابن خثيم عن ابن لبيبة عن أبي هريرة قال الشفق : البياض .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eفالشفق هو حمرة الأفق إما قبل طلوع الشمس كما قاله مجاهد وإما بعد غروبها كما هو معروف عند أهل اللغة\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eقال الخليل بن أحمد الشفق الحمرة من غروب الشمس إلى وقت العشاء الآخرة فإذا ذهب قيل غاب الشفق\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eوقال الجوهري الشفق بقية ضوء الشمس وحمرتها في أول الليل إلى قريب من العتمة وكذا قال عكرمة الشفق الذي يكون بين المغرب والعشاء\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eوفي صحيح مسلم عن عبد الله بن عمرو عن رسول الله صلى الله عليه وسلم أنه قال وقت المغرب ما لم يغب الشفق .\u003c/p\u003e\u003cp lang=\"ar\" class=\"ar \"\u003eففي هذا كله دليل على أن الشفق هو كما قاله الجوهري والخليل ولكن صح عن مجاهد أنه قال في هذه الآية \u003cspan class=\"arabic qpc-hafs\"\u003e( فلا أقسم بالشفق )\u003c/span\u003e هو النهار كله وفي رواية عنه أيضا أنه قال الشفق الشمس . رواهما ابن أبي حاتم\u003c/p\u003e"
                          },
