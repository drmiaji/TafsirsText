                                            "76:3":  {
                                                         "id":  5594
                                                     }
                                        },
                             "resource_id":  804,
                             "resource_name":  "Rebar Kurdish Tafsir",
                             "language_id":  89,
                             "slug":  "kurd-tafsir-rebar",
                             "translated_name":  {
                                                     "name":  "Rebar Kurdish Tafsir",
                                                     "language_name":  "english"
                                                 },
                             "text":  "{مرۆڤ سه‌رپشكه‌}\n [ \u003cspan class=\"arabic uthmani\"\u003eإِنَّا هَدَيْنَاهُ السَّبِيلَ\u003c/span\u003e ] ئێمه‌ هه‌ردوو ڕێگای خێرو شه‌ڕمان بۆ مرۆڤ ڕوون كردۆته‌وه‌و پێی ناساندووه‌ [ \u003cspan class=\"arabic uthmani\"\u003eإِمَّا شَاكِرًا وَإِمَّا كَفُورًا (٣)\u003c/span\u003e ] ئیتر به‌ ویستی خۆی یان ئه‌وه‌تا شوكرانه‌بژێری خوای گه‌وره‌ ئه‌كات، یان ئه‌وه‌تا كوفرانه‌ی خوای گه‌وره‌ ئه‌كات و سه‌رپشكه‌و تواناى هه‌یه‌."
                         },
