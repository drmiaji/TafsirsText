{
    "chapter": 107,
    "verses": {
        "1": {
            "verses": {
                "107:1": {
                    "id": 1
                }
            },
            "resource_id": 144,
            "resource_name": "Tafsir Tr Mokhtasar",
            "language_id": 38,
            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Kıyamet gününde karşılıkların verileceğini inkâr edeni bildin mi?</p>"
        },
        "2": {
            "verses": {
                "107:2": {
                    "id": 2
                }
            },
            "resource_id": 144,
            "resource_name": "Tafsir Tr Mokhtasar",
            "language_id": 38,
            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>İhtiyacından ötürü yetime kaba davranarak kovan da işte odur.</p>"
        },
        "3": {
            "verses": {
                "107:3": {
                    "id": 3
                }
            },
            "resource_id": 144,
            "resource_name": "Tafsir Tr Mokhtasar",
            "language_id": 38,
            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Fakir kimseleri doyurmaya ne kendisini, ne de başkalarını teşvik eder.</p>"
        },
        "4": {
            "verses": {
                "107:4": {
                    "id": 4
                }
            },
            "resource_id": 144,
            "resource_name": "Tafsir Tr Mokhtasar",
            "language_id": 38,
            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>Namaz kılanlar için bir helâk ve azap vardır.</h2>"
        },
        "5": {
            "verses": {
                "107:5": {
                    "id": 5
                }
            },
            "resource_id": 144,
            "resource_name": "Tafsir Tr Mokhtasar",
            "language_id": 38,
            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Onlar, namazlarının vakti sona erinceye kadar namazlarında oyalanan ve umursamayanlardır.</p>"
        },
        "6": {
            "verses": {
                "107:6": {
                    "id": 6
                }
            },
            "resource_id": 144,
            "resource_name": "Tafsir Tr Mokhtasar",
            "language_id": 38,
            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Onlar, namazları ve amelleriyle gösteriş yaparlar. Amellerini sadece Allah’a halis kılmazlar.</p>"
        },
        "7": {
            "verses": {
                "107:7": {
                    "id": 7
                }
            },
            "resource_id": 144,
            "resource_name": "Tafsir Tr Mokhtasar",
            "language_id": 38,
            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Yardım etmenin hiçbir zararı olmadığı basit işlerde dahi başkalarına yardım etmekten geri dururlar.</p>"
        }
    }
}