            "text": "<p>-Ey Peygamber!- De ki: Sabahın Rabbine sığınırım ve O'nun himayesini isterim.</p>"
        },
        "2": {
            "verses": {
                "113:2": {
                    "id": 2
                }
            },
            "resource_id": 144,
            "resource_name": "Tafsir Tr Mokhtasar",
