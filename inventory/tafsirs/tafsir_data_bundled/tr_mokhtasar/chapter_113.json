            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>Mahlûkattan zarar veren şeylerin kötülüklerinden.</h2>"
        },
        "3": {
            "verses": {
                "113:3": {
                    "id": 3
                }
            },
            "resource_id": 144,
            "resource_name": "Tafsir Tr Mokhtasar",
            "language_id": 38,
            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Gece ortaya çıkan canlıların ve hırsızların kötülüklerinden Allah’a sığınırım.</p>"
        },
        "4": {
            "verses": {
                "113:4": {
                    "id": 4
                }
            },
            "resource_id": 144,
            "resource_name": "Tafsir Tr Mokhtasar",
            "language_id": 38,
            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Düğümlere üfleyen büyücü kadınların kötülüklerinden O'na sığınırım.</p>"
        },
        "5": {
            "verses": {
                "113:5": {
                    "id": 5
                }
            },
            "resource_id": 144,
            "resource_name": "Tafsir Tr Mokhtasar",
            "language_id": 38,
            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Hasedinin kendisini yapmaya sürüklediği ameli işlediğinde hasetçilerin şerrinden O'na sığınırım.</p>"
        }
    }
