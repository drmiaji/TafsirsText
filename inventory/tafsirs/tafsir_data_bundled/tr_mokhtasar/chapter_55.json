            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Onlar Cehennem ve yüksek derecede kaynar su arasında gidip gelirler.</p>"
        },
        "45": {
            "verses": {
                "55:45": {
                    "id": 45
                }
            },
            "resource_id": 144,
            "resource_name": "Tafsir Tr Mokhtasar",
