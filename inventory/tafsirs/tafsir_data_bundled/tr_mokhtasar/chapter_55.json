            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>O iki Cennet boyunca suyu akıp giden iki pınar vardır.</h2>"
