            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Bu iki Cennet'te taze meyve veren büyük dalları olan ağaçlar vardır.</p>"
        },
        "49": {
            "verses": {
                "55:49": {
                    "id": 49
                }
