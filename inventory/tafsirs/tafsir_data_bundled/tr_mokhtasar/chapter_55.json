            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Ahirette Rabbinin huzurunda durmaktan korktuğu için iman eden ve salih amel işleyen kimse için iki Cennet vardır.</p>"
        },
        "47": {
            "verses": {
