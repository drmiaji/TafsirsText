{
    "chapter": 101,
    "verses": {
        "1": {
            "verses": {
                "101:1": {
                    "id": 1
                }
            },
            "resource_id": 144,
            "resource_name": "Tafsir Tr Mokhtasar",
            "language_id": 38,
            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Dehşetinin büyüklüğüyle insanların kalplerini bürüyen o (kıyamet) vakit.</p>"
        },
        "2": {
            "verses": {
                "101:2": {
                    "id": 2
                }
            },
            "resource_id": 144,
            "resource_name": "Tafsir Tr Mokhtasar",
            "language_id": 38,
            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Dehşetinin büyüklüğüyle insanların kalplerini hoplatan bu saat nedir?</p>"
        },
        "3": {
            "verses": {
                "101:3": {
                    "id": 3
                }
            },
            "resource_id": 144,
            "resource_name": "Tafsir Tr Mokhtasar",
            "language_id": 38,
            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>-Ey Peygamber!- Dehşetinin büyüklüğüyle insanların kalplerini hoplatan o saatin ne olduğunu sana ne öğretti? Şüphesiz o kıyamet günüdür.</p>"
        },
        "4": {
            "verses": {
                "101:4": {
                    "id": 4
                }
            },
            "resource_id": 144,
            "resource_name": "Tafsir Tr Mokhtasar",
            "language_id": 38,
            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Dehşetin kalpleri bürüdüğü o gün, insanlar etrafa saçılan pervaneler gibi olurlar.</p>"
        },
        "5": {
            "verses": {
                "101:5": {
                    "id": 5
                }
            },
            "resource_id": 144,
            "resource_name": "Tafsir Tr Mokhtasar",
            "language_id": 38,
            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Dağlar hızlı bir şekilde yerinden oynamasında ve hareket etmesinde etrafa atılmış yün gibi olurlar.</p>"
        },
        "6": {
            "verses": {
                "101:6": {
                    "id": 6
                }
            },
            "resource_id": 144,
            "resource_name": "Tafsir Tr Mokhtasar",
            "language_id": 38,
            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>Artık kimin salih amelleri, kötü amellerine ağır basarsa.</h2>"
        },
        "7": {
            "verses": {
                "101:7": {
                    "id": 7
                }
            },
            "resource_id": 144,
            "resource_name": "Tafsir Tr Mokhtasar",
            "language_id": 38,
            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>O, Cennet'te elde edeceği ve hoşnut olacağı bir hayatın içinde olacaktır.</p>"
        },
        "8": {
            "verses": {
                "101:8": {
                    "id": 8
                }
            },
            "resource_id": 144,
            "resource_name": "Tafsir Tr Mokhtasar",
            "language_id": 38,
            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Fakat kimin de kötü amelleri, salih amellerine ağır basarsa.</p>"
        },
        "9": {
            "verses": {
                "101:9": {
                    "id": 9
                }
            },
            "resource_id": 144,
            "resource_name": "Tafsir Tr Mokhtasar",
            "language_id": 38,
            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>Onun, kıyamet günü meskeni ve varacağı yer Cehennem'dir.</h2>"
        },
        "10": {
            "verses": {
                "101:10": {
                    "id": 10
                }
            },
            "resource_id": 144,
            "resource_name": "Tafsir Tr Mokhtasar",
            "language_id": 38,
            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>-Ey Peygamber!- Onun ne olduğunu sana ne öğretti?</h2>"
        },
        "11": {
            "verses": {
                "101:11": {
                    "id": 11
                }
            },
            "resource_id": 144,
            "resource_name": "Tafsir Tr Mokhtasar",
            "language_id": 38,
            "slug": "tr_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tr Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>O, sıcaklığı çok şiddetli bir ateştir.</h2>"
        }
    }
}