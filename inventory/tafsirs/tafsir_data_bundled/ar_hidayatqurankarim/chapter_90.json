{
    "chapter": 90,
    "verses": {
        "1": {
            "verses": {
                "90:1": {
                    "id": 1
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>أقسم الله بمكَّةَ تعظيمًا لشأنها، وكيف لا يكون عظيمًا مكانٌ انبثقَ منه نورُ الإسلام، ورُفع فيه البيتُ الحرام، وخرج منه رسولُ السَّلام؟</p>\n<p>__________</p>"
        },
        "2": {
            "verses": {
                "90:2": {
                    "id": 2
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>أقسم الله بمكَّةَ تعظيمًا لشأنها، وكيف لا يكون عظيمًا مكانٌ انبثقَ منه نورُ الإسلام، ورُفع فيه البيتُ الحرام، وخرج منه رسولُ السَّلام؟</p>\n<p>__________</p>"
        },
        "3": {
            "verses": {
                "90:3": {
                    "id": 3
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>في ذكر الوالد والولد تنبيهٌ على أهميَّة بِرِّ الآباء بأولادهم بحُسن تنشئتهم على الدِّين القويم، وبِرِّ الأولاد بالآباء الذين هم سببُ وجودهم وبابُهم الذي يَلِجونَ منه إلى الجنَّة.</p>\n<p>__________</p>"
        },
        "4": {
            "verses": {
                "90:4": {
                    "id": 4
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>الدنيا دارُ ابتلاءٍ واختبار، وعلى المسلم أن يوطِّنَ نفسَه على الصبر على لَأْوائها، وتحمُّل مَصاعبها، قابضًا على دينه كما يُقبَض على الجمر.</p>\n<p>__________</p>"
        },
        "5": {
            "verses": {
                "90:5": {
                    "id": 5
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>جرأة العبد على المعاصي وإسرافُه في الآثام علامةٌ على غَفلته عن قدرة الله عليه، فمَن استحضر قدرةَ الجبَّار انزجرَ وانتهى.</p>\n<p>__________</p>"
        },
        "6": {
            "verses": {
                "90:6": {
                    "id": 6
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>إنفاق المال في الشَّهَوات والمعاصي إتلافٌ له وإهلاك؛ لأنه لا يرجع على صاحبه إلا بالنَّدامة والخسار.</p>\n<p>__________</p>"
        },
        "7": {
            "verses": {
                "90:7": {
                    "id": 7
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>كم من قلوبٍ تعافَت حين تدبَّرت هذه الآيةَ من ذنوب الخلَوات، وبرئت من آثار المُنكرات.</p>\n<p>__________</p>"
        },
        "8": {
            "verses": {
                "90:8": {
                    "id": 8
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>كلُّ طَرفة عينٍ تَطرِفُها، وكلُّ إطباق شفاهٍ تُطبقها، تذكِّرك أيها الإنسانُ بعظيم نِعَم الله عليك، ولا يجحَدُها إلا كَفورٌ كَنود.</p>\n<p>__________</p>"
        },
        "9": {
            "verses": {
                "90:9": {
                    "id": 9
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>كلُّ طَرفة عينٍ تَطرِفُها، وكلُّ إطباق شفاهٍ تُطبقها، تذكِّرك أيها الإنسانُ بعظيم نِعَم الله عليك، ولا يجحَدُها إلا كَفورٌ كَنود.</p>\n<p>__________</p>"
        },
        "10": {
            "verses": {
                "90:10": {
                    "id": 10
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>آتاك الله أيها الإنسانُ قدرةً فِطريَّة على تمييز الحقِّ من الباطل، وإنما تضعُف هذه القدرةُ وتتلاشى بمُكابرة الحقِّ وجَحد البراهين.</p>\n<p>__________</p>"
        },
        "11": {
            "verses": {
                "90:11": {
                    "id": 11
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>العقَبة الكؤودُ تتطلَّب همَّةً عالية لاقتحامها، فتسلَّح بالهمَّة وصدق الرَّغبة، وسماحة النفس وكرم اليد، لتبلغَ قمَّة الطاعة.</p>\n<p>__________</p>"
        },
        "12": {
            "verses": {
                "90:12": {
                    "id": 12
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>العقَبة الكؤودُ تتطلَّب همَّةً عالية لاقتحامها، فتسلَّح بالهمَّة وصدق الرَّغبة، وسماحة النفس وكرم اليد، لتبلغَ قمَّة الطاعة.</p>\n<p>__________</p>"
        },
        "13": {
            "verses": {
                "90:13": {
                    "id": 13
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>هذه الآية أصلٌ من أصول التشريع الإِسلاميِّ وهو تشوُّف الشارع إلى الحريَّة، وترغيبه في إعتاق الرِّقاب المملوكة.</p>\n<p>__________</p>"
        },
        "14": {
            "verses": {
                "90:14": {
                    "id": 14
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>على المِحَكِّ تظهر معادنُ الرجال، وفي زمن القَحط والجَدب يزداد الشحُّ والبُخل، فلا يجود بماله حينئذٍ إلا سخيٌّ كريمٌ يؤثر الآخرةَ على الدنيا.</p>\n<p>__________</p>"
        },
        "15": {
            "verses": {
                "90:15": {
                    "id": 15
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>لو أنَّ كلَّ مُقتدرٍ تكفَّل بأهل قَرابته من المحتاجين، لما اضطُرَّ يتيمٌ ولا فقيرٌ أن يُريقَ ماء وجهه في تكفُّف الأبعَدين.</p>\n<p>__________</p>"
        },
        "16": {
            "verses": {
                "90:16": {
                    "id": 16
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>لو أنَّ كلَّ مُقتدرٍ تكفَّل بأهل قَرابته من المحتاجين، لما اضطُرَّ يتيمٌ ولا فقيرٌ أن يُريقَ ماء وجهه في تكفُّف الأبعَدين.</p>\n<p>__________</p>"
        },
        "17": {
            "verses": {
                "90:17": {
                    "id": 17
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>مدارُ أمر الطَّاعات على أصلَين جليلَين؛ تعظيمِ أمر الله تعالى والتَّواصي بالصبر عليه، والشَّفقةِ على الضُّعفاء والتَّواصي برحمتهم.</p>\n<p>__________</p>"
        },
        "18": {
            "verses": {
                "90:18": {
                    "id": 18
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>الإحسان إلى خَلق الله بابٌ عظيم من أبواب الفلاح في الدنيا والآخرة، وبإحسانك إلى الخلق يزداد قربُك من السُّعداء أهل اليمين.</p>\n<p>__________</p>"
        },
        "19": {
            "verses": {
                "90:19": {
                    "id": 19
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>الشؤم وانقطاع البركة ليس فيما يتوهَّمه الإنسانُ من أسباب، ولكنَّه يحصل بالكفر والشِّرك والعصيان.</p>\n<p>__________</p>"
        },
        "20": {
            "verses": {
                "90:20": {
                    "id": 20
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>إذا كان الإنسانُ في شدَّة الحرِّ لا يُطيق البقاءَ في مكانٍ مغلقٍ بلا تكييف بضعَ دقائق، فكيف يتحمَّل نارًا شديدة الحرِّ، لا سبيلَ إلى الخروج منها؟</p>\n<p>__________</p>"
        }
    }
}