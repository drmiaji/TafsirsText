                "92:1": {
                    "id": 1
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>القسَم بالليل والنهار يَلفِتُ قلبَ المؤمن إلى انتظام آيات الله تعالى في كونه، فيزيدُه خضوعا، ولجَنابه خشوعا.</p>\n<p>__________</p>"
        },
        "2": {
            "verses": {
                "92:2": {
                    "id": 2
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>القسَم بالليل والنهار يَلفِتُ قلبَ المؤمن إلى انتظام آيات الله تعالى في كونه، فيزيدُه خضوعا، ولجَنابه خشوعا.</p>\n<p>__________</p>"
        },
        "3": {
            "verses": {
                "92:3": {
                    "id": 3
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>في خَلق الزَّوجين كثيرٌ من أدلَّة عظمة الله تعالى وظهور قدرته وحكمته، فبهما تتكامل الحياة، وتتوالد الأجناسُ وتبقى.</p>\n<p>__________</p>"
        },
        "4": {
            "verses": {
                "92:4": {
                    "id": 4
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>يتباين سعيُ الناس في حياتهِم، بحسَب مقاصدهم ونيَّاتهِم، فمَن عمل لله كما أمر فهو المأجورُ المقبول، ومَن خالف ذلك فلا قيمةَ لسعيه ولا قَبول لعمله.</p>\n<p>__________</p>"
        },
        "5": {
            "verses": {
                "92:5": {
                    "id": 5
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>تضمَّنت هذه الكلماتُ الثلاث مراتبَ الدِّين جميعًا، فالإعطاء فعلُ المأمور، والتقوى تركُ المحظور، والتصديق بالحسنى تصديقٌ ويقين، فانتظم ذلك كلَّ الدِّين.</p>\n<p>__________</p>"
        },
        "6": {
            "verses": {
                "92:6": {
                    "id": 6
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>تضمَّنت هذه الكلماتُ الثلاث مراتبَ الدِّين جميعًا، فالإعطاء فعلُ المأمور، والتقوى تركُ المحظور، والتصديق بالحسنى تصديقٌ ويقين، فانتظم ذلك كلَّ الدِّين.</p>\n<p>__________</p>"
        },
        "7": {
            "verses": {
                "92:7": {
                    "id": 7
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>وهل بعد هذا من مَطمَعٍ للعبد؛ أن يُيسَّر لأيسر السبُل الموصلة إلى رضا الله والفلاح في الدنيا والآخرة؟</p>\n<p>__________</p>"
        },
        "8": {
            "verses": {
                "92:8": {
                    "id": 8
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>البخل خَصلةٌ مذمومة أيًّا كانت صورتُه، وهو يحمل صاحبَه على الاستغناء عن جزاء الله تعالى تكبُّرًا وغرورًا.</p>\n<p>__________</p>\n<p>منع الموجود من سوء الظنِّ بالمعبود، فلمَّا كذَّب المكذِّبون بجزاء ربِّهم وبخلَفه عليهم أمسكوا عن البذل، وبخلوا بالعطاء.</p>\n<p>__________</p>"
        },
        "9": {
            "verses": {
                "92:9": {
                    "id": 9
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>البخل خَصلةٌ مذمومة أيًّا كانت صورتُه، وهو يحمل صاحبَه على الاستغناء عن جزاء الله تعالى تكبُّرًا وغرورًا.</p>\n<p>__________</p>\n<p>منع الموجود من سوء الظنِّ بالمعبود، فلمَّا كذَّب المكذِّبون بجزاء ربِّهم وبخلَفه عليهم أمسكوا عن البذل، وبخلوا بالعطاء.</p>\n<p>__________</p>"
        },
