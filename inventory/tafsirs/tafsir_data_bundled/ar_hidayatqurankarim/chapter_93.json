                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>هي تسليةٌ للنبيِّ ﷺ؛ أن الله هو مربِّيك، وهو كافلك وراعيك، ولن يدعَك أو يجفوَك، فأحسن الظنَّ دومًا بربِّك تجده عند ظنِّك.</p>\n<p>__________</p>"
        },
        "3": {
            "verses": {
                "93:3": {
                    "id": 3
                }
            },
            "resource_id": 105,
