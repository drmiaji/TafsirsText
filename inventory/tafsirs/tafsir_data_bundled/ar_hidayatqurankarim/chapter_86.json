        "9": {
            "verses": {
                "86:9": {
                    "id": 9
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>طيِّب نيَّتَك، وأصلح باطنَك، فإنَّ أمامك وقفةً بين يدَي الله يُحصَّل فيها ما في الصُّدور، ويُكشَف فيها عمَّا في القلوب.</p>\n<p>__________</p>"
        },
        "10": {
            "verses": {
                "86:10": {
                    "id": 10
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>يأتي العباد يوم القيامة وقد سُلبَت منهم كلُّ قوَّة وعَون، والسَّعيد مَن قدَّم لهذا اليوم بعملٍ صالح وإيمانٍ راسخ.</p>\n<p>__________</p>"
        },
        "11": {
            "verses": {
                "86:11": {
                    "id": 11
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>أقسم الله بالسَّماء لما ينزلُ منها من غَيثٍ ورحمة، وبالأرض لما ينبُت فيها من نباتٍ وبركة، أفلا نشكر الله على هذه النعم العظيمة والمِنن الكريمة؟!</p>\n<p>__________</p>"
        },
