        "8": {
            "verses": {
                "104:8": {
                    "id": 8
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>ألا تعتبِرُ أيها المسلمُ بهذا المشهَد المُفزع من مشاهد القيامة؛ يوم تُطبِق النارُ على المتجبِّرين وتغلَّق عليهم أبوابُها، لا مَنجى لهم منها ولا خلاص؟!</p>\n<p>__________</p>"
        },
