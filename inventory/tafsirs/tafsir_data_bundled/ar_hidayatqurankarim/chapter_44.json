        "47": {
            "verses": {
                "44:47": {
                    "id": 47
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>إنها صورة تقشعِرُّ من هولها الأبدان؛ صورة الجاحد المتجبِّر وهو يُدفع بعُنف دفعًا إلى وسط جهنَّم؛ ليذوقَ من أشدِّ عذابها، أجارنا الله منها.</p>\n<p>__________</p>"
        },
        "48": {
            "verses": {
                "44:48": {
                    "id": 48
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>استمرار العذاب أشدُّ على المرء وأنكى، فكيف إذا كان عذابُ الحميم من فوقه، ولظى الجحيم من تحته؟!</p>\n<p>__________</p>"
        },
        "49": {
            "verses": {
                "44:49": {
                    "id": 49
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>لعلَّ ما يَلقى المستبدُّ الأثيم من لذع السخريَّة والتهكُّم أشدُّ وأمضُّ ممَّا يلقاه من سياط العذاب!</p>\n<p>__________</p>"
        },
        "50": {
            "verses": {
                "44:50": {
                    "id": 50
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>ما أشدَّه من عذاب معنويٍّ يسمعه الكافرون وهم يصطلون في الحميم، حين يقال لهم: هذا العذاب الذي تذوقونه هو العذابُ الذي كنتم في الدنيا تكذِّبون به!</p>\n<p>__________</p>"
        },
        "51": {
            "verses": {
                "44:51": {
                    "id": 51
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>تمام طِيب العيش باجتماع أمرين؛ طِيب المكان وجماله، وتحقُّق الأمن والأمان فيه، وليس ذلك إلا للمتَّقين، جعلنا الله منهم.</p>\n<p>__________</p>\n<p>قُل للباحثين عن الأمن والأمان، والسَّكينة والسلام: إنكم لن تجدوها خالصةً من شوائب المنغِّصات إلا في الجنَّات، فأعدُّوا لها بالتقوى عُدَّة.</p>\n<p>__________</p>"
        },
        "52": {
            "verses": {
                "44:52": {
                    "id": 52
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>تمام طِيب العيش باجتماع أمرين؛ طِيب المكان وجماله، وتحقُّق الأمن والأمان فيه، وليس ذلك إلا للمتَّقين، جعلنا الله منهم.</p>\n<p>__________</p>\n<p>قُل للباحثين عن الأمن والأمان، والسَّكينة والسلام: إنكم لن تجدوها خالصةً من شوائب المنغِّصات إلا في الجنَّات، فأعدُّوا لها بالتقوى عُدَّة.</p>\n<p>__________</p>"
        },
        "53": {
            "verses": {
                "44:53": {
                    "id": 53
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>تقابلُ المؤمنين بالوجوه يزيد من الألفة والمحبَّة بينهم؛ ومن هنا كانت مجالسُ أهل الجنَّة على هذه الهيئة بعد تطهير صدورهم من كلِّ غِلٍّ.</p>\n<p>__________</p>"
        },
        "54": {
            "verses": {
                "44:54": {
                    "id": 54
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>كما يأنس أهل الجنَّة بصُحبة الأهل والخُلَّان، فإن تمام أُنسهم يكون برفقة الحور الحِسان، كأنهنَّ الياقوتُ والمَرجان.</p>\n<p>__________</p>"
        },
        "55": {
            "verses": {
                "44:55": {
                    "id": 55
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>نعيم الآخرة دونه كلُّ نعيم، فهو فضلٌ من الله، وحسبُك بأمن النقص أو الضُّرِّ من عطاء.</p>\n<p>__________</p>"
        },
        "56": {
            "verses": {
                "44:56": {
                    "id": 56
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>قال رسولُ الله ﷺ: «إذا دخل أهلُ الجنَّة الجنَّةَ وأهلُ النار النارَ، نادى منادٍ: يا أهلَ الجنَّة، خلودٌ ولا موتَ فيه، ويا أهلَ النار، خلودٌ ولا موتَ فيه».</p>\n<p>__________</p>"
        },
        "57": {
            "verses": {
                "44:57": {
                    "id": 57
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>حذار أن تتَّكلَ أيُّها العبدُ على عملك، فلن يُنجيَك إلا فضلُ الله عليك؛  ﴿قُل بفَضلِ اللهِ وبرَحمَتِه فبِذَلِكَ فليَفرَحُوا هو خَيرٌ ممَّا يَجمَعُون﴾ .</p>\n<p>__________</p>\n<p>كيف لا يكون الفوز بالجنان، والنجاة من مصير أهل الكفر والعصيان، فوزًا عظيمًا، وهو فوزٌ براحة الأبد.</p>\n<p>__________</p>"
        },
        "58": {
            "verses": {
                "44:58": {
                    "id": 58
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>ما أرسل الله من رسول إلا بلسان قومه؛ ليَعقِلوا عنه، وتقومَ عليهم الحُجَّة، وعلى الدعاة أن يُخاطبوا الناسَ بما يعقلون.</p>\n<p>__________</p>"
        },
        "59": {
            "verses": {
                "44:59": {
                    "id": 59
                }
            },
            "resource_id": 105,
            "resource_name": "Tafsir Ar Hidayatqurankarim",
            "language_id": 38,
            "slug": "ar_hidayatqurankarim",
            "translated_name": {
                "name": "Tafsir Ar Hidayatqurankarim",
                "language_name": "english"
            },
            "text": "<p>كلٌّ يرتقب ويتمنَّى، ولكن شتَّان بين ارتقاب المؤمنين المتحقِّق بالتمكين والانتصار، وارتقاب الكافرين المنتهي بالخيبة.</p>\n<p>__________</p>"
        }
    }
