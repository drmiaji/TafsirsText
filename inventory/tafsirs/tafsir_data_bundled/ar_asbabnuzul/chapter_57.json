        "10": {
            "verses": {
                "57:10": {
                    "id": 10
                }
            },
            "resource_id": 103,
            "resource_name": "Tafsir Ar Asbabnuzul",
            "language_id": 38,
            "slug": "ar_asbabnuzul",
