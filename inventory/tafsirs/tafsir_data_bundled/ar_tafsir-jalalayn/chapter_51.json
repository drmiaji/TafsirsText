      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ما أُرِيد مِنهُمْ مِن رِزْق﴾</span> لِي ولِأَنْفُسِهِمْ وغَيْرهمْ <span class=\"qpc-hafs\">﴿وما أُرِيد أنْ يُطْعِمُونِ﴾</span> ولا أنْفُسهمْ ولا غَيْرهمْ</p></div>",
      "verses": {
