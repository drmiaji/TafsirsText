    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إيلافهمْ﴾</span> تَأْكِيد وهُوَ مَصْدَر آلَف بِالمَدِّ <span class=\"qpc-hafs\">﴿رِحْلَة الشِّتاء﴾</span> إلى اليَمَن <span class=\"qpc-hafs\">﴿و﴾</span> رِحْلَة <span class=\"qpc-hafs\">﴿الصَّيْف﴾</span> إلى الشّام فِي كُلّ عام، يَسْتَعِينُونَ بِالرِّحْلَتَيْنِ لِلتِّجارَةِ عَلى المُقام بِمَكَّة لِخِدْمَةِ البَيْت الَّذِي هُوَ فَخْرهمْ، وهُمْ ولَد النَّضْر بْن كِنانَة</p></div>",
      "verses": {
        "106:2": {
          "id": 6195
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَلْيَعْبُدُوا﴾</span> تَعَلَّقَ بِهِ لِإيلافِ والفاء زائِدَة <span class=\"qpc-hafs\">﴿رَبّ هَذا البَيْت﴾</span></p></div>",
      "verses": {
        "106:3": {
          "id": 6196
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿الَّذِي أطْعَمَهُمْ مِن جُوع﴾</span> أيْ مِن أجْله <span class=\"qpc-hafs\">﴿وآمَنَهُمْ مِن خَوْف﴾</span> أيْ مِن أجْله وكانَ يُصِيبهُمْ الجُوع لِعَدَمِ الزَّرْع بِمَكَّة وخافُوا جَيْش الفِيل.</p></div>",
      "verses": {
        "106:4": {
          "id": 6197
        }
      }
    }
  }
}