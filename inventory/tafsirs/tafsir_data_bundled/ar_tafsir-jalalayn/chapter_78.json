{
  "chapter": 78,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿عَمّ﴾</span> عَنْ أيّ شَيْء <span class=\"qpc-hafs\">﴿يَتَساءَلُونَ﴾</span> يَسْأَل بَعْض قُرَيْش بَعْضًا</p></div>",
      "verses": {
        "78:1": {
          "id": 5673
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿عَنْ النَّبَإ العَظِيم﴾</span> بَيان لِذَلِكَ الشَّيْء والِاسْتِفْهام لِتَفْخِيمِهِ وهُوَ ما جاءَ بِهِ النَّبِيّ ﷺ مِن القُرْآن المُشْتَمِل عَلى البَعْث وغَيْره</p></div>",
      "verses": {
        "78:2": {
          "id": 5674
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿الَّذِي هُمْ فِيهِ مُخْتَلِفُونَ﴾</span> فالمُؤْمِنُونَ يُثْبِتُونَهُ والكافِرُونَ يُنْكِرُونَهُ</p></div>",
      "verses": {
        "78:3": {
          "id": 5675
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَلّا﴾</span> رَدْع <span class=\"qpc-hafs\">﴿سَيَعْلَمُونَ﴾</span> ما يَحِلّ بِهِمْ عَلى إنْكارهمْ لَهُ</p></div>",
      "verses": {
        "78:4": {
          "id": 5676
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ كَلّا سَيَعْلَمُونَ﴾</span> تَأْكِيد وجِيءَ فِيهِ بِثُمَّ لِلْإيذانِ بِأَنَّ الوَعِيد الثّانِي أشَدّ مِن الأَوَّل، ثُمَّ أوْمَأَ تَعالى إلى القُدْرَة عَلى البَعْث فَقالَ: \" ألَمْ نَجْعَل الأَرْض مِهادًا \"</p></div>",
      "verses": {
        "78:5": {
          "id": 5677
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ألَمْ نَجْعَل الأَرْض مِهادًا﴾</span> فِراشًا كالمَهْدِ</p></div>",
      "verses": {
        "78:6": {
          "id": 5678
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والجِبال أوْتادًا﴾</span> تَثْبُت بِها الأَرْض كَما تَثْبُت الخِيام بِالأَوْتادِ، والِاسْتِفْهام لِلتَّقْرِيرِ</p></div>",
      "verses": {
        "78:7": {
          "id": 5679
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وخَلَقْناكُمْ أزْواجًا﴾</span> ذُكُورًا وإناثًا</p></div>",
      "verses": {
        "78:8": {
          "id": 5680
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وجَعَلْنا نَوْمكُمْ سُباتًا﴾</span> راحَة لِأَبْدانِكُمْ</p></div>",
      "verses": {
        "78:9": {
          "id": 5681
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وجَعَلْنا اللَّيْل لِباسًا﴾</span> ساتِرًا بِسَوادِهِ</p></div>",
      "verses": {
        "78:10": {
          "id": 5682
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وجَعَلْنا النَّهار مَعاشًا﴾</span> وقْتًا لِلْمَعايِشِ</p></div>",
      "verses": {
        "78:11": {
          "id": 5683
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وبَنَيْنا فَوْقكُمْ سَبْعًا﴾</span> سَبْع سَماوات <span class=\"qpc-hafs\">﴿شِدادًا﴾</span> جَمْع شَدِيدَة، أيْ قَوِيَّة مُحْكَمَة لا يُؤَثِّر فِيها مُرُور الزَّمان</p></div>",
      "verses": {
        "78:12": {
          "id": 5684
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وجَعَلْنا سِراجًا﴾</span> مُنِيرًا <span class=\"qpc-hafs\">﴿وهّاجًا﴾</span> وقّادًا: يَعْنِي الشَّمْس</p></div>",
      "verses": {
        "78:13": {
          "id": 5685
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَنْزَلْنا مِن المُعْصِرات﴾</span> السَّحابات الَّتِي حانَ لَها أنْ تُمْطِر، كالمُعْصِرِ الجارِيَة الَّتِي دَنَتْ مِن الحَيْض <span class=\"qpc-hafs\">﴿ماء ثَجّاجًا﴾</span> صَبّابًا</p></div>",
      "verses": {
        "78:14": {
          "id": 5686
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لِنُخْرِج بِهِ حَبًّا﴾</span> كالحِنْطَةِ <span class=\"qpc-hafs\">﴿ونَباتًا﴾</span> كالتِّينِ</p></div>",
      "verses": {
        "78:15": {
          "id": 5687
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وجَنّات﴾</span> بَساتِين <span class=\"qpc-hafs\">﴿ألْفافًا﴾</span> مُلْتَفَّة، جَمْع لَفِيف كَشَرِيفِ وأَشْراف</p></div>",
      "verses": {
        "78:16": {
          "id": 5688
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّ يَوْم الفَصْل﴾</span> بَيْن الخَلائِق <span class=\"qpc-hafs\">﴿كانَ مِيقاتًا﴾</span> وقْتًا لِلثَّوابِ والعِقاب</p></div>",
      "verses": {
        "78:17": {
          "id": 5689
        }
      }
    },
    "18": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَوْم يُنْفَخ فِي الصُّور﴾</span> القَرْن بَدَل مِن يَوْم الفَصْل أوْ بَيان لَهُ والنّافِخ إسْرافِيل <span class=\"qpc-hafs\">﴿فَتَأْتُونَ﴾</span> مِن قُبُوركُمْ إلى المَوْقِف <span class=\"qpc-hafs\">﴿أفْواجًا﴾</span> جَماعات مُخْتَلِفَة</p></div>",
      "verses": {
        "78:18": {
          "id": 5690
        }
      }
    },
    "19": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وفُتِحَتْ السَّماء﴾</span> بِالتَّشْدِيدِ والتَّخْفِيف شُقِّقَتْ لِنُزُولِ المَلائِكَة <span class=\"qpc-hafs\">﴿فَكانَتْ أبْوابًا﴾</span> ذات أبْواب</p></div>",
      "verses": {
        "78:19": {
          "id": 5691
        }
      }
    },
    "20": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وسُيِّرَتْ الجِبال﴾</span> ذُهِبَ بِها عَنْ أماكِنها <span class=\"qpc-hafs\">﴿فَكانَتْ سَرابًا﴾</span> هَباء، أيْ مِثْله فِي خِفَّة سَيْرها</p></div>",
      "verses": {
        "78:20": {
          "id": 5692
        }
      }
    },
    "21": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّ جَهَنَّم كانَتْ مِرْصادًا﴾</span> راصِدَة أوْ مُرْصَدَة</p></div>",
      "verses": {
        "78:21": {
          "id": 5693
        }
      }
    },
    "22": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لِلطّاغِينَ﴾</span> الكافِرِينَ فَلا يَتَجاوَزُونَها <span class=\"qpc-hafs\">﴿مَآبًا﴾</span> مَرْجِعًا لَهُمْ فَيَدْخُلُونَها</p></div>",
      "verses": {
        "78:22": {
          "id": 5694
        }
      }
    },
    "23": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لابِثِينَ﴾</span> حال مُقَدَّرَة، أيْ مُقَدَّرًا لُبْثهمْ <span class=\"qpc-hafs\">﴿فِيها أحْقابًا﴾</span> دُهُورًا لا نِهايَة لَها جَمْع حُقْب بِضَمِّ أوَّله</p></div>",
      "verses": {
        "78:23": {
          "id": 5695
        }
      }
    },
    "24": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لا يَذُوقُونَ فِيها بَرْدًا﴾</span> نَوْمًا فَإنَّهُمْ لا يَذُوقُونَهُ <span class=\"qpc-hafs\">﴿ولا شَرابًا﴾</span> ما يُشْرَب تَلَذُّذًا</p></div>",
      "verses": {
        "78:24": {
          "id": 5696
        }
      }
    },
    "25": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إلّا﴾</span> لَكِنْ <span class=\"qpc-hafs\">﴿حَمِيمًا﴾</span> ماء حارًّا غايَة الحَرارَة <span class=\"qpc-hafs\">﴿وغَسّاقًا﴾</span> بِالتَّخْفِيفِ والتَّشْدِيد ما يَسِيل مِن صَدِيد أهْل النّار فَإنَّهُمْ يَذُوقُونَهُ جُوزُوا بِذَلِكَ</p></div>",
      "verses": {
        "78:25": {
          "id": 5697
        }
      }
    },
    "26": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿جَزاء وِفاقًا﴾</span> مُوافِقًا لِعَمَلِهِمْ فَلا ذَنْب أعْظَم مِن الكُفْر ولا عَذاب أعْظَم مِن النّار</p></div>",
      "verses": {
        "78:26": {
          "id": 5698
        }
      }
    },
    "27": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّهُمْ كانُوا لا يَرْجُونَ﴾</span> يَخافُونَ <span class=\"qpc-hafs\">﴿حِسابًا﴾</span> لِإنْكارِهِمْ البَعْث</p></div>",
      "verses": {
        "78:27": {
          "id": 5699
        }
      }
    },
    "28": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وكَذَّبُوا بِآياتِنا﴾</span> القُرْآن <span class=\"qpc-hafs\">﴿كِذّابًا﴾</span> تَكْذِيبًا</p></div>",
      "verses": {
        "78:28": {
          "id": 5700
        }
      }
    },
    "29": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وكُلّ شَيْء﴾</span> مِن الأَعْمال <span class=\"qpc-hafs\">﴿أحْصَيْناهُ﴾</span> ضَبَطْناهُ <span class=\"qpc-hafs\">﴿كِتابًا﴾</span> كَتْبًا فِي اللَّوْح المَحْفُوظ لِنُجازِيَ عَلَيْهِ ومِن ذَلِكَ تَكْذِيبهمْ بِالقُرْآنِ</p></div>",
      "verses": {
        "78:29": {
          "id": 5701
        }
      }
    },
    "30": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَذُوقُوا﴾</span> أيْ فَيُقال لَهُمْ فِي الآخِرَة عِنْد وُقُوع العَذاب ذُوقُوا جَزاءَكُمْ <span class=\"qpc-hafs\">﴿فَلَنْ نَزِيدكُمْ إلّا عَذابًا﴾</span> فَوْق عَذابكُمْ</p></div>",
      "verses": {
        "78:30": {
          "id": 5702
        }
      }
    },
    "31": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّ لِلْمُتَّقِينَ مَفازًا﴾</span> مَكان فَوْز فِي الجَنَّة</p></div>",
      "verses": {
        "78:31": {
          "id": 5703
        }
      }
    },
    "32": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿حَدائِق﴾</span> بَساتِين بَدَل مِن مَفازًا أوْ بَيان لَهُ <span class=\"qpc-hafs\">﴿وأَعْنابًا﴾</span> عَطْف عَلى مَفازًا</p></div>",
      "verses": {
        "78:32": {
          "id": 5704
        }
      }
    },
    "33": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وكَواعِب﴾</span> جَوارِي تَكَعَّبَتْ ثُدِيّهنَّ جَمْع كاعِب <span class=\"qpc-hafs\">﴿أتْرابًا﴾</span> عَلى سِنّ واحِد، جَمْع تِرْب بِكَسْرِ التّاء وسُكُون الرّاء</p></div>",
      "verses": {
        "78:33": {
          "id": 5705
        }
      }
    },
    "34": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وكَأْسًا دِهاقًا﴾</span> خَمْرًا مالِئَة مَحالّها، وفِي سُورَة القِتال: \" وأَنْهار مِن خَمْر \"</p></div>",
      "verses": {
        "78:34": {
          "id": 5706
        }
      }
    },
    "35": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لا يَسْمَعُونَ فِيها﴾</span> أيْ الجَنَّة عِنْد شُرْب الخَمْر وغَيْرها مِن الأَحْوال <span class=\"qpc-hafs\">﴿لَغْوًا﴾</span> باطِلًا مِن القَوْل <span class=\"qpc-hafs\">﴿ولا كِذّابًا﴾</span> بِالتَّخْفِيفِ، أيْ: كَذِبًا، وبِالتَّشْدِيدِ أيْ تَكْذِيبًا مِن واحِد لِغَيْرِهِ بِخِلافِ ما يَقَع فِي الدُّنْيا عِنْد شُرْب الخَمْر</p></div>",
      "verses": {
        "78:35": {
          "id": 5707
        }
      }
    },
    "36": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿جَزاء مِن رَبّك﴾</span> أيْ جَزاهُمْ اللَّه بِذَلِكَ جَزاء <span class=\"qpc-hafs\">﴿عَطاء﴾</span> بَدَل مِن جَزاء <span class=\"qpc-hafs\">﴿حِسابًا﴾</span> أيْ كَثِيرًا، مِن قَوْلهمْ: أعْطانِي فَأَحْسَبنِي، أيْ أكْثَر عَلَيَّ حَتّى قُلْت حَسْبِي</p></div>",
      "verses": {
        "78:36": {
          "id": 5708
        }
      }
    },
    "37": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿رَبّ السَّماوات والأَرْض﴾</span> بِالجَرِّ والرَّفْع <span class=\"qpc-hafs\">﴿وما بَيْنهما الرَّحْمَن﴾</span> كَذَلِكَ وبِرَفْعِهِ مَعَ جَرّ رَبّ <span class=\"qpc-hafs\">﴿لا يَمْلِكُونَ﴾</span> أيْ الخَلْق <span class=\"qpc-hafs\">﴿مِنهُ﴾</span> تَعالى <span class=\"qpc-hafs\">﴿خِطابًا﴾</span> أيْ لا يَقْدِر أحَد أنْ يُخاطِبهُ خَوْفًا مِنهُ</p></div>",
      "verses": {
        "78:37": {
          "id": 5709
        }
      }
    },
    "38": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَوْم﴾</span> ظَرْف ل \" لا يَمْلِكُونَ \" <span class=\"qpc-hafs\">﴿يَقُوم الرُّوح﴾</span> جِبْرِيل أوْ جُنْد اللَّه <span class=\"qpc-hafs\">﴿والمَلائِكَة صَفًّا﴾</span> حال، أيْ مُصْطَفِّينَ <span class=\"qpc-hafs\">﴿لا يَتَكَلَّمُونَ﴾</span> أيْ الخَلْق <span class=\"qpc-hafs\">﴿إلّا مَن أذِنَ لَهُ الرَّحْمَن﴾</span> فِي الكَلام <span class=\"qpc-hafs\">﴿وقالَ﴾</span> قَوْلًا <span class=\"qpc-hafs\">﴿صَوابًا﴾</span> مِن المُؤْمِنِينَ والمَلائِكَة كَأَنْ يَشْفَعُوا لِمَن اِرْتَضى</p></div>",
      "verses": {
        "78:38": {
          "id": 5710
        }
      }
    },
    "39": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ذَلِكَ اليَوْم الحَقّ﴾</span> الثّابِت وُقُوعه وهُوَ يَوْم القِيامَة <span class=\"qpc-hafs\">﴿فَمَن شاءَ اِتَّخَذَ إلى رَبّه مَآبًا﴾</span> مَرْجِعًا، أيْ رَجَعَ إلى اللَّه بِطاعَتِهِ لِيَسْلَم مِن العَذاب فِيهِ</p></div>",
      "verses": {
        "78:39": {
          "id": 5711
        }
      }
    },
    "40": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّا أنْذَرْناكُمْ﴾</span> يا كُفّار مَكَّة <span class=\"qpc-hafs\">﴿عَذابًا قَرِيبًا﴾</span> عَذاب يَوْم القِيامَة الآتِي، وكُلّ آتٍ قَرِيب <span class=\"qpc-hafs\">﴿يَوْم﴾</span> ظَرْف لَعِذابًا بِصِفَتِهِ <span class=\"qpc-hafs\">﴿يَنْظُر المَرْء﴾</span> كُلّ اِمْرِئٍ <span class=\"qpc-hafs\">﴿ما قَدَّمَتْ يَداهُ﴾</span> مِن خَيْر وشَرّ <span class=\"qpc-hafs\">﴿ويَقُول الكافِر يا﴾</span> حَرْف تَنْبِيه <span class=\"qpc-hafs\">﴿لَيْتَنِي كُنْت تُرابًا﴾</span> يَعْنِي فَلا أُعَذَّب يَقُول ذَلِكَ عِنْدَما يَقُول اللَّه تَعالى لِلْبَهائِمِ بَعْد الِاقْتِصاص مِن بَعْضها: كُونِي تُرابًا.</p></div>",
      "verses": {
        "78:40": {
          "id": 5712
        }
      }
    }
  }
}