{
  "chapter": 96,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿اِقْرَأْ﴾</span> أوْجِدْ القِراءَة مُبْتَدِئًا <span class=\"qpc-hafs\">﴿بِاسْمِ رَبّك الَّذِي خَلَقَ﴾</span> الخَلائِق</p></div>",
      "verses": {
        "96:1": {
          "id": 6107
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿خَلَقَ الإنْسان﴾</span> الجِنْس <span class=\"qpc-hafs\">﴿مِن عَلَق﴾</span> جَمْع عَلَقَة وهِيَ القِطْعَة اليَسِيرَة مِن الدَّم الغَلِيظ</p></div>",
      "verses": {
        "96:2": {
          "id": 6108
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿اِقْرَأْ﴾</span> تَأْكِيد لِلْأَوَّلِ <span class=\"qpc-hafs\">﴿ورَبّك الأَكْرَم﴾</span> الَّذِي لا يُوازِيه كَرِيم، حال مِن الضَّمِير فِي اِقْرَأْ</p></div>",
      "verses": {
        "96:3": {
          "id": 6109
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿الَّذِي عَلَّمَ﴾</span> الخَطّ <span class=\"qpc-hafs\">﴿بِالقَلَمِ﴾</span> وأَوَّل مَن خَطَّ بِهِ إدْرِيس عَلَيْهِ السَّلام</p></div>",
      "verses": {
        "96:4": {
          "id": 6110
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿عَلَّمَ الإنْسان﴾</span> الجِنْس <span class=\"qpc-hafs\">﴿ما لَمْ يَعْلَم﴾</span> قَبْل تَعْلِيمه مِن الهُدى والكِتابَة والصِّناعَة وغَيْرها</p></div>",
      "verses": {
        "96:5": {
          "id": 6111
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَلّا﴾</span> حَقًّا <span class=\"qpc-hafs\">﴿إنَّ الإنْسان لَيَطْغى﴾</span></p></div>",
      "verses": {
        "96:6": {
          "id": 6112
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أنْ رَآهُ﴾</span> أيْ نَفْسه <span class=\"qpc-hafs\">﴿اِسْتَغْنى﴾</span> بِالمالِ، نَزَلَ فِي أبِي جَهْل، ورَأى عِلْمِيَّة واسْتَغْنى مَفْعُول ثانٍ وأَنْ رَآهُ مَفْعُول لَهُ</p></div>",
      "verses": {
        "96:7": {
          "id": 6113
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّ إلى رَبّك﴾</span> يا إنْسان <span class=\"qpc-hafs\">﴿الرُّجْعى﴾</span> أيْ الرُّجُوع تَخْوِيف لَهُ فَيُجازِي الطّاغِي بِما يَسْتَحِقّهُ</p></div>",
      "verses": {
        "96:8": {
          "id": 6114
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أرَأَيْت﴾</span> فِي الثَّلاثَة مَواضِع لِلتَّعَجُّبِ <span class=\"qpc-hafs\">﴿الَّذِي يَنْهى﴾</span> هُوَ أبُو جَهْل</p></div>",
      "verses": {
        "96:9": {
          "id": 6115
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿عَبْدًا﴾</span> هُوَ النَّبِيّ ﷺ <span class=\"qpc-hafs\">﴿إذا صَلّى﴾</span></p></div>",
      "verses": {
        "96:10": {
          "id": 6116
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أرَأَيْت إنْ كانَ﴾</span> المَنهِيّ <span class=\"qpc-hafs\">﴿عَلى الهُدى﴾</span></p></div>",
      "verses": {
        "96:11": {
          "id": 6117
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أوْ﴾</span> لِلتَّقْسِيمِ <span class=\"qpc-hafs\">﴿أمَرَ بِالتَّقْوى﴾</span></p></div>",
      "verses": {
        "96:12": {
          "id": 6118
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أرَأَيْت إنْ كَذَّبَ﴾</span> أيْ النّاهِي النَّبِيّ <span class=\"qpc-hafs\">﴿وتَوَلّى﴾</span> عَنْ الإيمان</p></div>",
      "verses": {
        "96:13": {
          "id": 6119
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p>\" <span class=\"qpc-hafs\">﴿ألَمْ يَعْلَم بِأَنَّ اللَّه يَرى﴾</span> ما صَدَرَ مِنهُ، أيْ يَعْلَمهُ فَيُجازِيه عَلَيْهِ، أيْ اِعْجَبْ مِنهُ يا مُخاطَب مِن حَيْثُ نَهْيه عَنْ الصَّلاة ومِن حَيْثُ أنَّ المَنهِيّ عَلى الهُدى آمِر بِالتَّقْوى ومِن حَيْثُ أنَّ النّاهِي مُكَذِّب مُتَوَلٍّ عَنْ الإيمان</p></div>",
      "verses": {
        "96:14": {
          "id": 6120
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَلّا﴾</span> رَدْع لَهُ <span class=\"qpc-hafs\">﴿لَئِنْ﴾</span> لام قَسَم <span class=\"qpc-hafs\">﴿لَمْ يَنْتَهِ﴾</span> عَمّا هُوَ عَلَيْهِ مِن الكُفْر <span class=\"qpc-hafs\">﴿لَنَسْفَعًا بِالنّاصِيَةِ﴾</span> لَأَجُرَّنَّ بِناصِيَتِهِ إلى النّار</p></div>",
      "verses": {
        "96:15": {
          "id": 6121
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ناصِيَة﴾</span> بَدَل نَكِرَة مِن مَعْرِفَة <span class=\"qpc-hafs\">﴿كاذِبَة خاطِئَة﴾</span> وصَفَها بِذَلِكَ مَجاز والمُراد صاحِبها</p></div>",
      "verses": {
        "96:16": {
          "id": 6122
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَلْيَدْعُ نادِيهِ﴾</span> أيْ أهْل نادِيهِ وهُوَ المَجْلِس يُنْتَدى يَتَحَدَّث فِيهِ القَوْم وكانَ قالَ لِلنَّبِيِّ ﷺ لَمّا اِنْتَهَرَهُ حَيْثُ نَهاهُ عَنْ الصَّلاة: لَقَدْ عَلِمْت ما بِها رَجُل أكْثَر نادِيًا مِنِّي لَأَمْلَأَنَّ عَلَيْك هَذا الوادِي إنْ شِئْت خَيْلًا جُرْدًا ورِجالًا مُرْدًا</p></div>",
      "verses": {
        "96:17": {
          "id": 6123
        }
      }
    },
    "18": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿سَنَدَعُ الزَّبانِيَة﴾</span> المَلائِكَة الغِلاظ الشِّداد لِإهْلاكِهِ كَما فِي الحَدِيث \" لَوْ دَعا نادِيهِ لَأَخَذَتْهُ الزَّبانِيَة عِيانًا \"</p></div>",
      "verses": {
        "96:18": {
          "id": 6124
        }
      }
    },
    "19": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَلّا﴾</span> رَدْع لَهُ <span class=\"qpc-hafs\">﴿لا تُطِعْهُ﴾</span> يا مُحَمَّد فِي تَرْك الصَّلاة <span class=\"qpc-hafs\">﴿واسْجُدْ﴾</span> صَلِّ لِلَّهِ <span class=\"qpc-hafs\">﴿واقْتَرِبْ﴾</span> مِنهُ بِطاعَتِهِ.</p></div>",
      "verses": {
        "96:19": {
          "id": 6125
        }
      }
    }
  }
}