{
  "chapter": 90,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لا﴾</span> زائِدَة <span class=\"qpc-hafs\">﴿أُقْسِم بِهَذا البَلَد﴾</span> مَكَّة</p></div>",
      "verses": {
        "90:1": {
          "id": 6024
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَنْتَ﴾</span> يا مُحَمَّد <span class=\"qpc-hafs\">﴿حِلّ﴾</span> حَلال <span class=\"qpc-hafs\">﴿بِهَذا البَلَد﴾</span> بِأَنْ يَحِلّ لَك فَتُقاتِل فِيهِ، وقَدْ أنْجَزَ اللَّه لَهُ هَذا الوَعْد يَوْم الفَتْح، فالجُمْلَة اِعْتِراض بَيْن المُقْسَم بِهِ وما عُطِفَ عَلَيْهِ</p></div>",
      "verses": {
        "90:2": {
          "id": 6025
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ووالِد﴾</span> أيْ آدَم <span class=\"qpc-hafs\">﴿وما ولَدَ﴾</span> أيْ ذُرِّيَّته وما بِمَعْنى مِن</p></div>",
      "verses": {
        "90:3": {
          "id": 6026
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لَقَدْ خَلَقْنا الإنْسان﴾</span> أيْ الجِنْس <span class=\"qpc-hafs\">﴿فِي كَبَد﴾</span> نَصَب وشِدَّة يُكابِد مَصائِب الدُّنْيا وشَدائِد الآخِرَة</p></div>",
      "verses": {
        "90:4": {
          "id": 6027
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أيَحْسَبُ﴾</span> أيَظُنُّ الإنْسان قَوِيّ قُرَيْش وهُوَ أبُو الأَشَدّ بْن كِلْدَة بِقُوَّتِهِ <span class=\"qpc-hafs\">﴿أنْ﴾</span> مُخَفَّفَة مِن الثَّقِيلَة واسْمها مَحْذُوف، أيْ أنَّهُ <span class=\"qpc-hafs\">﴿لَنْ يَقْدِر عَلَيْهِ أحَد﴾</span> واللَّه قادِر عَلَيْهِ</p></div>",
      "verses": {
        "90:5": {
          "id": 6028
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَقُول أهْلَكْت﴾</span> عَلى عَداوَة مُحَمَّد <span class=\"qpc-hafs\">﴿مالًا لُبَدًا﴾</span> كَثِيرًا بَعْضه عَلى بَعْض</p></div>",
      "verses": {
        "90:6": {
          "id": 6029
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أيَحْسَبُ أنْ﴾</span> أيْ أنَّهُ <span class=\"qpc-hafs\">﴿لَمْ يَرَهُ أحَد﴾</span> فِيما أنْفَقَهُ فَيَعْلَم قَدْره، واللَّه عالِم بِقَدْرِهِ وأَنَّهُ لَيْسَ مِمّا يَتَكَثَّر بِهِ ومُجازِيه عَلى فِعْله السَّيِّئ</p></div>",
      "verses": {
        "90:7": {
          "id": 6030
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ألَمْ نَجْعَل﴾</span> اِسْتِفْهام تَقْرِير، أيْ جَعَلْنا \" لَهُ عَيْنَيْنِ \"</p></div>",
      "verses": {
        "90:8": {
          "id": 6031
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "90:9": {
          "id": 6032
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وهَدَيْناهُ النَّجْدَيْنِ﴾</span> بَيَّنّا لَهُ طَرِيق الخَيْر والشَّرّ</p></div>",
      "verses": {
        "90:10": {
          "id": 6033
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَلا﴾</span> فَهَلّا <span class=\"qpc-hafs\">﴿اِقْتَحَمَ العَقَبَة﴾</span> جاوَزَها</p></div>",
      "verses": {
        "90:11": {
          "id": 6034
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما أدْراك﴾</span> أعْلَمَك <span class=\"qpc-hafs\">﴿ما العَقَبَة﴾</span> الَّتِي يَقْتَحِمها تَعْظِيمًا لِشَأْنِها، والجُمْلَة اِعْتِراض وبَيَّنَ سَبَب جَوازها</p></div>",
      "verses": {
        "90:12": {
          "id": 6035
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَكّ رَقَبَة﴾</span> مِن الرِّقّ بِأَنْ أعْتَقَها</p></div>",
      "verses": {
        "90:13": {
          "id": 6036
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أوْ إطْعام فِي يَوْم ذِي مَسْغَبَة﴾</span> مَجاعَة</p></div>",
      "verses": {
        "90:14": {
          "id": 6037
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَتِيمًا ذا مَقْرَبَة﴾</span> قَرابَة</p></div>",
      "verses": {
        "90:15": {
          "id": 6038
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أوْ مِسْكِينًا ذا مَتْرَبَة﴾</span> لُصُوق بِالتُّرابِ لِفَقْرِهِ، وفِي قِراءَة بَدَل الفِعْلَيْنِ مَصْدَرانِ مَرْفُوعانِ مُضاف الأَوَّل لِرَقَبَةِ ويُنَوَّن الثّانِي فَيُقَدَّر قَبْل العَقَبَة اِقْتِحام، والقِراءَة المَذْكُورَة بَيانه</p></div>",
      "verses": {
        "90:16": {
          "id": 6039
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ كانَ﴾</span> عَطْف عَلى اِقْتَحَمَ وثُمَّ لِلتَّرْتِيبِ الذِّكْرِيّ، والمَعْنى كانَ وقْت الِاقْتِحام <span class=\"qpc-hafs\">﴿مِن الَّذِينَ آمَنُوا وتَواصَوْا﴾</span> أوْصى بَعْضهمْ بَعْضًا <span class=\"qpc-hafs\">﴿بِالصَّبْرِ﴾</span> عَلى الطّاعَة وعَنْ المَعْصِيَة <span class=\"qpc-hafs\">﴿وتَواصَوْا بِالمَرْحَمَةِ﴾</span> الرَّحْمَة عَلى الخَلْق</p></div>",
      "verses": {
        "90:17": {
          "id": 6040
        }
      }
    },
    "18": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أُولَئِكَ﴾</span> المَوْصُوفُونَ بِهَذِهِ الصِّفات <span class=\"qpc-hafs\">﴿أصْحاب المَيْمَنَة﴾</span> اليَمِين</p></div>",
      "verses": {
        "90:18": {
          "id": 6041
        }
      }
    },
    "19": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والَّذِينَ كَفَرُوا بِآياتِنا هُمْ أصْحاب المَشْأَمَة﴾</span> الشِّمال</p></div>",
      "verses": {
        "90:19": {
          "id": 6042
        }
      }
    },
    "20": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿عَلَيْهِمْ نار مُؤْصَدَة﴾</span> بِالهَمْزَةِ والواو بَدَله مُطْبَقَة.</p></div>",
      "verses": {
        "90:20": {
          "id": 6043
        }
      }
    }
  }
}