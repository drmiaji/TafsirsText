{
  "chapter": 80,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿عَبَسَ﴾</span> النَّبِيّ: كَلَحَ وجْهه <span class=\"qpc-hafs\">﴿وتَوَلّى﴾</span> أعْرَضَ لِأَجْلِ</p></div>",
      "verses": {
        "80:1": {
          "id": 5759
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أنْ جاءَهُ الأَعْمى﴾</span> عَبْد اللَّه بْن أُمّ مَكْتُوم فَقَطَعَهُ عَمّا هُوَ مَشْغُول بِهِ مِمَّنْ يَرْجُو إسْلامه مِن أشْراف قُرَيْش الَّذِينَ هُوَ حَرِيص عَلى إسْلامهمْ، ولَمْ يَدْرِ الأَعْمى أنَّهُ مَشْغُول بِذَلِكَ فَناداهُ: عَلِّمْنِي مِمّا عَلَّمَك اللَّه، فانْصَرَفَ النَّبِيّ ﷺ إلى بَيْته فَعُوتِبَ فِي ذَلِكَ بِما نَزَلَ فِي هَذِهِ السُّورَة، فَكانَ بَعْد ذَلِكَ يَقُول لَهُ إذا جاءَ: \" مَرْحَبًا بِمَن عاتَبَنِي فِيهِ رَبِّي \" ويَبْسُط لَهُ رِداءَهُ</p></div>",
      "verses": {
        "80:2": {
          "id": 5760
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما يُدْرِيك﴾</span> يُعْلِمك <span class=\"qpc-hafs\">﴿لَعَلَّهُ يَزَّكّى﴾</span> فِيهِ إدْغام التّاء فِي الأَصْل فِي الزّاي، أيْ يَتَطَهَّر مِن الذُّنُوب بِما يَسْمَع مِنك</p></div>",
      "verses": {
        "80:3": {
          "id": 5761
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أوْ يَذَّكَّر﴾</span> فِيهِ إدْغام التّاء فِي الأَصْل فِي الذّال أيْ يَتَّعِظ <span class=\"qpc-hafs\">﴿فَتَنْفَعهُ الذِّكْرى﴾</span> العِظَة المَسْمُوعَة مِنك وفِي قِراءَة بِنَصْبِ تَنْفَعهُ جَواب التَّرَجِّي</p></div>",
      "verses": {
        "80:4": {
          "id": 5762
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أمّا مَن اِسْتَغْنى﴾</span> بِالمالِ</p></div>",
      "verses": {
        "80:5": {
          "id": 5763
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَنْتَ لَهُ تَصَدّى﴾</span> وفِي قِراءَة بِتَشْدِيدِ الصّاد بِإدْغامِ التّاء الثّانِيَة فِي الأَصْل فِيها: تُقْبِل وتَتَعَرَّض</p></div>",
      "verses": {
        "80:6": {
          "id": 5764
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما عَلَيْك ألّا يَزَّكّى﴾</span> يُؤْمِن</p></div>",
      "verses": {
        "80:7": {
          "id": 5765
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَمّا مَن جاءَك يَسْعى﴾</span> حال مِن فاعِل جاءَ</p></div>",
      "verses": {
        "80:8": {
          "id": 5766
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وهُوَ يَخْشى﴾</span> اللَّه حال مِن فاعِل يَسْعى وهُوَ الأَعْمى</p></div>",
      "verses": {
        "80:9": {
          "id": 5767
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَنْتَ عَنْهُ تَلَهّى﴾</span> فِيهِ حَذْف التّاء الأُخْرى فِي الأَصْل أيْ تَتَشاغَل</p></div>",
      "verses": {
        "80:10": {
          "id": 5768
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَلّا﴾</span> لا تَفْعَل مِثْل ذَلِكَ <span class=\"qpc-hafs\">﴿إنَّها﴾</span> أيْ السُّورَة أوْ الآيات <span class=\"qpc-hafs\">﴿تَذْكِرَة﴾</span> عِظَة لِلْخَلْقِ</p></div>",
      "verses": {
        "80:11": {
          "id": 5769
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَمَن شاءَ ذَكَرَهُ﴾</span> حَفِظَ ذَلِكَ فاتَّعَظَ بِهِ</p></div>",
      "verses": {
        "80:12": {
          "id": 5770
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فِي صُحُف﴾</span> خَبَر ثانٍ لِأَنَّها وما قَبْله اِعْتِراض <span class=\"qpc-hafs\">﴿مُكَرَّمَة﴾</span> عِنْد اللَّه</p></div>",
      "verses": {
        "80:13": {
          "id": 5771
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿مَرْفُوعَة﴾</span> فِي السَّماء <span class=\"qpc-hafs\">﴿مُطَهَّرَة﴾</span> مُنَزَّهَة عَنْ مَسّ الشَّياطِين</p></div>",
      "verses": {
        "80:14": {
          "id": 5772
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿بِأَيْدِي سَفَرَة﴾</span> كَتَبَة يَنْسَخُونَها مِن اللَّوْح المَحْفُوظ</p></div>",
      "verses": {
        "80:15": {
          "id": 5773
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كِرام بَرَرَة﴾</span> مُطِيعِينَ لِلَّهِ تَعالى وهُمْ المَلائِكَة</p></div>",
      "verses": {
        "80:16": {
          "id": 5774
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قُتِلَ الإنْسان﴾</span> لُعِنَ الكافِر <span class=\"qpc-hafs\">﴿ما أكْفَرَهُ﴾</span> اِسْتِفْهام تَوْبِيخ، أيْ ما حَمَلَهُ عَلى الكُفْر</p></div>",
      "verses": {
        "80:17": {
          "id": 5775
        }
      }
    },
    "18": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿مِن أيّ شَيْء خَلَقَهُ﴾</span> اِسْتِفْهام تَقْرِير، ثُمَّ بَيَّنَهُ فَقالَ: \" مِن نُطْفَة خَلَقَهُ فَقَدَّرَهُ \"</p></div>",
      "verses": {
        "80:18": {
          "id": 5776
        }
      }
    },
    "19": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿مِن نُطْفَة خَلَقَهُ فَقَدَّرَهُ﴾</span> عَلَقَة ثُمَّ مُضْغَة إلى آخِر خَلْقه</p></div>",
      "verses": {
        "80:19": {
          "id": 5777
        }
      }
    },
    "20": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ السَّبِيل﴾</span> أيْ طَرِيق خُرُوجه مِن بَطْن أُمّه \" يَسَّرَهُ \"</p></div>",
      "verses": {
        "80:20": {
          "id": 5778
        }
      }
    },
    "21": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ أماتَهُ فَأَقْبَرَهُ﴾</span> جَعَلَهُ فِي قَبْر يَسْتُرهُ</p></div>",
      "verses": {
        "80:21": {
          "id": 5779
        }
      }
    },
    "22": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ إذا شاءَ أنْشَرَهُ﴾</span> لِلْبَعْثِ</p></div>",
      "verses": {
        "80:22": {
          "id": 5780
        }
      }
    },
    "23": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَلّا﴾</span> حَقًّا <span class=\"qpc-hafs\">﴿لَمّا يَقْضِ﴾</span> لَمْ يَفْعَل <span class=\"qpc-hafs\">﴿ما أمَرَهُ﴾</span> بِهِ رَبّه</p></div>",
      "verses": {
        "80:23": {
          "id": 5781
        }
      }
    },
    "24": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَلْيَنْظُرْ الإنْسان﴾</span> نَظَر اِعْتِبار <span class=\"qpc-hafs\">﴿إلى طَعامه﴾</span> كَيْف قُدِّرَ ودُبِّرَ لَهُ</p></div>",
      "verses": {
        "80:24": {
          "id": 5782
        }
      }
    },
    "25": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أنّا صَبَبْنا الماء﴾</span> مِن السَّحاب \" صَبًّا \"</p></div>",
      "verses": {
        "80:25": {
          "id": 5783
        }
      }
    },
    "26": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ شَقَقْنا الأَرْض﴾</span> بِالنَّباتِ \" شَقًّا \"</p></div>",
      "verses": {
        "80:26": {
          "id": 5784
        }
      }
    },
    "27": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَنْبَتْنا فِيها حَبًّا﴾</span> كالحِنْطَةِ والشَّعِير</p></div>",
      "verses": {
        "80:27": {
          "id": 5785
        }
      }
    },
    "28": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وعِنَبًا وقَضْبًا﴾</span> هُوَ القَتّ الرَّطْب \" وزَيْتُونًا ونَخْلًا \"</p></div>",
      "verses": {
        "80:28": {
          "id": 5786
        }
      }
    },
    "29": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "80:29": {
          "id": 5787
        }
      }
    },
    "30": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وحَدائِق غُلْبًا﴾</span> بَساتِين كَثِيرَة الأَشْجار</p></div>",
      "verses": {
        "80:30": {
          "id": 5788
        }
      }
    },
    "31": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وفاكِهَة وأَبًّا﴾</span> ما تَرْعاهُ البَهائِم وقِيلَ التِّبْن</p></div>",
      "verses": {
        "80:31": {
          "id": 5789
        }
      }
    },
    "32": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿مَتاعًا﴾</span> مُتْعَة أوْ تَمْتِيعًا كَما تَقَدَّمَ فِي السُّورَة قَبْلها \" لَكُمْ ولِأَنْعامِكُمْ \" تَقَدَّمَ فِيها أيْضًا</p></div>",
      "verses": {
        "80:32": {
          "id": 5790
        }
      }
    },
    "33": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَإذا جاءَتْ الصّاخَّة﴾</span> النَّفْخَة الثّانِيَة</p></div>",
      "verses": {
        "80:33": {
          "id": 5791
        }
      }
    },
    "34": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "80:34": {
          "id": 5792
        }
      }
    },
    "35": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "80:34",
      "verses": {
        "80:35": {
          "id": 5793
        }
      }
    },
    "36": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وصاحِبَته﴾</span> زَوْجَته <span class=\"qpc-hafs\">﴿وبَنِيهِ﴾</span> يَوْم بَدَل مِن إذا، وجَوابها دَلَّ عَلَيْهِ</p></div>",
      "verses": {
        "80:36": {
          "id": 5794
        }
      }
    },
    "37": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لِكُلِّ اِمْرِئٍ مِنهُمْ يَوْمئِذٍ شَأْن يُغْنِيه﴾</span> حال يَشْغَلهُ عَنْ شَأْن غَيْره، أيْ اِشْتَغَلَ كُلّ واحِد بِنَفْسِهِ</p></div>",
      "verses": {
        "80:37": {
          "id": 5795
        }
      }
    },
    "38": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
