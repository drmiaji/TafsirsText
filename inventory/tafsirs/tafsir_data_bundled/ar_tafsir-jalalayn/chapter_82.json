{
  "chapter": 82,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إذا السَّماء اِنْفَطَرَتْ﴾</span> اِنْشَقَّتْ</p></div>",
      "verses": {
        "82:1": {
          "id": 5830
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإذا الكَواكِب اِنْتَثَرَتْ﴾</span> اِنْقَضَّتْ وتَساقَطَتْ</p></div>",
      "verses": {
        "82:2": {
          "id": 5831
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإذا البِحار فُجِّرَتْ﴾</span> فُتِحَ بَعْضها فِي بَعْض فَصارَتْ بَحْرًا واحِدًا واخْتَلَطَ العَذْب بِالمِلْحِ</p></div>",
      "verses": {
        "82:3": {
          "id": 5832
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإذا القُبُور بُعْثِرَتْ﴾</span> قُلِبَ تُرابها وبُعِثَ مَوْتاها وجَواب إذا وما عُطِفَ عَلَيْها</p></div>",
      "verses": {
        "82:4": {
          "id": 5833
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿عَلِمَتْ نَفْس﴾</span> أيْ كُلّ نَفْس وقْت هَذِهِ المَذْكُورات وهُوَ يَوْم القِيامَة <span class=\"qpc-hafs\">﴿ما قَدَّمَتْ﴾</span> مِن الأَعْمال <span class=\"qpc-hafs\">﴿و﴾</span> ما <span class=\"qpc-hafs\">﴿أخَّرَتْ﴾</span> مِنها فَلَمْ تَعْمَلهُ</p></div>",
      "verses": {
        "82:5": {
          "id": 5834
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يا أيّها الإنْسان﴾</span> الكافِر <span class=\"qpc-hafs\">﴿ما غَرَّك بِرَبِّك الكَرِيم﴾</span> حَتّى عَصَيْته</p></div>",
      "verses": {
        "82:6": {
          "id": 5835
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿الَّذِي خَلَقَك﴾</span> بَعْد أنْ لَمْ تَكُنْ <span class=\"qpc-hafs\">﴿فَسَوّاك﴾</span> جَعَلَك مُسْتَوِي الخِلْقَة، سالِم الأَعْضاء <span class=\"qpc-hafs\">﴿فَعَدَلَك﴾</span> بِالتَّخْفِيفِ والتَّشْدِيد: جَعَلَك مُعْتَدِل الخَلْق مُتَناسِب الأَعْضاء لَيْسَتْ يَد أوْ رِجْل أطْوَل مِن الأُخْرى</p></div>",
      "verses": {
        "82:7": {
          "id": 5836
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فِي أيّ صُورَة ما﴾</span> صِلَة \" شاءَ رَكَّبَك \"</p></div>",
      "verses": {
        "82:8": {
          "id": 5837
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَلّا﴾</span> رَدْع عَنْ الِاغْتِرار بِكَرَمِ اللَّه تَعالى <span class=\"qpc-hafs\">﴿بَلْ تُكَذِّبُونَ﴾</span> أيْ كُفّار مَكَّة <span class=\"qpc-hafs\">﴿بِالدِّينِ﴾</span> بِالجَزاءِ عَلى الأَعْمال</p></div>",
      "verses": {
        "82:9": {
          "id": 5838
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإنَّ عَلَيْكُمْ لَحافِظِينَ﴾</span> مِن المَلائِكَة لِأَعْمالِكُمْ</p></div>",
      "verses": {
        "82:10": {
          "id": 5839
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كِرامًا﴾</span> عَلى اللَّه <span class=\"qpc-hafs\">﴿كاتِبِينَ﴾</span> لَها</p></div>",
      "verses": {
        "82:11": {
          "id": 5840
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَعْلَمُونَ ما تَفْعَلُونَ﴾</span> جَمِيعه</p></div>",
      "verses": {
        "82:12": {
          "id": 5841
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّ الأَبْرار﴾</span> المُؤْمِنِينَ الصّادِقِينَ فِي إيمانهمْ <span class=\"qpc-hafs\">﴿لَفِي نَعِيم﴾</span> جَنَّة</p></div>",
      "verses": {
        "82:13": {
          "id": 5842
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإنَّ الفُجّار﴾</span> الكُفّار <span class=\"qpc-hafs\">﴿لَفِي جَحِيم﴾</span> نار مُحْرِقَة</p></div>",
      "verses": {
        "82:14": {
          "id": 5843
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَصْلَوْنَها﴾</span> يَدْخُلُونَها ويُقاسُونَ حَرّها <span class=\"qpc-hafs\">﴿يَوْم الدِّين﴾</span> الجَزاء</p></div>",
      "verses": {
        "82:15": {
          "id": 5844
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما هُمْ عَنْها بِغائِبِينَ﴾</span> بِمُخْرَجِينَ</p></div>",
      "verses": {
        "82:16": {
          "id": 5845
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما أدْراك﴾</span> أعْلَمَك \" ما يَوْم الدِّين \"</p></div>",
      "verses": {
        "82:17": {
          "id": 5846
        }
      }
    },
    "18": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ ما أدْراك ما يَوْم الدِّين﴾</span> تَعْظِيم لِشَأْنِهِ</p></div>",
      "verses": {
        "82:18": {
          "id": 5847
        }
      }
    },
    "19": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَوْم﴾</span> بِالرَّفْعِ، أيْ هُوَ يَوْم <span class=\"qpc-hafs\">﴿لا تَمْلِك نَفْس لِنَفْسٍ شَيْئًا﴾</span> مِن المَنفَعَة <span class=\"qpc-hafs\">﴿والأَمْر يَوْمئِذٍ لِلَّهِ﴾</span> لا أمْر لِغَيْرِهِ فِيهِ أيْ لَمْ يُمَكِّن أحَدًا مِن التَّوَسُّط فِيهِ بِخِلافِ الدُّنْيا.</p></div>",
      "verses": {
        "82:19": {
          "id": 5848
        }
      }
    }
  }
}