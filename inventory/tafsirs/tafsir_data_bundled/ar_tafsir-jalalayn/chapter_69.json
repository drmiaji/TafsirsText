{
  "chapter": 69,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p>سُورَة الحاقَّة [ مَكِّيَّة وآياتها اثْنَتانِ وخَمْسُونَ آيَة ]</p><p><span class=\"qpc-hafs\">﴿الحاقَّة﴾</span> القِيامَة الَّتِي يَحِقّ فِيها ما أُنْكِرَ مِن البَعْث والحِساب والجَزاء أوْ المُظْهِرَة لِذَلِكَ</p></div>",
      "verses": {
        "69:1": {
          "id": 5324
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ما الحاقَّة﴾</span> تَعْظِيم لِشَأْنِها وهُوَ مُبْتَدَأ وخَبَر الحاقَّة</p></div>",
      "verses": {
        "69:2": {
          "id": 5325
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما أدْراك﴾</span> أعْلَمَك <span class=\"qpc-hafs\">﴿ما الحاقَّة﴾</span> زِيادَة تَعْظِيم لِشَأْنِها فَما الأُولى مُبْتَدَأ وما بَعْدها خَبَره وما الثّانِيَة وخَبَرها فِي مَحَلّ المَفْعُول الثّانِي لِأَدْرى</p></div>",
      "verses": {
        "69:3": {
          "id": 5326
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَذَّبَتْ ثَمُود وعاد بِالقارِعَةِ﴾</span> القِيامَة لِأَنَّها تَقْرَع القُلُوب بِأَهْوالِها</p></div>",
      "verses": {
        "69:4": {
          "id": 5327
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَمّا ثَمُود فَأُهْلِكُوا بِالطّاغِيَةِ﴾</span> بِالصَّيْحَةِ المُجاوِزَة لِلْحَدِّ فِي الشِّدَّة</p></div>",
      "verses": {
        "69:5": {
          "id": 5328
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَمّا عاد فَأُهْلِكُوا بِرِيحٍ صَرْصَر عاتِيَة﴾</span> قَوِيَّة شَدِيدَة عَلى عادٍ مَعَ قُوَّتهمْ وشِدَّتهمْ</p></div>",
      "verses": {
        "69:6": {
          "id": 5329
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿سَخَّرَها﴾</span> أرْسَلَها بِالقَهْرِ <span class=\"qpc-hafs\">﴿عَلَيْهِمْ سَبْع لَيالٍ وثَمانِيَة أيّام﴾</span> أوَّلها مِن صُبْح يَوْم الأَرْبِعاء لِثَمانٍ بَقِينَ مِن شَوّال وكانَتْ فِي عَجُز الشِّتاء <span class=\"qpc-hafs\">﴿حُسُومًا﴾</span> مُتَتابِعات شُبِّهَتْ بِتَتابُعِ فِعْل الحاسِم فِي إعادَة الكَيّ عَلى الدّاء كَرَّة بَعْد أُخْرى حَتّى يَنْحَسِم <span class=\"qpc-hafs\">﴿فَتَرى القَوْم فِيها صَرْعى﴾</span> مَطْرُوحِينَ هالِكِينَ <span class=\"qpc-hafs\">﴿كَأَنَّهُمْ أعْجاز﴾</span> أُصُول <span class=\"qpc-hafs\">﴿نَخْل خاوِيَة﴾</span> ساقِطَة فارِغَة</p></div>",
      "verses": {
        "69:7": {
          "id": 5330
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَهَلْ تَرى لَهُمْ مِن باقِيَة﴾</span> لا تَرى لَهُمْ باقِيَة</p></div>",
      "verses": {
        "69:8": {
          "id": 5331
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وجاءَ فِرْعَوْن ومَن قَبَله﴾</span> أتْباعه وفِي قِراءَة بِفَتْحِ القاف وسُكُون الباء أيْ مَن تَقَدَّمَهُ مِن الأُمَم الكافِرَة <span class=\"qpc-hafs\">﴿والمُؤْتَفِكات﴾</span> أيْ أهْلها وهِيَ قُرى قَوْم لُوط <span class=\"qpc-hafs\">﴿بِالخاطِئَةِ﴾</span> بِالفِعْلاتِ ذات الخَطَأ</p></div>",
      "verses": {
        "69:9": {
          "id": 5332
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَعَصَوْا رَسُول رَبّهمْ﴾</span> أيْ لُوطًا وغَيْره <span class=\"qpc-hafs\">﴿فَأَخَذَهُمْ أخْذَة رابِيَة﴾</span> زائِدَة فِي الشِّدَّة عَلى غَيْرها</p></div>",
      "verses": {
        "69:10": {
          "id": 5333
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّا لَمّا طَغى الماء﴾</span> عَلا فَوْق كُلّ شَيْء مِن الجِبال وغَيْرها زَمَن الطُّوفان <span class=\"qpc-hafs\">﴿حَمَلْناكُمْ﴾</span> يَعْنِي آباءَكُمْ إذْ أنْتُمْ فِي أصْلابهمْ <span class=\"qpc-hafs\">﴿فِي الجارِيَة﴾</span> السَّفِينَة الَّتِي عَمِلَها نُوح ونَجا هُوَ ومَن كانَ مَعَهُ فِيها وغَرِقَ الآخَرُونَ</p></div>",
      "verses": {
        "69:11": {
          "id": 5334
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لِنَجْعَلها﴾</span> أيْ هَذِهِ الفَعْلَة وهِيَ إنْجاء المُؤْمِنِينَ وإهْلاك الكافِرِينَ <span class=\"qpc-hafs\">﴿لَكُمْ تَذْكِرَة﴾</span> عِظَة <span class=\"qpc-hafs\">﴿وتَعِيها﴾</span> ولِتَحْفَظها <span class=\"qpc-hafs\">﴿أُذُن واعِيَة﴾</span> حافِظَة لِما تَسْمَع</p></div>",
      "verses": {
        "69:12": {
          "id": 5335
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَإذا نُفِخَ فِي الصُّور نَفْخَة واحِدَة﴾</span> لِلْفَصْلِ بَيْن الخَلائِق وهِيَ الثّانِيَة</p></div>",
      "verses": {
        "69:13": {
          "id": 5336
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وحُمِلَتْ﴾</span> رُفِعَتْ <span class=\"qpc-hafs\">﴿الأَرْض والجِبال فَدُكَّتا﴾</span> دُقَّتا</p></div>",
      "verses": {
        "69:14": {
          "id": 5337
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَيَوْمئِذٍ وقَعَتْ الواقِعَة﴾</span> قامَتْ القِيامَة</p></div>",
      "verses": {
        "69:15": {
          "id": 5338
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وانْشَقَّتْ السَّماء فَهِيَ يَوْمئِذٍ واهِيَة﴾</span> ضَعِيفَة</p></div>",
      "verses": {
        "69:16": {
          "id": 5339
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والمَلَك﴾</span> يَعْنِي: المَلائِكَة <span class=\"qpc-hafs\">﴿عَلى أرْجائِها﴾</span> جَوانِب السَّماء <span class=\"qpc-hafs\">﴿ويَحْمِل عَرْش رَبّك فَوْقهمْ﴾</span> أيْ المَلائِكَة المَذْكُورِينَ <span class=\"qpc-hafs\">﴿يَوْمئِذٍ ثَمانِيَة﴾</span> مِن المَلائِكَة أوْ مِن صُفُوفهمْ</p></div>",
      "verses": {
        "69:17": {
          "id": 5340
        }
      }
    },
    "18": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَوْمئِذٍ تُعْرَضُونَ﴾</span> لِلْحِسابِ <span class=\"qpc-hafs\">﴿لا تَخْفى﴾</span> بِالتّاءِ والياء <span class=\"qpc-hafs\">﴿مِنكُمْ خافِيَة﴾</span> مِن السَّرائِر</p></div>",
      "verses": {
        "69:18": {
          "id": 5341
        }
      }
    },
    "19": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَمّا مَن أُوتِيَ كِتابه بِيَمِينِهِ فَيَقُول﴾</span> خِطابًا لِجَماعَتِهِ لِما سُرَّ بِهِ <span class=\"qpc-hafs\">﴿هاؤُمُ﴾</span> خُذُوا <span class=\"qpc-hafs\">﴿اقْرَءُوا كِتابِي﴾</span> تَنازَعَ فِيهِ هاؤُمُ واقْرَءُوا</p></div>",
      "verses": {
        "69:19": {
          "id": 5342
        }
      }
    },
    "20": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنِّي ظَنَنْت﴾</span> تَيَقَّنْت</p></div>",
      "verses": {
        "69:20": {
          "id": 5343
        }
      }
    },
    "21": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَهُوَ فِي عِيشَة راضِيَة﴾</span> مَرْضِيَّة</p></div>",
      "verses": {
        "69:21": {
          "id": 5344
        }
      }
    },
    "22": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "69:22": {
          "id": 5345
        }
      }
    },
    "23": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قُطُوفها﴾</span> ثِمارها <span class=\"qpc-hafs\">﴿دانِيَة﴾</span> قَرِيبَة يَتَناوَلها القائِم والقاعِد والمُضْطَجِع</p></div>",
      "verses": {
        "69:23": {
          "id": 5346
        }
      }
    },
    "24": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p>فَيُقال لَهُمْ <span class=\"qpc-hafs\">﴿كُلُوا واشْرَبُوا هَنِيئًا﴾</span> حال أيْ مُتَهَنِّئِينَ <span class=\"qpc-hafs\">﴿بِما أسْلَفْتُمْ فِي الأَيّام الخالِيَة﴾</span> الماضِيَة فِي الدُّنْيا</p></div>",
      "verses": {
        "69:24": {
          "id": 5347
        }
      }
    },
    "25": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَمّا مَن أُوتِيَ كِتابه بِشِمالِهِ فَيَقُول يا﴾</span> لِلتَّنْبِيهِ</p></div>",
      "verses": {
        "69:25": {
          "id": 5348
        }
      }
    },
    "26": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "69:26": {
          "id": 5349
        }
      }
    },
    "27": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يا لَيْتَها﴾</span> أيْ المَوْتَة فِي الدُّنْيا <span class=\"qpc-hafs\">﴿كانَتْ القاضِيَهْ﴾</span> القاطِعَة لِحَياتِي بِأَنْ لا أُبْعَث</p></div>",
      "verses": {
        "69:27": {
          "id": 5350
        }
      }
    },
    "28": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "69:28": {
          "id": 5351
        }
      }
    },
    "29": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿هَلَكَ عَنِّي سُلْطانِيَهْ﴾</span> قُوَّتِي وحُجَّتِي وهاء كِتابِيَهْ وحِسابِيَهْ ومالِيَهْ وسُلْطانِيَهْ لِلسَّكْتِ تَثْبُت وقْفًا ووَصْلًا اتِّباعًا لِلْمُصْحَفِ الإمام والنَّقْل ومِنهُمْ مَن حَذَفَها وصْلًا</p></div>",
      "verses": {
        "69:29": {
          "id": 5352
        }
      }
    },
    "30": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿خُذُوهُ﴾</span> خِطاب لِخَزَنَةِ جَهَنَّم <span class=\"qpc-hafs\">﴿فَغُلُّوهُ﴾</span> اجْمَعُوا يَدَيْهِ إلى عُنُقه فِي الغُلّ</p></div>",
      "verses": {
        "69:30": {
          "id": 5353
        }
      }
    },
    "31": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ الجَحِيم﴾</span> النّار المُحْرِقَة <span class=\"qpc-hafs\">﴿صَلُّوهُ﴾</span> أدْخِلُوهُ</p></div>",
      "verses": {
        "69:31": {
          "id": 5354
        }
      }
    },
    "32": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ فِي سَلْسَلَة ذَرْعها سَبْعُونَ ذِراعًا﴾</span> بِذِراعِ المَلَك <span class=\"qpc-hafs\">﴿فاسْلُكُوهُ﴾</span> أدْخِلُوهُ فِيها بَعْد إدْخاله النّار ولَمْ تَمْنَع الفاء مِن تَعَلُّق الفِعْل بِالظَّرْفِ المُتَقَدِّم</p></div>",
      "verses": {
        "69:32": {
          "id": 5355
        }
      }
    },
    "33": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "69:33": {
          "id": 5356
        }
      }
    },
    "34": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "69:33",
      "verses": {
        "69:34": {
          "id": 5357
        }
      }
    },
    "35": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَلَيْسَ لَهُ اليَوْم هاهُنا حَمِيم﴾</span> قَرِيب يَنْتَفِع بِهِ</p></div>",
      "verses": {
        "69:35": {
          "id": 5358
        }
      }
    },
    "36": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولا طَعام إلّا مِن غِسْلِين﴾</span> صَدِيد أهْل النّار أوْ شَجَر فِيها</p></div>",
      "verses": {
        "69:36": {
          "id": 5359
        }
      }
    },
    "37": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لا يَأْكُلهُ إلّا الخاطِئُونَ﴾</span> الكافِرُونَ</p></div>",
      "verses": {
        "69:37": {
          "id": 5360
        }
      }
    },
    "38": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَلا﴾</span> زائِدَة <span class=\"qpc-hafs\">﴿أُقْسِم بِما تُبْصِرُونَ﴾</span> مِن المَخْلُوقات</p></div>",
      "verses": {
        "69:38": {
          "id": 5361
        }
      }
    },
    "39": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما لا تُبْصِرُونَ﴾</span> مِنها أيْ بِكُلِّ مَخْلُوق</p></div>",
      "verses": {
        "69:39": {
          "id": 5362
        }
      }
    },
    "40": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّهُ﴾</span> أيْ القُرْآن <span class=\"qpc-hafs\">﴿لَقَوْل رَسُول كَرِيم﴾</span> أيْ قالَهُ رِسالَة عَنْ اللَّه تَعالى</p></div>",
      "verses": {
        "69:40": {
          "id": 5363
        }
      }
    },
    "41": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "69:41": {
          "id": 5364
        }
      }
    },
    "42": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولا بِقَوْلِ كاهِن قَلِيلًا ما تَذَكَّرُونَ﴾</span> بِالتّاءِ والياء فِي الفِعْلَيْنِ وما مَزِيدَة مُؤَكَّدَة والمَعْنى أنَّهُمْ آمَنُوا بِأَشْياء يَسِيرَة وتَذْكُرُوها مِمّا أتى بِهِ النَّبِيّ ﷺ مِن الخَيْر والصِّلَة والعَفاف فَلَمْ تُغْنِ عَنْهُمْ شَيْئًا</p></div>",
      "verses": {
        "69:42": {
          "id": 5365
        }
      }
    },
    "43": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p>بَلْ هُوَ <span class=\"qpc-hafs\">﴿تَنْزِيل مِن رَبّ العالَمِينَ﴾</span></p></div>",
      "verses": {
        "69:43": {
          "id": 5366
        }
      }
    },
    "44": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولَوْ تَقَوَّلَ﴾</span> أيْ النَّبِيّ <span class=\"qpc-hafs\">﴿عَلَيْنا بَعْض الأَقاوِيل﴾</span> بِأَنْ قالَ عَنّا ما لَمْ نَقُلْهُ</p></div>",
      "verses": {
        "69:44": {
          "id": 5367
        }
      }
    },
    "45": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لَأَخَذْنا﴾</span> لِنَلِنا <span class=\"qpc-hafs\">﴿مِنهُ﴾</span> عِقابًا <span class=\"qpc-hafs\">﴿بِاليَمِينِ﴾</span> بِالقُوَّةِ والقُدْرَة</p></div>",
      "verses": {
        "69:45": {
          "id": 5368
        }
      }
    },
    "46": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ لَقَطَعْنا مِنهُ الوَتِين﴾</span> نِياط القَلْب وهُوَ عِرْق مُتَّصِل بِهِ إذا انْقَطَعَ ماتَ صاحِبه</p></div>",
      "verses": {
        "69:46": {
          "id": 5369
        }
      }
    },
    "47": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَما مِنكُمْ مِن أحَد﴾</span> هُوَ اسْم ما ومِن زائِدَة لِتَأْكِيدِ النَّفْي ومِنكُمْ حال مِن أحَد <span class=\"qpc-hafs\">﴿عَنْهُ حاجِزِينَ﴾</span> مانِعِينَ خَبَر ما وجُمِعَ لِأَنَّ أحَدًا فِي سِياق النَّفْي بِمَعْنى الجَمْع وضَمِير عَنْهُ لِلنَّبِيِّ ﷺ أيْ لا مانِع لَنا عَنْهُ مِن حَيْثُ العِقاب</p></div>",
      "verses": {
        "69:47": {
          "id": 5370
        }
      }
    },
    "48": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإنَّهُ﴾</span> أيْ القُرْآن</p></div>",
      "verses": {
        "69:48": {
          "id": 5371
        }
      }
    },
    "49": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإنّا لَنَعْلَم أنَّ مِنكُمْ﴾</span> أيّها النّاس <span class=\"qpc-hafs\">﴿مُكَذِّبِينَ﴾</span> بِالقُرْآنِ ومُصَدِّقِينَ</p></div>",
      "verses": {
        "69:49": {
          "id": 5372
        }
      }
    },
    "50": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإنَّهُ﴾</span> أيْ القُرْآن <span class=\"qpc-hafs\">﴿لَحَسْرَة عَلى الكافِرِينَ﴾</span> إذا رَأَوْا ثَواب المُصَدِّقِينَ وعِقاب المُكَذِّبِينَ بِهِ</p></div>",
      "verses": {
        "69:50": {
          "id": 5373
        }
      }
    },
    "51": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإنَّهُ﴾</span> أيْ القُرْآن <span class=\"qpc-hafs\">﴿لَحَقّ اليَقِين﴾</span> أيْ اليَقِين الحَقّ</p></div>",
      "verses": {
        "69:51": {
          "id": 5374
        }
      }
    },
    "52": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَسَبِّحْ﴾</span> نَزِّهْ <span class=\"qpc-hafs\">﴿بِاسْمِ﴾</span> الباء زائِدَة <span class=\"qpc-hafs\">﴿رَبّك العَظِيم﴾</span> سُبْحانه</p></div>",
      "verses": {
        "69:52": {
          "id": 5375
        }
      }
    }
  }
}