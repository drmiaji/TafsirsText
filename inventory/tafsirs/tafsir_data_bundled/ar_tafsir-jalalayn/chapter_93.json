{
  "chapter": 93,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والضُّحى﴾</span> أيْ أوَّل النَّهار أوْ كُلّه</p></div>",
      "verses": {
        "93:1": {
          "id": 6080
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿واللَّيْل إذا سَجى﴾</span> غَطّى بِظَلامِهِ أوْ سَكَنَ</p></div>",
      "verses": {
        "93:2": {
          "id": 6081
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ما ودَّعَك﴾</span> تَرَكَك يا مُحَمَّد <span class=\"qpc-hafs\">﴿رَبّك وما قَلى﴾</span> أبْغَضك نَزَلَ هَذا لَمّا قالَ الكُفّار عِنْد تَأَخُّر الوَحْي عَنْهُ خَمْسَة عَشَر يَوْمًا: إنَّ رَبّه ودَّعَهُ وقَلاهُ</p></div>",
      "verses": {
        "93:3": {
          "id": 6082
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولَلْآخِرَة خَيْر لَك﴾</span> لِما فِيها مِن الكَرامات لَك <span class=\"qpc-hafs\">﴿مِن الأُولى﴾</span> الدُّنْيا</p></div>",
      "verses": {
        "93:4": {
          "id": 6083
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولَسَوْفَ يُعْطِيك رَبّك﴾</span> فِي الآخِرَة مِن الخَيْرات عَطاء جَزِيلًا <span class=\"qpc-hafs\">﴿فَتَرْضى﴾</span> بِهِ فَقالَ ﷺ: \" إذْن لا أرْضى وواحِد مِن أُمَّتِي فِي النّار \" إلى هُنا تَمَّ جَواب القَسَم بِمُثْبَتَيْنِ بَعْد مَنفِيَّيْنِ</p></div>",
      "verses": {
        "93:5": {
          "id": 6084
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ألَمْ يَجِدك﴾</span> اِسْتِفْهام تَقْرِير أيْ وجَدَك <span class=\"qpc-hafs\">﴿يَتِيمًا﴾</span> بِفَقْدِ أبِيك قَبْل وِلادَتك أوْ بَعْدها <span class=\"qpc-hafs\">﴿فَآوى﴾</span> بِأَنْ ضَمَّك إلى عَمّك أبِي طالِب</p></div>",
      "verses": {
        "93:6": {
          "id": 6085
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ووَجَدَك ضالًّا﴾</span> عَمّا أنْتَ عَلَيْهِ مِن الشَّرِيعَة <span class=\"qpc-hafs\">﴿فَهَدى﴾</span> أيْ هَداك إلَيْها</p></div>",
      "verses": {
        "93:7": {
          "id": 6086
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ووَجَدَك عائِلًا﴾</span> فَقِيرًا <span class=\"qpc-hafs\">﴿فَأَغْنى﴾</span> أغْناك بِما قَنَّعَك بِهِ مِن الغَنِيمَة وغَيْرها وفِي الحَدِيث: \" لَيْسَ الغِنى عَنْ كَثْرَة العَرَض ولَكِنَّ الغِنى غِنى النَّفْس \"</p></div>",
      "verses": {
        "93:8": {
          "id": 6087
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَمّا اليَتِيم فَلا تَقْهَر﴾</span> بِأَخْذِ ماله أوْ غَيْر ذَلِكَ</p></div>",
      "verses": {
        "93:9": {
          "id": 6088
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَمّا السّائِل فَلا تَنْهَر﴾</span> تَزْجُرهُ لِفَقْرِهِ</p></div>",
      "verses": {
        "93:10": {
          "id": 6089
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَمّا بِنِعْمَةِ رَبّك﴾</span> عَلَيْك بِالنُّبُوَّةِ وغَيْرها <span class=\"qpc-hafs\">﴿فَحَدِّثْ﴾</span> أخْبِرْ، وحُذِفَ ضَمِيره ﷺ فِي بَعْض الأَفْعال رِعايَة لِلْفَواصِلِ.</p></div>",
      "verses": {
        "93:11": {
          "id": 6090
        }
      }
    }
  }
}