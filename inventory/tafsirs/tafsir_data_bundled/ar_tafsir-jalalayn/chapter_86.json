{
  "chapter": 86,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والسَّماء والطّارِق﴾</span> أصْله كُلّ آتٍ لَيْلًا ومِنهُ النُّجُوم لِطُلُوعِها لَيْلًا</p></div>",
      "verses": {
        "86:1": {
          "id": 5932
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما أدْراك﴾</span> أعْلَمك <span class=\"qpc-hafs\">﴿ما الطّارِق﴾</span> مُبْتَدَأ وخَبَر فِي مَحَلّ المَفْعُول الثّانِي لَأَدْرى وما بَعْد ما الأُولى خَبَرها وفِيهِ تَعْظِيم لِشَأْنِ الطّارِق المُفَسَّر بِما بَعْده هُوَ</p></div>",
      "verses": {
        "86:2": {
          "id": 5933
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p>\" <span class=\"qpc-hafs\">﴿النَّجْم﴾</span> أيْ الثُّرَيّا أوْ كُلّ نَجْم <span class=\"qpc-hafs\">﴿الثّاقِب﴾</span> المُضِيء لِثَقْبِهِ الظَّلام بِضَوْئِهِ وجَواب القَسَم</p></div>",
      "verses": {
        "86:3": {
          "id": 5934
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنْ كُلّ نَفْس لَما عَلَيْها حافِظ﴾</span> بِتَخْفِيفِ ما فَهِيَ مَزِيدَة وإنْ مُخَفَّفَة مِن الثَّقِيلَة واسْمها مَحْذُوف، أيْ إنَّهُ واللّام فارِقَة وبِتَشْدِيدِها فَإنْ نافِيَة ولَما بِمَعْنى إلّا والحافِظ مِن المَلائِكَة يَحْفَظ عَمَلها مِن خَيْر وشَرّ</p></div>",
      "verses": {
        "86:4": {
          "id": 5935
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَلْيَنْظُرْ الإنْسان﴾</span> نَظَر اِعْتِبار <span class=\"qpc-hafs\">﴿مِمَّ خُلِقَ﴾</span> مِن أيّ شَيْء</p></div>",
      "verses": {
        "86:5": {
          "id": 5936
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿خُلِقَ مِن ماء دافِق﴾</span> هَذا جَواب قَوْله مِمَّ خُلِقَ ؟ خُلِقَ مِن ماء دافِق أيْ ذِي اِنْدِفاق مِن الرَّجُل والمَرْأَة فِي رَحِمها</p></div>",
      "verses": {
        "86:6": {
          "id": 5937
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَخْرُج مِن بَيْن الصُّلْب﴾</span> لِلرَّجُلِ <span class=\"qpc-hafs\">﴿والتَّرائِب﴾</span> لِلْمَرْأَةِ وهِيَ عِظام الصَّدْر</p></div>",
      "verses": {
        "86:7": {
          "id": 5938
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّهُ﴾</span> تَعالى <span class=\"qpc-hafs\">﴿عَلى رَجْعه﴾</span> بَعْث الإنْسان بَعْد مَوْته <span class=\"qpc-hafs\">﴿لَقادِر﴾</span> فَإذا اِعْتَبَرَ أصْله عَلِمَ أنَّ القادِر عَلى ذَلِكَ قادِر عَلى بَعْثه</p></div>",
      "verses": {
        "86:8": {
          "id": 5939
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَوْم تُبْلى﴾</span> تُخْتَبَر وتُكْشَف <span class=\"qpc-hafs\">﴿السَّرائِر﴾</span> ضَمائِر القُلُوب فِي العَقائِد والنِّيّات</p></div>",
      "verses": {
        "86:9": {
          "id": 5940
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَما لَهُ﴾</span> لِمُنْكِرِ البَعْث <span class=\"qpc-hafs\">﴿مِن قُوَّة﴾</span> يَمْتَنِع بِها مِن العَذاب <span class=\"qpc-hafs\">﴿ولا ناصِر﴾</span> يَدْفَعهُ عَنْهُ</p></div>",
      "verses": {
        "86:10": {
          "id": 5941
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والسَّماء ذات الرَّجْع﴾</span> المَطَر لِعَوْدِهِ كُلّ حِين</p></div>",
      "verses": {
        "86:11": {
          "id": 5942
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والأَرْض ذات الصَّدْع﴾</span> الشَّقّ عَنْ النَّبات</p></div>",
      "verses": {
        "86:12": {
          "id": 5943
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّهُ﴾</span> أيْ القُرْآن <span class=\"qpc-hafs\">﴿لَقَوْل فَصْل﴾</span> يَفْصِل بَيْن الحَقّ والباطِل</p></div>",
      "verses": {
        "86:13": {
          "id": 5944
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما هُوَ بِالهَزْلِ﴾</span> بِاللَّعِبِ والباطِل</p></div>",
      "verses": {
        "86:14": {
          "id": 5945
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّهُمْ﴾</span> أيْ الكُفّار <span class=\"qpc-hafs\">﴿يَكِيدُونَ كَيْدًا﴾</span> يَعْمَلُونَ المَكايِد لِلنَّبِيِّ ﷺ</p></div>",
      "verses": {
        "86:15": {
          "id": 5946
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَكِيد كَيْدًا﴾</span> أسْتَدْرِجهُمْ مِن حَيْثُ لا يَعْلَمُونَ</p></div>",
      "verses": {
        "86:16": {
          "id": 5947
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَمَهِّلْ﴾</span> يا مُحَمَّد <span class=\"qpc-hafs\">﴿الكافِرِينَ أمْهِلْهُمْ﴾</span> تَأْكِيد حَسَّنَهُ مُخالَفَة اللَّفْظ، أيْ أنْظِرْهُمْ <span class=\"qpc-hafs\">﴿رُوَيْدًا﴾</span> قَلِيلًا وهُوَ مَصْدَر مُؤَكَّد لِمَعْنى العامِل مُصَغَّر رَوْد أوْ أرْواد عَلى التَّرْخِيم وقَدْ أخَذَهُمْ اللَّه تَعالى بِبَدْرٍ ونَسَخَ الإمْهال بِآيَةِ السَّيْف، أيْ الأَمْر بِالقِتالِ والجِهاد.</p></div>",
      "verses": {
        "86:17": {
          "id": 5948
        }
      }
    }
  }
}