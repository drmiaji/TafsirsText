      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لا أعْبُد﴾</span> فِي الحال <span class=\"qpc-hafs\">﴿ما تَعْبُدُونَ﴾</span> مِن الأَصْنام</p></div>",
      "verses": {
        "109:2": {
          "id": 6209
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولا أنْتُمْ عابِدُونَ﴾</span> فِي الحال <span class=\"qpc-hafs\">﴿ما أعْبُد﴾</span> وهُوَ اللَّه تَعالى وحْده</p></div>",
      "verses": {
        "109:3": {
          "id": 6210
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولا أنا عابِد﴾</span> فِي الِاسْتِقْبال <span class=\"qpc-hafs\">﴿ما عَبَدْتُمْ﴾</span></p></div>",
      "verses": {
        "109:4": {
          "id": 6211
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولا أنْتُمْ عابِدُونَ﴾</span> فِي الِاسْتِقْبال <span class=\"qpc-hafs\">﴿ما أعْبُد﴾</span> عَلِمَ اللَّه مِنهُمْ أنَّهُمْ لا يُؤْمِنُونَ، وإطْلاق ما عَلى اللَّه عَلى وجْه المُقابَلَة.</p></div>",
      "verses": {
        "109:5": {
          "id": 6212
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لَكُمْ دِينكُمْ﴾</span> الشِّرْك <span class=\"qpc-hafs\">﴿ولِيَ دِين﴾</span> الإسْلام وهَذا قَبْل أنْ يُؤْمَر بِالحَرْبِ وحَذَفَ ياء الإضافَة القُرّاء السَّبْعَة وقْفًا ووَصْلًا وأَثْبَتَها يَعْقُوب فِي الحالَيْنِ.</p></div>",
      "verses": {
        "109:6": {
          "id": 6213
        }
      }
    }
  }
}