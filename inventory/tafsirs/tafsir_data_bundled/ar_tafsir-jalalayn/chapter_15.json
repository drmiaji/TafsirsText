{
  "chapter": 15,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p>الحِجْر [ مَكِّيَّة وآياتها ٩٩ ]</p><p><span class=\"qpc-hafs\">﴿الر﴾</span> اللَّه أعْلَم بِمُرادِهِ بِذَلِكَ <span class=\"qpc-hafs\">﴿تِلْكَ﴾</span> هَذِهِ الآيات <span class=\"qpc-hafs\">﴿آيات الكِتاب﴾</span> القُرْآن والإضافَة بِمَعْنى مِن <span class=\"qpc-hafs\">﴿وقُرْآن مُبِين﴾</span> مُظْهِر لِلْحَقِّ مِن الباطِل عَطْف بِزِيادَةِ صِفَة</p></div>",
      "verses": {
        "15:1": {
          "id": 1803
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿رُبَما﴾</span> بِالتَّشْدِيدِ والتَّخْفِيف <span class=\"qpc-hafs\">﴿يَوَدّ﴾</span> يَتَمَنّى <span class=\"qpc-hafs\">﴿الَّذِينَ كَفَرُوا﴾</span> يَوْم القِيامَة إذا عايَنُوا حالهمْ وحال المُسْلِمِينَ <span class=\"qpc-hafs\">﴿لَوْ كانُوا مُسْلِمِينَ﴾</span> ورُبّ لِلتَّكْثِيرِ فَإنَّهُ يَكْثُر مِنهُمْ تَمَنِّي ذَلِك وقِيلَ لِلتَّقْلِيلِ فَإنَّ الأَهْوال تُدْهِشهُمْ فَلا يُفِيقُونَ حَتّى يَتَمَنَّوْا ذَلِكَ إلّا فِي أحْيان قَلِيلَة</p></div>",
      "verses": {
        "15:2": {
          "id": 1804
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ذَرْهُمْ﴾</span> اُتْرُكْ الكُفّار يا مُحَمَّد <span class=\"qpc-hafs\">﴿يَأْكُلُوا ويَتَمَتَّعُوا﴾</span> بِدُنْياهُمْ <span class=\"qpc-hafs\">﴿ويُلْهِهِمْ﴾</span> يَشْغَلهُمْ <span class=\"qpc-hafs\">﴿الأَمَل﴾</span> بِطُولِ العُمْر وغَيْره عَنْ الإيمان <span class=\"qpc-hafs\">﴿فَسَوْفَ يَعْلَمُونَ﴾</span> عاقِبَة أمْرهمْ وهَذا قَبْل الأَمْر بِالقِتالِ</p></div>",
      "verses": {
        "15:3": {
          "id": 1805
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما أهْلَكْنا مِن﴾</span> زائِدَة <span class=\"qpc-hafs\">﴿قَرْيَة﴾</span> أُرِيدَ أهْلها <span class=\"qpc-hafs\">﴿إلّا ولَها كِتاب﴾</span> أجَل <span class=\"qpc-hafs\">﴿مَعْلُوم﴾</span> مَحْدُود لِإهْلاكِها</p></div>",
      "verses": {
        "15:4": {
          "id": 1806
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ما تَسْبِق مِن﴾</span> زائِدَة <span class=\"qpc-hafs\">﴿أُمَّة أجَلها وما يَسْتَأْخِرُونَ﴾</span> يَتَأَخَّرُونَ عَنْهُ</p></div>",
      "verses": {
        "15:5": {
          "id": 1807
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وقالُوا﴾</span> أيْ كُفّار مَكَّة لِلنَّبِيِّ ﷺ <span class=\"qpc-hafs\">﴿يا أيّها الَّذِي نُزِّلَ عَلَيْهِ الذِّكْر﴾</span> القُرْآن فِي زَعْمه</p></div>",
      "verses": {
        "15:6": {
          "id": 1808
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لَوْ ما﴾</span> هَلّا <span class=\"qpc-hafs\">﴿تَأْتِينا بِالمَلائِكَةِ إنْ كُنْت مِنَ الصّادِقِينَ﴾</span> فِي قَوْلك إنّك نَبِيّ وإنَّ هَذا القُرْآن مِن عِنْد اللَّه</p></div>",
      "verses": {
        "15:7": {
          "id": 1809
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ما نُنَزِّل﴾</span> فِيهِ حَذْف إحْدى التّاءَيْنِ <span class=\"qpc-hafs\">﴿المَلائِكَة إلّا بِالحَقِّ﴾</span> بِالعَذابِ <span class=\"qpc-hafs\">﴿وما كانُوا إذًا﴾</span> أيْ حِين نُزُول المَلائِكَة بِالعَذابِ <span class=\"qpc-hafs\">﴿مُنْظَرِينَ﴾</span> مُؤَخَّرِينَ</p></div>",
      "verses": {
        "15:8": {
          "id": 1810
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّا نَحْنُ﴾</span> تَأْكِيد لِاسْمِ إنّ أوْ فَصْل <span class=\"qpc-hafs\">﴿نَزَّلْنا الذِّكْر﴾</span> القُرْآن <span class=\"qpc-hafs\">﴿وإنّا لَهُ لَحافِظُونَ﴾</span> مِن التَّبْدِيل والتَّحْرِيف والزِّيادَة والنَّقْص</p></div>",
      "verses": {
        "15:9": {
          "id": 1811
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولَقَدْ أرْسَلْنا مِن قَبْلك﴾</span> رُسُلًا <span class=\"qpc-hafs\">﴿فِي شِيَع﴾</span> فِرَق</p></div>",
      "verses": {
        "15:10": {
          "id": 1812
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما﴾</span> كانَ <span class=\"qpc-hafs\">﴿يَأْتِيهِمْ مِن رَسُول إلّا كانُوا بِهِ يَسْتَهْزِئُونَ﴾</span> كاسْتِهْزاءِ قَوْمك بِك وهَذا تَسْلِيَة لَهُ ﷺ</p></div>",
      "verses": {
        "15:11": {
          "id": 1813
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَذَلِكَ نَسْلُكهُ﴾</span> أيْ مِثْل إدْخالنا التَّكْذِيب فِي قُلُوب أُولَئِكَ نُدْخِلهُ <span class=\"qpc-hafs\">﴿فِي قُلُوب المُجْرِمِينَ﴾</span> أيْ كُفّار مَكَّة</p></div>",
      "verses": {
        "15:12": {
          "id": 1814
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لا يُؤْمِنُونَ بِهِ﴾</span> بِالنَّبِيِّ ﷺ <span class=\"qpc-hafs\">﴿وقَدْ خَلَتْ سُنَّة الأَوَّلِينَ﴾</span> أيْ سُنَّة اللَّه فِيهِمْ مِن تَعْذِيبهمْ بِتَكْذِيبِهِمْ أنْبِياءَهُمْ وهَؤُلاءِ مِثْلهمْ</p></div>",
      "verses": {
        "15:13": {
          "id": 1815
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولَوْ فَتَحْنا عَلَيْهِمْ بابًا مِنَ السَّماء فَظَلُّوا فِيهِ﴾</span> فِي الباب <span class=\"qpc-hafs\">﴿يَعْرُجُونَ﴾</span> يَصْعَدُونَ</p></div>",
      "verses": {
        "15:14": {
          "id": 1816
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لَقالُوا إنّما سُكِّرَتْ﴾</span> سُدَّتْ <span class=\"qpc-hafs\">﴿أبْصارنا بَلْ نَحْنُ قَوْم مَسْحُورُونَ﴾</span> يُخَيَّل إلَيْنا ذَلِكَ</p></div>",
      "verses": {
        "15:15": {
          "id": 1817
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولَقَدْ جَعَلْنا فِي السَّماء بُرُوجًا﴾</span> اثْنَيْ عَشَر: الحَمْل والثَّوْر والجَوْزاء والسَّرَطان والأَسَد والسُّنْبُلَة والمِيزان والعَقْرَب والقَوْس والجَدْي والدَّلْو والحُوت وهِيَ مَنازِل الكَواكِب السَّبْعَة السَّيّارَة: المِرِّيخ ولَهُ الحَمْل والعَقْرَب والزُّهْرَة ولَها الثَّوْر والمِيزان وعُطارِد ولَهُ الجَوْزاء والسُّنْبُلَة والقَمَر ولَهُ السَّرَطان والشَّمْس ولَها الأَسَد والمُشْتَرى ولَهُ القَوْس والحُوت وزُحَل ولَهُ الجَدْي والدَّلْو <span class=\"qpc-hafs\">﴿وزَيَّنّاها﴾</span> بِالكَواكِبِ</p></div>",
      "verses": {
        "15:16": {
          "id": 1818
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وحَفِظْناها﴾</span> بِالشُّهُبِ <span class=\"qpc-hafs\">﴿مِن كُلّ شَيْطان رَجِيم﴾</span> مَرْجُوم</p></div>",
      "verses": {
        "15:17": {
          "id": 1819
        }
      }
    },
    "18": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إلّا﴾</span> لَكِنْ <span class=\"qpc-hafs\">﴿مَنِ اسْتَرَقَ السَّمْع﴾</span> خَطَفَهُ <span class=\"qpc-hafs\">﴿فَأَتْبَعَهُ شِهاب مُبِين﴾</span> كَوْكَب يُضِيء ويُحْرِقهُ أوْ يَثْقُبهُ أوْ يَخْبِلهُ</p></div>",
      "verses": {
        "15:18": {
          "id": 1820
        }
      }
    },
    "19": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والأَرْض مَدَدْناها﴾</span> بَسَطْناها <span class=\"qpc-hafs\">﴿وأَلْقَيْنا فِيها رَواسِي﴾</span> جِبالًا ثَوابِت لِئَلّا تَتَحَرَّك بِأَهْلِها <span class=\"qpc-hafs\">﴿وأَنْبَتْنا فِيها مِن كُلّ شَيْء مَوْزُون﴾</span> مَعْلُوم مُقَدَّر</p></div>",
      "verses": {
        "15:19": {
          "id": 1821
        }
      }
    },
    "20": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وجَعَلْنا لَكُمْ فِيها مَعايِش﴾</span> بِالياءِ مِن الثِّمار والحُبُوب <span class=\"qpc-hafs\">﴿و﴾</span> جَعَلْنا لَكُمْ <span class=\"qpc-hafs\">﴿مَن لَسْتُمْ لَهُ بِرازِقِينَ﴾</span> مِن العَبِيد والدَّوابّ والأَنْعام فَإنَّما يَرْزُقهُمْ اللَّه</p></div>",
      "verses": {
        "15:20": {
          "id": 1822
        }
      }
    },
    "21": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإنْ﴾</span> ما <span class=\"qpc-hafs\">﴿مِن﴾</span> زائِدَة <span class=\"qpc-hafs\">﴿شَيْء إلّا عِنْدنا خَزائِنه﴾</span> مَفاتِيح خَزائِنه <span class=\"qpc-hafs\">﴿وما نُنَزِّلهُ إلّا بِقَدَرٍ مَعْلُوم﴾</span> عَلى حَسَب المَصالِح</p></div>",
      "verses": {
        "15:21": {
          "id": 1823
        }
      }
    },
    "22": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَرْسَلْنا الرِّياح لَواقِح﴾</span> تُلَقِّح السَّحاب فَيَمْتَلِئ ماء <span class=\"qpc-hafs\">﴿فَأَنْزَلْنا مِنَ السَّماء﴾</span> السَّحاب <span class=\"qpc-hafs\">﴿ماء﴾</span> مَطَرًا <span class=\"qpc-hafs\">﴿فأسقيناكموه وما أنْتُمْ لَهُ بِخازِنِينَ﴾</span> أيّ لَيْسَتْ خَزائِنه بِأَيْدِيكُمْ</p></div>",
      "verses": {
        "15:22": {
          "id": 1824
        }
      }
    },
    "23": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإنّا لَنَحْنُ نُحْيِي ونُمِيت ونَحْنُ الوارِثُونَ﴾</span> الباقُونَ نَرِث جَمِيع الخَلْق</p></div>",
      "verses": {
        "15:23": {
          "id": 1825
        }
      }
    },
    "24": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولَقَدْ عَلِمْنا المُسْتَقْدِمِينَ مِنكُمْ﴾</span> أيْ مَن تَقَدَّمَ مِن الخَلْق مِن لَدُنْ آدَم <span class=\"qpc-hafs\">﴿ولَقَدْ عَلِمْنا المُسْتَأْخِرِينَ﴾</span> المُتَأَخِّرِينَ إلى يَوْم القِيامَة</p></div>",
      "verses": {
        "15:24": {
          "id": 1826
        }
      }
    },
    "25": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإنَّ رَبّك هُوَ يَحْشُرهُمْ إنّهُ حَكِيم﴾</span> فِي صُنْعه <span class=\"qpc-hafs\">﴿عَلِيم﴾</span> بِخَلْقِهِ</p></div>",
      "verses": {
        "15:25": {
          "id": 1827
        }
      }
    },
    "26": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولَقَدْ خَلَقْنا الإنْسان﴾</span> آدَم <span class=\"qpc-hafs\">﴿مِن صَلْصال﴾</span> طِين يابِس يُسْمَع لَهُ صَلْصَلَة إذا نُقِرَ <span class=\"qpc-hafs\">﴿مِن حَمَإٍ﴾</span> طِين أسْوَد <span class=\"qpc-hafs\">﴿مَسْنُون﴾</span> مُتَغَيِّر</p></div>",
      "verses": {
        "15:26": {
          "id": 1828
        }
      }
    },
    "27": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والجانّ﴾</span> أبا الجانّ وهُوَ إبْلِيس <span class=\"qpc-hafs\">﴿خَلَقْناهُ مِن قَبْل﴾</span> أيْ قَبْل خَلْق آدَم <span class=\"qpc-hafs\">﴿مِن نار السَّمُوم﴾</span> هِيَ نار لا دُخان لَها تَنْفُذ مِن المَسامّ</p></div>",
      "verses": {
        "15:27": {
          "id": 1829
        }
      }
    },
    "28": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿و﴾</span> اُذْكُرْ <span class=\"qpc-hafs\">﴿إذا قالَ رَبّك لِلْمَلائِكَةِ إنِّي خالِق بَشَرًا مِن صَلْصال مِن حَمَإٍ مَسْنُون﴾</span></p></div>",
      "verses": {
        "15:28": {
          "id": 1830
        }
      }
    },
    "29": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَإذا سَوَّيْته﴾</span> أتْمَمْته <span class=\"qpc-hafs\">﴿ونَفَخْت﴾</span> أجْرَيْت <span class=\"qpc-hafs\">﴿فِيهِ مِن رُوحِي﴾</span> فَصارَ حَيًّا وإضافَة الرُّوح إلَيْهِ تَشْرِيف لِآدَم <span class=\"qpc-hafs\">﴿فَقَعُوا لَهُ ساجِدِينَ﴾</span> سُجُود تَحِيَّة بِالِانْحِناءِ</p></div>",
      "verses": {
        "15:29": {
          "id": 1831
        }
      }
    },
    "30": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَسَجَدَ المَلائِكَة كُلّهمْ أجْمَعُونَ﴾</span> فِيهِ تَأْكِيدانِ</p></div>",
      "verses": {
        "15:30": {
          "id": 1832
        }
      }
    },
    "31": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إلّا إبْلِيس﴾</span> هُوَ أبُو الجِنّ كانَ بَيْن المَلائِكَة <span class=\"qpc-hafs\">﴿أبى﴾</span> امْتَنَعَ مِن أنْ يَكُون مَعَ السّاجِدِينَ</p></div>",
      "verses": {
        "15:31": {
          "id": 1833
        }
      }
    },
    "32": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالَ﴾</span> تَعالى <span class=\"qpc-hafs\">﴿يا إبْلِيس ما لَك﴾</span> ما مَنَعَك <span class=\"qpc-hafs\">﴿أ﴾</span> أنْ <span class=\"qpc-hafs\">﴿لا﴾</span> زائِدَة</p></div>",
      "verses": {
        "15:32": {
          "id": 1834
        }
      }
    },
    "33": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالَ لَمْ أكُنْ لِأَسْجُد﴾</span> لا يَنْبَغِي لِي أنْ أسْجُد</p></div>",
      "verses": {
        "15:33": {
          "id": 1835
        }
      }
    },
    "34": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالَ فاخْرُجْ مِنها﴾</span> أيْ مِن الجَنَّة وقِيلَ مِن السَّماوات <span class=\"qpc-hafs\">﴿فَإنَّك رَجِيم﴾</span> مَطْرُود</p></div>",
      "verses": {
        "15:34": {
          "id": 1836
        }
      }
    },
    "35": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإنَّ عَلَيْك اللَّعْنَة إلى يَوْم الدِّين﴾</span> الجَزاء</p></div>",
      "verses": {
        "15:35": {
          "id": 1837
        }
      }
    },
    "36": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالَ رَبّ فَأَنْظِرْنِي إلى يَوْم يُبْعَثُونَ﴾</span> أيْ النّاس</p></div>",
      "verses": {
        "15:36": {
          "id": 1838
        }
      }
    },
    "37": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "15:37": {
          "id": 1839
        }
      }
    },
    "38": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إلى يَوْم الوَقْت المَعْلُوم﴾</span> وقْت النَّفْخَة الأُولى</p></div>",
      "verses": {
        "15:38": {
          "id": 1840
        }
      }
    },
    "39": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالَ رَبّ بِما أغْوَيْتنِي﴾</span> أيْ بِإغْوائِك لِي والباء لِلْقَسَمِ وجَوابه <span class=\"qpc-hafs\">﴿لَأُزَيِّنَن لَهُمْ فِي الأَرْض﴾</span> المَعاصِي</p></div>",
      "verses": {
        "15:39": {
          "id": 1841
        }
      }
    },
    "40": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إلّا عِبادك مِنهُمْ المُخْلَصِينَ﴾</span> أيْ المُؤْمِنِينَ</p></div>",
      "verses": {
        "15:40": {
          "id": 1842
        }
      }
    },
    "41": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالَ﴾</span> تَعالى</p></div>",
      "verses": {
        "15:41": {
          "id": 1843
        }
      }
    },
    "42": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p>وهُو <span class=\"qpc-hafs\">﴿إنّ عِبادِي﴾</span> أيْ المُؤْمِنِينَ <span class=\"qpc-hafs\">﴿لَيْسَ لَك عَلَيْهِمْ سُلْطان﴾</span> قُوَّة <span class=\"qpc-hafs\">﴿إلّا﴾</span> لَكِنْ <span class=\"qpc-hafs\">﴿مَنِ اتَّبَعَك مِنَ الغاوِينَ﴾</span> الكافِرِينَ</p></div>",
      "verses": {
        "15:42": {
          "id": 1844
        }
      }
    },
    "43": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإنَّ جَهَنَّم لَمَوْعِدهمْ أجْمَعِينَ﴾</span> أيْ مَن اتَّبَعَك مَعَك</p></div>",
      "verses": {
        "15:43": {
          "id": 1845
        }
      }
    },
    "44": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لَها سَبْعَة أبْواب﴾</span> أطْباق <span class=\"qpc-hafs\">﴿لِكُلِّ باب﴾</span> مِنها <span class=\"qpc-hafs\">﴿مِنهُمْ جُزْء﴾</span> نَصِيب</p></div>",
      "verses": {
        "15:44": {
          "id": 1846
        }
      }
    },
    "45": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّ المُتَّقِينَ فِي جَنّات﴾</span> بَساتِين <span class=\"qpc-hafs\">﴿وعُيُون﴾</span> تَجْرِي فِيها</p></div>",
      "verses": {
        "15:45": {
          "id": 1847
        }
      }
    },
    "46": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p>يُقال لَهُمْ <span class=\"qpc-hafs\">﴿اُدْخُلُوها بِسَلامٍ﴾</span> أيْ سالِمِينَ مِن كُلّ مَخُوف أوْ مَعَ سَلام أيْ سَلِّمُوا وادْخُلُوا <span class=\"qpc-hafs\">﴿آمِنِينَ﴾</span> مِن كُلّ فَزَع</p></div>",
      "verses": {
        "15:46": {
          "id": 1848
        }
      }
    },
    "47": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ونَزَعْنا ما فِي صُدُورهمْ مِن غِلٍّ﴾</span> حِقْد <span class=\"qpc-hafs\">﴿إخْوانًا﴾</span> حال مِنهُمْ <span class=\"qpc-hafs\">﴿عَلى سُرُر مُتَقابِلِينَ﴾</span> حال أيْضًا أيْ لا يَنْظُر بَعْضهمْ إلى قَفا بَعْض لِدَوَرانِ الأَسِرَّة بِهِمْ</p></div>",
      "verses": {
        "15:47": {
          "id": 1849
        }
      }
    },
    "48": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لا يَمَسّهُمْ فِيها نَصَب﴾</span> تَعَب <span class=\"qpc-hafs\">﴿وما هُمْ مِنها بِمُخْرَجِينَ﴾</span> أبَدًا</p></div>",
      "verses": {
        "15:48": {
          "id": 1850
        }
      }
    },
    "49": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿نَبِّئْ﴾</span> خَبِّرْ يا مُحَمَّد <span class=\"qpc-hafs\">﴿عِبادِي أنِّي أنا الغَفُور﴾</span> لِلْمُؤْمِنِينَ <span class=\"qpc-hafs\">﴿الرَّحِيم﴾</span> بِهِمْ</p></div>",
      "verses": {
        "15:49": {
          "id": 1851
        }
      }
    },
    "50": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَنَّ عَذابِي﴾</span> لِلْعُصاةِ <span class=\"qpc-hafs\">﴿هُوَ العَذاب الأَلِيم﴾</span> المُؤْلِم</p></div>",
      "verses": {
        "15:50": {
          "id": 1852
        }
      }
    },
    "51": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ونَبِّئْهُمْ عَنْ ضَيْف إبْراهِيم﴾</span> وهُمْ المَلائِكَة اثْنا عَشَر أوْ عَشْرَة أوْ ثَلاثَة مِنهُمْ جِبْرِيل</p></div>",
      "verses": {
        "15:51": {
          "id": 1853
        }
      }
    },
    "52": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إذْ دَخَلُوا عَلَيْهِ فَقالُوا سَلامًا﴾</span> أيْ هَذا اللَّفْظ <span class=\"qpc-hafs\">﴿قالَ﴾</span> إبْراهِيم لَمّا عَرَضَ عَلَيْهِمْ الأَكْل فَلَمْ يَأْكُلُوا <span class=\"qpc-hafs\">﴿إنّا مِنكُمْ وجِلُونَ﴾</span> خائِفُونَ</p></div>",
      "verses": {
        "15:52": {
          "id": 1854
        }
      }
    },
    "53": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالُوا لا تَوْجَل﴾</span> لا تَخَفْ <span class=\"qpc-hafs\">﴿إنّا﴾</span> رُسُل رَبّك <span class=\"qpc-hafs\">﴿نُبَشِّرك بِغُلامٍ عَلِيم﴾</span> ذِي عِلْم كَثِير هُوَ إسْحاق كَما ذَكَرْنا فِي سُورَة هُود</p></div>",
      "verses": {
        "15:53": {
          "id": 1855
        }
      }
    },
    "54": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالَ أبَشَّرْتُمُونِي﴾</span> بِالوَلَدِ <span class=\"qpc-hafs\">﴿عَلى أنْ مَسَّنِيَ الكِبَر﴾</span> حال أيْ مَعَ مَسّه إيّايَ <span class=\"qpc-hafs\">﴿فَبِمَ تُبَشِّرُونَ﴾</span> فَبِأَيِّ شَيْء اسْتِفْهام تَعَجُّب</p></div>",
      "verses": {
        "15:54": {
          "id": 1856
        }
      }
    },
    "55": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالُوا بَشَّرْناك بِالحَقِّ﴾</span> بِالصِّدْقِ <span class=\"qpc-hafs\">﴿فَلا تَكُنْ مِنَ القانِطِينَ﴾</span> الآيِسِينَ</p></div>",
      "verses": {
        "15:55": {
          "id": 1857
        }
      }
    },
    "56": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالَ ومَن﴾</span> أيْ لا <span class=\"qpc-hafs\">﴿يَقْنَط﴾</span> بِكَسْرِ النُّون وفَتْحها <span class=\"qpc-hafs\">﴿مِن رَحْمَة رَبّه إلّا الضّالُّونَ﴾</span> الكافِرُونَ</p></div>",
      "verses": {
        "15:56": {
          "id": 1858
        }
      }
    },
    "57": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالَ فَما خَطْبكُمْ﴾</span> شَأْنكُمْ</p></div>",
      "verses": {
        "15:57": {
          "id": 1859
        }
      }
    },
    "58": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالُوا إنّا أُرْسِلنا إلى قَوْم مُجْرِمِينَ﴾</span> كافِرِينَ أيْ قَوْم لُوط لِإهْلاكِهِمْ</p></div>",
      "verses": {
        "15:58": {
          "id": 1860
        }
      }
    },
    "59": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إلّا آل لُوط إنّا لَمُنَجُّوهُمْ أجْمَعِينَ﴾</span> لِإيمانِهِمْ</p></div>",
      "verses": {
        "15:59": {
          "id": 1861
        }
      }
    },
    "60": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إلّا امْرَأَته قَدَّرْنا إنّها لَمِنَ الغابِرِينَ﴾</span> الباقِينَ فِي العَذاب لِكُفْرِها</p></div>",
      "verses": {
        "15:60": {
          "id": 1862
        }
      }
    },
    "61": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَلَمّا جاءَ آل لُوط﴾</span> أيْ لُوطًا</p></div>",
      "verses": {
        "15:61": {
          "id": 1863
        }
      }
    },
    "62": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالَ﴾</span> لَهُمْ <span class=\"qpc-hafs\">﴿إنّكُمْ قَوْم مُنْكَرُونَ﴾</span> لا أعْرِفكُمْ</p></div>",
      "verses": {
        "15:62": {
          "id": 1864
        }
      }
    },
    "63": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالُوا بَلْ جِئْناك بِما كانُوا﴾</span> أيْ قَوْمك <span class=\"qpc-hafs\">﴿فِيهِ يَمْتَرُونَ﴾</span> يَشُكُّونَ وهُوَ العَذاب</p></div>",
      "verses": {
        "15:63": {
          "id": 1865
        }
      }
    },
    "64": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وآتَيْناك بِالحَقِّ وإنّا لَصادِقُونَ﴾</span> فِي قَوْلنا</p></div>",
      "verses": {
        "15:64": {
          "id": 1866
        }
      }
    },
    "65": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَسْرِ بِأَهْلِك بِقِطَعٍ مِنَ اللَّيْل واتَّبِعْ أدْبارهمْ﴾</span> امْشِ خَلْفهمْ. <span class=\"qpc-hafs\">﴿ولا يَلْتَفِت مِنكُمْ أحَد﴾</span> لِئَلّا يَرى عَظِيم ما يَنْزِل بِهِمْ <span class=\"qpc-hafs\">﴿وامْضُوا حَيْثُ تُؤْمَرُونَ﴾</span> وهُوَ الشّام</p></div>",
      "verses": {
        "15:65": {
          "id": 1867
        }
      }
    },
    "66": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وقَضَيْنا﴾</span> أوْحَيْنا <span class=\"qpc-hafs\">﴿إلَيْهِ ذَلِكَ الأَمْر﴾</span> وهُوَ <span class=\"qpc-hafs\">﴿أنَّ دابِر هَؤُلاءِ مَقْطُوع مُصْبِحِينَ﴾</span> حال أيْ يَتِمّ اسْتِئْصالهمْ فِي الصَّباح</p></div>",
      "verses": {
        "15:66": {
          "id": 1868
        }
      }
    },
    "67": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وجاءَ أهْل المَدِينَة﴾</span> مَدِينَة سدوم وهُمْ قَوْم لُوط لَمّا أُخْبِرُوا أنَّ فِي بَيْت لُوط مُرْدًا حِسانًا وهُمْ المَلائِكَة <span class=\"qpc-hafs\">﴿يَسْتَبْشِرُونَ﴾</span> حال طَمَعًا فِي فِعْل الفاحِشَة بِهِمْ</p></div>",
      "verses": {
        "15:67": {
          "id": 1869
        }
      }
    },
    "68": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالَ﴾</span> لُوط <span class=\"qpc-hafs\">﴿إنَّ هَؤُلاءِ ضَيْفِي فَلا تَفْضَحُونِ﴾</span></p></div>",
      "verses": {
        "15:68": {
          "id": 1870
        }
      }
    },
    "69": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿واتَّقُوا اللَّه ولا تُخْزُونِ﴾</span> بِقَصْدِكُمْ إيّاهُمْ بِفِعْلِ الفاحِشَة بِهِمْ</p></div>",
      "verses": {
        "15:69": {
          "id": 1871
        }
      }
    },
    "70": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالُوا أوَلَمْ نَنْهَك عَنِ العالَمِينَ﴾</span> عَنْ إضافَتهمْ</p></div>",
      "verses": {
        "15:70": {
          "id": 1872
        }
      }
    },
    "71": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالَ هَؤُلاءِ بَناتِي إنْ كُنْتُمْ فاعِلِينَ﴾</span> ما تُرِيدُونَ مِن قَضاء الشَّهْوَة فَتَزَوَّجُوهُنَّ</p></div>",
      "verses": {
        "15:71": {
          "id": 1873
        }
      }
    },
    "72": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لَعَمْرُك﴾</span> خِطاب لِلنَّبِيِّ ﷺ: أيْ وحَياتك <span class=\"qpc-hafs\">﴿إنّهُمْ لَفِي سَكْرَتهمْ يَعْمَهُونَ﴾</span> يَتَرَدَّدُونَ</p></div>",
      "verses": {
        "15:72": {
          "id": 1874
        }
      }
    },
    "73": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَخَذَتْهُمْ الصَّيْحَة﴾</span> صَيْحَة جِبْرِيل <span class=\"qpc-hafs\">﴿مُشْرِقِينَ﴾</span> وقْت شُرُوق الشَّمْس</p></div>",
      "verses": {
        "15:73": {
          "id": 1875
        }
      }
    },
    "74": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَجَعَلْنا عالِيها﴾</span> أيْ قُراهُمْ <span class=\"qpc-hafs\">﴿سافِلها﴾</span> بِأَنْ رَفَعَها جِبْرِيل إلى السَّماء وأَسْقَطَها مَقْلُوبَة إلى الأَرْض <span class=\"qpc-hafs\">﴿وأَمْطَرْنا عَلَيْهِمْ حِجارَة مِن سِجِّيل﴾</span> طِين طُبِخَ بِالنّارِ</p></div>",
      "verses": {
        "15:74": {
          "id": 1876
        }
      }
    },
    "75": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّ فِي ذَلِك﴾</span> المَذْكُور <span class=\"qpc-hafs\">﴿لَآيات﴾</span> دَلالات عَلى وحْدانِيَّة اللَّه <span class=\"qpc-hafs\">﴿لِلْمُتَوَسِّمِينَ﴾</span> لِلنّاظِرِينَ المُعْتَبِرِينَ</p></div>",
      "verses": {
        "15:75": {
          "id": 1877
        }
      }
    },
    "76": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإنَّها﴾</span> أيْ قُرى قَوْم لُوط <span class=\"qpc-hafs\">﴿لَبِسَبِيلٍ مُقِيم﴾</span> طَرِيق قُرَيْش إلى الشّام لَمْ تَنْدَرِس أفَلا يَعْتَبِرُونَ بِهِمْ ؟</p></div>",
      "verses": {
        "15:76": {
          "id": 1878
        }
      }
    },
    "77": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّ فِي ذَلِك لَآيَة﴾</span> لَعِبْرَة</p></div>",
      "verses": {
        "15:77": {
          "id": 1879
        }
      }
    },
    "78": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإنْ﴾</span> مُخَفَّفَة أيْ إنّهُ <span class=\"qpc-hafs\">﴿كانَ أصْحاب الأَيْكَة﴾</span> هِيَ غَيْضَة شَجَر بِقُرْبِ مَدْيَن وهُمْ قَوْم شُعَيْب <span class=\"qpc-hafs\">﴿لَظالِمِينَ﴾</span> بِتَكْذِيبِهِمْ شُعَيْبًا</p></div>",
      "verses": {
        "15:78": {
          "id": 1880
        }
      }
    },
    "79": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فانْتَقَمْنا مِنهُمْ﴾</span> بِأَنْ أهْلَكْناهُمْ بِشِدَّةِ الحَرّ <span class=\"qpc-hafs\">﴿وإنَّهُما﴾</span> أيْ قُرى قَوْم لُوط والأَيْكَة <span class=\"qpc-hafs\">﴿لَبِإمامٍ﴾</span> طَرِيق <span class=\"qpc-hafs\">﴿مُبِين﴾</span> واضِح أفَلا تَعْتَبِرُونَ بِهِمْ يا أهْل مَكَّة</p></div>",
      "verses": {
        "15:79": {
          "id": 1881
        }
      }
    },
    "80": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولَقَدْ كَذَّبَ أصْحاب الحِجْر﴾</span> وادٍ بَيْن المَدِينَة والشّام وهُمْ ثَمُود <span class=\"qpc-hafs\">﴿المُرْسَلِينَ﴾</span> بِتَكْذِيبِهِمْ صالِحًا لِأَنَّهُ تَكْذِيب لِباقِي الرُّسُل لِاشْتِراكِهِمْ فِي المَجِيء بِالتَّوْحِيدِ</p></div>",
      "verses": {
        "15:80": {
          "id": 1882
        }
      }
    },
    "81": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وآتَيْناهُمْ آياتنا﴾</span> فِي النّاقَة <span class=\"qpc-hafs\">﴿فَكانُوا عَنْها مُعْرِضِينَ﴾</span> لا يَتَفَكَّرُونَ فِيها</p></div>",
      "verses": {
        "15:81": {
          "id": 1883
        }
      }
    },
    "82": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "15:82": {
          "id": 1884
        }
      }
    },
    "83": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَخَذَتْهُمْ الصَّيْحَة مُصْبِحِينَ﴾</span> وقْت الصَّباح</p></div>",
      "verses": {
        "15:83": {
          "id": 1885
        }
      }
    },
    "84": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَما أغْنى﴾</span> دَفَعَ <span class=\"qpc-hafs\">﴿عَنْهُمْ﴾</span> العَذاب <span class=\"qpc-hafs\">﴿ما كانُوا يَكْسِبُونَ﴾</span> مِن بِناء الحُصُون وجَمْع الأَمْوال</p></div>",
      "verses": {
        "15:84": {
          "id": 1886
        }
      }
    },
    "85": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما خَلَقْنا السَّمَوات والأَرْض وما بَيْنهما إلّا بِالحَقِّ وإنَّ السّاعَة لَآتِيَة﴾</span> لا مَحالَة فَيُجازى كُلّ أحَد بِعَمَلِهِ <span class=\"qpc-hafs\">﴿فاصْفَحْ﴾</span> يا مُحَمَّد عَنْ قَوْمك <span class=\"qpc-hafs\">﴿الصَّفْح الجَمِيل﴾</span> أعْرِضْ عَنْهُمْ إعْراضًا لا جَزَع فِيهِ وهَذا مَنسُوخ بِآيَةِ السَّيْف</p></div>",
      "verses": {
        "15:85": {
          "id": 1887
        }
      }
    },
    "86": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّ رَبّك هُوَ الخَلّاق﴾</span> لِكُلِّ شَيْء <span class=\"qpc-hafs\">﴿العَلِيم﴾</span> بِكُلِّ شَيْء</p></div>",
      "verses": {
        "15:86": {
          "id": 1888
        }
      }
    },
    "87": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولَقَدْ آتَيْناك سَبْعًا مِنَ المَثانِي﴾</span> قالَ ﷺ هِيَ الفاتِحَة رَواهُ الشَّيْخانِ لِأَنَّها تُثَنّى فِي كُلّ رَكْعَة</p></div>",
      "verses": {
        "15:87": {
          "id": 1889
        }
      }
    },
    "88": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لا تَمُدَّنّ عَيْنَيْك إلى ما مَتَّعْنا بِهِ أزْواجًا﴾</span> أصْنافًا <span class=\"qpc-hafs\">﴿مِنهُمْ ولا تَحْزَن عَلَيْهِمْ﴾</span> إنْ لَمْ يُؤْمِنُوا <span class=\"qpc-hafs\">﴿واخْفِضْ جَناحك﴾</span> ألِنْ جانِبك</p></div>",
      "verses": {
        "15:88": {
          "id": 1890
        }
      }
    },
    "89": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وقُلْ إنِّي أنا النَّذِير﴾</span> مِن عَذاب اللَّه أنْ يَنْزِل عَلَيْكُمْ <span class=\"qpc-hafs\">﴿المُبِين﴾</span> البَيِّن الإنْذار</p></div>",
      "verses": {
        "15:89": {
          "id": 1891
        }
      }
    },
    "90": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَما أنْزَلْنا﴾</span> العَذاب <span class=\"qpc-hafs\">﴿عَلى المُقْتَسِمِينَ﴾</span> اليَهُود والنَّصارى</p></div>",
      "verses": {
        "15:90": {
          "id": 1892
        }
      }
    },
    "91": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿الَّذِينَ جَعَلُوا القُرْآن﴾</span> أيْ كُتُبهمْ المُنَزَّلَة عَلَيْهِمْ <span class=\"qpc-hafs\">﴿عِضِينَ﴾</span> أجْزاء حَيْثُ آمَنُوا بِبَعْضٍ وكَفَرُوا بِبَعْضٍ وقِيلَ المُراد بِهِمْ الَّذِينَ اقْتَسَمُوا طُرُق مَكَّة يَصُدُّونَ النّاس عَنْ الإسْلام وقالَ بَعْضهمْ فِي القُرْآن سِحْر وبَعْضهمْ كَهانَة وبَعْضهمْ شِعْر</p></div>",
      "verses": {
        "15:91": {
          "id": 1893
        }
      }
    },
    "92": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَوَرَبِّك لَنَسْأَلَنَّهُمْ أجْمَعِينَ﴾</span> سُؤال تَوْبِيخ</p></div>",
      "verses": {
