    "94": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فاصْدَعْ﴾</span> يا مُحَمَّد <span class=\"qpc-hafs\">﴿بِما تُؤْمَر﴾</span> بِهِ أيْ اجْهَرْ بِهِ وأَمْضِهِ <span class=\"qpc-hafs\">﴿وأَعْرِضْ عَنِ المُشْرِكِينَ﴾</span> هَذا قَبْل الأَمْر بِالجِهادِ</p></div>",
      "verses": {
