    "95": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّا كَفَيْناك المُسْتَهْزِئِينَ﴾</span> بِك بِإهْلاكِنا كُلًّا مِنهُمْ بِآفَةٍ وهُمْ الوَلِيد بْن المُغِيرَة والعاصُ بْن وائِل وعَدِيّ بْن قَيْس والأَسْوَد بْن المُطَّلِب والأَسْوَد بْن عَبْد يَغُوث</p></div>",
      "verses": {
        "15:95": {
          "id": 1897
