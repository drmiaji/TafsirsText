{
  "chapter": 94,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ألَمْ نَشْرَح﴾</span> اِسْتِفْهام تَقْرِير أيْ شَرَحْنا <span class=\"qpc-hafs\">﴿لَك﴾</span> يا مُحَمَّد <span class=\"qpc-hafs\">﴿صَدْرك﴾</span> بِالنُّبُوَّةِ وغَيْرها</p></div>",
      "verses": {
        "94:1": {
          "id": 6091
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ووَضَعْنا﴾</span> حَطَطْنا \" عَنْك وِزْرك \"</p></div>",
      "verses": {
        "94:2": {
          "id": 6092
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿الَّذِي أنْقَضَ﴾</span> أثْقَل <span class=\"qpc-hafs\">﴿ظَهْرك﴾</span> وهَذا كَقَوْلِهِ تَعالى: \" لِيَغْفِر لَك اللَّه ما تَقَدَّمَ مِن ذَنْبك \"</p></div>",
      "verses": {
        "94:3": {
          "id": 6093
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ورَفَعْنا لَك ذِكْرك﴾</span> بِأَنْ تُذْكَر مَعَ ذِكْرِي فِي الأَذان والإقامَة والتَّشَهُّد والخُطْبَة وغَيْرها</p></div>",
      "verses": {
        "94:4": {
          "id": 6094
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَإنَّ مَعَ العُسْر﴾</span> الشِّدَّة <span class=\"qpc-hafs\">﴿يُسْرًا﴾</span> سُهُولَة</p></div>",
      "verses": {
        "94:5": {
          "id": 6095
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّ مَعَ العُسْر يُسْرًا﴾</span> والنَّبِيّ ﷺ قاسى مِن الكُفّار شِدَّة ثُمَّ حَصَلَ لَهُ اليُسْر بِنَصْرِهِ عَلَيْهِمْ</p></div>",
      "verses": {
        "94:6": {
          "id": 6096
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَإذا فَرَغْت﴾</span> مِن الصَّلاة <span class=\"qpc-hafs\">﴿فانْصَبْ﴾</span> اِتْعَبْ فِي الدُّعاء</p></div>",
      "verses": {
        "94:7": {
          "id": 6097
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإلى رَبّك فارْغَبْ \" تَضَرَّعْ.﴾</span></p></div>",
      "verses": {
        "94:8": {
          "id": 6098
        }
      }
    }
  }
}