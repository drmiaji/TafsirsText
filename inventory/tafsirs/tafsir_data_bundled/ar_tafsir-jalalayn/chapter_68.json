{
  "chapter": 68,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p>سُورَة القَلَم [ مَكِّيَّة وآياتها اثْنَتانِ وخَمْسُونَ آيَة ]</p><p><span class=\"qpc-hafs\">﴿ن﴾</span> أحَد حُرُوف الهِجاء اللَّه أعْلَم بِمُرادِهِ بِهِ <span class=\"qpc-hafs\">﴿والقَلَم﴾</span> الَّذِي كَتَبَ بِهِ الكائِنات فِي اللَّوْح المَحْفُوظ <span class=\"qpc-hafs\">﴿وما يَسْطُرُونَ﴾</span> أيْ المَلائِكَة مِن الخَيْر والصَّلاح</p></div>",
      "verses": {
        "68:1": {
          "id": 5272
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ما أنْتَ﴾</span> يا مُحَمَّد <span class=\"qpc-hafs\">﴿بِنِعْمَةِ رَبّك بِمَجْنُونٍ﴾</span> أيْ انْتَفى الجُنُون عَنْك بِسَبَبِ إنْعام رَبّك عَلَيْك بِالنُّبُوَّةِ وغَيْرها وهَذا رَدّ لِقَوْلِهِمْ إنّهُ مَجْنُون</p></div>",
      "verses": {
        "68:2": {
          "id": 5273
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإنَّ لَك لَأَجْرًا غَيْر مَمْنُون﴾</span> أيْ أجْرًا غَيْر مَقْطُوع</p></div>",
      "verses": {
        "68:3": {
          "id": 5274
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿خُلُق﴾</span> دِين</p></div>",
      "verses": {
        "68:4": {
          "id": 5275
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "68:5": {
          "id": 5276
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿بِأَيِيِّكُمْ المَفْتُون﴾</span> مَصْدَر كالمَعْقُولِ أيْ الفُتُون بِمَعْنى الجُنُون أيْ أبِك أمْ بِهِمْ</p></div>",
      "verses": {
        "68:6": {
          "id": 5277
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّ رَبّك أعْلَم بِمَن ضَلَّ عَنْ سَبِيله وهُوَ أعْلَم بِالمُهْتَدِينَ﴾</span> لَهُ وأَعْلَم بِمَعْنى عالِم</p></div>",
      "verses": {
        "68:7": {
          "id": 5278
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "68:8": {
          "id": 5279
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ودُّوا﴾</span> تَمَنَّوْا <span class=\"qpc-hafs\">﴿لَوْ﴾</span> مَصْدَرِيَّة <span class=\"qpc-hafs\">﴿تُدْهِن﴾</span> تَلِينَ لَهُمْ <span class=\"qpc-hafs\">﴿فَيُدْهِنُونَ﴾</span> يَلِينُونَ لَك وهُوَ مَعْطُوف عَلى تُدْهِن وإنْ جَعَلَ جَواب التَّمَنِّي المَفْهُوم مِن ودُّوا قَدْر قَبْله بَعْد الفاء هُمْ</p></div>",
      "verses": {
        "68:9": {
          "id": 5280
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولا تُطِعْ كُلّ حَلّاف﴾</span> كَثِير الحَلِف بِالباطِلِ <span class=\"qpc-hafs\">﴿مَهِين﴾</span> حَقِير</p></div>",
      "verses": {
        "68:10": {
          "id": 5281
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿هَمّاز﴾</span> عَيّاب أيْ مُغْتاب <span class=\"qpc-hafs\">﴿مَشّاء بِنَمِيمٍ﴾</span> أيْ ساعٍ بِالكَلامِ بَيْن النّاس عَلى وجْه الإفْساد بَيْنهمْ</p></div>",
      "verses": {
        "68:11": {
          "id": 5282
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿مَنّاع لِلْخَيْرِ﴾</span> بَخِيل بِالمالِ عَنْ الحُقُوق <span class=\"qpc-hafs\">﴿مُعْتَدٍ﴾</span> ظالِم <span class=\"qpc-hafs\">﴿أثِيم﴾</span> آثِم</p></div>",
      "verses": {
        "68:12": {
          "id": 5283
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿عُتُلّ﴾</span> غَلِيظ جافٍ <span class=\"qpc-hafs\">﴿بَعْد ذَلِكَ زَنِيم﴾</span> دُعِيَ فِي قُرَيْش وهُوَ الوَلِيد بْن المُغِيرَة ادَّعاهُ أبُوهُ بَعْد ثَمانِي عَشْرَة سَنَة قالَ ابْن عَبّاس: لا نَعْلَم أنَّ اللَّه وصَفَ أحَدًا بِما وصَفَهُ بِهِ مِن العُيُوب فَأَلْحَقَ بِهِ عارًا لا يُفارِقهُ أبَدًا وتَعَلَّقَ بِزَنِيمٍ الظَّرْف قَبْله</p></div>",
      "verses": {
        "68:13": {
          "id": 5284
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أنْ كانَ ذا مال وبَنِينَ﴾</span> أيْ لِأَنَّ وهُوَ مُتَعَلِّق بِما دَلَّ عَلَيْهِ</p></div>",
      "verses": {
        "68:14": {
          "id": 5285
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إذا تُتْلى عَلَيْهِ آياتنا﴾</span> القُرْآن <span class=\"qpc-hafs\">﴿قالَ﴾</span> هِيَ <span class=\"qpc-hafs\">﴿أساطِير الأَوَّلِينَ﴾</span> أيْ كَذَّبَ بِها لِإنْعامِنا عَلَيْهِ بِما ذُكِرَ وفِي قِراءَة أأَنْ بِهَمْزَتَيْنِ مَفْتُوحَتَيْنِ</p></div>",
      "verses": {
        "68:15": {
          "id": 5286
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿سَنَسِمُهُ عَلى الخُرْطُوم﴾</span> سَنَجْعَلُ عَلى أنْفه عَلامَة يُعَيَّر بِها ما عاشَ فَخُطِمَ أنْفه بِالسَّيْفِ يَوْم بَدْر</p></div>",
      "verses": {
        "68:16": {
          "id": 5287
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّا بَلَوْناهُمْ﴾</span> امْتَحَنّا أهْل مَكَّة بِالقَحْطِ والجُوع <span class=\"qpc-hafs\">﴿كَما بَلَوْنا أصْحاب الجَنَّة﴾</span> أيْ أصْحاب البُسْتان <span class=\"qpc-hafs\">﴿إذْ أقَسَمُوا لِيَصْرِمُنَّها﴾</span> يَقْطَعُونَ ثَمَرَتها <span class=\"qpc-hafs\">﴿مُصْبِحِينَ﴾</span> وقْت الصَّباح كَيْ لا يَشْعُر بِهِمْ المَساكِين فَلا يُعْطُونَهُمْ مِنها ما كانَ أبُوهُمْ يَتَصَدَّق بِهِ عَلَيْهِمْ مِنها</p></div>",
      "verses": {
        "68:17": {
          "id": 5288
        }
      }
    },
    "18": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولا يَسْتَثْنُونَ﴾</span> فِي يَمِينهمْ بِمَشِيئَةِ اللَّه تَعالى والجُمْلَة مُسْتَأْنَفَة أيْ وشَأْنهمْ ذَلِكَ</p></div>",
      "verses": {
        "68:18": {
          "id": 5289
        }
      }
    },
    "19": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَطافَ عَلَيْها طائِف مِن رَبّك﴾</span> نار أحْرَقَتْها لَيْلًا</p></div>",
      "verses": {
        "68:19": {
          "id": 5290
        }
      }
    },
    "20": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَصْبَحَتْ كالصَّرِيمِ﴾</span> كاللَّيْلِ الشَّدِيد الظُّلْمَة أيْ سَوْداء</p></div>",
      "verses": {
        "68:20": {
          "id": 5291
        }
      }
    },
    "21": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "68:21": {
          "id": 5292
        }
      }
    },
    "22": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أنْ اُغْدُوا عَلى حَرْثكُمْ﴾</span> غَلَّتْكُمْ تَفْسِير لِتَنادَوْا أوْ أنْ مَصْدَرِيَّة أيْ بِأَنْ <span class=\"qpc-hafs\">﴿إنْ كُنْتُمْ صارِمِينَ﴾</span> مُرِيدِينَ القَطْع وجَواب الشَّرْط دَلَّ عَلَيْهِ ما قَبْله</p></div>",
      "verses": {
        "68:22": {
          "id": 5293
        }
      }
    },
    "23": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فانْطَلَقُوا وهُمْ يَتَخافَتُونَ﴾</span> يَتَسارُّونَ</p></div>",
      "verses": {
        "68:23": {
          "id": 5294
        }
      }
    },
    "24": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أنْ لا يَدْخُلَنها اليَوْم عَلَيْكُمْ مِسْكِين﴾</span> تَفْسِير لِما قَبْله أوْ أنْ مَصْدَرِيَّة أيْ بِأَنْ</p></div>",
      "verses": {
        "68:24": {
          "id": 5295
        }
      }
    },
    "25": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وغَدَوْا عَلى حَرْد﴾</span> مَنع لِلْفُقَراءِ <span class=\"qpc-hafs\">﴿قادِرِينَ﴾</span> عَلَيْهِ فِي ظَنّهمْ</p></div>",
      "verses": {
        "68:25": {
          "id": 5296
        }
      }
    },
    "26": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَلَمّا رَأَوْها﴾</span> سَوْداء مُحْتَرِقَة <span class=\"qpc-hafs\">﴿قالُوا إنّا لَضالُّونَ﴾</span> عَنْها أيْ لَيْسَتْ هَذِهِ ثُمَّ قالُوا لَمّا عَلِمُوها</p></div>",
      "verses": {
        "68:26": {
          "id": 5297
        }
      }
    },
    "27": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</span> ثَمَرَتها بِمَنعِنا الفُقَراء مِنها</p></div>",
      "verses": {
        "68:27": {
          "id": 5298
        }
      }
    },
    "28": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالَ أوْسَطهمْ﴾</span> خَيْرهمْ <span class=\"qpc-hafs\">﴿ألَمْ أقُلْ لَكُمْ لَوْلا﴾</span> هَلّا <span class=\"qpc-hafs\">﴿تُسَبِّحُونَ﴾</span> اللَّه تائِبِينَ</p></div>",
      "verses": {
        "68:28": {
          "id": 5299
        }
      }
    },
    "29": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالُوا سُبْحان رَبّنا إنّا كُنّا ظالِمِينَ﴾</span> بِمَنعِ الفُقَراء حَقّهمْ</p></div>",
      "verses": {
        "68:29": {
          "id": 5300
        }
      }
    },
    "30": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "68:30": {
          "id": 5301
        }
      }
    },
    "31": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالُوا يا﴾</span> لِلتَّنْبِيهِ <span class=\"qpc-hafs\">﴿ويْلنا﴾</span> هَلاكنا</p></div>",
      "verses": {
        "68:31": {
          "id": 5302
        }
      }
    },
    "32": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يُبْدِلنا﴾</span> بِالتَّشْدِيدِ والتَّخْفِيف <span class=\"qpc-hafs\">﴿خَيْرًا مِنها إنّا إلى رَبّنا راغِبُونَ﴾</span> لِيَقْبَل تَوْبَتنا ويَرُدّ عَلَيْنا خَيْرًا مِن جَنَّتنا رُوِيَ أنَّهُمْ أُبْدِلُوا خَيْرًا مِنها</p></div>",
      "verses": {
        "68:32": {
          "id": 5303
        }
      }
    },
    "33": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَذَلِكَ﴾</span> أيْ مِثْل العَذاب لِهَؤُلاءِ <span class=\"qpc-hafs\">﴿العَذاب﴾</span> لِمَن خالَفَ أمْرنا مِن كُفّار مَكَّة وغَيْرهمْ <span class=\"qpc-hafs\">﴿ولَعَذاب الآخِرَة أكْبَر لَوْ كانُوا يَعْلَمُونَ﴾</span> عَذابها ما خالَفُوا أمْرنا ونَزَلَ لَمّا قالُوا إنْ بَعَثَنا نُعْطى أفَضْل مِنكُمْ</p></div>",
      "verses": {
        "68:33": {
          "id": 5304
        }
      }
    },
    "34": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "68:34": {
          "id": 5305
        }
      }
    },
    "35": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أفَنَجْعَل المُسْلِمِينَ كالمُجْرِمِينَ﴾</span> أيْ تابِعِينَ لَهُمْ فِي العَطاء</p></div>",
      "verses": {
        "68:35": {
          "id": 5306
        }
      }
    },
    "36": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ما لَكُمْ كَيْفَ تَحْكُمُونَ﴾</span> هَذا الحُكْم الفاسِد</p></div>",
      "verses": {
        "68:36": {
          "id": 5307
        }
      }
    },
    "37": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أمْ﴾</span> أيْ بَلْ أ <span class=\"qpc-hafs\">﴿لَكُمْ كِتاب﴾</span> مُنَزَّل <span class=\"qpc-hafs\">﴿فِيهِ تَدْرُسُونَ﴾</span> أيْ تَقْرَءُونَ</p></div>",
      "verses": {
        "68:37": {
          "id": 5308
        }
      }
    },
    "38": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّ لَكُمْ فِيهِ لَما تَخَيَّرُونَ﴾</span> تَخْتارُونَ</p></div>",
      "verses": {
        "68:38": {
          "id": 5309
        }
      }
    },
    "39": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أمْ لَكُمْ أيْمان﴾</span> عُهُود <span class=\"qpc-hafs\">﴿عَلَيْنا بالِغَة﴾</span> واثِقَة <span class=\"qpc-hafs\">﴿إلى يَوْم القِيامَة﴾</span> مُتَعَلِّق مَعْنى بِعَلَيْنا وفِي هَذا الكَلام مَعْنى القَسَم أيْ أقْسَمْنا لَكُمْ وجَوابه <span class=\"qpc-hafs\">﴿إنّ لَكُمْ لَما تَحْكُمُونَ﴾</span> بِهِ لِأَنْفُسِكُمْ</p></div>",
      "verses": {
        "68:39": {
          "id": 5310
        }
      }
    },
    "40": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿سَلْهُمْ أيّهمْ بِذَلِكَ﴾</span> الحُكْم الَّذِي يَحْكُمُونَ بِهِ لِأَنْفُسِهِمْ مِن أنَّهُمْ يُعْطُونَ فِي الآخِرَة أفَضْل مِن المُؤْمِنِينَ <span class=\"qpc-hafs\">﴿زَعِيم﴾</span> كَفِيل لَهُمْ</p></div>",
      "verses": {
        "68:40": {
          "id": 5311
        }
      }
    },
    "41": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أمْ لَهُمْ﴾</span> أيْ عِنْدهمْ <span class=\"qpc-hafs\">﴿شُرَكاء﴾</span> مُوافِقُونَ لَهُمْ فِي هَذا القَوْل يَكْفُلُونَ بِهِ لَهُمْ فَإنْ كانَ كَذَلِكَ <span class=\"qpc-hafs\">﴿فَلْيَأْتُوا بِشُرَكائِهِمْ﴾</span> الكافِلِينَ لَهُمْ بِهِ</p></div>",
      "verses": {
        "68:41": {
          "id": 5312
        }
      }
    },
    "42": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَوْم يُكْشَف عَنْ ساق﴾</span> هُوَ عِبارَة عَنْ شِدَّة الأَمْر يَوْم القِيامَة لِلْحِسابِ والجَزاء يُقال: كَشَفَتْ الحَرْب عَنْ ساق: إذا اشْتَدَّ الأَمْر فِيها <span class=\"qpc-hafs\">﴿ويُدْعَوْنَ إلى السُّجُود﴾</span> امْتِحانًا لِإيمانِهِمْ <span class=\"qpc-hafs\">﴿فَلا يَسْتَطِيعُونَ﴾</span> تَصِير ظُهُورهمْ طَبَقًا واحِدًا</p></div>",
      "verses": {
        "68:42": {
          "id": 5313
        }
      }
    },
    "43": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿خاشِعَة﴾</span> حال مِن ضَمِير يَدْعُونَ أيْ ذَلِيلَة <span class=\"qpc-hafs\">﴿أبْصارهمْ﴾</span> لا يَرْفَعُونَها <span class=\"qpc-hafs\">﴿تَرْهَقهُمْ﴾</span> تَغْشاهُمْ <span class=\"qpc-hafs\">﴿ذِلَّة وقَدْ كانُوا يُدْعَوْنَ﴾</span> فِي الدُّنْيا <span class=\"qpc-hafs\">﴿إلى السُّجُود وهُمْ سالِمُونَ﴾</span> فَلا يَأْتُونَ بِهِ بِأَنْ لا يُصَلُّوا</p></div>",
      "verses": {
        "68:43": {
          "id": 5314
        }
      }
    },
    "44": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَذَرْنِي﴾</span> دَعْنِي <span class=\"qpc-hafs\">﴿ومَن يُكَذِّب بِهَذا الحَدِيث﴾</span> القُرْآن <span class=\"qpc-hafs\">﴿سَنَسْتَدْرِجُهُمْ﴾</span> نَأْخُذهُمْ قَلِيلًا قَلِيلًا</p></div>",
      "verses": {
        "68:44": {
          "id": 5315
        }
      }
    },
    "45": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأُمْلِي لَهُمْ﴾</span> أمْهِلْهُمْ <span class=\"qpc-hafs\">﴿إنّ كَيْدِي مَتِين﴾</span> شَدِيد لا يُطاق</p></div>",
      "verses": {
        "68:45": {
          "id": 5316
        }
      }
    },
    "46": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أمْ﴾</span> بَلْ أ <span class=\"qpc-hafs\">﴿تَسْأَلُهُمْ﴾</span> عَلى تَبْلِيغ الرِّسالَة <span class=\"qpc-hafs\">﴿أجْرًا فَهُمْ مِن مَغْرَم﴾</span> مِمّا يُعْطُونَكَهُ <span class=\"qpc-hafs\">﴿مُثْقَلُونَ﴾</span> فَلا يُؤْمِنُونَ لِذَلِكَ</p></div>",
      "verses": {
        "68:46": {
          "id": 5317
        }
      }
    },
    "47": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أمْ عِنْدهمْ الغَيْب﴾</span> أيْ اللَّوْح المَحْفُوظ الَّذِي فِيهِ الغَيْب <span class=\"qpc-hafs\">﴿فَهُمْ يَكْتُبُونَ﴾</span> مِنهُ ما يَقُولُونَ</p></div>",
      "verses": {
        "68:47": {
          "id": 5318
        }
      }
    },
    "48": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فاصْبِرْ لِحُكْمِ رَبّك﴾</span> فِيهِمْ بِما يَشاء <span class=\"qpc-hafs\">﴿ولا تَكُنْ كَصاحِبِ الحُوت﴾</span> فِي الضَّجَر والعَجَلَة وهُوَ يُونُس عَلَيْهِ السَّلام <span class=\"qpc-hafs\">﴿إذْ نادى﴾</span> دَعا رَبّه <span class=\"qpc-hafs\">﴿وهُوَ مَكْظُوم﴾</span> مَمْلُوء غَمًّا فِي بَطْن الحُوت</p></div>",
      "verses": {
        "68:48": {
          "id": 5319
        }
      }
    },
    "49": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لَوْلا أنْ تَدارَكَهُ﴾</span> لَوْلا أنْ أدْرَكَهُ <span class=\"qpc-hafs\">﴿نِعْمَة﴾</span> رَحْمَة <span class=\"qpc-hafs\">﴿مِن رَبّه لَنُبِذَ﴾</span> مِن بَطْن الحُوت <span class=\"qpc-hafs\">﴿بِالعَراءِ﴾</span> بِالأَرْضِ الفَضاء <span class=\"qpc-hafs\">﴿وهُوَ مَذْمُوم﴾</span> لَكِنَّهُ رُحِمَ فَنُبِذَ غَيْر مَذْمُوم</p></div>",
      "verses": {
        "68:49": {
          "id": 5320
        }
      }
    },
    "50": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فاجْتَباهُ رَبّه﴾</span> بِالنُّبُوَّةِ <span class=\"qpc-hafs\">﴿فَجَعَلَهُ مِن الصّالِحِينَ﴾</span> أيْ مِن الأَنْبِياء</p></div>",
      "verses": {
        "68:50": {
          "id": 5321
        }
      }
    },
    "51": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإنْ يَكاد الَّذِينَ كَفَرُوا لَيُزْلِقُونَكَ﴾</span> بِضَمِّ الياء وفَتْحها <span class=\"qpc-hafs\">﴿بِأَبْصارِهِمْ﴾</span> يَنْظُرُونَ إلَيْك نَظَرًا شَدِيدًا يَكاد أنْ يَصْرَعك ويُسْقِطك مِن مَكانك <span class=\"qpc-hafs\">﴿لَمّا سَمِعُوا الذِّكْر﴾</span> القُرْآن <span class=\"qpc-hafs\">﴿ويَقُولُونَ﴾</span> حَسَدًا <span class=\"qpc-hafs\">﴿إنّهُ لَمَجْنُون﴾</span> بِسَبَبِ القُرْآن الَّذِي جاءَ بِهِ</p></div>",
      "verses": {
        "68:51": {
          "id": 5322
        }
      }
    },
    "52": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما هُوَ﴾</span> أيْ القُرْآن <span class=\"qpc-hafs\">﴿إلّا ذِكْر﴾</span> مَوْعِظَة <span class=\"qpc-hafs\">﴿لِلْعالَمِينَ﴾</span> الجِنّ والإنْس لا يَحْدُث بِسَبَبِ جُنُون</p></div>",
      "verses": {
        "68:52": {
          "id": 5323
        }
      }
    }
  }
}