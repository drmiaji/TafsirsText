{
  "chapter": 44,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p>سُورَة الدُّخان [ مَكِّيَّة إلّا آيَة ١٥ وآياتها ٥٦ أوْ ٥٧ أوْ ٥٩ ]</p><p><span class=\"qpc-hafs\">﴿حم﴾</span> اللَّه أعْلَم بِمُرادِهِ بِهِ</p></div>",
      "verses": {
        "44:1": {
          "id": 4415
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والكِتاب﴾</span> القُرْآن <span class=\"qpc-hafs\">﴿المُبِين﴾</span> المُظْهِر الحَلال مِن الحَرام</p></div>",
      "verses": {
        "44:2": {
          "id": 4416
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّا أنْزَلْناهُ فِي لَيْلَة مُبارَكَة﴾</span> هِيَ لَيْلَة القَدْر أوْ لَيْلَة النِّصْف مِن شَعْبان نَزَلَ فِيها مِن أُمّ الكِتاب مِن السَّماء السّابِعَة إلى سَماء الدُّنْيا <span class=\"qpc-hafs\">﴿إنّا كُنّا مُنْذِرِينَ﴾</span> مُخَوِّفِينَ بِهِ</p></div>",
      "verses": {
        "44:3": {
          "id": 4417
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فِيها﴾</span> أيْ فِي لَيْلَة القَدْر أوْ لَيْلَة النِّصْف مِن شَعْبان <span class=\"qpc-hafs\">﴿يُفْرَق﴾</span> يُفْصَل <span class=\"qpc-hafs\">﴿كُلّ أمْر حَكِيم﴾</span> مُحَكَّم مِن الأَرْزاق والآجال وغَيْرهما الَّتِي تَكُون فِي السَّنَة إلى مِثْل تِلْكَ اللَّيْلَة</p></div>",
      "verses": {
        "44:4": {
          "id": 4418
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أمْرًا﴾</span> فَرْقًا <span class=\"qpc-hafs\">﴿مِن عِنْدنا إنّا كُنّا مُرْسِلِينَ﴾</span> الرُّسُل مُحَمَّدًا ومَن قَبْله</p></div>",
      "verses": {
        "44:5": {
          "id": 4419
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿رَحْمَة﴾</span> رَأْفَة بِالمُرْسَلِ إلَيْهِمْ <span class=\"qpc-hafs\">﴿مِن رَبّك إنّهُ هُوَ السَّمِيع﴾</span> لِأَقْوالِهِمْ <span class=\"qpc-hafs\">﴿العَلِيم﴾</span> بِأَفْعالِهِمْ</p></div>",
      "verses": {
        "44:6": {
          "id": 4420
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿رَبّ السَّمَوات والأَرْض وما بَيْنهما﴾</span> بِرَفْعِ رَبّ خَبَر ثالِث وبِجَرِّهِ بَدَل مِن رَبّك <span class=\"qpc-hafs\">﴿إنْ كُنْتُمْ﴾</span> يا أهْل مَكَّة <span class=\"qpc-hafs\">﴿مُوقِنِينَ﴾</span> بِأَنَّهُ تَعالى رَبّ السَّماوات والأَرْض فَأَيْقَنُوا بِأَنَّ مُحَمَّدًا رَسُوله</p></div>",
      "verses": {
        "44:7": {
          "id": 4421
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "44:8": {
          "id": 4422
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿بَلْ هُمْ فِي شَكّ﴾</span> مِن البَعْث <span class=\"qpc-hafs\">﴿يَلْعَبُونَ﴾</span> اسْتِهْزاء بِك يا مُحَمَّد فَقالَ: \"اللَّهُمَّ أعِنِّي عَلَيْهِمْ بِسَبْعٍ كَسَبْعِ يُوسُف\"</p></div>",
      "verses": {
        "44:9": {
          "id": 4423
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فارْتَقِبْ يَوْم تَأْتِي السَّماء بِدُخانٍ مُبِين﴾</span> فَأَجْدَبَتْ الأَرْض واشْتَدَّ بِهِمْ الجُوع إلى أنْ رَأَوْا مِن شِدَّته كَهَيْئَةِ الدُّخان بَيْن السَّماء والأَرْض</p></div>",
      "verses": {
        "44:10": {
          "id": 4424
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَغْشى النّاس﴾</span> فَقالُوا <span class=\"qpc-hafs\">﴿هَذا عَذاب ألِيم﴾</span></p></div>",
      "verses": {
        "44:11": {
          "id": 4425
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿رَبّنا اكْشِفْ عَنّا العَذاب إنّا مُؤْمِنُونَ﴾</span> مُصَدِّقُونَ نَبِيّك</p></div>",
      "verses": {
        "44:12": {
          "id": 4426
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أنّى لَهُمْ الذِّكْرى﴾</span> أيْ لا يَنْفَعهُمْ الإيمان عِنْد نُزُول العَذاب <span class=\"qpc-hafs\">﴿وقَدْ جاءَهُمْ رَسُول مُبِين﴾</span> بَيِّن الرِّسالَة</p></div>",
      "verses": {
        "44:13": {
          "id": 4427
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ تَوَلَّوْا عَنْهُ وقالُوا مُعَلَّم﴾</span> أيْ يُعَلِّمهُ القُرْآن بَشَر</p></div>",
      "verses": {
        "44:14": {
          "id": 4428
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّا كاشِفُوا العَذاب﴾</span> أيْ الجُوع عَنْكُمْ زَمَنًا <span class=\"qpc-hafs\">﴿قَلِيلًا﴾</span> فَكَشَفَ عَنْهُمْ <span class=\"qpc-hafs\">﴿إنّكُمْ عائِدُونَ﴾</span> إلى كُفْركُمْ فَعادُوا إلَيْهِ</p></div>",
      "verses": {
        "44:15": {
          "id": 4429
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p>اُذْكُرْ <span class=\"qpc-hafs\">﴿يَوْم نَبْطِش البَطْشَة الكُبْرى﴾</span> هُوَ يَوْم بَدْر والبَطْش الأَخْذ بِقُوَّةٍ <span class=\"qpc-hafs\">﴿إنّا مُنْتَقِمُونَ﴾</span> مِنهُمْ</p></div>",
      "verses": {
        "44:16": {
          "id": 4430
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولَقَدْ فَتَنّا﴾</span> بَلَوْنا <span class=\"qpc-hafs\">﴿قَبْلهمْ قَوْم فِرْعَوْن﴾</span> مَعَهُ <span class=\"qpc-hafs\">﴿وجاءَهُمْ رَسُول﴾</span> هُوَ مُوسى عَلَيْهِ السَّلام <span class=\"qpc-hafs\">﴿كَرِيم﴾</span> عَلى اللَّه تَعالى</p></div>",
      "verses": {
        "44:17": {
          "id": 4431
        }
      }
    },
    "18": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أنْ﴾</span> أيْ بِأَنْ <span class=\"qpc-hafs\">﴿أدُّوا إلَيَّ﴾</span> ما أدْعُوكُمْ إلَيْهِ مِن الإيمان أيْ أظْهِرُوا إيمانكُمْ لِي يا <span class=\"qpc-hafs\">﴿عِباد اللَّه إنِّي لَكُمْ رَسُول أمِين﴾</span> عَلى ما أُرْسِلْت بِهِ</p></div>",
      "verses": {
        "44:18": {
          "id": 4432
        }
      }
    },
    "19": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَنْ لا تَعْلُوا﴾</span> تَتَجَبَّرُوا <span class=\"qpc-hafs\">﴿عَلى اللَّه﴾</span> بِتَرْكِ طاعَته <span class=\"qpc-hafs\">﴿إنِّي آتِيكُمْ بِسُلْطانٍ﴾</span> بُرْهان <span class=\"qpc-hafs\">﴿مُبِين﴾</span> بَيِّن عَلى رِسالَتِي فَتَوَعَّدَهُ بِالرَّجْمِ</p></div>",
      "verses": {
        "44:19": {
          "id": 4433
        }
      }
    },
    "20": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإنِّي عُذْت بِرَبِّي ورَبّكُمْ أنْ تَرْجُمُونِي﴾</span> بِالحِجارَةِ</p></div>",
      "verses": {
        "44:20": {
          "id": 4434
        }
      }
    },
    "21": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإنْ لَمْ تُؤْمِنُوا لِي﴾</span> تُصَدِّقُونِي <span class=\"qpc-hafs\">﴿فاعْتَزِلُونِ﴾</span> فاتْرُكُوا أذايَ فَلَمْ يَتْرُكُوهُ</p></div>",
      "verses": {
        "44:21": {
          "id": 4435
        }
      }
    },
    "22": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَدَعا رَبّه أنَّ﴾</span> أيْ بِأَنَّ <span class=\"qpc-hafs\">﴿هَؤُلاءِ قَوْم مُجْرِمُونَ﴾</span> مُشْرِكُونَ</p></div>",
      "verses": {
        "44:22": {
          "id": 4436
        }
      }
    },
    "23": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَسْرِ﴾</span> بِقَطْعِ الهَمْزَة ووَصْلها <span class=\"qpc-hafs\">﴿بِعِبادِي﴾</span> بَنِي إسْرائِيل <span class=\"qpc-hafs\">﴿لَيْلًا إنّكُمْ مُتَّبِعُونَ﴾</span> يَتَّبِعكُمْ فِرْعَوْن وقَوْمه</p></div>",
      "verses": {
        "44:23": {
          "id": 4437
        }
      }
    },
    "24": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿واتْرُكِ البَحْر﴾</span> إذا قَطَعْته أنْتَ وأَصْحابك <span class=\"qpc-hafs\">﴿رَهْوًا﴾</span> ساكِنًا مُنْفَرِجًا حَتّى يَدْخُلهُ القِبْط <span class=\"qpc-hafs\">﴿إنّهُمْ جُنْد مُغْرَقُونَ﴾</span> فاطْمَأَنَّ بِذَلِكَ فَأُغْرِقُوا</p></div>",
      "verses": {
        "44:24": {
          "id": 4438
        }
      }
    },
    "25": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَمْ تَرَكُوا مِن جَنّات﴾</span> بَساتِين <span class=\"qpc-hafs\">﴿وعُيُون﴾</span> تَجْرِي</p></div>",
      "verses": {
        "44:25": {
          "id": 4439
        }
      }
    },
    "26": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وزُرُوع ومَقام كَرِيم﴾</span> مَجْلِس حَسَن</p></div>",
      "verses": {
        "44:26": {
          "id": 4440
        }
      }
    },
    "27": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ونِعْمَة﴾</span> مُتْعَة <span class=\"qpc-hafs\">﴿كانُوا فِيها فاكِهِينَ﴾</span> ناعِمِينَ</p></div>",
      "verses": {
        "44:27": {
          "id": 4441
        }
      }
    },
    "28": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَذَلِكَ﴾</span> خَبَر مُبْتَدَأ أيْ الأَمْر <span class=\"qpc-hafs\">﴿وأَوْرَثْناها﴾</span> أيْ أمْوالهمْ <span class=\"qpc-hafs\">﴿قَوْمًا آخَرِينَ﴾</span> أيْ بَنِي إسْرائِيل</p></div>",
      "verses": {
        "44:28": {
          "id": 4442
        }
      }
    },
    "29": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَما بَكَتْ عَلَيْهِمُ السَّماء والأَرْض﴾</span> بِخِلافِ المُؤْمِنِينَ يَبْكِي عَلَيْهِمْ بِمَوْتِهِمْ مُصَلّاهُمْ مِن الأَرْض ومُصْعَد عَمَلهمْ مِن السَّماء <span class=\"qpc-hafs\">﴿وما كانُوا مُنْظَرِينَ﴾</span> مُؤَخِّرِينَ لِلتَّوْبَةِ</p></div>",
      "verses": {
        "44:29": {
          "id": 4443
        }
      }
    },
    "30": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولَقَدْ نَجَّيْنا بَنِي إسْرائِيل مِنَ العَذاب المُهِين﴾</span> قَتْل الأَبْناء واسْتِخْدام النِّساء</p></div>",
      "verses": {
        "44:30": {
          "id": 4444
        }
      }
    },
    "31": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿مِن فِرْعَوْن﴾</span> قِيلَ بَدَل مِن العَذاب بِتَقْدِيرِ مُضاف أيْ عَذاب وقِيلَ حال مِن العَذاب</p></div>",
      "verses": {
        "44:31": {
          "id": 4445
        }
      }
    },
    "32": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولَقَدِ اخْتَرْناهُمْ﴾</span> أيْ بَنِي إسْرائِيل <span class=\"qpc-hafs\">﴿عَلى عِلْم﴾</span> مِنّا بِحالِهِمْ <span class=\"qpc-hafs\">﴿عَلى العالَمِينَ﴾</span> أيْ عالِمِي زَمانهمْ أيْ العُقَلاء</p></div>",
      "verses": {
        "44:32": {
          "id": 4446
        }
      }
    },
    "33": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وآتَيْناهُمْ مِنَ الآيات ما فِيهِ بَلاء مُبِين﴾</span> نِعْمَة ظاهِرَة مِن فَلْق البَحْر والمَنّ والسَّلْوى وغَيْرها</p></div>",
      "verses": {
        "44:33": {
          "id": 4447
        }
      }
    },
    "34": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّ هَؤُلاءِ﴾</span> أيْ كُفّار مَكَّة</p></div>",
      "verses": {
        "44:34": {
          "id": 4448
        }
      }
    },
    "35": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنْ هِيَ﴾</span> ما المَوْتَة الَّتِي بَعْدها الحَياة <span class=\"qpc-hafs\">﴿إلّا مَوْتَتنا الأُولى﴾</span> أيْ وهُمْ نُطَف <span class=\"qpc-hafs\">﴿وما نَحْنُ بِمُنْشَرِينَ﴾</span> بِمَبْعُوثِينَ أحْياء بَعْد الثّانِيَة</p></div>",
      "verses": {
        "44:35": {
          "id": 4449
        }
      }
    },
    "36": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأْتُوا بِآبائِنا﴾</span> أحْياء <span class=\"qpc-hafs\">﴿إنْ كُنْتُمْ صادِقِينَ﴾</span> أنّا نُبْعَث بَعْد مَوْتنا أيْ نُحْيا</p></div>",
      "verses": {
        "44:36": {
          "id": 4450
        }
      }
    },
    "37": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أهُوَ خَيْر أمْ قَوْم تُبَّع﴾</span> هُوَ نَبِيّ أوْ رَجُل صالِح <span class=\"qpc-hafs\">﴿والَّذِينَ مِن قَبْلهمْ﴾</span> مِن الأُمَم <span class=\"qpc-hafs\">﴿أهْلَكْناهُمْ﴾</span> بِكُفْرِهِمْ والمَعْنى لَيْسُوا أقْوى مِنهُمْ وأُهْلِكُوا</p></div>",
      "verses": {
        "44:37": {
          "id": 4451
        }
      }
    },
    "38": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما خَلَقْنا السَّمَوات والأَرْض وما بَيْنهما لاعِبِينَ﴾</span> بِخَلْقِ ذَلِكَ حال</p></div>",
      "verses": {
        "44:38": {
          "id": 4452
        }
      }
    },
    "39": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ما خَلَقْناهُما﴾</span> وما بَيْنهما <span class=\"qpc-hafs\">﴿إلّا بِالحَقِّ﴾</span> أيْ مُحِقِّينَ فِي ذَلِكَ لِيُسْتَدَلّ بِهِ عَلى قُدْرَتنا ووَحْدانِيّتنا وغَيْر ذَلِكَ <span class=\"qpc-hafs\">﴿ولَكِنَّ أكْثَرهمْ﴾</span> أيْ كُفّار مَكَّة</p></div>",
      "verses": {
        "44:39": {
          "id": 4453
        }
      }
    },
    "40": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّ يَوْم الفَصْل﴾</span> يَوْم القِيامَة يَفْصِل اللَّه فِيهِ بَيْن العِباد <span class=\"qpc-hafs\">﴿مِيقاتهمْ أجْمَعِينَ﴾</span> لِلْعَذابِ الدّائِم</p></div>",
      "verses": {
        "44:40": {
          "id": 4454
        }
      }
    },
    "41": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَوْم لا يُغْنِي مَوْلى عَنْ مَوْلى﴾</span> بِقَرابَةٍ أوْ صَداقَة أيْ لا يَدْفَع عَنْهُ، ويَوْم بَدَل مِن يَوْم الفَصْل <span class=\"qpc-hafs\">﴿شَيْئًا﴾</span> مِن العَذاب <span class=\"qpc-hafs\">﴿ولا هُمْ يُنْصَرُونَ﴾</span> يُمْنَعُونَ مِنهُ</p></div>",
      "verses": {
        "44:41": {
          "id": 4455
        }
      }
    },
    "42": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إلّا مَن رَحِمَ اللَّه﴾</span> وهُمْ المُؤْمِنُونَ فَإنَّهُ يَشْفَع بَعْضهمْ لِبَعْضٍ بِإذْنِ اللَّه <span class=\"qpc-hafs\">﴿إنّهُ هُوَ العَزِيز﴾</span> الغالِب فِي انْتِقامه مِن الكُفّار <span class=\"qpc-hafs\">﴿الرَّحِيم﴾</span> بِالمُؤْمِنِينَ</p></div>",
      "verses": {
        "44:42": {
          "id": 4456
        }
      }
    },
    "43": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّ شَجَرَة الزَّقُّوم﴾</span> هِيَ مِن أخْبَث الشَّجَر المُرّ بتِهامَة يُنْبِتها اللَّه تَعالى فِي الجَحِيم</p></div>",
      "verses": {
        "44:43": {
          "id": 4457
        }
      }
    },
    "44": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿طَعام الأَثِيم﴾</span> أبِي جَهْل وأَصْحابه ذَوِي الإثْم الكَبِير</p></div>",
      "verses": {
        "44:44": {
          "id": 4458
        }
      }
    },
    "45": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كالمُهْلِ﴾</span> أيْ كَدُرْدِيِّ الزَّيْت الأَسْوَد خَبَر ثانٍ <span class=\"qpc-hafs\">﴿يَغْلِي فِي البُطُون﴾</span> بالفَوْقانية خَبَر ثالِث وبالتَّحْتانِيّة حال مِن المُهْل</p></div>",
      "verses": {
        "44:45": {
          "id": 4459
        }
      }
    },
    "46": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَغَلْيِ الحَمِيم﴾</span> الماء الشَّدِيد الحَرارَة</p></div>",
      "verses": {
        "44:46": {
          "id": 4460
        }
      }
    },
    "47": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿خُذُوهُ﴾</span> يُقال لِلزَّبانِيَةِ: خُذُوا الأَثِيم <span class=\"qpc-hafs\">﴿فاعْتِلُوهُ﴾</span> بِكَسْرِ التّاء وضَمّها جُرُّوهُ بِغِلْظَةٍ وشِدَّة <span class=\"qpc-hafs\">﴿إلى سَواء الجَحِيم﴾</span> وسَط النّار</p></div>",
      "verses": {
        "44:47": {
          "id": 4461
        }
      }
    },
    "48": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ صُبُّوا فَوْق رَأْسه مِن عَذاب الحَمِيم﴾</span> أيْ مِن الحَمِيم الَّذِي لا يُفارِقهُ العَذاب فَهُوَ أبْلَغ مِمّا فِي آيَة \"يُصَبّ مِن فَوْق رُءُوسِهِمُ الحَمِيم\" <span class=\"qpc-hafs\">﴿﴾</span></p></div>",
      "verses": {
        "44:48": {
          "id": 4462
        }
      }
    },
    "49": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p>ويُقال لَهُ <span class=\"qpc-hafs\">﴿ذُقْ﴾</span> أيْ العَذاب <span class=\"qpc-hafs\">﴿إنّك أنْتَ العَزِيز الكَرِيم﴾</span> بِزَعْمِك وقَوْلك ما بَيْن جَبَلَيْها أعَزّ وأَكْرَم مِنِّي</p></div>",
      "verses": {
        "44:49": {
          "id": 4463
        }
      }
    },
    "50": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّ هَذا﴾</span> الَّذِي تَرَوْنَ مِن العَذاب <span class=\"qpc-hafs\">﴿ما كُنْتُمْ بِهِ تَمْتَرُونَ﴾</span> فِيهِ تَشُكُّونَ</p></div>",
      "verses": {
        "44:50": {
          "id": 4464
        }
      }
    },
    "51": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّ المُتَّقِينَ فِي مَقام﴾</span> مَجْلِس <span class=\"qpc-hafs\">﴿أمِين﴾</span> يُؤْمَن فِيهِ الخَوْف</p></div>",
      "verses": {
        "44:51": {
          "id": 4465
        }
      }
    },
    "52": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فِي جَنّات﴾</span> بَساتِين</p></div>",
      "verses": {
        "44:52": {
          "id": 4466
        }
      }
    },
    "53": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَلْبَسُونَ مِن سُنْدُس وإسْتَبْرَق﴾</span> أيْ ما رَقَّ مِن الدِّيباج وما غَلُظَ مِنهُ <span class=\"qpc-hafs\">﴿مُتَقابِلِينَ﴾</span> حال أيْ لا يَنْظُر بَعْضهمْ إلى قَفا بَعْض لِدَوَرانِ الأَسِرَّة بِهِمْ</p></div>",
      "verses": {
        "44:53": {
          "id": 4467
        }
      }
    },
    "54": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَذَلِكَ﴾</span> يُقَدَّر قَبْله الأَمْر <span class=\"qpc-hafs\">﴿وزَوَّجْناهُمْ﴾</span> مِن التَّزْوِيج أوْ قَرَنّاهُمْ <span class=\"qpc-hafs\">﴿بِحُورٍ عِين﴾</span> بِنِساءٍ بِيض واسِعات الأَعْيُن حِسانها</p></div>",
      "verses": {
        "44:54": {
          "id": 4468
        }
      }
    },
    "55": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَدْعُونَ﴾</span> يَطْلُبُونَ الخَدَم <span class=\"qpc-hafs\">﴿فِيها﴾</span> أيْ الجَنَّة أنْ يَأْتُوا <span class=\"qpc-hafs\">﴿بِكُلِّ فاكِهَة﴾</span> مِنها <span class=\"qpc-hafs\">﴿آمِنِينَ﴾</span> مِن انْقِطاعها ومَضَرَّتها ومِن كُلّ مَخُوف حال</p></div>",
      "verses": {
        "44:55": {
          "id": 4469
        }
      }
    },
    "56": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لا يَذُوقُونَ فِيها المَوْت إلّا المَوْتَة الأُولى﴾</span> أيْ الَّتِي فِي الدُّنْيا بَعْد حَياتهمْ فِيها قالَ بَعْضهمْ إلّا بِمَعْنى بَعْد</p></div>",
      "verses": {
        "44:56": {
          "id": 4470
        }
      }
    },
    "57": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَضْلًا﴾</span> مَصْدَر بِمَعْنى تَفَضُّلًا مَنصُوب بِتَفَضُّلٍ مُقَدَّرًا</p></div>",
      "verses": {
        "44:57": {
          "id": 4471
        }
      }
    },
    "58": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَإنَّما يَسَّرْناهُ﴾</span> سَهَّلْنا القُرْآن <span class=\"qpc-hafs\">﴿بِلِسانِك﴾</span> بِلُغَتِك لِتَفْهَمهُ العَرَب مِنك <span class=\"qpc-hafs\">﴿لَعَلَّهُمْ يَتَذَكَّرُونَ﴾</span> يَتَّعِظُونَ فَيُؤْمِنُونَ لَكِنَّهُمْ لا يُؤْمِنُونَ</p></div>",
      "verses": {
        "44:58": {
          "id": 4472
        }
      }
    },
    "59": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فارْتَقِبْ﴾</span> انْتَظِرْ هَلاكهمْ <span class=\"qpc-hafs\">﴿إنّهُمْ مُرْتَقِبُونَ﴾</span> هَلاكك وهَذا قَبْل نُزُول الأَمْر بِجِهادِهِمْ</p></div>",
      "verses": {
        "44:59": {
          "id": 4473
        }
      }
    }
  }
}