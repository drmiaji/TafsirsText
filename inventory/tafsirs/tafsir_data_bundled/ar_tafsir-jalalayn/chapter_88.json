{
  "chapter": 88,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿هَلْ﴾</span> قَدْ <span class=\"qpc-hafs\">﴿أتاك حَدِيث الغاشِيَة﴾</span> القِيامَة لِأَنَّها تَغْشى الخَلائِق بِأَهْوالِها</p></div>",
      "verses": {
        "88:1": {
          "id": 5968
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وُجُوه يَوْمئِذٍ﴾</span> عَبَّرَ بِها عَنْ الذَّوات فِي المَوْضِعَيْنِ <span class=\"qpc-hafs\">﴿خاشِعَة﴾</span> ذَلِيلَة</p></div>",
      "verses": {
        "88:2": {
          "id": 5969
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿عامِلَة ناصِبَة﴾</span> ذات نَصَب وتَعَب بِالسَّلاسِلِ والأَغْلال</p></div>",
      "verses": {
        "88:3": {
          "id": 5970
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿تَصْلى﴾</span> بِفَتْحِ التّاء وضَمّها \" نارًا حامِيَة \"</p></div>",
      "verses": {
        "88:4": {
          "id": 5971
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿تُسْقى مِن عَيْن آنِيَّة﴾</span> شَدِيدَة الحَرارَة</p></div>",
      "verses": {
        "88:5": {
          "id": 5972
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لَيْسَ لَهُمْ طَعام إلّا مِن ضَرِيع﴾</span> هُوَ نَوْع مِن الشَّوْك لا تَرْعاهُ دابَّة لِخُبْثِهِ</p></div>",
      "verses": {
        "88:6": {
          "id": 5973
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "88:7": {
          "id": 5974
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وُجُوه يَوْمئِذٍ ناعِمَة﴾</span> حَسَنَة</p></div>",
      "verses": {
        "88:8": {
          "id": 5975
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لِسَعْيِها﴾</span> فِي الدُّنْيا بِالطّاعَةِ <span class=\"qpc-hafs\">﴿راضِيَة﴾</span> فِي الآخِرَة لَمّا رَأَتْ ثَوابه</p></div>",
      "verses": {
        "88:9": {
          "id": 5976
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فِي جَنَّة عالِيَة﴾</span> حِسًّا ومَعْنًى</p></div>",
      "verses": {
        "88:10": {
          "id": 5977
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لا تَسْمَع﴾</span> بِالياءِ والتّاء <span class=\"qpc-hafs\">﴿فِيها لاغِيَة﴾</span> أيْ نَفْس ذات لَغْو: هَذَيان مِن الكَلام</p></div>",
      "verses": {
        "88:11": {
          "id": 5978
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فِيها عَيْن جارِيَة﴾</span> بِالماءِ بِمَعْنى عُيُون</p></div>",
      "verses": {
        "88:12": {
          "id": 5979
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فِيها سُرَر مَرْفُوعَة﴾</span> ذاتًا وقَدْرًا ومَحِلًّا</p></div>",
      "verses": {
        "88:13": {
          "id": 5980
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَكْواب﴾</span> أقْداح لا عُرا لَها <span class=\"qpc-hafs\">﴿مَوْضُوعَة﴾</span> عَلى حافّات العُيُون مُعَدَّة لِشُرْبِهِمْ</p></div>",
      "verses": {
        "88:14": {
          "id": 5981
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ونَمارِق﴾</span> وسائِد <span class=\"qpc-hafs\">﴿مَصْفُوفَة﴾</span> بَعْضها بِجَنْبِ بَعْض يُسْتَنَد إلَيْها</p></div>",
      "verses": {
        "88:15": {
          "id": 5982
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وزَرابِيّ﴾</span> بُسُط طَنافِس لَها خَمْل <span class=\"qpc-hafs\">﴿مَبْثُوثَة﴾</span> مَبْسُوطَة</p></div>",
      "verses": {
        "88:16": {
          "id": 5983
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أفَلا يَنْظُرُونَ﴾</span> أيْ كُفّار مَكَّة نَظَر اِعْتِبار <span class=\"qpc-hafs\">﴿إلى الإبِل كَيْف خُلِقَتْ﴾</span></p></div>",
      "verses": {
        "88:17": {
          "id": 5984
        }
      }
    },
    "18": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "88:18": {
          "id": 5985
        }
      }
    },
    "19": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "88:18",
      "verses": {
        "88:19": {
          "id": 5986
        }
      }
    },
    "20": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإلى الأَرْض كَيْف سُطِحَتْ﴾</span> أيْ بُسِطَتْ، فَيَسْتَدِلُّونَ بِها عَلى قُدْرَة اللَّه تَعالى ووَحْدانِيّته، وصُدِّرَتْ بِالإبِلِ لِأَنَّهُمْ أشَدّ مُلابَسَة لَها مِن غَيْرها، وقَوْله: \" سُطِحَتْ \" ظاهِر فِي أنَّ الأَرْض سَطْح، وعَلَيْهِ عُلَماء الشَّرْع، لا كُرَة كَما قالَهُ أهْل الهَيْئَة وإنْ لَمْ يَنْقُض رُكْنًا مِن أرْكان الشَّرْع</p></div>",
      "verses": {
        "88:20": {
          "id": 5987
        }
      }
    },
    "21": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَذَكِّرْ﴾</span> هُمْ نِعَم اللَّه ودَلائِل تَوْحِيده \" إنَّما أنْتَ مُذَكِّر \"</p></div>",
      "verses": {
        "88:21": {
          "id": 5988
        }
      }
    },
    "22": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لَسْت عَلَيْهِمْ بِمُصَيْطِر﴾</span> وفِي قِراءَة بِالسِّينِ بَدَل الصّاد، أيْ بِمُسَلَّطٍ وهَذا قَبْل الأَمْر بِالجِهادِ</p></div>",
      "verses": {
        "88:22": {
          "id": 5989
        }
      }
    },
    "23": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إلّا﴾</span> لَكِنْ <span class=\"qpc-hafs\">﴿مَن تَوَلّى﴾</span> أعْرَضَ عَنْ الإيمان <span class=\"qpc-hafs\">﴿وكَفَرَ﴾</span> بِالقُرْآنِ</p></div>",
      "verses": {
        "88:23": {
          "id": 5990
        }
      }
    },
    "24": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَيُعَذِّبهُ اللَّه العَذاب الأَكْبَر﴾</span> عَذاب الآخِرَة والأَصْغَر عَذاب الدُّنْيا بِالقَتْلِ والأَسْر</p></div>",
      "verses": {
        "88:24": {
          "id": 5991
        }
      }
    },
    "25": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّ إلَيْنا إيابهمْ﴾</span> رُجُوعهمْ بَعْد المَوْت</p></div>",
      "verses": {
        "88:25": {
          "id": 5992
        }
      }
    },
    "26": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ إنَّ عَلَيْنا حِسابهمْ﴾</span> جَزاءَهُمْ لا نَتْرُكهُ أبَدًا.</p></div>",
      "verses": {
        "88:26": {
          "id": 5993
        }
      }
    }
  }
}