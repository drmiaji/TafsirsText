    "50": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَبِأَيِّ حَدِيث بَعْده﴾</span> أيْ القُرْآن <span class=\"qpc-hafs\">﴿يُؤْمِنُونَ﴾</span> أيْ لا يَمْكَن إيمانهمْ بِغَيْرِهِ مِن كُتُب اللَّه بَعْد تَكْذِيبهمْ بِهِ لِاشْتِمالِهِ عَلى الإعْجاز الَّذِي لَمْ يَشْتَمِل عَلَيْهِ غَيْره.</p></div>",
      "verses": {
