    "48": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإذا قِيلَ لَهُمْ ارْكَعُوا﴾</span> صَلُّوا <span class=\"qpc-hafs\">﴿لا يَرْكَعُونَ﴾</span> لا يُصَلُّونَ</p></div>",
      "verses": {
