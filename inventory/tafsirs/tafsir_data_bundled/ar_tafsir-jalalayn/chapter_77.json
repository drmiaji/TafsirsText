    "46": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كُلُوا وتَمَتَّعُوا﴾</span> خِطاب لِلْكُفّارِ فِي الدُّنْيا <span class=\"qpc-hafs\">﴿قَلِيلًا﴾</span> مِن الزَّمان وغايَته إلى المَوْت وفِي هَذا تَهْدِيد لَهُمْ</p></div>",
      "verses": {
        "77:46": {
          "id": 5668
        }
      }
    },
