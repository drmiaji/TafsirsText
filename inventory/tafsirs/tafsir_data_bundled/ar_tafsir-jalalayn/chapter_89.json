{
  "chapter": 89,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والفَجْر﴾</span> أيْ فَجْر كُلّ يَوْم</p></div>",
      "verses": {
        "89:1": {
          "id": 5994
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولَيالٍ عَشْر﴾</span> أيْ عَشْر ذِي الحِجَّة</p></div>",
      "verses": {
        "89:2": {
          "id": 5995
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والشَّفْع﴾</span> الزَّوْج <span class=\"qpc-hafs\">﴿والوَتْر﴾</span> بِفَتْحِ الواو وكَسْرها لُغَتانِ: الفَرْد</p></div>",
      "verses": {
        "89:3": {
          "id": 5996
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿واللَّيْل إذا يَسْرِ﴾</span> مُقْبِلًا ومُدْبِرًا</p></div>",
      "verses": {
        "89:4": {
          "id": 5997
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿هَلْ فِي ذَلِكَ﴾</span> القَسَم <span class=\"qpc-hafs\">﴿قَسَم لِذِي حِجْر﴾</span> عَقْل، وجَواب القَسَم مَحْذُوف أيْ: لَتُعَذَّبُنَّ يا كُفّار مَكَّة</p></div>",
      "verses": {
        "89:5": {
          "id": 5998
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ألَمْ تَرى﴾</span> تَعْلَم يا مُحَمَّد <span class=\"qpc-hafs\">﴿كَيْف فَعَلَ رَبّك بِعادٍ﴾</span></p></div>",
      "verses": {
        "89:6": {
          "id": 5999
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إرَم﴾</span> هِيَ عاد الأُولى، فَإرَم عَطْف بَيان أوْ بَدَل، ومَنع الصَّرْف لِلْعَلَمِيَّةِ والتَّأْنِيث <span class=\"qpc-hafs\">﴿ذات العِماد﴾</span> أيْ الطُّول كانَ طُول الطَّوِيل مِنهُمْ أرْبَعمِائَةِ ذِراع</p></div>",
      "verses": {
        "89:7": {
          "id": 6000
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿الَّتِي لَمْ يُخْلَق مِثْلها فِي البِلاد﴾</span> فِي بَطْشهمْ وقُوَّتهمْ</p></div>",
      "verses": {
        "89:8": {
          "id": 6001
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وثَمُود الَّذِينَ جابُوا﴾</span> قَطَعُوا <span class=\"qpc-hafs\">﴿الصَّخْر﴾</span> جَمْع صَخْرَة واِتَّخَذُوها بُيُوتًا <span class=\"qpc-hafs\">﴿بِالوادِ﴾</span> وادِي القُرى</p></div>",
      "verses": {
        "89:9": {
          "id": 6002
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وفِرْعَوْن ذِي الأَوْتاد﴾</span> كانَ يَتِد أرْبَعَة أوْتاد يَشُدّ إلَيْها يَدَيْ ورِجْلَيْ مَن يُعَذِّبهُ</p></div>",
      "verses": {
        "89:10": {
          "id": 6003
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿الَّذِينَ طَغَوْا﴾</span> تَجَبَّرُوا \" فِي البِلاد \"</p></div>",
      "verses": {
        "89:11": {
          "id": 6004
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَكْثَرُوا فِيها الفَساد﴾</span> القَتْل وغَيْره</p></div>",
      "verses": {
        "89:12": {
          "id": 6005
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَصَبَّ عَلَيْهِمْ رَبّك سَوْط﴾</span> نَوْع \" عَذاب \"</p></div>",
      "verses": {
        "89:13": {
          "id": 6006
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّ رَبّك لَبِالمِرْصادِ﴾</span> يَرْصُد أعْمال العِباد فَلا يَفُوتهُ مِنها شَيْء لِيُجازِيَهُمْ عَلَيْها</p></div>",
      "verses": {
        "89:14": {
          "id": 6007
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَمّا الإنْسان﴾</span> الكافِر <span class=\"qpc-hafs\">﴿إذا ما اِبْتَلاهُ﴾</span> اِخْتَبَرَهُ <span class=\"qpc-hafs\">﴿رَبّه فَأَكْرَمَهُ﴾</span> بِالمالِ وغَيْره <span class=\"qpc-hafs\">﴿ونَعَّمَهُ فَيَقُول رَبِّي أكْرَمْنَ﴾</span></p></div>",
      "verses": {
        "89:15": {
          "id": 6008
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَمّا إذا ما اِبْتَلاهُ فَقَدَرَ﴾</span> ضَيَّقَ <span class=\"qpc-hafs\">﴿عَلَيْهِ رِزْقه فَيَقُول رَبِّي أهانَن﴾</span></p></div>",
      "verses": {
        "89:16": {
          "id": 6009
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَلّا﴾</span> رَدْع، أيْ لَيْسَ الإكْرام بِالغِنى والإهانَة بِالفَقْرِ وإنَّما هُوَ بِالطّاعَةِ والمَعْصِيَة، وكُفّار مَكَّة لا يَنْتَبِهُونَ لِذَلِكَ <span class=\"qpc-hafs\">﴿بَلْ لا تُكْرِمُونَ اليَتِيم﴾</span> لا يُحْسِنُونَ إلَيْهِ مَعَ غِناهُمْ أوْ لا يُعْطُونَهُ حَقّه مِن المِيراث</p></div>",
      "verses": {
        "89:17": {
          "id": 6010
        }
      }
    },
    "18": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولا تَحاضُّونَ﴾</span> أنْفُسهمْ أوْ غَيْرهمْ <span class=\"qpc-hafs\">﴿عَلى طَعام﴾</span> أيْ إطْعام <span class=\"qpc-hafs\">﴿المِسْكِين﴾</span></p></div>",
      "verses": {
        "89:18": {
          "id": 6011
        }
      }
    },
    "19": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وتَأْكُلُونَ التُّراث﴾</span> المِيراث <span class=\"qpc-hafs\">﴿أكْلًا لَمًّا﴾</span> أيْ شَدِيدًا، لِلَمِّهِمْ نَصِيب النِّساء والصِّبْيان مِن المِيراث مَعَ نَصِيبهمْ مِنهُ أوْ مَعَ مالهمْ</p></div>",
      "verses": {
        "89:19": {
          "id": 6012
        }
      }
    },
    "20": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وتُحِبُّونَ المال حُبًّا جَمًّا﴾</span> أيْ: كَثِيرًا فَلا يُنْفِقُونَهُ، وفِي قِراءَة بِالفَوْقانِيَّةِ فِي الأَفْعال الأَرْبَعَة</p></div>",
      "verses": {
        "89:20": {
          "id": 6013
        }
      }
    },
    "21": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَلّا﴾</span> رَدْع لَهُمْ عَنْ ذَلِكَ <span class=\"qpc-hafs\">﴿إذا دُكَّتْ الأَرْض دَكًّا دَكًّا﴾</span> زُلْزِلَتْ حَتّى يَنْهَدِم كُلّ بِناء عَلَيْها ويَنْعَدِم</p></div>",
      "verses": {
        "89:21": {
          "id": 6014
        }
      }
    },
    "22": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وجاءَ رَبّك﴾</span> أيْ أمْره <span class=\"qpc-hafs\">﴿والمَلَك﴾</span> أيْ المَلائِكَة <span class=\"qpc-hafs\">﴿صَفًّا صَفًّا﴾</span> حال، أيْ مُصْطَفِّينَ أوْ ذَوِي صُفُوف كَثِيرَة</p></div>",
      "verses": {
        "89:22": {
          "id": 6015
        }
      }
    },
    "23": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وجِيءَ يَوْمئِذٍ بِجَهَنَّم﴾</span> تُقاد بِسَبْعِينَ ألْف زِمام كُلّ زِمام بِأَيْدِي سَبْعِينَ ألْف مَلَك لَها زَفِير وتَغَيُّظ <span class=\"qpc-hafs\">﴿يَوْمئِذٍ﴾</span> بَدَل مِن إذا وجَوابها <span class=\"qpc-hafs\">﴿يَتَذَكَّر الإنْسان﴾</span> أيْ الكافِر ما فَرَّطَ فِيهِ <span class=\"qpc-hafs\">﴿وأَنّى لَهُ الذِّكْرى﴾</span> اِسْتِفْهام بِمَعْنى النَّفْي، أيْ لا يَنْفَعهُ تَذَكُّره ذَلِكَ</p></div>",
      "verses": {
        "89:23": {
          "id": 6016
        }
      }
    },
    "24": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَقُول﴾</span> مَعَ تَذَكُّره <span class=\"qpc-hafs\">﴿يا لَيْتَنِي﴾</span> لِلتَّنْبِيهِ <span class=\"qpc-hafs\">﴿قَدَّمْت﴾</span> الخَيْر والإيمان <span class=\"qpc-hafs\">﴿لِحَياتِي﴾</span> الطَّيِّبَة فِي الآخِرَة أوْ وقْت حَياتِي فِي الدُّنْيا</p></div>",
      "verses": {
        "89:24": {
          "id": 6017
        }
      }
    },
    "25": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَيَوْمئِذٍ لا يُعَذِّب﴾</span> بِكَسْرِ الذّال <span class=\"qpc-hafs\">﴿عَذابه﴾</span> أيْ اللَّه <span class=\"qpc-hafs\">﴿أحَد﴾</span> أيْ لا يَكِلهُ إلى غَيْره</p></div>",
      "verses": {
        "89:25": {
          "id": 6018
        }
      }
    },
    "26": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولا يُوثِق﴾</span> وكَذا \" لا يُوثِق \" بِكَسْرِ الثّاء <span class=\"qpc-hafs\">﴿وثاقه أحَد﴾</span> وفِي قِراءَة بِفَتْحِ الذّال والثّاء فَضَمِير عَذابه ووَثاقه لِلْكافِرِ والمَعْنى لا يُعَذَّب أحَد مِثْل تَعْذِيبه ولا يُوثَق مِثْل إيثاقه</p></div>",
      "verses": {
        "89:26": {
          "id": 6019
        }
      }
    },
    "27": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يا أيَّتها النَّفْس المُطَمْئِنَة﴾</span> الآمِنَة وهِيَ المُؤْمِنَة</p></div>",
      "verses": {
        "89:27": {
          "id": 6020
        }
      }
    },
    "28": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿اِرْجِعِي إلى رَبّك﴾</span> يُقال لَها ذَلِكَ عِنْد المَوْت، أيْ اِرْجِعِي إلى أمْره وإرادَته <span class=\"qpc-hafs\">﴿راضِيَة﴾</span> بِالثَّوابِ <span class=\"qpc-hafs\">﴿مَرْضِيَّة﴾</span> عِنْد اللَّه بِعَمَلِك، أيْ جامِعَة بَيْن الوَصْفَيْنِ وهُما حالانِ ويُقال لَها فِي القِيامَة</p></div>",
      "verses": {
        "89:28": {
          "id": 6021
        }
      }
    },
    "29": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فادْخُلِي فِي﴾</span> جُمْلَة <span class=\"qpc-hafs\">﴿عِبادِي﴾</span> الصّالِحِينَ</p></div>",
      "verses": {
        "89:29": {
          "id": 6022
        }
      }
    },
    "30": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وادْخُلِي جَنَّتِي﴾</span> مَعَهُمْ.</p></div>",
      "verses": {
        "89:30": {
          "id": 6023
        }
      }
    }
  }
}