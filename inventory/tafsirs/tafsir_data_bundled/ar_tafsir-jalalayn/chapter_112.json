{
  "chapter": 112,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قُلْ هُوَ اللَّه أحَد﴾</span> سُئِلَ النَّبِيّ ﷺ عَنْ رَبّه فَنَزَلَ <span class=\"qpc-hafs\">﴿قُلْ هُوَ اللَّه أحَد﴾</span> فاللَّه خَبَر هُوَ وأَحَد بَدَل مِنهُ أوْ خَبَر ثانٍ</p></div>",
      "verses": {
        "112:1": {
          "id": 6222
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿اللَّه الصَّمَد﴾</span> مُبْتَدَأ وخَبَر أيْ المَقْصُود فِي الحَوائِج عَلى الدَّوام</p></div>",
      "verses": {
        "112:2": {
          "id": 6223
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لَمْ يَلِد﴾</span> لِانْتِفاءِ مُجانَسَته <span class=\"qpc-hafs\">﴿ولَمْ يُولَد﴾</span> لِانْتِفاءِ الحُدُوث عَنْهُ</p></div>",
      "verses": {
        "112:3": {
          "id": 6224
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولَمْ يَكُنْ لَهُ كُفُوًا أحَد﴾</span> أيْ مُكافِئًا ومُماثِلًا، ولَهُ مُتَعَلِّق بِكُفُوًا، وقُدِّمَ عَلَيْهِ لِأَنَّهُ مَحَطّ القَصْد بِالنَّفْيِ وأُخِّرَ أحَد وهُوَ اِسْم يَكُنْ عَنْ خَبَرها رِعايَة لِلْفاصِلَةِ.</p></div>",
      "verses": {
        "112:4": {
          "id": 6225
        }
      }
    }
  }
}