{
  "chapter": 87,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿سَبِّحْ اِسْم رَبّك﴾</span> أيْ نَزِّهْ رَبّك عَمّا لا يَلِيق بِهِ واسْم زائِد <span class=\"qpc-hafs\">﴿الأَعْلى﴾</span> صِفَة لِرَبِّك</p></div>",
      "verses": {
        "87:1": {
          "id": 5949
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿الَّذِي خَلَقَ فَسَوّى﴾</span> مَخْلُوقه، جَعَلَهُ مُتَناسِب الأَجْزاء غَيْر مُتَفاوِت</p></div>",
      "verses": {
        "87:2": {
          "id": 5950
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والَّذِي قَدَّرَ﴾</span> ما شاءَ <span class=\"qpc-hafs\">﴿فَهَدى﴾</span> إلى ما قَدَّرَهُ مِن خَيْر وشَرّ</p></div>",
      "verses": {
        "87:3": {
          "id": 5951
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والَّذِي أخْرَجَ المَرْعى﴾</span> أنْبَتَ العُشْب</p></div>",
      "verses": {
        "87:4": {
          "id": 5952
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَجَعَلَهُ﴾</span> بَعْد الخُضْرَة <span class=\"qpc-hafs\">﴿غُثاء﴾</span> جافًّا هَشِيمًا <span class=\"qpc-hafs\">﴿أحَوى﴾</span> أسْوَد يابِسًا</p></div>",
      "verses": {
        "87:5": {
          "id": 5953
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿سَنُقْرِئُك﴾</span> القُرْآن <span class=\"qpc-hafs\">﴿فَلا تَنْسى﴾</span> ما تَقْرَؤُهُ</p></div>",
      "verses": {
        "87:6": {
          "id": 5954
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إلّا ما شاءَ اللَّه﴾</span> أنْ تَنْساهُ بِنَسْخِ تِلاوَته وحُكْمه، وكانَ ﷺ يَجْهَر بِالقِراءَةِ مَعَ قِراءَة جِبْرِيل خَوْف النِّسْيان فَكَأَنَّهُ قِيلَ لَهُ: لا تَعْجَل بِها إنَّك لا تَنْسى فَلا تُتْعِب نَفْسك بِالجَهْرِ بِها <span class=\"qpc-hafs\">﴿إنَّهُ﴾</span> تَعالى <span class=\"qpc-hafs\">﴿يَعْلَم الجَهْر﴾</span> مِن القَوْل والفِعْل <span class=\"qpc-hafs\">﴿وما يَخْفى﴾</span> مِنهُما</p></div>",
      "verses": {
        "87:7": {
          "id": 5955
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ونُيَسِّرُكَ لِلْيُسْرى﴾</span> لِلشَّرِيعَةِ السَّهْلَة وهِيَ الإسْلام</p></div>",
      "verses": {
        "87:8": {
          "id": 5956
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَذَكِّرْ﴾</span> عِظْ بِالقُرْآنِ <span class=\"qpc-hafs\">﴿إنْ نَفَعَتْ الذِّكْرى﴾</span> مِن تَذْكِرَة المَذْكُور فِي سَيَذَّكَّرُ، يَعْنِي وإنْ لَمْ تَنْفَع ونَفْعها لِبَعْضٍ وعَدَم النَّفْع لِبَعْضٍ آخَر</p></div>",
      "verses": {
        "87:9": {
          "id": 5957
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿سَيَذَّكَّرُ﴾</span> بِها <span class=\"qpc-hafs\">﴿مَن يَخْشى﴾</span> يَخاف اللَّه تَعالى كَآيَةِ</p></div>",
      "verses": {
        "87:10": {
          "id": 5958
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ويَتَجَنَّبها﴾</span> أيْ الذِّكْرى، أيْ يَتْرُكها جانِبًا لا يَلْتَفِت إلَيْها <span class=\"qpc-hafs\">﴿الأَشْقى﴾</span> بِمَعْنى الشَّقِيّ أيْ الكافِر</p></div>",
      "verses": {
        "87:11": {
          "id": 5959
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿الَّذِي يَصْلى النّار الكُبْرى﴾</span> هِيَ نار الآخِرَة والصُّغْرى نار الدُّنْيا</p></div>",
      "verses": {
        "87:12": {
          "id": 5960
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ لا يَمُوت فِيها﴾</span> فَيَسْتَرِيح <span class=\"qpc-hafs\">﴿ولا يَحْيا﴾</span> حَياة هَنِيئَة</p></div>",
      "verses": {
        "87:13": {
          "id": 5961
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قَدْ أفْلَحَ﴾</span> فازَ <span class=\"qpc-hafs\">﴿مَن تَزَكّى﴾</span> تَطَهَّرَ بِالإيمانِ</p></div>",
      "verses": {
        "87:14": {
          "id": 5962
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وذَكَرَ اِسْم رَبّه﴾</span> مُكَبِّرًا <span class=\"qpc-hafs\">﴿فَصَلّى﴾</span> الصَّلَوات الخَمْس وذَلِكَ مِن أُمُور الآخِرَة وكَفّار مَكَّة مُعْرِضُونَ عَنْها</p></div>",
      "verses": {
        "87:15": {
          "id": 5963
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿بَلْ تُؤْثِرُونَ﴾</span> بِالفَوْقانِيَّةِ والتَّحْتانِيَّة <span class=\"qpc-hafs\">﴿الحَياة الدُّنْيا﴾</span> عَلى الآخِرَة</p></div>",
      "verses": {
        "87:16": {
          "id": 5964
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والآخِرَة﴾</span> المُشْتَمِلَة عَلى الجَنَّة <span class=\"qpc-hafs\">﴿خَيْر وأَبْقى﴾</span></p></div>",
      "verses": {
        "87:17": {
          "id": 5965
        }
      }
    },
    "18": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّ هَذا﴾</span> إفْلاح مَن تَزَكّى وكَوْن الآخِرَة خَبَرًا <span class=\"qpc-hafs\">﴿لَفِي الصُّحُف الأُولى﴾</span> أيْ المُنَزَّلَة قَبْل القُرْآن</p></div>",
      "verses": {
        "87:18": {
          "id": 5966
        }
      }
    },
    "19": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿صُحُف إبْراهِيم ومُوسى﴾</span> وهِيَ عَشْر صُحُف لِإبْراهِيم والتَّوْراة لِمُوسى.</p></div>",
      "verses": {
        "87:19": {
          "id": 5967
        }
      }
    }
  }
}