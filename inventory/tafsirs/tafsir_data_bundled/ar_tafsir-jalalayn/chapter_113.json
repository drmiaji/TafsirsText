      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قُلْ أعُوذ بِرَبِّ الفَلَق﴾</span> الصُّبْح</p></div>",
      "verses": {
        "113:1": {
          "id": 6226
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿مِن شَرّ ما خَلَقَ﴾</span> مِن حَيَوان مُكَلَّف وغَيْر مُكَلَّف وجَماد كالسُّمِّ وغَيْر ذَلِكَ</p></div>",
      "verses": {
        "113:2": {
          "id": 6227
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ومِن شَرّ غاسِق إذا وقَبَ﴾</span> أيْ اللَّيْل إذا أظْلَمَ والقَمَر إذا غابَ</p></div>",
      "verses": {
        "113:3": {
          "id": 6228
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ومِن شَرّ النَّفّاثات﴾</span> السَّواحِر تَنْفُث <span class=\"qpc-hafs\">﴿فِي العُقَد﴾</span> الَّتِي تَعْقِدها فِي الخَيْط تَنْفُخ فِيها بِشَيْءٍ تَقُولهُ مِن غَيْر رِيق، وقالَ الزَّمَخْشَرِيّ مَعَهُ كَبَناتِ لَبِيد المَذْكُور</p></div>",
      "verses": {
        "113:4": {
          "id": 6229
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ومِن شَرّ حاسِد إذا حَسَدَ﴾</span> أظْهَر حَسَدَهُ وعَمِلَ بِمُقْتَضاهُ، كَلَبِيد المَذْكُور مِن اليَهُود الحاسِدِينَ لِلنَّبِيِّ ﷺ، وذِكْر الثَّلاثَة الشّامِل لَها ما خَلَقَ بَعْده لِشِدَّةِ شَرّها.</p></div>",
      "verses": {
        "113:5": {
          "id": 6230
        }
      }
    }
  }
}