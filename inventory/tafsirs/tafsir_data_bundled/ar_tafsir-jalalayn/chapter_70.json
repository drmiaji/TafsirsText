{
  "chapter": 70,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p>سُورَة المَعارِج [ مَكِّيَّة وآياتها أرْبَع وأَرْبَعُونَ آيَة ]</p><p><span class=\"qpc-hafs\">﴿سَأَلَ سائِل﴾</span> دَعا داعٍ</p></div>",
      "verses": {
        "70:1": {
          "id": 5376
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لِلْكافِرِينَ لَيْسَ لَهُ دافِع﴾</span> هُوَ النَّضْر بْن الحارِث قالَ <span class=\"qpc-hafs\">﴿اللَّهُمَّ إنْ كانَ هَذا هُوَ الحَقّ﴾</span> الآيَة</p></div>",
      "verses": {
        "70:2": {
          "id": 5377
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿مِن اللَّه﴾</span> مُتَّصِل بِواقِعِ <span class=\"qpc-hafs\">﴿ذِي المَعارِج﴾</span> مَصاعِد المَلائِكَة وهِيَ السَّماوات</p></div>",
      "verses": {
        "70:3": {
          "id": 5378
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿تَعْرُج﴾</span> بِالتّاءِ والياء <span class=\"qpc-hafs\">﴿المَلائِكَة والرُّوح﴾</span> جِبْرِيل <span class=\"qpc-hafs\">﴿إلَيْهِ﴾</span> إلى مَهْبِط أمْره مِن السَّماء <span class=\"qpc-hafs\">﴿فِي يَوْم﴾</span> مُتَعَلِّق بِمَحْذُوفٍ أيْ يَقَع العَذاب بِهِمْ فِي يَوْم القِيامَة <span class=\"qpc-hafs\">﴿كانَ مِقْداره خَمْسِينَ ألْف سَنَة﴾</span> بِالنِّسْبَةِ إلى الكافِر لِما يَلْقى فِيهِ مِن الشَّدائِد وأَمّا المُؤْمِن فَيَكُون أخَفّ عَلَيْهِ مِن صَلاة مَكْتُوبَة يُصَلِّيها فِي الدُّنْيا كَما جاءَ فِي الحَدِيث</p></div>",
      "verses": {
        "70:4": {
          "id": 5379
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فاصْبِرْ﴾</span> وهَذا قَبْل أنْ يُؤْمَر بِالقِتالِ <span class=\"qpc-hafs\">﴿صَبْرًا جَمِيلًا﴾</span> أيْ لا جَزَع فِيهِ</p></div>",
      "verses": {
        "70:5": {
          "id": 5380
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّهُمْ يَرَوْنَهُ﴾</span> أيْ العَذاب <span class=\"qpc-hafs\">﴿بَعِيدًا﴾</span> غَيْر واقِع</p></div>",
      "verses": {
        "70:6": {
          "id": 5381
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ونَراهُ قَرِيبًا﴾</span> واقِعًا لا مَحالَة</p></div>",
      "verses": {
        "70:7": {
          "id": 5382
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَوْم تَكُون السَّماء﴾</span> مُتَعَلِّق بِمَحْذُوفٍ تَقْدِيره يَقَع <span class=\"qpc-hafs\">﴿كالمُهْلِ﴾</span> كَذائِبِ الفِضَّة</p></div>",
      "verses": {
        "70:8": {
          "id": 5383
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وتَكُون الجِبال كالعِهْنِ﴾</span> كالصُّوفِ فِي الخِفَّة والطَّيَران بِالرِّيحِ</p></div>",
      "verses": {
        "70:9": {
          "id": 5384
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولا يَسْأَل حَمِيم حَمِيمًا﴾</span> قَرِيب قَرِيبه لِاشْتِغالِ كُلّ بِحالِهِ</p></div>",
      "verses": {
        "70:10": {
          "id": 5385
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يُبَصَّرُونَهُمْ﴾</span> أيْ يُبْصِر الأَحْماء بَعْضهمْ بَعْضًا ويَتَعارَفُونَ ولا يَتَكَلَّمُونَ والجُمْلَة مُسْتَأْنَفَة <span class=\"qpc-hafs\">﴿يَوَدّ المُجْرِم﴾</span> يَتَمَنّى الكافِر <span class=\"qpc-hafs\">﴿لَوْ﴾</span> بِمَعْنى أنْ <span class=\"qpc-hafs\">﴿يَفْتَدِي مِن عَذاب يَوْمئِذٍ﴾</span> بِكَسْرِ المِيم وفَتْحها</p></div>",
      "verses": {
        "70:11": {
          "id": 5386
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وصاحِبَته﴾</span> زَوْجَته</p></div>",
      "verses": {
        "70:12": {
          "id": 5387
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وفَصِيلَته﴾</span> عَشِيرَته لِفَصْلِهِ مِنها <span class=\"qpc-hafs\">﴿الَّتِي تُئْوِيهِ﴾</span> تَضُمّهُ</p></div>",
      "verses": {
        "70:13": {
          "id": 5388
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ومَن فِي الأَرْض جَمِيعًا ثُمَّ يُنْجِيه﴾</span> ذَلِكَ الِافْتِداء والجُمْلَة عَطْف عَلى يَفْتَدِي</p></div>",
      "verses": {
        "70:14": {
          "id": 5389
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَلّا﴾</span> رَدّ لِما يَوَدّهُ <span class=\"qpc-hafs\">﴿إنّها﴾</span> أيْ النّار <span class=\"qpc-hafs\">﴿لَظى﴾</span> اسْم لِجَهَنَّم لِأَنَّها تَتَلَظّى أيْ تَتَلَهَّب عَلى الكُفّار</p></div>",
      "verses": {
        "70:15": {
          "id": 5390
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿نَزّاعَة لِلشَّوى﴾</span> جَمْع شَواة وهِيَ جِلْدَة الرَّأْس</p></div>",
      "verses": {
        "70:16": {
          "id": 5391
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿تَدْعُوا مَن أدْبَرَ وتَوَلّى﴾</span> عَنْ الإيمان بِأَنْ تَقُول: إلَيَّ إلَيَّ</p></div>",
      "verses": {
        "70:17": {
          "id": 5392
        }
      }
    },
    "18": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وجَمَعَ﴾</span> المال <span class=\"qpc-hafs\">﴿فَأَوْعى﴾</span> أمْسَكَهُ فِي وِعائِهِ ولَمْ يُؤَدِّ حَقَّ اللَّه مِنهُ</p></div>",
      "verses": {
        "70:18": {
          "id": 5393
        }
      }
    },
    "19": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّ الإنْسان خُلِقَ هَلُوعًا﴾</span> حال مُقَدَّره وتَفْسِيره</p></div>",
      "verses": {
        "70:19": {
          "id": 5394
        }
      }
    },
    "20": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إذا مَسَّهُ الشَّرّ جَزُوعًا﴾</span> وقْت مَسّ الشَّرّ</p></div>",
      "verses": {
        "70:20": {
          "id": 5395
        }
      }
    },
    "21": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإذا مَسَّهُ الخَيْر مَنُوعًا﴾</span> وقْت مَسّه الخَيْر أيْ المال لِحَقِّ اللَّه مِنهُ</p></div>",
      "verses": {
        "70:21": {
          "id": 5396
        }
      }
    },
    "22": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إلّا المُصَلِّينَ﴾</span> أيْ المُؤْمِنِينَ</p></div>",
      "verses": {
        "70:22": {
          "id": 5397
        }
      }
    },
    "23": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿الَّذِينَ هُمْ عَلى صَلاتهمْ دائِمُونَ﴾</span> مُواظِبُونَ</p></div>",
      "verses": {
        "70:23": {
          "id": 5398
        }
      }
    },
    "24": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والَّذِينَ فِي أمْوالهمْ حَقّ مَعْلُوم﴾</span> هُوَ الزَّكاة</p></div>",
      "verses": {
        "70:24": {
          "id": 5399
        }
      }
    },
    "25": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لِلسّائِلِ والمَحْرُوم﴾</span> المُتَعَفِّف عَنْ السُّؤال فَيُحْرَم</p></div>",
      "verses": {
        "70:25": {
          "id": 5400
        }
      }
    },
    "26": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والَّذِينَ يُصَدِّقُونَ بِيَوْمِ الدِّين﴾</span> الجَزاء</p></div>",
      "verses": {
        "70:26": {
          "id": 5401
        }
      }
    },
    "27": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والَّذِينَ هُمْ مِن عَذاب رَبّهمْ مُشْفِقُونَ﴾</span> خائِفُونَ</p></div>",
      "verses": {
        "70:27": {
          "id": 5402
        }
      }
    },
    "28": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّ عَذاب رَبّهمْ غَيْر مَأْمُون﴾</span> نُزُوله غَيْر مَأْمُون</p></div>",
      "verses": {
        "70:28": {
          "id": 5403
        }
      }
    },
    "29": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "70:29": {
          "id": 5404
        }
      }
    },
    "30": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إلّا عَلى أزْواجهمْ أوْ ما مَلَكَتْ أيْمانهمْ﴾</span> مِن الإماء</p></div>",
      "verses": {
        "70:30": {
          "id": 5405
        }
      }
    },
    "31": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَمَن ابْتَغى وراء ذَلِكَ فَأُولَئِكَ هُمْ العادُونَ﴾</span> المُتَجاوِزُونَ الحَلال إلى الحَرام</p></div>",
      "verses": {
        "70:31": {
          "id": 5406
        }
      }
    },
    "32": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والَّذِينَ هُمْ لِأَماناتِهِمْ﴾</span> وفِي قِراءَة بِالإفْرادِ: ما ائْتَمَنُوا عَلَيْهِ مِن أمْر الدِّين والدُّنْيا <span class=\"qpc-hafs\">﴿وعَهْدهمْ﴾</span> المَأْخُوذ عَلَيْهِمْ فِي ذَلِكَ <span class=\"qpc-hafs\">﴿راعُونَ﴾</span> حافِظُونَ</p></div>",
      "verses": {
        "70:32": {
          "id": 5407
        }
      }
    },
    "33": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والَّذِينَ هُمْ بِشَهاداتِهِمْ﴾</span> وفِي قِراءَة بِالجَمْعِ <span class=\"qpc-hafs\">﴿قائِمُونَ﴾</span> يُقِيمُونَها ولا يَكْتُمُونَها</p></div>",
      "verses": {
        "70:33": {
          "id": 5408
        }
      }
    },
    "34": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والَّذِينَ هُمْ عَلى صَلاتهمْ يُحافِظُونَ﴾</span> بِأَدائِها فِي أوْقاتها</p></div>",
      "verses": {
        "70:34": {
          "id": 5409
        }
      }
    },
    "35": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "70:35": {
          "id": 5410
        }
      }
    },
    "36": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَمال الَّذِينَ كَفَرُوا قِبَلك﴾</span> نَحْوك <span class=\"qpc-hafs\">﴿مُهْطِعِينَ﴾</span> حال أيْ مُدِيمِي النَّظَر</p></div>",
      "verses": {
        "70:36": {
