    "37": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿عَنْ اليَمِين وعَنْ الشِّمال﴾</span> مِنك <span class=\"qpc-hafs\">﴿عِزِينَ﴾</span> حال أيْضًا أيْ جَماعات حِلَقًا حِلَقًا يَقُولُونَ اسْتِهْزاء بِالمُؤْمِنِينَ: لَئِنْ دَخَلَ هَؤُلاءِ الجَنَّة لَنَدْخُلَنَّها قَبْلهمْ</p></div>",
      "verses": {
        "70:37": {
          "id": 5412
        }
      }
    },
