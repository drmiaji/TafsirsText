    "39": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَلّا﴾</span> رَدْع لَهُمْ عَنْ طَمَعهمْ فِي الجَنَّة <span class=\"qpc-hafs\">﴿إنّا خَلَقْناهُمْ﴾</span> كَغَيْرِهِمْ <span class=\"qpc-hafs\">﴿مِمّا يَعْلَمُونَ﴾</span> مِن نُطَف فَلا يُطْمَع بِذَلِكَ فِي الجَنَّة وإنَّما يُطْمَع فِيها بِالتَّقْوى</p></div>",
      "verses": {
        "70:39": {
          "id": 5414
        }
      }
    },
    "40": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَلا﴾</span> لا زائِدَة <span class=\"qpc-hafs\">﴿أُقْسِم بِرَبِّ المَشارِق والمَغارِب﴾</span> لِلشَّمْسِ والقَمَر وسائِر الكَواكِب</p></div>",
      "verses": {
        "70:40": {
          "id": 5415
        }
      }
    },
    "41": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿عَلى أنْ نُبَدَّل﴾</span> نَأْتِي بَدَلهمْ <span class=\"qpc-hafs\">﴿خَيْرًا مِنهُمْ وما نَحْنُ بِمَسْبُوقِينَ﴾</span> بِعاجِزِينَ عَنْ ذَلِكَ</p></div>",
      "verses": {
        "70:41": {
          "id": 5416
        }
      }
    },
    "42": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَذَرْهُمْ﴾</span> اُتْرُكْهُمْ <span class=\"qpc-hafs\">﴿يَخُوضُوا﴾</span> فِي باطِلهمْ <span class=\"qpc-hafs\">﴿ويَلْعَبُوا﴾</span> فِي دُنْياهُمْ <span class=\"qpc-hafs\">﴿حَتّى يُلاقُوا﴾</span> يَلْقَوْا <span class=\"qpc-hafs\">﴿يَوْمهمْ الَّذِي يُوعَدُونَ﴾</span> فِيهِ العَذاب</p></div>",
      "verses": {
        "70:42": {
          "id": 5417
        }
      }
    },
    "43": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَوْم يَخْرُجُونَ مِن الأَجْداث﴾</span> القُبُور <span class=\"qpc-hafs\">﴿سِراعًا﴾</span> إلى المَحْشَر <span class=\"qpc-hafs\">﴿كَأَنَّهُمْ إلى نُصُب﴾</span> وفِي قِراءَة بِضَمِّ الحَرْفَيْنِ شَيْء مَنصُوب كَعَلَمٍ أوْ رايَة <span class=\"qpc-hafs\">﴿يُوفِضُونَ﴾</span> يُسْرِعُونَ</p></div>",
      "verses": {
        "70:43": {
          "id": 5418
        }
      }
    },
    "44": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿خاشِعَة﴾</span> ذَلِيلَة <span class=\"qpc-hafs\">﴿أبْصارهمْ تَرْهَقهُمْ﴾</span> تَغْشاهُمْ <span class=\"qpc-hafs\">﴿ذِلَّة ذَلِكَ اليَوْم الَّذِي كانُوا يُوعَدُونَ﴾</span> ذَلِكَ مُبْتَدَأ وما بَعْده خَبَر ومَعْناهُ يَوْم القِيامَة</p></div>",
      "verses": {
        "70:44": {
          "id": 5419
        }
      }
    }
  }
