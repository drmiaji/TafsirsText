    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إلّا الَّذِينَ آمَنُوا وعَمِلُوا الصّالِحات﴾</span> فَلَيْسُوا فِي خُسْران <span class=\"qpc-hafs\">﴿وتَواصَوْا﴾</span> أوْصى بَعْضهمْ بَعْضًا <span class=\"qpc-hafs\">﴿بِالحَقِّ﴾</span> الإيمان <span class=\"qpc-hafs\">﴿وتَواصَوْا بِالصَّبْرِ﴾</span> عَلى الطّاعَة وعَنْ المَعْصِيَة</p></div>",
      "verses": {
        "103:3": {
          "id": 6179
        }
      }
    }
