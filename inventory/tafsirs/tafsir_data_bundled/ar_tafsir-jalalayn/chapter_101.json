{
  "chapter": 101,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿القارِعَة﴾</span> القِيامَة الَّتِي تَقْرَع القُلُوب بِأَهْوالِها</p></div>",
      "verses": {
        "101:1": {
          "id": 6158
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ما القارِعَة﴾</span> تَهْوِيل لِشَأْنِها وهُما مُبْتَدَأ وخَبَر خَبَر القارِعَة</p></div>",
      "verses": {
        "101:2": {
          "id": 6159
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما أدْراك﴾</span> أعْلَمَك <span class=\"qpc-hafs\">﴿ما القارِعَة﴾</span> زِيادَة تَهْوِيل لَها وما الأُولى مُبْتَدَأ وما بَعْدها خَبَره وما الثّانِيَة وخَبَرها فِي مَحَلّ المَفْعُول الثّانِي لَأَدْرى</p></div>",
      "verses": {
        "101:3": {
          "id": 6160
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَوْم﴾</span> ناصِبه دَلَّ عَلَيْهِ القارِعَة، أيْ تَقْرَع <span class=\"qpc-hafs\">﴿يَكُون النّاس كالفِراشِ المَبْثُوث﴾</span> كَغَوْغاء الجَراد المُنْتَشِر يَمُوج بَعْضهمْ فِي بَعْض لِلْحِيرَةِ إلى أنْ يُدْعَوْا لِلْحِسابِ</p></div>",
      "verses": {
        "101:4": {
          "id": 6161
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وتَكُون الجِبال كالعِهْنِ المَنفُوش﴾</span> كالصُّوفِ المَندُوف فِي خِفَّة سَيْرها حَتّى تَسْتَوِي مَعَ الأَرْض</p></div>",
      "verses": {
        "101:5": {
          "id": 6162
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَمّا مَن ثَقُلَتْ مَوازِينه﴾</span> بِأَنْ رَجَحَتْ حَسَناته عَلى سَيِّئاته</p></div>",
      "verses": {
        "101:6": {
          "id": 6163
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَهُوَ فِي عِيشَة راضِيَة﴾</span> فِي الجَنَّة، أيْ ذات رِضًى بِأَنْ يَرْضاها، أيْ مَرْضِيَّة لَهُ</p></div>",
      "verses": {
        "101:7": {
          "id": 6164
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَمّا مَن خَفَّتْ مَوازِينه﴾</span> بِأَنْ رَجَحَتْ سَيِّئاته عَلى حَسَناته</p></div>",
      "verses": {
        "101:8": {
          "id": 6165
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأُمّه﴾</span> فَمَسْكَنه <span class=\"qpc-hafs\">﴿هاوِيَة﴾</span></p></div>",
      "verses": {
        "101:9": {
          "id": 6166
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما أراك ما هِيَهْ﴾</span> أيْ ما هاوِيَة</p></div>",
      "verses": {
        "101:10": {
          "id": 6167
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿نار حامِيَة﴾</span> هِيَ شَدِيدَة الحَرارَة وهاء هِيَهْ لِلسَّكْتِ تُثْبَت وصْلًا ووَقْفًا وفِي قِراءَة تُحْذَف وصْلًا.</p></div>",
      "verses": {
        "101:11": {
          "id": 6168
        }
      }
    }
  }
}