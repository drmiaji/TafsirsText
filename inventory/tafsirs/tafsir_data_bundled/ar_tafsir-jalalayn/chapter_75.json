{
  "chapter": 75,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p>سُورَة القِيامَة [ مَكِّيَّة وآياتها أرْبَعُونَ آيَة ]</p><p><span class=\"qpc-hafs\">﴿لا﴾</span> زائِدَة فِي المَوْضِعَيْنِ</p></div>",
      "verses": {
        "75:1": {
          "id": 5552
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولا أُقْسِم بِالنَّفْسِ اللَّوّامَة﴾</span> الَّتِي تَلُوم نَفْسها وإنْ اجْتَهَدَتْ فِي الإحْسان وجَواب القَسَم مَحْذُوف أيْ لَتُبْعَثُنَّ دَلَّ عَلَيْهِ:</p></div>",
      "verses": {
        "75:2": {
          "id": 5553
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أيَحْسَبُ الإنْسان﴾</span> أيْ الكافِر <span class=\"qpc-hafs\">﴿ألَّنْ نَجْمَع عِظامه﴾</span> لِلْبَعْثِ والإحْياء</p></div>",
      "verses": {
        "75:3": {
          "id": 5554
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿بَلى﴾</span> نَجْمَعها <span class=\"qpc-hafs\">﴿قادِرِينَ﴾</span> مَعَ جَمْعها <span class=\"qpc-hafs\">﴿عَلى أنْ نُسَوِّيَ بَنانه﴾</span> وهُوَ الأَصابِع أيْ نُعِيد عِظامها كَما كانَتْ مَعَ صِغَرها فَكَيْفَ بِالكَبِيرَةِ</p></div>",
      "verses": {
        "75:4": {
          "id": 5555
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿بَلْ يُرِيد الإنْسان لِيَفْجُر﴾</span> اللّام زائِدَة ونَصَبَهُ بِأَنْ مُقَدَّرَة أيْ أنْ يُكَذِّب <span class=\"qpc-hafs\">﴿أمامه﴾</span> أيْ يَوْم القِيامَة دَلَّ عَلَيْهِ:</p></div>",
      "verses": {
        "75:5": {
          "id": 5556
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَسْأَل أيّانَ﴾</span> مَتى <span class=\"qpc-hafs\">﴿يَوْم القِيامَة﴾</span> سُؤال اسْتِهْزاء وتَكْذِيب</p></div>",
      "verses": {
        "75:6": {
          "id": 5557
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَإذا بَرِقَ البَصَر﴾</span> بِكَسْرِ الرّاء وفَتْحها فِي بَرِقَ بِمَعْنى دَهَشَ وتَحَيَّرَ لِما رَأى مِمّا كانَ يُكَذِّبهُ</p></div>",
      "verses": {
        "75:7": {
          "id": 5558
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وخَسَفَ القَمَر﴾</span> أظْلَمَ وذَهَبَ ضَوْءُهُ</p></div>",
      "verses": {
        "75:8": {
          "id": 5559
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وجُمِعَ الشَّمْس والقَمَر﴾</span> فَطَلَعا مِن المَغْرِب أوْ ذَهَبَ ضَوْءُهُما وذَلِكَ فِي يَوْم القِيامَة</p></div>",
      "verses": {
        "75:9": {
          "id": 5560
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَقُول الإنْسان يَوْمئِذٍ أيْنَ المَفَرّ﴾</span> الفِرار</p></div>",
      "verses": {
        "75:10": {
          "id": 5561
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَلّا﴾</span> رَدْع عَنْ طَلَب الفِرار <span class=\"qpc-hafs\">﴿لا وزَر﴾</span> لا مَلْجَأ يَتَحَصَّن بِهِ</p></div>",
      "verses": {
        "75:11": {
          "id": 5562
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إلى رَبّك يَوْمئِذٍ المُسْتَقَرّ﴾</span> مُسْتَقَرّ الخَلائِق فَيُحاسَبُونَ ويُجازُونَ</p></div>",
      "verses": {
        "75:12": {
          "id": 5563
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يُنَبَّأ الإنْسان يَوْمئِذٍ بِما قَدَّمَ وأَخَّرَ﴾</span> بِأَوَّلِ عَمَله وآخِره</p></div>",
      "verses": {
        "75:13": {
          "id": 5564
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿بَلْ الإنْسان عَلى نَفْسه بَصِيرَة﴾</span> شاهِد تَنْطِق جَوارِحه بِعَمَلِهِ والهاء لِلْمُبالَغَةِ فَلا بُدّ مِن جَزائِهِ</p></div>",
      "verses": {
        "75:14": {
          "id": 5565
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولَوْ ألْقى مَعاذِيره﴾</span> جَمْع مَعْذِرَة عَلى غَيْر قِياس أيْ لَوْ جاءَ بِكُلِّ مَعْذِرَة ما قُبِلَتْ مِنهُ</p></div>",
      "verses": {
        "75:15": {
          "id": 5566
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p>قالَ تَعالى لِنَبِيِّهِ <span class=\"qpc-hafs\">﴿لا تُحَرِّك بِهِ﴾</span> بِالقُرْآنِ قَبْل فَراغ جِبْرِيل مِنهُ <span class=\"qpc-hafs\">﴿لِسانك لِتَعْجَل بِهِ﴾</span> خَوْف أنْ يَنْفَلِت مِنك</p></div>",
      "verses": {
        "75:16": {
          "id": 5567
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّ عَلَيْنا جَمْعه﴾</span> فِي صَدْرك <span class=\"qpc-hafs\">﴿وقُرْآنه﴾</span> قِراءَتك إيّاهُ أيْ جَرَيانه عَلى لِسانك</p></div>",
      "verses": {
        "75:17": {
          "id": 5568
        }
      }
    },
    "18": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَإذا قَرَأْناهُ﴾</span> عَلَيْك بِقِراءَةِ جِبْرِيل <span class=\"qpc-hafs\">﴿فاتَّبِعْ قُرْآنه﴾</span> اسْتَمِعْ قِراءَته فَكانَ ﷺ يَسْتَمِع ثُمَّ يَقْرَؤُهُ</p></div>",
      "verses": {
        "75:18": {
          "id": 5569
        }
      }
    },
    "19": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ إنّ عَلَيْنا بَيانه﴾</span> بِالتَّفْهِيمِ لَك والمُناسَبَة بَيْن هَذِهِ الآيَة وما قَبْلها أنَّ تِلْكَ تَضَمَّنَتْ الإعْراض عَنْ آيات اللَّه وهَذِهِ تَضَمَّنَتْ المُبادَرَة إلَيْها بِحِفْظِها</p></div>",
      "verses": {
        "75:19": {
          "id": 5570
        }
      }
    },
    "20": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَلّا﴾</span> اسْتِفْتاح بِمَعْنى ألا <span class=\"qpc-hafs\">﴿بَلْ تُحِبُّونَ العاجِلَة﴾</span> الدُّنْيا بِالياءِ والتّاء فِي الفِعْلَيْنِ</p></div>",
      "verses": {
        "75:20": {
          "id": 5571
        }
      }
    },
    "21": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وتَذَرُونَ الآخِرَة﴾</span> فَلا يَعْمَلُونَ لَها</p></div>",
      "verses": {
        "75:21": {
          "id": 5572
        }
      }
    },
    "22": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وُجُوه يَوْمئِذٍ﴾</span> أيْ فِي يَوْم القِيامَة <span class=\"qpc-hafs\">﴿ناضِرَة﴾</span> حَسَنَة مُضِيئَة</p></div>",
      "verses": {
        "75:22": {
          "id": 5573
        }
      }
    },
    "23": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إلى رَبّها ناظِرَة﴾</span> أيْ يَرَوْنَ اللَّه سُبْحانه وتَعالى فِي الآخِرَة</p></div>",
      "verses": {
        "75:23": {
          "id": 5574
        }
      }
    },
    "24": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ووُجُوه يَوْمئِذٍ باسِرَة﴾</span> كالِحَة شَدِيدَة العُبُوس</p></div>",
      "verses": {
        "75:24": {
          "id": 5575
        }
      }
    },
    "25": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿تَظُنّ﴾</span> تُوقِن <span class=\"qpc-hafs\">﴿أنْ يُفْعَل بِها فاقِرَة﴾</span> داهِيَة عَظِيمَة تَكْسِر فَقار الظَّهْر</p></div>",
      "verses": {
        "75:25": {
          "id": 5576
        }
      }
    },
    "26": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَلّا﴾</span> بِمَعْنى ألا <span class=\"qpc-hafs\">﴿إذا بَلَغَتْ﴾</span> النَّفْس <span class=\"qpc-hafs\">﴿التَّراقِيَ﴾</span> عِظام الحَلْق</p></div>",
      "verses": {
        "75:26": {
          "id": 5577
        }
      }
    },
    "27": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وقِيلَ﴾</span> قالَ مَن حَوْله <span class=\"qpc-hafs\">﴿مَن راقٍ﴾</span> أيْ يَرْقِيه لِيُشْفى</p></div>",
      "verses": {
        "75:27": {
          "id": 5578
        }
      }
    },
    "28": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وظَنَّ﴾</span> أيْقَنَ مَن بَلَغَتْ نَفْسه ذَلِكَ <span class=\"qpc-hafs\">﴿أنَّهُ الفِراق﴾</span> أيْ فِراق الدُّنْيا</p></div>",
      "verses": {
        "75:28": {
          "id": 5579
        }
      }
    },
    "29": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والتَفَّتْ السّاق بِالسّاقِ﴾</span> أيْ إحْدى ساقَيْهِ بِالأُخْرى عِنْد المَوْت أوْ التَفَّتْ شِدَّة فِراق الدُّنْيا بِشِدَّةِ إقْبال الآخِرَة</p></div>",
      "verses": {
        "75:29": {
          "id": 5580
        }
      }
    },
    "30": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إلى رَبّك يَوْمئِذٍ المَساق﴾</span> أيْ السَّوْق وهَذا يَدُلّ عَلى العامِل فِي إذا والمَعْنى إذا بَلَغَتْ النَّفْس الحُلْقُوم تُساق إلى حُكْم رَبّها</p></div>",
      "verses": {
        "75:30": {
          "id": 5581
        }
      }
    },
    "31": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَلا صَدَّقَ﴾</span> الإنْسان <span class=\"qpc-hafs\">﴿ولا صَلّى﴾</span> أيْ لَمْ يُصَدِّق ولَمْ يُصَلِّ</p></div>",
      "verses": {
        "75:31": {
          "id": 5582
        }
      }
    },
    "32": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولَكِنْ كَذَّبَ﴾</span> بِالقُرْآنِ <span class=\"qpc-hafs\">﴿وتَوَلّى﴾</span> عَنْ الإيمان</p></div>",
      "verses": {
        "75:32": {
          "id": 5583
        }
      }
    },
    "33": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ ذَهَبَ إلى أهْله يَتَمَطّى﴾</span> يَتَبَخْتَر فِي مِشْيَته إعْجابًا</p></div>",
      "verses": {
        "75:33": {
          "id": 5584
        }
      }
    },
    "34": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أوْلى لَك﴾</span> فِيهِ التِفات عَنْ الغِيبَة والكَلِمَة اسْم فِعْل واللّام لِلتَّبْيِينِ أيْ ولِيّك ما تَكْرَه <span class=\"qpc-hafs\">﴿فَأَوْلى﴾</span> أيْ فَهُوَ أوْلى بِك مِن غَيْرك</p></div>",
      "verses": {
        "75:34": {
