{
  "chapter": 107,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أرَأَيْت الَّذِي يُكَذِّب بِالدِّينِ﴾</span> بِالجَزاءِ والحِساب، أيْ هَلْ عَرَفْته وإنْ لَمْ تَعْرِفهُ:</p></div>",
      "verses": {
        "107:1": {
          "id": 6198
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَذَلِكَ﴾</span> بِتَقْدِيرِ هُوَ بَعْد الفاء <span class=\"qpc-hafs\">﴿الَّذِي يَدُعّ اليَتِيم﴾</span> أيْ يَدْفَعهُ بِعُنْفٍ عَنْ حَقّه</p></div>",
      "verses": {
        "107:2": {
          "id": 6199
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولا يَحُضّ﴾</span> نَفْسه ولا غَيْره <span class=\"qpc-hafs\">﴿عَلى طَعام المِسْكِين﴾</span> أيْ إطْعامه، نَزَلَتْ فِي العاصِي بْن وائِل أوْ الوَلِيد بْن المُغِيرَة</p></div>",
      "verses": {
        "107:3": {
          "id": 6200
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "107:4": {
          "id": 6201
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿الَّذِينَ هُمْ عَنْ صَلاتهمْ ساهُونَ﴾</span> غافِلُونَ يُؤَخِّرُونَها عَنْ وقْتها</p></div>",
      "verses": {
        "107:5": {
          "id": 6202
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿الَّذِينَ هُمْ يُراءُونَ﴾</span> فِي الصَّلاة وغَيْرها</p></div>",
      "verses": {
        "107:6": {
          "id": 6203
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ويَمْنَعُونَ الماعُون﴾</span> كالإبْرَةِ والفَأْس والقِدْر والقَصْعَة.</p></div>",
      "verses": {
        "107:7": {
          "id": 6204
        }
      }
    }
  }
}