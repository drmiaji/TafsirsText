{
  "chapter": 81,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إذا الشَّمْس كُوِّرَتْ﴾</span> لُفِّفَتْ وذُهِبَ بِنُورِها</p></div>",
      "verses": {
        "81:1": {
          "id": 5801
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإذا النُّجُوم اِنْكَدَرَتْ﴾</span> اِنْقَضَّتْ وتَساقَطَتْ عَلى الأَرْض</p></div>",
      "verses": {
        "81:2": {
          "id": 5802
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإذا الجِبال سُيِّرَتْ﴾</span> ذُهِبَ بِها عَنْ وجْه الأَرْض فَصارَتْ هَباء مُنْبَثًّا</p></div>",
      "verses": {
        "81:3": {
          "id": 5803
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإذا العِشار﴾</span> النُّوق الحَوامِل <span class=\"qpc-hafs\">﴿عُطِّلَتْ﴾</span> تُرِكَتْ بِلا راعٍ أوْ بِلا حَلْب لِما دَهاهُمْ مِن الأَمْر، وإنْ لَمْ يَكُنْ مال أعْجَب إلَيْهِمْ مِنها</p></div>",
      "verses": {
        "81:4": {
          "id": 5804
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإذا الوُحُوش حُشِرَتْ﴾</span> جُمِعَتْ بَعْد البَعْث لِيَقْتَصّ لِبَعْضٍ مِن بَعْض ثُمَّ تَصِير تُرابًا</p></div>",
      "verses": {
        "81:5": {
          "id": 5805
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإذا البِحار سُجِّرَتْ﴾</span> بِالتَّخْفِيفِ والتَّشْدِيد: أُوقِدَتْ فَصارَتْ نارًا</p></div>",
      "verses": {
        "81:6": {
          "id": 5806
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإذا النُّفُوس زُوِّجَتْ﴾</span> قُرِنَتْ بِأَجْسادِها</p></div>",
      "verses": {
        "81:7": {
          "id": 5807
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإذا المَوْءُودَة﴾</span> الجارِيَة تُدْفَن حَيَّة خَوْف العار والحاجَة <span class=\"qpc-hafs\">﴿سُئِلَتْ﴾</span> تَبْكِيتًا لِقاتِلِها</p></div>",
      "verses": {
        "81:8": {
          "id": 5808
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿بِأَيِّ ذَنْب قُتِلَتْ﴾</span> وقُرِئَ بِكَسْرِ التّاء حِكايَة لِما تُخاطَب بِهِ وجَوابها أنْ تَقُول: قُتِلْت بِلا ذَنْب</p></div>",
      "verses": {
        "81:9": {
          "id": 5809
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإذا الصُّحُف﴾</span> صُحُف الأَعْمال <span class=\"qpc-hafs\">﴿نُشِرَتْ﴾</span> بِالتَّخْفِيفِ والتَّشْدِيد فُتِحَتْ وبُسِطَتْ</p></div>",
      "verses": {
        "81:10": {
          "id": 5810
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإذا السَّماء كُشِطَتْ﴾</span> نُزِعَتْ عَنْ أماكِنها كَما يُنْزَع الجِلْد عَنْ الشّاة</p></div>",
      "verses": {
        "81:11": {
          "id": 5811
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإذا الجَحِيم﴾</span> النّار <span class=\"qpc-hafs\">﴿سُعِّرَتْ﴾</span> بِالتَّخْفِيفِ والتَّشْدِيد أُجِّجَتْ</p></div>",
      "verses": {
        "81:12": {
          "id": 5812
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإذا الجَنَّة أُزْلِفَتْ﴾</span> قُرِّبَتْ لِأَهْلِها لِيَدْخُلُوها وجَواب إذا أوَّل السُّورَة وما عُطِفَ عَلَيْها</p></div>",
      "verses": {
        "81:13": {
          "id": 5813
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿عَلِمَتْ نَفْس﴾</span> كُلّ نَفْس وقْت هَذِهِ المَذْكُورات وهُوَ يَوْم القِيامَة <span class=\"qpc-hafs\">﴿ما أحْضَرَتْ﴾</span> مِن خَيْر وشَرّ</p></div>",
      "verses": {
        "81:14": {
          "id": 5814
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَلا أُقْسِم﴾</span> لا زائِدَة \" بِالخُنَّسِ \"</p></div>",
      "verses": {
        "81:15": {
          "id": 5815
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿الجَوارِي الكُنَّس﴾</span> هِيَ النُّجُوم الخَمْسَة: زُحَل والمُشْتَرى والمَرِّيخ والزُّهَرَة وعُطارِد، تَخْنُس بِضَمِّ النُّون، أيْ تَرْجِع فِي مَجْراها وراءَها، بَيْنَما نَرى النَّجْم فِي آخِر البُرْج إذْ كَرَّ راجِعًا إلى أوَّله، وتَكْنِس بِكَسْرِ النُّون: تَدْخُل فِي كِناسها، أيْ تَغِيب فِي المَواضِع الَّتِي تَغِيب فِيها</p></div>",
      "verses": {
        "81:16": {
          "id": 5816
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿واللَّيْل إذا عَسْعَسَ﴾</span> أقْبَلَ بِظَلامِهِ أوْ أدْبَرَ</p></div>",
      "verses": {
        "81:17": {
          "id": 5817
        }
      }
    },
    "18": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والصُّبْح إذا تَنَفَّسَ﴾</span> اِمْتَدَّ حَتّى يَصِير نَهارًا بَيِّنًا</p></div>",
      "verses": {
        "81:18": {
          "id": 5818
        }
      }
    },
    "19": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّهُ﴾</span> أيْ القُرْآن <span class=\"qpc-hafs\">﴿لَقَوْل رَسُول كَرِيم﴾</span> عَلى اللَّه تَعالى وهُوَ جِبْرِيل أُضِيفَ إلَيْهِ لِنُزُولِهِ بِهِ</p></div>",
      "verses": {
        "81:19": {
          "id": 5819
        }
      }
    },
    "20": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ذِي قُوَّة﴾</span> أيْ شَدِيد القُوى <span class=\"qpc-hafs\">﴿عِنْد ذِي العَرْش﴾</span> أيْ اللَّه تَعالى <span class=\"qpc-hafs\">﴿مَكِين﴾</span> ذِي مَكانَة مُتَعَلِّق بِهِ عِنْد</p></div>",
      "verses": {
        "81:20": {
          "id": 5820
        }
      }
    },
    "21": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿مُطاع ثَمَّ﴾</span> تُطِيعهُ المَلائِكَة فِي السَّماوات <span class=\"qpc-hafs\">﴿أمِين﴾</span> عَلى الوَحْي</p></div>",
      "verses": {
        "81:21": {
          "id": 5821
        }
      }
    },
    "22": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما صاحِبكُمْ﴾</span> مُحَمَّد ﷺ عُطِفَ عَلى إنَّهُ إلى آخِر المُقْسَم عَلَيْهِ <span class=\"qpc-hafs\">﴿بِمَجْنُونٍ﴾</span> كَما زَعَمْتُمْ</p></div>",
      "verses": {
        "81:22": {
          "id": 5822
        }
      }
    },
    "23": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولَقَدْ رَآهُ﴾</span> رَأى مُحَمَّد ﷺ جِبْرِيل عَلى صُورَته الَّتِي خُلِقَ عَلَيْها <span class=\"qpc-hafs\">﴿بِالأُفُقِ المُبِين﴾</span> البَيِّن وهُوَ الأَعْلى بِناحِيَةِ المَشْرِق</p></div>",
      "verses": {
        "81:23": {
          "id": 5823
        }
      }
    },
    "24": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما هُوَ﴾</span> مُحَمَّد ﷺ <span class=\"qpc-hafs\">﴿عَلى الغَيْب﴾</span> ما غابَ مِن الوَحْي وخَبَر السَّماء <span class=\"qpc-hafs\">﴿بِضَنِينِ﴾</span> أيْ بِمُتَّهَمٍ، وفِي قِراءَة بِالضّادِ، أيْ بِبَخِيلٍ فَيَنْتَقِص شَيْئًا مِنهُ</p></div>",
      "verses": {
        "81:24": {
          "id": 5824
        }
      }
    },
    "25": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما هُوَ﴾</span> أيْ القُرْآن <span class=\"qpc-hafs\">﴿بِقَوْلِ شَيْطان﴾</span> مُسْتَرِق السَّمْع <span class=\"qpc-hafs\">﴿رَجِيم﴾</span> مَرْجُوم</p></div>",
      "verses": {
        "81:25": {
          "id": 5825
        }
      }
    },
    "26": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَيْنَ تَذْهَبُونَ﴾</span> فَبِأَيِّ طَرِيق تَسْلُكُونَ فِي إنْكاركُمْ القُرْآن وإعْراضكُمْ عَنْهُ</p></div>",
      "verses": {
        "81:26": {
          "id": 5826
        }
      }
    },
    "27": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنْ﴾</span> ما <span class=\"qpc-hafs\">﴿هُوَ إلّا ذِكْر﴾</span> عِظَة <span class=\"qpc-hafs\">﴿لِلْعالَمِينَ﴾</span> الإنْس والجِنّ</p></div>",
      "verses": {
        "81:27": {
          "id": 5827
        }
      }
    },
    "28": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لِمَن شاءَ مِنكُمْ﴾</span> بَدَل مِن العالَمِينَ بِإعادَةِ الجارّ <span class=\"qpc-hafs\">﴿أنْ يَسْتَقِيم﴾</span> بِاتِّباعِ الحَقّ</p></div>",
      "verses": {
        "81:28": {
          "id": 5828
        }
      }
    },
    "29": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما تَشاءُونَ﴾</span> الِاسْتِقامَة عَلى الحَقّ <span class=\"qpc-hafs\">﴿إلّا أنْ يَشاء اللَّه رَبّ العالَمِينَ \" الخَلائِق اِسْتِقامَتكُمْ عَلَيْهِ.﴾</span></p></div>",
      "verses": {
        "81:29": {
          "id": 5829
        }
      }
    }
  }
}