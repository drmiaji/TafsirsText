{
  "chapter": 84,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "84:1": {
          "id": 5885
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَذِنَتْ﴾</span> سَمِعَتْ وأَطاعَتْ فِي الِانْشِقاق <span class=\"qpc-hafs\">﴿لِرَبِّها وحُقَّتْ﴾</span> أيْ وحُقَّ لَها أنْ تَسْمَع وتُطِيع</p></div>",
      "verses": {
        "84:2": {
          "id": 5886
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإذا الأَرْض مُدَّتْ﴾</span> زِيدَ فِي سَعَتها كَما يُمَدّ الأَدِيم ولَمْ يَبْقَ عَلَيْها بِناء ولا جَبَل</p></div>",
      "verses": {
        "84:3": {
          "id": 5887
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَلْقَتْ ما فِيها﴾</span> مِن المَوْتى إلى ظاهِرها <span class=\"qpc-hafs\">﴿وتَخَلَّتْ﴾</span> عَنْهُ</p></div>",
      "verses": {
        "84:4": {
          "id": 5888
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَذِنَتْ﴾</span> سَمِعَتْ وأَطاعَتْ فِي ذَلِكَ <span class=\"qpc-hafs\">﴿لِرَبِّها وحُقَّتْ﴾</span> وذَلِكَ كُلّه يَكُون يَوْم القِيامَة، وجَواب إذا وما عُطِفَ عَلَيْها مَحْذُوف دَلَّ عَلَيْهِ ما بَعْده تَقْدِيره لَقِيَ الإنْسان عَمَله</p></div>",
      "verses": {
        "84:5": {
          "id": 5889
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يا أيّها الإنْسان إنَّك كادِح﴾</span> جاهِد فِي عَمَلك <span class=\"qpc-hafs\">﴿إلى﴾</span> لِقاء <span class=\"qpc-hafs\">﴿رَبّك﴾</span> وهُوَ المَوْت <span class=\"qpc-hafs\">﴿كَدْحًا فَمُلاقِيه﴾</span> أيْ مُلاقٍ عَمَلك المَذْكُور مِن خَيْر أوْ شَرّ يَوْم القِيامَة</p></div>",
      "verses": {
        "84:6": {
          "id": 5890
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَمّا مَن أُوتِيَ كِتابه﴾</span> كِتاب عَمَله <span class=\"qpc-hafs\">﴿بِيَمِينِهِ﴾</span> هُوَ المُؤْمِن</p></div>",
      "verses": {
        "84:7": {
          "id": 5891
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَسَوْفَ يُحاسَب حِسابًا يَسِيرًا﴾</span> هُوَ عَرْض عَمَله عَلَيْهِ كَما فِي حَدِيث الصَّحِيحَيْنِ وفِيهِ \" مَن نُوقِشَ الحِساب هَلَكَ \" وبَعْد العَرْض يُتَجاوَز عَنْهُ</p></div>",
      "verses": {
        "84:8": {
          "id": 5892
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ويَنْقَلِب إلى أهْله﴾</span> فِي الجَنَّة <span class=\"qpc-hafs\">﴿مَسْرُورًا﴾</span> بِذَلِكَ</p></div>",
      "verses": {
        "84:9": {
          "id": 5893
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَمّا مَن أُوتِيَ كِتابه وراء ظَهْره﴾</span> هُوَ الكافِر تُغَلّ يُمْناهُ إلى عُنُقه وتُجْعَل يُسْراهُ وراء ظَهْره فَيَأْخُذ بِها كِتابه</p></div>",
      "verses": {
        "84:10": {
          "id": 5894
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَسَوْفَ يَدْعُو﴾</span> عِنْد رُؤْيَته ما فِيهِ <span class=\"qpc-hafs\">﴿ثُبُورًا﴾</span> يُنادِي هَلاكه بِقَوْلِهِ: يا ثُبُوراه</p></div>",
      "verses": {
        "84:11": {
          "id": 5895
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ويَصْلى سَعِيرًا﴾</span> يَدْخُل النّار الشَّدِيدَة وفِي قِراءَة بِضَمِّ الياء وفَتْح الصّاد واللّام المُشَدَّدَة</p></div>",
      "verses": {
        "84:12": {
          "id": 5896
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p>\" <span class=\"qpc-hafs\">﴿إنَّهُ كانَ فِي أهْله﴾</span> عَشِيرَته فِي الدُّنْيا <span class=\"qpc-hafs\">﴿مَسْرُورًا﴾</span> بَطِرًا بِاتِّباعِهِ لِهَواهُ</p></div>",
      "verses": {
        "84:13": {
          "id": 5897
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّهُ ظَنَّ أنْ﴾</span> مُخَفَّفَة مِن الثَّقِيلَة واسْمها مَحْذُوف، أيْ أنَّهُ <span class=\"qpc-hafs\">﴿لَنْ يَحُور﴾</span> يَرْجِع إلى رَبّه</p></div>",
      "verses": {
        "84:14": {
          "id": 5898
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿بَلى﴾</span> يَرْجِع إلَيْهِ <span class=\"qpc-hafs\">﴿إنَّ رَبّه كانَ بِهِ بَصِيرًا﴾</span> عالِمًا بِرُجُوعِهِ إلَيْهِ</p></div>",
      "verses": {
        "84:15": {
          "id": 5899
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَلا أُقْسِم﴾</span> لا زائِدَة <span class=\"qpc-hafs\">﴿بِالشَّفَقِ﴾</span> هُوَ الحُمْرَة فِي الأُفُق بَعْد غُرُوب الشَّمْس</p></div>",
      "verses": {
        "84:16": {
          "id": 5900
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿واللَّيْل وما وسَقَ﴾</span> جَمَعَ ما دَخَلَ عَلَيْهِ مِن الدَّوابّ وغَيْرها</p></div>",
      "verses": {
        "84:17": {
          "id": 5901
        }
      }
    },
    "18": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والقَمَر إذا اِتَّسَقَ﴾</span> اِجْتَمَعَ وتَمَّ نُوره وذَلِكَ فِي اللَّيالِي البِيض</p></div>",
      "verses": {
        "84:18": {
          "id": 5902
        }
      }
    },
    "19": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لَتَرْكَبُنَّ﴾</span> أيّها النّاس أصْله تَرْكَبُونَنَّ حُذِفَتْ نُون الرَّفْع لِتَوالِي الأَمْثال والواو لِالتِقاءِ السّاكِنَيْنِ <span class=\"qpc-hafs\">﴿طَبَقًا عَنْ طَبَق﴾</span> حالًا بَعْد حال، وهُوَ المَوْت ثُمَّ الحَياة وما بَعْدها مِن أحْوال القِيامَة</p></div>",
      "verses": {
        "84:19": {
          "id": 5903
        }
      }
    },
    "20": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَما لَهُمْ﴾</span> أيْ الكُفّار <span class=\"qpc-hafs\">﴿لا يُؤْمِنُونَ﴾</span> أيْ أيّ مانِع مِن الإيمان أوْ أيّ حُجَّة لَهُمْ فِي تَرْكه مَعَ وُجُود بَراهِينه</p></div>",
      "verses": {
        "84:20": {
          "id": 5904
        }
      }
    },
    "21": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿و﴾</span> ما لَهُمْ <span class=\"qpc-hafs\">﴿إذا قُرِئَ عَلَيْهِمْ القُرْآن لا يَسْجُدُونَ﴾</span> يَخْضَعُونَ بِأَنْ يُؤْمِنُوا بِهِ لِإعْجازِهِ</p></div>",
      "verses": {
        "84:21": {
          "id": 5905
        }
      }
    },
    "22": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿بَلْ الَّذِينَ كَفَرُوا يُكَذِّبُونَ﴾</span> بِالبَعْثِ وغَيْره</p></div>",
      "verses": {
        "84:22": {
          "id": 5906
        }
      }
    },
    "23": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿واللَّه أعْلَم بِما يُوعُونَ﴾</span> يَجْمَعُونَ فِي صُحُفهمْ مِن الكُفْر والتَّكْذِيب وأَعْمال السُّوء</p></div>",
      "verses": {
        "84:23": {
          "id": 5907
        }
      }
    },
    "24": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَبَشِّرْهُمْ﴾</span> أخْبِرْهُمْ <span class=\"qpc-hafs\">﴿بِعَذابٍ ألِيم﴾</span> مُؤْلِم</p></div>",
      "verses": {
        "84:24": {
          "id": 5908
        }
      }
    },
    "25": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إلّا﴾</span> لَكِنْ <span class=\"qpc-hafs\">﴿الَّذِينَ آمَنُوا وعَمِلُوا الصّالِحات لَهُ أجْر غَيْر مَمْنُون﴾</span> غَيْر مَقْطُوع ولا مَنقُوص ولا يُمَنّ بِهِ عَلَيْهِمْ.</p></div>",
      "verses": {
        "84:25": {
          "id": 5909
        }
      }
    }
  }
}