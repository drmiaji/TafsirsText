{
  "chapter": 91,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والشَّمْس وضُحاها﴾</span> ضَوْئِها</p></div>",
      "verses": {
        "91:1": {
          "id": 6044
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والقَمَر إذا تَلاها﴾</span> تَبِعَها طالِعًا عِنْد غُرُوبها</p></div>",
      "verses": {
        "91:2": {
          "id": 6045
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والنَّهار إذا جَلّاها﴾</span> بِارْتِفاعِهِ</p></div>",
      "verses": {
        "91:3": {
          "id": 6046
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿واللَّيْل إذا يَغْشاها﴾</span> يُغَطِّيها بِظُلْمَتِهِ وإذا فِي الثَّلاثَة لِمُجَرَّدِ الظَّرْفِيَّة والعامِل فِيها فِعْل القَسَم</p></div>",
      "verses": {
        "91:4": {
          "id": 6047
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "91:5": {
          "id": 6048
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والأَرْض وما طَحاها﴾</span> بَسَطَها</p></div>",
      "verses": {
        "91:6": {
          "id": 6049
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ونَفْس﴾</span> بِمَعْنى نُفُوس <span class=\"qpc-hafs\">﴿وما سَوّاها﴾</span> فِي الخِلْقَة وما فِي الثَّلاثَة مَصْدَرِيَّة أوْ بِمَعْنى مَن</p></div>",
      "verses": {
        "91:7": {
          "id": 6050
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَلْهَمَها فُجُورها وتَقْواها﴾</span> بَيَّنَ لَها طَرِيق الخَيْر والشَّرّ وأَخَّرَ التَّقْوى رِعايَة لِرُءُوسِ الآي وجَواب القَسَم: \" قَدْ أفْلَحَ \"</p></div>",
      "verses": {
        "91:8": {
          "id": 6051
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قَدْ أفْلَحَ﴾</span> حُذِفَتْ مِنهُ اللّام لِطُولِ الكَلام <span class=\"qpc-hafs\">﴿مَن زَكّاها﴾</span> طَهَّرَها مِن الذُّنُوب</p></div>",
      "verses": {
        "91:9": {
          "id": 6052
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وقَدْ خابَ﴾</span> خَسِرَ <span class=\"qpc-hafs\">﴿مَن دَسّاها﴾</span> أخْفاها بِالمَعْصِيَةِ وأَصْله دَسَّسَها أُبْدِلَتْ السِّين الثّانِيَة ألِفًا تَخْفِيفًا</p></div>",
      "verses": {
        "91:10": {
          "id": 6053
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَذَّبَتْ ثَمُود﴾</span> رَسُولها صالِحًا <span class=\"qpc-hafs\">﴿بِطَغْواها﴾</span> بِسَبَبِ طُغْيانها</p></div>",
      "verses": {
        "91:11": {
          "id": 6054
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إذْ اِنْبَعَثَ﴾</span> أسْرَعَ <span class=\"qpc-hafs\">﴿أشْقاها﴾</span> واسْمه قَدّار إلى عَقْر النّاقَة بِرِضاهُمْ</p></div>",
      "verses": {
        "91:12": {
          "id": 6055
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَقالَ لَهُمْ رَسُول اللَّه﴾</span> صالِح <span class=\"qpc-hafs\">﴿ناقَة اللَّه﴾</span> أيْ ذَرُوها <span class=\"qpc-hafs\">﴿وسُقْياها﴾</span> شُرْبها فِي يَوْمها وكانَ لَها يَوْم ولَهُمْ يَوْم</p></div>",
      "verses": {
        "91:13": {
          "id": 6056
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَكَذَّبُوهُ﴾</span> فِي قَوْله ذَلِكَ عَنْ اللَّه المُرَتَّب عَلَيْهِ نُزُول العَذاب بِهِمْ إنْ خالَفُوهُ <span class=\"qpc-hafs\">﴿فَعَقَرُوها﴾</span> قَتَلُوها لِيَسْلَم لَهُمْ ماء شُرْبها <span class=\"qpc-hafs\">﴿فَدَمْدَمَ﴾</span> أطْبَقَ <span class=\"qpc-hafs\">﴿عَلَيْهِمْ رَبّهمْ﴾</span> العَذاب <span class=\"qpc-hafs\">﴿بِذَنْبِهِمْ فَسَوّاها﴾</span> أيْ الدَّمْدَمَة عَلَيْهِمْ، أيْ عَمَّهُمْ بِها فَلَمْ يَفْلِت مِنهُمْ أحَد</p></div>",
      "verses": {
        "91:14": {
          "id": 6057
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولا﴾</span> بِالواوِ والفاء <span class=\"qpc-hafs\">﴿يَخاف عُقْباها﴾</span> تَبِعَتها</p></div>",
      "verses": {
        "91:15": {
          "id": 6058
        }
      }
    }
  }
}