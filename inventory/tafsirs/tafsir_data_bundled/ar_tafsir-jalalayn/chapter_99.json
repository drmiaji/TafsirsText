{
  "chapter": 99,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إذا زُلْزِلَتْ الأَرْض﴾</span> حُرِّكَتْ لِقِيامِ السّاعَة <span class=\"qpc-hafs\">﴿زِلْزالها﴾</span> تَحْرِيكها الشَّدِيد المُناسِب لِعَظَمَتِها</p></div>",
      "verses": {
        "99:1": {
          "id": 6139
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَخْرَجَتْ الأَرْض أثْقالها﴾</span> كُنُوزها ومَوْتاها فَأَلْقَتْها عَلى ظَهْرها</p></div>",
      "verses": {
        "99:2": {
          "id": 6140
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وقالَ الإنْسان﴾</span> الكافِر بِالبَعْثِ <span class=\"qpc-hafs\">﴿ما لَها﴾</span> إنْكارًا لِتِلْكَ الحالَة</p></div>",
      "verses": {
        "99:3": {
          "id": 6141
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَوْمئِذٍ﴾</span> بَدَل مِن إذا وجَوابها <span class=\"qpc-hafs\">﴿تُحَدِّث أخْبارها﴾</span> تُخْبِر بِما عُمِلَ عَلَيْها مِن خَيْر وشَرّ</p></div>",
      "verses": {
        "99:4": {
          "id": 6142
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿بِأَنَّ﴾</span> بِسَبَبِ أنَّ <span class=\"qpc-hafs\">﴿رَبّك أوْحى لَها﴾</span> أيْ أمَرَها بِذَلِكَ، وفِي الحَدِيث \" تَشْهَد عَلى كُلّ عَبْد أوْ أمَة بِكُلِّ ما عَمِلَ عَلى ظَهْرها \"</p></div>",
      "verses": {
        "99:5": {
          "id": 6143
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَوْمئِذٍ يَصْدُر النّاس﴾</span> يَنْصَرِفُونَ مِن مَوْقِف الحِساب <span class=\"qpc-hafs\">﴿أشْتاتًا﴾</span> مُتَفَرِّقِينَ فَآخِذ ذات اليَمِين إلى الجَنَّة وآخِذ ذات الشِّمال إلى النّار <span class=\"qpc-hafs\">﴿لِيُرَوْا أعْمالهمْ﴾</span> أيْ جَزاءَها مِن الجَنَّة أوْ النّار</p></div>",
      "verses": {
        "99:6": {
          "id": 6144
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَمَن يَعْمَل مِثْقال ذَرَّة﴾</span> زِنَة نَمْلَة صَغِيرَة <span class=\"qpc-hafs\">﴿خَيْرًا يَرَهُ﴾</span> يَرَ ثَوابه</p></div>",
      "verses": {
        "99:7": {
          "id": 6145
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ومَن يَعْمَل مِثْقال ذَرَّة شَرًّا يَرَهُ \" يَرَ جَزاءَهُ.﴾</span></p></div>",
      "verses": {
        "99:8": {
          "id": 6146
        }
      }
    }
  }
}