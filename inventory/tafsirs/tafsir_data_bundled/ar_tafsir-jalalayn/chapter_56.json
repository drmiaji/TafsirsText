{
  "chapter": 56,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p>سُورَة الواقِعَة [ مَكِّيَّة إلّا آيَتَيْ ٨١ و ٨٢ فَمَدَنِيَّتانِ ] \"وآياتها ٩٦ و ٩٧ و ٩٩\"</p><p><span class=\"qpc-hafs\">﴿إذا وقَعَتْ الواقِعَة﴾</span> قامَتْ القِيامَة</p></div>",
      "verses": {
        "56:1": {
          "id": 4980
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لَيْسَ لِوَقْعَتِها كاذِبَة﴾</span> نَفْس تَكْذِب بِأَنْ تَنْفِيها كَما نَفَتْها فِي الدُّنْيا</p></div>",
      "verses": {
        "56:2": {
          "id": 4981
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿خافِضَة رافِعَة﴾</span> أيْ هِيَ مُظْهِرَة لِخَفْضِ أقْوام بِدُخُولِهِمْ النّار ولِرَفْعِ آخَرِينَ بِدُخُولِهِمْ الجَنَّة</p></div>",
      "verses": {
        "56:3": {
          "id": 4982
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إذا رُجَّتْ الأَرْض رَجًّا﴾</span> حُرِّكَتْ حَرَكَة شَدِيدَة وإذا هَذِهِ بَدَل مِن الأُولى</p></div>",
      "verses": {
        "56:4": {
          "id": 4983
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وبُسَّتْ الجِبال بَسًّا﴾</span> فُتِّتَتْ</p></div>",
      "verses": {
        "56:5": {
          "id": 4984
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَكانَتْ هَباء﴾</span> غُبارًا <span class=\"qpc-hafs\">﴿مُنْبَثًّا﴾</span> مُنْتَشِرًا</p></div>",
      "verses": {
        "56:6": {
          "id": 4985
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وكُنْتُمْ﴾</span> فِي القِيامَة <span class=\"qpc-hafs\">﴿أزْواجًا﴾</span> أصْنافًا</p></div>",
      "verses": {
        "56:7": {
          "id": 4986
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَصْحاب المَيْمَنَة﴾</span> وهُمْ الَّذِينَ يُؤْتُونَ كُتُبهمْ بِأَيْمانِهِمْ مُبْتَدَأ خَبَره <span class=\"qpc-hafs\">﴿ما أصْحاب المَيْمَنَة﴾</span> تَعْظِيم لِشَأْنِهِمْ بِدُخُولِهِمْ الجَنَّة</p></div>",
      "verses": {
        "56:8": {
          "id": 4987
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَصْحاب المَشْأَمَة﴾</span> أيْ الشِّمال بِأَنْ يُؤْتى كُلّ مِنهُمْ كِتابه بِشِمالِهِ <span class=\"qpc-hafs\">﴿ما أصْحاب المَشْأَمَة﴾</span> تَحْقِير لِشَأْنِهِمْ بِدُخُولِهِمْ النّار</p></div>",
      "verses": {
        "56:9": {
          "id": 4988
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والسّابِقُونَ﴾</span> إلى الخَيْر وهُمْ الأَنْبِياء مُبْتَدَأ <span class=\"qpc-hafs\">﴿السّابِقُونَ﴾</span> تَأْكِيد لِتَعْظِيمِ شَأْنهمْ</p></div>",
      "verses": {
        "56:10": {
          "id": 4989
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "56:11": {
          "id": 4990
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "56:11",
      "verses": {
        "56:12": {
          "id": 4991
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُلَّة مِن الأَوَّلِينَ﴾</span> مُبْتَدَأ أيْ جَماعَة مِن الأُمَم الماضِيَة</p></div>",
      "verses": {
        "56:13": {
          "id": 4992
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وقَلِيل مِن الآخِرِينَ﴾</span> مِن أُمَّة مُحَمَّد ﷺ وهُمْ السّابِقُونَ مِن الأُمَم الماضِيَة وهَذِهِ الأُمَّة والخَبَر</p></div>",
      "verses": {
        "56:14": {
          "id": 4993
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿عَلى سُرَر مَوْضُونَة﴾</span> مَنسُوجَة بِقُضْبانِ الذَّهَب والجَواهِر</p></div>",
      "verses": {
        "56:15": {
          "id": 4994
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿مُتَّكِئِينَ عَلَيْها مُتَقابِلِينَ﴾</span> حالانِ مِن الضَّمِير فِي الخَبَر</p></div>",
      "verses": {
        "56:16": {
          "id": 4995
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَطُوف عَلَيْهِمْ﴾</span> لِلْخِدْمَةِ <span class=\"qpc-hafs\">﴿وِلْدان مُخَلَّدُونَ﴾</span> عَلى شَكْل الأَوْلاد لا يَهْرَمُونَ</p></div>",
      "verses": {
        "56:17": {
          "id": 4996
        }
      }
    },
    "18": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿بِأَكْوابٍ﴾</span> أقْداح لا عُرا لَها <span class=\"qpc-hafs\">﴿وأَبارِيق﴾</span> لَها عُرا وخَراطِيم <span class=\"qpc-hafs\">﴿وكَأْس﴾</span> إناء شُرْب الخَمْر <span class=\"qpc-hafs\">﴿مِن مَعِين﴾</span> أيْ خَمْر جارِيَة مِن مَنبَع لا يَنْقَطِع أبَدًا</p></div>",
      "verses": {
        "56:18": {
          "id": 4997
        }
      }
    },
    "19": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لا يُصَدَّعُونَ عَنْها ولا يُنْزَفُونَ﴾</span> بِفَتْحِ الزّاي وكَسْرها مِن نَزَفَ الشّارِب وأَنْزَفَ أيْ لا يَحْصُل لَهُمْ مِنها صُداع ولا ذَهاب عَقْل بِخِلافِ خَمْر الدُّنْيا</p></div>",
      "verses": {
        "56:19": {
          "id": 4998
        }
      }
    },
    "20": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "56:20": {
          "id": 4999
        }
      }
    },
    "21": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولَحْم طَيْر مِمّا يَشْتَهُونَ﴾</span> لَهُمْ لِلِاسْتِمْتاعِ</p></div>",
      "verses": {
        "56:21": {
          "id": 5000
        }
      }
    },
    "22": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وحُور﴾</span> نِساء شَدِيدات سَواد العُيُون وبَياضها <span class=\"qpc-hafs\">﴿عِين﴾</span> ضِخام العُيُون كُسِرَتْ عَيْنه بَدَل ضَمّها لِمُجانَسَةِ الياء ومُفْرَده عَيْناء كَحَمْراء وفِي قِراءَة بِجَرِّ حُور عِين</p></div>",
      "verses": {
        "56:22": {
          "id": 5001
        }
      }
    },
    "23": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَأَمْثالِ اللُّؤْلُؤ المَكْنُون﴾</span> المَصُون</p></div>",
      "verses": {
        "56:23": {
          "id": 5002
        }
      }
    },
    "24": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿جَزاء﴾</span> مَفْعُول لَهُ أوْ مَصْدَر والعامِل المُقَدَّر أيْ جَعَلْنا لَهُمْ ما ذُكِرَ لِلْجَزاءِ أوْ جَزَيْناهُمْ</p></div>",
      "verses": {
        "56:24": {
          "id": 5003
        }
      }
    },
    "25": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لا يَسْمَعُونَ فِيها﴾</span> فِي الجَنَّة <span class=\"qpc-hafs\">﴿لَغْوًا﴾</span> فاحِشًا مِن الكَلام <span class=\"qpc-hafs\">﴿ولا تَأْثِيمًا﴾</span> ما يُؤْثِم</p></div>",
      "verses": {
        "56:25": {
          "id": 5004
        }
      }
    },
    "26": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إلّا﴾</span> لَكِنْ <span class=\"qpc-hafs\">﴿قِيلًا﴾</span> قَوْلًا <span class=\"qpc-hafs\">﴿سَلامًا سَلامًا﴾</span> بَدَل مِن قِيلًا فَإنَّهُمْ يَسْمَعُونَهُ</p></div>",
      "verses": {
        "56:26": {
          "id": 5005
        }
      }
    },
    "27": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "56:27": {
          "id": 5006
        }
      }
    },
    "28": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فِي سِدْر﴾</span> شَجَر النَّبْق <span class=\"qpc-hafs\">﴿مَخْضُود﴾</span> لا شَوْك فِيهِ</p></div>",
      "verses": {
        "56:28": {
          "id": 5007
        }
      }
    },
    "29": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وطَلْح﴾</span> شَجَر المَوْز <span class=\"qpc-hafs\">﴿مَنضُود﴾</span> بِالحَمْلِ مِن أسْفَله إلى أعْلاهُ</p></div>",
      "verses": {
        "56:29": {
          "id": 5008
        }
      }
    },
    "30": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وظِلّ مَمْدُود﴾</span> دائِم</p></div>",
      "verses": {
        "56:30": {
          "id": 5009
        }
      }
    },
    "31": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وماء مَسْكُوب﴾</span> جارٍ دائِمًا</p></div>",
      "verses": {
        "56:31": {
          "id": 5010
        }
      }
    },
    "32": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "56:32": {
          "id": 5011
        }
      }
    },
    "33": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لا مَقْطُوعَة﴾</span> فِي زَمَن <span class=\"qpc-hafs\">﴿ولا مَمْنُوعَة﴾</span> بِثَمَنٍ</p></div>",
      "verses": {
        "56:33": {
          "id": 5012
        }
      }
    },
    "34": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وفُرُش مَرْفُوعَة﴾</span> عَلى السُّرَر</p></div>",
      "verses": {
        "56:34": {
          "id": 5013
        }
      }
    },
    "35": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّا أنْشَأْناهُنَّ إنْشاء﴾</span> أيْ الحُور العِين مِن غَيْر وِلادَة</p></div>",
      "verses": {
        "56:35": {
          "id": 5014
        }
      }
    },
    "36": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَجَعَلْناهُنَّ أبْكارًا﴾</span> عَذارى كُلَّما أتاهُنَّ أزْواجهنَّ وجَدُوهُنَّ عَذارى ولا وجَع</p></div>",
      "verses": {
        "56:36": {
          "id": 5015
        }
      }
    },
    "37": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿عُرُبًا﴾</span> بِضَمِّ الرّاء وسُكُونها جَمْع عُرُوب وهِيَ المُتَحَبِّبَة إلى زَوْجها عِشْقًا لَهُ <span class=\"qpc-hafs\">﴿أتْرابًا﴾</span> جَمْع تِرْب أيْ مُسْتَوِيات فِي السِّنّ</p></div>",
      "verses": {
        "56:37": {
          "id": 5016
        }
      }
    },
    "38": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لِأَصْحابِ اليَمِين﴾</span> صِلَة أنْشَأْناهُنَّ أوْ جَعَلْناهُنَّ وهُمْ: <span class=\"qpc-hafs\">﴿ثُلَّة مِن الأَوَّلِينَ وثُلَّة مِن الآخِرِينَ﴾</span></p></div>",
      "verses": {
        "56:38": {
          "id": 5017
        }
      }
    },
    "39": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "56:39": {
          "id": 5018
        }
      }
    },
    "40": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "56:39",
      "verses": {
        "56:40": {
          "id": 5019
        }
      }
    },
    "41": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "56:39",
      "verses": {
        "56:41": {
          "id": 5020
        }
      }
    },
    "42": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فِي سَمُوم﴾</span> رِيح حارَّة مِن النّار تَنْفُذ فِي المَسامّ <span class=\"qpc-hafs\">﴿وحَمِيم﴾</span> ماء شَدِيد الحَرارَة</p></div>",
      "verses": {
        "56:42": {
          "id": 5021
        }
      }
    },
    "43": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وظِلّ مِن يَحْمُوم﴾</span> دُخان شَدِيد السَّواد</p></div>",
      "verses": {
        "56:43": {
          "id": 5022
        }
      }
    },
    "44": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لا بارِد﴾</span> كَغَيْرِهِ مِن الظِّلال <span class=\"qpc-hafs\">﴿ولا كَرِيم﴾</span> حَسَن المَنظَر</p></div>",
      "verses": {
        "56:44": {
          "id": 5023
        }
      }
    },
    "45": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّهُمْ كانُوا قَبْل ذَلِك﴾</span> فِي الدُّنْيا <span class=\"qpc-hafs\">﴿مُتْرَفِينَ﴾</span> مُنَعَّمِينَ لا يَتْعَبُونَ فِي الطّاعَة</p></div>",
      "verses": {
        "56:45": {
          "id": 5024
        }
      }
    },
    "46": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وكانُوا يُصِرُّونَ عَلى الحِنْث﴾</span> الذَّنْب <span class=\"qpc-hafs\">﴿العَظِيم﴾</span> أيْ الشِّرْك</p></div>",
      "verses": {
        "56:46": {
          "id": 5025
        }
      }
    },
    "47": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وكانُوا يَقُولُونَ أإذا مِتْنا وكُنّا تُرابًا وعِظامًا أإنّا لَمَبْعُوثُونَ﴾</span> فِي الهَمْزَتَيْنِ فِي المَوْضِعَيْنِ التَّحْقِيق وتَسْهِيل الثّانِيَة وإدْخال ألِف بَيْنهما عَلى الوَجْهَيْنِ</p></div>",
      "verses": {
        "56:47": {
          "id": 5026
        }
      }
    },
    "48": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أوَ آباؤُنا الأَوَّلُونَ﴾</span> بِفَتْحِ الواو لِلْعَطْفِ والهَمْزَة لِلِاسْتِفْهامِ وهُوَ فِي ذَلِكَ وفِيما قَبْله لِلِاسْتِبْعادِ وفِي قِراءَة بِسُكُونِ الواو عَطْفًا بِأَوْ والمَعْطُوف عَلَيْهِ مَحَلّ إنّ واسْمها</p></div>",
      "verses": {
        "56:48": {
          "id": 5027
        }
      }
    },
    "49": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "56:49": {
          "id": 5028
        }
      }
    },
    "50": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لَمَجْمُوعُونَ إلى مِيقات﴾</span> لِوَقْتِ <span class=\"qpc-hafs\">﴿يَوْم مَعْلُوم﴾</span> أيْ يَوْم القِيامَة</p></div>",
      "verses": {
        "56:50": {
          "id": 5029
        }
      }
    },
    "51": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "56:51": {
          "id": 5030
        }
      }
    },
    "52": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لَآكِلُونَ مِن شَجَر مِن زَقُّوم﴾</span> بَيان لِلشَّجَرِ</p></div>",
      "verses": {
        "56:52": {
          "id": 5031
        }
      }
    },
    "53": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَمالِئُونَ مِنها﴾</span> مِن الشَّجَر</p></div>",
      "verses": {
        "56:53": {
          "id": 5032
        }
      }
    },
    "54": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَشارِبُونَ عَلَيْهِ﴾</span> أيْ الزَّقُّوم المَأْكُول</p></div>",
      "verses": {
        "56:54": {
          "id": 5033
        }
      }
    },
    "55": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَشارِبُونَ شَرْب﴾</span> بِفَتْحِ الشِّين وضَمّها مَصْدَر <span class=\"qpc-hafs\">﴿الهِيم﴾</span> الإبِل العِطاش جَمْع هَيْمان لِلذَّكَرِ وهَيْمى لِلْأُنْثى كَعَطْشان وعَطْشى</p></div>",
      "verses": {
        "56:55": {
          "id": 5034
        }
      }
    },
    "56": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿هَذا نُزُلهمْ﴾</span> ما أُعِدَّ لَهُمْ <span class=\"qpc-hafs\">﴿يَوْم الدِّين﴾</span> يَوْم القِيامَة</p></div>",
      "verses": {
        "56:56": {
          "id": 5035
        }
      }
    },
    "57": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿نَحْنُ خَلَقْناكُمْ﴾</span> أوَجَدْناكُمْ مِن عَدَم <span class=\"qpc-hafs\">﴿فَلَوْلا﴾</span> هَلّا <span class=\"qpc-hafs\">﴿تُصَدِّقُونَ﴾</span> بِالبَعْثِ إذْ القادِر عَلى الإنْشاء قادِر عَلى الإعادَة</p></div>",
      "verses": {
        "56:57": {
          "id": 5036
        }
      }
    },
    "58": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أفَرَأَيْتُمْ ما تُمْنُونَ﴾</span> تُرِيقُونَ مِن المَنِيّ فِي أرْحام النِّساء</p></div>",
      "verses": {
        "56:58": {
          "id": 5037
        }
      }
    },
    "59": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أأَنْتُمْ﴾</span> بِتَحْقِيقِ الهَمْزَتَيْنِ وإبْدال الثّانِيَة ألِفًا وتَسْهِيلها وإدْخال ألِف بَيْن المُسَهَّلَة والأُخْرى وتَرْكه فِي المَواضِع الأُخْرى <span class=\"qpc-hafs\">﴿تَخْلُقُونَهُ﴾</span> أيْ المَنِيّ بَشَرًا</p></div>",
      "verses": {
        "56:59": {
          "id": 5038
        }
      }
    },
    "60": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿نَحْنُ قَدَّرْنا﴾</span> بِالتَّشْدِيدِ والتَّخْفِيف <span class=\"qpc-hafs\">﴿بَيْنكُمْ المَوْت وما نَحْنُ بِمَسْبُوقِينَ﴾</span> بِعاجِزِينَ</p></div>",
      "verses": {
        "56:60": {
          "id": 5039
        }
      }
    },
    "61": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿عَلى﴾</span> عَنْ <span class=\"qpc-hafs\">﴿أنْ نُبَدِّل﴾</span> نَجْعَل <span class=\"qpc-hafs\">﴿أمْثالكُمْ﴾</span> مَكانكُمْ <span class=\"qpc-hafs\">﴿ونُنْشِئكُمْ﴾</span> نَخْلُقكُمْ <span class=\"qpc-hafs\">﴿فِي ما لا تَعْلَمُونَ﴾</span> مِن الصُّوَر كالقِرَدَةِ والخَنازِير</p></div>",
      "verses": {
        "56:61": {
          "id": 5040
        }
      }
    },
    "62": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولَقَدْ عَلِمْتُمْ النَّشْأَة الأُولى﴾</span> وفِي قِراءَة بِسُكُونِ الشِّين <span class=\"qpc-hafs\">﴿فَلَوْلا تَذَكَّرُونَ﴾</span> فِيهِ إدْغام التّاء الثّانِيَة فِي الأَصْل فِي الذّال</p></div>",
      "verses": {
        "56:62": {
          "id": 5041
        }
      }
    },
    "63": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أفَرَأَيْتُمْ ما تَحْرُثُونَ﴾</span> تُثِيرُونَ فِي الأَرْض وتُلْقُونَ البَذْر فِيها</p></div>",
      "verses": {
        "56:63": {
          "id": 5042
        }
      }
    },
    "64": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أأَنْتُمْ تَزْرَعُونَهُ﴾</span> تُنْبِتُونَهُ</p></div>",
      "verses": {
        "56:64": {
          "id": 5043
        }
      }
    },
    "65": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لَوْ نَشاء لَجَعَلْناهُ حُطامًا﴾</span> نَباتًا يابِسًا لا حَبّ فِيهِ <span class=\"qpc-hafs\">﴿فَظَلْتُمْ﴾</span> أصْله ظَلِلْتُمْ بِكَسْرِ اللّام حُذِفَتْ تَخْفِيفًا أيْ أقَمْتُمْ نَهارًا <span class=\"qpc-hafs\">﴿تَفَكَّهُونَ﴾</span> حُذِفَتْ مِنهُ إحْدى التّاءَيْنِ فِي الأَصْل تَعْجَبُونَ مِن ذَلِكَ وتَقُولُونَ:</p></div>",
      "verses": {
        "56:65": {
          "id": 5044
        }
      }
    },
    "66": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّا لَمُغْرَمُونَ﴾</span> نَفَقَة زَرْعنا</p></div>",
      "verses": {
        "56:66": {
          "id": 5045
        }
      }
    },
    "67": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿بَلْ نَحْنُ مَحْرُومُونَ﴾</span> مَمْنُوعُونَ رِزْقنا</p></div>",
      "verses": {
        "56:67": {
          "id": 5046
        }
      }
    },
    "68": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "56:68": {
          "id": 5047
        }
      }
    },
    "69": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أأَنْتُمْ أنَزَلْتُمُوهُ مِن المُزْن﴾</span> السَّحاب جَمْع مُزْنَة</p></div>",
      "verses": {
        "56:69": {
          "id": 5048
        }
      }
    },
    "70": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لَوْ نَشاء جَعَلْناهُ أُجاجًا﴾</span> مِلْحًا لا يُمْكِن شُرْبه <span class=\"qpc-hafs\">﴿فَلَوْلا﴾</span> هَلّا</p></div>",
      "verses": {
        "56:70": {
          "id": 5049
        }
      }
    },
    "71": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أفَرَأَيْتُمْ النّار الَّتِي تُورُونَ﴾</span> تُخْرِجُونَ مِن الشَّجَر الأَخْضَر</p></div>",
      "verses": {
        "56:71": {
          "id": 5050
        }
      }
    },
    "72": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أأَنْتُمْ أنْشَأْتُمْ شَجَرَتها﴾</span> كالمَرْخِ والعَفار والكلخ</p></div>",
      "verses": {
        "56:72": {
          "id": 5051
        }
      }
    },
    "73": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿نَحْنُ جَعَلْناها تَذْكِرَة﴾</span> لِنارِ جَهَنَّم <span class=\"qpc-hafs\">﴿ومَتاعًا﴾</span> بِلُغَةٍ <span class=\"qpc-hafs\">﴿لِلْمُقْوِينَ﴾</span> لِلْمُسافِرِينَ مِن أقْوى القَوْم: أيْ صارُوا بالقوا بِالقَصْرِ والمَدّ أيْ القَفْر وهُوَ مَفازَة لا نَبات فِيها ولا ماء</p></div>",
      "verses": {
        "56:73": {
          "id": 5052
        }
      }
    },
    "74": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَسَبِّحْ﴾</span> نَزِّهْ <span class=\"qpc-hafs\">﴿بِاسْمِ﴾</span> زائِدَة <span class=\"qpc-hafs\">﴿رَبّك العَظِيم﴾</span> اللَّه</p></div>",
      "verses": {
        "56:74": {
          "id": 5053
        }
      }
    },
    "75": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَلا أُقْسِم﴾</span> لا زائِدَة <span class=\"qpc-hafs\">﴿بِمَواقِع النُّجُوم﴾</span> بِمَساقِطِها لِغُرُوبِها</p></div>",
      "verses": {
        "56:75": {
          "id": 5054
        }
      }
    },
    "76": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإنَّهُ﴾</span> أيْ القَسَم بِها <span class=\"qpc-hafs\">﴿لَقَسَم لَوْ تَعْلَمُونَ عَظِيم﴾</span> لَوْ كُنْتُمْ مِن ذَوِي العِلْم لَعَلِمْتُمْ عِظَم هَذا القَسَم</p></div>",
      "verses": {
        "56:76": {
          "id": 5055
        }
      }
    },
    "77": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّهُ﴾</span> أيْ المَتْلُوّ عَلَيْكُمْ</p></div>",
      "verses": {
        "56:77": {
          "id": 5056
        }
      }
    },
    "78": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فِي كِتاب﴾</span> مَكْتُوب <span class=\"qpc-hafs\">﴿مَكْنُون﴾</span> مَصُون وهُوَ المُصْحَف</p></div>",
      "verses": {
        "56:78": {
          "id": 5057
        }
      }
    },
    "79": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لا يَمَسّهُ﴾</span> خَبَر بِمَعْنى النَّهْي <span class=\"qpc-hafs\">﴿إلّا المُطَهَّرُونَ﴾</span> الَّذِينَ طَهَّرُوا أنْفُسهمْ مِن الأَحْداث</p></div>",
      "verses": {
        "56:79": {
          "id": 5058
        }
      }
    },
    "80": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿تَنْزِيل﴾</span> مُنَزَّل</p></div>",
      "verses": {
        "56:80": {
          "id": 5059
        }
      }
    },
    "81": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أفَبِهَذا الحَدِيث﴾</span> القُرْآن <span class=\"qpc-hafs\">﴿أنْتُمْ مُدْهِنُونَ﴾</span> مُتَهاوِنُونَ مُكَذِّبُونَ</p></div>",
      "verses": {
        "56:81": {
          "id": 5060
        }
      }
    },
    "82": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وتَجْعَلُونَ رِزْقكُمْ﴾</span> مِن المَطَر أيْ شُكْره <span class=\"qpc-hafs\">﴿أنَّكُمْ تُكَذِّبُونَ﴾</span> بِسُقْيا اللَّه حَيْثُ قُلْتُمْ مُطِرْنا بِنَوْءِ كَذا</p></div>",
      "verses": {
        "56:82": {
          "id": 5061
        }
      }
    },
    "83": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَلَوْلا﴾</span> فَهَلّا <span class=\"qpc-hafs\">﴿إذا بَلَغَتْ﴾</span> الرُّوح وقْت النَّزْع <span class=\"qpc-hafs\">﴿الحُلْقُوم﴾</span> هُوَ مَجْرى الطَّعام</p></div>",
      "verses": {
        "56:83": {
          "id": 5062
        }
      }
    },
    "84": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَنْتُمْ﴾</span> يا حاضِرِي المَيِّت <span class=\"qpc-hafs\">﴿حِينَئِذٍ تَنْظُرُونَ﴾</span> تَنْظُرُونَ إلَيْهِ</p></div>",
      "verses": {
        "56:84": {
          "id": 5063
        }
      }
    },
    "85": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ونَحْنُ أقْرَب إلَيْهِ مِنكُمْ﴾</span> بِالعِلْمِ <span class=\"qpc-hafs\">﴿ولَكِنْ لا تُبْصِرُونَ﴾</span> مِن البَصِيرَة أيْ لا تَعْلَمُونَ ذَلِكَ</p></div>",
      "verses": {
        "56:85": {
          "id": 5064
        }
      }
    },
    "86": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَلَوْلا﴾</span> فَهَلّا <span class=\"qpc-hafs\">﴿إنْ كُنْتُمْ غَيْر مَدِينِينَ﴾</span> مَجْزِيِّينَ بِأَنْ تُبْعَثُوا أيْ غَيْر مَبْعُوثِينَ بِزَعْمِكُمْ</p></div>",
      "verses": {
        "56:86": {
          "id": 5065
        }
      }
    },
    "87": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿تَرْجِعُونَها﴾</span> تَرُدُّونَ الرُّوح إلى الجَسَد بَعْد بُلُوغ الحُلْقُوم <span class=\"qpc-hafs\">﴿إنْ كُنْتُمْ صادِقِينَ﴾</span> فِيما زَعَمْتُمْ فَلَوْلا الثّانِيَة تَأْكِيد لِلْأُولى وإذا ظَرْف لِتَرْجِعُونَ المُتَعَلِّق بِهِ الشَّرْطانِ والمَعْنى: هَلّا تَرْجِعُونَها إنْ نَفَيْتُمْ البَعْث صادِقِينَ فِي نَفْيه أيْ لِيَنْتَفِيَ عَنْ مَحِلّها المَوْت كالبَعْثِ</p></div>",
      "verses": {
        "56:87": {
          "id": 5066
        }
      }
    },
    "88": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَمّا إنْ كانَ﴾</span> المَيِّت</p></div>",
      "verses": {
        "56:88": {
          "id": 5067
        }
      }
    },
    "89": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَرَوْح﴾</span> أيْ فَلَهُ اسْتِراحَة <span class=\"qpc-hafs\">﴿ورَيْحان﴾</span> أيْ رِزْق حَسَن <span class=\"qpc-hafs\">﴿وجَنَّة نَعِيم﴾</span> وهَلْ الجَواب لِأَمّا أوْ لإنْ أوْ لَهُما ؟ أقْوال.</p></div>",
      "verses": {
        "56:89": {
          "id": 5068
        }
      }
    },
    "90": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
