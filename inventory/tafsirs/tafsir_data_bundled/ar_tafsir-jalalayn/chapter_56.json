          "id": 5069
        }
      }
    },
    "91": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَسَلام لَك﴾</span> أيْ لَهُ السَّلامَة مِن العَذاب <span class=\"qpc-hafs\">﴿مِن أصْحاب اليَمِين﴾</span> مِن جِهَة أنَّهُ مِنهُمْ</p></div>",
      "verses": {
        "56:91": {
          "id": 5070
        }
      }
    },
