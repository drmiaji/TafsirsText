      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّ هَذا لَهُوَ حَقّ اليَقِين﴾</span> مِن إضافَة المَوْصُوف إلى صِفَته</p></div>",
      "verses": {
        "56:95": {
          "id": 5074
        }
