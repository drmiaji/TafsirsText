{
  "chapter": 79,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والنّازِعات﴾</span> المَلائِكَة تَنْزِع أرْواح الكُفّار <span class=\"qpc-hafs\">﴿غَرْقًا﴾</span> نَزْعًا بِشِدَّةٍ</p></div>",
      "verses": {
        "79:1": {
          "id": 5713
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والنّاشِطات نَشْطًا﴾</span> المَلائِكَة تَنْشِط أرْواح المُؤْمِنِينَ، أيْ تَسُلّها بِرِفْقٍ</p></div>",
      "verses": {
        "79:2": {
          "id": 5714
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والسّابِحات سَبْحًا﴾</span> المَلائِكَة تَسْبَح مِن السَّماء بِأَمْرِهِ تَعالى، أيْ تَنْزِل</p></div>",
      "verses": {
        "79:3": {
          "id": 5715
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فالسّابِقات سَبْقًا﴾</span> المَلائِكَة تَسْبِق بِأَرْواحِ المُؤْمِنِينَ إلى الجَنَّة</p></div>",
      "verses": {
        "79:4": {
          "id": 5716
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فالمُدَبِّرات أمْرًا﴾</span> المَلائِكَة تُدَبِّر أمْر الدُّنْيا، أيْ تَنْزِل بِتَدْبِيرِهِ، وجَواب هَذِهِ الأَقْسام مَحْذُوف، أيْ لَتُبْعَثُنَّ يا كُفّار مَكَّة وهُوَ عامِل فِي \" يَوْم تَرْجُف الرّاجِفَة \"</p></div>",
      "verses": {
        "79:5": {
          "id": 5717
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَوْم تَرْجُف الرّاجِفَة﴾</span> النَّفْخَة الأُولى بِها يَرْجُف كُلّ شَيْء، أيْ يَتَزَلْزَل فَوُصِفَتْ بِما يَحْدُث مِنها</p></div>",
      "verses": {
        "79:6": {
          "id": 5718
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿تَتْبَعها الرّادِفَة﴾</span> النَّفْخَة الثّانِيَة وبَيْنهما أرْبَعُونَ سَنَة، والجُمْلَة حال مِن الرّاجِفَة، فاليَوْم واسِع لِلنَّفْخَتَيْنِ وغَيْرهما فَصَحَّ ظَرْفِيَّته لِلْبَعْثِ الواقِع عَقِب الثّانِيَة</p></div>",
      "verses": {
        "79:7": {
          "id": 5719
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قُلُوب يَوْمئِذٍ واجِفَة﴾</span> خائِفَة قَلِقَة</p></div>",
      "verses": {
        "79:8": {
          "id": 5720
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أبْصارها خاشِعَة﴾</span> ذَلِيلَة لِهَوْلِ ما تَرى</p></div>",
      "verses": {
        "79:9": {
          "id": 5721
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَقُولُونَ﴾</span> أيْ أرْباب القُلُوب والأَبْصار اِسْتِهْزاء وإنْكارًا لِلْبَعْثِ <span class=\"qpc-hafs\">﴿أئِنّا﴾</span> بِتَحْقِيقِ الهَمْزَتَيْنِ وتَسْهِيل الثّانِيَة وإدْخال ألِف بَيْنهما عَلى الوَجْهَيْنِ فِي المَوْضِعَيْنِ <span class=\"qpc-hafs\">﴿لَمَرْدُودُونَ فِي الحافِرَة﴾</span> أيْ أنُرَدُّ بَعْد المَوْت إلى الحَياة، والحافِرَة: اِسْم لِأَوَّلِ الأَمْر، ومِنهُ رَجَعَ فُلان فِي حافِرَته: إذا رَجَعَ مِن حَيْثُ جاءَ</p></div>",
      "verses": {
        "79:10": {
          "id": 5722
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أئِذا كُنّا عِظامًا نَخِرَة﴾</span> وفِي قِراءَة ناخِرَة بالِيَة مُتَفَتِّتَة نَحْيا</p></div>",
      "verses": {
        "79:11": {
          "id": 5723
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالُوا تِلْكَ﴾</span> أيْ رَجْعَتنا إلى الحَياة <span class=\"qpc-hafs\">﴿إذًا﴾</span> إنْ صَحَّتْ <span class=\"qpc-hafs\">﴿كَرَّة﴾</span> رَجْعَة <span class=\"qpc-hafs\">﴿خاسِرَة﴾</span> ذات خُسْران</p></div>",
      "verses": {
        "79:12": {
          "id": 5724
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَإنَّما هِيَ﴾</span> أيْ الرّادِفَة الَّتِي يَعْقُبها البَعْث <span class=\"qpc-hafs\">﴿زَجْرَة﴾</span> نَفْخَة <span class=\"qpc-hafs\">﴿واحِدَة﴾</span> فَإذا نُفِخَتْ</p></div>",
      "verses": {
        "79:13": {
          "id": 5725
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَإذا هُمْ﴾</span> أيْ كُلّ الخَلائِق <span class=\"qpc-hafs\">﴿بِالسّاهِرَةِ﴾</span> بِوَجْهِ الأَرْض أحْياء بَعْدَما كانُوا بِبَطْنِها أمْواتًا</p></div>",
      "verses": {
        "79:14": {
          "id": 5726
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿هَلْ أتاك﴾</span> يا مُحَمَّد <span class=\"qpc-hafs\">﴿حَدِيث مُوسى﴾</span> عامِل فِي \" إذْ ناداهُ رَبّه بِالوادِ المُقَدَّس طُوًى \"</p></div>",
      "verses": {
        "79:15": {
          "id": 5727
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إذْ ناداهُ رَبّه بِالوادِ المُقَدَّس طُوًى﴾</span> اِسْم الوادِي بِالتَّنْوِينِ وتَرْكه</p></div>",
      "verses": {
        "79:16": {
          "id": 5728
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿اِذْهَبْ إلى فِرْعَوْن إنَّهُ طَغى﴾</span> تَجاوَزَ الحَدّ فِي الكُفْر</p></div>",
      "verses": {
        "79:17": {
          "id": 5729
        }
      }
    },
    "18": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَقُلْ هَلْ لَك﴾</span> أدْعُوك <span class=\"qpc-hafs\">﴿إلى أنْ تَزَكّى﴾</span> وفِي قِراءَة بِتَشْدِيدِ الزّاي بِإدْغامِ التّاء الثّانِيَة فِي الأَصْل فِيها: تَتَطَهَّر مِن الشِّرْك بِأَنْ تَشْهَد أنْ لا إلَه إلّا اللَّه</p></div>",
      "verses": {
        "79:18": {
          "id": 5730
        }
      }
    },
    "19": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَهْدِيَك إلى رَبّك﴾</span> أدُلّك عَلى مَعْرِفَته بِبُرْهانٍ <span class=\"qpc-hafs\">﴿فَتَخْشى﴾</span> فَتَخافهُ</p></div>",
      "verses": {
        "79:19": {
          "id": 5731
        }
      }
    },
    "20": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَراهُ الآيَة الكُبْرى﴾</span> مِن آياته السَّبْع وهِيَ اليَد أوْ العَصا</p></div>",
      "verses": {
        "79:20": {
          "id": 5732
        }
      }
    },
    "21": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَكَذَّبَ﴾</span> فِرْعَوْن مُوسى <span class=\"qpc-hafs\">﴿وعَصى﴾</span> اللَّه تَعالى</p></div>",
      "verses": {
        "79:21": {
          "id": 5733
        }
      }
    },
    "22": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ أدْبَرَ﴾</span> عَنْ الإيمان <span class=\"qpc-hafs\">﴿يَسْعى﴾</span> فِي الأَرْض بِالفَسادِ</p></div>",
      "verses": {
        "79:22": {
          "id": 5734
        }
      }
    },
    "23": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَحَشَرَ﴾</span> جَمَعَ السَّحَرَة وجُنْده \" فَنادى \"</p></div>",
      "verses": {
        "79:23": {
          "id": 5735
        }
      }
    },
    "24": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَقالَ أنا رَبّكُمْ الأَعْلى﴾</span> لا رَبّ فَوْقِي</p></div>",
      "verses": {
        "79:24": {
          "id": 5736
        }
      }
    },
    "25": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَخَذَهُ اللَّه﴾</span> أهْلَكَهُ بِالغَرَقِ <span class=\"qpc-hafs\">﴿نَكال﴾</span> عُقُوبَة <span class=\"qpc-hafs\">﴿الآخِرَة﴾</span> أيْ هَذِهِ الكَلِمَة <span class=\"qpc-hafs\">﴿والأُولى﴾</span> أيْ قَوْله قَبْلها: \" ما عَلِمْت لَكُمْ مِن إلَه غَيْرِي \" وكانَ بَيْنهما أرْبَعُونَ سَنَة</p></div>",
      "verses": {
        "79:25": {
          "id": 5737
        }
      }
    },
    "26": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّ فِي ذَلِكَ﴾</span> المَذْكُور <span class=\"qpc-hafs\">﴿لَعِبْرَةٌ لِمَن يَخْشى﴾</span> اللَّه تَعالى</p></div>",
      "verses": {
        "79:26": {
          "id": 5738
        }
      }
    },
    "27": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أأَنَتُّمْ﴾</span> بِتَحْقِيقِ الهَمْزَتَيْنِ وإبْدال الثّانِيَة ألِفًا وتَسْهِيلها وإدْخال ألِف بَيْن المُسَهَّلَة والأُخْرى وتَرْكه، أيْ مُنْكِرُو البَعْث <span class=\"qpc-hafs\">﴿أشَدّ خَلْقًا أمْ السَّماء﴾</span> أشَدّ خَلْقًا <span class=\"qpc-hafs\">﴿بَناها﴾</span> بَيان لِكَيْفِيَّةِ خَلْقها</p></div>",
      "verses": {
        "79:27": {
          "id": 5739
        }
      }
    },
    "28": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿رَفَعَ سَمْكها﴾</span> تَفْسِير لِكَيْفِيَّةِ البِناء، أيْ جَعَلَ سَمْتها فِي جِهَة العُلُوّ رَفِيعًا، وقِيلَ سَمْكها سَقْفها <span class=\"qpc-hafs\">﴿فَسَوّاها﴾</span> جَعَلَها مُسْتَوِيَة بِلا عَيْب</p></div>",
      "verses": {
        "79:28": {
          "id": 5740
        }
      }
    },
    "29": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَغْطَشَ لَيْلها﴾</span> أظْلَمَهُ <span class=\"qpc-hafs\">﴿وأَخْرَجَ ضُحاها﴾</span> أبْرَزَ نُور شَمْسها وأُضِيفَ إلَيْها اللَّيْل لِأَنَّهُ ظِلّها والشَّمْس لِأَنَّها سِراجها</p></div>",
      "verses": {
        "79:29": {
          "id": 5741
        }
      }
    },
    "30": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والأَرْض بَعْد ذَلِكَ دَحاها﴾</span> بَسَطَها وكانَتْ مَخْلُوقَة قَبْل السَّماء مِن غَيْر دَحْو</p></div>",
      "verses": {
        "79:30": {
          "id": 5742
        }
      }
    },
    "31": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أخْرَجَ﴾</span> حال بِإضْمارِ قَدْ أيْ مُخْرِجًا <span class=\"qpc-hafs\">﴿مِنها ماءَها﴾</span> بِتَفْجِيرِ عُيُونها <span class=\"qpc-hafs\">﴿ومَرْعاها﴾</span> ما تَرْعاهُ النَّعَم مِن الشَّجَر والعُشْب وما يَأْكُلهُ النّاس مِن الأَقْوات والثِّمار، وإطْلاق المَرْعى عَلَيْهِ اِسْتِعارَة</p></div>",
      "verses": {
        "79:31": {
          "id": 5743
        }
      }
    },
    "32": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والجِبال أرْساها﴾</span> أثْبَتَها عَلى وجْه الأَرْض لِتَسْكُن</p></div>",
      "verses": {
        "79:32": {
          "id": 5744
        }
      }
    },
    "33": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿مَتاعًا﴾</span> مَفْعُول لَهُ لِمُقَدَّرٍ، أيْ فَعَلَ ذَلِكَ مُتْعَة أوْ مَصْدَر أيْ تَمْتِيعًا <span class=\"qpc-hafs\">﴿لَكُمْ ولِأَنْعامِكُمْ﴾</span> جَمْع نَعَم وهِيَ الإبِل والبَقَر والغَنَم</p></div>",
      "verses": {
        "79:33": {
          "id": 5745
        }
      }
    },
    "34": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَإذا جاءَتْ الطّامَّة الكُبْرى﴾</span> النَّفْخَة الثّانِيَة</p></div>",
      "verses": {
        "79:34": {
          "id": 5746
        }
      }
    },
    "35": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَوْم يَتَذَكَّر الإنْسان﴾</span> بَدَل مِن إذا <span class=\"qpc-hafs\">﴿ما سَعى﴾</span> فِي الدُّنْيا مِن خَيْر وشَرّ</p></div>",
      "verses": {
        "79:35": {
          "id": 5747
        }
      }
    },
    "36": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وبُرِّزَتْ﴾</span> أُظْهِرَتْ <span class=\"qpc-hafs\">﴿الجَحِيم﴾</span> النّار المُحْرِقَة <span class=\"qpc-hafs\">﴿لِمَن يَرى﴾</span> لِكُلِّ راءٍ وجَواب إذا: \" فَأَمّا مَن طَغى \"</p></div>",
      "verses": {
        "79:36": {
          "id": 5748
        }
      }
    },
    "37": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَمّا مَن طَغى﴾</span> كَفَرَ</p></div>",
      "verses": {
        "79:37": {
          "id": 5749
        }
      }
    },
    "38": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وآثَرَ الحَياة الدُّنْيا﴾</span> بِاتِّباعِ الشَّهَوات</p></div>",
      "verses": {
        "79:38": {
          "id": 5750
        }
      }
    },
    "39": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَإنَّ الجَحِيم هِيَ المَأْوى﴾</span> مَأْواهُ</p></div>",
      "verses": {
        "79:39": {
          "id": 5751
        }
      }
    },
    "40": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَمّا مَن خافَ مَقام رَبّه﴾</span> قِيامه بَيْن يَدَيْهِ <span class=\"qpc-hafs\">﴿ونَهى النَّفْس﴾</span> الأَمّارَة <span class=\"qpc-hafs\">﴿عَنْ الهَوى﴾</span> المُرْدِي بِاتِّباعِ الشَّهَوات</p></div>",
      "verses": {
        "79:40": {
          "id": 5752
        }
      }
    },
    "41": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَإنَّ الجَنَّة هِيَ المَأْوى﴾</span> وحاصِل الجَواب: فالعاصِي فِي النّار والمُطِيع فِي الجَنَّة</p></div>",
      "verses": {
        "79:41": {
          "id": 5753
        }
      }
    },
    "42": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَسْأَلُونَك﴾</span> أيْ كُفّار مَكَّة <span class=\"qpc-hafs\">﴿عَنْ السّاعَة أيّانَ مُرْساها﴾</span> مَتى وُقُوعها وقِيامها</p></div>",
      "verses": {
        "79:42": {
          "id": 5754
        }
      }
    },
    "43": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فِيمَ﴾</span> فِي أيّ شَيْء <span class=\"qpc-hafs\">﴿أنْتَ مِن ذِكْراها﴾</span> أيْ لَيسَ عِنْدك عِلْمها حَتّى تَذْكُرها</p></div>",
      "verses": {
        "79:43": {
          "id": 5755
        }
      }
    },
    "44": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إلى رَبّك مُنْتَهاها﴾</span> مُنْتَهى عِلْمها لا يَعْلَمهُ غَيْره</p></div>",
      "verses": {
        "79:44": {
          "id": 5756
        }
      }
    },
    "45": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّما أنْتَ مُنْذِر﴾</span> إنَّما يَنْفَع إنْذارك <span class=\"qpc-hafs\">﴿مَن يَخْشاها﴾</span> يَخافها</p></div>",
      "verses": {
        "79:45": {
          "id": 5757
        }
      }
    },
    "46": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَأَنَّهُمْ يَوْم يَرَوْنَها لَمْ يَلْبَثُوا﴾</span> فِي قُبُورهمْ <span class=\"qpc-hafs\">﴿إلّا عَشِيَّة أوْ ضُحاها﴾</span> عَشِيَّة يَوْم أوْ بُكْرَته وصَحَّ إضافَة الضُّحى إلى العَشِيَّة لِما بَيْنهما مِن المُلابَسَة إذْ هُما طَرَفا النَّهار، وحَسَّنَ الإضافَة وُقُوع الكَلِمَة الفاصِلَة.</p></div>",
      "verses": {
        "79:46": {
          "id": 5758
        }
      }
    }
  }
}