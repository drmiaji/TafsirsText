{
  "chapter": 85,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والسَّماء ذات البُرُوج﴾</span> الكَواكِب اِثْنَيْ عَشَر بُرْجًا تَقَدَّمَتْ فِي الفُرْقان</p></div>",
      "verses": {
        "85:1": {
          "id": 5910
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿واليَوْم المَوْعُود﴾</span> يَوْم القِيامَة</p></div>",
      "verses": {
        "85:2": {
          "id": 5911
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وشاهِد﴾</span> يَوْم الجُمْعَة <span class=\"qpc-hafs\">﴿ومَشْهُود﴾</span> يَوْم عَرَفَة كَذا فُسِّرَتْ الثَّلاثَة فِي الحَدِيث فالأَوَّل مَوْعُود بِهِ والثّانِي شاهِد بِالعَمَلِ فِيهِ، والثّالِث تَشْهَدهُ النّاس والمَلائِكَة، وجَواب القَسَم مَحْذُوف صَدْره، تَقْدِيره لَقَدْ</p></div>",
      "verses": {
        "85:3": {
          "id": 5912
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قُتِلَ﴾</span> لُعِنَ <span class=\"qpc-hafs\">﴿أصْحاب الأُخْدُود﴾</span> الشَّقّ فِي الأَرْض</p></div>",
      "verses": {
        "85:4": {
          "id": 5913
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿النّار﴾</span> بَدَل اِشْتِمال مِنهُ <span class=\"qpc-hafs\">﴿ذات الوُقُود﴾</span> ما تُوقَد بِهِ</p></div>",
      "verses": {
        "85:5": {
          "id": 5914
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إذْ هُمْ عَلَيْها﴾</span> حَوْلها عَلى جانِب الأُخْدُود عَلى الكَراسِيّ \" قُعُود \"</p></div>",
      "verses": {
        "85:6": {
          "id": 5915
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وهُمْ عَلى ما يَفْعَلُونَ بِالمُؤْمِنِينَ﴾</span> بِاللَّهِ مِن تَعْذِيبهمْ بِالإلْقاءِ فِي النّار إنْ لَمْ يَرْجِعُوا عَنْ إيمانهمْ <span class=\"qpc-hafs\">﴿شُهُود﴾</span> حُضُور، رُوِيَ أنَّ اللَّه أنْجى المُؤْمِنِينَ المُلْقَيْنَ فِي النّار بِقَبْضِ أرْواحهمْ قَبْل وُقُوعهمْ فِيها وخَرَجَتْ النّار إلى مَن ثَمَّ فَأَحْرَقَتْهُمْ</p></div>",
      "verses": {
        "85:7": {
          "id": 5916
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما نَقَمُوا مِنهُمْ إلّا يُؤْمِنُوا بِاللَّهِ العَزِيز﴾</span> فِي مُلْكه <span class=\"qpc-hafs\">﴿الحَمِيد﴾</span> المَحْمُود</p></div>",
      "verses": {
        "85:8": {
          "id": 5917
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿الَّذِي لَهُ مُلْك السَّمَوات والأَرْض واللَّه عَلى كُلّ شَيْء شَهِيد﴾</span> أيْ ما أنْكَرَ الكُفّار عَلى المُؤْمِنِينَ إلّا إيمانهمْ</p></div>",
      "verses": {
        "85:9": {
          "id": 5918
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّ الَّذِينَ فَتَنُوا المُؤْمِنِينَ والمُؤْمِنات﴾</span> بِالإحْراقِ <span class=\"qpc-hafs\">﴿ثُمَّ لَمْ يَتُوبُوا فَلَهُمْ عَذاب جَهَنَّم﴾</span> بِكُفْرِهِمْ <span class=\"qpc-hafs\">﴿ولَهُمْ عَذاب الحَرِيق﴾</span> أيْ عَذاب إحْراقهمْ المُؤْمِنِينَ فِي الآخِرَة، وقِيلَ فِي الدُّنْيا بِأَنْ أُخْرِجَتْ النّار فَأَحْرَقَتْهُمْ كَما تَقَدَّمَ</p></div>",
      "verses": {
        "85:10": {
          "id": 5919
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "85:11": {
          "id": 5920
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّ بَطْش رَبّك﴾</span> بِالكَفّارِ <span class=\"qpc-hafs\">﴿لَشَدِيد﴾</span> بِحَسْب إرادَته</p></div>",
      "verses": {
        "85:12": {
          "id": 5921
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّهُ هُوَ يُبْدِئ﴾</span> الخَلْق <span class=\"qpc-hafs\">﴿ويُعِيد﴾</span> فَلا يُعْجِزهُ ما يُرِيد</p></div>",
      "verses": {
        "85:13": {
          "id": 5922
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وهُوَ الغَفُور﴾</span> لِلْمُذْنِبِينَ المُؤْمِنِينَ ٤ \" الوَدُود \" <span class=\"qpc-hafs\">﴿المُتَوَدِّد إلى أوْلِيائِهِ بِالكَرامَةِ﴾</span></p></div>",
      "verses": {
        "85:14": {
          "id": 5923
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ذُو العَرْش﴾</span> خالِقه ومالِكه <span class=\"qpc-hafs\">﴿المَجِيد﴾</span> بِالرَّفْعِ: المُسْتَحِقّ لِكَمالِ صِفات العُلُوّ</p></div>",
      "verses": {
        "85:15": {
          "id": 5924
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَعّال لِما يُرِيد﴾</span> لا يُعْجِزهُ شَيْء</p></div>",
      "verses": {
        "85:16": {
          "id": 5925
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿هَلْ أتاك﴾</span> يا مُحَمَّد \" حَدِيث الجُنُود \"</p></div>",
      "verses": {
        "85:17": {
          "id": 5926
        }
      }
    },
    "18": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فِرْعَوْن وثَمُود﴾</span> بَدَل مِن الجُنُود واسْتُغْنِيَ بِذِكْرِ فِرْعَوْن عَنْ أتْباعه، وحَدِيثهمْ أنَّهُمْ أُهْلِكُوا بِكُفْرِهِمْ وهَذا تَنْبِيه لِمَن كَفَرَ بِالنَّبِيِّ ﷺ والقُرْآن لِيَتَّعِظُوا</p></div>",
      "verses": {
        "85:18": {
          "id": 5927
        }
      }
    },
    "19": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿بَلْ الَّذِينَ كَفَرُوا فِي تَكْذِيب﴾</span> بِما ذُكِرَ</p></div>",
      "verses": {
        "85:19": {
          "id": 5928
        }
      }
    },
    "20": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿واللَّه مِن ورائِهِمْ مُحِيط﴾</span> لا عاصِم لَهُمْ مِنهُ</p></div>",
      "verses": {
        "85:20": {
          "id": 5929
        }
      }
    },
    "21": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿بَلْ هُوَ قُرْآن مَجِيد﴾</span> عَظِيم</p></div>",
      "verses": {
        "85:21": {
          "id": 5930
        }
      }
    },
    "22": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فِي لَوْح﴾</span> هُوَ فِي الهَواء فَوْق السَّماء السّابِعَة <span class=\"qpc-hafs\">﴿مَحْفُوظ﴾</span> بِالجَرِّ مِن الشَّياطِين ومِن تَغْيِير شَيْء مِنهُ طُوله ما بَيْن السَّماء والأَرْض، وعَرْضه ما بَيْن المَشْرِق والمَغْرِب، وهُوَ دُرَّة بَيْضاء قالَهُ اِبْن عَبّاس رَضِيَ اللَّه عَنْهُما.</p></div>",
      "verses": {
        "85:22": {
          "id": 5931
        }
      }
    }
  }
}