{
  "chapter": 104,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ويْل﴾</span> كَلِمَة عَذاب أوْ وادٍ فِي جَهَنَّم <span class=\"qpc-hafs\">﴿لِكُلِّ هُمَزَة لُمَزَة﴾</span> أيْ كَثِير الهَمْز واللَّمْز، أيْ الغِيبَة نَزَلَتْ فِيمَن كانَ يَغْتاب النَّبِيّ ﷺ والمُؤْمِنِينَ كَأُمَيَّة بْن خَلَف والوَلِيد بْن المُغِيرَة وغَيْرهما</p></div>",
      "verses": {
        "104:1": {
          "id": 6180
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿الَّذِي جَمَعَ﴾</span> بِالتَّخْفِيفِ والتَّشْدِيد <span class=\"qpc-hafs\">﴿مالًا وعَدَّدَهُ﴾</span> أحْصاهُ وجَعَلَهُ عُدَّة لِحَوادِث الدَّهْر</p></div>",
      "verses": {
        "104:2": {
          "id": 6181
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَحْسَب﴾</span> لِجَهْلِهِ <span class=\"qpc-hafs\">﴿أنَّ ماله أخْلَدَهُ﴾</span> جَعَلَهُ خالِدًا لا يَمُوت</p></div>",
      "verses": {
        "104:3": {
          "id": 6182
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَلّا﴾</span> رَدْع <span class=\"qpc-hafs\">﴿لَيُنَبَذَنَّ﴾</span> جَواب قَسَم مَحْذُوف، أيْ لَيُطْرَحَنَّ <span class=\"qpc-hafs\">﴿فِي الحُطَمَة﴾</span> الَّتِي تُحَطِّم كُلّ ما أُلْقِيَ فِيها</p></div>",
      "verses": {
        "104:4": {
          "id": 6183
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما أدْراك﴾</span> أعْلَمَك <span class=\"qpc-hafs\">﴿ما الحُطَمَة﴾</span></p></div>",
      "verses": {
        "104:5": {
          "id": 6184
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿نار اللَّه المُوقِدَة﴾</span> المُسَعَّرَة</p></div>",
      "verses": {
        "104:6": {
          "id": 6185
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿الَّتِي تَطَّلِع﴾</span> تُشْرِف <span class=\"qpc-hafs\">﴿عَلى الأَفْئِدَة﴾</span> القُلُوب فَتُحْرِقها وأَلَمها أشَدّ مِن ألَم غَيْرها لِلُطْفِها</p></div>",
      "verses": {
        "104:7": {
          "id": 6186
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّها عَلَيْهِمْ﴾</span> جَمَعَ الضَّمِير رِعايَة لِمَعْنى كُلّ <span class=\"qpc-hafs\">﴿مُؤْصَدَة﴾</span> بِالهَمْزِ وبِالواوِ بَدَله، مُطْبَقَة</p></div>",
      "verses": {
        "104:8": {
          "id": 6187
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فِي عَمَد﴾</span> بِضَمِّ الحَرْفَيْنِ وبِفَتْحِهِما <span class=\"qpc-hafs\">﴿مُمَدَّدَة﴾</span> صِفَة لِما قَبْله فَتَكُون النّار داخِل العَمَد</p></div>",
      "verses": {
        "104:9": {
          "id": 6188
        }
      }
    }
  }
}