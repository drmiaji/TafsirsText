{
  "chapter": 83,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ويْل﴾</span> كَلِمَة عَذاب، أوْ وادٍ فِي جَهَنَّم \" لِلْمُطَفِّفِينَ \"</p></div>",
      "verses": {
        "83:1": {
          "id": 5849
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿الَّذِينَ إذا اِكْتالُوا عَلى﴾</span> أيْ مِن <span class=\"qpc-hafs\">﴿النّاس يَسْتَوْفُونَ﴾</span> الكَيْل</p></div>",
      "verses": {
        "83:2": {
          "id": 5850
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإذا كالُوهُمْ﴾</span> أيْ كالُوا لَهُمْ <span class=\"qpc-hafs\">﴿أوْ وزَنُوهُمْ﴾</span> أيْ وزَنُوا لَهُمْ <span class=\"qpc-hafs\">﴿يُخْسِرُونَ﴾</span> يُنْقِصُونَ الكَيْل أوْ الوَزْن</p></div>",
      "verses": {
        "83:3": {
          "id": 5851
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ألا﴾</span> اِسْتِفْهام تَوْبِيخ <span class=\"qpc-hafs\">﴿يَظُنّ﴾</span> يَتَيَقَّن \" أُولَئِكَ أنَّهُمْ مَبْعُوثُونَ \"</p></div>",
      "verses": {
        "83:4": {
          "id": 5852
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لِيَوْمٍ عَظِيم﴾</span> أيْ فِيهِ وهُوَ يَوْم القِيامَة</p></div>",
      "verses": {
        "83:5": {
          "id": 5853
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَوْم﴾</span> بَدَل مِن مَحَلّ لِيَوْمٍ فَناصِبه مَبْعُوثُونَ <span class=\"qpc-hafs\">﴿يَقُوم النّاس﴾</span> مِن قُبُورهمْ <span class=\"qpc-hafs\">﴿لِرَبِّ العالَمِينَ﴾</span> الخَلائِق لِأَجْلِ أمْره وحِسابه وجَزائِهِ</p></div>",
      "verses": {
        "83:6": {
          "id": 5854
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَلّا﴾</span> حَقًّا <span class=\"qpc-hafs\">﴿إنَّ كِتاب الفُجّار﴾</span> أيْ كِتاب أعْمال الكُفّار <span class=\"qpc-hafs\">﴿لَفِي سِجِّين﴾</span> قِيلَ هُوَ كِتاب جامِع لِأَعْمالِ الشَّياطِين والكَفَرَة، وقِيلَ هُوَ مَكان أسْفَل الأَرْض السّابِعَة وهُوَ مَحَلّ إبْلِيس وجُنُوده</p></div>",
      "verses": {
        "83:7": {
          "id": 5855
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما أدْراك ما سِجِّين﴾</span> ما كِتاب سِجِّين</p></div>",
      "verses": {
        "83:8": {
          "id": 5856
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كِتاب مَرْقُوم﴾</span> مَخْتُوم</p></div>",
      "verses": {
        "83:9": {
          "id": 5857
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "83:10": {
          "id": 5858
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿الَّذِينَ يُكَذِّبُونَ بِيَوْمِ الدِّين﴾</span> الجَزاء بَدَل أوْ بَيان لِلْمُكَذِّبِينَ</p></div>",
      "verses": {
        "83:11": {
          "id": 5859
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما يُكَذِّب بِهِ إلّا كُلّ مُعْتَدٍ﴾</span> مُتَجاوِز الحَدّ <span class=\"qpc-hafs\">﴿أثِيم﴾</span> صِيغَة مُبالَغَة</p></div>",
      "verses": {
        "83:12": {
          "id": 5860
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إذا تُتْلى عَلَيْهِ آياتنا﴾</span> القُرْآن <span class=\"qpc-hafs\">﴿قالَ أساطِير الأَوَّلِينَ﴾</span> الحِكايات الَّتِي سُطِّرَتْ قَدِيمًا جَمَعَ أُسْطُورَة بِالضَّمِّ أوْ إسْطارَة بِالكَسْرِ</p></div>",
      "verses": {
        "83:13": {
          "id": 5861
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَلّا﴾</span> رَدْع وزَجْر لِقَوْلِهِمْ ذَلِكَ <span class=\"qpc-hafs\">﴿بَلْ رانَ﴾</span> غَلَبَ <span class=\"qpc-hafs\">﴿عَلى قُلُوبهمْ﴾</span> فَغَشِيَها <span class=\"qpc-hafs\">﴿ما كانُوا يَكْسِبُونَ﴾</span> مِن المَعاصِي فَهُوَ كالصَّدَأِ</p></div>",
      "verses": {
        "83:14": {
          "id": 5862
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَلّا﴾</span> حَقًّا <span class=\"qpc-hafs\">﴿إنَّهُمْ عَنْ رَبّهمْ يَوْمئِذٍ﴾</span> يَوْم القِيامَة <span class=\"qpc-hafs\">﴿لَمَحْجُوبُونَ﴾</span> فَلا يَرَوْنَهُ</p></div>",
      "verses": {
        "83:15": {
          "id": 5863
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ إنَّهُمْ لَصالُوا الجَحِيم﴾</span> لَداخِلُو النّار المُحْرِقَة</p></div>",
      "verses": {
        "83:16": {
          "id": 5864
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ يُقال﴾</span> لَهُمْ <span class=\"qpc-hafs\">﴿هَذا﴾</span> أيْ العَذاب \" الَّذِي كُنْتُمْ بِهِ تُكَذِّبُونَ \"</p></div>",
      "verses": {
        "83:17": {
          "id": 5865
        }
      }
    },
    "18": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَلّا﴾</span> حَقًّا <span class=\"qpc-hafs\">﴿إنَّ كِتاب الأَبْرار﴾</span> أيْ كِتاب أعْمال المُؤْمِنِينَ الصّادِقِينَ فِي إيمانهمْ <span class=\"qpc-hafs\">﴿لَفِي عِلِّيِّينَ﴾</span> قِيلَ هُوَ كِتاب جامِع لِأَعْمالِ الخَيْر مِن المَلائِكَة ومُؤْمِنِي الثَّقَلَيْنِ، وقِيلَ هُوَ مَكان فِي السَّماء السّابِعَة تَحْت العَرْش</p></div>",
      "verses": {
        "83:18": {
          "id": 5866
        }
      }
    },
    "19": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما أدْراك﴾</span> أعْلَمَك <span class=\"qpc-hafs\">﴿ما عِلِّيُّونَ﴾</span> ما كِتاب عِلِّيِّينَ</p></div>",
      "verses": {
        "83:19": {
          "id": 5867
        }
      }
    },
    "20": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كِتاب مَرْقُوم﴾</span> مَخْتُوم</p></div>",
      "verses": {
        "83:20": {
          "id": 5868
        }
      }
    },
    "21": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَشْهَدهُ المُقَرَّبُونَ﴾</span> مِن المَلائِكَة</p></div>",
      "verses": {
        "83:21": {
          "id": 5869
        }
      }
    },
    "22": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّ الأَبْرار لَفِي نَعِيم﴾</span> جَنَّة</p></div>",
      "verses": {
        "83:22": {
          "id": 5870
        }
      }
    },
    "23": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿عَلى الأَرائِك﴾</span> السُّرَر فِي الحِجال <span class=\"qpc-hafs\">﴿يَنْظُرُونَ﴾</span> ما أُعْطُوا مِن النَّعِيم</p></div>",
      "verses": {
        "83:23": {
          "id": 5871
        }
      }
    },
    "24": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿تَعْرِف فِي وُجُوههمْ نَضْرَة النَّعِيم﴾</span> بَهْجَة التَّنَعُّم وحُسْنه</p></div>",
      "verses": {
        "83:24": {
          "id": 5872
        }
      }
    },
    "25": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يُسْقَوْنَ مِن رَحِيق﴾</span> خَمْر خالِصَة مِن الدَّنَس <span class=\"qpc-hafs\">﴿مَخْتُوم﴾</span> عَلى إنائِها لا يَفُكّ خَتْمه غَيْرهمْ</p></div>",
      "verses": {
        "83:25": {
          "id": 5873
        }
      }
    },
    "26": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿خِتامه مِسْك﴾</span> أيْ آخِر شُرْبه تَفُوح مِنهُ رائِحَة المِسْك <span class=\"qpc-hafs\">﴿وفِي ذَلِكَ فَلْيَتَنافَسْ المُتَنافِسُونَ﴾</span> فَلْيَرْغَبُوا بِالمُبادَرَةِ إلى طاعَة اللَّه</p></div>",
      "verses": {
        "83:26": {
          "id": 5874
        }
      }
    },
    "27": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ومِزاجه﴾</span> أيْ ما يُمْزَج بِهِ <span class=\"qpc-hafs\">﴿مِن تَسْنِيم﴾</span> فُسِّرَ بِقَوْلِهِ \" عَيْنًا \"</p></div>",
      "verses": {
        "83:27": {
          "id": 5875
        }
      }
    },
    "28": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿عَيْنًا﴾</span> فَنَصَبَهُ بِأَمْدَحَ مُقَدَّرًا <span class=\"qpc-hafs\">﴿يَشْرَب بِها المُقَرَّبُونَ﴾</span> مِنها، أوْ ضَمَّنَ يَشْرَب مَعْنى يَلْتَذّ</p></div>",
      "verses": {
        "83:28": {
          "id": 5876
        }
      }
    },
    "29": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّ الَّذِينَ أجْرَمُوا﴾</span> كَأَبِي جَهْل ونَحْوه <span class=\"qpc-hafs\">﴿كانُوا مِن الَّذِينَ آمَنُوا﴾</span> كَعَمّارٍ وبِلال ونَحْوهما <span class=\"qpc-hafs\">﴿يَضْحَكُونَ﴾</span> اِسْتِهْزاء بِهِمْ</p></div>",
      "verses": {
        "83:29": {
          "id": 5877
        }
      }
    },
    "30": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإذا مَرُّوا﴾</span> أيْ المُؤْمِنُونَ <span class=\"qpc-hafs\">﴿بِهِمْ يَتَغامَزُونَ﴾</span> يُشِير المُجْرِمُونَ إلى المُؤْمِنِينَ بِالجَفْنِ والحاجِب اِسْتِهْزاء</p></div>",
      "verses": {
        "83:30": {
          "id": 5878
        }
      }
    },
    "31": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإذا اِنْقَلَبُوا﴾</span> رَجَعُوا <span class=\"qpc-hafs\">﴿إلى أهْلهمْ اِنْقَلَبُوا فَكِهِينَ﴾</span> وفِي قِراءَة  فَكِهِينَ  مُعْجَبِينَ بِذِكْرِهِمْ المُؤْمِنِينَ</p></div>",
      "verses": {
        "83:31": {
          "id": 5879
        }
      }
    },
    "32": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإذا رَأَوْهُمْ﴾</span> أيْ المُؤْمِنِينَ <span class=\"qpc-hafs\">﴿قالُوا إنَّ هَؤُلاءِ لَضالُّونَ﴾</span> لِإيمانِهِمْ بِمُحَمَّدٍ ﷺ</p></div>",
      "verses": {
        "83:32": {
          "id": 5880
        }
      }
    },
    "33": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما أُرْسِلُوا﴾</span> أيْ الكُفّار <span class=\"qpc-hafs\">﴿عَلَيْهِمْ﴾</span> عَلى المُؤْمِنِينَ <span class=\"qpc-hafs\">﴿حافِظِينَ﴾</span> لَهُمْ أوْ لِأَعْمالِهِمْ حَتّى يُدْرُوهُمْ إلى مَصالِحهمْ</p></div>",
      "verses": {
