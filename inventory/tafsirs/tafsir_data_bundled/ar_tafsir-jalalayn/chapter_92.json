{
  "chapter": 92,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿واللَّيْل إذا يَغْشى﴾</span> بِظُلْمَتِهِ كُلّ ما بَيْن السَّماء والأَرْض</p></div>",
      "verses": {
        "92:1": {
          "id": 6059
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والنَّهار إذا تَجَلّى﴾</span> تَكَشَّفَ وظَهَرَ وإذا فِي المَوْضِعَيْنِ لِمُجَرَّدِ الظَّرْفِيَّة والعامِل فِيها فِعْل القَسَم</p></div>",
      "verses": {
        "92:2": {
          "id": 6060
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما﴾</span> بِمَعْنى مَن أوْ مَصْدَرِيَّة <span class=\"qpc-hafs\">﴿خَلَقَ الذَّكَر والأُنْثى﴾</span> آدَم وحَوّاء وكُلّ ذَكَر وكُلّ أُنْثى، والخُنْثى المُشْكِل عِنْدنا ذَكَر أوْ أُنْثى عِنْد اللَّه تَعالى فَيَحْنَث بِتَكْلِيمِهِ مَن حَلَفَ لا يُكَلِّم ذَكَرًا ولا أُنْثى</p></div>",
      "verses": {
        "92:3": {
          "id": 6061
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّ سَعْيكُمْ﴾</span> عَمَلكُمْ <span class=\"qpc-hafs\">﴿لَشَتّى﴾</span> مُخْتَلِف فَعامِل لِلْجَنَّةِ بِالطّاعَةِ وعامِل لِلنّارِ بِالمَعْصِيَةِ</p></div>",
      "verses": {
        "92:4": {
          "id": 6062
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَمّا مَن أعْطى﴾</span> حَقّ اللَّه <span class=\"qpc-hafs\">﴿واتَّقى﴾</span> اللَّه</p></div>",
      "verses": {
        "92:5": {
          "id": 6063
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وصَدَّقَ بِالحُسْنى﴾</span> أيْ بِلا إلَه إلّا اللَّه فِي المَوْضِعَيْنِ</p></div>",
      "verses": {
        "92:6": {
          "id": 6064
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَسَنُيَسِّرُهُ لِلْيُسْرى﴾</span> لِلْجَنَّةِ</p></div>",
      "verses": {
        "92:7": {
          "id": 6065
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَمّا مَن بَخِلَ﴾</span> بِحَقِّ اللَّه <span class=\"qpc-hafs\">﴿واسْتَغْنى﴾</span> عَنْ ثَوابه</p></div>",
      "verses": {
        "92:8": {
          "id": 6066
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "92:9": {
          "id": 6067
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَسَنُيَسِّرُهُ﴾</span> نُهَيِّئهُ <span class=\"qpc-hafs\">﴿لِلْعُسْرى﴾</span> لِلنّارِ</p></div>",
      "verses": {
        "92:10": {
          "id": 6068
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وما﴾</span> نافِيَة <span class=\"qpc-hafs\">﴿يُغْنِي عَنْهُ ماله إذا تَرَدّى﴾</span> فِي النّار</p></div>",
      "verses": {
        "92:11": {
          "id": 6069
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّ عَلَيْنا لَلْهُدى﴾</span> لَتَبْيِين طَرِيق الهُدى مِن طَرِيق الضَّلال لِيَمْتَثِل أمْرنا بِسُلُوكِ الأَوَّل ونَهْينا عَنْ اِرْتِكاب الثّانِي</p></div>",
      "verses": {
        "92:12": {
          "id": 6070
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإنَّ لَنا لَلْآخِرَة والأُولى﴾</span> أيْ الدُّنْيا فَمَن طَلَبَهُما مِن غَيْرنا فَقَدْ أخْطَأَ</p></div>",
      "verses": {
        "92:13": {
          "id": 6071
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَنْذَرْتُكُمْ﴾</span> خَوَّفْتُكُمْ يا أهْل مَكَّة <span class=\"qpc-hafs\">﴿نارًا تَلَظّى﴾</span> بِحَذْفِ إحْدى التّاءَيْنِ مِن الأَصْل وقُرِئَ بِثُبُوتِها، أيْ تَتَوَقَّد</p></div>",
      "verses": {
        "92:14": {
          "id": 6072
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لا يَصْلاها﴾</span> يَدْخُلها <span class=\"qpc-hafs\">﴿إلّا الأَشْقى﴾</span> بِمَعْنى الشَّقِيّ</p></div>",
      "verses": {
        "92:15": {
          "id": 6073
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿الَّذِي كَذَّبَ﴾</span> النَّبِيّ <span class=\"qpc-hafs\">﴿وتَوَلّى﴾</span> عَنْ الإيمان وهَذا الحَصْر مُؤَوَّل لِقَوْلِهِ تَعالى: \" ويَغْفِر ما دُون ذَلِكَ لِمَن يَشاء \" فَيَكُون المُراد الصِّلِيّ المُؤَبَّد</p></div>",
      "verses": {
        "92:16": {
          "id": 6074
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وسَيُجَنَّبُها﴾</span> يُبْعَد عَنْها <span class=\"qpc-hafs\">﴿الأَتْقى﴾</span> بِمَعْنى التَّقِيّ</p></div>",
      "verses": {
        "92:17": {
          "id": 6075
        }
      }
    },
    "18": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p>\" <span class=\"qpc-hafs\">﴿الَّذِي يُؤْتِي ماله يَتَزَكّى﴾</span> مُتَزَكِّيًا بِهِ عِنْد اللَّه تَعالى بِأَنْ يُخْرِجهُ لِلَّهِ تَعالى لا رِياء ولا سُمْعَة، فَيَكُون زاكِيًا عِنْد اللَّه، وهَذا نَزَلَ فِي الصِّدِّيق رَضِيَ اللَّه عَنْهُ لَمّا اِشْتَرى بِلالًا المُعَذَّب عَلى إيمانه وأَعْتَقَهُ، فَقالَ الكُفّار: إنَّما فَعَلَ ذَلِكَ لِيَدٍ كانَتْ لَهُ عِنْده فَنَزَلَتْ. <span class=\"qpc-hafs\">﴿وما لِأَحَدٍ عِنْده مِن نِعْمَة تُجْزى﴾</span></p></div>",
      "verses": {
        "92:18": {
          "id": 6076
        }
      }
    },
    "19": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "92:19": {
          "id": 6077
        }
      }
    },
    "20": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إلّا﴾</span> لَكِنْ فَعَلَ ذَلِكَ <span class=\"qpc-hafs\">﴿اِبْتِغاء وجْه رَبّه الأَعْلى﴾</span> أيْ طَلَب ثَواب اللَّه</p></div>",
      "verses": {
        "92:20": {
          "id": 6078
        }
      }
    },
    "21": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولَسَوْفَ يَرْضى﴾</span> بِما يُعْطاهُ مِن الثَّواب فِي الجَنَّة والآيَة تَشْمَل مَن فَعَلَ مِثْل فِعْله رَضِيَ اللَّه تَعالى عَنْهُ فَيُبْعَد عَنْ النّار ويُثاب.</p></div>",
      "verses": {
        "92:21": {
          "id": 6079
        }
      }
    }
  }
}