{
  "chapter": 102,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ألْهاكُمْ﴾</span> شَغَلَكُمْ عَنْ طاعَة اللَّه <span class=\"qpc-hafs\">﴿التَّكاثُر﴾</span> التَّفاخُر بِالأَمْوالِ والأَوْلاد والرِّجال</p></div>",
      "verses": {
        "102:1": {
          "id": 6169
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿حَتّى زُرْتُمْ المَقابِر﴾</span> بِأَنْ مُتُّمْ فَدُفِنْتُمْ فِيها، أوْ عَدَدْتُمْ المَوْتى تَكاثُرًا</p></div>",
      "verses": {
        "102:2": {
          "id": 6170
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَلّا﴾</span> رَدْع <span class=\"qpc-hafs\">﴿سَوْفَ تَعْلَمُونَ﴾</span></p></div>",
      "verses": {
        "102:3": {
          "id": 6171
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ كَلّا سَوْفَ تَعْلَمُونَ﴾</span> سُوء عاقِبَة تَفاخُركُمْ عِنْد النَّزْع ثُمَّ فِي القَبْر</p></div>",
      "verses": {
        "102:4": {
          "id": 6172
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَلّا﴾</span> حَقًّا <span class=\"qpc-hafs\">﴿لَوْ تَعْلَمُونَ عِلْم اليَقِين﴾</span> عِلْمًا يَقِينًا عاقِبَة التَّفاخُر ما اِشْتَغَلْتُمْ بِهِ</p></div>",
      "verses": {
        "102:5": {
          "id": 6173
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لَتَرَوُنَّ الجَحِيم﴾</span> النّار جَواب قَسَم مَحْذُوف وحُذِفَ مِنهُ لام الفِعْل وعَيْنه وأُلْقِيَتْ حَرَكَتها عَلى الرّاء</p></div>",
      "verses": {
        "102:6": {
          "id": 6174
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ لَتَرَوُنَّها﴾</span> تَأْكِيد <span class=\"qpc-hafs\">﴿عَيْن اليَقِين﴾</span> مَصْدَر لِأَنَّ رَأى وعايَنَ بِمَعْنًى واحِد</p></div>",
      "verses": {
        "102:7": {
          "id": 6175
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ لَتُسْأَلُنَّ﴾</span> حُذِفَ مِنهُ نُون الرَّفْع لِتَوالِي النُّونات وواو ضَمِير الجَمْع لِالتِقاءِ السّاكِنَيْنِ <span class=\"qpc-hafs\">﴿يَوْمئِذٍ﴾</span> يَوْم رُؤْيَتها <span class=\"qpc-hafs\">﴿عَنْ النَّعِيم﴾</span> ما يُلْتَذّ بِهِ فِي الدُّنْيا مِن الصِّحَّة والفَراغ والمَطْعَم والمَشْرَب وغَيْر ذَلِكَ.</p></div>",
      "verses": {
        "102:8": {
          "id": 6176
        }
      }
    }
  }
}