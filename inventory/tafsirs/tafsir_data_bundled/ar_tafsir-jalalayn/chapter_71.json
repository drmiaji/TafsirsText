{
  "chapter": 71,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p>سُورَة نُوح [ مَكِّيَّة وآياتها ٢٨ أوْ ٢٩ آيَة ]</p><p><span class=\"qpc-hafs\">﴿أنْ أنْذِرْ﴾</span> أيْ بِإنْذارِ <span class=\"qpc-hafs\">﴿قَوْمك مِن قَبْل أنْ يَأْتِيهِمْ﴾</span> إنْ لَمْ يُؤْمِنُوا <span class=\"qpc-hafs\">﴿عَذاب ألِيم﴾</span> مُؤْلِم فِي الدُّنْيا والآخِرَة</p></div>",
      "verses": {
        "71:1": {
          "id": 5420
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالَ يا قَوْم إنِّي لَكُمْ نَذِير مُبِين﴾</span> بَيِّن الإنْذار</p></div>",
      "verses": {
        "71:2": {
          "id": 5421
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أنْ﴾</span> أيْ بِأَنْ أقُول لَكُمْ</p></div>",
      "verses": {
        "71:3": {
          "id": 5422
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَغْفِر لَكُمْ مِن ذُنُوبكُمْ﴾</span> مِن زائِدَة فَإنَّ الإسْلام يُغْفَر بِهِ ما قَبْله أوْ تَبْعِيضِيَّة لِإخْراجِ حُقُوق العِباد <span class=\"qpc-hafs\">﴿ويُؤَخِّركُمْ﴾</span> بِلا عَذاب <span class=\"qpc-hafs\">﴿إلى أجَل مُسَمّى﴾</span> أجَل المَوْت <span class=\"qpc-hafs\">﴿إنّ أجَل اللَّه﴾</span> بِعَذابِكُمْ إنْ لَمْ تُؤْمِنُوا <span class=\"qpc-hafs\">﴿إذا جاءَ لا يُؤَخَّر لَوْ كُنْتُمْ تَعْلَمُونَ﴾</span> ذَلِكَ لَآمَنتُمْ</p></div>",
      "verses": {
        "71:4": {
          "id": 5423
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالَ رَبّ إنِّي دَعَوْت قَوْمِي لَيْلًا ونَهارًا﴾</span> أيْ دائِمًا مُتَّصِلًا</p></div>",
      "verses": {
        "71:5": {
          "id": 5424
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَلَمْ يَزِدْهُمْ إلّا فِرارًا﴾</span> عَنْ الإيمان</p></div>",
      "verses": {
        "71:6": {
          "id": 5425
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإنِّي كُلَّما دَعَوْتهمْ لِتَغْفِر لَهُمْ جَعَلُوا أصابِعهمْ فِي آذانهمْ﴾</span> لِئَلّا يَسْمَعُوا كَلامِي <span class=\"qpc-hafs\">﴿واسْتَغْشَوْا ثِيابهمْ﴾</span> غَطَّوْا رُءُوسهمْ بِها لِئَلّا يُنْظِرُونِي <span class=\"qpc-hafs\">﴿وأَصَرُّوا﴾</span> عَلى كُفْرهمْ <span class=\"qpc-hafs\">﴿واسْتَكْبَرُوا﴾</span> تَكَبَّرُوا عَنْ الإيمان</p></div>",
      "verses": {
        "71:7": {
          "id": 5426
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ إنِّي دَعَوْتهمْ جِهارًا﴾</span> أيْ بِأَعْلى صَوْتِي</p></div>",
      "verses": {
        "71:8": {
          "id": 5427
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ إنِّي أعْلَنْت لَهُمْ﴾</span> صَوْتِي <span class=\"qpc-hafs\">﴿وأَسْرَرْت﴾</span> الكَلام</p></div>",
      "verses": {
        "71:9": {
          "id": 5428
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَقُلْت اسْتَغْفِرُوا رَبّكُمْ﴾</span> مِن الشِّرْك</p></div>",
      "verses": {
        "71:10": {
          "id": 5429
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يُرْسِل السَّماء﴾</span> المَطَر وكانُوا قَدْ مَنَعُوهُ <span class=\"qpc-hafs\">﴿عَلَيْكُمْ مِدْرارًا﴾</span> كَثِير الدُّرُور</p></div>",
      "verses": {
        "71:11": {
          "id": 5430
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ويُمْدِدْكُمْ بِأَمْوالٍ وبَنِينَ ويَجْعَل لَكُمْ جَنّات﴾</span> بَساتِين <span class=\"qpc-hafs\">﴿ويَجْعَل لَكُمْ أنْهارًا﴾</span> جارِيَة</p></div>",
      "verses": {
        "71:12": {
          "id": 5431
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ما لَكُمْ لا تَرْجُونَ لِلَّهِ وقارًا﴾</span> أيْ تَأْمُلُونَ وقار اللَّه إيّاكُمْ بِأَنْ تُؤْمِنُوا</p></div>",
      "verses": {
        "71:13": {
          "id": 5432
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وقَدْ خَلَقَكُمْ أطْوارًا﴾</span> جَمْع طَوْر وهُوَ الحال فَطَوْرًا نُطْفَة وطَوْرًا عَلَقَة إلى تَمام خَلْق الإنْسان والنَّظَر فِي خَلْقه يُوجِب الإيمان بِخالِقِهِ</p></div>",
      "verses": {
        "71:14": {
          "id": 5433
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ألَمْ تَرَوْا﴾</span> تَنْظُرُوا <span class=\"qpc-hafs\">﴿كَيْفَ خَلَقَ اللَّه سَبْع سَمَوات طِباقًا﴾</span> بَعْضها فَوْق بَعْض</p></div>",
      "verses": {
        "71:15": {
          "id": 5434
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وجَعَلَ القَمَر فِيهِنَّ﴾</span> أيْ فِي مَجْمُوعهنَّ الصّادِق بِالسَّماءِ الدُّنْيا <span class=\"qpc-hafs\">﴿نُورًا وجَعَلَ الشَّمْس سِراجًا﴾</span> مِصْباحًا مُضِيئًا وهُوَ أقْوى مِن نُور القَمَر</p></div>",
      "verses": {
        "71:16": {
          "id": 5435
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿واللَّه أنْبَتَكُمْ﴾</span> خَلَقَكُمْ <span class=\"qpc-hafs\">﴿مِن الأَرْض﴾</span> إذْ خَلَقَ أباكُمْ آدَم مِنها</p></div>",
      "verses": {
        "71:17": {
          "id": 5436
        }
      }
    },
    "18": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ثُمَّ يُعِيدكُمْ فِيها﴾</span> مَقْبُورِينَ <span class=\"qpc-hafs\">﴿ويُخْرِجكُمْ﴾</span> لِلْبَعْثِ</p></div>",
      "verses": {
        "71:18": {
          "id": 5437
        }
      }
    },
    "19": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿واللَّه جَعَلَ لَكُمْ الأَرْض بِساطًا﴾</span> مَبْسُوطَة</p></div>",
      "verses": {
        "71:19": {
          "id": 5438
        }
      }
    },
    "20": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لِتَسْلُكُوا مِنها سُبُلًا﴾</span> طُرُقًا <span class=\"qpc-hafs\">﴿فِجاجًا﴾</span> واسِعَة</p></div>",
      "verses": {
        "71:20": {
          "id": 5439
        }
      }
    },
    "21": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿قالَ نُوح رَبّ إنّهُمْ عَصَوْنِي واتَّبَعُوا﴾</span> أيْ السَّفَلَة والفُقَراء <span class=\"qpc-hafs\">﴿مَن لَمْ يَزِدْهُ ماله ووُلْده﴾</span> وهُمْ الرُّؤَساء المُنَعَّم عَلَيْهِمْ بِذَلِكَ ووُلْد بِضَمِّ الواو وسُكُون اللّام وبِفَتْحِهِما والأَوَّل قِيلَ جَمْع ولَد بِفَتْحِهِما كَخُشْبِ وخَشَب وقِيلَ بِمَعْناهُ كَبُخْلِ وبَخَل <span class=\"qpc-hafs\">﴿إلّا خَسارًا﴾</span> طُغْيانًا وكُفْرًا</p></div>",
      "verses": {
        "71:21": {
          "id": 5440
        }
      }
    },
    "22": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ومَكَرُوا﴾</span> أيْ الرُّؤَساء <span class=\"qpc-hafs\">﴿مَكْرًا كُبّارًا﴾</span> عَظِيمًا جِدًّا بِأَنْ كَذَّبُوا نُوحًا وآذَوْهُ ومَن اتَّبَعَهُ</p></div>",
      "verses": {
        "71:22": {
          "id": 5441
        }
      }
    },
    "23": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وقالُوا﴾</span> لِلسَّفَلَةِ <span class=\"qpc-hafs\">﴿لا تَذَرُونَّ آلِهَتكُمْ ولا تَذَرُونَّ ودًّا﴾</span> بِفَتْحِ الواو وضَمّها <span class=\"qpc-hafs\">﴿ولا سُواعًا ولا يَغُوث ويَعُوق ونَسْرًا﴾</span> هِيَ أسْماء أصْنامهمْ</p></div>",
      "verses": {
        "71:23": {
          "id": 5442
        }
      }
    },
    "24": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وقَدْ أضَلُّوا﴾</span> بِها <span class=\"qpc-hafs\">﴿كَثِيرًا﴾</span> مِن النّاس بِأَنْ أمَرُوهُمْ بِعِبادَتِهِمْ <span class=\"qpc-hafs\">﴿ولا تَزِدْ الظّالِمِينَ إلّا ضَلالًا﴾</span> عَطْفًا عَلى قَدْ أضَلُّوا دَعا عَلَيْهِمْ لَمّا أُوحِيَ إلَيْهِ أنَّهُ لَنْ يُؤْمِن مِن قَوْمك إلّا مَن قَدْ آمَنَ</p></div>",
      "verses": {
        "71:24": {
          "id": 5443
        }
      }
    },
    "25": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿مِمّا﴾</span> ما صِلَة <span class=\"qpc-hafs\">﴿خَطَياهُمْ﴾</span> وفِي قِراءَة خَطِيئَآتِهِمْ بِالهَمْزِ <span class=\"qpc-hafs\">﴿أُغْرِقُوا﴾</span> بِالطُّوفانِ <span class=\"qpc-hafs\">﴿فَأُدْخِلُوا نارًا﴾</span> عُوقِبُوا بِها عَقِب الإغْراق تَحْت الماء <span class=\"qpc-hafs\">﴿فَلَمْ يَجِدُوا لَهُمْ مِن دُون﴾</span> أيْ غَيْر <span class=\"qpc-hafs\">﴿اللَّه أنْصارًا﴾</span> يَمْنَعُونَ عَنْهُمْ العَذاب</p></div>",
      "verses": {
        "71:25": {
          "id": 5444
        }
      }
    },
    "26": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وقالَ نُوح رَبّ لا تَذَر عَلى الأَرْض مِن الكافِرِينَ دَيّارًا﴾</span> أيْ نازِل دار والمَعْنى أحَدًا</p></div>",
      "verses": {
        "71:26": {
          "id": 5445
        }
      }
    },
    "27": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنّك إنْ تَذَرهُمْ يُضِلُّوا عِبادك ولا يَلِدُوا إلّا فاجِرًا كَفّارًا﴾</span> مَن يَفْجُر ويَكْفُر قالَ ذَلِكَ لِما تَقَدَّمَ مِن الإيحاء إلَيْهِ</p></div>",
      "verses": {
        "71:27": {
          "id": 5446
        }
      }
    },
    "28": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿رَبّ اغْفِرْ لِي ولِوالِدَيَّ﴾</span> وكانا مُؤْمِنَيْنِ <span class=\"qpc-hafs\">﴿ولِمَن دَخَلَ بَيْتِي﴾</span> مَنزِلِي أوْ مَسْجِدِي <span class=\"qpc-hafs\">﴿مُؤْمِنًا ولِلْمُؤْمِنِينَ والمُؤْمِنات﴾</span> إلى يَوْم القِيامَة <span class=\"qpc-hafs\">﴿ولا تَزِدْ الظّالِمِينَ إلّا تَبارًا﴾</span> هَلاكًا فَأُهْلِكُوا</p></div>",
      "verses": {
        "71:28": {
          "id": 5447
        }
      }
    }
  }
}