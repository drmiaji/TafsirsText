{
  "chapter": 100,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والعادِيات﴾</span> الخَيْل تَعْدُو فِي الغَزْو وتَضْبَح <span class=\"qpc-hafs\">﴿ضَبْحًا﴾</span> هُوَ صَوْت أجْوافها إذا عَدَتْ</p></div>",
      "verses": {
        "100:1": {
          "id": 6147
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فالمُورِيات﴾</span> الخَيْل تُورِي النّار <span class=\"qpc-hafs\">﴿قَدْحًا﴾</span> بِحَوافِرِها إذا سارَتْ فِي الأَرْض ذات الحِجارَة بِاللَّيْلِ</p></div>",
      "verses": {
        "100:2": {
          "id": 6148
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فالمُغِيرات صُبْحًا﴾</span> الخَيْل تُغِير عَلى العَدُوّ وقْت الصُّبْح بِإغارَةِ أصْحابها</p></div>",
      "verses": {
        "100:3": {
          "id": 6149
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَأَثَرْنَ﴾</span> هَيَّجْنَ <span class=\"qpc-hafs\">﴿بِهِ﴾</span> بِمَكانِ عَدْوهنَّ أوْ بِذَلِكَ الوَقْت <span class=\"qpc-hafs\">﴿نَقْعًا﴾</span> غُبارًا بِشِدَّةِ حَرَكَتهنَّ</p></div>",
      "verses": {
        "100:4": {
          "id": 6150
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَوَسَطْنَ بِهِ﴾</span> بِالنَّقْعِ <span class=\"qpc-hafs\">﴿جَمْعًا﴾</span> مِن العَدْو أيْ صِرْنَ وسَطه وعُطِفَ الفِعْل عَلى الِاسْم لِأَنَّهُ فِي تَأْوِيل الفِعْل أيْ واللّاتِي عَدَوْنَ فَأَوْرَيْن فَأَغَرْنَ</p></div>",
      "verses": {
        "100:5": {
          "id": 6151
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّ الإنْسان﴾</span> الكافِر <span class=\"qpc-hafs\">﴿لِرَبِّهِ لَكَنُود﴾</span> لَكَفُور يَجْحَد نِعْمَته تَعالى</p></div>",
      "verses": {
        "100:6": {
          "id": 6152
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإنَّهُ عَلى ذَلِكَ﴾</span> أيْ كَنُوده <span class=\"qpc-hafs\">﴿لَشَهِيد﴾</span> يَشْهَد عَلى نَفْسه بِصُنْعِهِ</p></div>",
      "verses": {
        "100:7": {
          "id": 6153
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وإنَّهُ لِحُبِّ الخَيْر﴾</span> أيْ المال <span class=\"qpc-hafs\">﴿لَشَدِيد﴾</span> الحُبّ لَهُ فَيَبْخَل بِهِ</p></div>",
      "verses": {
        "100:8": {
          "id": 6154
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿أفَلا يَعْلَم إذا بُعْثِرَ﴾</span> أُثِيرَ وأُخْرِجَ <span class=\"qpc-hafs\">﴿ما فِي القُبُور﴾</span> مِن المَوْتى، أيْ بُعِثُوا</p></div>",
      "verses": {
        "100:9": {
          "id": 6155
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وحُصِّلَ﴾</span> بُيِّنَ وأُفْرِزَ <span class=\"qpc-hafs\">﴿ما فِي الصُّدُور﴾</span> القُلُوب مِن الكُفْر والإيمان</p></div>",
      "verses": {
        "100:10": {
          "id": 6156
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿إنَّ رَبّهمْ بِهِمْ يَوْمئِذٍ لَخَبِير﴾</span> لَعالَم فَيُجازِيهِمْ عَلى كُفْرهمْ، أُعِيدَ الضَّمِير جَمْعًا نَظَرًا لِمَعْنى الإنْسان وهَذِهِ الجُمْلَة دَلَّتْ عَلى مَفْعُول يَعْلَم، أيْ إنّا نُجازِيه وقْت ما ذَكَرَ وتَعَلَّقَ خَبِير بِيَوْمَئِذ وهُوَ تَعالى خَبِير دائِمًا لِأَنَّهُ يَوْم المُجازاة</p></div>",
      "verses": {
        "100:11": {
          "id": 6157
        }
      }
    }
  }
}