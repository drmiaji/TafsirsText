    },
    "52": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فِيهِما مِن كُلّ فاكِهَة﴾</span> فِي الدُّنْيا أوْ كُلّ ما يُتَفَكَّه بِهِ <span class=\"qpc-hafs\">﴿زَوْجانِ﴾</span> نَوْعانِ رَطْب ويابِس والمُرّ مِنهُما فِي الدُّنْيا كالحَنْظَلِ حُلْو</p></div>",
      "verses": {
        "55:52": {
          "id": 4953
        }
      }
    },
    "53": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:53": {
          "id": 4954
        }
      }
    },
    "54": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿مُتَّكِئِينَ﴾</span> حال عامِله مَحْذُوف أيْ يَتَنَعَّمُونَ <span class=\"qpc-hafs\">﴿عَلى فُرُش بَطائِنها مِن إسْتَبْرَق﴾</span> ما غَلُظَ مِن الدِّيباج وخَشُنَ والظَّهائِر مِن السُّنْدُس <span class=\"qpc-hafs\">﴿وجَنى الجَنَّتَيْنِ﴾</span> ثَمَرهما <span class=\"qpc-hafs\">﴿دانٍ﴾</span> قَرِيب يَنالهُ القائِم والقاعِد والمُضْطَجِع</p></div>",
      "verses": {
        "55:54": {
          "id": 4955
        }
      }
    },
    "55": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:55": {
          "id": 4956
        }
      }
    },
    "56": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فِيهِنَّ﴾</span> فِي الجَنَّتَيْنِ وما اشْتَمَلَتا عَلَيْهِ مِن العَلالِيّ والقُصُور <span class=\"qpc-hafs\">﴿قاصِرات الطَّرْف﴾</span> العَيْن عَلى أزْواجهنَّ المُتَّكِئِينَ مِن الإنْس والجِنّ <span class=\"qpc-hafs\">﴿لَمْ يَطْمِثهُنَّ﴾</span> يَفْتَضّهُنَّ وهُنَّ مِن الحُور أوْ مِن نِساء الدُّنْيا المُنْشَآت</p></div>",
      "verses": {
        "55:56": {
          "id": 4957
        }
      }
    },
    "57": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:57": {
          "id": 4958
        }
      }
    },
    "58": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كَأَنَّهُنَّ الياقُوت﴾</span> مِن صَفاء <span class=\"qpc-hafs\">﴿والمَرْجان﴾</span> اللُّؤْلُؤ بَياضًا</p></div>",
      "verses": {
        "55:58": {
          "id": 4959
        }
      }
    },
    "59": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:59": {
          "id": 4960
        }
      }
    },
    "60": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿هَلْ﴾</span> ما <span class=\"qpc-hafs\">﴿جَزاء الإحْسان﴾</span> بِالطّاعَةِ <span class=\"qpc-hafs\">﴿إلّا الإحْسان﴾</span> بِالنَّعِيمِ</p></div>",
      "verses": {
        "55:60": {
          "id": 4961
        }
      }
    },
    "61": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:61": {
          "id": 4962
        }
      }
    },
    "62": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ومِن دُونهما﴾</span> مِن دُون الجَنَّتَيْنِ المَذْكُورَتَيْنِ <span class=\"qpc-hafs\">﴿جَنَّتانِ﴾</span> أيْضًا لِمَن خافَ مَقام رَبّه</p></div>",
      "verses": {
        "55:62": {
          "id": 4963
        }
      }
    },
    "63": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:63": {
          "id": 4964
        }
      }
    },
    "64": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿مُدْهامَّتانِ﴾</span> سَوْداوانِ مِن شِدَّة خُضْرَتهما</p></div>",
      "verses": {
        "55:64": {
          "id": 4965
        }
      }
    },
    "65": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:65": {
          "id": 4966
        }
      }
    },
    "66": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فِيهِما عَيْنانِ نَضّاخَتانِ﴾</span> فَوّارَتانِ بِالماءِ</p></div>",
      "verses": {
        "55:66": {
          "id": 4967
        }
      }
    },
    "67": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:67": {
          "id": 4968
        }
      }
    },
    "68": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فِيهِما فاكِهَة ونَخْل ورُمّان﴾</span> هُما مِنها وقِيلَ مِن غَيْرها</p></div>",
      "verses": {
        "55:68": {
          "id": 4969
        }
      }
    },
    "69": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:69": {
          "id": 4970
        }
      }
    },
    "70": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فِيهِنَّ﴾</span> أيْ الجَنَّتَيْنِ وما فِيهِما <span class=\"qpc-hafs\">﴿خَيْرات﴾</span> أخَلاقها خَيِّرَة <span class=\"qpc-hafs\">﴿حِسان﴾</span> حَسَنَة الوُجُوه</p></div>",
      "verses": {
        "55:70": {
          "id": 4971
        }
      }
    },
    "71": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:71": {
          "id": 4972
        }
      }
    },
    "72": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿حُور﴾</span> شَدِيدات سَواد العُيُون وبَياضها\" <span class=\"qpc-hafs\">﴿﴾</span> \"مَقْصُورات\" <span class=\"qpc-hafs\">﴿مَسْتُورات﴾</span> \"فِي الخِيام\" <span class=\"qpc-hafs\">﴿خِيام مِن دُرّ مُجَوَّف مُضافَة إلى القُصُور شَبِيهَة بِالخُدُورِ﴾</span></p></div>",
      "verses": {
        "55:72": {
          "id": 4973
        }
      }
    },
    "73": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:73": {
          "id": 4974
        }
      }
    },
    "74": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿لَمْ يَطْمِثهُنَّ إنْس قَبْلهمْ﴾</span> قَبْل أزْواجهنَّ</p></div>",
      "verses": {
        "55:74": {
          "id": 4975
        }
      }
    },
