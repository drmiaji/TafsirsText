{
  "chapter": 55,
  "verses": {
    "1": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p>سُورَة الرَّحْمَن [ مَكِّيَّة إلّا آيَة ٢٩ فَمَدَنِيَّة وآياتها سِتّ أوْ ثَمان وسَبْعُونَ آيَة ]</p><p><span class=\"qpc-hafs\">﴿الرَّحْمَن﴾</span> اللَّه تَعالى</p></div>",
      "verses": {
        "55:1": {
          "id": 4902
        }
      }
    },
    "2": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿عَلَّمَ﴾</span> مَن شاءَ</p></div>",
      "verses": {
        "55:2": {
          "id": 4903
        }
      }
    },
    "3": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿خَلَقَ الإنْسان﴾</span> أيْ الجِنْس</p></div>",
      "verses": {
        "55:3": {
          "id": 4904
        }
      }
    },
    "4": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿عَلَّمَهُ البَيان﴾</span> النُّطْق</p></div>",
      "verses": {
        "55:4": {
          "id": 4905
        }
      }
    },
    "5": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿الشَّمْس والقَمَر بِحُسْبانٍ﴾</span> يَجْرِيانِ</p></div>",
      "verses": {
        "55:5": {
          "id": 4906
        }
      }
    },
    "6": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والنَّجْم﴾</span> ما لا ساقَ لَهُ مِن النَّبات <span class=\"qpc-hafs\">﴿والشَّجَر﴾</span> ما لَهُ ساق <span class=\"qpc-hafs\">﴿يَسْجُدانِ﴾</span> يَخْضَعانِ لِما يُراد مِنهُما</p></div>",
      "verses": {
        "55:6": {
          "id": 4907
        }
      }
    },
    "7": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والسَّماء رَفَعَها ووَضَعَ المِيزان﴾</span> أثْبَت العَدْل</p></div>",
      "verses": {
        "55:7": {
          "id": 4908
        }
      }
    },
    "8": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ألّا تَطْغَوْا﴾</span> أيْ لِأَجْلِ أنْ لا تَجُورُوا <span class=\"qpc-hafs\">﴿فِي المِيزان﴾</span> ما يُوزَن بِهِ</p></div>",
      "verses": {
        "55:8": {
          "id": 4909
        }
      }
    },
    "9": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وأَقِيمُوا الوَزْن بِالقِسْطِ﴾</span> بِالعَدْلِ <span class=\"qpc-hafs\">﴿ولا تُخْسِرُوا المِيزان﴾</span> تُنْقِصُوا المَوْزُون</p></div>",
      "verses": {
        "55:9": {
          "id": 4910
        }
      }
    },
    "10": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والأَرْض وضَعَها﴾</span> أثْبَتَها <span class=\"qpc-hafs\">﴿لِلْأَنامِ﴾</span> لِلْخَلْقِ الإنْس والجِنّ وغَيْرهمْ</p></div>",
      "verses": {
        "55:10": {
          "id": 4911
        }
      }
    },
    "11": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فِيها فاكِهَة والنَّخْل﴾</span> المَعْهُود <span class=\"qpc-hafs\">﴿ذات الأَكْمام﴾</span> أوْعِيَة طَلْعها</p></div>",
      "verses": {
        "55:11": {
          "id": 4912
        }
      }
    },
    "12": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿والحَبّ﴾</span> كالحِنْطَةِ والشَّعِير <span class=\"qpc-hafs\">﴿ذُو العَصْف﴾</span> التِّبْن <span class=\"qpc-hafs\">﴿والرَّيْحان﴾</span> الوَرَق المَشْمُوم</p></div>",
      "verses": {
        "55:12": {
          "id": 4913
        }
      }
    },
    "13": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَبِأَيِّ آلاء﴾</span> نِعَم <span class=\"qpc-hafs\">﴿رَبّكُما﴾</span> أيّها الإنْس والجِنّ <span class=\"qpc-hafs\">﴿تُكَذِّبانِ﴾</span> ذُكِرَتْ إحْدى وثَلاثِينَ مَرَّة والِاسْتِفْهام فِيها لِلتَّقْرِيرِ لِما رَوى الحاكِم عَنْ جابِر قالَ: \"قَرَأَ عَلَيْنا رَسُول اللَّه ﷺ سُورَة الرَّحْمَن حَتّى خَتَمَها ثُمَّ قالَ: مالِي أراكُمْ سُكُوتًا لَلْجِنّ كانُوا أحْسَن مِنكُمْ رَدًّا ما قَرَأْت عَلَيْهِمْ هَذِهِ الآيَة مِن مَرَّة <span class=\"qpc-hafs\">﴿فَبِأَيِّ آلاء رَبّكُما تُكَذِّبانِ﴾</span> إلّا قالُوا: ولا بِشَيْءٍ مِن نِعَمك رَبّنا نُكَذِّب فَلَك الحَمْد</p></div>",
      "verses": {
        "55:13": {
          "id": 4914
        }
      }
    },
    "14": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿خَلَقَ الإنْسان﴾</span> آدَم <span class=\"qpc-hafs\">﴿مِن صَلْصال﴾</span> طِين يابِس يُسْمَع لَهُ صَلْصَلَة أيْ صَوْت إذا نُقِرَ <span class=\"qpc-hafs\">﴿كالفَخّارِ﴾</span> وهُوَ ما طُبِخَ مِن طِين</p></div>",
      "verses": {
        "55:14": {
          "id": 4915
        }
      }
    },
    "15": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿وخَلَقَ الجانّ﴾</span> أبا الجِنّ وهُوَ إبْلِيس <span class=\"qpc-hafs\">﴿مِن مارِج مِن نار﴾</span> هُوَ لَهَبها الخالِص مِن الدُّخان</p></div>",
      "verses": {
        "55:15": {
          "id": 4916
        }
      }
    },
    "16": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:16": {
          "id": 4917
        }
      }
    },
    "17": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿رَبّ المَشْرِقَيْنِ﴾</span> مَشْرِق الشِّتاء ومَشْرِق الصَّيْف <span class=\"qpc-hafs\">﴿ورَبّ المَغْرِبَيْنِ﴾</span> مَغْرِب الصَّيْف ومَغْرِب الشِّتاء</p></div>",
      "verses": {
        "55:17": {
          "id": 4918
        }
      }
    },
    "18": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:18": {
          "id": 4919
        }
      }
    },
    "19": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿مَرَجَ﴾</span> أرْسَلَ <span class=\"qpc-hafs\">﴿البَحْرَيْنِ﴾</span> العَذْب والمِلْح <span class=\"qpc-hafs\">﴿يَلْتَقِيانِ﴾</span> فِي رَأْي العَيْن</p></div>",
      "verses": {
        "55:19": {
          "id": 4920
        }
      }
    },
    "20": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿بَيْنهما بَرْزَخ﴾</span> حاجِز مِن قُدْرَته تَعالى <span class=\"qpc-hafs\">﴿لا يَبْغِيانِ﴾</span> لا يَبْغِي واحِد مِنهُما عَلى الآخَر فَيَخْتَلِط بِهِ</p></div>",
      "verses": {
        "55:20": {
          "id": 4921
        }
      }
    },
    "21": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:21": {
          "id": 4922
        }
      }
    },
    "22": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَخْرُج﴾</span> بِالبِناءِ لِلْمَفْعُولِ والفاعِل <span class=\"qpc-hafs\">﴿مِنهُما﴾</span> مِن مَجْمُوعهما الصّادِق بِأَحَدِهِما وهُوَ المِلْح <span class=\"qpc-hafs\">﴿اللُّؤْلُؤ والمَرْجان﴾</span> خَرَز أحْمَر أوْ صِغار اللُّؤْلُؤ</p></div>",
      "verses": {
        "55:22": {
          "id": 4923
        }
      }
    },
    "23": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:23": {
          "id": 4924
        }
      }
    },
    "24": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولَهُ الجَوار﴾</span> السُّفُن <span class=\"qpc-hafs\">﴿المُنْشَآت﴾</span> المُحْدَثات <span class=\"qpc-hafs\">﴿فِي البَحْر كالأَعْلامِ﴾</span> كالجِبالِ عِظَمًا وارْتِفاعًا</p></div>",
      "verses": {
        "55:24": {
          "id": 4925
        }
      }
    },
    "25": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:25": {
          "id": 4926
        }
      }
    },
    "26": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿كُلّ مَن عَلَيْها﴾</span> أيْ الأَرْض مِن الحَيَوان <span class=\"qpc-hafs\">﴿فانٍ﴾</span> هالِك وعَبَّرَ بِمَن تَغْلِيبًا لِلْعُقَلاءِ</p></div>",
      "verses": {
        "55:26": {
          "id": 4927
        }
      }
    },
    "27": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ويَبْقى وجْه رَبّك﴾</span> ذاته <span class=\"qpc-hafs\">﴿ذُو الجَلال﴾</span> العَظَمَة <span class=\"qpc-hafs\">﴿والإكْرام﴾</span> لِلْمُؤْمِنِينَ بِأَنْعُمِهِ عَلَيْهِمْ</p></div>",
      "verses": {
        "55:27": {
          "id": 4928
        }
      }
    },
    "28": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:28": {
          "id": 4929
        }
      }
    },
    "29": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَسْأَلهُ مَن فِي السَّماوات والأَرْض﴾</span> بِنُطْقٍ أوْ حال: ما يَحْتاجُونَ إلَيْهِ مِن القُوَّة عَلى العِبادَة والرِّزْق والمَغْفِرَة وغَيْر ذَلِكَ <span class=\"qpc-hafs\">﴿كُلّ يَوْم﴾</span> وقْت <span class=\"qpc-hafs\">﴿هُوَ فِي شَأْن﴾</span> أمْر يُظْهِرهُ عَلى وفْق ما قَدَّرَهُ فِي الأَزَل مِن إحْياء وإماتَة وإعْزاز وإذْلال وإغْناء وإعْدام وإجابَة داعٍ وإعْطاء سائِل وغَيْر ذَلِكَ</p></div>",
      "verses": {
        "55:29": {
          "id": 4930
        }
      }
    },
    "30": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:30": {
          "id": 4931
        }
      }
    },
    "31": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿سَنَفْرُغُ لَكُمْ﴾</span> سَنَقْصِدُ لِحِسابِكُمْ <span class=\"qpc-hafs\">﴿أيّها الثَّقَلانِ﴾</span> الإنْس والجِنّ</p></div>",
      "verses": {
        "55:31": {
          "id": 4932
        }
      }
    },
    "32": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:32": {
          "id": 4933
        }
      }
    },
    "33": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يا مَعْشَر الجِنّ والإنْس إنِ اسْتَطَعْتُمْ أنْ تَنْفُذُوا﴾</span> تَخْرُجُوا <span class=\"qpc-hafs\">﴿مِن أقْطار﴾</span> نَواحِي <span class=\"qpc-hafs\">﴿السَّماوات والأَرْض فانْفُذُوا﴾</span> أمْر تَعْجِيز <span class=\"qpc-hafs\">﴿لا تَنْفُذُونَ إلّا بِسُلْطانٍ﴾</span> بِقُوَّةٍ ولا قُوَّة لَكُمْ عَلى ذَلِكَ</p></div>",
      "verses": {
        "55:33": {
          "id": 4934
        }
      }
    },
    "34": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:34": {
          "id": 4935
        }
      }
    },
    "35": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يُرْسَل عَلَيْكُما شُواظ مِن نار﴾</span> هُوَ لَهَبها الخالِص مِن الدُّخان أوْ مَعَهُ <span class=\"qpc-hafs\">﴿ونُحاس﴾</span> أيْ دُخان لا لَهَب فِيهِ <span class=\"qpc-hafs\">﴿فَلا تَنْتَصِرانِ﴾</span> تَمْتَنِعانِ مِن ذَلِكَ بَلْ يَسُوقكُمْ إلى المَحْشَر</p></div>",
      "verses": {
        "55:35": {
          "id": 4936
        }
      }
    },
    "36": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:36": {
          "id": 4937
        }
      }
    },
    "37": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَإذا انْشَقَّتِ السَّماء﴾</span> انْفَرَجَتْ أبْوابًا لِنُزُولِ المَلائِكَة <span class=\"qpc-hafs\">﴿فَكانَتْ ورْدَة﴾</span> أيْ مِثْلها مُحْمَرَّة <span class=\"qpc-hafs\">﴿كالدِّهانِ﴾</span> كالأَدِيمِ الأَحْمَر عَلى خِلاف العَهْد بِها وجَواب إذا فَما أعْظَم الهَوْل</p></div>",
      "verses": {
        "55:37": {
          "id": 4938
        }
      }
    },
    "38": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:38": {
          "id": 4939
        }
      }
    },
    "39": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿فَيَوْمئِذٍ لا يُسْأَل عَنْ ذَنْبه إنْس ولا جانّ﴾</span> عَنْ ذَنْبه ويُسْأَلُونَ فِي وقْت آخَر <span class=\"qpc-hafs\">﴿فَوَرَبِّك لَنَسْأَلَنَّهُمْ أجْمَعِينَ﴾</span> والجانّ هُنا وفِيما سَيَأْتِي بِمَعْنى الجِنّ والإنْس فِيهِما بِمَعْنى الإنْسِيّ</p></div>",
      "verses": {
        "55:39": {
          "id": 4940
        }
      }
    },
    "40": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:40": {
          "id": 4941
        }
      }
    },
    "41": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يُعْرَف المُجْرِمُونَ بِسِيماهُمْ﴾</span> سَواد الوُجُوه وزُرْقَة العُيُون <span class=\"qpc-hafs\">﴿فَيُؤْخَذ بِالنَّواصِي والأَقْدام﴾</span> <span class=\"qpc-hafs\">﴿فَبِأَيِّ آلاء رَبّكُما تُكَذِّبانِ﴾</span> تُضَمّ ناصِيَة كُلّ مِنهُمْ إلى قَدَمَيْهِ مِن خَلْف أوْ قُدّام ويُلْقى فِي النّار ويُقال لَهُمْ: <span class=\"qpc-hafs\">﴿هَذِهِ جَهَنَّم الَّتِي يُكَذِّب بِها المُجْرِمُونَ﴾</span></p></div>",
      "verses": {
        "55:41": {
          "id": 4942
        }
      }
    },
    "42": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:42": {
          "id": 4943
        }
      }
    },
    "43": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "55:42",
      "verses": {
        "55:43": {
          "id": 4944
        }
      }
    },
    "44": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿يَطُوفُونَ﴾</span> يَسْعَوْنَ <span class=\"qpc-hafs\">﴿بَيْنها وبَيْن حَمِيم﴾</span> ماء حارّ <span class=\"qpc-hafs\">﴿آنٍ﴾</span> شَدِيد الحَرارَة يُسْقَوْنَهُ إذا اسْتَغاثُوا مِن حَرّ النّار وهُوَ مَنقُوص كَقاضٍ</p></div>",
      "verses": {
        "55:44": {
          "id": 4945
        }
      }
    },
    "45": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:45": {
          "id": 4946
        }
      }
    },
    "46": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ولِمَن خافَ﴾</span> أيْ لِكُلٍّ مِنهُمْ أوْ لِمَجْمُوعِهِمْ <span class=\"qpc-hafs\">﴿مَقام رَبّه﴾</span> قِيامه بَيْن يَدَيْهِ لِلْحِسابِ فَتَرَكَ مَعْصِيَته</p></div>",
      "verses": {
        "55:46": {
          "id": 4947
        }
      }
    },
    "47": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:47": {
          "id": 4948
        }
      }
    },
    "48": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar><p><span class=\"qpc-hafs\">﴿ذَواتا﴾</span> تَثْنِيَة ذَوات عَلى الأَصْل ولامها ياء <span class=\"qpc-hafs\">﴿أفْنان﴾</span> أغْصان جَمْع فَنَن كَطَلَلٍ</p></div>",
      "verses": {
        "55:48": {
          "id": 4949
        }
      }
    },
    "49": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "<div class=ar lang=ar></div>",
      "verses": {
        "55:49": {
          "id": 4950
        }
      }
    },
    "50": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "55:49",
      "verses": {
        "55:50": {
          "id": 4951
        }
      }
    },
    "51": {
      "slug": "ar_tafsir-jalalayn",
      "translated_name": {
        "language_name": "english",
        "name": ""
      },
      "text": "55:49",
      "verses": {
