            "slug": "ar_mukhtasar",
            "translated_name": {
                "name": "Tafsir Ar Mukhtasar",
                "language_name": "english"
            },
            "text": "<h2>يتردَّدون بينها وبين ماء حارٍّ شديد الحرارة.</h2>"
        },
        "45": {
            "verses": {
