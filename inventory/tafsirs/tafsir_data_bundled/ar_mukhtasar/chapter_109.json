            },
            "text": "<h2>ولا أنتم عابدون ما أعبده أنا، وهو الله وحده.</h2>"
        },
        "6": {
            "verses": {
                "109:6": {
                    "id": 6
                }
            },
            "resource_id": 107,
            "resource_name": "Tafsir Ar Mukhtasar",
