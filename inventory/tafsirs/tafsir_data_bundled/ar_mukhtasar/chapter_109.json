            "slug": "ar_mukhtasar",
            "translated_name": {
                "name": "Tafsir Ar Mukhtasar",
                "language_name": "english"
            },
            "text": "<p>لكم دينكم الذي ابتدعتموه لأنفسكم، ولي ديني الذي أنزله الله عليّ.</p>"
        }
