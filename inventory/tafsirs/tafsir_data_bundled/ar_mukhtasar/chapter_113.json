                "name": "Tafsir Ar Mukhtasar",
                "language_name": "english"
            },
            "text": "<h2>* سورة الفلق مكية</h2>\n<h2>* مِن مَّقاصِدِ السُّورَةِ:</h2>\n<h2>التحصُّن والاعتصام بالله من الشرور الظاهرة.</h2>\n<h2>* التَّفْسِيرُ:</h2>\n<h2>قل - أيها الرسول -: أعتصم بربّ الصبح، وأستجير به.</h2>"
        },
        "2": {
            "verses": {
                "113:2": {
                    "id": 2
                }
            },
            "resource_id": 107,
            "resource_name": "Tafsir Ar Mukhtasar",
            "language_id": 38,
            "slug": "ar_mukhtasar",
            "translated_name": {
                "name": "Tafsir Ar Mukhtasar",
                "language_name": "english"
            },
            "text": "<h2>من شرّ ما يؤذي من المخلوقات.</h2>"
        },
        "3": {
            "verses": {
                "113:3": {
                    "id": 3
                }
            },
            "resource_id": 107,
            "resource_name": "Tafsir Ar Mukhtasar",
            "language_id": 38,
            "slug": "ar_mukhtasar",
            "translated_name": {
                "name": "Tafsir Ar Mukhtasar",
                "language_name": "english"
            },
            "text": "<h2>وأعتصم بالله من الشرور التي تظهر في الليل من دواب ولصوص.</h2>"
        },
        "4": {
            "verses": {
                "113:4": {
                    "id": 4
                }
            },
            "resource_id": 107,
            "resource_name": "Tafsir Ar Mukhtasar",
            "language_id": 38,
            "slug": "ar_mukhtasar",
            "translated_name": {
                "name": "Tafsir Ar Mukhtasar",
                "language_name": "english"
            },
            "text": "<h2>وأعتصم به من شرّ السواحر اللائي يَنْفُثْن في العُقَد.</h2>"
        },
        "5": {
            "verses": {
                "113:5": {
                    "id": 5
                }
            },
            "resource_id": 107,
            "resource_name": "Tafsir Ar Mukhtasar",
            "language_id": 38,
            "slug": "ar_mukhtasar",
            "translated_name": {
                "name": "Tafsir Ar Mukhtasar",
                "language_name": "english"
            },
            "text": "<h2>وأعتصم به من شرّ حاسد إذا عمل بما يدفعه إليه الحسد.</h2>"
        }
    }
}