            "translated_name": {
                "name": "Tafsir En Jalalayn",
                "language_name": "english"
            },
            "text": "<p>Verily man (al-insn: the generic) is in [a state of] loss, in all his bargaining,</p>"
        },
        "3": {
            "verses": {
                "103:3": {
                    "id": 3
                }
            },
            "resource_id": 125,
            "resource_name": "Tafsir En Jalalayn",
