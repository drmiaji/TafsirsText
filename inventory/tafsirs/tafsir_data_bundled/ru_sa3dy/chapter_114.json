            },
            "text": "<p>от зла искусителя отступающего (или сжимающегося) при поминании Аллаха,</p>"
        },
        "5": {
            "verses": {
                "114:5": {
                    "id": 5
                }
            },
            "resource_id": 139,
            "resource_name": "Tafsir Ru Sa3Dy",
