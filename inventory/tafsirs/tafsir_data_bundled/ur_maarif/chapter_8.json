            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اس کا سبب یہ ہے کہ اللہ ہرگز بدلنے والا نہیں اس نعمت کو جو دی تھی اس نے کسی قوم کو جب تک وہی نہ بدل ڈالیں اپنے جیوں کی بات اور یہ کہ اللہ سننے والا جاننے والا ہے۔</p>"
        },
        "54": {
            "verses": {
                "8:54": {
                    "id": 54
