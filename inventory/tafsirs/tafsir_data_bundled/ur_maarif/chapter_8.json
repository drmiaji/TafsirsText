            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر وہ چاہیں کہ تجھ کو دغا دیں تو تجھ کو کافی ہے اللہ، اسی نے تجھ کو زور دیا اپنی مدد کا اور مسلمانوں کا۔</p>"
        },
        "63": {
            "verses": {
                "8:63": {
                    "id": 63
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
