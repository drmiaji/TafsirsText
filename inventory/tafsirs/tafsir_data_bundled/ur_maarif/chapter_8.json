            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جیسے دستور فرعون والوں کا اور جو ان سے پہلے تھے، کہ منکر ہوئے اللہ کی باتوں سے سو پکڑا ان کو اللہ نے ان کے گناہوں پر، بیشک اللہ زور آور ہے سخت عذاب کرنے والا،</p>"
        },
        "53": {
            "verses": {
