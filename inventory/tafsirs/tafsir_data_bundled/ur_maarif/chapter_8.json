            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جب کہنے لگے منافق اور جن کے دلوں میں بیماری ہے یہ لوگ مغرور ہیں اپنے دین پر، اور جو کوئی بھروسہ کرے اللہ پر تو اللہ زبردست ہے حکمت والا۔</p>"
        },
