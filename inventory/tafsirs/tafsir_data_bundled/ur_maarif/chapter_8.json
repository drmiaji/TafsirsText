            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے نبی کہہ دے ان سے جو تمہارے ہاتھ میں ہیں قیدی اگر جانے گا اللہ تمہارے دلوں میں کچھ نیکی تو دے گا تم کو بہتر اس سے جو تم سے چھن گیا اور تم کو بخشے گا، اور اللہ ہے بخشنے والا مہربان</p>"
        },
