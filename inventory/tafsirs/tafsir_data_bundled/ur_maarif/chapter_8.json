            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ بدلہ ہے اسی کا جو تم نے آگے بھیجا اپنے ہاتھوں اور اس واسطے کہ اللہ ظلم نہیں کرتا بندوں پر،</p>"
        },
        "52": {
            "verses": {
                "8:52": {
                    "id": 52
