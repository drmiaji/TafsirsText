                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بدتر سب جانداروں میں اللہ کے ہاں وہ ہیں جو منکر ہوئے پھر وہ نہیں ایمان لاتے۔</p>"
        },
        "56": {
            "verses": {
