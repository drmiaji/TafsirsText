            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے نبی کافی ہے تجھ کو اللہ اور جتنے تیرے ساتھ ہیں مسلمان اے نبی شوق دلا مسلمانوں کو لڑائی کا</p>"
        },
        "65": {
            "verses": {
