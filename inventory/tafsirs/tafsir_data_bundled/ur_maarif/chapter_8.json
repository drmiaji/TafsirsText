            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اگر ہو تم میں بیس شخص ثابت قدم رہنے والے تو غالب ہوں دو سو پر، اور اگر ہوں تم میں سو شخص تو غالب ہوں ہزار کافروں پر اس واسطے کہ وہ لوگ سمجھ نہیں رکھتے۔</p>"
        },
        "66": {
            "verses": {
