            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر تم دیکھے جس وقت جان قبض کرتے ہیں کافروں کی فرشتے مارتے ہیں ان کے منہ پر اور ان کے پیچھے، اور کہتے ہیں چکھو عذاب جلنے کا،</p>"
        },
        "51": {
            "verses": {
