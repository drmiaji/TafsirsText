            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اگر نہ ہوتی ایک بات جس کو لکھ چکا اللہ پہلے سے تو تم کو پہنچتا اس لینے میں بڑا عذاب۔</p>"
        },
