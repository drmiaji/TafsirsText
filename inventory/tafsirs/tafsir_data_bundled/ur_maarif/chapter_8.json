            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو کھاؤ جو تم کو غنیمت میں ملا حلال ستھرا اور ڈرتے رہو اللہ سے بےبیشک اللہ ہے بخشنے والا مہربان۔</p>"
        },
