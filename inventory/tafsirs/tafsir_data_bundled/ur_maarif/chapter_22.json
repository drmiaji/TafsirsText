        },
        "60": {
            "verses": {
                "22:60": {
                    "id": 60
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ سن چکے اور جس نے بدلہ لیا جیسا کہ اس کو دکھ دیا تھا پھر اس پر کوئی زیادتی کرے تو البتہ اس کی مدد کرے گا اللہ، بیشک اللہ درگزر کرنے والا بخشنے والا ہے۔</p>"
        },
        "61": {
            "verses": {
                "22:61": {
                    "id": 61
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ اس واسطے کہ اللہ لے لیتا ہے رات کو دن میں اور دن کو رات میں اور اللہ سنتا دیکھتا ہے</p>"
        },
        "62": {
            "verses": {
                "22:62": {
                    "id": 62
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ اس واسطے کہ اللہ وہی ہے صحیح اور جس کو پکارتے ہیں اس کے سوائے وہی ہے غلط اور اللہ وہی ہے سب سے اوپر بڑا</p>"
        },
        "63": {
            "verses": {
                "22:63": {
                    "id": 63
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو نے نہیں دیکھا کہ اللہ نے اتارا آسمان سے پانی پھر زمین ہوجاتی ہے سرسبز بیشک اللہ جانتا ہے چھپی تدبیریں خبردار ہے</p>"
        },
        "64": {
            "verses": {
                "22:64": {
                    "id": 64
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اسی کا ہے جو کچھ ہے آسمان اور زمین میں اور اللہ وہی ہے بےپروا تعریفوں والا</p>"
        },
        "65": {
            "verses": {
                "22:65": {
                    "id": 65
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو نے نہ دیکھا کہ اللہ نے بس میں کردیا تمہارے جو کچھ ہے زمین میں اور کشتی کو جو چلتی ہے دریا میں اس کے حکم سے اور تمام رکھتا ہے آسمان کو اس سے کہ گر پڑے زمین پر مگر اس کے حکم سے بیشک اللہ لوگوں پر نرمی کرنے والا مہربان ہے</p>"
        },
        "66": {
            "verses": {
                "22:66": {
                    "id": 66
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اسی نے تم کو جلایا پھر مارتا ہے پھر زندہ کرے گا بیشک انسان ناشکر ہے۔</p>"
        },
        "67": {
            "verses": {
                "22:67": {
                    "id": 67
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ہر امت کے لئے ہم نے مقرر کردی ایک راہ بندگی کی کہ وہ اس طرح کرتے ہیں بندگی، سو چاہئے تجھ سے جھگڑا نہ کریں اس کام میں اور بلائے جا اپنے رب کی طرف، بیشک تو ہے سیدھی راہ ،</p>"
        },
        "68": {
            "verses": {
                "22:68": {
                    "id": 68
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پر سوجھ والا اور اگر تجھ سے جھگڑنے لگیں تو تو کہہ اللہ بہتر جانتا ہے جو تم کرتے ہو</p>"
        },
        "69": {
            "verses": {
                "22:69": {
                    "id": 69
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اللہ فیصلہ کرے گا تم میں قیامت کے دن جس چیز میں تمہاری راہ جدا جدا تھی</p>"
        },
        "70": {
            "verses": {
                "22:70": {
                    "id": 70
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا تجھ کو معلوم نہیں کہ اللہ جانتا ہے جو کچھ ہے آسمان اور زمین میں یہ سب لکھا ہوا ہے کتاب میں یہ اللہ پر آسان ہے۔</p>"
        },
        "71": {
            "verses": {
                "22:71": {
                    "id": 71
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور پوجتے ہیں اللہ کے سوائے اس چیز کو جس چیز کی سند نہیں اتاری اس نے اور جس کی خبر نہیں ان کو اور بےانصافوں کا کوئی نہیں مددگار</p>"
        },
        "72": {
            "verses": {
                "22:72": {
                    "id": 72
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب سنائے ان کو ہماری آیتیں صاف تو پہچانے تو منکروں کے منہ کی بری شکل نزدیک ہوتے ہیں کہ حملہ کر پڑیں ان پر جو پڑھتے ہیں ان کے پاس ہماری آیتیں تو کہہ میں تم کو بتلاؤں ایک چیز اس سے بدتر وہ آگ ہے اس کا وعدہ کردیا ہے اللہ نے منکروں کو اور وہ بہت بری ہے پھرجانے کی جگہ</p>"
        },
        "73": {
            "verses": {
                "22:73": {
                    "id": 73
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے لوگو ! ایک مثال کہی ہے سو اس پر کان رکھوں جن کو تم پوجتے ہو اللہ کے سوائے ہرگز نہ بنا سکیں گے ایک مکھی اگرچہ سارے جمع ہوجائیں اور اگر کچھ چھین لے ان سے مکھی چھڑا نہ سکیں وہ اس سے بودا ہے چاہنے والا اور جن کو چاہتا ہے</p>"
        },
        "74": {
            "verses": {
                "22:74": {
                    "id": 74
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اللہ کی قدر نہیں سمجھے جیسی اس کی قدر ہے بیشک اللہ زور آور ہے زبردست۔</p>"
        },
        "75": {
            "verses": {
                "22:75": {
                    "id": 75
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اللہ چھانٹ لیتا ہے فرشتوں میں پیغام پہنچانے والے اور آدمیوں میں اللہ سنتا دیکھتا ہے</p>"
        },
        "76": {
            "verses": {
                "22:76": {
                    "id": 76
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جانتا ہے جو کچھ ان کے آگے ہے اور جو کچھ ان کے پیچھے اور اللہ تک پہنچ ہے ہر کام کی</p>"
        },
        "77": {
            "verses": {
                "22:77": {
                    "id": 77
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے ایمان والو ! رکوع کرو اور سجدہ کرو اور بندگی کرو اپنے رب کی اور بھلائی کرو تاکہ تمہارا بھلا ہو</p>"
        },
        "78": {
            "verses": {
                "22:78": {
                    "id": 78
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور محنت کرو اللہ کے واسطے جیسی کہ چاہئے اس کے واسطے محنت، اس نے تم کو پسند کیا اور نہیں رکھی تم پر دین میں کچھ مشکل دین تمہارے باپ ابراہیم کا اسی نے نام رکھا تمہارا مسلمان پہلے سے اور اس قرآن میں تاکہ رسول ہو بتانے والا تم پر اور تم ہو بتانے والے لوگوں پر سو قائم رکھو نماز اور دیتے رہو زکوٰة اور مضبوط پکڑو اللہ کو وہ تمہارا مالک ہے سو خوب مالک ہے اور خوب مددگار۔</p>"
        }
    }
