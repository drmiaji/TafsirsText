            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ سن چکے اور جو کوئی برائی رکھے اللہ کی حرمتوں کی سو وہ بہتر ہے اس کے لئے اپنے رب کے پاس اور حلال ہیں تم کو چوپائے مگر جو تم کو سناتے ہیں سو بچتے رہو بتوں کی گندگی سے اور بچتے رہو جھوٹی بات سے</p>"
        },
        "31": {
            "verses": {
                "22:31": {
                    "id": 31
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ایک اللہ کی طرف کے ہو کر نہ کہ اس کے ساتھ شریک بنا کر اور جس نے شریک بنایا اللہ کا سو جیسے گر پڑا آسمان سے پھر اچکتے ہیں اس کو اڑنے والے مردار خوار یا جا ڈالا اس کو ہوا نے کسی دور مکان میں</p>"
        },
        "32": {
            "verses": {
                "22:32": {
                    "id": 32
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ سن چکے اور جو کوئی ادب رکھے اللہ کے نام لگی چیزوں کا سو وہ دل کی پرہیزگاری کی بات ہے</p>"
        },
        "33": {
            "verses": {
                "22:33": {
                    "id": 33
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تمہارے واسطے چوپایوں میں فائدے ہیں ایک مقرر وعدہ تک پھر ان کو پہنچنا اس قدیم گھر تک۔</p>"
        },
        "34": {
            "verses": {
                "22:34": {
                    "id": 34
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ہر امت کے واسطے ہم نے مقرر کردی ہے قربانی کہ یاد کریں اللہ کے نام ذبح پر چوپایوں کے، جو ان کو اللہ نے دیئے سو اللہ تمہارا ایک اللہ ہے سو اسی کے حکم میں رہو اور بشارت سنا دے عاجزی کرنے والوں کو</p>"
        },
        "35": {
            "verses": {
                "22:35": {
                    "id": 35
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ کہ جب نام لیجئے اللہ کا ڈر جائیں ان کے دل اور سہنے والے اس کو جو ان پر پڑے اور قائم رکھنے والے نماز کے اور ہمارا دیا ہوا کچھ خرچ کرتے رہتے ہیں</p>"
        },
        "36": {
            "verses": {
                "22:36": {
                    "id": 36
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کعبہ کے چڑھانے کے اونٹ ٹھہرائے ہیں ہم نے تمہارے واسطے نشانی اللہ کے نام کی، تمہارے واسطے اس میں بھلائی ہے سو پڑھو ان پر نام اللہ کا قطار باندھ کر پھر جب گر پڑے ان کی کروٹ تو کھاؤ اس میں سے اور کھلاؤ صبر سے بیٹھے کو اور بےقراری کرتے کو اسی طرح تمہارے بس میں کردیا ہم نے ان جانوروں کو تاکہ تم احسان مانو</p>"
        },
        "37": {
            "verses": {
                "22:37": {
                    "id": 37
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اللہ کو نہیں پہنچتا ان کا گوشت اور ان کا لہو لیکن اس کو پہنچتا ہے تمہارے دل کا ادب اسی طرح ان کو بس میں کردیا تمہارے کہ اللہ کی بڑائی پڑھو اس بات پر کہ تم کو راہ سمجھائی اور بشارت سنا دے نیکی والوں کو</p>"
        },
        "38": {
            "verses": {
                "22:38": {
                    "id": 38
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اللہ دشمنوں کو ہٹا دے گا ایمان والوں سے اللہ کو خوش نہیں آتا کوئی دغا باز ناشکر۔</p>"
        },
        "39": {
            "verses": {
                "22:39": {
                    "id": 39
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>حکم ہوا ان لوگوں کو جن سے کافر لڑتے ہیں اس واسطے کہ ان پر ظلم ہوا اور اللہ ان کی مدد کرنے پر قادر ہے</p>"
        },
        "40": {
            "verses": {
                "22:40": {
                    "id": 40
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ لوگ جن کو نکالا ان کے گھروں سے اور دعویٰ کچھ نہیں سوائے اس کے کہ وہ کہتے ہیں ہمارا رب اللہ ہے اور اگر نہ ہٹایا کرتا اللہ لوگوں کو ایک کو دوسرے سے تو ڈھائے جاتے تکیئے اور مدرسے اور عبادت خانے اور مسجدیں جن میں نام پڑھا جاتا ہے اللہ کا بہت اور اللہ مقرر مدد کرے گا اس کی جو مدد کرے گا اس کی بیشک اللہ زبردست ہے زور والا</p>"
        },
        "41": {
            "verses": {
                "22:41": {
                    "id": 41
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ لوگ کہ اگر ہم ان کو قدرت دیں ملک میں تو وہ قائم رکھیں نماز اور دیں زکوٰة اور حکم کریں بھلے کام کا اور منع کریں برائی سے اور اللہ کے اختیار میں ہے آخر ہر کام کا۔</p>"
        },
        "42": {
            "verses": {
                "22:42": {
                    "id": 42
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر تجھ کو جھٹلائیں تو ان سے پہلے جھٹلا چکی ہے نوح کی قوم اور عاد اور ثمود</p>"
        },
        "43": {
            "verses": {
                "22:43": {
                    "id": 43
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور ابراہیم کی قوم اور لوط کی قوم</h2>"
        },
        "44": {
            "verses": {
                "22:44": {
                    "id": 44
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور مدین کے لوگ اور موسیٰ کو جھٹلایا پھر میں نے ڈھیل دی منکروں کو پھر پکڑ لیا ان کو تو کیسا ہوا میرا انکار</p>"
        },
        "45": {
            "verses": {
                "22:45": {
                    "id": 45
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو کتنی بستیاں ہم نے غارت کر ڈالیں اور وہ گنہگار تھیں اب وہ گری پڑی ہیں اپنی چھتوں پر اور کتنے کنویں نکمے پڑے اور کتنے محل گچکاری کے</p>"
        },
        "46": {
            "verses": {
                "22:46": {
                    "id": 46
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا سیر نہیں کی ملک کی جو ان کے دل ہوتے جن سے سمجھتے یا کان ہوتے جن سے سنتے سو کچھ آنکھیں اندھی نہیں ہوتیں پر اندھے ہوجاتے ہیں دل جو سینوں میں ہیں</p>"
        },
        "47": {
            "verses": {
                "22:47": {
                    "id": 47
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور تجھ سے جلدی مانگتے ہیں عذاب اور اللہ ہرگز نہ ٹالے گا اپنا وعدہ اور ایک دن تیرے رب کے یہاں ہزار برس کے برابر ہوتا ہے جو تم گنتے ہو</p>"
        },
        "48": {
            "verses": {
                "22:48": {
                    "id": 48
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کتنی بستیاں ہیں کہ میں نے ان کو ڈھیل دی اور وہ گنہگار تھیں پھر میں نے ان کو پکڑا اور میری طرف پھر کر آنا ہے</p>"
        },
        "49": {
            "verses": {
                "22:49": {
                    "id": 49
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>تو کہہ اے لوگو ! میں تو ڈر سنا دینے والا ہوں تم کو کھول کر</h2>"
        },
        "50": {
            "verses": {
                "22:50": {
                    "id": 50
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو جو لوگ یقین لائے اور کیں بھلائیاں ان کے گناہ بخش دیتے ہیں اور ان کو روزی ہے عزت کی</p>"
        },
        "51": {
            "verses": {
                "22:51": {
                    "id": 51
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو دوڑے ہماری آیتوں کے ہرانے کو وہی ہیں دوزخ کے رہنے والے۔</p>"
        },
        "52": {
            "verses": {
                "22:52": {
                    "id": 52
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو رسول بھیجا ہم نے تجھ سے پہلے یا نبی سو جب لگا خیال باندھنے شیطان نے ملا دیا اس کے خیال میں پھر اللہ مٹا دیتا ہے شیطان کا ملایا ہوا پھر پکی کردیتا ہے اپنی باتیں اور اللہ سب خبر رکھتا ہے حکمتوں والا</p>"
        },
        "53": {
            "verses": {
                "22:53": {
                    "id": 53
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اس واسطے کہ جو کچھ شیطان نے ملایا اس سے جانچے ان کو کہ جن کے دل میں روگ ہیں اور جن کے دل سخت ہیں اور گنہگار تو ہیں مخالفت میں دور جا پڑے</p>"
        },
        "54": {
            "verses": {
                "22:54": {
                    "id": 54
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اس واسطے کہ معلوم کرلیں وہ لوگ جن کو سمجھ ملی ہے کہ یہ تحقیق ہے تیرے رب کی طرف سے پھر اس پر یقین لائیں اور نرم ہوجائیں اس کے آگے دل ان کے اور اللہ سمجھانے والا ہے یقین لانے والوں کو راہ سیدھی</p>"
        },
        "55": {
            "verses": {
                "22:55": {
                    "id": 55
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور منکروں کو ہمیشہ رہے گا اس میں دھوکا جب تک آپہنچے ان پر قیامت بیخبر ی میں یا آپہنچے ان پر آفت ایسے دن کی جس میں راہ نہیں خلاصی کی</p>"
        },
        "56": {
            "verses": {
                "22:56": {
                    "id": 56
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>راج اس دن اللہ کا ہے ان میں فیصلہ کرے گا سو جو یقین لائے اور کیں بھلائیاں نعمت کے باغوں میں ہیں</p>"
        },
        "57": {
            "verses": {
                "22:57": {
                    "id": 57
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
