{
    "chapter": 59,
    "verses": {
        "1": {
            "verses": {
                "59:1": {
                    "id": 1
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اللہ کی پاکی بیان کرتا ہے جو کچھ ہے آسمانوں میں اور زمین میں اور وہی ہے زبردست حکمت والا</p>"
        },
        "2": {
            "verses": {
                "59:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہی ہے جس نے نکال دیا ان کو جو منکر ہیں کتاب والوں میں ان کے گھروں سے پہلے ہی اجتماع پر لشکر کے ، تم نہ اٹکل کرتے تھے کہ نکلیں گے وہ اور وہ خیال رکھتے تھے کہ ان کو بچا لیں گے ان کے قلعے اللہ کے ہاتھ سے پھر پہنچا ان پر اللہ جہاں سے ان کو خیال نہ تھا اور ڈال دی ان کے دلوں میں دھاک اجاڑنے لگے اپنے گھر اپنے ہاتھوں اور مسلمانوں کے ہاتھوں سو عبرت پکڑو اے آنکھ والو !</p>"
        },
        "3": {
            "verses": {
                "59:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر نہ ہوتی یہ بات کہ لکھ دیا تھا اللہ نے ان پر جلا وطن ہونا تو ان کو عذاب دیتا دنیا میں اور آخرت میں ان کے لئے ہے آگ کا عذاب</p>"
        },
        "4": {
            "verses": {
                "59:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ اس لئے کہ وہ مخالف ہوئے اللہ سے اور اس کے رسول سے اور جو کوئی مخالف ہو اللہ سے تو اللہ کا عذاب سخت ہے</p>"
        },
        "5": {
            "verses": {
                "59:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جو کاٹ ڈالا تم نے کجھور کا درخت یا رہنے دیا کھڑا اپنی جڑ پر سو اللہ کے حکم سے اور تاکہ رسوا کرے نافرمانوں کو</p>"
        },
        "6": {
            "verses": {
                "59:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو مال کہ لوٹا دیا اللہ نے اپنے رسول پر ان سے سو تم نے نہیں دوڑائے اس پر گھوڑے اور نہ اونٹ لیکن اللہ غلبہ دیتا ہے اپنے رسولوں کو جس پر چاہے اور اللہ سب کچھ کرسکتا ہے</p>"
        },
        "7": {
            "verses": {
                "59:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جو مال لوٹایا اللہ نے اپنے رسول پر بستیوں والوں سے سو اللہ کے واسطے اور رسول کے اور قرابت والے کے اور یتیموں کے اور محتاجوں کے اور مسافر کے تاکہ نہ آئے لینے دینے میں دولت مندوں کے تم میں سے اور جو دے تم کو رسول سو لے لو اور جس سے منع کرے سو چھوڑ دو اور ڈرتے رہو اللہ سے بیشک اللہ کا عذاب سخت ہے</p>"
        },
        "8": {
            "verses": {
                "59:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>واسطے ان مفلسوں وطن چھوڑنے والوں کے جو نکالے ہوئے آئے ہیں اپنے گھروں سے اور اپنے مالوں سے ڈھونڈتے آئے ہیں اللہ کا فضل اور اس کی رضا مندی اور مدد کرنے کو اللہ کی اور اس کے رسول کی وہ لوگ وہی ہیں سچے</p>"
        },
        "9": {
            "verses": {
                "59:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو لوگ جگہ پکڑ رہے ہیں اس گھر میں اور ایمان میں ان سے پہلے سے وہ محبت کرتے ہیں اس سے جو وطن چھوڑ کر آئے ان کے پاس اور نہیں پاتے اپنے دل میں تنگی اس چیز سے جو ان (مہاجرین) کو دی جائے اور مقدم رکھتے ہیں ان کو اپنی جان سے اور اگرچہ ہو اپنے اوپر فاقہ اور جو بچایا گیا اپنے جی کے لالچ سے تو وہی لوگ ہیں مراد پانے والے</p>"
        },
        "10": {
            "verses": {
                "59:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور واسطے ان لوگوں کے جو آئے ان کے بعد کہتے ہوئے اے رب بخش ہم کو اور ہمارے بھائیوں کو جو ہم سے پہلے داخل ہوئے ایمان میں اور نہ رکھ ہمارے دلوں میں بیر ایمان والوں کا اے رب تو ہی ہے نرمی والا مہربان۔</p>"
        },
        "11": {
            "verses": {
                "59:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا تو نے نہیں دیکھا ان لوگوں کو جو دغا باز ہیں کہتے ہیں اپنے بھائیوں کو جو کہ کافر ہیں اہل کتاب میں سے اگر تم کو کوئی نکال دے گا تو ہم بھی نکلیں گے تمہارے ساتھ اور کہا نہ مانیں گے کسی کا تمہارے معاملہ میں کبھی اور اگر تم سے لڑائی ہوئی تو ہم تمہاری مدد کریں گے اور اللہ گواہی دیتا ہے کہ وہ جھوٹے ہیں</p>"
        },
        "12": {
            "verses": {
                "59:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اگر وہ نکالے جائیں یہ نہ نکلیں گے ان کے ساتھ اور اگر ان سے لڑائی ہوئی یہ نہ مدد کریں گے ان کی اور اگر مدد کریں گے تو بھاگیں کے پیٹھ پھیر کر پھر کہیں مدد نہ پائیں گے</p>"
        },
        "13": {
            "verses": {
                "59:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>البتہ تمہارا ڈر زیادہ ہے ان کے دلوں میں اللہ کے ڈر سے یہ اس لئے کہ وہ لوگ سمجھ نہیں رکھتے</p>"
        },
        "14": {
            "verses": {
                "59:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>لڑ نہ سکیں گے تم سے سب مل کر مگر بستیوں کے کوٹ میں یا دیواروں کی اوٹ میں ان کی لڑائی آپس میں سخت ہے تو سمجھے وہ اکٹھے ہیں اور ان کے دل جدا جدا ہو رہے ہیں یہ اس لئے کہ وہ لوگ عقل نہیں رکھتے</p>"
        },
        "15": {
            "verses": {
                "59:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جیسے قصہ ان لوگوں کا جو ہوچکے ہیں ان سے قریب ہی چکھی انہوں نے سزا اپنے کام کی اور ان کے لئے عذاب درد ناک ہے</p>"
        },
        "16": {
            "verses": {
                "59:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جیسے قصہ شیطان کا جب کہے انسان کو تو منکر ہو پھر جب وہ منکر ہوگیا کہے میں الگ ہوں تجھ سے میں ڈرتا ہوں اللہ سے جو رب سارے جہان کا</p>"
        },
        "17": {
            "verses": {
                "59:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر انجام دونوں کا یہی کہ وہ دونوں ہیں آگ میں ہمیشہ رہیں اسی میں اور یہی ہے سزا گنہگاروں کی۔</p>"
        },
        "18": {
            "verses": {
                "59:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے ایمان والو ! ڈرتے رہو اللہ سے اور چاہئے کہ دیکھ لے ہر ایک جی کیا بھیجتا ہے کل کے واسطے اور ڈرتے رہو اللہ سے بیشک اللہ کو خبر ہے جو تم کرتے ہو</p>"
        },
        "19": {
            "verses": {
                "59:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور مت ہو ان جیسے جنہوں نے بھلا دیا اللہ کو پھر اللہ نے بھلا دیئے ان کو ان کے جی وہ لوگ وہی ہیں نافرمان</p>"
        },
        "20": {
            "verses": {
                "59:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>برابر نہیں دوزخ والے اور بہشت والے بہشت والے جو ہیں وہی ہیں مراد پانے والے</p>"
        },
        "21": {
            "verses": {
                "59:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اگر ہم اتارتے یہ قرآن ایک پہاڑ پر تو تو دیکھ لیتا کہ وہ دب جاتا پھٹ جاتا اللہ کے ڈر سے اور یہ مثالیں ہم سناتے ہیں لوگوں کو تاکہ وہ غور کریں</p>"
        },
        "22": {
            "verses": {
                "59:22": {
                    "id": 22
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ اللہ ہے جس کے سوائے بندگی نہیں کسی کی جانتا ہے جو پوشیدہ ہے اور جو ظاہر ہے وہ ہے بڑا مہربان رحم والا</p>"
        },
        "23": {
            "verses": {
                "59:23": {
                    "id": 23
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ اللہ ہے جس کے سوائے بندگی نہیں کسی کی وہ بادشاہ ہے پاک ذات سب عیبوں سے سالم امان دینے والا پناہ میں لینے والا زبردست دباؤ والا صاحب عظمت پاک ہے اللہ ان کے شریک بتلانے سے</p>"
        },
        "24": {
