                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ اللہ ہے بنانے والا نکال کھڑا کرنے والا صورت کھینچنے والا اسی کے ہیں سب نام خاصے پاکی بول رہا ہے اس کی جو کچھ ہے آسمانوں میں اور زمین میں اور وہی ہے زبردست حکمتوں والا۔</p>"
        }
