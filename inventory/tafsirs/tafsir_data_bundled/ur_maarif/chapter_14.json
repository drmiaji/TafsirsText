{
    "chapter": 14,
    "verses": {
        "1": {
            "verses": {
                "14:1": {
                    "id": 1
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ ایک کتاب ہے کہ ہم نے اتاری تیری طرف کہ تو نکالے لوگوں کو اندھیروں سے اجالے کی طرف، ان کے رب کے حکم سے رستہ پر اس زبردست خوبیوں والے</p>"
        },
        "2": {
            "verses": {
                "14:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اللہ کے جس کا ہے جو کچھ کہ موجود ہے آسمانوں میں اور جو کچھ ہے زمین میں اور مصیبت ہے کافروں کو ایک سخت عذاب سے</p>"
        },
        "3": {
            "verses": {
                "14:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جو کہ پسند رکھتے ہیں زندگی دنیا کی آخرت سے اور روکتے ہیں اللہ کی راہ سے اور تلاش کرتے ہیں اس میں کجی، وہ راستہ بھول کر جا پڑے ہیں دور</p>"
        },
        "4": {
            "verses": {
                "14:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کوئی رسول نہیں بھیجا ہم نے مگر بولی بولنے والا اپنی قوم کی تاکہ ان کو سمجھائے، پھر راستہ بھلاتا ہے اللہ جس کو چاہے اور راستہ دکھلا دیتا ہے جس کو چاہے اور وہ ہے زبردست حکمتوں والا۔</p>"
        },
        "5": {
            "verses": {
                "14:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور بھیجا تھا ہم نے موسیٰ کو اپنی نشانیاں دیکر کہ نکال اپنی قوم کو اندھیروں سے اجالے کی طرف اور یاد دلا ان کو دن اللہ کے، البتہ اس میں نشانیاں ہیں اس کو جو صبر کرنے والا ہے شکر گزار</p>"
        },
        "6": {
            "verses": {
                "14:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب کہا موسیٰ نے اپنی قوم کو یاد کرو اللہ کا احسان اپنے اوپر جب چھڑا دیا تم کو فرعون کی قوم سے وہ پہنچاتے تھے تم کو برا عذاب اور ذبح کرتے تمہارے بیٹوں کو اور زندہ رکھتے تمہاری عورتوں کو اور اس میں مدد ہوئی تمہارے رب کی طرف سے بڑی ،</p>"
        },
        "7": {
            "verses": {
                "14:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب سنا دیا تمہارے رب نے اگر احسان مانو گے تو اور بھی دوں گا تم کو اور اگر ناشکری کرو گے تو میرا عذاب البتہ سخت ہے</p>"
        },
        "8": {
            "verses": {
                "14:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہا موسیٰ نے اگر کفر کرو گے تم اور جو لوگ زمین میں ہیں سارے تو اللہ بےپرواہ ہے سب خوبیوں والا</p>"
        },
        "9": {
            "verses": {
                "14:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا نہیں پہنچی تم کو خبر ان لوگوں کی جو پہلے تھے تم سے قوم نوح کی اور عاد اور ثمود اور جو ان سے پیچھے ہوئے، کسی کو ان کی خبر نہیں مگر اللہ کو آئے ان کے پاس ان کے رسول نشانیاں لے کر پھر لوٹائے انہوں نے اپنے ہاتھ اپنے منہ میں اور بولے ہم نہیں مانتے جو تم کو دے کر بھیجا گیا اور ہم کو تو شبہ ہے اس راہ میں جس کی طرف تم ہم کو بلاتے ہو خلجان میں ڈالنے والا</p>"
        },
        "10": {
            "verses": {
                "14:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بولے ان کے رسول کیا اللہ میں شبہ ہے جس نے بنائے آسمان اور زمین وہ تم کو بلاتا ہے تاکہ بخشے تم کو کچھ گناہ تمہارے اور ڈھیل دے تم کو ایک وعدہ تک جو ٹھہر چکا ہے کہنے لگے تم تو یہی آدمی ہو ہم جیسے، تم چاہتے ہو کہ روک دو ہم کو ان چیزوں سے جن کو پوجتے رہے ہمارے باپ دادا سو لاؤ کوئی سند کھلی ہوئی</p>"
        },
        "11": {
            "verses": {
                "14:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ان کو کہا ان کے رسولوں نے ہم تو یہی آدمی ہیں جیسے تم لیکن اللہ احسان کرتا ہے اپنے بندوں میں جس پر چاہے، اور ہمارا کام نہیں کہ لے آئیں تمہارے پاس سند مگر اللہ کے حکم سے اور اللہ پر بھروسہ چاہئے ایمان والوں کو</p>"
        },
        "12": {
            "verses": {
                "14:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ہم کو کیا ہوا کہ بھروسہ نہ کریں اللہ پر اور وہ سمجھا چکا ہم کو ہماری راہیں، اور ہم صبر کریں گے ایذا پر جو تم ہم کو دیتے ہو اور اللہ پر بھروسہ چاہئے بھروسے والوں کو</p>"
        },
        "13": {
            "verses": {
                "14:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہا کافروں نے اپنے رسولوں کو ہم نکال دیں گے تم کو اپنی زمین سے یا لوٹ آؤ ہمارے دین میں، تب حکم بھیجا ان کو ان کے رب نے ہم غارت کریں گے ان ظالموں کو</p>"
        },
        "14": {
            "verses": {
                "14:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور آباد کریں گے تم کو اس زمین میں ان کے پیچھے، یہ ملتا ہے اس کو جو ڈرتا ہے کھڑے ہونے سے میرے سامنے اور ڈرتا ہے میرے عذاب کے وعدے سے</p>"
        },
        "15": {
            "verses": {
                "14:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور فیصلہ لگے مانگنے پیغمبر اور ناراہ ہوا ہر ایک سرکش ضدی۔</h2>"
        },
        "16": {
            "verses": {
                "14:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پیچھے اس کے دوزخ ہے اور پلائیں گے اس کو پانی پیپ کا</h2>"
        },
        "17": {
            "verses": {
                "14:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>گھونٹ گھونٹ پیتا ہے اس کو اور گلے سے نہیں اتار سکتا اور چلی آتی ہے اس پر موت ہر طرف سے اور وہ نہیں مرتا، اور اس کے پیچھے عذاب ہے سخت۔</p>"
        },
        "18": {
            "verses": {
                "14:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>حال ان لوگوں کا جو منکر ہوئے اپنے رب سے ان کے عمل ہیں جیسے وہ راکھ کہ زور کی چلے اس پر ہوا آندھی کے دن، کچھ ان کے ہاتھ میں نہ ہوگا اپنی کمائی میں سے یہی ہے بہک کر دور جا پڑنا</p>"
        },
        "19": {
            "verses": {
                "14:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو نے کیا نہیں دیکھا کہ اللہ نے بنائے آسمان اور زمین جیسی چاہئے، اگر چاہے تم کو لیجئے اور لائے کوئی پیدائش نئی</p>"
        },
        "20": {
            "verses": {
                "14:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور یہ اللہ کو کچھ مشکل نہیں</h2>"
        },
        "21": {
            "verses": {
                "14:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور سامنے کھڑے ہوں گے اللہ کے سارے پھر کہیں گے کمزور بڑائی والوں کو ہم تو تمہارے تابع تھے، سو کیا بچاؤ گے ہم کو اللہ کے کسی عذاب سے کچھ، وہ کہیں گے اگر ہدایت کرتا ہم کو اللہ تو البتہ ہم تم کو ہدایت کرتے، اب برابر ہے ہمارے حق میں ہم بیقراری کریں یا صبر کریں ہم کو نہیں خلاصی،</p>"
        },
        "22": {
            "verses": {
                "14:22": {
                    "id": 22
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور بولا شیطان جب فیصل ہوچکا سب کام بیشک اللہ نے تم کو دیا تھا سچا وعدہ اور میں نے تم سے وعدہ کیا پھر جھوٹا کیا، اور میری تم پر کچھ حکومت نہ تھی مگر یہ کہ میں نے بلایا تم کو پھر تم نے مان لیا میری بات کو سوالزام نہ دو مجھ کو اور الزام دو اپنے آپ کو، نہ میں تمہاری فریاد کو پہنچوں اور نہ تم میری فریاد کو پہنچو ! میں منکر ہوں جو تم نے مجھ کو شریک بنایا تھا اس سے پہلے، البتہ جو ظالم ہیں ان کے لئے ہے عذاب درد ناک۔</p>"
        },
        "23": {
            "verses": {
                "14:23": {
                    "id": 23
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور داخل کئے گئے جو لوگ ایمان لائے تھے اور کام کئے تھے نیک باغوں میں جن کے نیچے بہتی ہیں نہریں ہمیشہ رہیں ان میں اپنے رب کے حکم سے ان کی ملاقات ہے وہاں سلام۔</p>"
        },
        "24": {
            "verses": {
                "14:24": {
                    "id": 24
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو نے نہ دیکھا کیسی بیان کی اللہ نے ایک مثال بات ستھری جیسے ایک درخت ستھرا اس کی جڑ مضبوط ہے اور ٹہنی ہے آسمان میں</p>"
        },
        "25": {
            "verses": {
                "14:25": {
                    "id": 25
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>لاتا ہے پھل اپنا ہر وقت پر اپنے رب کے حکم سے اور بیان کرتا ہے اللہ مثالیں لوگوں کے واسطے تاکہ وہ فکر کریں</p>"
        },
        "26": {
            "verses": {
                "14:26": {
                    "id": 26
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور مثال گندی بات کی جیسے درخت گندا اکھاڑ لیا اس کو زمین کے اوپر سے کچھ نہیں اس کو ٹھہراؤ،</p>"
        },
        "27": {
            "verses": {
                "14:27": {
                    "id": 27
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>مضبوط کرتا ہے اللہ ایمان والوں کو مضبوط بات سے دنیا کی زندگی میں اور آخرت میں بچلا دیتا ہے اللہ بےانصافوں کو اور کرتا ہے اللہ جو چاہے</p>"
        },
