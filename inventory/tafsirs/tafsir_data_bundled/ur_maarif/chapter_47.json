{
    "chapter": 47,
    "verses": {
        "1": {
            "verses": {
                "47:1": {
                    "id": 1
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جو لوگ منکر ہوئے اور روکا اوروں کو اللہ کی راہ سے کھو دئیے اللہ نے ان کے کئے کام</p>"
        },
        "2": {
            "verses": {
                "47:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو یقین لائے اور کئے بھلے کام اور مانا اس کو جو اترا محمد ﷺ پر اور وہی ہے سچا دین ان کے رب کی طرف سے ان پر سے اتاریں ان کی برائیاں اور سنوارا ان کا حال</p>"
        },
        "3": {
            "verses": {
                "47:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ اس لئے کہ جو منکر ہیں وہ چلے جھوٹی بات پر اور جو یقین لائے انہوں نے مانی سچی بات اپنے رب کی طرف سے یوں بتلاتا ہے اللہ لوگوں کو ان کے احوال۔</p>"
        },
        "4": {
            "verses": {
                "47:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو جب تم مقابل ہو منکروں کے تو مارو گردنیں یہاں تک کہ جب خوب قتل کر چکو ان کو تو مظبوط باندھ لو قید پھر یا احسان کیجیو اور یا معاوضہ لیجئیو جب تک کہ رکھ دے لڑائی اپنے ہتھیار۔ یہ سن چکے اور اگر چاہے اللہ تو بدلہ لے ان سے پر جانچنا چاہتا ہے تمہارے ایک سے دوسرے کو اور جو لوگ مارے گئے اللہ کی راہ میں تو نہ ضائع کرے گا وہ ان کے کئے کام</p>"
        },
        "5": {
            "verses": {
                "47:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>ان کو راہ دے گا اور سنوارے گا ان کا حال</h2>"
        },
        "6": {
            "verses": {
                "47:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور داخل کرے گا ان کو بہشت میں جو معلوم کرا دی ہے ان کو</h2>"
        },
        "7": {
            "verses": {
                "47:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے ایمان والو اگر تم مدد کرو گے اللہ کی تو وہ تمہاری مدد کرے گا اور جمادے گا تمہارے پاؤں</p>"
        },
        "8": {
            "verses": {
                "47:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو لوگ کہ منکر ہوئے وہ گرے منہ کے بل اور کھو دئیے ان کے کئے کام</p>"
        },
        "9": {
            "verses": {
                "47:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ اس لئے کہ ان کو پسند نہ ہوا جو اتارا اللہ نے پھر اکارت کر دئیے ان کے کئے کام</p>"
        },
        "10": {
            "verses": {
                "47:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا وہ پھرے نہیں ملک میں کہ دیکھیں کیسا ہوا انجام ان کا جو ان سے پہلے تھے ہلاکی ڈالی اللہ نے ان پر اور منکروں کو ملتی رہتی ہیں ایسی چیزیں</p>"
        },
        "11": {
            "verses": {
                "47:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ اس لئے کہ اللہ رفیق ہے ان کا جو یقین لائے اور یہ کہ جو منکر ہیں ان کا رفیق نہیں کوئی۔</p>"
        },
        "12": {
            "verses": {
                "47:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>مقرر اللہ داخل کرے گا ان کو جو یقین لائے اور کئے بھلے کام باغوں میں جن کے نیچے بہتی ہیں نہریں اور جو لوگ منکر ہیں برت رہے ہیں اور کھاتے ہیں جیسے کہ کھائیں چوپائے اور آگ ہے گھر ان کا</p>"
        },
        "13": {
            "verses": {
                "47:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کتنی تھیں بستیاں جو زیادہ تھیں زور میں اس تیری بستی سے جس نے تجھ کو نکالا ہم نے ان کو غارت کردیا پھر کوئی نہیں ان کا مددگار</p>"
        },
        "14": {
            "verses": {
                "47:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بھلا ایک جو چلتا ہے واضح رستہ پر اپنے رب کے برابر ہے اس کے جس کو بھلا دکھایا اس کا برا کام اور چلتے ہیں اپنی خواہش پر</p>"
        },
        "15": {
            "verses": {
                "47:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>احوال اس بہشت کا جس کا وعدہ ہوا ہے ڈرنے والوں اس میں نہریں ہیں پانی کی جو بو نہیں کر گیا اور نہریں ہیں دودھ کی جس کا مزہ نہیں پھرا اور نہریں ہیں شراب کی جس میں مزہ ہے پینے والوں کے واسطے اور نہریں ہیں شہد کی جھاگ اتارا ہوا اور ان کے لئے وہاں سب طرح کے میوے ہیں اور معافی ہے ان کے رب سے یہ برابر ہے اسکے جو سدا رہے آگ میں اور پلایا جائے ان کو کھولتا پانی تو کاٹ نکالے ان کی آنتیں۔</p>"
        },
        "16": {
            "verses": {
                "47:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور بعض ان میں ہیں کہ کان رکھتے ہیں تیری طرف یہاں تک کہ جب نکلیں تیرے پاس سے کہتے ہیں ان کو جن کو علم ملا ہے کیا کہا تھا اس شخص نے ابھی، یہ وہی ہیں جن کے دلوں پر مہر لگا دی ہے اللہ نے اور چلے ہیں اپنی خواہشوں پر</p>"
        },
        "17": {
            "verses": {
                "47:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو لوگ راہ پر آئے ہیں ان کو اور بڑھ گئی اس سے سوجھ اور ان کو اس سے ملا بچ کر چلنا</p>"
        },
        "18": {
            "verses": {
                "47:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اب یہی انتظار کرتے ہیں قیامت کا کہ آ کھڑی ہو ان پر اچانک سو آ چکی ہیں اس کی نشانیاں پھر کہاں نصیب ہوگا ان کو جب وہ آپہنچے ان پر سمجھ پکڑنا۔</p>"
        },
        "19": {
            "verses": {
                "47:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو تو جان لے کہ کسی کی بندگی نہیں سوائے اللہ کے اور معافی مانگ اپنے گناہ کے واسطے اور ایماندار مردوں اور عورتوں کے لئے اور اللہ کو معلوم ہے بازگشت تمہاری اور گھر تمہارا۔</p>"
        },
        "20": {
            "verses": {
                "47:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہتے ہیں ایمان والے کیوں نہ اتری ایک سورت پھر جب اتری ایک سورت جانچی ہوئی اور ذکر ہوا اسمیں لڑائی کا تو دیکھتا ہے ان کو جن کے دل میں روگ ہے تکتے ہیں تیری طرف جیسے تکتا ہے کوئی بیہوش پڑا ہوا مرنے کے وقت سو خرابی ہے ان کی</p>"
        },
        "21": {
            "verses": {
                "47:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>حکم ماننا اور بھلی بات کہنا پھر جب تاکید ہو کام کی تو اگر سچے رہیں اللہ سے تو ان کا بھلا ہے</p>"
        },
        "22": {
            "verses": {
                "47:22": {
                    "id": 22
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر تم سے یہ بھی توقع ہے کہ اگر تم کو حکومت ملجائے تو خرابی ڈالو ملک میں اور قطع کر اپنی قرابتیں</p>"
        },
        "23": {
            "verses": {
                "47:23": {
                    "id": 23
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ایسے لوگ ہیں جن پر لعنت کی اللہ نے پھر کردیا انکو بہرا اور اندھی کردیں ان کی آنکھیں</p>"
        },
        "24": {
            "verses": {
                "47:24": {
                    "id": 24
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کیا دھیان نہیں کرتے قرآن میں یا دلوں پر لگ رہے ہیں انکے قفل</h2>"
        },
        "25": {
            "verses": {
                "47:25": {
                    "id": 25
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بیشک جو لوگ الٹے پھرگئے اپنی پیٹھ پر بعد اس کے کہ ظاہر ہوچکی ان پر سیدھی راہ شیطان نے بات بنائی انکے دل میں اور دیر کے وعدے کئے</p>"
        },
        "26": {
            "verses": {
                "47:26": {
                    "id": 26
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ اس واسطے کہ انہوں نے کہا ان لوگوں سے جو بیزار ہیں اللہ کی اتاری کتاب سے ہم تمہاری بات بھی مانیں گے بعض کا موں میں اور اللہ جانتا ہے ان کو مشورہ کرنا</p>"
        },
        "27": {
            "verses": {
                "47:27": {
                    "id": 27
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر کیسا ہوگا حال جبکہ فرشتے جان نکالیں گے ان کی مارتے جاتے ہوں انکے منہ پر اور پیٹھ پر</p>"
        },
