            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور جب ماپ کردیں ان کو یا تول کر تو گھٹا کردیں</h2>"
        },
        "4": {
            "verses": {
