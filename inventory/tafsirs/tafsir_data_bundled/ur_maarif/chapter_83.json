            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جب سنائے اس کو ہماری آیتیں کہے نقلیں ہیں پہلوں کی</h2>"
