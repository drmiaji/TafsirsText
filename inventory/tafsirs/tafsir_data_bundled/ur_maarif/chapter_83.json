            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کوئی نہیں وہ اپنے رب سے اس دن روک دیئے جائیں گے</h2>"
