            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور اس کو جھٹلاتا ہے وہی جو جڑھ نکلنے والا گنہگار ہے</h2>"
