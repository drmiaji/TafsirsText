            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جو جھوٹ جانتے ہیں انصاف کے دن کو</h2>"
        },
        "12": {
            "verses": {
                "83:12": {
