            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>ہرگز نہیں بیشک اعمال نامہ گنہگاروں کا سجین میں ہے</h2>"
        },
        "8": {
