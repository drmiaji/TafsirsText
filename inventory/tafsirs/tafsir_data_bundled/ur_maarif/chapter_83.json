            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کوئی نہیں پر زنگ پکڑ گیا ہے ان کے دلوں پر جو وہ کماتے تھے</h2>"
