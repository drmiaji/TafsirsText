            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کیا خیال نہیں رکھتے وہ لوگ کہ ان کو اٹھنا ہے</h2>"
        },
        "5": {
            "verses": {
