            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جس دن کھڑے رہیں لوگ راہ دیکھتے جہان کے مالک کی</h2>"
        },
        "7": {
            "verses": {
