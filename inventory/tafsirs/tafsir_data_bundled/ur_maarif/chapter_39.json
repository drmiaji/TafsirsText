            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر چکھائی ان کو اللہ نے رسوائی دنیا کی زندگی میں اور عذاب آخرت کا تو بہت ہی بڑا ہے اگر ان کو سمجھ ہوتی</p>"
        },
