            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>نہیں بلکہ اللہ ہی کو پوج اور رہ حق ماننے والوں میں</h2>"
        },
        "67": {
            "verses": {
                "39:67": {
                    "id": 67
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
