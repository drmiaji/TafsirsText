            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور پورا ملے ہر جی کو جو اس نے کیا اور اس کو خوب خبر ہے جو کچھ کرتے ہیں</p>"
        },
        "71": {
            "verses": {
                "39:71": {
