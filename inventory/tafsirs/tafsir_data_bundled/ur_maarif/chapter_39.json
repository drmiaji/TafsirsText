            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور قیامت کے دن تو دیکھے ان کو جو جھوٹ بولتے ہیں اللہ پر کہ ان کے منہ ہوں سیاہ کیا نہیں دوزخ میں ٹھکانا غرور والوں کا</p>"
        },
        "61": {
            "verses": {
