            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور حکم ہوچکا تجھ کو اور تجھ سے اگلوں کو کہ اگر تو نے شریک مان لیا تو اکارت جائیں گے تیرے عمل اور تو ہوگا ٹوٹے میں پڑا</p>"
        },
        "66": {
