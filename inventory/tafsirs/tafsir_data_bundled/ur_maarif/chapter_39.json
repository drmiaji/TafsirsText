            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اللہ بنانے والا ہے ہر چیز کا اور وہ ہر چیز کا ذمہ لیتا ہے</h2>"
        },
        "63": {
            "verses": {
                "39:63": {
                    "id": 63
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
