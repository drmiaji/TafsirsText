            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اس کے پاس ہیں کنجیاں آسمانوں کی اور زمین کی اور جو منکر ہوئے اللہ کی باتوں سے وہ لوگ جو ہیں وہی ہیں ٹوٹے میں پڑے</p>"
        },
        "64": {
            "verses": {
