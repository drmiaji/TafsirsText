            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور بچائے گا اللہ ان کو جو ڈرتے رہے ان کے بچاؤ کی جگہ نہ لگے ان کو برائی اور نہ وہ غمگین ہوں۔</p>"
        },
        "62": {
