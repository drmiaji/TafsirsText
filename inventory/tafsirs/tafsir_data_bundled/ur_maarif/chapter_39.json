            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کہہ چکے ہیں یہ بات ان سے اگلے پھر کچھ کام نہ آیا ان کو جو کماتے تھے پھر پڑگئیں ان پر برائیاں جو کمائی تھیں</p>"
        },
