            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ اب اللہ کے سوائے کس کو بتلاتے ہو کہ پوجوں اے نادانو !</p>"
        },
        "65": {
            "verses": {
                "39:65": {
                    "id": 65
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
