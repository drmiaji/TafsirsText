{
    "chapter": 61,
    "verses": {
        "1": {
            "verses": {
                "61:1": {
                    "id": 1
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اللہ کی پاکی بولتا ہے جو کچھ ہے آسمانوں اور جو کچھ ہے زمین میں اور وہی ہے زبردست حکمت والا</p>"
        },
        "2": {
            "verses": {
                "61:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اے ایمان والو ! کیوں کہتے ہو منہ سے جو نہیں کرتے</h2>"
        },
        "3": {
            "verses": {
                "61:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>بڑی بیزاری کی بات ہے اللہ کے یہاں کہ کہو وہ چیز جو نہ کرو</h2>"
        },
        "4": {
            "verses": {
                "61:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اللہ چاہتا ہے ان لوگوں کو جو لڑتے ہیں اس کی راہ میں قطار باندھ کر گویا وہ دیوار ہیں سیسہ پلائی ہوئی</p>"
        },
        "5": {
            "verses": {
                "61:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب کہا موسیٰ نے اپنی قوم کو اے قوم میری کیوں ستاتے ہو مجھ کو اور تم کو معلوم کہ میں اللہ کا بھیجا ہوا آیا ہوں تمہارے پاس پھر جب وہ پھرگئے تو پھیر دیئے اللہ نے ان کے دل اور اللہ راہ نہیں دیتا نافرمان لوگوں کو</p>"
        },
        "6": {
            "verses": {
                "61:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب کہا عیسیٰ مریم کے بیٹے نے اے بنی اسرائیل میں بھیجا ہوا آیا ہوں اللہ کا تمہارے پاس یقین کرنے والا اس پر جو مجھ سے آگے ہے توریت اور خوشخبری سنانے والا ایک رسول کی جو آئے گا میرے بعد اس کا نام ہے احمد پھر جب آیا ان کے پاس کھلی نشانیاں لیکر کہنے لگے یہ جادو ہے صریح</p>"
        },
        "7": {
            "verses": {
                "61:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اس سے زیادہ بےانصاف کون جو باندھے اللہ پر جھوٹ اور اس کو بلاتے ہیں مسلمان ہونے کو اور اللہ راہ نہیں دیتا بےانصاف لوگوں کو</p>"
        },
        "8": {
            "verses": {
                "61:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>چاہتے ہیں کہ بجھا دیں اللہ کی روشنی اپنے منہ سے اور اللہ کو پوری کرنی ہے اپنی روشنی اور پڑے برامانیں منکر</p>"
        },
        "9": {
            "verses": {
                "61:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہی ہے جس نے بھیجا اپنا رسول راہ کی سوجھ دے کر اور سچا دین کہ اس کو اوپر کرے سب دینوں سے اور پڑے برا مانیں شرک کرنے والے۔</p>"
        },
        "10": {
            "verses": {
                "61:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے ایمان والو ! میں بتلاؤں تم کو ایسی سوداگری جو بچائے تم کو ایک عذاب درد ناک سے</p>"
        },
        "11": {
            "verses": {
                "61:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ایمان لاؤ اللہ پر اور اس کے رسول پر اور لڑو اللہ کی راہ میں اپنے مال سے اور اپنی جان سے یہ بہتر ہے تمہارے حق میں اگر تم سمجھ رکھتے ہو</p>"
        },
        "12": {
            "verses": {
                "61:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بخشے گا وہ تمہارے گناہ اور داخل کرے گا تم کو باغوں میں جن کے نیچے بہتی ہیں نہریں اور ستھرے گھروں میں بسنے کے باغوں کے اندر یہ ہے بڑی مراد ملنی</p>"
        },
        "13": {
            "verses": {
                "61:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ایک اور چیز دے جس کو تم چاہتے ہو مدد اللہ کی طرف سے اور فتح جلدی اور خوشی سنا دے ایمان والوں کو</p>"
        },
        "14": {
            "verses": {
                "61:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے ایمان والو ! تم ہوجاؤ مددگار اللہ کے جیسے کہا عیسیٰ مریم کے بیٹے نے اپنے یاروں کو کون ہے کہ مدد کرے میری اللہ کی راہ میں بولے یار ہم ہیں مددگار اللہ کے پھر ایمان لایا ایک فرقہ بنی اسرائیل سے اور منکر ہوا ایک فرقہ پھر قوت دی ہم نے ان کو جو ایمان لائے تھے ان کے دشمنوں پر پھر ہو رہے غالب۔</p>"
        }
    }
}