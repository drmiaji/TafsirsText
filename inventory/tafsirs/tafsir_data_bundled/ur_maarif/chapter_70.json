                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>مانگا ایک مانگنے والے نے عذاب پڑنے والا</h2>"
        },
        "2": {
            "verses": {
                "70:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>منکروں کے واسطے کوئی نہیں اس کو ہٹانے والا</h2>"
        },
        "3": {
            "verses": {
                "70:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>آئے اللہ کی طرف سے جو چڑھتے درجوں والا ہے</h2>"
        },
        "4": {
            "verses": {
                "70:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>چڑھیں گے اس کی طرف فرشتے اور روح اس دن میں جس کا لنباؤ پچاس ہزار برس</p>"
        },
        "5": {
            "verses": {
                "70:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>ہے سو تو صبر کر بھلی طرح کا صبر کرنا</h2>"
        },
        "6": {
            "verses": {
                "70:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>وہ دیکھتے ہیں اس کو دور</h2>"
        },
        "7": {
            "verses": {
                "70:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور ہم دیکھتے ہیں اس کو نزدیک</h2>"
        },
        "8": {
            "verses": {
                "70:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جس دن ہوگا آسمان جیسے تانبا پگھلا ہوا</h2>"
        },
        "9": {
            "verses": {
                "70:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور ہونگے پہاڑ جیسے اون رنگی ہوئی</h2>"
        },
        "10": {
            "verses": {
                "70:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور نہ پوچھے گا دوستدار دوستدار کو</h2>"
        },
        "11": {
            "verses": {
                "70:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سب نظر آجائیں گے ان کو چاہئے گا گنہگار کسی طرح چھڑوائی میں دے کر اس دن کے عذاب سے اپنے بیٹے کو</p>"
        },
        "12": {
            "verses": {
                "70:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور اپنی ساتھ والی کو اور اپنے بھائی کو</h2>"
        },
        "13": {
            "verses": {
                "70:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور اپنے گھرانے کو جس میں رہتا تھا</h2>"
        },
        "14": {
            "verses": {
                "70:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
