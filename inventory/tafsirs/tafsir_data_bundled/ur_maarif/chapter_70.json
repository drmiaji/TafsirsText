            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور جن کے مال میں حصہ مقرر ہے</h2>"
        },
        "25": {
            "verses": {
                "70:25": {
                    "id": 25
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>مانگنے والے اور ہارے ہوئے کا</h2>"
        },
        "26": {
            "verses": {
                "70:26": {
                    "id": 26
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور جو یقین کرتے ہیں انصاف کے دن پر</h2>"
        },
        "27": {
            "verses": {
                "70:27": {
                    "id": 27
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور جو لوگ کہ اپنے رب کے عذاب سے ڈرتے ہیں</h2>"
        },
        "28": {
            "verses": {
                "70:28": {
                    "id": 28
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>بیشک ان کے رب کے عذاب سے کسی کو نڈر نہ ہونا چاہئے</h2>"
        },
        "29": {
            "verses": {
                "70:29": {
                    "id": 29
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور جو اپنی شہوت کی جگہ کو تھامتے ہیں</h2>"
        },
        "30": {
            "verses": {
                "70:30": {
                    "id": 30
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>مگر اپنی جوروؤں سے یا اپنے ہاتھ کے مال سے سو ان پر نہیں کچھ الاہنا</p>"
        },
        "31": {
            "verses": {
                "70:31": {
                    "id": 31
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر جو کوئی ڈھونڈے اس کے سوائے سو وہی ہیں حد سے بڑھنے والے</h2>"
        },
        "32": {
            "verses": {
                "70:32": {
                    "id": 32
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور جو لوگ کہ اپنی امانتوں اور اپنے قول کو نباہتے ہیں</h2>"
        },
        "33": {
            "verses": {
                "70:33": {
                    "id": 33
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور جو اپنی گواہیوں پر سیدھے ہیں</h2>"
        },
        "34": {
            "verses": {
                "70:34": {
                    "id": 34
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور جو اپنی نماز سے خبر دار ہیں</h2>"
        },
        "35": {
            "verses": {
                "70:35": {
                    "id": 35
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>وہی لوگ ہیں باغوں میں عزت سے</h2>"
        },
        "36": {
            "verses": {
                "70:36": {
                    "id": 36
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر کیا ہوا ہے منکروں کو تیری طرف دوڑتے ہوئے آتے ہیں</h2>"
        },
        "37": {
            "verses": {
                "70:37": {
                    "id": 37
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>داہنے سے اور بائیں سے غول کے غول</h2>"
        },
        "38": {
            "verses": {
                "70:38": {
                    "id": 38
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا طمع رکھتا ہے ہر ایک شخص ان میں کہ داخل ہوجائے نعمت کے باغ میں</p>"
        },
        "39": {
            "verses": {
                "70:39": {
                    "id": 39
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>ہرگز نہیں ہم نے ان کو بنایا ہے جس سے وہ بھی جانتے ہیں</h2>"
        },
        "40": {
            "verses": {
                "70:40": {
                    "id": 40
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو میں قسم کھاتا ہوں مشرقوں اور مغربوں کے مالک کی تحقیق ہم کرسکتے ہیں</p>"
        },
        "41": {
            "verses": {
                "70:41": {
                    "id": 41
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کہ بدل کرلے آئیں ان سے بہتر اور ہمارے قابو سے نکل نہ جائیں گے</p>"
        },
        "42": {
            "verses": {
                "70:42": {
                    "id": 42
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو چھوڑ دے ان کو کہ باتیں بنائیں اور کھیلا کریں یہاں تک کہ مل جائیں اپنے اس دن سے جس کا ان سے وعدہ ہے</p>"
        },
