            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور جتنے زمین پر ہیں سب کو پھر اپنے آپ کو بچا لے</h2>"
        },
        "15": {
            "verses": {
                "70:15": {
                    "id": 15
                }
