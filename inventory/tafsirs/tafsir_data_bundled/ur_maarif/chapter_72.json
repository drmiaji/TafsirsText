{
    "chapter": 72,
    "verses": {
        "1": {
            "verses": {
                "72:1": {
                    "id": 1
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ مجھ کو حکم آیا کہ سن گئے کتنے لوگ جنوں کے پھر کہنے لگے ہم نے سنا ہے کہ ایک قرآن عجیب</p>"
        },
        "2": {
            "verses": {
                "72:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کہ سمجھاتا ہے نیک راہ سو ہم نے اس پر یقین لائے اور ہرگز نہ شریک بتلائیں گے ہم اپنے رب کا کسی کو</p>"
        },
        "3": {
            "verses": {
                "72:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور یہ کہ اونچی ہے شان ہمارے رب کی نہیں رکھی اس نے جورو نہ بیٹا</p>"
        },
        "4": {
            "verses": {
                "72:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور یہ کہ ہم میں کا بیوقوف اللہ پر بڑھا کر باتیں کہا کرتا تھا</p>"
        },
        "5": {
            "verses": {
                "72:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور یہ کہ ہم کو خیال تھا کہ ہرگز نہ بولیں گے آدمی اور جن اللہ پر جھوٹ</p>"
        },
        "6": {
            "verses": {
                "72:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور یہ کہ تھے کتنے مرد آدمیوں میں کے پناہ پکڑتے تھے کتنے مردوں کی جنوں میں کے پھر تو وہ اور زیادہ</p>"
        },
        "7": {
            "verses": {
                "72:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سر چڑھنے لگے اور یہ کہ ان کو بھی خیال تھا جیسا تم کو خیال تھا کہ ہرگز نہ اٹھائے گا اللہ کسی کو</p>"
        },
        "8": {
            "verses": {
                "72:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور یہ کہ ہم نے ٹٹول دیکھا آسمان کو پھر پایا اس کو بھر رہے ہیں اس میں چوکیدار سخت اور انگارے</p>"
        },
        "9": {
            "verses": {
                "72:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور یہ کہ ہم بیٹھا کرتے تھے ٹھکانوں میں سننے کے واسطے پھر جو کوئی اب سننا چاہئے وہ پائے اپنے واسطے ایک انگار گھات میں</p>"
        },
        "10": {
            "verses": {
                "72:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور یہ کہ ہم نہیں جانتے کہ برا ارادہ ٹھہرا ہے زمین کے رہنے والوں پر یا چاہا ہے ان کے حق میں ان کے رب نے راہ پر لانا</p>"
        },
        "11": {
            "verses": {
                "72:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور یہ کہ کوئی ہم میں نیک ہیں اور کوئی اس کے سوائے ہم تھے کئی راہ پر پھٹے ہوئے</p>"
        },
        "12": {
            "verses": {
                "72:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور یہ کہ ہمارے خیال میں آ گیا کہ ہم چھپ نہ جائیں گے اللہ سے زمین میں اور نہ تھکا دیں گے اس کو بھاگ کر</p>"
        },
        "13": {
            "verses": {
                "72:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور یہ کہ جب ہم نے سن لی راہ کی بات تو ہم نے اس کو مان لیا پھر جو کوئی یقین لائے گا اپنے رب پر سو وہ نہ ڈرے گا نقصان سے اور نہ زبردستی سے</p>"
        },
        "14": {
            "verses": {
                "72:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور یہ کہ کچھ ہم میں حکمبردار ہیں اور کچھ ہیں بےانصاف سو جو لوگ حکم میں آگئے تو انہوں نے اٹکل کرلیا نیک راہ کو</p>"
        },
        "15": {
            "verses": {
                "72:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور جو بےانصاف ہیں وہ ہوئے دوزخ کے ایندھن</h2>"
        },
        "16": {
            "verses": {
                "72:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور یہ حکم آیا کہ اگر لوگ سیدھے رہتے راہ پر تو ہم پلاتے ان کو پانی بھر کر</p>"
        },
        "17": {
            "verses": {
                "72:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تاکہ ان کو جانچیں اس میں اور جو کوئی منہ موڑے اپنے رب کی یاد سے وہ ڈالا دے گا اس کو چڑھتے عذاب میں</p>"
        },
        "18": {
            "verses": {
                "72:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور یہ کہ مسجدیں اللہ کی یاد کے واسطے ہیں سو مت پکارو اللہ کے ساتھ کسی کو</p>"
        },
        "19": {
            "verses": {
                "72:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور یہ کہ جب کھڑا ہو اللہ کا بندہ کہ اس کو پکارے لوگوں کا بندھنے لگتا ہے اس پر ٹھٹھ</p>"
        },
        "20": {
            "verses": {
                "72:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>تو کہہ میں تو پکارتا ہوں بس اپنے رب کو اور شریک نہیں کرتا</h2>"
        },
        "21": {
            "verses": {
                "72:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اس کا کسی کو تو کہہ میرے اختیار میں نہیں</h2>"
        },
        "22": {
            "verses": {
                "72:22": {
                    "id": 22
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تمہارا برا اور نہ راہ پر لانا تو کہہ مجھ کو نہ بچائے گا اللہ کے ہاتھ سے کوئی اور نہ پاؤں گا اس کے سوائے کہیں سرک رہنے کو جگہ</p>"
        },
        "23": {
            "verses": {
                "72:23": {
                    "id": 23
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>مگر پہنچانا ہے اللہ کی طرف سے اور اس کے پیغام لانے اور جو کوئی حکم نہ مانے اللہ کا اور اس کے رسول کا سو اس کے لئے آگ ہے دوزخ کی رہا کریں اس میں ہمیشہ</p>"
        },
        "24": {
            "verses": {
                "72:24": {
                    "id": 24
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہاں تک کہ جب دیکھیں گے جو کچھ ان سے وعدہ ہوا تب جان لیں گے کس کے مددگار کمزور ہیں اور گنتی میں تھوڑے</p>"
        },
        "25": {
            "verses": {
                "72:25": {
                    "id": 25
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ میں نہیں جانتا کہ نزدیک ہے جس چیز کا تم سے وعدہ ہوا ہے یا کر دے اس کو میرا رب ایک مدت کے بعد</p>"
        },
        "26": {
            "verses": {
                "72:26": {
                    "id": 26
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جاننے والا بھید کا سو نہیں خبر دیتا اپنے بھید کی کسی کو</h2>"
        },
        "27": {
            "verses": {
                "72:27": {
                    "id": 27
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>مگر جو پسند کرلیا کسی رسول کو تو وہ چلاتا ہے اس کے آگے اور پیچھے چوکیدار</p>"
        },
        "28": {
            "verses": {
                "72:28": {
                    "id": 28
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تاکہ جانے کہ انہوں نے پہنچائے پیغام اپنے رب کے اور قابو میں رکھا ہے جو ان کے پاس ہے اور گن لی ہے ہر چیز کی گنتی۔</p>"
        }
    }
}