{
    "chapter": 67,
    "verses": {
        "1": {
            "verses": {
                "67:1": {
                    "id": 1
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بڑی برکت ہے اس کی جس کے ہاتھ میں ہے راج اور وہ سب کچھ کرسکتا ہے</p>"
        },
        "2": {
            "verses": {
                "67:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جس نے بنایا مرنا اور جینا تاکہ تم کو جانچے کون تم میں اچھا کرتا ہے کام اور وہ زبردست ہے بخشنے والا</p>"
        },
        "3": {
            "verses": {
                "67:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جس نے بنائے سات آسمان تہ پر تہ کیا دیکھتا ہے تو رحمن کے بنانے میں کچھ فرق پھر دوبارہ نگاہ کر کہیں نظر آتی ہے تجھ کو دراڑ</p>"
        },
        "4": {
            "verses": {
                "67:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر لوٹا کر نگاہ کردو دو بار لوٹ آئے گی تیرے پاس تیری نگاہ رد ہو کر تھک کر</p>"
        },
        "5": {
            "verses": {
                "67:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ہم نے رونق دی سب سے ورلے آسمان کو چراغوں سے اور ان سے کر رکھی ہے ہم نے پھینک مار شیطانوں کے واسطے اور رکھا ہے اس کے واسطے عذاب دہکتی آگ کا</p>"
        },
        "6": {
            "verses": {
                "67:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو لوگ منکر ہوئے اپنے رب سے ان کے واسطے ہے عذاب دوزخ کا اور بری جگہ جا پہنچے</p>"
        },
        "7": {
            "verses": {
                "67:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جب اس میں ڈالے جائیں گے سنیں گے اس کا دہاڑنا اور وہ اچھل رہی ہوگی</p>"
        },
        "8": {
            "verses": {
                "67:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ایسا لگتا ہے کہ پھٹ پڑے گی جوش سے جس وقت پڑے اس میں ایک گروہ پوچھیں ان سے دوزخ کے داروغہ کیا نہ پہنچا تھا تمہارے پاس کوئی ڈر سنانے والا</p>"
        },
        "9": {
            "verses": {
                "67:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ بولیں کیوں نہیں ہمارے پاس پہنچا تھا ڈر سنانے والا پھر ہم نے جھٹلایا اور کہا نہیں اتاری اللہ نے کوئی چیز تم تو پڑے ہوئے ہو بڑے بہکاوے میں</p>"
        },
        "10": {
            "verses": {
                "67:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہیں گے اگر ہم ہوتے سنتے یا سمجھتے تو نہ ہوتے دوزخ والوں میں</p>"
        },
        "11": {
            "verses": {
                "67:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>سو قائل ہوگئے اپنے گناہ کے اب دفع ہوجائیں دوزخ والے</h2>"
        },
        "12": {
            "verses": {
                "67:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جو لوگ ڈرتے ہیں اپنے رب سے بن دیکھے ان کے لئے معافی ہے اور ثواب بڑا</p>"
        },
        "13": {
            "verses": {
                "67:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور تم چھپا کر کہو اپنی بات یا کھول کر اور خوب جانتا ہے جیوں کے بھید</p>"
        },
        "14": {
            "verses": {
                "67:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بھلا وہ نہ جانے جس نے بنایا اور وہی ہے بھید جاننے والا خبر دار</p>"
        },
        "15": {
            "verses": {
                "67:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہی ہے جس نے کیا تمہارے آگے زمین کو پست اب چلو پھر و اس کے کندھوں پر اور کھاؤ کچھ اس کی دی ہوئی روزی اور اسی کی طرف جی اٹھنا ہے</p>"
        },
        "16": {
            "verses": {
                "67:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا تم نڈر ہوگئے اس سے جو آسمان میں ہے اس سے کہ دھنسا دے تم کو زمین میں پھر تبھی وہ لرزنے لگے</p>"
        },
        "17": {
            "verses": {
                "67:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یا نڈر ہوگئے ہو اس سے جو آسمان میں ہے اس بات سے کہ برسا دے تم کو مینہ پتھروں کا سو جان لو گے کیسا ہے میرا ڈرانا</p>"
        },
        "18": {
            "verses": {
                "67:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور جھٹلا چکے ہیں جو ان سے پہلے تھے پھر کیسا ہوا میرا انکار</h2>"
        },
        "19": {
            "verses": {
                "67:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کیا نہیں دیکھتے ہو اڑتے جانوروں کو اپنے اوپر پر کھولے ہوئے اور پر جھپکتے ہوئے ان کو کوئی نہیں تھام رہا رحمن کے سوائے اس کی نگاہ میں ہے ہر چیز</p>"
        },
        "20": {
            "verses": {
                "67:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بھلا وہ کون ہے جو فوج ہے تمہاری مدد کرے تمہاری رحمن کے سوائے منکر پڑے ہیں برے بہکائے میں</p>"
        },
        "21": {
            "verses": {
                "67:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بھلا وہ کون ہے جو روزی دے تم کو اگر وہ رکھ چھوڑے اپنی روزی کوئی نہیں پر اڑ رہے ہیں شرارت اور بدکنے پر</p>"
        },
        "22": {
            "verses": {
                "67:22": {
                    "id": 22
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بھلا ایک جو چلے اوندھا اپنے منہ کے بل وہ سیدھی راہ پائے یا وہ شخص جو چلے سیدھا ایک سیدھی راہ پر</p>"
        },
        "23": {
            "verses": {
                "67:23": {
                    "id": 23
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ وہی ہے جس نے تم کو بنا کھڑا کیا اور بنا دیئے تمہارے واسطے کان اور آنکھیں اور دل تم بہت تھوڑا حق مانتے ہو</p>"
        },
        "24": {
            "verses": {
                "67:24": {
                    "id": 24
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ وہی ہے جس نے بکھیر دیا تم کو زمین میں اور اسی کی طرف اکٹھے کئے جاؤ گے</p>"
        },
        "25": {
            "verses": {
                "67:25": {
                    "id": 25
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور کہتے ہیں کب ہوگا یہ وعدہ اگر تم سچے ہو</h2>"
        },
        "26": {
            "verses": {
                "67:26": {
                    "id": 26
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ خبر تو ہے اللہ ہی کے پاس اور میرا کام تو یہی ڈر سنا دینا ہے</p>"
        },
        "27": {
            "verses": {
                "67:27": {
                    "id": 27
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کھول کر پھر جب دیکھیں گے کہ وہ پاس آ لگا تو بگڑ جائیں گے منہ منکروں کے اور کہے گا یہی ہے جس کو تم مانگتے تھے</p>"
        },
        "28": {
            "verses": {
                "67:28": {
                    "id": 28
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ بھلا دیکھو تو اگر ہلاک کر دے مجھ کو اللہ اور میرے ساتھ والوں کو یا ہم پر رحم کرے پھر وہ کون ہے جو بچائے منکروں کو عذاب درد ناک سے</p>"
        },
        "29": {
            "verses": {
                "67:29": {
                    "id": 29
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ وہی رحمن ہے ہم نے اس کو مانا اور اسی پر بھروسہ کیا سو اب تم جان لوگے کون پڑا ہے صریح بہکائے میں</p>"
        },
        "30": {
            "verses": {
                "67:30": {
                    "id": 30
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ بھلا دیکھو تو اگر ہوجائے صبح کو پانی تمہارا خشک پھر کون ہے جو لائے تمہارے پاس پانی نتھرا۔</p>"
        }
    }
}