                "language_name": "english"
            },
            "text": "<p>لئے پھریں گے ان کے پاس رکابیاں سونے کی اور آبخورے اور وہاں ہے جو دل چاہے اور جس سے آنکھیں آرام پائیں اور تم ان میں ہمیشہ رہو گے</p>"
        },
        "72": {
            "verses": {
                "43:72": {
                    "id": 72
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور یہ وہی بہشت ہے جو میراث پائی تم نے بدلے میں ان کاموں کے جو کرتے تھے</p>"
        },
        "73": {
            "verses": {
                "43:73": {
                    "id": 73
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>تمہارے واسطے ان میں بہت میوے ہیں ان میں سے کھاتے رہو</h2>"
        },
        "74": {
            "verses": {
                "43:74": {
                    "id": 74
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>البتہ جو لوگ کہ گنہگار ہیں وہ دوزخ کے عذاب میں ہمیشہ رہنے والے ہیں</p>"
        },
        "75": {
            "verses": {
                "43:75": {
                    "id": 75
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>نہ ہلکا ہوتا ہے ان پر سے اور وہ اسی میں پڑے ہیں آس ٹوٹے</h2>"
        },
        "76": {
            "verses": {
                "43:76": {
                    "id": 76
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور ہم نے ان پر ظلم نہیں کیا لیکن تھے وہی بےانصاف</h2>"
        },
        "77": {
            "verses": {
                "43:77": {
                    "id": 77
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور پکاریں گے اے مالک کہیں ہم پر فیصل کرچکے تیرا رب وہ کہے گا تم کو ہمیشہ رہنا ہے۔</p>"
        },
        "78": {
            "verses": {
                "43:78": {
                    "id": 78
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ہم لائے ہیں تمہارے پاس سچا دین پر تم بہت لوگ سچی بات سے برا مانتے ہو</p>"
        },
        "79": {
            "verses": {
                "43:79": {
                    "id": 79
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کیا انہوں نے ٹھہرائی ہے ایک بات تو ہم بھی کچھ ٹھہرائیں گے</h2>"
        },
        "80": {
            "verses": {
                "43:80": {
                    "id": 80
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا خیال رکھتے ہیں کہ ہم نہیں جانتے ان کا بھید اور ان کا مشورہ کیوں نہیں اور ہمارے بھیجے ہوئے ان کے پاس لکھتے رہتے ہیں</p>"
        },
        "81": {
            "verses": {
                "43:81": {
                    "id": 81
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>تو کہہ اگر ہو رحمن کے واسطے اولاد تو میں سب سے پہلے پوجوں</h2>"
        },
        "82": {
            "verses": {
                "43:82": {
                    "id": 82
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پاک ذات ہے وہ رب آسمانوں کا اور زمین کا صاحب عرش کا ان باتوں سے جو یہ بیان کرتے ہیں</p>"
        },
        "83": {
            "verses": {
                "43:83": {
                    "id": 83
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اب چھوڑ دے ان کو بک بک کریں اور کھیلیں یہاں تک کہ ملیں اپنے اس دن سے جس کا ان کو وعدہ دیا ہے</p>"
        },
        "84": {
            "verses": {
                "43:84": {
                    "id": 84
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور وہی ہے جس کی بندگی ہے آسمان میں اور اس کی بندگی ہے زمین میں اور وہی ہے حکمت والا سب سے خبردار اور بڑی برکت ہے</p>"
        },
        "85": {
            "verses": {
                "43:85": {
                    "id": 85
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اس کی جس کا راج ہے آسمانوں میں اور زمین میں اور جو کچھ ان کے بیچ میں ہے اور اسی کے پاس ہے خبر قیامت کی اور اسی تک پھر کر پہنچ جاؤ گے</p>"
        },
        "86": {
            "verses": {
                "43:86": {
                    "id": 86
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اختیار نہیں رکھتے وہ لوگ جن کو یہ پکارتے ہیں سفارش کا مگر جس نے گواہی دی سچی اور ان کو خبر تھی</p>"
        },
        "87": {
            "verses": {
                "43:87": {
                    "id": 87
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر تو ان سے پوچھے کہ ان کو کس نے بنایا تو کہیں گے اللہ نے پھر کہاں سے الٹ جاتے ہیں</p>"
        },
        "88": {
            "verses": {
                "43:88": {
                    "id": 88
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>قسم ہے رسول کے اس کہنے کی کہ اے رب یہ لوگ ہیں کہ یقین نہیں لاتے</p>"
        },
        "89": {
            "verses": {
                "43:89": {
                    "id": 89
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو تو منہ پھیرلے ان کی طرف سے اور کہہ سلام ہے اب آخر کو معلوم کرلیں گے۔</p>"
        }
    }
}