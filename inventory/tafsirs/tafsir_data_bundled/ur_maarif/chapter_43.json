            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>حم</p>"
        },
        "2": {
            "verses": {
                "43:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>قسم ہے اس کتاب واضح کی</h2>"
        },
        "3": {
            "verses": {
                "43:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>ہم نے رکھا اس کو قرآن عربی زبان کا تاکہ تم سمجھو</h2>"
        },
        "4": {
            "verses": {
                "43:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور تحقیق یہ قرآن لوح محفوظ میں ہمارے پاس ہے برتر مستحکم</h2>"
        },
        "5": {
            "verses": {
                "43:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا پھیر دیں گے ہم تمہاری طرف سے یہ کتاب موڑ کر اس سبب سے کہ تم ہو ایسے لوگ کہ حد پر نہیں رہتے</p>"
        },
        "6": {
            "verses": {
                "43:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور بہت بھیجے ہیں ہم نے نبی پہلوں میں</h2>"
        },
        "7": {
            "verses": {
                "43:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور نہیں آتا لوگوں کے پاس کوئی پیغام لانے والا جس سے ٹھٹھا نہیں کرتے</p>"
        },
        "8": {
            "verses": {
                "43:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر برباد کر ڈالے ہم نے ان سے سخت زور والے اور چلی آئی ہے مثال پہلوں کی۔</p>"
        },
        "9": {
            "verses": {
                "43:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر تو ان سے پوچھے کس نے بنائے آسمان اور زمین تو کہیں بنائے اس زبردست خبردار نے</p>"
        },
        "10": {
            "verses": {
                "43:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہی ہے جس نے بنادیا تمہارے لئے زمین کو بچھونا اور رکھ دیں تمہارے واسطے اس میں راہیں تاکہ تم راہ پاؤ</p>"
        },
        "11": {
            "verses": {
                "43:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جس نے اتارا آسمان سے پانی ماپ کر پھر ابھار کھڑا کیا ہم نے اس سے ایک دیس مردہ کو اسی طرح تم کو بھی نکالیں گے</p>"
        },
        "12": {
            "verses": {
                "43:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جس نے بنائے سب چیز کے جوڑے اور بنادیا تمہارے واسطے کشتیوں اور چوپایوں کو جس پر تم سوار ہوتے ہو</p>"
        },
        "13": {
            "verses": {
                "43:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تاکہ چڑھ بیٹھو تم اس کی پیٹھ پر پھر یاد کرو اپنے رب کا احسان جب بیٹھ چکو اس پر اور کہو پاک ذات ہے وہ جس نے بس میں کردیا ہمارے اس کو اور ہم نہ تھے اس کو قابو میں لا سکتے</p>"
        },
        "14": {
            "verses": {
                "43:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور ہم کو اپنے رب کی طرف پھرجانا ہے</h2>"
        },
        "15": {
            "verses": {
                "43:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ٹھہرائی ہے انہوں نے حق تعالیٰ کے واسطے اولاد اس کے بندوں میں سے تحقیق انسان بڑا ناشکرا ہے صریح</p>"
        },
        "16": {
            "verses": {
                "43:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا اس نے رکھ لیں اپنی مخلوقات میں سے بیٹیاں اور تم کو دیدیئے چن کر بیٹے</p>"
        },
        "17": {
            "verses": {
                "43:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب ان میں کسی کو خوشخبری ملے اس چیز کی جس کو رحمن کے نام لگایا تو سارے دن رہے منہ اس کا سیاہ اور وہ دل میں گھٹ رہا ہے</p>"
        },
        "18": {
            "verses": {
                "43:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا ایسا شخص کہ پرورش پاتا ہے زیور میں اور وہ جھگڑے میں بات نہ کہہ سکے</p>"
        },
        "19": {
            "verses": {
                "43:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ٹھہرایا انہوں نے فرشتوں کو جو بندے ہیں رحمن کے عورتیں کیا دیکھتے تھے ان کا بننا اب لکھ رکھیں گے ان کی گواہی اور ان سے پوچھ ہوگی</p>"
        },
        "20": {
            "verses": {
                "43:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہتے ہیں اگر چاہتا رحمن تو ہم نہ پوجتے ان کو کچھ خبر نہیں ان کو اس کی یہ سب اٹکلیں دوڑاتے ہیں</p>"
        },
        "21": {
            "verses": {
                "43:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا ہم نے کوئی کتاب دی ہے ان کو اس سے پہلے سو انہوں نے اس کو مضبوط پکڑ رکھا ہے</p>"
        },
        "22": {
            "verses": {
                "43:22": {
                    "id": 22
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>بلکہ کہتے ہیں ہم نے پایا اپنے باپ دادوں کو ایک راہ پر</h2>"
        },
        "23": {
            "verses": {
                "43:23": {
                    "id": 23
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ہم انہی کے قدموں پر ہیں راہ پائے ہوئے اور اسی طرح جس کسی کو بھیجا ہم نے تجھ سے پہلے ڈر سنانے والا کسی گاؤں میں سو کہنے لگے وہاں کے خوشحال لوگ ہم نے تو پایا اپنے باپ دادوں کو ایک راہ پر اور ہم انہی کے قدموں پر چلتے ہیں</p>"
        },
        "24": {
            "verses": {
                "43:24": {
                    "id": 24
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ بولا اور جو میں لادوں تم کو اس سے زیادہ سوجھ کی راہ جس پر تم نے پایا اپنے باپ دادوں کو تو یہی کہنے لگے ہم تمہارا لایا ہوا نہیں مانیں گے</p>"
        },
        "25": {
            "verses": {
                "43:25": {
                    "id": 25
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر ہم نے ان سے بدلہ لیا سو دیکھ لے کیسا ہوا انجام جھٹلانے والوں کا۔</p>"
        },
        "26": {
            "verses": {
                "43:26": {
                    "id": 26
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب کہا ابراہیم نے اپنے باپ کو اور اس کی قوم کو میں الگ ہوں ان چیزوں سے جن کو تم پوجتے ہو</p>"
        },
        "27": {
            "verses": {
                "43:27": {
                    "id": 27
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>مگر جس نے مجھ کو بنایا سو وہ مجھ کو راہ سمجھائے گا</h2>"
        },
        "28": {
            "verses": {
                "43:28": {
                    "id": 28
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور یہی بات پیچھے چھوڑ گیا اپنی اولاد میں تاکہ وہ رجوع رہیں</h2>"
        },
        "29": {
            "verses": {
                "43:29": {
                    "id": 29
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کوئی نہیں پر میں نے برتنے دیا ان کو اور ان کے باپ دادوں کو یہاں تک کہ پہنچا ان کے پاس دین سچا اور رسول کھول کر سنا دینے والا</p>"
        },
        "30": {
            "verses": {
                "43:30": {
                    "id": 30
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب پہنچا ان کے پاس سچا دین کہنے لگے یہ جادو ہے اور ہم اس کو نہ مانیں گے۔</p>"
        },
        "31": {
            "verses": {
                "43:31": {
                    "id": 31
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہتے ہیں کیوں نہ اترا یہ قرآن کسی بڑے مرد پر ان دونوں بستیوں میں کے</p>"
        },
        "32": {
            "verses": {
                "43:32": {
                    "id": 32
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا وہ بانٹتے ہیں تیرے رب کی رحمت کو ہم نے بانٹ دی ہے ان میں روزی ان کی دنیا کی زندگانی میں اور بلند کردیئے درجے بعض کے بعض پر کہ ٹھہراتا ہے ایک دوسرے کو خدمت گار اور تیرے رب کی رحمت بہتر ہے ان چیزوں سے جو سمیٹتے ہیں۔</p>"
        },
        "33": {
            "verses": {
                "43:33": {
                    "id": 33
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر یہ بات نہ ہوتی کہ سب لوگ ہوجائیں ایک دین پر تو ہم دیتے ان لوگوں کو جو منکر ہیں رحمن سے ان کے گھروں کے واسطے چھت چاندی کی اور سیڑھیاں جن پر چڑھیں</p>"
        },
        "34": {
            "verses": {
                "43:34": {
                    "id": 34
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ان کے گھروں کے واسطے دروازے اور تخت جن پر تکیہ لگا کر بیٹھیں</p>"
        },
        "35": {
            "verses": {
                "43:35": {
                    "id": 35
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور سونے کے اور یہ سب کچھ نہیں ہے مگر برتنا دنیا کی زندگی کا اور آخرت تیرے رب کے یہاں انہی کے لئے ہے جو ڈرتے ہیں۔</p>"
        },
        "36": {
            "verses": {
                "43:36": {
                    "id": 36
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو کوئی آنکھیں چرائے رحمن کی یاد سے ہم اس پر مقرر کردیں ایک شیطان پھر وہ رہے اس کا ساتھی</p>"
        },
        "37": {
            "verses": {
                "43:37": {
                    "id": 37
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور وہ ان کو روکتے رہتے ہیں راہ سے اور یہ سمجھتے ہیں کہ ہم راہ پر ہیں</p>"
        },
        "38": {
            "verses": {
                "43:38": {
                    "id": 38
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہاں تک کہ جب آئے ہمارے پاس کہے کسی طرح مجھ میں اور تجھ میں فرق ہو مشرق مغرب کا سا کہ کیا برا ساتھی ہے</p>"
        },
        "39": {
            "verses": {
                "43:39": {
                    "id": 39
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کچھ فائدہ نہیں تم کو آج کے دن جبکہ تم ظالم ٹھہر چکے اس بات سے کہ تم عذاب میں شامل ہو</p>"
        },
        "40": {
            "verses": {
                "43:40": {
                    "id": 40
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو کیا تو سنائے گا بہروں کو یا سمجھائے گا اندھوں کو اور صریح غلطی میں بھٹکتوں کو</p>"
        },
        "41": {
            "verses": {
                "43:41": {
                    "id": 41
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر اگر کبھی ہم تجھ کو یہاں سے لے جائیں تو ہم کو ان سے بدلہ لینا ہے</p>"
        },
        "42": {
            "verses": {
                "43:42": {
                    "id": 42
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یا تجھ کو دکھا دیں جو ان سے وعدہ ٹھہرایا ہے تو یہ ہمارے بس میں ہیں</p>"
        },
        "43": {
            "verses": {
                "43:43": {
                    "id": 43
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو تو مضبوط پکڑے رہ اسی کو جو تجھ کو حکم پہنچا تو ہے بیشک سیدھی راہ پر</p>"
        },
        "44": {
            "verses": {
                "43:44": {
                    "id": 44
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور یہ مذکور رہے گا تیرا اور تیری قوم کا اور آگے تم سے پوچھ ہوگی</p>"
        },
        "45": {
            "verses": {
                "43:45": {
                    "id": 45
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور پوچھ دیکھ جو رسول بھیجے ہم نے تجھ سے پہلے کبھی ہم نے رکھے ہیں رحمن کے سوائے اور حاکم کہ پوجے جائیں۔</p>"
        },
        "46": {
            "verses": {
                "43:46": {
                    "id": 46
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ہم نے بھیجا موسیٰ کو اپنی نشانیاں دے کر فرعون اور اس کے سرداروں کے پاس تو کہا میں بھیجا ہوا ہوں جہان کے رب کا</p>"
        },
        "47": {
            "verses": {
                "43:47": {
                    "id": 47
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر جب لایا ان کے پاس ہماری نشانیاں وہ تو لگے ان پر ہنسنے</h2>"
        },
        "48": {
            "verses": {
                "43:48": {
                    "id": 48
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو دکھلاتے گئے ہم ان کو نشانی سو پہلی سے بڑی اور پکڑا ہم نے ان کو تکلیف میں تاکہ وہ باز آئیں</p>"
        },
        "49": {
            "verses": {
                "43:49": {
                    "id": 49
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہنے لگے اے جادوگر پکار ہمارے واسطے اپنے رب کو جیسا سکھلا رکھا ہے تجھ کو ہم ضرور راہ پر آجائیں گے</p>"
        },
        "50": {
            "verses": {
                "43:50": {
                    "id": 50
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر جب اٹھا لی ہم نے ان پر سے تکلیف تبھی وہ وعدہ توڑ ڈالتے</h2>"
        },
        "51": {
            "verses": {
                "43:51": {
                    "id": 51
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور پکارا فرعون نے اپنی قوم میں بولا اے میری قوم بھلا میرے ہاتھ میں نہیں حکومت مصر کی اور یہ نہریں چل رہی ہیں میرے محل کے نیچے کیا تم نہیں دیکھتے</p>"
        },
        "52": {
            "verses": {
                "43:52": {
                    "id": 52
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بھلا میں ہوں بہتر اس شخص سے جس کو کچھ عزت نہیں اور صاف نہیں بول سکتا</p>"
        },
        "53": {
            "verses": {
                "43:53": {
                    "id": 53
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر کیوں نہ آ پڑے اس پر کنگن سونے کے یا آتے اس کے ساتھ فرشتے پرا باندھ کر</p>"
        },
        "54": {
            "verses": {
                "43:54": {
                    "id": 54
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر عقل کھو دی اپنی قوم کی پھر اسی کا کہنا مانا مقرر وہ تھے لوگ نافرمان</p>"
        },
        "55": {
            "verses": {
                "43:55": {
                    "id": 55
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر جب ہم کو غصہ دلایا تو ہم نے ان سے بدلہ لیا پھر ڈبو دیا ان سب کو</p>"
        },
        "56": {
            "verses": {
                "43:56": {
                    "id": 56
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر کر ڈالا ان کو گئے گزرے اور ایک نظیر پچھلوں کے واسطے۔</h2>"
        },
        "57": {
            "verses": {
                "43:57": {
                    "id": 57
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب مثال لائے مریم کے بیٹے کی تبھی قوم تیری اس سے چلانے لگتے ہیں</p>"
        },
        "58": {
            "verses": {
                "43:58": {
                    "id": 58
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہتے ہیں ہمارے معبود بہتر ہیں یا وہ یہ مثال جو ڈالتے ہیں تجھ پر سو جھگڑنے کو بلکہ یہ لوگ ہیں جھگڑا لو</p>"
        },
        "59": {
            "verses": {
                "43:59": {
                    "id": 59
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ کیا ہے ایک بندہ ہے کہ ہم نے اس پر فضل کیا اور کھڑا کردیا اس کو بنی اسرائیل کے واسطے</p>"
        },
        "60": {
            "verses": {
                "43:60": {
                    "id": 60
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر ہم چاہیں نکالیں تم میں سے فرشتے رہیں زمین میں تمہاری جگہ</p>"
        },
        "61": {
            "verses": {
                "43:61": {
                    "id": 61
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور وہ نشان ہے قیامت کا سو اس میں شک مت کرو اور میرا کہا مانو یہ ایک سیدھی راہ ہے</p>"
        },
        "62": {
            "verses": {
                "43:62": {
                    "id": 62
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور نہ روک دے تم کو شیطان وہ تو تمہارا دشمن ہے صریح</h2>"
        },
        "63": {
            "verses": {
                "43:63": {
                    "id": 63
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب آیا عیسیٰ نشانیاں لے کر بولا میں لایا ہوں تمہارے پاس پکی باتیں اور بتلانے کو بعضی وہ چیز جس میں تم جھگڑتے تھے سو ڈرو اللہ سے اور میرا کہا مانو</p>"
        },
        "64": {
            "verses": {
                "43:64": {
                    "id": 64
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بیشک اللہ جو ہے وہی ہے رب میرا اور رب تمہارا سو اسی کی بندگی کرو یہ ایک سیدھی راہ ہے</p>"
        },
        "65": {
            "verses": {
                "43:65": {
                    "id": 65
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر پھٹ گئے کتنے فرقے ان کے بیچ سے سو خرابی ہے گنہگاروں کو آفت سے دکھ والے دن کی۔</p>"
        },
        "66": {
            "verses": {
                "43:66": {
                    "id": 66
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اب یہی ہے کہ راہ دیکھتے ہیں قیامت کی کہ آ کھڑی ہو ان پر اچانک اور ان کو خبر بھی نہ ہو</p>"
        },
        "67": {
            "verses": {
                "43:67": {
                    "id": 67
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جتنے دوست ہیں اس دن ایک دوسرے کے دشمن ہوں گے مگر جو لوگ ہیں ڈر والے</p>"
        },
        "68": {
            "verses": {
                "43:68": {
                    "id": 68
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اے بندو میرے نہ ڈر ہے تم پر آج کے دن اور نہ تم غمگین ہوں گے</h2>"
        },
        "69": {
            "verses": {
                "43:69": {
                    "id": 69
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جو یقین لائے ہماری باتوں پر اور رہے حکم بردار</h2>"
        },
        "70": {
            "verses": {
                "43:70": {
                    "id": 70
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>چلے جاؤ بہشت میں تم اور تمہاری عورتیں کہ تمہاری عزت کریں</h2>"
        },
        "71": {
            "verses": {
                "43:71": {
                    "id": 71
                }
            },
