            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ ان کو زندہ کرے گا جس نے بنایا ان کو پہلی بار اور وہ سب بنانا جانتا ہے</p>"
        },
        "80": {
