            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا دیکھتا نہیں انسان کہ ہم نے اس کو بنایا ایک قطرہ سے پھر تب ہی وہ ہوگیا جھگڑنے بولنے والا</p>"
        },
        "78": {
            "verses": {
