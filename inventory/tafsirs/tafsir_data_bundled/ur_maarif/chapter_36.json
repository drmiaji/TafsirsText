            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اب تو غمگین مت ہو ان کی بات سے ہم جانتے ہیں جو وہ چھپاتے ہیں اور جو ظاہر کرتے ہیں</p>"
        },
        "77": {
            "verses": {
