            },
            "text": "<p>یٰس</p>"
        },
        "2": {
            "verses": {
                "36:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>قسم ہے اس پکے قرآن کی</h2>"
        },
        "3": {
            "verses": {
                "36:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>تو تحقیق ہے بھیجے ہوؤں میں سے</h2>"
        },
        "4": {
            "verses": {
                "36:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اوپر سیدھی راہ کے</h2>"
        },
        "5": {
            "verses": {
                "36:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اتارا زبردست رحم والے نے</h2>"
        },
        "6": {
            "verses": {
                "36:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تاکہ تو ڈرائے ایک قوم کو کہ ڈر نہیں سنا ان کے باپ دادوں نے سو ان کو خبر نہیں</p>"
        },
        "7": {
            "verses": {
                "36:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>ثابت ہوچکی ہے بات ان میں بہتوں پر سو وہ نہ مانیں گے</h2>"
        },
        "8": {
            "verses": {
                "36:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ہم نے ڈالے ہیں ان کی گردنوں میں طوق سو وہ ہیں تھوڑیوں تک پھر ان کے سر الل رہے ہیں</p>"
        },
        "9": {
            "verses": {
                "36:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور بنائی ہم نے ان کے آگے دیوار اور پیچھے دیوار پھر اوپر سے ڈھانک دیا سو ان کو کچھ نہیں سوجھتا</p>"
        },
        "10": {
            "verses": {
                "36:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور برابر ہے ان کو تو ڈرائے یا نہ ڈرائے یقین نہیں کریں گے</h2>"
        },
        "11": {
            "verses": {
                "36:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو تو ڈر سنائے اس کو جو چلے سمجھائے پر اور ڈرے رحمن سے بن دیکھے سو اس کو خوشخبری دے معافی کی اور عزت کے ثواب کی</p>"
        },
        "12": {
            "verses": {
                "36:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ہم ہیں جو زندہ کرتے ہیں مردوں کو اور لکھتے ہیں جو آگے بھیج چکے اور جو نشان ان کے پیچھے رہے اور ہر چیز گن لی ہم نے ایک کھلی اصل میں۔</p>"
        },
        "13": {
            "verses": {
                "36:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور بیان کر ان کے واسطے ایک مثال اس گاؤں کے لوگوں کی جب کہ آئے اس میں بھیجے ہوئے جب بھیجے ہم نے ان کی طرف دو تو ان کو جھٹلایا</p>"
        },
        "14": {
            "verses": {
                "36:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر ہم نے قوت دی تیسرے سے تب کہا انہوں نے ہم تمہاری طرف آئے ہیں بھیجے ہوئے</p>"
        },
        "15": {
            "verses": {
                "36:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ بولے تم تو یہی انسان ہو جیسے ہم اور رحمن نے کچھ نہیں اتارا تم سارے جھوٹ کہتے ہو</p>"
        },
        "16": {
            "verses": {
                "36:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کہا ہمارا رب جانتا ہے ہم بیشک تمہاری طرف بھیجے ہوئے آئے ہیں</h2>"
        },
        "17": {
            "verses": {
                "36:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور ہمارا ذمہ یہی ہے پیغام پہنچا دینا کھول کر</h2>"
        },
        "18": {
            "verses": {
                "36:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بولے ہم نے نامبارک دیکھا تم کو اگر تم باز نہ رہو گے تو ہم تم کو سنگسار کریں گے اور تم کو پہنچے گا ہمارے ہاتھ سے عذاب درد ناک</p>"
        },
        "19": {
            "verses": {
                "36:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کہنے لگے تمہاری نامبارکی تمہارے ساتھ ہے کیا اتنی بات پر کہ تم کو سمجھایا کوئی نہیں پر تم لوگ ہو کہ حد پر نہیں رہتے</p>"
        },
        "20": {
            "verses": {
                "36:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور آیا شہر کے پرلے سرے سے ایک مرد دوڑتا ہوا بولا اے قوم چلو راہ پر بھیجے ہوؤں کی</p>"
        },
        "21": {
            "verses": {
                "36:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>چلو راہ پر ایسے شخص کی جو تم بےبدلہ نہیں چاہتے اور وہ ٹھیک راستہ پر ہیں۔</p>"
        },
        "22": {
            "verses": {
                "36:22": {
                    "id": 22
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور مجھ کو کیا ہوا کہ میں بندگی نہ کروں اس کی جس نے مجھ کو بنایا اور اسی کی طرف سب پھر جاؤ گے</p>"
        },
        "23": {
            "verses": {
                "36:23": {
                    "id": 23
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بھلا میں پکڑوں اس کے سوائے اوروں کو پوجنا کہ اگر مجھ پر چاہے رحمن تکلیف تو کچھ کام نہ آئے مجھ کو ان کی سفارش اور نہ وہ مجھ کو چھڑائیں</p>"
        },
        "24": {
            "verses": {
                "36:24": {
                    "id": 24
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>تو تو میں بھٹکتا رہوں صریح</h2>"
        },
        "25": {
            "verses": {
                "36:25": {
                    "id": 25
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>میں یقین لایا تمہارے رب پر مجھ سے سن لو</h2>"
        },
        "26": {
            "verses": {
                "36:26": {
                    "id": 26
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>حکم ہوا چلا جا بہشت میں بولا کسی طرح میری قوم معلوم کرلیں</h2>"
        },
        "27": {
            "verses": {
                "36:27": {
                    "id": 27
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کہ بخشا مجھ کو میرے رب نے اور کیا مجھ کو عزت والوں میں</h2>"
        },
        "28": {
            "verses": {
                "36:28": {
                    "id": 28
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور نہیں اتاری ہم نے اس کو قوم پر اس کے پیچھے کوئی فوج آسمان سے اور ہم (فوج) نہیں اتارا کرتے</p>"
        },
        "29": {
            "verses": {
                "36:29": {
                    "id": 29
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>بس یہی تھی ایک چنگھاڑ پھر اسی دم سب بجھ گئے</h2>"
        },
        "30": {
            "verses": {
                "36:30": {
                    "id": 30
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا افسوس ہے بندوں پر کوئی رسول نہیں آیا ان کے پاس جس سے ٹھٹھا نہیں کرتے</p>"
        },
        "31": {
            "verses": {
                "36:31": {
                    "id": 31
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا نہیں دیکھتے کتنی غارت کرچکے ہم ان سے پہلے جماعتیں کہ وہ ان کے پاس پھر کر نہیں آئیں گی</p>"
        },
        "32": {
            "verses": {
                "36:32": {
                    "id": 32
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ان سب میں کوئی نہیں جو اکٹھے ہو کر نہ آئیں ہمارے پاس پکڑے ہوئے۔</p>"
        },
        "33": {
            "verses": {
                "36:33": {
                    "id": 33
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ایک نشانی ہے ان کے واسطے زمین مردہ اس کو ہم نے زندہ کردیا اور نکالا اس میں سے اناج سو اسی میں سے کھاتے ہیں</p>"
        },
        "34": {
            "verses": {
                "36:34": {
                    "id": 34
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور بنائے ہم نے اس میں باغ کجھور کے اور انگور کے اور بہا دیئے اس میں بعضے چشمے</p>"
        },
        "35": {
            "verses": {
                "36:35": {
                    "id": 35
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کہ کھائیں اس کے میووں سے اور اس کو بنایا نہیں ان کے ہاتھوں نے پھر کیوں شکر نہیں کرتے</p>"
        },
        "36": {
            "verses": {
                "36:36": {
                    "id": 36
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پاک ذات ہے جس نے بنائے جوڑے سب چیز کے اس قسم میں سے جو اگتا ہے زمین میں سے اور خود ان میں سے اور ان چیزوں میں کہ جن کی ان کو خبر نہیں</p>"
        },
        "37": {
            "verses": {
                "36:37": {
                    "id": 37
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ایک نشانی ہے ان کے واسطے رات کھینچ لیتے ہیں ہم اس پر سے دن کو پھر تب ہی یہ رہ جاتے ہیں اندھیرے میں</p>"
        },
        "38": {
            "verses": {
                "36:38": {
                    "id": 38
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور سورج چلا جاتا ہے اپنے ٹھہرے ہوئے رستہ پر یہ سادھا ہے اس زبردست باخبر نے</p>"
        },
        "39": {
            "verses": {
                "36:39": {
                    "id": 39
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور چاند کو ہم نے بانٹ دی ہیں منزلیں یہاں تک کہ پھر آ رہا جیسے ٹہنی پرانی</p>"
        },
        "40": {
            "verses": {
                "36:40": {
                    "id": 40
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>نہ سورج سے ہو کہ پکڑ لے چاند کو اور نہ رات آگے بڑھے دن سے اور ہر کوئی ایک چکر میں پیرتے ہیں</p>"
        },
        "41": {
            "verses": {
                "36:41": {
                    "id": 41
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ایک نشانی ہے ان کے واسطے کہ ہم نے اٹھا لیا ان کی نسل کو اس بھری ہوئی کشتی میں</p>"
        },
        "42": {
            "verses": {
                "36:42": {
                    "id": 42
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور بنادیا ہم نے ان کے واسطے کشتی جیسی چیزوں کو جس پر سوار ہوتے ہیں</p>"
        },
        "43": {
            "verses": {
                "36:43": {
                    "id": 43
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر ہم چاہیں تو ان کو ڈبا دیں پھر کوئی نہ پہنچے ان کی فریاد کو اور نہ وہ چھڑائے جائیں</p>"
        },
        "44": {
            "verses": {
                "36:44": {
                    "id": 44
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>مگر ہم اپنی مہربانی سے اور ان کا کام چلانے کو ایک وقت تک۔</h2>"
        },
        "45": {
            "verses": {
                "36:45": {
                    "id": 45
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب کہئے ان کو بچو اس سے جو تمہارے سامنے آتا ہے اور جو پیچھے چھوڑتے ہو شاید کہ تم پر رحم ہو</p>"
        },
        "46": {
            "verses": {
                "36:46": {
                    "id": 46
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کوئی حکم نہیں پہنچتا ان کو اپنے رب کے حکموں سے جس کو وہ ٹلاتے نہ ہوں اور جب کہئے ان کو خرچ کرو کچھ اللہ کا دیا</p>"
        },
        "47": {
            "verses": {
                "36:47": {
                    "id": 47
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کہتے ہیں منکر ایمان والوں کو ہم کیوں کھلائیں ایسوں کو کہ اللہ چاہتا تو اس کو کھلا دیتا تم لوگ تو بالکل بہک رہے ہو صریح۔</p>"
        },
        "48": {
            "verses": {
                "36:48": {
                    "id": 48
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور کہتے ہیں کب ہوگا یہ وعدہ اگر تم سچے ہو</h2>"
        },
        "49": {
            "verses": {
                "36:49": {
                    "id": 49
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ تو راہ دیکھتے ہیں ایک چنگھاڑ کی جو ان کو آپکڑے گی جب آپس میں جھگڑ رہے ہوں گے</p>"
        },
        "50": {
            "verses": {
                "36:50": {
                    "id": 50
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر نہ کرسکیں گے کہ کچھ کہہ ہی مریں اور نہ اپنے گھر کو پھر کر جاسکیں گے</p>"
        },
        "51": {
            "verses": {
                "36:51": {
                    "id": 51
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور پھونکی جائے صور پھر تب ہی وہ قبروں سے اپنے رب کی طرف پھیل پڑیں گے</p>"
        },
        "52": {
            "verses": {
                "36:52": {
                    "id": 52
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کہیں گے اے خرابی ہماری کس نے اٹھا دیا ہم کو ہماری نیند کی جگہ سے یہ وہ ہے جو وعدہ کیا تھا رحمن نے اور سچ کہا تھا پیغمبروں نے</p>"
        },
        "53": {
            "verses": {
                "36:53": {
                    "id": 53
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بس ایک چنگھاڑ ہوگی پھر اسی دم وہ سارے ہمارے پاس پکڑے چلے آئیں</p>"
        },
        "54": {
            "verses": {
                "36:54": {
                    "id": 54
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر آج کے دن ظلم نہ ہوگا کسی جی پر ذرا اور وہی بدلہ پاؤ گے جو کرتے تھے</p>"
        },
        "55": {
            "verses": {
                "36:55": {
                    "id": 55
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>تحقیق بہشت کے لوگ آج ایک مشغلہ میں ہیں باتیں کرتے</h2>"
        },
        "56": {
            "verses": {
                "36:56": {
                    "id": 56
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>وہ اور ان کی عورتیں سایوں میں تختوں پر بیٹھے ہیں تکیہ لگائے</h2>"
        },
        "57": {
            "verses": {
                "36:57": {
                    "id": 57
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>ان کے لئے وہاں ہے میوہ اور ان کے لئے ہے جو کچھ مانیں</h2>"
        },
        "58": {
            "verses": {
                "36:58": {
                    "id": 58
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>سلام بولنا ہے رب مہربان سے</h2>"
        },
        "59": {
            "verses": {
                "36:59": {
                    "id": 59
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور تم الگ ہوجاؤ آج اے گنہگاروں</h2>"
        },
        "60": {
            "verses": {
                "36:60": {
                    "id": 60
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>میں نے نہ کہہ رکھا تھا تم کو اے آدم کی اولاد کہ نہ پوجیو شیطان کو وہ کھلا دشمن ہے تمہارا</p>"
        },
        "61": {
            "verses": {
                "36:61": {
                    "id": 61
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور یہ کہ پوجو مجھ کو یہ راہ ہے سیدھی</h2>"
        },
        "62": {
            "verses": {
                "36:62": {
                    "id": 62
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور وہ بہکا لے گیا تم میں سے بہت خلقت کو پھر کیا تم کو سمجھ نہ تھی</p>"
        },
        "63": {
            "verses": {
                "36:63": {
                    "id": 63
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>یہ دوزخ ہے جس کا تم کو وعدہ تھا</h2>"
        },
        "64": {
            "verses": {
                "36:64": {
                    "id": 64
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جا پڑو اس میں آج کے دن بدلہ اپنے کفر کا</h2>"
        },
        "65": {
            "verses": {
                "36:65": {
                    "id": 65
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>آج ہم مہر لگا دیں گے ان کے منہ پر اور بولیں گے ہم سے ان کے ہاتھ اور بتلائیں گے ان کے پاؤں جو کچھ وہ کماتے تھے</p>"
        },
        "66": {
            "verses": {
                "36:66": {
                    "id": 66
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر ہم چاہیں مٹا دیں ان کی آنکھیں پھر دوڑیں رستہ پانے کو پھر کہاں سے سوجھے</p>"
        },
        "67": {
            "verses": {
                "36:67": {
                    "id": 67
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر ہم چاہیں صورت مسخ کردیں ان کی جہاں کی تہاں پھر نہ آگے چل سکیں اور نہ وہ الٹے پھر سکیں</p>"
        },
        "68": {
            "verses": {
                "36:68": {
                    "id": 68
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جس کو ہم بوڑھا کریں اوندھا کریں اس کی پیدائش میں پھر کیا ان کو سمجھ نہیں۔</p>"
        },
        "69": {
            "verses": {
                "36:69": {
                    "id": 69
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ہم نے نہیں سکھایا اس کو شعر کہنا اور یہ اس کے لائق نہیں یہ تو خاص نصیحت ہے اور قرآن ہے صاف</p>"
        },
        "70": {
            "verses": {
                "36:70": {
                    "id": 70
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تاکہ ڈر سنائے اس کو جس میں جان ہو اور ثابت ہو الزام منکروں پر</p>"
        },
        "71": {
            "verses": {
                "36:71": {
                    "id": 71
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا اور نہیں دیکھتے وہ کہ ہم نے بنا دیئے ان کے واسطے اپنے ہاتھوں کی بنائی ہوئی چیزوں سے چوپائے پھر وہ ان کے مالک ہیں</p>"
        },
        "72": {
            "verses": {
                "36:72": {
                    "id": 72
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور عاجز کردیا ان کو ان کے آگے پھر ان میں کوئی ہے ان کی سواری اور کسی کو کھاتے ہیں</p>"
        },
        "73": {
            "verses": {
                "36:73": {
                    "id": 73
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ان کے واسطے چوپایوں میں فائدے ہیں اور پینے کے گھاٹ پھر کیوں شکر نہیں کرتے</p>"
        },
        "74": {
            "verses": {
                "36:74": {
                    "id": 74
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
