        "37": {
            "verses": {
                "78:37": {
                    "id": 37
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جو رب ہے آسمانوں کا اور زمین کا اور جو کچھ ان کے بیچ میں ہے بڑی رحمت والا قدرت نہیں کہ کوئی اس سے بات کرے</p>"
        },
        "38": {
            "verses": {
                "78:38": {
                    "id": 38
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جس دن کھڑی ہو روح اور فرشتے قطار باندھ کر کوئی نہیں بولتا مگر جس کو حکم دیا رحمن نے اور بولا بات ٹھیک</p>"
        },
        "39": {
            "verses": {
                "78:39": {
                    "id": 39
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ دن ہے بر حق پھر جو کوئی چاہئے بنا رکھے اپنے رب کے پاس ٹھکانا</p>"
        },
        "40": {
            "verses": {
                "78:40": {
                    "id": 40
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ہم نے خبر سنا دی تم کو ایک آفت نزدیک آنے والی کی جس دن دیکھ لے گا آدمی جو آگے بھیجا اس کے ہاتھوں نے اور کہے گا کافر کسی طرح میں مٹی ہوتا۔</p>"
        }
    }
