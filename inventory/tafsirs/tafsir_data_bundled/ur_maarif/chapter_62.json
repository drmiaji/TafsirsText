{
    "chapter": 62,
    "verses": {
        "1": {
            "verses": {
                "62:1": {
                    "id": 1
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اللہ کی پاکی بولتا ہے جو کچھ کہ ہے آسمانوں میں اور جو کچھ کہ ہے زمین میں بادشاہ پاک ذات زبردست حکمتوں والا</p>"
        },
        "2": {
            "verses": {
                "62:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہی ہے جس نے اٹھایا ان پڑھوں میں ایک رسول انہی میں کا پڑھ کر سناتا ہے ان کو اس کی آیتیں اور ان کو سنوارتا ہے اور سکھلاتا ہے ان کو کتاب اور عقلمندی اور اس سے پہلے وہ پڑے ہوئے تھے صریح بھول میں</p>"
        },
        "3": {
            "verses": {
                "62:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور (اٹھایا اس رسول کو ایک) دوسرے لوگوں کے واسطے بھی انہی میں سے جو ابھی نہیں ملے ان میں اور وہی ہے زبردست حکمت والا</p>"
        },
        "4": {
            "verses": {
                "62:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ بڑائی اللہ کی ہے دیتا ہے جس کو چاہئے اور اللہ کا فضل بڑا ہے</p>"
        },
        "5": {
            "verses": {
                "62:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>مثال ان لوگوں کی جن پر لادی توریت پھر نہ اٹھائی انہوں نے جیسے مثال گدھے کی پیٹھ پر لے چلتا ہے کتابیں بری مثال ہے ان لوگوں کی جنہوں نے جھٹلایا اللہ کی باتوں کو اور اللہ راہ نہیں دیتا بےانصاف لوگوں کو</p>"
        },
        "6": {
            "verses": {
                "62:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ اے یہودی ہونے والو ! اگر تم کو دعویٰ ہے کہ تم دوست ہو اللہ کے سب لوگوں کے سوائے تو مناؤ اپنے مرنے کو اگر تم سچے ہو</p>"
        },
        "7": {
            "verses": {
                "62:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور وہ کبھی نہ منائیں گے اپنا مرنا ان کاموں کی وجہ سے جن کو آگے بھیج چکے ہیں ان کے ہاتھ اور اللہ کو خوب معلوم ہیں سب گنہگار</p>"
        },
        "8": {
            "verses": {
                "62:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ موت وہ جس سے تم بھاگتے ہو سو وہ تم سے ضرور ملنے والی ہے پھر تم پھیرے جاؤ گے اس چھپے اور کھلے جاننے والے کے پاس پھر جتلا دے گا تم کو جو تم کرتے تھے۔</p>"
        },
        "9": {
            "verses": {
                "62:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے ایمان والو ! جب اذان ہو نماز کی جمعہ کے دن تو دوڑو اللہ کی یاد کو اور چھوڑ دو خریدو فروخت یہ بہتر ہے تمہارے حق میں اگر تم کو سمجھ ہے</p>"
        },
        "10": {
            "verses": {
                "62:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر جب تمام ہوچکے نماز تو پھیل پڑو زمین میں اور ڈھونڈو فضل اللہ کا اور یاد کرو اللہ کو بہت سا تاکہ تمہارا بھلا ہو</p>"
        },
        "11": {
            "verses": {
                "62:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب دیکھیں سودا بکتا یا کچھ تماشا متفرق ہوجائیں اس کی طرف اور تجھ کو چھوڑ جائیں کھڑا تو کہہ جو اللہ کے پاس ہے سو بہتر ہے تماشے سے اور سوداگری سے اور اللہ بہتر ہے روزی دینے والا۔</p>"
        }
    }
}