{
    "chapter": 76,
    "verses": {
        "1": {
            "verses": {
                "76:1": {
                    "id": 1
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کبھی گزرا ہے انسان پر ایک وقت زمانے میں کہ نہ تھا وہ کوئی چیز</p>"
        },
        "2": {
            "verses": {
                "76:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جو زبان پر آتی ہم نے بنایا آدمی کو ایک دورنگی بوند سے ہم پلٹتے رہے اس کو پھر کردیا اس کو ہم نے سننے والا دیکھنے والا</p>"
        },
        "3": {
            "verses": {
                "76:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ہم نے اس کو سمجھائی راہ یا حق مانتا ہے اور یا ناشکری کرتا ہے</p>"
        },
        "4": {
            "verses": {
                "76:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ہم نے تیار کر رکھی ہیں منکروں کے واسطے زنجیریں اور طوق اور آگ دہکتی</p>"
        },
        "5": {
            "verses": {
                "76:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>البتہ نیک لوگ پیتے ہیں پیالہ جس کی ملونی ہے کافور</h2>"
        },
        "6": {
            "verses": {
                "76:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ایک چشمہ ہے جس سے پیتے ہیں بندے اللہ کے چلاتے ہیں وہ اس کی نالیاں</p>"
        },
        "7": {
            "verses": {
                "76:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پورا کرتے ہیں منت کو اور ڈرتے ہیں اس دن سے کہ اس کی برائی پھیل پڑے گی</p>"
        },
        "8": {
            "verses": {
                "76:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کھلاتے ہیں کھانا اس کی محبت پر محتاج کو اور یتیم کو اور قیدی کو</p>"
        },
        "9": {
            "verses": {
                "76:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ہم جو تم کو کھلاتے ہیں سو خالص اللہ کی خوشی چاہنے کو نہ تم سے ہم چاہیں بدلہ اور نہ چاہیں شکر گزاری</p>"
        },
        "10": {
            "verses": {
                "76:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>ہم ڈرتے ہیں اپنے رب سے ایک دن اداسی والے کی سختی سے</h2>"
        },
        "11": {
            "verses": {
                "76:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر بچا لیا ان کو اللہ نے برائی سے اس دن کی اور ملا دی ان کی تازگی اور خوش وقتی</p>"
        },
        "12": {
            "verses": {
                "76:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور بدلہ دیا ان کو ان کے صبر پر باغ اور پوشاک ریشمی</h2>"
        },
        "13": {
            "verses": {
                "76:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تکیہ لگائے بیٹھیں اس میں تختوں کے اوپر نہیں دیکھتے وہاں دھوپ اور نہ ٹھہر</p>"
        },
        "14": {
            "verses": {
                "76:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جھک رہیں ان پر اس کی چھائیں اور پست کر رکھے ہیں اس کے گچھے لٹکا کر</p>"
        },
        "15": {
            "verses": {
                "76:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور لوگ لئے پھرتے ہیں ان کے پاس برتن چاندی کے اور آجورے جو ہو رہے ہیں شیشے کے</p>"
        },
        "16": {
            "verses": {
                "76:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>شیشے ہیں چاندی کے ماپ رکھا ہے ان کا ماپ</h2>"
        },
        "17": {
            "verses": {
                "76:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور ان کو وہاں پلاتے ہیں پیالے جس کی ملونی ہے سونٹھ</h2>"
        },
        "18": {
            "verses": {
                "76:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>ایک چشمہ ہے اس میں اس کا نام کہتے ہیں سلسبیل</h2>"
        },
        "19": {
            "verses": {
                "76:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور پھرتے ہیں ان کے پاس لڑکے سدا رہنے والے جب تو ان کو دیکھے خیال کرے کہ موتی ہیں بکھرے ہوئے</p>"
        },
        "20": {
            "verses": {
                "76:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور جب تو دیکھے وہاں تو دیکھے نعمت اور سلطنت بڑی</h2>"
        },
        "21": {
            "verses": {
                "76:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اوپر کی پوشاک ان کی کپڑے ہیں باریک ریشم کے سبز اور گاڑھے اور ان کو پہنائے جائیں گے کنگن چاندی کے اور پلائے ان کو ان کا رب شراب جو پاک کرے</p>"
        },
        "22": {
            "verses": {
                "76:22": {
                    "id": 22
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>دل کو یہ ہے تمہارا بدلہ اور کمائی تمہاری ٹھکانے لگی</h2>"
        },
        "23": {
            "verses": {
                "76:23": {
                    "id": 23
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>ہم نے اتارا تجھ پر قرآن سہج سہج اتارنا</h2>"
        },
        "24": {
            "verses": {
                "76:24": {
                    "id": 24
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو تو انتظار کرتا اپنے رب کے حکم کا اور کہنا مت مان ان میں سے کسی گنہگار یا ناشکر کا</p>"
        },
        "25": {
            "verses": {
                "76:25": {
                    "id": 25
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور لیتا رہ نام اپنے رب کا صبح اور شام</h2>"
        },
        "26": {
            "verses": {
                "76:26": {
                    "id": 26
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کسی وقت رات کو سجدہ کر اس کو اور پاکی بول اس کی بڑی رات تک</p>"
        },
        "27": {
            "verses": {
                "76:27": {
                    "id": 27
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ لوگ چاہتے ہیں جلدی لنے والے کو اور چھوڑ رکھا ہے اپنے پیچھے ایک بھاری دن کو</p>"
        },
        "28": {
            "verses": {
                "76:28": {
                    "id": 28
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ہم نے ان کو بنایا اور مضبوط کیا ان کی جوڑ بندی کو اور جب ہم چاہیں بدل لائیں ان جیسے لوگ بدل کر</p>"
        },
        "29": {
            "verses": {
                "76:29": {
                    "id": 29
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>یہ تو نصیحت ہے پھر جو کوئی چاہے کر رکھے اپنے رب تک راہ</h2>"
        },
        "30": {
            "verses": {
                "76:30": {
                    "id": 30
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور تم نہیں چاہو گے مگر جو چاہے اللہ بیشک اللہ ہے سب کچھ جاننے والا حکمتوں والا</p>"
        },
        "31": {
            "verses": {
                "76:31": {
                    "id": 31
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>داخل کرلے جس کو چاہے اپنی رحمت میں اور جو گنہگار ہیں تیار ہے ان کے واسطے عذاب درد ناک۔</p>"
        }
    }
}