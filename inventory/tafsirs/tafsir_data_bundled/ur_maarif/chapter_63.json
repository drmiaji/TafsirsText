{
    "chapter": 63,
    "verses": {
        "1": {
            "verses": {
                "63:1": {
                    "id": 1
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جب آئیں تیرے پاس منافق کہیں ہم قائل ہیں تو رسول ہے اللہ کا اور اللہ جانتا ہے کہ تو اس کا رسول ہے اور اللہ گواہی دیتا ہے کہ یہ منافق جھوٹے ہیں</p>"
        },
        "2": {
            "verses": {
                "63:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>انہوں نے رکھا ہے اپنی قسموں کو ڈھال بنا کر پھر روکتے ہیں اللہ کی راہ سے یہ لوگ برے کام ہیں جو کر رہے ہیں</p>"
        },
        "3": {
            "verses": {
                "63:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ اس لئے کہ وہ ایمان لائے پھر منکر ہوگئے پھر مہر لگ گئی ان کے دل پر سو وہ اب کچھ نہیں سمجھتے</p>"
        },
        "4": {
            "verses": {
                "63:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب تو دیکھے ان کو تو اچھے لگیں تجھ کو ان کے ڈیل اور اگر بات کہیں سنے تو ان کی بات کیسے ہیں جیسے کہ لکڑی لگا دی دیوار سے جو کوئی چیخیں جانیں ہم ہی پر بلا آئی وہی ہیں دشمن ان سے بچتارہ گردن مارے ان کی اللہ کہاں سے پھرے جاتے ہیں</p>"
        },
        "5": {
            "verses": {
                "63:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب کہئے ان کو آؤ معاف کرا دے تم کو رسول اللہ کا مٹکائے ہیں اپنے سر اور تو دیکھے کہ وہ روکتے ہیں اور وہ غرور کرتے ہیں</p>"
        },
        "6": {
            "verses": {
                "63:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>برابر ہے ان پر تو معافی چاہے ان کی یا نہ معافی چاہئے ہرگز نہ معاف کرے گا ان کو اللہ بیشک اللہ راہ نہیں دیتا نافرمان لوگوں کو</p>"
        },
        "7": {
            "verses": {
                "63:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہی ہیں جو کہتے ہیں خرچ مت کرو ان پر جو پاس رہتے ہیں رسول اللہ کے یہاں تک کہ متفرق ہوجائیں اور اللہ کے ہیں خزانے آسمانوں کے اور زمین کے لیکن منافق نہیں سمجھتے</p>"
        },
        "8": {
            "verses": {
                "63:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کہتے ہیں البتہ اگر ہم پھرگئے مدینہ کو تو نکال دے گا جس کا زور ہے وہاں سے کمزور لوگوں کو اور زور تو اللہ کا ہے اور اس کے رسول کا اور ایمان والوں کا لیکن منافق نہیں جانتے۔</p>"
        },
        "9": {
            "verses": {
                "63:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے ایمان والو ! غافل نہ کردیں تم کو تمہارے مال اور تمہاری اولاد اللہ کی یاد سے اور جو کوئی یہ کام کرے تو وہی لوگ ہیں ٹوٹے میں</p>"
        },
        "10": {
            "verses": {
                "63:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور خرچ کرو کچھ ہمارا دیا ہوا اس سے پہلے کہ آپہنچے تم میں کسی کو موت تب کہے اے رب کیوں نہ ڈھیل دی تو نے مجھ کو ایک تھوڑی سی مدت کہ میں خیرات کرتا اور ہوجاتا نیک لوگوں میں</p>"
        },
        "11": {
            "verses": {
                "63:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ہرگز نہ ڈھیل دے گا اللہ کسی جی کو جب آپہنچا اس کا وعدہ اور اللہ کو خبر ہے جو تم کرتے ہو۔</p>"
        }
    }
}