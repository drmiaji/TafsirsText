{
    "chapter": 71,
    "verses": {
        "1": {
            "verses": {
                "71:1": {
                    "id": 1
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ہم نے بھیجا نوح کو اس کی قوم کی طرف کہ ڈرا اپنی قوم کو اس سے پہلے کہ پہنچے ان پر عذاب درد ناک</p>"
        },
        "2": {
            "verses": {
                "71:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>بولا اے قوم میری میں تم کو ڈر سناتا ہوں</h2>"
        },
        "3": {
            "verses": {
                "71:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کھول کر کہ بندگی کرو اللہ کی اور اس سے ڈرو</h2>"
        },
        "4": {
            "verses": {
                "71:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور میرا کہنا مانو تاکہ بخشے وہ تم کو کچھ گناہ تمہارے اور ڈھیل دے تم کو ایک مقرر وعدہ تک وہ جو وعدہ کیا ہے اللہ نے جب آپہنچے گا اس کو ڈھیل نہ ہوگی اگر تم کو سمجھ ہے</p>"
        },
        "5": {
            "verses": {
                "71:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>بولا اے رب میں بلاتا رہا اپنی قوم کو رات اور دن</h2>"
        },
        "6": {
            "verses": {
                "71:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر میرے بلانے سے اور زیادہ بھاگنے لگے</h2>"
        },
        "7": {
            "verses": {
                "71:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور میں نے جب کبھی ان کو بلایا تاکہ تو ان کو بخشے ڈالنے لگے انگلیاں اپنے کانوں میں اور لپیٹنے لگے اپنے اوپر کپڑے اور ضد کی اور غرور کیا بڑا غرور</p>"
        },
        "8": {
            "verses": {
                "71:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر میں نے ان کو بلایا بر ملا</h2>"
        },
        "9": {
            "verses": {
                "71:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر میں نے ان کو کھول کر کہا اور چھپ کر کہا چپکے سے</h2>"
        },
        "10": {
            "verses": {
                "71:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>تو میں نے کہا گناہ بخشواؤ اپنے رب سے بیشک وہ ہے بخشنے والا</h2>"
        },
        "11": {
            "verses": {
                "71:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>چھوڑ دے گا آسمان کی تم پر دھاریں</h2>"
        },
        "12": {
            "verses": {
                "71:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور بڑھا دے گا تم کو مال اور بیٹوں سے اور بنا دے گا تمہارے واسطے باغ اور بنا دے گا تمہارے لئے نہریں</p>"
        },
        "13": {
            "verses": {
                "71:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کیا ہوا ہے تم کو کیوں نہیں امید رکھتے اللہ سے بڑائی کی</h2>"
        },
        "14": {
            "verses": {
                "71:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور اسی نے بنایا تم کو طرح طرح سے</h2>"
        },
        "15": {
            "verses": {
                "71:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کیا تم نے نہیں دیکھا کیسے بنائے اللہ نے سات آسمان تہ پر تہ</h2>"
        },
        "16": {
            "verses": {
                "71:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور رکھا چاند کو ان میں اجالا اور رکھا سورج کو چراغ جلتا ہوا</p>"
        },
        "17": {
            "verses": {
                "71:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور اللہ نے اگایا تم کو زمین سے جما کر</h2>"
        },
        "18": {
            "verses": {
                "71:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر مکرر ڈالے گا تم کو اس میں اور نکالے گا تم کو باہر</h2>"
        },
        "19": {
            "verses": {
                "71:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور اللہ نے بنادیا تمہارے لئے زمین کو بچھونا</h2>"
        },
        "20": {
            "verses": {
                "71:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>تاکہ چلو اس میں کشادہ راستے</h2>"
        },
        "21": {
            "verses": {
                "71:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کہا نوح نے اے رب میرے انہوں نے میرا کہا نہ مانا اور مانا ایسے کا جس کو اس کے مال اور اولاد سے اور زیادہ ہو ٹوٹا</p>"
        },
        "22": {
            "verses": {
                "71:22": {
                    "id": 22
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور داؤ کیا ہے بڑا داؤ</h2>"
        },
        "23": {
            "verses": {
                "71:23": {
                    "id": 23
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>او بولے ہرگز نہ چھوڑیو اپنے معبودوں کو اور نہ چھوڑیو ود کو اور نہ سواع کو اور نہ یغوث کو اور یعوق اور نسر کو</p>"
        },
        "24": {
            "verses": {
                "71:24": {
                    "id": 24
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور بہکا دیا بہتوں کو اور تو نہ زیادہ کرنا بےانصافوں کو مگر بھٹکنا</p>"
        },
        "25": {
            "verses": {
                "71:25": {
                    "id": 25
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کچھ وہ اپنے گناہوں سے ڈبائے گئے پھر ڈالے گئے آگ میں پھر نہ پائے اپنے واسطے انہوں نے اللہ کے سوائے کوئی مددگار</p>"
        },
        "26": {
            "verses": {
                "71:26": {
                    "id": 26
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہا نوح نے اے رب نہ چھوڑ یو زمین پر منکروں کا ایک گھر بسنے والا مقرر</p>"
        },
        "27": {
            "verses": {
                "71:27": {
                    "id": 27
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اگر تو چھوڑ دے گا ان کو بہکائیں گے تیرے بندوں کو اور جو جنیں گے سو ڈھیٹھ حق کا منکر</p>"
        },
        "28": {
            "verses": {
                "71:28": {
                    "id": 28
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے رب معاف کر مجھ کو اور میرے ماں باپ کو اور جو آئے میرے گھر میں ایماندار اور سب ایمان والے مردوں کو اور عورتوں کو اور گنہگاروں پر بڑھتا رکھ یہی برباد ہونا۔</p>"
        }
    }
}