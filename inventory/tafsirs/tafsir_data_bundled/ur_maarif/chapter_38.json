            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>فرمایا تو ٹھیک بات یہ ہے اور میں ٹھیک ہی کہتا ہوں</h2>"
        },
        "85": {
            "verses": {
                "38:85": {
                    "id": 85
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
