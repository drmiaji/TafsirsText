            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>مجھ کو بھرنا ہے دوزخ تجھ سے اور جو ان میں تیری راہ چلے ان سب سے</p>"
        },
        "86": {
            "verses": {
