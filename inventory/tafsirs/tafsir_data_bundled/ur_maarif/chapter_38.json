            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ میں مانگتا نہیں تم سے اس پر کچھ بدلا اور میں نہیں اپنے آپ کو بنانے والا</p>"
        },
