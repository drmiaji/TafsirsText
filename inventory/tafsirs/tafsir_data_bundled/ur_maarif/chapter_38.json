            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>مگر ابلیس نے غرور کیا اور تھا وہ منکروں میں</h2>"
        },
        "75": {
            "verses": {
                "38:75": {
                    "id": 75
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>فرمایا اے ابلیس کس چیز نے روک دیا تجھ کو کہ سجدہ کرے اس کو جس کو میں نے بنایا اپنے دونوں ہاتھ سے یہ تو نے غرور کیا یا تو بڑا تھا درجہ میں</p>"
        },
        "76": {
            "verses": {
                "38:76": {
                    "id": 76
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بولا میں بہتر ہوں اس سے مجھ کو بنایا تو نے آگ سے اور اس کو بنایا مٹی سے</p>"
        },
        "77": {
            "verses": {
                "38:77": {
                    "id": 77
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>فرمایا تو تو نکل یہاں سے کہ تو مردود ہوا</h2>"
        },
        "78": {
            "verses": {
                "38:78": {
                    "id": 78
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور تجھ پر میری پھٹکار ہے اس جزا کے دن تک</h2>"
        },
        "79": {
            "verses": {
                "38:79": {
                    "id": 79
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>بولا اے رب مجھ کو ڈھیل دے جس دن تک مردے جی اٹھیں</h2>"
        },
        "80": {
            "verses": {
                "38:80": {
                    "id": 80
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>فرمایا تو تجھ کو ڈھیل ہے</h2>"
        },
        "81": {
            "verses": {
                "38:81": {
                    "id": 81
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اسی وقت کے دن تک جو معلوم ہے</h2>"
        },
        "82": {
            "verses": {
                "38:82": {
                    "id": 82
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>بولا تو قسم ہے تیری عزت کی میں گمراہ کروں گا ان سب کو</h2>"
        },
        "83": {
            "verses": {
                "38:83": {
                    "id": 83
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>مگر جو بندے ہیں ان میں تیرے چنے ہوئے</h2>"
        },
        "84": {
            "verses": {
                "38:84": {
                    "id": 84
