{
    "chapter": 41,
    "verses": {
        "1": {
            "verses": {
                "41:1": {
                    "id": 1
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>حم</p>"
        },
        "2": {
            "verses": {
                "41:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اتارا ہوا ہے بڑے مہربان رحم والے کی طرف سے</h2>"
        },
        "3": {
            "verses": {
                "41:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ایک کتاب ہے کہ جدی جدی کی ہیں اس کی آیتیں قرآن عربی زبان کا ایک سمجھ والے لوگوں کو سنانے والا</p>"
        },
        "4": {
            "verses": {
                "41:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>خوشخبری اور ڈر پر دھیان میں نہ لائے وہ بہت لوگ سو وہ نہیں سنتے</p>"
        },
        "5": {
            "verses": {
                "41:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہتے ہیں ہمارے دل غلاف میں ہیں اس بات سے جس کی طرف تو ہم کو بلاتا ہے اور ہمارے کانوں میں بوجھ ہے اور ہمارے اور تیرے بیچ میں پردہ ہے سو تو اپنا کام کر ہم اپنا کام کرتے ہیں</p>"
        },
        "6": {
            "verses": {
                "41:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ میں بھی آدمی ہوں جیسے تم، حکم آتا ہے مجھ کو کہ تم پر بندگی ایک حاکم کی ہے سو سیدھے رہو اس کی طرف اور اس سے گناہ بخشواؤ اور خربی ہے شریک کرنے والوں کو</p>"
        },
        "7": {
            "verses": {
                "41:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جو نہیں دیتے زکوٰة اور وہ آخرت سے منکر ہیں</h2>"
        },
        "8": {
            "verses": {
                "41:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>البتہ جو لوگ یقین لائے اور کئے بھلے کام ان کو ثواب ملنا ہے جو موقوف نہ ہو۔</p>"
        },
        "9": {
            "verses": {
                "41:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ کیا تم منکر ہو اس سے جس نے بنائی زمین دو دن میں اور برابر کرتے ہو اس کے ساتھ اوروں کو وہ ہے رب جہان کا</p>"
        },
        "10": {
            "verses": {
                "41:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور رکھے اس میں بھاری پہاڑ اوپر سے اور برکت رکھی اس کے اندر اور ٹھہرائیں اس میں خوراکیں اس کی چار دن میں پورا ہوا پوچھنے والوں کو</p>"
        },
        "11": {
            "verses": {
                "41:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر چڑھا آسمان کو اور وہ دھواں ہو رہا تھا پھر کہا اس کو اور زمین کو آؤ تم دونوں خوشی سے یا زور سے وہ بولے ہم آئے خوشی سے</p>"
        },
        "12": {
            "verses": {
                "41:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر کردیئے وہ سات آسمان دو دن میں اور اتارا ہر آسمان میں حکم اس کا اور رونق دی ہم نے سب سے درلے آسمان کو چراغوں سے اور محفوظ کردیا یہ سادھا ہوا ہے زبردست خبر دار کا۔</p>"
        },
        "13": {
            "verses": {
                "41:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر اگر وہ ٹلائیں تو تو کہہ میں نے خبر سنا دی تم کو ایک سخت عذاب کی جیسے عذاب آیا عاد اور ثمود پر</p>"
        },
        "14": {
            "verses": {
                "41:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جب آئے ان کے پاس رسول آگے سے اور پیچھے سے کہ نہ پوجو کسی کو سوائے اللہ کے کہنے لگے اگر ہمارا رب چاہتا تو بھیجتا فرشتے سو ہم تمہارا لایا ہوا نہیں مانتے</p>"
        },
        "15": {
            "verses": {
                "41:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو وہ جو عاد تھے وہ غرور کرنے لگے ملک میں ناحق اور کہنے لگے کون ہے ہم سے زیادہ زور میں کیا دیکھتے نہیں کہ اللہ جس نے ان کو بنایا وہ زیادہ ہے ان سے زور میں اور تھے ہماری نشانیوں سے منکر</p>"
        },
        "16": {
            "verses": {
                "41:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر بھیجی ہم نے ان پر ہوا بڑے زور کی کئی دن جو مصیبت کے تھے تاکہ چکھائیں ان کو رسوائی کا عذاب دنیا کی زندگانی میں اور آخرت کے عذاب میں تو پوری رسوائی ہے اور ان کو کہیں مدد نہیں</p>"
        },
        "17": {
            "verses": {
                "41:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور وہ جو ثمود تھے سو ہم نے ان کو راہ بتلائی پھر ان کو خوش لگا اندھا رہنا راہ سوجھنے سے پھر پکڑا ان کو کڑک نے ذلت کے عذاب کی بدلہ اس کا جو کماتے تھے</p>"
        },
        "18": {
            "verses": {
                "41:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور بچا دیا ہم نے ان لوگوں کو جو یقین لائے تھے اور بچ کر چلتے تھے</p>"
        },
        "19": {
            "verses": {
                "41:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جس دن جمع ہونگے دشمن اللہ کے دوزخ پر پھر ان کی جماعتیں بنائی جائیں گی</p>"
        },
        "20": {
            "verses": {
                "41:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہاں تک کہ جب پہنچیں اس پر بتائیں گے ان کو ان کے کان اور ان کی آنکھیں اور ان کے چمڑے جو کچھ وہ کرتے تھے</p>"
        },
        "21": {
            "verses": {
                "41:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور وہ کہیں گے اپنے چمڑوں کو تم نے کیوں بتلایا ہم کو وہ بولیں گے ہم کو بلوایا اللہ نے جس نے بلوایا ہر چیز کو اور اسی نے بنایا تم کو پہلی بار اور اسی کی طرف پھیرے جاتے ہو</p>"
        },
        "22": {
            "verses": {
                "41:22": {
                    "id": 22
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور تم پردہ نہ کرتے تھے اس بات سے کہ تم کو بتلائیں گے تمہارے کان اور نہ تمہاری آنکھیں اور نہ تمہارے چمڑے پر تم کو یہ خیال تھا کہ اللہ نہیں جانتا بہت چیزیں جو تم کرتے ہو</p>"
        },
        "23": {
            "verses": {
                "41:23": {
                    "id": 23
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور یہ وہی تمہارا خیال ہے جو تم رکھتے تھے اپنے رب کے حق میں اسی نے تم کو غارت کیا پھر آج رہ گئے ٹوٹے میں</p>"
        },
        "24": {
            "verses": {
                "41:24": {
                    "id": 24
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر اگر وہ صبر کریں تو آگ ان کا گھر ہے اور اگر وہ منایا چاہیں تو ان کو کوئی نہیں مناتا</p>"
        },
        "25": {
            "verses": {
                "41:25": {
                    "id": 25
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور لگا دیئے ہم نے ان کے پیچھے ساتھ رہنے والے پھر انہوں نے خوبصورت بنادیا ان کی آنکھوں میں اس کو جو ان کے آگے ہے اور جو ان کے پیچھے ہے اور ٹھیک پڑچکی ان پر عذاب کی بات ان فرقوں کے ساتھ جو گزر چکے ان سے پہلے جنوں کے اور آدمیوں کے بیشک وہ تھے ٹوٹے والے۔</p>"
        },
        "26": {
            "verses": {
                "41:26": {
                    "id": 26
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہنے لگے منکر مت کان دھڑ اس قرآن کے سننے کو اور بک بک کرو اس کے پڑھنے میں شاید تم غالب ہو</p>"
        },
        "27": {
            "verses": {
                "41:27": {
                    "id": 27
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو ہم کو ضرور چکھانا ہے منکروں کو سخت عذاب اور ان کو بدلہ دینا ہے برے سے برے کاموں کا جو وہ کرتے تھے</p>"
        },
        "28": {
            "verses": {
                "41:28": {
                    "id": 28
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ سزا ہے اللہ کے دشمنوں کی آگ ان کا اسی میں گھر ہے سدا کو بدلہ اس کا جو ہماری باتوں سے انکار کرتے تھے</p>"
        },
        "29": {
            "verses": {
                "41:29": {
                    "id": 29
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہیں گے وہ لوگ جو منکر ہیں اے رب ہمارے ہم کو دکھلا دے وہ دونوں جنہوں نے ہم کو بہکایا جو جن ہے اور جو آدمی کہ ڈالیں ہم ان کو اپنے پاؤں کے نیچے کہ وہ رہیں سب سے نیچے۔</p>"
        },
        "30": {
            "verses": {
                "41:30": {
                    "id": 30
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تحقیق جنہوں نے کہا رب ہمارا اللہ ہے پھر اسی پر قا ئم رہے ان پر اترتے ہیں فرشتے کہ تم مت ڈرو اور نہ غم کھاؤ اور خوشخبری سنو اس بہشت کی جس کا تم سے وعدہ تھا</p>"
        },
        "31": {
            "verses": {
                "41:31": {
                    "id": 31
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ہم ہیں تمہارے رفیق دنیا اور آخرت میں اور تمہارے لئے وہاں ہے جو چاہے جی تمہارا اور تمہارے لئے وہاں ہے جو کچھ مانگو</p>"
        },
        "32": {
            "verses": {
                "41:32": {
                    "id": 32
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>مہمانی ہے اس بخشنے والے مہربان کی طرف سے</h2>"
        },
        "33": {
            "verses": {
                "41:33": {
                    "id": 33
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اس سے بہتر کس کی بات جس نے بلایا اللہ کی طرف اور کیا نیک کام اور کہا میں حکم بردار ہوں</p>"
        },
        "34": {
            "verses": {
                "41:34": {
                    "id": 34
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور برابر نہیں نیکی اور نہ بدی جواب میں وہ کہہ جو اس سے بہتر ہو پھر تو دیکھ لے کہ تجھ میں اور جس میں دشمنی تھی گویا دوست دار ہے قرابت والا</p>"
        },
        "35": {
            "verses": {
                "41:35": {
                    "id": 35
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور یہ بات ملتی ہے انہی کو جو سہار رکھتے ہیں اور یہ بات ملتی ہے اسی کو جن کی بڑی قسمت ہے</p>"
        },
        "36": {
            "verses": {
                "41:36": {
                    "id": 36
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو کبھی چوک لگے تجھ کو شیطان کے چوک لگانے سے تو پناہ پکڑ اللہ کی بیشک وہی ہے سننے والا جاننے والا۔</p>"
        },
        "37": {
            "verses": {
                "41:37": {
                    "id": 37
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اس کی قدرت کے نمونے ہیں رات اور دن اور سورج اور چاند سجدہ نہ کرو سورج کو اور نہ چاند کو اور سجدہ کرو اللہ کو جس نے ان کو بنایا اگر تم اسی کو پوجتے ہو</p>"
        },
        "38": {
            "verses": {
                "41:38": {
                    "id": 38
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر اگر غرور کریں تو جو لوگ تیرے رب کے پاس ہیں پاکی بولتے رہتے ہیں اس کی رات اور دن اور وہ نہیں تھکتے</p>"
        },
        "39": {
            "verses": {
                "41:39": {
                    "id": 39
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ایک اس کی نشانی یہ کہ تو دیکھتا ہے زمین کو دبی پڑی پھر جب اتارا ہم نے اس پر پانی تازی ہوئی اور ابھری بیشک جس نے اس کو زندہ کیا وہ زندہ کرے گا مردوں کو وہ سب کچھ کرسکتا ہے۔</p>"
        },
        "40": {
            "verses": {
                "41:40": {
                    "id": 40
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جو لوگ ٹیرھے چلتے ہیں ہماری باتوں میں وہ ہم سے چھپے ہوئے نہیں بھلا ایک جو پڑتا ہے آگ میں وہ بہتر یا ایک جو آئے گا امن سے دن قیامت کے کئے جاؤ جو چاہو بیشک جو تم کرتے ہو وہ دیکھتا ہے</p>"
        },
        "41": {
            "verses": {
                "41:41": {
                    "id": 41
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جو لوگ منکر ہوئے نصیحت سے جب آئی ان کے پاس اور وہ کتاب ہے نادر</p>"
        },
        "42": {
            "verses": {
                "41:42": {
                    "id": 42
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اس پر جھوٹ کا دخل نہیں آگے سے اور نہ پیچھے سے اتاری ہوئی ہے حکمتوں والے سب تعریفوں والے کی</p>"
        },
        "43": {
            "verses": {
                "41:43": {
                    "id": 43
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تجھے وہی کہتے ہیں جو کہہ چکے ہیں سب رسولوں سے تجھ سے پہلے تیرے رب کے یہاں معافی بھی ہے اور سزا بھی ہے درد ناک</p>"
        },
        "44": {
            "verses": {
                "41:44": {
                    "id": 44
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر ہم اس کو کرتے قرآن اوپری زبان کا تو کہتے اس کی باتیں کیوں کھولی گئیں کیا اوپری زبان کی کتاب اور عربی لوگ تو کہہ یہ ایمان والوں کے لئے سوجھ ہے اور روگ کا دور کرنے والا اور جو یقین نہیں لاتے ان کے کانوں میں بوجھ ہے اور یہ قرآن ان کے حق میں اندھاپا ہے ان کو پکارتے ہیں دور کی جگہ سے</p>"
        },
        "45": {
            "verses": {
                "41:45": {
                    "id": 45
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ہم نے دی تھی موسیٰ کو کتاب پھر اس میں اختلاف پڑا اور اگر نہ ہوئی ایک بات جو پہلے نکل چکی تھی تیرے رب کی طرف سے تو ان میں فیصلہ ہوجاتا اور وہ ایسے دھوکے میں ہیں اس قرآن سے جو چین نہیں لینے دیتا</p>"
        },
        "46": {
            "verses": {
                "41:46": {
                    "id": 46
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جس کی بھلائی سو اپنے واسطے اور جس نے کی برائی و وہ بھی اسی پر اور تیرا رب ایسا نہیں جو ظلم کرے بندوں پر۔</p>"
        },
        "47": {
            "verses": {
                "41:47": {
                    "id": 47
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اسی کی طرف حوالہ ہے قیامت کی خبر کا اور نہیں نکلتے کوئی میوے اپنے غلاف سے اور نہیں رہتا حمل کسی مادہ کو اور نہ وہ جنے کہ جس کی اس کو خبر نہیں اور جس دن ان کو پکارے گا کہاں ہیں میرے شریک بولیں گے ہم نے تجھ کو کہہ سنایا ہم میں کوئی اس کا اقرار نہیں کرتا</p>"
        },
        "48": {
            "verses": {
                "41:48": {
                    "id": 48
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور چوک گیا ان سے جو پکارتے تھے پہلے اور سمجھ گئے کہ ان کو کہیں نہیں خلاصی</p>"
        },
        "49": {
            "verses": {
                "41:49": {
                    "id": 49
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>نہیں تھکتا آدمی مانگنے سے بھلائی اور اگر لگ جائے اس کو برائی تو آس توڑ بیٹھے ناامید ہوکر</p>"
        },
        "50": {
            "verses": {
                "41:50": {
                    "id": 50
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر ہم چکھائیں اس کو کچھ اپنی مہربانی پیچھے ایک تکلیف کے جو اس کو پہنچی تھی تو کہنے لگے یہ ہے میرے لائق اور میں نہیں سمجھتا کہ قیامت آنے والی ہے اور اگر میں پھر بھی گیا اپنے رب کی طرف بیشک میرے لئے ہے اس کے پاس خوبی سو ہم جتلا دیں گے منکروں کو جو انہوں نے کیا ہے اور چکھائیں گے ان کو ایک گاڑھا عذاب</p>"
        },
        "51": {
            "verses": {
                "41:51": {
                    "id": 51
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب ہم نعمتیں بھیجیں انسان پر تو ٹلا جاوے اور موڑ لے اپنی کروٹ اور جب لگے اس کو برائی تو دعائیں کرے چوڑی</p>"
        },
        "52": {
            "verses": {
                "41:52": {
                    "id": 52
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ بھلا دیکھو تو اگر یہ ہو اللہ کے پاس سے پھر تم نے اس کو نہ مانا پھر اس سے گمراہ زیادہ کون جو دور چلا جائے مخالف ہو کر</p>"
        },
        "53": {
            "verses": {
                "41:53": {
                    "id": 53
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اب ہم دکھلائیں گے ان کو اپنے نمونے دنیا میں اور خود ان کی جانوں میں یہاں تک کہ کھل جائے ان پر کہ یہ ٹھیک ہے کیا تیرا رب تھوڑا ہے ہر چیز پر گواہ ہونے کے لئے سنتا ہے</p>"
        },
        "54": {
            "verses": {
                "41:54": {
                    "id": 54
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ دھوکے میں ہیں اپنے رب کی ملاقات سے سنتا ہے وہ گھیر رہا ہے ہر چیز کو۔</p>"
        }
    }
