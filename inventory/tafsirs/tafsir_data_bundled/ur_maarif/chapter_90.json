            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور تجھ پر قید نہیں رہے گی اس شہر میں</h2>"
        },
        "3": {
            "verses": {
                "90:3": {
                    "id": 3
