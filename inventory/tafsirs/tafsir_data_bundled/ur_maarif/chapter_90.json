            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کہتا ہے میں نے خرچ کر ڈالا مال ڈھیروں</h2>"
        },
        "7": {
            "verses": {
