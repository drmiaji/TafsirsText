            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>تحقیق ہم نے بنایا آدمی کو محنت میں</h2>"
        },
        "5": {
            "verses": {
                "90:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کیا خیال رکھتا ہے وہ کہ اس پر بس نہ چلے گا کسی کا</h2>"
        },
        "6": {
            "verses": {
