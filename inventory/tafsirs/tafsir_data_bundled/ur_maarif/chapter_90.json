            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کیا خیال رکھتا ہے کہ دیکھا نہیں اس کو کسی نے</h2>"
        },
        "8": {
            "verses": {
