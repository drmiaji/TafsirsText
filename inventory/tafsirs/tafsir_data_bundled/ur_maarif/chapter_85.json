            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>قسم ہے آسمان کی جس میں برج ہیں</h2>"
        },
        "2": {
            "verses": {
                "85:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور اس دن کی جس کا وعدہ ہے</h2>"
        },
        "3": {
            "verses": {
                "85:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اس دن کی جو حاضر ہوتا ہے اور اس کی کہ جس کے پاس حاضر ہوتے ہیں</p>"
        },
        "4": {
            "verses": {
                "85:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>مارے گئے کھائیاں کھودنے والے</h2>"
        },
        "5": {
            "verses": {
                "85:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>آگ ہے بہت ایندھن والی</h2>"
        },
        "6": {
            "verses": {
                "85:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جب وہ اس پر بیٹھے</h2>"
        },
        "7": {
            "verses": {
                "85:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور جو کچھ وہ کرتے مسلمانوں کے ساتھ اپنی آنکھوں سے دیکھتے</h2>"
        },
        "8": {
            "verses": {
                "85:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ان سے بدلہ نہ لیتے تھے مگر اسی بات کا کہ وہ یقین لائے اللہ پر جو زبردست ہے تعریفوں والا</p>"
        },
        "9": {
            "verses": {
                "85:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جس کا راج ہے آسمانوں میں اور زمین میں اور اللہ کے سامنے ہر چیز</p>"
        },
        "10": {
            "verses": {
                "85:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تحقیق جو دین سے بچلائے ایمان والے مردوں کو اور عورتوں کو پھر توبہ نہ کی تو ان کے لئے عذاب ہے دوزخ کا اور ان کے لئے عذاب ہے آگ لگے کا</p>"
        },
        "11": {
            "verses": {
                "85:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بیشک جو لوگ یقین لائے اور کیں انہوں نے بھلائیاں ان کے لئے باغ ہیں جن کے نیچے بہتی ہیں نہریں یہ ہے بڑی مراد ملنی</p>"
        },
        "12": {
            "verses": {
                "85:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>بیشک تیرے رب کی پکڑ سخت ہے</h2>"
        },
        "13": {
            "verses": {
                "85:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>بیشک وہی کرتا ہے پہلی مرتبہ اور دوسری</h2>"
        },
        "14": {
            "verses": {
                "85:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور وہی ہے بخشنے والا محبت کرنے والا</h2>"
        },
        "15": {
            "verses": {
                "85:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>مالک عرش کا بڑی شان والا</h2>"
        },
        "16": {
            "verses": {
                "85:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کر ڈالنے والا جو چاہے</h2>"
        },
        "17": {
            "verses": {
                "85:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کیا پہنچی تجھ کو بات ان لشکروں کی</h2>"
        },
        "18": {
            "verses": {
                "85:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>فرعون اور ثمود کے</h2>"
        },
        "19": {
            "verses": {
                "85:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کوئی نہیں بلکہ منکر جھٹلاتے ہیں</h2>"
        },
        "20": {
            "verses": {
                "85:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور اللہ نے ان کو ہر طرف سے گھیر رکھا ہے</h2>"
        },
        "21": {
            "verses": {
                "85:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کوئی نہیں یہ قرآن ہے بڑی شان کا</h2>"
        },
        "22": {
            "verses": {
                "85:22": {
                    "id": 22
                }
            },
