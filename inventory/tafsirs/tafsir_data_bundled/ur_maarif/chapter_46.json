                "language_name": "english"
            },
            "text": "<p>حم</p>"
        },
        "2": {
            "verses": {
                "46:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اتارنا کتاب کا ہے اللہ زبردست حکمت والے کی طرف سے</h2>"
        },
        "3": {
            "verses": {
                "46:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ہم نے جو بنائے آسمان اور زمین اور جو ان کے بیچ میں ہے سو ٹھیک کام پر اور ایک ٹھہرے وعدہ پر اور جو لوگ منکر ہیں وہ ڈر کو سن کر منہ پھیر لیتے ہیں</p>"
        },
        "4": {
            "verses": {
                "46:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ بھلا دیکھو تو جن کو تم پکارتے ہو اللہ کے سوائے دکھلاؤ تو مجھ کو انہوں نے کیا بنایا زمین میں یا ان کا کچھ ساجھا ہے آسمانوں میں لاؤ میرے پاس کوئی کتاب اس سے پہلے کی یا کوئی علم جو چلا آتا ہو اگر ہو تم سچے</p>"
        },
        "5": {
            "verses": {
                "46:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اس سے زیادہ گمراہ کون جو پکارے اللہ کے سوائے ایسے کو نہ پہنچے اس کی پکار کو دن قیامت تک اور ان کو خبر نہیں ان کے پکارنے کی</p>"
        },
        "6": {
            "verses": {
                "46:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب لوگ جمع ہوں گے وہ ہوں گے ان کے دشمن اور ہوں گے ان کے پوجنے سے منکر۔</p>"
        },
        "7": {
            "verses": {
                "46:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب سنائی جائیں ان کو ہماری باتیں کھلی کھلی کہتے ہیں منکر سچی بات کو جب ان تک پہنچی یہ جادو ہے صریح</p>"
        },
        "8": {
            "verses": {
                "46:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا کہتے ہیں یہ بنالایا ہے تو کہہ اگر میں یہ بنالایا ہوں تو تم میرا بھلا نہیں کرسکتے اللہ کے سامنے ذرا بھی اس کو خوب خبر ہے جن باتوں میں تم لگ رہے ہو وہ کافی ہے حق بتانے والا میرے اور تمہارے بیچ اور وہی ہے بخشنے والا مہربان</p>"
        },
        "9": {
            "verses": {
                "46:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ میں کچھ نیا رسول نہیں آیا اور مجھ کو معلوم نہیں کیا ہونا ہے مجھ سے اور تم سے میں اسی پر چلتا ہوں جو حکم آتا ہے مجھ کو اور میرا کام تو یہی ہے ڈر سنا دینا کھول کر</p>"
        },
        "10": {
            "verses": {
                "46:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ بھلا دیکھو تو اگر یہ آیا ہو اللہ کے یہاں سے اور تم نے اس کو نہیں مانا اور گواہی دے چکا ایک گواہ بنی اسرائیل کا ایک ایسی کتاب کی پھر وہ یقین لایا اور تم نے غرور کیا بیشک اللہ راہ نہیں دیتا گنہگاروں کو۔</p>"
        },
        "11": {
            "verses": {
                "46:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہنے لگے منکر ایمان والوں کو اگر یہ دین بہتر ہوتا تو یہ نہ دوڑتے اس پر ہم سے پہلے اور جب راہ پر نہیں آئے اس کے بتلانے سے تو یہ اب کہیں گے یہ جھوٹ ہے بہت پرانا</p>"
        },
        "12": {
            "verses": {
                "46:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اس سے پہلے کتاب موسیٰ کی تھی راہ ڈالنے والی اور رحمت اور یہ کتاب ہے اس کی تصدیق کرتی عربی زبان میں تاکہ ڈر سنائے گنہگاروں کو اور خوشخبری نیکی والوں کو۔</p>"
        },
        "13": {
            "verses": {
                "46:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>مقرر جنہوں نے کہا رب ہمارا اللہ ہے پھر ثابت قدم رہے تو نہ ڈر ہے ان پر اور نہ وہ غمگین ہوں گے</p>"
        },
        "14": {
            "verses": {
                "46:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ لوگ ہیں بہشت والے سدا رہیں گے اس میں بدلہ ہے ان کاموں کا جو کرتے تھے</p>"
        },
        "15": {
            "verses": {
                "46:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ہم نے حکم کردیا انسان کو اپنے ماں باپ سے بھلائی کا پیٹ میں رکھا اس کو اس کی ماں نے تکلیف سے اور جنا اس کو تکلیف سے اور حمل میں رہنا اس کا اور دودھ چھوڑنا تیس مہینے میں ہے یہاں تک کہ جب پہنچا اپنی قوت کو اور پہنچ گیا چالیس برس کو کہنے لگا اے رب میرے میری قسمت میں کر کہ شکر کروں تیرے احسان کا جو تو نے مجھ پر کیا اور میرے ماں باپ پر اور یہ کہ کروں نیک کام جس سے تو راضی ہو اور مجھ کو دے نیک اولاد میری، میں نے توبہ کی تیری طرف اور میں ہوں حکمبردار</p>"
        },
        "16": {
            "verses": {
                "46:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ وہ لوگ ہیں جن سے ہم قبول کرتے ہیں بہتر سے بہتر کام جو کئے ہیں اور معاف کرتے ہیں ہم برائیاں ان کی رہنے والے جنت کے لوگوں میں سچا وعدہ جو ان سے کیا جاتا تھا</p>"
        },
        "17": {
            "verses": {
                "46:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا مجھ کو وعدہ دیتے ہو کہ میں نکالا جاؤں گا قبر سے اور گزر چکی ہیں بہت جماعتیں مجھ سے پہلے اور وہ دونوں فریاد کرتے ہیں اللہ سے کہ اے خرابی تیری تو ایمان لے آ بیشک وعدہ اللہ کا ٹھیک ہے پھر کہتا ہے یہ سب نقلیں ہیں پہلوں کی</p>"
        },
        "18": {
            "verses": {
                "46:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ وہ لوگ ہیں کہ جن پر ثابت ہوئی بات عذاب کی شامل اور فرقوں میں جو گزر چکے ہیں ان سے پہلے جنوں کے اور آدمیوں کے بیشک وہ تھے ٹوٹے میں پڑے</p>"
        },
        "19": {
            "verses": {
                "46:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ہر فرقے کے کئی درجے ہیں اپنے کئے کاموں کے موافق اور تاکہ پورے دے ان کو کام ان کے اور ان پر ظلم نہ ہوگا</p>"
        },
        "20": {
            "verses": {
                "46:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ہر فرقے کے کئی درجے ہیں اپنے کئے کاموں کے موافق اور تاکہ پورے دے ان کو کام ان کے اور ان پر ظلم نہ ہوگا</p>"
        },
        "21": {
            "verses": {
                "46:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور یاد کر عاد کے بھائی کو جب ڈرایا اپنی قوم کو احقاف میں اور گزر چکے تھے ڈرانے والے اس کے آگے سے اور پیچھے سے کہ بندگی نہ کرو کسی کی اللہ کے سوائے میں ڈرتا ہوں تم پر آفت سے ایک بڑے دن کی</p>"
        },
        "22": {
            "verses": {
                "46:22": {
                    "id": 22
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بولے کیا تو آیا ہے ہمارے پاس کہ پھیر دے ہم کو ہمارے معبودوں سے سو لے آ ہم پر جو وعدہ کرتا ہے اگر ہے تو سچا</p>"
        },
        "23": {
            "verses": {
                "46:23": {
                    "id": 23
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کہا یہ خبر تو اللہ ہی کو ہے اور میں تو پہنچا دیتا ہوں جو کچھ بھیج دیا میرے ہاتھ لیکن میں دیکھتا ہوں تم لوگ نادانی کرتے ہو</p>"
        },
        "24": {
            "verses": {
                "46:24": {
                    "id": 24
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر جب دیکھا اس کو ابر سامنے آیا ان کے نالوں کے بولے یہ ابر ہے ہم پر برسے گا کوئی نہیں یہ تو وہ چیز ہے جس کی تم جلدی کرتے تھے ہوا ہے جس میں عذاب ہے درد ناک</p>"
        },
        "25": {
            "verses": {
                "46:25": {
                    "id": 25
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اکھاڑ پھینکے ہر چیز کو اپنے رب کے حکم سے پھر کل کو رہ گئے کہ کوئی نظر نہیں آتا تھا سوائے ان کے گھروں کے یوں ہم سزا دیتے ہیں گنہگار لوگوں کو</p>"
        },
        "26": {
            "verses": {
                "46:26": {
                    "id": 26
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ہم نے مقدور دیا تھا ان کو ان چیزوں کا جن کا تم کو مقدور نہیں دیا اور ہم نے ان کو دیئے تھے کان اور آنکھیں اور دل پھر کام نہ آئے ان کے کان ان کے اور نہ آنکھیں ان کی اور نہ دل ان کے کسی چیز میں اس لئے کہ منکر ہوتے تھے اللہ کی باتوں سے اور الٹ پڑی ان پر جس بات سے کہ وہ ٹھٹھا کرتے تھے۔</p>"
        },
