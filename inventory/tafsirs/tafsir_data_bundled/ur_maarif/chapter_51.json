            },
            "text": "<h2>قسم ہے ان ہواؤں کی بکھیرتی ہیں اڑا کر</h2>"
        },
        "2": {
            "verses": {
                "51:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر اٹھانے والیاں بوجھ کو</h2>"
        },
        "3": {
            "verses": {
                "51:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر چلنے والیاں نرمی سے</h2>"
        },
        "4": {
            "verses": {
                "51:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر بانٹنے والیاں حکم سے</h2>"
        },
        "5": {
            "verses": {
                "51:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>بیشک جو وعدہ کیا ہے تم سے سو سچ ہے</h2>"
        },
        "6": {
            "verses": {
                "51:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور بیشک انصاف ہونا ضرور ہے</h2>"
        },
        "7": {
            "verses": {
                "51:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>قسم ہے آسمان جال دار کی</h2>"
        },
        "8": {
            "verses": {
                "51:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>تم پڑ رہے ہو ایک جھگڑے کی بات میں</h2>"
        },
        "9": {
            "verses": {
                "51:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اس سے باز ہے وہی جو پھیرا گیا</h2>"
        },
        "10": {
            "verses": {
                "51:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>مارے گئے اٹکل دوڑانے والے</h2>"
        },
        "11": {
            "verses": {
                "51:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>وہ جو غفلت میں ہیں بھول رہے</h2>"
        },
        "12": {
            "verses": {
                "51:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پوچھتے ہیں کب ہے دن انصاف کا</h2>"
        },
        "13": {
            "verses": {
                "51:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جس دن وہ آگ پر الٹے سیدھے پڑیں گے</h2>"
        },
        "14": {
            "verses": {
                "51:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>چکھو مزہ اپنی شرارت کا یہ ہے جس کی تم جلدی کرتے تھے</h2>"
        },
        "15": {
            "verses": {
                "51:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>البتہ ڈرنے والے باغوں میں ہیں اور چشموں میں</h2>"
        },
        "16": {
            "verses": {
                "51:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>لیتے ہیں جو دیا ان کو ان کے رب نے وہ تھے اس سے پہلے نیکی والے</p>"
        },
        "17": {
            "verses": {
                "51:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>وہ تھے رات کو تھوڑا سوتے</h2>"
        },
        "18": {
            "verses": {
                "51:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور صبح کے وقتوں میں معافی مانگتے</h2>"
        },
        "19": {
            "verses": {
                "51:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور ان کے مال میں حصہ تھا مانگنے والوں کا اور ہارے ہوئے کا</h2>"
        },
        "20": {
            "verses": {
                "51:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور زمین میں نشانیاں ہیں یقین لانے والوں کے واسطے</h2>"
        },
        "21": {
            "verses": {
                "51:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور خود تمہارے اندر سو کیا تم کو سوجھتا نہیں</h2>"
        },
        "22": {
            "verses": {
                "51:22": {
                    "id": 22
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور آسمان میں ہے روزی تمہاری اور جو تم سے وعدہ کیا گیا</h2>"
        },
        "23": {
            "verses": {
                "51:23": {
                    "id": 23
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو قسم ہے رب آسمان اور زمین کی کہ یہ بات تحقیق ہے جیسے کہ تم بولتے ہو۔</p>"
        },
        "24": {
            "verses": {
                "51:24": {
                    "id": 24
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا پہنچی ہے تجھ کو بات ابراہیم کے مہمانوں کی جو عزت والے تھے</p>"
        },
        "25": {
            "verses": {
                "51:25": {
                    "id": 25
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جب اندر پہنچے اس کے پاس تو بولے سلام وہ بولا سلام ہے یہ لوگ ہیں اوپرے</p>"
        },
        "26": {
            "verses": {
                "51:26": {
                    "id": 26
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر دوڑا اپنے گھر کو تو لے آیا ایک بچھڑا گھی میں تلا ہوا</h2>"
        },
        "27": {
            "verses": {
                "51:27": {
                    "id": 27
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر ان کے سامنے رکھا کہا کیوں تم کھاتے نہیں</h2>"
        },
        "28": {
            "verses": {
                "51:28": {
                    "id": 28
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر جی میں گھبرایا ان کے ڈر سے بولے تو مت ڈر اور خوشخبری دی اس کو ایک لڑکے ہوشیار کی</p>"
        },
        "29": {
            "verses": {
                "51:29": {
                    "id": 29
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر سامنے سے آئی اس کی عورت بولتی ہوئی پھر پیٹا اپنا ماتھا اور کہنے لگی کہیں بڑھیا بانجھ</p>"
        },
        "30": {
            "verses": {
                "51:30": {
                    "id": 30
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ بولے یونہی کہا تیرے رب نے وہ جو ہے وہی ہے حکمت والا خبردار</p>"
        },
        "31": {
            "verses": {
                "51:31": {
                    "id": 31
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>بولا پھر کیا مطلب ہے تمہارا اے بھیجے ہوؤ</h2>"
        },
        "32": {
            "verses": {
                "51:32": {
                    "id": 32
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>وہ بولے ہم کو بھیجا گیا ہے ایک گنہگار قوم پر</h2>"
        },
        "33": {
            "verses": {
                "51:33": {
                    "id": 33
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کہ چھوڑیں ہم ان پر پتھر مٹی کے</h2>"
        },
        "34": {
            "verses": {
                "51:34": {
                    "id": 34
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>نشان پڑے ہوئے تیرے رب کے یہاں سے حد سے نکل چلنے والوں کیلئے</h2>"
        },
        "35": {
            "verses": {
                "51:35": {
                    "id": 35
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر بچا نکالا ہم نے جو تھا وہاں ایمان والا پھر نہ پایا ہم نے اس جگہ</p>"
        },
        "36": {
            "verses": {
                "51:36": {
                    "id": 36
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>سوائے ایک گھر کے مسلمانوں سے</h2>"
        },
        "37": {
            "verses": {
                "51:37": {
                    "id": 37
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور باقی رکھا ہم نے اس میں نشان ان لوگوں کے لئے جو ڈرتے ہیں عذاب درد ناک سے</p>"
        },
        "38": {
            "verses": {
                "51:38": {
                    "id": 38
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور نشانی ہے موسیٰ (کے حال) میں جب بھیجا ہم نے اس کو فرعون کے پاس دیکر کھلی سند</p>"
        },
        "39": {
            "verses": {
                "51:39": {
                    "id": 39
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر اس نے منہ موڑ لیا اپنے زور سر اور بولا یہ جادو گر ہے یا دیوانہ</p>"
        },
        "40": {
            "verses": {
                "51:40": {
                    "id": 40
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر پکڑا ہم نے اس کو اور اس کے لشکروں کو پھر پھینک دیا اور ان کو دریا میں اور اس پر لگا الزام</p>"
        },
        "41": {
            "verses": {
                "51:41": {
                    "id": 41
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور نشانی ہے عاد میں جب بھیجی ہم نے ان پر ہوا خبر سے خالی</h2>"
        },
        "42": {
            "verses": {
                "51:42": {
                    "id": 42
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>نہیں چھوڑتی کسی چیز کو جس پر گزرے کہ نہ کر ڈالے اس کو جیسے چورا</p>"
        },
        "43": {
            "verses": {
                "51:43": {
                    "id": 43
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور نشانی ہے ثمود میں جب کہا ان کو برت لو ایک وقت تک</h2>"
        },
        "44": {
            "verses": {
                "51:44": {
                    "id": 44
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر شرارت کرنے لگے اپنے رب کے حکم سے پھر پکڑا ان کو کڑک نے اور وہ دیکھتے تھے</p>"
        },
        "45": {
            "verses": {
                "51:45": {
                    "id": 45
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر نہ ہوسکا ان سے کہ اٹھیں اور نہ ہوئے کہ بدلہ لیں</h2>"
        },
        "46": {
            "verses": {
                "51:46": {
                    "id": 46
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ہلاک کیا نوح کی قوم کو اس سے پہلے تحقیق وہ تھے لوگ نافرمان۔</p>"
        },
        "47": {
            "verses": {
                "51:47": {
                    "id": 47
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور بنایا ہم نے آسمان ہاتھ کے بل سے اور ہم کو سب مقدور ہے</h2>"
        },
        "48": {
            "verses": {
                "51:48": {
                    "id": 48
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور زمین کو بچھایا ہم نے سو کیا خوب بچھانا جانتے ہیں ہم</h2>"
        },
        "49": {
            "verses": {
                "51:49": {
                    "id": 49
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور ہر چیز کے بنائے ہم نے جوڑے تاکہ تم دھیان کرو</h2>"
        },
        "50": {
            "verses": {
                "51:50": {
                    "id": 50
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو بھاگو اللہ کی طرف میں تم کو اس کی طرف سے ڈر سناتا ہوں کھول کر</p>"
        },
        "51": {
            "verses": {
                "51:51": {
                    "id": 51
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور مت ٹھہراؤ اللہ کے ساتھ اور کسی کو معبود میں تم کو اس کی طرف سے ڈر سناتا ہوں کھول کر</p>"
        },
        "52": {
            "verses": {
                "51:52": {
                    "id": 52
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اسی طرح ان سے پہلے لوگوں کے پاس جو رسول آیا اس کو یہی کہا کہ جادوگر ہے یا دیوانہ</p>"
        },
        "53": {
            "verses": {
                "51:53": {
                    "id": 53
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا یہی وصیت کر مرے ہیں ایک دوسرے کو کوئی نہیں پر یہ لوگ شریر ہیں</p>"
        },
        "54": {
            "verses": {
                "51:54": {
                    "id": 54
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>سو تو لوٹ آ ان کی طرف سے اب تجھ پر نہیں ہے الزام</h2>"
        },
        "55": {
            "verses": {
                "51:55": {
                    "id": 55
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور سمجھاتا رہ کہ سمجھانا کام آتا ہے ایمان والوں کو۔</h2>"
        },
        "56": {
            "verses": {
                "51:56": {
                    "id": 56
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور میں نے جو بنائے جن اور آدمی سو اپنی بندگی کو</h2>"
        },
        "57": {
            "verses": {
                "51:57": {
                    "id": 57
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>میں نہیں چاہتا ان سے روزینہ اور نہیں چاہتا کہ مجھ کو کھلائیں</p>"
        },
        "58": {
            "verses": {
                "51:58": {
                    "id": 58
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اللہ جو ہے وہی ہے روزی دینے والا زور آور مضبوط</h2>"
        },
        "59": {
            "verses": {
                "51:59": {
                    "id": 59
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو ان گنہگاروں کا بھی ڈول بھر چکا ہے جیسے ڈول بھرا ان کے ساتھیوں کا اب مجھ سے جلدی نہ کریں</p>"
        },
        "60": {
            "verses": {
                "51:60": {
                    "id": 60
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو خرابی ہے منکروں کو ان کے اس دن سے جس کا ان سے وعدہ ہوچکا ہے۔</p>"
        }
    }
