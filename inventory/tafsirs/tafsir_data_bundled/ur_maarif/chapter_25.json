            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور وہ لوگ جو کہتے ہیں اے رب دے ہم کو ہماری عورتوں کی طرف سے اور اولاد کی طرف سے آنکھ کی ٹھنڈک اور کر ہم کو پرہیزگاروں کا پیشوا</p>"
        },
