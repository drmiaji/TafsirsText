            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور بندے رحمن کے وہ ہیں جو چلتے ہیں زمین پر دبے پاؤں اور جب بات کرنے لگیں ان سے بےسمجھ لوگ تو کہیں صاحب سلامت</p>"
        },
