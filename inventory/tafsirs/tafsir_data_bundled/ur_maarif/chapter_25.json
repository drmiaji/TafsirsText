            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو کوئی توبہ کرے اور کرے کام نیک سو وہ پھر آتا ہے اللہ کی طرف پھر آنے کی جگہ</p>"
        },
