            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور وہ لوگ کہ جب خرچ کرنے لگیں نہ بےجا اڑائیں اور نہ تنگی کریں اور ہے اس کے بیچ ایک سیدھی گزران</p>"
        },
        "68": {
            "verses": {
