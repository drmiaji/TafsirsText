            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور وہ لوگ کہ جب ان کو سمجھایئے ان کے رب کی باتیں نہ پڑیں ان پر بہرے اندھے ہو کر</p>"
        },
