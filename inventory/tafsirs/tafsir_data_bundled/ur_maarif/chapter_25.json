            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>دونا ہوگا، اس کو عذاب قیامت کے دن اور پڑا رہے گا اس میں خوار ہو کر</p>"
        },
        "70": {
            "verses": {
                "25:70": {
                    "id": 70
