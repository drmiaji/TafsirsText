            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور وہ لوگ کہ نہیں پکارتے اللہ کے ساتھ دوسرے حاکم کو اور نہیں خون کرتے جان کا جو منع کردی اللہ نے مگر جہاں چاہئے اور بدکاری نہیں کرتے اور جو کوئی کرے یہ کام وہ جا پڑا گناہ میں</p>"
        },
        "69": {
            "verses": {
