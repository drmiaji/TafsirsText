{
    "chapter": 25,
    "verses": {
        "1": {
            "verses": {
                "25:1": {
                    "id": 1
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بڑی برکت ہے اس کی جس نے اتاری فیصلہ کی کتاب اپنے بندہ پر تاکہ رہے جہان والوں کے لئے ڈرانے والا</p>"
        },
        "2": {
            "verses": {
                "25:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ کہ جس کی ہے سلطنت آسمان اور زمین میں اور نہیں پکڑا اس نے بیٹا اور نہیں کوئی اس کا ساجھی سلطنت میں اور بتائی ہر چیز پھر ٹھیک کیا اس کو ماپ کر</p>"
        },
        "3": {
            "verses": {
                "25:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور لوگوں نے پکڑ رکھے ہیں اس سے ورے کتنے حاکم جو نہیں بناتے کچھ چیز اور وہ خود بنائے گئے ہیں اور نہیں مالک اپنے حق میں برے کے اور نہ بھلے کے اور نہیں مالک مرنے کے اور نہ جینے کے اور نہ جی اٹھنے کے۔</p>"
        },
        "4": {
            "verses": {
                "25:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہنے لگے جو منکر ہیں اور کچھ نہیں ہے یہ مگر طوفان باندھ لایا ہے اور ساتھ دیا ہے اس کا اس میں اور لوگوں نے سو آگئے بےانصافی اور جھوٹ پر</p>"
        },
        "5": {
            "verses": {
                "25:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہنے لگے یہ نقلیں ہیں پہلوں کی جن کو اس نے لکھ رکھا ہے سو وہ ہی لکھوائی جاتی ہیں اس کے پاس صبح اور شام</p>"
        },
        "6": {
            "verses": {
                "25:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ اس کو اتارا ہے اس نے جو جانتا ہے چھپے ہوئے بھید آسمانوں میں اور زمین میں بیشک وہ بخشنے والا مہربان ہے</p>"
        },
        "7": {
            "verses": {
                "25:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہنے لگے یہ کیسا رسول ہے کھاتا ہے کھانا اور پھرتا ہے بازاروں میں کیوں نہ اترا اس کی طرف کوئی فرشتہ کہ رہتا اس کے ساتھ ڈرانے کو</p>"
        },
        "8": {
            "verses": {
                "25:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یا آپڑتا اس کے پاس خزانہ یا ہوجاتا اس کے لئے ایک باغ کہ کھایا کرتا اس میں سے، اور کہنے لگے بےانصاف تم پیروی کرتے ہو اس ایک مرد جادو مارے کی</p>"
        },
        "9": {
            "verses": {
                "25:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>دیکھ کیسی بٹھلاتے ہیں تجھ پر مثلیں سو بہک گئے اب پا نہیں سکتے راستہ۔</p>"
        },
        "10": {
            "verses": {
                "25:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بڑی برکت ہے اس کی جو چاہے تو کر دے تیرے واسطے اس سے بہتر باغ کہ نیچے بہتی ہیں ان کے نہریں اور کر دے تیرے واسطے محل</p>"
        },
        "11": {
            "verses": {
                "25:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کچھ نہیں وہ جھٹلاتے ہیں قیامت کو اور ہم نے تیار کی ہے اس کے واسطے کہ جھٹلاتا ہے قیامت کو آگ ،</p>"
        },
        "12": {
            "verses": {
                "25:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جب وہ دیکھے گی ان کو دور کی جگہ سے سنیں گے اس کا جھنجھلانا اور چلانا</p>"
        },
        "13": {
            "verses": {
                "25:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب ڈالے جائیں گے اس کے اندر ایک جگہ تنگ میں ایک زنجیر میں کئی کئی بندھے ہوئے پکاریں گے اس جگہ موت کو</p>"
        },
        "14": {
            "verses": {
                "25:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>مت پکارو آج ایک مرنے کو اور پکارو بہت سے مرنے کو</h2>"
        },
        "15": {
            "verses": {
                "25:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ بھلا یہ چیز بہتر ہے یا باغ ہمیشہ رہنے کا جس کا وعدہ ہوچکا پرہیزگاروں سے وہ ہوگا ان کا بدلہ اور پھرجانے کی جگہ</p>"
        },
        "16": {
            "verses": {
                "25:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ان کے واسطے وہاں ہے جو وہ چاہیں رہا کریں ہمیشہ ہوچکا تیرے رب کے ذمہ وعدہ مانگا ملتا</p>"
        },
        "17": {
            "verses": {
                "25:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جس دن جمع کر بلائے گا ان کو اور جن کو وہ پوجتے ہیں اللہ کے سوائے پھر ان سے کہے گا کیا تم نے بہکایا میرے ان بندوں کو یا وہ آپ بہکے راہ سے</p>"
        },
        "18": {
            "verses": {
                "25:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بولیں گے تو پاک ہے ہم سے بن نہ آتا تھا کہ پکڑ لیں کسی کو تیرے بغیر رفیق لیکن تو ان کو فائدہ پہنچاتا رہا اور ان کے باپ دادوں کو یہاں تک کہ بھلا بیٹھے تیری یاد اور یہ تھے لوگ تباہ ہونے والے ،</p>"
        },
        "19": {
            "verses": {
                "25:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو وہ تو جھٹلا چکے تم کو تمہاری بات میں اب نہ تم لوٹا سکتے ہو اور نہ مدد کرسکتے ہو اور جو کوئی تم میں گنہگار ہے اس کو ہم چکھائیں گے بڑا عذاب</p>"
        },
        "20": {
            "verses": {
                "25:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جتنے بھیجے ہم نے تجھ سے پہلے رسول سب کھاتے تھے کھانا اور پھرتے تھے بازاروں میں اور ہم نے رکھا ہے تم میں ایک دوسرے کے جانچنے کو، دیکھیں ثابت بھی رہتے ہو اور تیرا رب سب کچھ دیکھتا ہے</p>"
        },
        "21": {
            "verses": {
                "25:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور بولے وہ لوگ جو امید نہیں رکھتے کہ ہم سے ملیں گے کیوں نہ اترے ہم پر فرشتے یا ہم دیکھ لیتے اپنے رب کو، بہت بڑائی رکھتے ہیں اپنے جی میں اور سر چڑھ رہے ہیں بڑی شرارت میں</p>"
        },
        "22": {
            "verses": {
                "25:22": {
                    "id": 22
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جس دن دیکھیں گے فرشتوں کو کچھ خوشخبری نہیں اس دن گنہگاروں کو اور کہیں گے کہیں روک دی جائے کوئی آڑ۔</p>"
        },
        "23": {
            "verses": {
                "25:23": {
                    "id": 23
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ہم پہنچے ان کے کاموں پر جو انہوں نے کئے تھے پھر ہم نے کر ڈالا اس کو خاک اڑتی ہوئی</p>"
        },
        "24": {
            "verses": {
                "25:24": {
                    "id": 24
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بہشت کے لوگوں کا اس دن خوب ہے ٹھکانا اور خوب ہے جگہ دوپہر کے آرام کی</p>"
        },
        "25": {
            "verses": {
                "25:25": {
                    "id": 25
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جس دن پھٹ جائے آسمان بادل سے اور اتارے جائیں فرشتے تار لگا کر</p>"
        },
        "26": {
            "verses": {
                "25:26": {
                    "id": 26
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>بادشاہی اس دن سچی ہے رحمن کی اور ہے وہ دن منکروں پر مشکل</h2>"
        },
        "27": {
            "verses": {
                "25:27": {
                    "id": 27
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جس دن کاٹ کاٹ کھائے گا گنہگار اپنے ہاتھوں کو کہے گا اے کاش کہ میں نے پکڑا ہوتا رسول کے ساتھ رستہ</p>"
        },
        "28": {
            "verses": {
                "25:28": {
                    "id": 28
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اے خرابی میری کاش کہ نہ پکڑا ہوتا میں نے فلانے کو دوست</h2>"
        },
        "29": {
            "verses": {
                "25:29": {
                    "id": 29
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اس نے تو بہکا دیا مجھ کو نصیحت سے مجھ تک پہنچ چکنے کے پیچھے، اور ہے شیطان آدمی کو وقت پر دغا دینے والا</p>"
        },
        "30": {
            "verses": {
                "25:30": {
                    "id": 30
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہا رسول نے اے میرے رب میری قوم نے ٹھہرایا ہے اس قرآن کو جھک جھک</p>"
        },
        "31": {
            "verses": {
                "25:31": {
                    "id": 31
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اسی طرح رکھے ہیں ہم نے ہر نبی کے لئے دشمن گنہگاروں میں سے اور کافی ہے تیرا رب راہ دکھلانے کو اور مدد کرنے کو۔</p>"
        },
        "32": {
            "verses": {
                "25:32": {
                    "id": 32
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہنے لگے وہ لوگ جو منکر ہیں کیوں نہ اترا اس پر قرآن سارا ایک جگہ ہو کر اسی طرح اتارا تاکہ ثابت رکھیں ہم اس سے تیرا دل اور پڑھ سنایا ہم نے اس کو ٹھہر ٹھہر کر۔</p>"
        },
        "33": {
            "verses": {
                "25:33": {
                    "id": 33
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور نہیں لاتے تیرے پاس کوئی مثال کہ ہم نہیں پہنچا دیتے تجھ کو ٹھیک بات اور اس سے بہتر کھول کر</p>"
        },
        "34": {
            "verses": {
                "25:34": {
                    "id": 34
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جو لوگ کہ گھیر کر لائیں جائیں گے اوندھے پڑے ہوئے اپنے منہ پر دوزخ کی طرف، انہی کا برا درجہ ہے اور بہت بہکے ہوئے ہیں راہ سے</p>"
        },
        "35": {
            "verses": {
                "25:35": {
                    "id": 35
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ہم نے دی موسیٰ کو کتاب اور کردیا ہم نے اس کے ساتھ اس کا بھائی ہارون کام بٹانے والا</p>"
        },
        "36": {
            "verses": {
                "25:36": {
                    "id": 36
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر کہا ہم نے تم دونوں جاؤ ان لوگوں کے پاس جنہوں نے جھٹلایا ہماری باتوں کو پھر دے مارا ہم نے ان کو اکھاڑ کر۔</p>"
        },
        "37": {
            "verses": {
                "25:37": {
                    "id": 37
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور نوح کی قوم کو جب انہوں نے جھٹلایا پیغام لانے والوں کو ہم نے ان کو ڈبا دیا اور کیا ان کو لوگوں کے حق میں نشانی اور تیار کر رکھا ہے ہم نے گنہگاروں کے واسطے عذاب درد ناک</p>"
        },
        "38": {
            "verses": {
                "25:38": {
                    "id": 38
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور عاد کو اور ثمود کو اور کنوئیں والوں کو اور اس کے بیچ میں بہت سی جماعتوں کو</p>"
        },
        "39": {
            "verses": {
                "25:39": {
                    "id": 39
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور سب کو کہہ سنائیں ہم نے مثالیں اور سب کو کھو دیا ہم نے غارت کر کر</p>"
        },
        "40": {
            "verses": {
                "25:40": {
                    "id": 40
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور یہ لوگ ہو آئے ہیں اس بستی کے پاس جن پر برسا برا برساؤ کیا دیکھتے نہ تھے اس کو، نہیں پر امید نہیں رکھتے جی اٹھنے کی</p>"
        },
        "41": {
            "verses": {
                "25:41": {
                    "id": 41
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جہاں تجھ کو دیکھیں کچھ کام نہیں ان کو تجھ سے مگر ٹھٹھے کرتے کیا یہی ہے جس کو بھیجا اللہ نے پیغام دے کر</p>"
        },
        "42": {
            "verses": {
                "25:42": {
                    "id": 42
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ تو ہم کو بچلا ہی دیتا ہمارے معبودوں سے اگر ہم نہ جمے رہتے ان پر اور آگے جان لیں گے جس وقت دیکھیں گے عذاب کو کہ کون بہت بچلا ہوا ہے راہ سے</p>"
        },
        "43": {
            "verses": {
                "25:43": {
                    "id": 43
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بھلا دیکھ تو اس شخص کو جس نے پوجنا اختیار کیا اپنی خواہش کا، کہیں تو لے سکتا ہے اس کا ذمہ</p>"
        },
        "44": {
            "verses": {
                "25:44": {
                    "id": 44
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یا تو خیال رکھتا ہے کہ بہت سے ان میں سنتے یا سمجھتے ہیں اور کچھ نہیں وہ برابر ہیں چوپایوں کے بلکہ وہ زیادہ بہکے ہوئے ہیں راہ سے۔</p>"
        },
        "45": {
            "verses": {
                "25:45": {
                    "id": 45
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو نے نہیں دیکھا اپنے رب کی طرف کیسے دراز کیا سایہ کو اور اگر چاہتا تو اس کو ٹھہرا رکھتا پھر ہم نے مقرر کیا سورج کو اس کا راہ بتلانے والا</p>"
        },
        "46": {
            "verses": {
                "25:46": {
                    "id": 46
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر کھینچ لیا ہم نے اس کو اپنی طرف سہج سہج سمیٹ کر</h2>"
        },
        "47": {
            "verses": {
                "25:47": {
                    "id": 47
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور وہی ہے جس نے بنادیا تمہارے واسطے رات کو اوڑھنا اور نیند کو آرام اور دن کو بنادیا اٹھ نکلنے کے لئے</p>"
        },
        "48": {
            "verses": {
                "25:48": {
                    "id": 48
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور وہی ہے جس نے چلائیں ہوائیں خوشخبری لانے والیاں اس کی رحمت سے آگے اور اتارا ہم نے آسمان سے پانی پاکی حاصل کرنے کا</p>"
        },
        "49": {
            "verses": {
                "25:49": {
                    "id": 49
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کہ زندہ کردیں اس سے مرے ہوئے دیس کو اور پلائیں اس کو اپنے پیدا کئے ہوئے بہت سے</p>"
        },
        "50": {
            "verses": {
                "25:50": {
                    "id": 50
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>چوپایوں اور آدمیوں کو اور طرح طرح سے تقسیم کیا ہم نے اس کو ان کے بیچ میں تاكه دھیان رکھیں پھر بھی نہیں رہتے بہ لوگ بدون ناشکری کئے</p>"
        },
        "51": {
            "verses": {
                "25:51": {
                    "id": 51
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور اگر ہم چاہتے تو اٹھاتے ہر بستی میں کوئی ڈرانے والا ،</h2>"
        },
        "52": {
            "verses": {
                "25:52": {
                    "id": 52
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو تو کہنا مت مان منکروں کا اور مقابلہ کر ان کا اس کے ساتھ بڑے زور سے</p>"
        },
        "53": {
            "verses": {
                "25:53": {
                    "id": 53
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور وہی ہے جس نے ملے ہوئے چلائے دو دریا یہ میٹھا ہے پیاس بجھانے والا اور یہ کھاری ہے کڑوا اور رکھا ان دونوں کے بیچ پردہ اور آڑ روکی ہوئی</p>"
        },
        "54": {
            "verses": {
                "25:54": {
                    "id": 54
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور وہی ہے جس نے بنایا پانی سے آدمی پھر ٹھہرایا اس کے لئے جد اور سسرال اور تیرا رب سب کچھ کرسکتا ہے</p>"
        },
        "55": {
            "verses": {
                "25:55": {
                    "id": 55
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور پوجتے ہیں اللہ کو چھوڑ کر وہ چیز جو نہ بھلا کرے ان کا نہ برا اور ہے کافر اپنے رب کی طرف سے پیٹھ پھیر رہا</p>"
        },
        "56": {
            "verses": {
                "25:56": {
                    "id": 56
