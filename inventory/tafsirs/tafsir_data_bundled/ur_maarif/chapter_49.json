{
    "chapter": 49,
    "verses": {
        "1": {
            "verses": {
                "49:1": {
                    "id": 1
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے ایمان والو ! آگے نہ بڑھو اللہ سے اور اس کے رسول سے اور ڈرتے رہو اللہ سے اللہ سنتا ہے جانتا ہے</p>"
        },
        "2": {
            "verses": {
                "49:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے ایمان والو بلند نہ کرو اپنی آوازیں نبی کی آواز سے اوپر اور اس سے نہ بولو تڑخ کر جیسے تڑختے ہو ایک دوسرے پر کہیں اکارت نہ ہوجائیں تمہارے کام اور تم کو خبر بھی نہ ہو</p>"
        },
        "3": {
            "verses": {
                "49:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جو لوگ دبی آواز سے بولتے ہیں رسول اللہ کے پاس وہی ہیں جن کے دلوں کو جانچ لیا ہے اللہ نے ادب کے واسطے ان کے لئے معافی ہے اور ثواب بڑا</p>"
        },
        "4": {
            "verses": {
                "49:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جو لوگ پکارتے ہیں تجھ کو دیوار کے پیچھے سے وہ اکثر عقل نہیں رکھتے۔</p>"
        },
        "5": {
            "verses": {
                "49:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر وہ صبر کرتے جب تک تو نکلتا ان کی طرف تو ان کے حق میں بہتر ہوتا اور اللہ بخشنے والا مہربان ہے۔</p>"
        },
        "6": {
            "verses": {
                "49:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے ایمان والو ! اگر آئے تمہارے پاس کوئی گناہ گار خبرلے کر تو تحقیق کرلو، کہیں جا نہ پڑو کسی قوم پر نادانی سے پھر کل کو اپنے کئے پر لگو پچھتانے۔</p>"
        },
        "7": {
            "verses": {
                "49:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جان لو کہ تم میں رسول ہے اللہ کا اگر وہ تمہاری بات مان لیا کرے بہت کاموں میں تو تم پر مشکل پڑے اللہ نے محبت ڈال دی تمہارے دل میں ایمان کی اور کھبا دیا اس کو تمہارے دلوں میں اور نفرت ڈال دی تمہارے دل میں کفر اور گناہ اور نافرمانی کی وہ لوگ وہی ہیں نیک راہ پر</p>"
        },
        "8": {
            "verses": {
                "49:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اللہ کے فضل سے اور احسان سے اور اللہ سب کچھ جانتا ہے حکمتوں والا۔</p>"
        },
        "9": {
            "verses": {
                "49:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر دو فریق مسلمانوں کے آپس میں لڑ پڑیں تو ان میں ملاپ کرا دو پھر اگر چڑھا چلا جائے ایک ان میں سے دوسرے پر تو تم سب لڑو اس چڑھائی والے سے یہاں تک کہ پھر آئے اللہ کے حکم پر پھر اگر پھر آیا تو ملاپ کرادو ان میں برابر اور انصاف کرو بیشک اللہ کو خوش آتے ہیں انصاف والے</p>"
        },
        "10": {
            "verses": {
                "49:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>مسلمان جو ہیں سو بھائی ہیں سوملاپ کرادو اپنے دو بھائیوں میں اور ڈرتے رہو اللہ سے تاکہ تم پر رحم ہو۔</p>"
        },
        "11": {
            "verses": {
                "49:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے ایمان والو ٹھٹھا نہ کریں ایک لوگ دوسرے سے شاید وہ بہتر ہوں ان سے اور نہ عورتیں دوسری عورتوں سے شاید وہ بہتر ہوں ان سے اور عجیب نہ لگاؤ ایک دوسرے کو اور نام نہ ڈالو چڑانے کو ایک دوسرے کے برا نام ہے گنہگاری پیچھے ایمان کے اور جو کوئی توبہ نہ کرے تو وہی ہیں بےانصاف۔</p>"
        },
        "12": {
            "verses": {
                "49:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے ایمان والو ! بچتے رہو بہت تہمتیں کرنے سے مقرر بعضی تہمت گناہ ہے اور بھید نہ ٹٹولو کسی کا اور برا نہ کہو پیٹھ پیچھے ایک دوسرے کا، بھلا خوش لگتا ہے تم میں کسی کو کہ کھائے گوشت اپنے بھائی کا جو مردہ ہو سو گھن آتا ہے تم کو اس سے اور ڈرتے رہو اللہ سے بیشک اللہ معاف کرنیوالا ہے مہربان۔</p>"
        },
        "13": {
            "verses": {
                "49:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے آدمیو ! ہم نے تم کو بنایا ایک مرد اور ایک عورت سے اور رکھیں تمہاری ذاتیں اور قبلے تاکہ آپس کی پہچان ہو تحقیق عزت اللہ کے یہاں اسی کو بڑی جس کو ادب بڑا اللہ سب کچھ جانتا ہے خبردار۔</p>"
        },
        "14": {
            "verses": {
                "49:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کہتے ہیں گنوار کہ ہم ایمان لائے تو کہہ تم ایمان نہیں لائے پر تم کہو ہم مسلمان ہوئے اور ابھی نہیں گھسا ایمان تمہارے دلوں میں اور اگر حکم پر چلو گے اللہ کے اور اس کے رسول کے کاٹ نہ لے گا تمہارے کاموں میں سے کچھ اللہ بخشتا ہے مہربان ہے</p>"
        },
        "15": {
            "verses": {
                "49:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ایمان والے وہ لوگ ہیں جو ایمان لائے اللہ پر اور اس کے رسول پر پھر شبہ نہ لائے اور لڑے اللہ کی راہ میں اپنے مال اور اپنی جان سے وہ لوگ جو ہیں وہی ہیں سچے</p>"
        },
        "16": {
            "verses": {
                "49:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ کیا تم جتلاتے ہو اللہ کو اپنی دینداری اور اللہ کو تو خبر ہے جو کچھ ہے آسمانوں میں اور زمین میں اور اللہ ہر چیز کو جانتا ہے</p>"
        },
        "17": {
            "verses": {
                "49:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تجھ پر احسان رکھتے ہیں کہ مسلمان ہوئے تو کہہ مجھ پر احسان نہ رکھو اپنے اسلام لانے کا بلکہ اللہ تم پر احسان رکھتا ہے کہ اس نے تم کو راہ دی ایمان کی اگر سچ کہو</p>"
        },
        "18": {
            "verses": {
                "49:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اللہ جانتا ہے چھپے بھید آسمانوں کے اور زمین کے اور اللہ دیکھتا ہے جو تم کرتے ہو۔</p>"
        }
    }
}