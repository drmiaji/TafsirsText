{
    "chapter": 50,
    "verses": {
        "1": {
            "verses": {
                "50:1": {
                    "id": 1
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>ق قسم ہے اس قرآن بڑی شان والے کی</h2>"
        },
        "2": {
            "verses": {
                "50:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بلکہ ان کو تعجب ہوا کہ آیا ان کے پاس ڈر سنانے والا انہی میں کا تو کہنے لگے منکر یہ تعجب کی چیز ہے</p>"
        },
        "3": {
            "verses": {
                "50:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کیا جب ہم مر چکیں اور ہوجائیں مٹی یہ پھر آنا بہت دور ہے</h2>"
        },
        "4": {
            "verses": {
                "50:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ہم کو معلوم ہے جتنا گھٹاتی ہے زمین ان میں سے اور ہمارے پاس کتاب ہے جس میں سب کچھ محفوظ ہے</p>"
        },
        "5": {
            "verses": {
                "50:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کوئی نہیں جھٹلاتے ہیں سچے دین کو جب ان تک پہنچا سو وہ پڑ رہے ہیں الجھی ہوئی بات میں</p>"
        },
        "6": {
            "verses": {
                "50:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا نہیں دیکھتے آسمان کو اپنے اوپر کیسا ہم نے اس کو بنایا اور رونق دی اور اس میں نہیں کوئی سوراخ</p>"
        },
        "7": {
            "verses": {
                "50:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور زمین کو پھیلایا اور ڈالے اس میں بوجھ اور اگائی اس میں ہر قسم کی رونق کی چیز</p>"
        },
        "8": {
            "verses": {
                "50:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>سمجھانے کو اور یاد دلانے کو اس بندہ کیلئے جو رجوع کرے</h2>"
        },
        "9": {
            "verses": {
                "50:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اتارا ہم نے آسمان سے پانی برکت کا پھر اگائے ہم نے اس سے باغ اور اناج جس کا کھیت کاٹا جاتا ہے</p>"
        },
        "10": {
            "verses": {
                "50:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور کھجوریں لمبی ان کا خوشہ ہے تہہ پر تہہ</h2>"
        },
        "11": {
            "verses": {
                "50:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>روزی دینے کو بندوں کے اور زندہ کیا ہم نے اس سے ایک مردہ دیس کو، یونہی ہوگا نکل کھڑے ہونا</p>"
        },
        "12": {
            "verses": {
                "50:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جھٹلاچکے ہیں ان سے پہلے نوح کی قوم اور کنویں والے اور ثمود</h2>"
        },
        "13": {
            "verses": {
                "50:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور عاد اور فرعون اور لوط کے بھائی</h2>"
        },
        "14": {
            "verses": {
                "50:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور بن کے رہنے والے اور تبع کی قوم ان سب نے جھٹلایا رسولوں کو پھر ٹھیک پڑا میرا ڈرانا</p>"
        },
        "15": {
            "verses": {
                "50:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اب کیا ہم تھک گئے پہلی بار بنا کر کوئی نہیں ان کو دھوکا ہے ایک نئے بنانے میں۔</p>"
        },
        "16": {
            "verses": {
                "50:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور البتہ ہم نے بنایا انسان کو اور ہم جانتے ہیں جو باتیں آتی رہتی ہیں اس کے جی میں اور ہم اس سے نزدیک ہیں دھڑکتی رگ سے زیادہ</p>"
        },
        "17": {
            "verses": {
                "50:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جب لیتے جاتے ہیں دو لینے والے داہنے بیٹھا اور بائیں بیٹھا</h2>"
        },
        "18": {
            "verses": {
                "50:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>نہیں بولتا کچھ بات جو نہیں ہوتا اس کے پاس ایک راہ دیکھنے والا تیار</p>"
        },
        "19": {
            "verses": {
                "50:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور وہ آئی بیہوشی موت کی تحقیق یہ وہ ہے جس سے تو ٹلتا رہتا تھا</p>"
        },
        "20": {
            "verses": {
                "50:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور پھونکا گیا صور یہ ہے دن ڈرانے کا</h2>"
        },
        "21": {
            "verses": {
                "50:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور آیا ہر ایک جی اس کے ساتھ ہی ایک ہانکنے والا اور ایک احوال بتلانے والا</p>"
        },
        "22": {
            "verses": {
                "50:22": {
                    "id": 22
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو بیجز رہا اس دن سے اب کھول دی ہم نے تجھ پر سے تیری اندھیری سو تیری نگاہ آج تیز ہے</p>"
        },
        "23": {
            "verses": {
                "50:23": {
                    "id": 23
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور بولا (فرشتہ) اس کے ساتھ والا یہ ہے جو میرے پاس تھا حاضر</h2>"
        },
        "24": {
            "verses": {
                "50:24": {
                    "id": 24
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>ڈال دو تم دونوں دوزخ میں ہر ناشکر مخالف کو</h2>"
        },
        "25": {
            "verses": {
                "50:25": {
                    "id": 25
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>نیکی سے روکنے والا حد سے بڑھنے والا شبہ ڈالنے والا</h2>"
        },
        "26": {
            "verses": {
                "50:26": {
                    "id": 26
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جس نے ٹھہرایا اللہ کے ساتھ اور کو پوجنا سو ڈال دو اس کو سخت عذاب میں</p>"
        },
        "27": {
            "verses": {
                "50:27": {
                    "id": 27
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بولا (شیطان) اس کا ساتھی اے رب ہمارے میں نے اس کو شرارت میں نہیں ڈالا پر یہ تھا راہ کو بھولا دور پڑا ہوا</p>"
        },
        "28": {
            "verses": {
                "50:28": {
                    "id": 28
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>فرمایا جھگڑا نہ کرو میرے پاس اور میں پہلے ہی ڈرا چکا تھا تم کو عذاب سے</p>"
        },
        "29": {
            "verses": {
                "50:29": {
                    "id": 29
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>بدلتی نہیں بات میرے پاس اور میں ظلم نہیں کرتا بندوں پر۔</h2>"
        },
        "30": {
            "verses": {
                "50:30": {
                    "id": 30
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جس دن ہم کہیں دوزخ کو تو بھر بھی چکی اور وہ بولے کچھ اور بھی ہے</p>"
        },
        "31": {
            "verses": {
                "50:31": {
                    "id": 31
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور نزدیک لائی جائے بہشت ڈرانیوالوں کے واسطے دور نہیں</h2>"
        },
        "32": {
            "verses": {
                "50:32": {
                    "id": 32
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ ہے جس کا وعدہ ہوا تھا تم سے ہر ایک رجوع رہنے والے یاد رکھنے والے کے واسطے</p>"
        },
        "33": {
            "verses": {
                "50:33": {
                    "id": 33
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جو ڈرا رحمٰن سے بن دیکھے اور لایا دل رجوع ہونے والا</h2>"
        },
        "34": {
            "verses": {
                "50:34": {
                    "id": 34
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>چلے جاؤ اس میں سلامت یہ دن ہے ہمیشہ رہنے کا</h2>"
        },
        "35": {
            "verses": {
                "50:35": {
                    "id": 35
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ان کے واسطے ہے وہاں جو وہ چاہیں اور ہمارے پاس ہے کچھ زیادہ بھی۔</p>"
        },
        "36": {
            "verses": {
                "50:36": {
                    "id": 36
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کتنی تباہ کرچکے ہم ان سے پہلے جماعتیں کہ ان کی قوت زبردست تھی ان سے پھر لگے کریدنے شہروں میں کہیں ہے بھاگ جانے کو ٹھکانا</p>"
        },
        "37": {
            "verses": {
                "50:37": {
                    "id": 37
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اس میں سوچنے کی جگہ ہے اس کو جس کے اندر دل ہے یا لگائے کان دل لگا کر</p>"
        },
        "38": {
            "verses": {
                "50:38": {
                    "id": 38
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ہم نے بنائے آسمان اور زمین اور جو کچھ ان کے بیچ میں ہے چھ دن میں اور ہم کو نہ ہوا کچھ تکان</p>"
        },
        "39": {
            "verses": {
