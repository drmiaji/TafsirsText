{
    "chapter": 32,
    "verses": {
        "1": {
            "verses": {
                "32:1": {
                    "id": 1
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>ال م</h2>"
        },
        "2": {
            "verses": {
                "32:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اتارنا کتاب کا اس میں کچھ دھوکہ نہیں پروردگار عالم کی طرف سے ہے</p>"
        },
        "3": {
            "verses": {
                "32:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا کہتے ہیں کہ یہ جھوٹ باندھ لایا ہے کوئی نہیں وہ ٹھیک ہے تیرے رب کی طرف سے تاکہ تو ڈر سناوے ان لوگوں کو جن کے پاس نہیں آیا کوئی ڈرانے والا تجھ سے پہلے تاکہ وہ راہ پر آئیں۔</p>"
        },
        "4": {
            "verses": {
                "32:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اللہ ہے جس نے بنائے آسمان اور زمین اور جو کچھ ان کے بیچ میں ہے چھ دن کے اندر پھر قائم ہوا عرش پر کوئی نہیں تمہارا اس کے سوائے حمایتی اور نہ سفارشی پھر کیا تم دھیان نہیں کرتے</p>"
        },
        "5": {
            "verses": {
                "32:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تدبیر سے اتارتا ہے کام آسمان سے زمین تک پھر چڑہتا ہے وہ کام اس کی طرف ایک دن میں جس کا پیمانہ ہزار برس کا ہے تمہاری گنتی میں</p>"
        },
        "6": {
            "verses": {
                "32:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>یہ ہے جاننے والا چھپے اور اور کھلے کا زبردست رحم والا</h2>"
        },
        "7": {
            "verses": {
                "32:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جس نے خوب بنائی جو چیز بنائی اور شروع کی انسان کی پیدائش ایک گارے سے</p>"
        },
        "8": {
            "verses": {
                "32:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر بنائی اس کی اولاد نچڑے ہوئے بےقدر پانی سے</h2>"
        },
        "9": {
            "verses": {
                "32:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر اس کو برابر کیا اور پھونکی اس میں اپنی ایک جان اور بنا دیئے تمہارے لئے کان اور آنکھیں اور دل تم بہت تھوڑا شکر کرتے ہو۔</p>"
        },
        "10": {
            "verses": {
                "32:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہتے ہیں کہ جب ہم رل گئے زمین میں کیا ہم کو نیا بننا ہے ؟ کچھ نہیں وہ اپنے رب کی ملاقات سے منکر ہیں</p>"
        },
        "11": {
            "verses": {
                "32:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ قبض کرلیتا ہے تم کو فرشتہ موت کا جو تم پر مقرر ہے پھر اپنے رب کی طرف پھر جاؤ گے</p>"
        },
        "12": {
            "verses": {
                "32:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کبھی تو دیکھے جس وقت کو منکر سر ڈالے ہوئے ہوں گے اپنے رب کے سامنے اے رب ہمارے ہم نے دیکھ لیا اور سن لیا اب ہم کو بھیج دے کہ ہم کریں بھلے کام ہم کو یقین آ گیا</p>"
        },
        "13": {
            "verses": {
                "32:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر ہم چاہتے تو سمجھا دیتے ہر جی کو اس کی راہ لیکن ٹھیک پڑچکی میری کہی بات کہ مجھ کو بھرنی ہے دوزخ جنوں سے اور آدمیوں سے اکٹھے</p>"
        },
        "14": {
            "verses": {
                "32:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو اب چکھو مزہ جیسے تم نے بھلا دیا تھا اس اپنے دن کے ملنے کو ہم نے بھی بھلا دیا تم کو اور چکھو عذاب سدا کا عوض اپنے کئے کا</p>"
        },
        "15": {
            "verses": {
                "32:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ہماری باتوں کو وہی مانتے ہیں کہ جب ان کو سمجھائے ان سے گر پڑیں سجدہ کر کر اور پاک ذات کو یاد کریں اپنے رب کی خوبیوں کے ساتھ اور وہ بڑائی نہیں کرتے</p>"
        },
        "16": {
            "verses": {
                "32:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جدا رہتی ہیں ان کی کروٹیں اپنے سونے کی جگہ سے پکارتے ہیں اپنے رب کو ڈر سے اور لالچ سے اور ہمارا دیا ہوا کچھ خرچ کرتے ہیں</p>"
        },
        "17": {
            "verses": {
                "32:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو کسی جی کو معلوم نہیں جو چھپا دھری ہے ان کے واسطے آنکھوں کی ٹھنڈک بدلہ اس کا جو کرتے تھے</p>"
        },
        "18": {
            "verses": {
                "32:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بھلا ایک جو ہے ایمان پر کیا برابر ہے اس کے جو نافرمان ہے ؟ نہیں برابر ہوتے</p>"
        },
        "19": {
            "verses": {
                "32:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو وہ لوگ جو یقین لائے اور کئے کام بھلے تو ان کے لئے باغ ہیں رہنے کے مہمانی ان کاموں کی وجہ سے جو کرتے تھے</p>"
        },
        "20": {
            "verses": {
                "32:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور وہ لوگ جو نافرمان ہوئے سو ان کا گھر ہے آگ جب چاہیں کہ نکل پڑیں اس میں سے الٹا دیئے جائیں پھر اسی میں اور کہیں ان کو چکھو آگ کا عذاب جس کو تم جھٹلایا کرتے تھے</p>"
        },
        "21": {
            "verses": {
                "32:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور البتہ چکھائیں گے ہم ان کو تھوڑا عذاب ورے اس بڑے عذاب کے تاکہ وہ پھر آئیں</p>"
        },
        "22": {
            "verses": {
                "32:22": {
                    "id": 22
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کون بےانصاف زیادہ اس سے جو سمجھایا گیا اس کے رب کی باتوں سے پھر ان سے منہ موڑ گیا مقرر ہم کو ان گنہگاروں سے بدلہ لینا ہے۔</p>"
        },
        "23": {
            "verses": {
                "32:23": {
                    "id": 23
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ہم نے دی ہے موسیٰ کو کتاب سو تو مت رہ دھوکے میں اس کے ملنے سے اور کیا ہم نے اس کو ہدایت بنی اسرائیل کے واسطے</p>"
        },
        "24": {
            "verses": {
                "32:24": {
                    "id": 24
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کئے ہم نے ان میں پیشوا جو راہ چلاتے تھے ہمارے حکم سے جب وہ صبر کرتے رہے اور رہے ہماری باتوں پر یقین کرتے</p>"
        },
        "25": {
            "verses": {
                "32:25": {
                    "id": 25
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تیرا رب جو ہے وہی فیصلہ کرے گا ان میں دن قیامت کے جس بات میں کہ وہ اختلاف کرتے تھے</p>"
        },
        "26": {
            "verses": {
                "32:26": {
                    "id": 26
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا ان کو راہ نہ سوجھی اس بات سے کہ کتنی غارت کر ڈالیں ہم نے ان سے پہلے جماعتیں کہ پھرتے ہیں یہ ان کے گھروں میں اس میں بہت نشانیاں ہیں کیا وہ سنتے نہیں ؟</p>"
        },
        "27": {
            "verses": {
                "32:27": {
                    "id": 27
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا دیکھا نہیں انہوں نے کہ ہم ہانک دیتے ہیں پانی کو ایک زمین چٹیل کی طرف پھر ہم نکالتے ہیں اس سے کھیتی کہ کھاتے ہیں ان میں سے ان کے چوپائے اور خود وہ بھی پھر کیا دیکھتے نہیں ؟</p>"
        },
        "28": {
            "verses": {
                "32:28": {
                    "id": 28
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور کہتے ہیں کب ہوگا یہ فیصلہ اگر تم سچے ہو</h2>"
        },
        "29": {
            "verses": {
                "32:29": {
                    "id": 29
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ کہ فیصلہ کے دن کام نہ آئے گا منکروں کو ان کا ایمان لانا اور نہ ان کو ڈھیل ملے گی</p>"
        },
        "30": {
            "verses": {
                "32:30": {
                    "id": 30
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>تو تو خیال چھوڑ ان کا اور منتظر رہ وہ بھی منتظر ہیں۔</h2>"
        }
    }
}