            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کام نہیں کسی ایمان دار مرد کا اور نہ ایماندار عورت کا جبکہ مقرر کر دے اللہ اور اس کا رسول کوئی کام کہ ان کو رہے اختیار اپنے کام کا اور جس نے نافرمانی کی اللہ کی اور اس کے رسول کی سو وہ راہ بھولا صریح چوک کر</p>"
        },
