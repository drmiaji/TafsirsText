            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے نبی کی عورتوں تم نہیں ہو جیسے ہر کوئی عورتیں اگر تم ڈر رکھو سو تم دب کر بات نہ کرو پھر لالچ کرے کوئی جس کے دل میں روگ ہے اور کہو بات معقول</p>"
        },
