            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے نبی کی عورتو ! جو کوئی کر لائے تم میں کام بےحیائی کا صریح دونا ہو اس کو عذاب دوہرا اور ہے یہ اللہ پر آسان</p>"
        },
