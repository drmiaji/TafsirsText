            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہا مت مان منکروں کا اور دغا بازوں کا اور چھوڑ دے ان کا ستانا اور بھروسہ کر اللہ پر اور اللہ بس ہے کام بنانے والا۔</p>"
        },
