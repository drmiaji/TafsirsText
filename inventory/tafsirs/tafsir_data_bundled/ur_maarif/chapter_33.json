{
    "chapter": 33,
    "verses": {
        "1": {
            "verses": {
                "33:1": {
                    "id": 1
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے نبی ڈر اللہ سے اور کہا نہ مان منکروں کا اور دغابازوں کا مقرر اللہ ہے سب کچھ جاننے والا حکمتوں والا</p>"
        },
        "2": {
            "verses": {
                "33:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور چل اسی پر جو حکم آئے تجھ کو تیرے رب کی طرف سے بیشک اللہ تمہارے کام کی خبر رکھتا ہے</p>"
        },
        "3": {
            "verses": {
                "33:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور بھروسہ رکھ اللہ پر اور اللہ کافی ہے کام بنانے والا۔</h2>"
        },
        "4": {
            "verses": {
                "33:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اللہ نے رکھے نہیں کسی مرد کے دو دل اس کے اندر اور نہیں کیا تمہاری جوروؤں کو جن کو ماں کہہ بیٹھے ہو (سچی) مائیں تمہاری اور نہیں کیا تمہارے لے پالکوں کو تمہارے بیٹے یہ تمہاری بات ہے اپنے منہ کی اور اللہ کہتا ہے ٹھیک بات اور وہی سمجھاتا ہے راہ</p>"
        },
        "5": {
            "verses": {
                "33:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پکارو لے پالکوں کو ان کے باپ کی طرف نسبت کر کے یہی پورا انصاف ہے اللہ کے یہاں پھر اگر نہ جانتے ہو ان کے باپ کو تو تمہارے بھائی ہیں دین میں اور رفیق ہیں اور گناہ نہیں تم پر جس چیز میں چوک جاؤ پر وہ جو دل سے ارادہ کرو اور ہے اللہ بخشنے والا مہربان۔</p>"
        },
        "6": {
            "verses": {
                "33:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>نبی سے لگاؤ ہے ایمان والوں کو زیادہ اپنی جان سے اور اس کی عورتیں ان کی مائیں ہیں اور قرابت والے ایک دوسرے سے لگاؤ رکھتے ہیں اللہ کے حکم میں زیادہ سب ایمان والوں اور ہجرت کرنے والوں سے مگر یہ کہ کرنا چاہو اپنے رفیقوں سے احسان یہ ہے کتاب میں لکھا ہوا۔</p>"
        },
        "7": {
            "verses": {
                "33:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب لیا ہم نے نبیوں سے ان کا اقرار اور تجھ سے اور نوح سے اور ابراہیم سے اور موسیٰ سے اور عیسیٰ سے جو بیٹا مریم کا اور لیا ہم نے ان سے گاڑھا قرار</p>"
        },
        "8": {
            "verses": {
                "33:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تاکہ پوچھے اللہ سچوں سے ان کا سچ اور تیار کر رکھا ہے منکروں کے لئے درد ناک عذاب۔</p>"
        },
        "9": {
            "verses": {
                "33:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے ایمان والو ! یاد کرو احسان اللہ کا اپنے اوپر جب چڑھ آئیں تم پر فوجیں پھر ہم نے بھیج دی ان پر ہوا اور وہ فوجیں جو تم نے نہیں دیکھیں اور ہے اللہ جو کچھ کرتے ہو دیکھنے والا</p>"
        },
        "10": {
            "verses": {
                "33:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جب چڑھ آئے تم پر اوپر کی طرف سے اور نیچے سے اور جب بدلنے لگیں آنکھیں اور پہنچے دل گلوں تک اور اٹکل کرنے لگے تم اللہ پر طرح طرح کی اٹکلیں</p>"
        },
        "11": {
            "verses": {
                "33:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہاں جانچے گئے ایمان والے اور جھڑ جھڑائے گئے زور کا جھڑ جھڑانا</p>"
        },
        "12": {
            "verses": {
                "33:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب کہنے لگے منافق اور جن کے دلوں میں روگ ہے جو وعدہ کیا تھا ہم سے اللہ نے اور اس کے رسول نے سب فریب تھا</p>"
        },
        "13": {
            "verses": {
                "33:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب کہنے لگی ایک جماعت ان میں سے اے یثرب والو ! تمہارے لئے ٹھکانہ نہیں سو پھر چلو اور رخصت مانگنے لگا ایک فرقہ ان میں نبی سے کہنے لگے ہمارے گھر کھلے پڑے ہیں اور وہ کھلے نہیں پڑے ان کی کوئی غرض نہیں مگر بھاگ جانا</p>"
        },
        "14": {
            "verses": {
                "33:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر شہر میں کوئی گھس آئے ان پر اس کے کناروں سے پھر ان سے چاہے دین سے بچلنا تو مان لیں اور دیر نہ کریں اس میں مگر تھوڑی</p>"
        },
        "15": {
            "verses": {
                "33:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اقرار کرچکے تھے اللہ سے پہلے کہ نہ پھیریں گے پیٹھ اور اللہ کے قرار کی پوچھ ہوتی ہے</p>"
        },
        "16": {
            "verses": {
                "33:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ کچھ کام نہ آئے گا تمہارے یہ بھاگنا اگر بھاگو گے مرنے سے یا مارے جانے سے اور پھر بھی پھل نہ پاؤ گے مگر تھوڑے دنوں</p>"
        },
        "17": {
            "verses": {
                "33:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ کون ہے کہ تم کو بچائے اللہ سے اگر چاہے تم پر برائی یا چاہے تم پر مہربانی اور نہ پائیں گے اپنے واسطے اللہ کے سوائے کوئی حمایتی اور نہ مددگار</p>"
        },
        "18": {
            "verses": {
                "33:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اللہ کو خوب معلوم ہیں جو اٹکانے والے ہیں تم میں اور کہتے ہیں اپنے بھائیوں کو چلے آؤ ہمارے پاس اور لڑائی میں نہیں آتے مگر کبھی</p>"
        },
        "19": {
            "verses": {
                "33:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>دریغ رکھتے ہیں تم سے پھر جب آئے ڈر کا وقت تو تو دیکھے ان کو کہ تکتے ہیں تیری طرف پھرتی ہیں آنکھیں ان کی جیسے کسی پر آئے بےہوشی موت کی پھر جب جاتا رہے ڈر کا وقت چڑھ چڑھ بولیں تم پر تیز تیز زبانوں سے ڈھلے پڑتے ہیں مال پر وہ لوگ یقین نہیں لائے پھر اکارت کر ڈالے اللہ نے ان کے کام اور یہ ہے اللہ پر آسان</p>"
        },
        "20": {
            "verses": {
                "33:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سمجھتے ہیں کہ فوجیں کفار کی نہیں پھر گئیں اور اگر آجائیں وہ فوجیں تو آرزو کریں کسی طرح ہم باہر نکلے ہوئے ہوں گاؤں میں پوچھ لیا کریں تمہاری خبریں اور اگر ہوں تم میں لڑائی نہ کریں مگر بہت تھوڑی</p>"
        },
        "21": {
            "verses": {
                "33:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تمہارے لئے بھلی تھی سیکھنی رسول ﷺ اللہ کی چال اس کے لئے جو کوئی امید رکھتا ہے اللہ کی اور پچھلے دن کی اور یاد کرتا ہے اللہ کو بہت سا</p>"
        },
        "22": {
            "verses": {
                "33:22": {
                    "id": 22
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب دیکھی مسلمانوں نے فوجیں بولے یہ وہی ہے جو وعدہ دیا تھا ہم کو اللہ نے اور اس کے رسول نے اور سچ کہا اللہ نے اور اس کے رسول ﷺ نے اور ان کو اور بڑھ گیا یقین اور اطاعت کرنا</p>"
        },
