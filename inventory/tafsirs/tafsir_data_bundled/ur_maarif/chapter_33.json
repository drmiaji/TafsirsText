            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور یاد کرو جو پڑھی جاتی ہیں تمہارے گھروں میں اللہ کی باتیں اور عقلمندی کی مقرر اللہ ہے بھید جاننے والا خبردار۔</p>"
