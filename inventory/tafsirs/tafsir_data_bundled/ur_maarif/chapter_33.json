            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>دعا ان کی جس دن اس سے ملیں گے سلام ہے اور تیار رکھا ہے ان کے واسطے ثواب عزت کا</p>"
        },
