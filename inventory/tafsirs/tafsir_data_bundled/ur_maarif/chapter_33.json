            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو کوئی تم میں اطاعت کرے اللہ کی اور اس کے رسول کی اور عمل کرے اچھے دیویں ہم اس کو اس کا ثواب دو بار اور رکھی ہے ہم نے اس کے واسطے روزی عزت کی</p>"
        },
        "32": {
