            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تاکہ بدلہ دے اللہ سچوں کو ان کے سچ کا اور عذاب کرے منافقوں پر اگر چاہے یا توبہ ڈالے ان کے دل پر بیشک اللہ ہے بخشنے والا مہربان</p>"
        },
