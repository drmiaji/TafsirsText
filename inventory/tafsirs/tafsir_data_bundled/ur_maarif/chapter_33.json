            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اتار دیا ان کو جو ان کے پشت پناہ ہوئے تھے اہل کتاب سے ان کے قلعوں سے اور ڈال دی ان کے دلوں میں دھاک کتنوں کو تم جان سے مارنے لگے اور کتنوں کو قید کرلیا</p>"
        },
