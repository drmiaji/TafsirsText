        "13": {
            "verses": {
                "87:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر نہ مرے گا اس میں اور نہ جئے گا</h2>"
