            "text": "<h2>پاکی بیان کر اپنے رب کے نام کی جو سب سے اوپر</h2>"
        },
        "2": {
            "verses": {
                "87:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جس نے بنایا پھر ٹھیک کیا</h2>"
        },
        "3": {
            "verses": {
                "87:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور جس نے ٹھہرا دیا پھر راہ بتلائی</h2>"
        },
        "4": {
            "verses": {
                "87:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور جس نے نکالا چارا</h2>"
        },
        "5": {
            "verses": {
                "87:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر کر ڈالا اس کو کوڑا سیاہ</h2>"
        },
        "6": {
            "verses": {
                "87:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>البتہ ہم پڑھائیں گے تجھ کو پھر تو نہ بھولے گا</h2>"
        },
        "7": {
            "verses": {
                "87:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>مگر جو چاہے اللہ وہ جانتا ہے پکارنے کو اور جو چھپا ہوا ہے</h2>"
        },
        "8": {
            "verses": {
                "87:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور سہج سہج پہنچائیں گے ہم تجھ کو آسانی تک</h2>"
        },
        "9": {
            "verses": {
                "87:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>ہو تو سمجھا دے اگر فائدہ کرے سمجھانا</h2>"
        },
        "10": {
            "verses": {
                "87:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>سمجھ جائے گا جس کو ڈر ہوگا</h2>"
        },
        "11": {
            "verses": {
                "87:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور یکسور رہے گا اس سے بڑا بدقسمت</h2>"
        },
        "12": {
            "verses": {
                "87:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>وہ جو داخل ہوگا بڑی آگ میں</h2>"
