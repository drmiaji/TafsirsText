            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>وہ ثابت ہو چکنے والی</h2>"
        },
        "2": {
            "verses": {
                "69:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کیا ہے وہ ثابت ہو چکنے والی</h2>"
        },
        "3": {
            "verses": {
                "69:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور تو نے کیا سوچا کیا ہے وہ ثابت ہو چکنے والی</h2>"
        },
        "4": {
            "verses": {
                "69:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جھٹلایا ثمود اور عاد نے اس کوٹ ڈالنے والی کو</h2>"
        },
        "5": {
            "verses": {
                "69:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>سو وہ جو ثمود تھے سو غارت کردیئے گئے اچھال کر</h2>"
        },
        "6": {
            "verses": {
                "69:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور وہ جو عاد تھے سو برباد ہوئے ٹھنڈی سناٹے کی ہوا سے</h2>"
        },
        "7": {
            "verses": {
                "69:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>نکل جائے ہاتھوں سے مقرر کردیا اس کو ان پر سات رات اور آٹھ دن تک لگاتار پھر تو دیکھے کہ وہ لوگ اس میں بچھڑ گئے گویا وہ ڈھنڈ ہیں کجھور کے کھوکھلے</p>"
        },
        "8": {
            "verses": {
                "69:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر تو دیکھتا ہے کوئی ان میں کا بچا</h2>"
        },
        "9": {
            "verses": {
                "69:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور آیا فرعون اور جو اس سے پہلے تھے اور الٹ جانے والی بستیاں خطائیں کرتے ہوئے</p>"
        },
        "10": {
            "verses": {
                "69:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر حکم نہ مانا اپنے رب کے رسول کا پھر پکڑا ان کو پکڑنا سخت</h2>"
        },
        "11": {
            "verses": {
                "69:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>ہم نے جس وقت پانی ابلا لادلیا تم کو چلتی کشتی میں</h2>"
        },
        "12": {
            "verses": {
                "69:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تاکہ رکھیں اس کو تمہاری یادگاری کے واسطے اور سینٹ کر رکھے اس کو کان سینٹ کر رکھنے والا</p>"
        },
        "13": {
            "verses": {
                "69:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر جب پھونکا جائے صور میں ایک بار پھونکنا</h2>"
        },
        "14": {
            "verses": {
                "69:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور اٹھائی جائے زمین اور پہاڑ پھر کوٹ دیئے جائیں ایک بار</h2>"
        },
        "15": {
            "verses": {
                "69:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر اس دن ہو پڑے وہ ہو پڑے والی</h2>"
        },
        "16": {
            "verses": {
                "69:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور پھٹ جائے آسمان پھر وہ اس دن بکھ رہا ہے</h2>"
        },
        "17": {
            "verses": {
                "69:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور فرشتے ہونگے اس کے کناروں پر اور اٹھائیں گے تخت تیرے رب کا اپنے اوپر اس دن آٹھ شخص</p>"
        },
        "18": {
            "verses": {
                "69:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اس دن سامنے کئے جاؤ گے چھپی نہ رہے گی تمہاری کوئی چھپی بات</h2>"
        },
        "19": {
            "verses": {
                "69:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو جس کو ملا اس کا لکھا داہنے ہاتھ میں وہ کہتا ہے لیجیو پڑھیو میرا لکھا</p>"
        },
        "20": {
            "verses": {
                "69:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>میں نے خیال رکھا اس بات کا کہ مجھ کو ملے گا میرا حساب</h2>"
        },
        "21": {
            "verses": {
                "69:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>سو وہ ہیں من مانتے گزران میں</h2>"
        },
        "22": {
            "verses": {
                "69:22": {
                    "id": 22
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اونچے باغ میں</h2>"
        },
        "23": {
            "verses": {
                "69:23": {
                    "id": 23
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جس کے میوے مجھ کے پڑے ہیں</h2>"
        },
        "24": {
            "verses": {
                "69:24": {
                    "id": 24
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کھاؤ اور پیؤ رج کر بدلہ اس کا جو آگے بھیج چکے ہو تم پہلے دنوں میں</p>"
        },
        "25": {
            "verses": {
                "69:25": {
                    "id": 25
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جس کو ملا اس کا لکھا بائیں ہاتھ میں وہ کہتا ہے کیا اچھا ہوتا جو مجھ کو نہ ملتا میرا لکھا</p>"
        },
        "26": {
            "verses": {
                "69:26": {
                    "id": 26
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور مجھ کو خبر نہ ہوتی کہ کیا ہے حساب میرا</h2>"
        },
        "27": {
            "verses": {
                "69:27": {
                    "id": 27
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کسی طرح وہی موت ختم کر جاتی</h2>"
        },
        "28": {
            "verses": {
                "69:28": {
                    "id": 28
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کچھ کام نہ آیا مجھ کو میرا مال</h2>"
        },
        "29": {
            "verses": {
                "69:29": {
                    "id": 29
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>برباد ہوئی مجھ سے حکومت میری</h2>"
        },
        "30": {
            "verses": {
                "69:30": {
                    "id": 30
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اس کو پکڑو پھر طوق ڈالوں</h2>"
        },
        "31": {
            "verses": {
                "69:31": {
                    "id": 31
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر آگ کے ڈھیر میں اس کو ڈالوں</h2>"
        },
        "32": {
            "verses": {
                "69:32": {
                    "id": 32
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر ایک رنجیر میں جس کا طول ستر گز ہے اس کو جکڑ دو</h2>"
        },
        "33": {
            "verses": {
                "69:33": {
                    "id": 33
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>وہ تھا کہ یقین نہ لاتا تھا اللہ پر جو سب سے بڑا</h2>"
        },
        "34": {
            "verses": {
                "69:34": {
                    "id": 34
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور تاکید نہ کرتا تھا فقیر کے کھانے پر</h2>"
        },
        "35": {
            "verses": {
                "69:35": {
                    "id": 35
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>سو کوئی نہیں آج اس کا یہاں دوستدار</h2>"
        },
        "36": {
            "verses": {
                "69:36": {
                    "id": 36
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور نہ کچھ ملے کھانا مگر زخموں کا دھو ون</h2>"
        },
        "37": {
            "verses": {
                "69:37": {
                    "id": 37
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کوئی نہ کھائے اس کو مگر وہی گنہگار</h2>"
        },
        "38": {
            "verses": {
                "69:38": {
                    "id": 38
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>سو قسم کھاتا ہوں ان چیزوں کی جو دیکھتے ہو</h2>"
        },
        "39": {
            "verses": {
                "69:39": {
                    "id": 39
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور جو چیزیں کہ تم نہیں دیکھتے</h2>"
        },
        "40": {
            "verses": {
                "69:40": {
                    "id": 40
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
