            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>یہ کہا ہے ایک پیغام لانے والے سردار کا</h2>"
        },
        "41": {
            "verses": {
                "69:41": {
                    "id": 41
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور نہیں ہے یہ کہا کسی شاعر کا تم تھوڑا یقین کرتے ہو</h2>"
        },
