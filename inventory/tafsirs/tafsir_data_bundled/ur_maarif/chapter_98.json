            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>نہ تھے وہ لوگ جو منکر ہیں اہل کتاب اور مشرک باز آنے والے یہاں تک کہ پہنچے ان کے پاس کھلی بات</p>"
        },
        "2": {
            "verses": {
                "98:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اس رسول اللہ کا پڑھتا ہوا ورق پاک</h2>"
        },
        "3": {
            "verses": {
                "98:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اس میں لکھی ہیں کتابیں مضبوط</h2>"
        },
        "4": {
            "verses": {
                "98:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور وہ جو پھوٹ پڑی اہل کتاب میں سو جبکہ آ چکی ان کے پاس کھلی بات</p>"
        },
        "5": {
            "verses": {
                "98:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ان کو حکم یہی ہوا کہ بندگی کریں اللہ کے خالص کر کے اس کے واسطے بندگی ابراہیم کی راہ پر اور قائم رکھیں نماز اور دیں زکوٰة اور یہ ہے راہ مضبوط لوگوں کی</p>"
        },
        "6": {
            "verses": {
                "98:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو منکر ہوئے اہل کتاب اور مشرک ہونگے دوزخ کی آگ میں سدا رہیں اس میں وہ لوگ ہیں سب خلق سے بدتر</p>"
        },
        "7": {
            "verses": {
                "98:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ لوگ جو یقین لائے اور کئے بھلے کام وہ لوگ ہیں سب خلق سے بہتر</p>"
        },
        "8": {
            "verses": {
                "98:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بدلہ ان کا ان کے رب کے یہاں باغ ہیں ہمیشہ رہنے کو نیچے بہتی ہیں ان کے نہریں سدا رہیں ان میں ہمیشہ اللہ ان سے راضی اور وہ اس سے راضی یہ ملتا ہے اس کو جو ڈرا اپنے رب سے۔</p>"
        }
    }
}