            },
            "text": "<h2>جب آسمان پھٹ جائے</h2>"
        },
        "2": {
            "verses": {
                "84:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور سن لے حکم اپنے رب کا اور وہ آسمان اسی لائق ہے</h2>"
        },
        "3": {
            "verses": {
                "84:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور جب زمین پھیلا دی جائے</h2>"
        },
        "4": {
            "verses": {
                "84:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور نکال ڈالے جو کچھ اس میں ہے اور خالی ہو جائے</h2>"
        },
        "5": {
            "verses": {
                "84:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور سن لے حکم اپنے رب کا اور وہ زمین اسی لائق ہے</h2>"
        },
        "6": {
            "verses": {
                "84:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے آدمی تجھ کو تکلیف اٹھانی ہے اپنے رب تک پہنچنے میں سہ سہ کر پھر اس سے ملنا ہے</p>"
        },
        "7": {
            "verses": {
                "84:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>سو جس کو ملا اعمال نامہ اس کا دہانے ہاتھ میں</h2>"
        },
        "8": {
            "verses": {
                "84:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>تو اس سے حساب لیں گے آسان حساب</h2>"
        },
        "9": {
            "verses": {
                "84:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور پھر کر آئے گا اپنے لوگوں کے پاس خوش ہو کر</h2>"
        },
        "10": {
            "verses": {
                "84:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور جس کو ملا اس کا اعمال نامہ پیٹھ کے پیچھے سے</h2>"
        },
        "11": {
            "verses": {
                "84:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>سو وہ پکارے گا موت موت</h2>"
        },
        "12": {
            "verses": {
                "84:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور پڑے گا آگ میں</h2>"
        },
        "13": {
            "verses": {
                "84:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>وہ رہا تھا اپنے گھر میں بےغم</h2>"
        },
        "14": {
            "verses": {
                "84:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اس نے خیال کیا تھا کہ پھر کر نہ جائے گا</h2>"
        },
        "15": {
            "verses": {
                "84:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کیوں نہیں اس کا رب اس کو دیکھتا تھا</h2>"
        },
        "16": {
            "verses": {
                "84:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>سو قسم کھاتا ہوں شام کی سرخی کی</h2>"
