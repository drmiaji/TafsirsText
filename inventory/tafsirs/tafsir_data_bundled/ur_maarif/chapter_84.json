        "19": {
            "verses": {
                "84:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کہ تم کو چڑھنا ہے سیڑھی پر سیڑھی</h2>"
