            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور جب پڑھئے ان کے پاس قرآن وہ سجدہ نہیں کرتے اوپر سے</h2>"
