            },
            "text": "<h2>ال م</h2>"
        },
        "2": {
            "verses": {
                "31:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>یہ آیتیں ہیں پکی کتاب کی</h2>"
        },
        "3": {
            "verses": {
                "31:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>ہدایت ہے اور مہربانی نیکی کرنے والوں کیلئے</h2>"
        },
        "4": {
            "verses": {
                "31:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جو کہ قائم رکھتے ہیں نماز اور دیتے ہیں زکوٰۃ اور وہ ہیں جو آخرت پر ان کو یقین ہے</p>"
        },
        "5": {
            "verses": {
                "31:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>انہوں نے پائی ہے راہ اپنے رب کی طرف سے اور وہی مراد کو پہنچے</p>"
        },
        "6": {
            "verses": {
                "31:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ور ایک وہ لوگ ہیں کہ خریدار ہیں کھیل کی باتوں کے تاکہ بچلائیں اللہ کی راہ سے بن سمجھے اور ٹھہرائیں اس کو ہنسی وہ جو ہیں ان کو ذلت کا عذاب ہے</p>"
        },
        "7": {
            "verses": {
                "31:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب سنائے اس کو ہماری آیتیں پیٹھ دے جائے غرور سے گویا ان کو سنا ہی نہیں گویا اس کے دونوں کان بہرے ہیں سو خوشخبری دے اس کو درد ناک عذاب کی</p>"
        },
        "8": {
            "verses": {
                "31:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جو لوگ یقین لائے اور کئے بھلے کام ان کے واسطے ہیں نعمت کے باغ</p>"
        },
        "9": {
            "verses": {
                "31:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ہمیشہ رہا کریں ان میں وعدہ ہوچکا اللہ کا سچا اور وہ زبردست ہے حکمتوں والا۔</p>"
        },
        "10": {
            "verses": {
                "31:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بنائے آسمان بغیر ستونوں کے تم اس کو دیکھتے ہو اور رکھ دیئے زمین پر پہاڑ کہ تم کو لے کر جھک نہ پڑے اور بکھیر دیئے اس میں سب طرح کے جانور اور اتارا ہم نے آسمان سے پانی پھر اگائے زمین میں ہر قسم کے جوڑے خاصے</p>"
        },
        "11": {
            "verses": {
                "31:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ سب کچھ بنایا ہوا ہے اللہ کا اب دکھلاؤ مجھ کو کیا بنایا ہے اوروں نے جو اس کے سوا ہیں کچھ نہیں پر بےانصاف صریح بھٹک رہے ہیں۔</p>"
        },
        "12": {
            "verses": {
                "31:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ہم نے دی لقمان کو عقلمندی کہ حق مان اللہ کا اور جو کوئی حق مانے اللہ کا تو مانے گا اپنے بھلے کو اور جو کوئی منکر ہوگا تو اللہ بےپرواہ ہے سب تعریفوں والا</p>"
        },
        "13": {
            "verses": {
                "31:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب کہا لقمان نے اپنے بیٹے کو جب اس کو سمجھانے لگا اے بیٹے شریک نہ ٹھہرائیو اللہ کا بیشک شریک بنانا بھاری بےانصافی ہے</p>"
        },
        "14": {
            "verses": {
                "31:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ہم نے تاکید کردی انسان کو اس کے ماں باپ کے واسطے پیٹ میں رکھا اس کو اس کی ماں نے تھک تھک کر اور دودھ چھڑانا ہے اس کا دو برس میں کہ حق مان میرا اور اپنے ماں باپ کا آخر مجھ ہی تک آنا ہے</p>"
        },
        "15": {
            "verses": {
                "31:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر وہ دونوں تجھ سے اڑیں اس بات پر کہ شریک مان میرا اس چیز کو جو تجھ کو معلوم نہیں تو ان کا کہنا مت مان اور ساتھ دے ان کا دنیا میں دستور کے موافق اور راہ چل اس کی جو رجوع ہوا میری طرف پھر میری طرف ہے تم کو پھر آنا پھر میں جتلا دوں گا تم کو جو کچھ تم کرتے تھے</p>"
        },
        "16": {
            "verses": {
                "31:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے بیٹے اگر کوئی چیز ہو برابر رائی کے دانہ کی پھر وہ ہو کسی پتھر میں یا آسمانوں میں یا زمین میں لا حاضر کرے اس کو اللہ بیشک اللہ جانتا ہے چھپی ہوئی چیزوں کو خبردار ہے</p>"
        },
        "17": {
            "verses": {
                "31:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے بیٹے قائم رکھ نماز کو اور سکھلا بھلی بات اور منع کر برائی سے اور تحمل کر جو تجھ پر پڑے بیشک یہ ہیں ہمت کے کام</p>"
        },
        "18": {
            "verses": {
                "31:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اپنے گال مت پھلا لوگوں کی طرف اور مت چل زمین پر اتراتا بیشک اللہ کو نہیں بھاتا کوئی اتراتا بڑائیاں کرنے والا</p>"
        },
        "19": {
            "verses": {
                "31:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور چل بیچ کی چال اور نیچی کر آواز اپنی بیشک بری سے بری آواز گدھے کی آواز ہے۔</p>"
        },
        "20": {
            "verses": {
                "31:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا تم نے نہیں دیکھا کہ اللہ نے کام میں لگائے تمہارے جو کچھ ہے آسمان اور زمین میں اور پوری کردیں تم پر اپنی نعمتیں کھلی اور چھپی اور لوگوں میں ایسے بھی ہیں جو جھگڑتے ہیں اللہ کی بات میں نہ سمجھ رکھیں نہ سوجھ اور نہ روشن کتاب</p>"
        },
        "21": {
            "verses": {
                "31:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب ان کو کہتے چلو اس حکم پر جو اتارا اللہ نے کہیں نہیں ہم تو چلیں گے اس پر جس پر پایا ہم نے اپنے باپ دادوں کو بھلا اور جو شیطان بلاتا ہو ان کو دوزخ کی طرف تو بھی ؟</p>"
        },
        "22": {
            "verses": {
                "31:22": {
                    "id": 22
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو کوئی تابع کرے اپنا منہ اللہ کی طرف اور وہ ہو نیکی پر سو اس نے پکڑ لیا مضبوط کڑا اور اللہ کی طرف ہے آخر ہر کام کا</p>"
        },
        "23": {
            "verses": {
                "31:23": {
                    "id": 23
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو کوئی منکر ہوا تو تو غم نہ کھا اس کے انکار سے ہماری طرف پھر آنا ہے ان کو پھر ہم جتلا دیں گے ان کو جو انہوں نے کیا ہے البتہ اللہ جانتا ہے جو بات ہے دلوں میں</p>"
        },
        "24": {
            "verses": {
                "31:24": {
                    "id": 24
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کام چلا دیں گے ہم ان کا تھوڑے دنوں پھر پکڑ بلائیں گے ان کو گاڑھے عذاب میں</p>"
        },
        "25": {
            "verses": {
                "31:25": {
                    "id": 25
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر تو پوچھے ان سے کس نے بنائے آسمان اور زمین تو کہیں اللہ تعالیٰ نے تو کہہ سب خوبی اللہ کو ہے پر وہ بہت لوگ سمجھ نہیں رکھتے</p>"
        },
        "26": {
            "verses": {
                "31:26": {
                    "id": 26
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اللہ کا ہے جو کچھ ہے آسمان اور زمین میں بیشک اللہ وہی ہے بےپروا سب خوبیوں والا</p>"
        },
        "27": {
            "verses": {
                "31:27": {
                    "id": 27
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر جتنے درخت ہیں زمین میں قلم ہوں اور سمندر ہو اس کی سیاہی اس کے پیچھے سات سمندر نہ تمام ہوں باتیں اللہ کی بیشک اللہ زبردست ہے حکمتوں والا</p>"
        },
        "28": {
            "verses": {
                "31:28": {
                    "id": 28
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تم سب کا بنانا اور مرے پیچھے جلانا ایسا ہی ہے جیسا ایک جی کا بیشک اللہ سب کچھ سنتا دیکھتا ہے</p>"
        },
        "29": {
            "verses": {
                "31:29": {
                    "id": 29
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو نے نہیں دیکھا کہ اللہ داخل کرتا ہے رات کو دن میں اور داخل کرتا ہے دن کو رات میں اور کام میں لگا دیا ہے سورج اور چاند کو ہر ایک چلتا ہے ایک مقرر وقت تک اور یہ کہ اللہ خبر رکھتا ہے اس کی جو تم کرتے ہو</p>"
        },
        "30": {
            "verses": {
                "31:30": {
                    "id": 30
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ اس لئے (کہا) کہ اللہ وہی ہے ٹھیک اور جس کسی کو پکارتے ہیں سوائے اس کے سو وہی جھوٹ ہے اور اللہ وہی ہے سب سے اوپر بڑا</p>"
        },
        "31": {
            "verses": {
                "31:31": {
                    "id": 31
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
