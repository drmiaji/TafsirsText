            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جس دن جمع کرے گا ان سب کو پھر کہے گا فرشتوں کو کیا یہ لوگ تم کو پوجا کرتے تھے ؟</p>"
        },
