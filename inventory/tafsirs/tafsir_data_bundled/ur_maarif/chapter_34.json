            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو آج تم مالک نہیں ایک دوسرے کے بھلے کے نہ برے کے اور کہیں گے ہم ان گنہگاروں کو چکھو تکلیف اس آگ کی جس کو تم جھوٹ بتلاتے تھے۔</p>"
        },
