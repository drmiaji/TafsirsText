            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو لوگ دوڑتے ہیں ہماری آیتوں کے ہرانے کو وہ عذاب میں پکڑے ہوئے آتے ہیں</p>"
        },
        "39": {
            "verses": {
                "34:39": {
                    "id": 39
