            },
            "text": "<h2>اور کہتے ہیں کب ہے یہ وعدہ اگر تم سچے ہو</h2>"
        },
        "30": {
            "verses": {
                "34:30": {
                    "id": 30
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ تمہارے لئے وعدہ ہے ایک دن کا نہ دیر کرو گے اس سے ایک گھڑی نہ جلدی اور کہنے لگے منکر ہم ہرگز نہ مانیں گے اس قرآن کو اور نہ اس سے اگلے کو</p>"
        },
        "31": {
            "verses": {
                "34:31": {
                    "id": 31
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کبھی تو دیکھے جب کہ گنہگار کھڑے کئے جائیں اپنے رب کے پاس ایک دوسرے پر ڈالتا ہے بات کو کہتے ہیں وہ لوگ جو کمزور سمجھے جاتے تھے بڑائی کرنے والوں کو اگر تم نہ ہوتے تو ہم ایمان دار ہوتے</p>"
        },
        "32": {
            "verses": {
                "34:32": {
                    "id": 32
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کہنے لگے بڑائی کرنے والے ان سے جو کہ کمزور ہوگئے تھے کیا ہم نے روکا تم کو حق بات سے تمہارے پاس پہنچ چکنے کے بعد کوئی نہیں تم ہی تھے گنہگار</p>"
        },
        "33": {
            "verses": {
                "34:33": {
                    "id": 33
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہنے لگے وہ لوگ جو کمزور گنے گئے تھے بڑائی کرنے والوں کو کوئی نہیں پر فریب سے رات دن کے جب تم ہم کو حکم کیا کرتے کہ ہم نہ مانیں اللہ کو اور ٹھہرائیں اس کے ساتھ برابر کے ساجھی اور چھپے چھپے پچھتانے لگے جب دیکھ لیا عذاب اور ہم نے ڈالے ہیں طوق گردنوں میں منکروں کے وہی بدلہ پاتے ہیں جو عمل کرتے تھے۔</p>"
        },
        "34": {
            "verses": {
                "34:34": {
                    "id": 34
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور نہیں بھیجا ہم نے کسی بستی میں کوئی ڈرانے والا مگر کہنے لگے وہاں کے آسودہ لوگ جو تمہارے ہاتھ بھیجا گیا ہم اس کو نہیں مانتے</p>"
        },
        "35": {
            "verses": {
                "34:35": {
                    "id": 35
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہنے لگے ہم زیادہ ہیں مال اور اولاد میں اور ہم پر آفت نہیں آنے والی</p>"
        },
        "36": {
            "verses": {
                "34:36": {
                    "id": 36
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ میرا رب ہے جو کشادہ کردیتا ہے روزی جس کو چاہے اور ماپ کردیتا ہے لیکن بہت لوگ سمجھ نہیں رکھتے</p>"
        },
        "37": {
            "verses": {
                "34:37": {
                    "id": 37
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور تمہارے مال اور تمہاری اولاد وہ نہیں کہ نزدیک کردیں ہمارے پاس تمہارا درجہ پر جو کوئی یقین لایا اور بھلا کام کیا سو ان کے لئے ہے بدلہ دونا ان کے کئے کام کا اور وہ جھروکوں میں بیٹھے ہیں دل جمعی سے</p>"
        },
        "38": {
            "verses": {
