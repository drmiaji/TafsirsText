            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ کہیں گے پاک ذات ہے تیری ہم تیری طرف میں ہیں ان کی طرف میں نہیں پر پوجتے تھے جنوں کو یہ اکثر انہیں پر اعتقاد رکھتے تھے</p>"
        },
