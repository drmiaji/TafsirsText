                    "id": 27
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ مجھ کو دکھلاؤ تو سہی جن کو اس سے ملاتے ہو ساجھی قرار دیکر کوئی نہیں وہی اللہ ہے زبردست حکمتوں والا۔</p>"
        },
