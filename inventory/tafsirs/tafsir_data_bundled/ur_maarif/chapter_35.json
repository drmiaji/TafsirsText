            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>غرور کرنا ملک میں اور داؤ کرنا برے کام کا اور برائی کا داؤ الٹے گا انہی داؤ والوں پر پھر اب وہی راہ دیکھتے ہیں پہلو کے دستور کی تو تو نہ پائے گا اللہ کا دستور بدلتا اور نہ پائے گا اللہ کا دستور ٹلتا</p>"
        },
