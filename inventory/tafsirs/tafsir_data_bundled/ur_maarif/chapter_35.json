            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جس نے اتارا ہم کو آباد رہنے کے گھر میں اپنے فضل سے نہ پہنچے ہم کو اس میں مشقت</p>"
        },
        "36": {
            "verses": {
