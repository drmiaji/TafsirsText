            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>باغ ہیں بسنے کے جن میں وہ جائیں گے وہاں ان کو گہنا پہنایا جائے گا کنگن سونے کے اور موتی کے اور ان کی پوشاک وہاں ریشمی ہے</p>"
        },
        "34": {
