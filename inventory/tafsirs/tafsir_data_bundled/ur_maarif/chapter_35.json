            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو ہم نے تجھ پر اتاری کتاب وہی ٹھیک ہے تصدیق کرنے والی اپنے سے اگلی کتابوں کی بیشک اللہ اپنے بندوں سے خبردار ہے دیکھنے والا</p>"
        },
        "32": {
            "verses": {
                "35:32": {
                    "id": 32
