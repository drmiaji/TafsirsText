            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تحقیق اللہ تھام رہا ہے آسمانوں کو اور زمین کو کہ ٹل نہ جائیں اور اگر ٹل جائیں تو کوئی نہ تھام سکے ان کو اس کے سوائے وہ ہے تحمل والا بخشنے والا۔</p>"
        },
        "42": {
            "verses": {
                "35:42": {
                    "id": 42
