            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور قسمیں کھاتے تھے اللہ کی تاکید کی قسمیں اپنی کہ اگر آئے گا ان کے پاس ڈر سنانے والا البتہ بہتر راہ چلیں گے ہر ایک امت سے پھر جب آیا ان کے پاس ڈر سنانے والا اور زیادہ ہوگیا ان کا بدکنا</p>"
        },
        "43": {
            "verses": {
                "35:43": {
                    "id": 43
