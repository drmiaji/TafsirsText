{
    "chapter": 64,
    "verses": {
        "1": {
            "verses": {
                "64:1": {
                    "id": 1
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پاکی بول رہا ہے اللہ کی جو کچھ ہے آسمانوں میں اور جو کچھ ہے زمین میں اسی کا راج ہے اور اسی کی تعریف ہے اور وہی ہر چیز کرسکتا ہے</p>"
        },
        "2": {
            "verses": {
                "64:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہی ہے جس نے تم کو بنایا پھر کوئی تم میں منکر ہے اور کوئی تم میں ایمان دار اور اللہ جو تم کرتے ہو دیکھتا ہے</p>"
        },
        "3": {
            "verses": {
                "64:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بنایا آسمانوں کو اور زمین کو تدبیر سے اور صورت کھینچی تمہاری پھر اچھی بنائی تمہاری صورت اور اس کی طرف سب کو پھرجانا ہے</p>"
        },
        "4": {
            "verses": {
                "64:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جانتا ہے جو کچھ ہے آسمانوں میں اور زمین میں اور جانتا ہے جو تم چھپاتے ہو اور جو کھول کر کرتے ہو اور اللہ کو معلوم ہے جیوں کی بات</p>"
        },
        "5": {
            "verses": {
                "64:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا پہنچی نہیں تم کو خبر ان لوگوں کی جو منکر ہوچکے ہیں پہلے پھر انہوں نے چکھی سزا اپنے کام کی اور ان کو عذاب درد ناک ہے</p>"
        },
        "6": {
            "verses": {
                "64:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ اس لئے کہ لاتے تھے ان کے پاس ان کے رسول نشانیاں پھر کہتے کیا آدمی ہم کو راہ سمجھائیں گے پھر منکر ہوئے اور منہ موڑ لیا اور اللہ نے بےپروائی کی اور اللہ بےپرواہ ہے سب تعریفوں والا</p>"
        },
        "7": {
            "verses": {
                "64:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>دعویٰ کرتے ہیں منکر کہ ہرگز ان کو کوئی نہ اٹھائے گا تو کہہ کیوں نہیں قسم ہے میرے رب کی تم کو بیشک اٹھانا ہے پھر تم کو جتلانا ہے جو کچھ تم نے کیا اور یہ اللہ پر آسان ہے</p>"
        },
        "8": {
            "verses": {
                "64:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو ایمان لاؤ اللہ پر اور اس کے رسول پر اور نور پر جو ہم نے اتارا اور اللہ کو تمہارے سب کام کی خبر ہے</p>"
        },
        "9": {
            "verses": {
                "64:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جس دن تم کو اکٹھا کرے گا جمع ہونے کے دن وہ دن ہے ہار جیت کا اور جو کوئی یقین لائے اللہ پر اور کرے کام بھلا اتار دے گا اس پر سے اس کی برائیاں اور داخل کرے گا اس کو باغوں میں جن کے نیچے بہتی ہیں ندیاں رہا کریں ان میں ہمیشہ یہی ہے بڑی مراد ملنی</p>"
        },
        "10": {
            "verses": {
                "64:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو لوگ منکر ہوئے اور جھٹلائیں انہوں نے ہماری آیتیں وہ لوگ ہیں دوزخ والے رہا کریں اسی میں اور بری جگہ جا پہنچے۔</p>"
        },
        "11": {
            "verses": {
                "64:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>نہیں پہنچتی کوئی تکلیف بدون حکم اللہ کے اور جو کوئی یقین لائے اللہ پر وہ راہ بتلائے اس کے دل کو اور اللہ کو ہر چیز معلوم ہے</p>"
        },
        "12": {
            "verses": {
                "64:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور حکم مانو اللہ کا اور حکم مانو رسول کا پھر اگر تم منہ موڑو تو ہمارے رسول کا تو یہی کام ہے پہنچا دینا کھول کر</p>"
        },
        "13": {
            "verses": {
                "64:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اللہ اس کے سوا کسی کی بندگی نہیں اور اللہ پر چاہئے بھروسہ کریں ایمان والے</p>"
        },
        "14": {
            "verses": {
                "64:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے ایمان والو ! تمہاری بعض جو روئیں اور اولاد دشمن ہیں تمہارے سو ان سے بچتے رہو اور اگر معاف کرو اور درگزر کرو اور بخشو تو اللہ ہے بخشنے والا مہربان</p>"
        },
        "15": {
            "verses": {
                "64:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تمہارے مال اور تمہاری اولاد یہی ہیں جانچنے کو اور اللہ جو ہے اس کے پاس ہے ثواب بڑا</p>"
        },
        "16": {
            "verses": {
                "64:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو ڈرو اللہ سے جہاں تک ہو سکے اور سنو اور مانو اور خرچ کرو اپنے بھلے کو اور جس کو بچا دیا اپنے جی کے لالچ سے سو وہ لوگ وہی مراد کو پہنچے</p>"
        },
        "17": {
            "verses": {
                "64:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اگر قرض دو اللہ کو اچھی طرح پر قرض دینا وہ دونا کر دے تم کو اور تم کو بخشے اور اللہ قدر دان ہے تحمل والا</p>"
        },
        "18": {
            "verses": {
                "64:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جاننے والا پوشیدہ اور ظاہر کا زبردست حکمت والا۔</h2>"
        }
    }
}