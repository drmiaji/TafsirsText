            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جھوٹ نہیں کہا رسول کے دل نے جو دیکھا</h2>"
        },
        "12": {
            "verses": {
                "53:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اب کیا تم اس سے جھگڑتے ہو اس پر جو اس نے دیکھا</h2>"
        },
        "13": {
            "verses": {
                "53:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور اس کو اس نے دیکھا ہے اترتے ہوئے ایک بار اور بھی</h2>"
        },
        "14": {
            "verses": {
                "53:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
