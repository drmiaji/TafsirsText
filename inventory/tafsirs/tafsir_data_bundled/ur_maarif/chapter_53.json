            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>سدرة المنتہیٰ کے پاس</h2>"
        },
        "15": {
            "verses": {
                "53:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اس کے پاس ہے بہشت آرام سے رہنے کی</h2>"
        },
        "16": {
            "verses": {
                "53:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جب چھا رہا تھا اس بیری پر جو کچھ چھا رہا تھا</h2>"
        },
        "17": {
            "verses": {
                "53:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>بہکی نہیں نگاہ اور نہ حد سے بڑھی</h2>"
        },
        "18": {
            "verses": {
                "53:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>بیشک دیکھے اس نے اپنے رب کے بڑے نمونے۔</h2>"
        },
        "19": {
            "verses": {
                "53:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>بھلا تم دیکھو تو لات اور عزیٰ کو</h2>"
        },
        "20": {
            "verses": {
                "53:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور منات تیسرے پچھلے کو</h2>"
        },
        "21": {
            "verses": {
                "53:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کیا تم کو تو ملے بیٹے اور اس کو بیٹیاں</h2>"
        },
        "22": {
            "verses": {
                "53:22": {
                    "id": 22
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>یہ بانٹا تو بہت بھونڈا</h2>"
        },
        "23": {
            "verses": {
                "53:23": {
                    "id": 23
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ سب نام ہیں جو رکھ لئے تم نے اور تمہارے باپ دادوں نے اللہ نے نہیں اتاری ان کی کوئی سند محض اٹکل پر چلتے ہیں اور جو جیوں کی امنگ ہے اور پہنچی ہے ان کو ان کے رب سے راہ کی سوجھ</p>"
        },
        "24": {
            "verses": {
                "53:24": {
                    "id": 24
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کہیں آدمی کو ملتا ہے جو کچھ چاہے</h2>"
        },
        "25": {
            "verses": {
                "53:25": {
                    "id": 25
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>سو اللہ کے ہاتھ ہے سب بھلائی پچھلی اور پہلی</h2>"
        },
        "26": {
            "verses": {
                "53:26": {
                    "id": 26
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور بہت فرشتے ہیں آسمانوں میں کچھ کام نہیں آتی ان کی سفارش مگر جب حکم دے اللہ جس کے واسطے چاہے اور پسند کرے</p>"
        },
        "27": {
            "verses": {
                "53:27": {
                    "id": 27
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جو یقین نہیں رکھتے آخرت کا وہ نام رکھتے ہیں فرشتوں کے زنانے نام</p>"
        },
        "28": {
            "verses": {
                "53:28": {
                    "id": 28
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اس کو اس کی کچھ خبر نہیں محض اٹکل پر چلتے ہیں اور اٹکل کچھ کام نہ آئے ٹھیک بات میں۔</p>"
        },
        "29": {
            "verses": {
                "53:29": {
                    "id": 29
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو تو دھیان نہ کر اس پر جو منہ موڑے ہماری یاد سے اور کچھ نہ چاہے مگر دنیا کا جینا</p>"
        },
        "30": {
            "verses": {
                "53:30": {
                    "id": 30
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بس یہیں تک پہنچی ان کی سمجھ تحقیق تیرا رب ہی خوب جانے اس کو جو بہکا اس کی راہ سے</p>"
        },
        "31": {
            "verses": {
                "53:31": {
                    "id": 31
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور وہی خوب جانے اس کو جو راہ پر آیا اور اللہ کا ہے جو کچھ ہے آسمانوں میں اور زمین میں تاکہ وہ بدلہ دے برائی والوں کو ان کے کئے کا اور بدلہ دے بھلائی والوں کو بھلائی سے</p>"
        },
        "32": {
            "verses": {
                "53:32": {
                    "id": 32
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جو کہ بچتے ہیں بڑے گناہوں سے اور بےحیائی کے کاموں سے مگر کچھ آلودگی بیشک تیرے رب کی بخشش میں بڑی سمائی ہے وہ تم کو خوب جانتا ہے جب بنانکالا تم کو زمین سے اور جب تم بچے تھے ماں کے پیٹ میں سو مت بیان کرو اپنی خوبیاں وہ خوب جانتا ہے اس کو بچ کر چلا۔</p>"
        },
        "33": {
            "verses": {
                "53:33": {
                    "id": 33
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>بھلا تو نے دیکھا اس کو جس نے منہ پھیر لیا</h2>"
        },
        "34": {
            "verses": {
                "53:34": {
                    "id": 34
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور لایا تھوڑا سا اور سخت نکلا</h2>"
        },
        "35": {
            "verses": {
                "53:35": {
                    "id": 35
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کیا اس کے پاس خبر ہے غیب کی سو وہ دیکھتا ہے</h2>"
        },
        "36": {
            "verses": {
                "53:36": {
                    "id": 36
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کیا اس کو خبر نہیں پہنچی اس کی جو ہے ورقوں میں موسیٰ کے</h2>"
        },
        "37": {
            "verses": {
                "53:37": {
                    "id": 37
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور ابراہیم کے جس نے کہ اپنا قول پورا اتارا</h2>"
        },
        "38": {
            "verses": {
