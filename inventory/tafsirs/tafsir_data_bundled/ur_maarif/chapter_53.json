            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کہ اٹھاتا نہیں کوئی اٹھانے والا بوجھ کسی دوسرے کا</h2>"
        },
        "39": {
