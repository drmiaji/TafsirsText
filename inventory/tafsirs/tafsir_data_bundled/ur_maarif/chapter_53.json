            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر حکم بھیجا اللہ نے اپنے بندہ پر جو بھیجا</h2>"
        },
        "11": {
            "verses": {
                "53:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
