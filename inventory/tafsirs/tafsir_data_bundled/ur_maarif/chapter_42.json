                "language_name": "english"
            },
            "text": "<p>اور وہی ہے جو اتارتا ہے مینہہ بعد اس کے کہ آس توڑ چکے اور پھیلاتا ہے اپنی رحمت اور وہی ہے کام بنانے والا سب تعریفوں کے لائق</p>"
        },
        "29": {
            "verses": {
                "42:29": {
                    "id": 29
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ایک اس کی نشانی ہے بنانا آسمانوں کا اور زمین کا اور جس قدر بکھیرے ہیں ان میں جانور اور وہ جب چاہے ان سب کو اکٹھا کرسکتا ہے</p>"
        },
        "30": {
            "verses": {
                "42:30": {
                    "id": 30
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو پڑے تم پر کوئی سختی سو وہ بدلہ ہے اس کا جو کھایا تمہارے ہاتھوں نے اور معاف کرتا ہے بہت سے گناہ</p>"
        },
        "31": {
            "verses": {
                "42:31": {
                    "id": 31
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور تم تھکا دینے والے نہیں بھاگ کر زمین میں اور کوئی نہیں تمہارا اللہ کے سوائے کام بنانے والا اور نہ مددگار</p>"
        },
        "32": {
            "verses": {
                "42:32": {
                    "id": 32
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور ایک اس کی نشانی ہے کہ جہاز چلتے ہیں دریا میں جیسے پہاڑ</h2>"
        },
        "33": {
            "verses": {
                "42:33": {
                    "id": 33
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اگر چاہے تھام دے ہوا کو پھر رہیں سارے دن ٹھہرے ہوئے اس کی پیٹھ پر مقرر اس بات میں پتے ہیں ہر قائم رہنے والے کو جو احسان مانے</p>"
        },
        "34": {
            "verses": {
                "42:34": {
                    "id": 34
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یا تباہ کر دے ان کو یہ سبب ان کی کمائی کے اور معاف بھی کرے بہتوں کو</p>"
        },
        "35": {
            "verses": {
                "42:35": {
                    "id": 35
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور تاکہ جان لیں وہ لوگ جو جھگڑتے ہیں ہماری قدرتوں میں کہ نہیں ان کے لئے بھاگنے کی جگہ۔</p>"
        },
        "36": {
            "verses": {
                "42:36": {
                    "id": 36
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو جو کچھ ملا ہے تم کو کوئی چیز ہو سو وہ برت لینا ہے دنیا کی زندگانی میں اور جو کچھ اللہ کے یہاں ہے بہتر ہے اور باقی رہنے والا واسطے ایمان والوں کے جو اپنے رب پر بھروسہ رکھتے ہیں</p>"
        },
        "37": {
            "verses": {
                "42:37": {
                    "id": 37
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو لوگ کہ بچتے ہیں بڑے گناہوں سے اور بےحیائی سے اور جب غصہ آوے تو وہ معاف کردیتے ہیں</p>"
        },
        "38": {
            "verses": {
                "42:38": {
                    "id": 38
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جنہوں نے کہ حکم مانا اپنے رب کا اور قائم کیا نماز کو اور کام کرتے ہیں مشورہ سے آپس کے اور ہمارا دیا کچھ خرچ کرتے ہیں</p>"
        },
        "39": {
            "verses": {
                "42:39": {
                    "id": 39
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور وہ لوگ کہ جب ان پر ہو وے چڑھائی تو وہ بدلہ لیتے ہیں</h2>"
        },
        "40": {
            "verses": {
                "42:40": {
                    "id": 40
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور برائی کا بدلہ ہے برائی ویسی ہی پھر جو کوئی معاف کرے اور صلح کرے سو اس کا ثواب ہے اللہ کے ذمے بیشک اس کو پسند نہیں آتے گنہگار</p>"
        },
        "41": {
            "verses": {
                "42:41": {
                    "id": 41
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو کوئی بدلہ لے اپنے مظلوم ہونے کے بعد سو ان پر بھی نہیں کچھ الزام</p>"
        },
        "42": {
            "verses": {
                "42:42": {
                    "id": 42
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>الزام تو ان پر ہے جو ظلم کرتے ہیں لوگوں پر اور دھوم اٹھاتے ہیں ملک میں ناحق ان لوگوں کے لئے ہے عذاب درد ناک</p>"
        },
        "43": {
            "verses": {
                "42:43": {
                    "id": 43
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور البتہ جس نے سہا اور معاف کیا بیشک یہ کام ہمت کے ہیں۔</h2>"
        },
        "44": {
            "verses": {
                "42:44": {
                    "id": 44
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جس کو راہ نہ سمجھائے اللہ تو کوئی نہیں اس کا کام بنانے والا اس کے سوا اور تو دیکھے گنہگاروں کو جس وقت دیکھیں گے عذاب کہیں گے کسی طرح پھرجانے کی بھی ہوگی کوئی راہ</p>"
        },
        "45": {
            "verses": {
                "42:45": {
                    "id": 45
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور تو دیکھے ان کو کہ سامنے لائے جائیں آگ کے آنکھیں جھکائے ہوئے ذلت سے دیکھتے ہوں گے چھپی نگاہ سے اور کہیں وہ لوگ جو ایمان دار تھے مقرر ٹوٹے والے وہی ہیں جنہوں نے گنوایا اپنی جان کو اور اپنے گھر والوں کو قیامت کے دن سنتا ہے گنہگار پڑے ہیں سدا کے عذاب میں</p>"
        },
        "46": {
            "verses": {
                "42:46": {
                    "id": 46
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کوئی نہ ہوئے ان کے حمایتی جو مدد کرتے ان کی اللہ کے سوائے اور جس کو بھٹکائے اللہ اس کے لئے کہیں نہیں راہ</p>"
        },
        "47": {
            "verses": {
                "42:47": {
                    "id": 47
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>مانو اپنے رب کا حکم اس سے پہلے کہ آئے وہ دن جس کو پھرنا نہیں اللہ کے یہاں سے نہیں ملے گا تم کو بچاؤ اس دن اور نہ ملے گا الوپ ہو جانا</p>"
        },
        "48": {
            "verses": {
                "42:48": {
                    "id": 48
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر اگر وہ منہ پھیریں تو تجھ کو نہیں بھیجا ہم نے ان پر نگہبان تیرا ذمہ تو بس یہی ہے پہنچا دینا اور ہم جب چکھاتے ہیں آدمی کو اپنی طرف سے رحمت اس پر پھولا نہیں سماتا اور اگر پہنچتی ہے ان کو کچھ برائی بدلے میں اپنی کمائی کے تو انسان بڑا ناشکرا ہے</p>"
        },
        "49": {
            "verses": {
                "42:49": {
                    "id": 49
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اللہ کا راج ہے آسمانوں میں اور زمین میں پیدا کرتا ہے جو چاہے بخشتا ہے جس کو چاہے بیٹیاں اور بخشتا ہے جس کو چاہے بیٹے</p>"
        },
