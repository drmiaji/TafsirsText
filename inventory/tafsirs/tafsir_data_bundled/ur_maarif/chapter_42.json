            },
            "text": "<p>حم</p>"
        },
        "2": {
            "verses": {
                "42:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>عسق</p>"
        },
        "3": {
            "verses": {
                "42:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اسی طرح وحی بھیجتا ہے تیری طرف اور تجھ سے پہلوں کی طرف اللہ زبردست حکمتوں والا</p>"
        },
        "4": {
            "verses": {
                "42:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اسی کا ہے جو کچھ ہے آسمانوں میں اور زمین میں اور وہی ہے سب سے اوپر بڑا قریب ہے</p>"
        },
        "5": {
            "verses": {
                "42:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کہ پھٹ پڑیں آسمان اوپر سے اور فرشتے پاکی بولتے ہیں خوبیاں اپنے رب کی اور گناہ بخشواتے ہیں زمین والوں کے سنتا ہے وہی ہے اللہ معاف کرنے والا مہربان</p>"
        },
        "6": {
            "verses": {
                "42:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جنہوں نے پکڑے ہیں اس کے سوائے رفیق اللہ کو وہ سب یاد ہیں اور تجھ پر نہیں ان کا ذمہ</p>"
        },
        "7": {
            "verses": {
                "42:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اسی طرح اتارا ہم نے تجھ پر قرآن عربی زبان کہ تو ڈر سنائے بڑے گاؤں کو اور اس کے آس پاس والوں کو اور خبر سنا دے جمع ہونے کے دن کی اس میں دھوکا نہیں ایک فرقہ بہشت میں اور ایک فرقہ آگ میں</p>"
        },
        "8": {
            "verses": {
                "42:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر چاہتا اللہ تو سب لوگوں کو کرتا ایک ہی فرقہ لیکن وہ داخل کرتا ہے جس کو چاہے اپنی رحمت میں اور گنہگار جو ہیں ان کا کوئی نہیں رفیق اور نہ مدد گار</p>"
        },
        "9": {
            "verses": {
                "42:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا انہوں نے پکڑے ہیں اس سے ورے کام بنانے والے سو اللہ جو ہے وہی ہے کام بنانے والا اور وہی جلاتا ہے مردوں کو اور وہ ہر چیز کرسکتا ہے۔</p>"
        },
        "10": {
            "verses": {
                "42:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جس بات میں جھگڑا کرتے ہو تم لوگ کوئی چیز ہو اس کا فیصلہ ہے اللہ کے حوالے وہ اللہ ہے رب میرا اسی پر ہے مجھ کو بھروسہ اور اسی کی طرف میری رجوع ہے</p>"
        },
        "11": {
            "verses": {
                "42:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بنا نکالنے والا آسمانوں اور زمین کا بنا دیئے تمہارے واسطے تم ہی میں سے جوڑے اور چوپایوں میں سے جوڑے بکھیرتا ہے تم کو اسی طرح نہیں ہے اس کی طرح کا سا کوئی اور وہی ہے سننے والا دیکھنے والا</p>"
        },
        "12": {
            "verses": {
                "42:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اسی کے پاس ہیں کنجیاں آسمانوں کی اور زمین کی پھیلا دیتا ہے روزی جس کے واسطے چاہے اور ماپ کردیتا ہے وہ ہر چیز کی خبر رکھتا ہے۔</p>"
        },
        "13": {
            "verses": {
                "42:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>راہ ڈال دی تمہارے لئے دین میں وہی جس کا حکم کیا تھا نوح کو اور جس کا حکم بھیجا ہم نے تیری طرف اور جس کا حکم کیا ہم نے ابراہیم کو اور موسیٰ کو اور عیسیٰ کو یہ کہ قائم رکھو دین کو اور اختلاف نہ ڈالو اس میں بھاری ہے شرک کرنے والوں کو وہ چیز جس کی طرف تو ان کو بلاتا ہے اللہ چن لیتا ہے اپنی طرف سے جس کو چاہے اور راہ دیتا ہے اپنی طرف اس کو جو رجوع لائے</p>"
        },
        "14": {
            "verses": {
                "42:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جنہوں نے اختلاف ڈالا سو سمجھ آچکنے کے بعد آپس کی ضد سے اور اگر نہ ہوتی ایک بات جو نکلی ہے تیرے رب سے ایک مقررہ وعدہ تک تو فیصلہ ہوجاتا ان میں اور جن کو ملی ہے کتاب ان کے پیچھے وہ البتہ اس سے دھوکہ میں ہیں جو چین نہیں آنے دیتا</p>"
        },
        "15": {
            "verses": {
                "42:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو تو اسی طرف بلا اور قائم رہ جیسا کہ فرما دیا ہے تجھ کو اور مت چل ان کی خواہشوں پر اور کہہ میں یقین لایا ہر کتاب پر جو اتاری اللہ نے اور مجھ کو حکم ہے کہ انصاف کروں تمہارے بیچ میں اللہ رب ہے ہمارا اور تمہارا ہم کو ملیں گے ہمارے کام اور تم کو تمہارے کام کچھ جھگڑا نہیں ہم میں اور تم میں اللہ اکٹھا کرے گا ہم سب کو اور اسی کی طرف پھرجانا ہے۔</p>"
        },
        "16": {
            "verses": {
                "42:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو لوگ جھگڑا ڈالتے ہیں اللہ کی بات میں جب لوگ اس کو مان چکے ان کا جھگڑا باطل ہے ان کے رب کے یہاں اور ان پر غصہ ہے اور ان کو سخت عذاب ہے</p>"
        },
        "17": {
            "verses": {
                "42:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اللہ وہی ہے جس نے اتاری کتاب سچے دین پر اور ترازو بھی اور تجھ کو کیا خبر ہے شاید وہ گھڑی پاس ہو</p>"
        },
        "18": {
            "verses": {
                "42:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جلدی کرتے ہیں اس گھڑی کی وہ لوگ کہ یقین نہیں رکھتے اس پر اور جو یقین رکھتے ہیں ان کو اس کا ڈر ہے اور جانتے ہیں کہ وہ ٹھیک ہے سنتا ہے جو لوگ جھگڑتے ہیں اس گھڑی کے آنے میں وہ بہک کر دور جا پڑے۔</p>"
        },
        "19": {
            "verses": {
                "42:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اللہ نرمی رکھتا ہے اپنے بندوں پر روزی دیتا ہے جس کو چاہے اور وہی ہے زور آور زبردست</p>"
        },
        "20": {
            "verses": {
                "42:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جو کوئی چاہتا ہو آخرت کی کھیتی زیادہ کریں ہم اس کے واسطے اس کی کھیتی اور جو کوئی چاہتا ہو دنیا کی کھیتی اس کو دیویں ہم کچھ اس میں سے اور اس کے لئے نہیں آخرت میں کچھ حصہ۔</p>"
        },
        "21": {
            "verses": {
                "42:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا ان کے لئے اور شریک ہیں کہ راہ ڈالی ہے انہوں نے ان کے واسطے دین کی کہ جس کا حکم نہیں دیا اللہ نے اور اگر نہ مقرر ہوچکی ہوتی ایک بات فیصلہ کی تو فیصلہ ہوجاتا ان میں اور بیشک جو گنہگار ہیں ان کو عذاب ہے درد ناک</p>"
        },
        "22": {
            "verses": {
                "42:22": {
                    "id": 22
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو دیکھے گا گنہگاروں کو کہ ڈرتے ہوں گے اپنی کمائی سے اور وہ پڑ کر رہے گا ان پر اور جو لوگ یقین لائے اور بھلے کام کئے باغوں میں ہیں جنت کے اس کے لئے ہے جو وہ چاہیں اپنے رب کے پاس یہی ہے بڑی بزرگی</p>"
        },
        "23": {
            "verses": {
                "42:23": {
                    "id": 23
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ ہے جو خوشخبری دیتا ہے اللہ اپنے ایمان دار بندوں کو جو کرتے ہیں بھلے کام تو کہہ میں مانگتا نہیں تم سے اس پر کچھ بدلا مگر دوستی چاہئے قرابت میں اور جو کوئی کمائے گا نیکی ہم اس کو بڑھا دیں گے اس کی خوبی بیشک اللہ معاف کرنے والا حق ماننے والا ہے۔</p>"
        },
        "24": {
            "verses": {
                "42:24": {
                    "id": 24
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا وہ کہتے ہیں کہ اس نے باندھا اللہ پر جھوٹ سو اگر اللہ چاہے مہر کر دے تیرے دل پر اور مٹاتا ہے اللہ جھوٹ کو اور ثابت کرتا ہے سچ کو اپنی باتوں سے اس کو معلوم ہے جو دلوں میں ہے</p>"
        },
        "25": {
            "verses": {
                "42:25": {
                    "id": 25
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور وہی ہے جو قبول کرتا ہے توبہ اپنے بندوں کی اور معاف کرتا ہے برائیاں اور جانتا ہے جو کچھ تم کرتے ہو</p>"
        },
        "26": {
            "verses": {
                "42:26": {
                    "id": 26
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور دعا سنتا ہے ایمان والوں کی جو بھلے کام کرتے ہیں اور زیادہ دیتا ہے ان کو اپنے فضل سے اور جو منکر ہیں ان کے لئے سخت عذاب ہے۔</p>"
        },
        "27": {
            "verses": {
