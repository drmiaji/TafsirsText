            "verses": {
                "68:42": {
                    "id": 42
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جس دن کہ کھولی جائے پنڈلی اور وہ بلائے جائیں سجدہ کرنے کو پھر نہ کرسکیں</p>"
        },
