                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>قسم ہے قلم کی اور جو کچھ لکھتے ہیں</h2>"
        },
        "2": {
            "verses": {
                "68:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>تو نہیں اپنے رب کے فضل سے دیوانہ</h2>"
        },
        "3": {
            "verses": {
                "68:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور تیرے واسطے بدلہ ہے بےانتہا</h2>"
        },
        "4": {
            "verses": {
                "68:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور تو پیدا ہوا ہے بڑے خلق پر</h2>"
        },
        "5": {
            "verses": {
                "68:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>سو اب تو بھی دیکھ لے گا اور وہ بھی دیکھ لیں گے</h2>"
        },
        "6": {
            "verses": {
                "68:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کہ کون ہے تم میں جو بچل رہا ہے</h2>"
        },
        "7": {
            "verses": {
                "68:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بیشک تیرا رب وہی خوب جانے اس کو جو بہکا اس کی راہ سے اور وہی خوب جانتا ہے راہ پانے والوں کو</p>"
        },
        "8": {
            "verses": {
                "68:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>سو تو کہنا مت مان جھٹلانے والوں</h2>"
        },
        "9": {
            "verses": {
                "68:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کا وہ چاہتے ہیں کسی طرح تو ڈھیلا ہو تو وہ بھی ڈھیلے ہوں</h2>"
        },
        "10": {
            "verses": {
                "68:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور تو کہا مت مان کسی قسمیں کھانے والے بےقدر کا</h2>"
        },
        "11": {
            "verses": {
                "68:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>طعنے دے چغلی کھاتا پھرے</h2>"
        },
        "12": {
            "verses": {
                "68:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>بھلے کام سے روکے حد سے بڑھے بڑا گنہگار</h2>"
        },
        "13": {
            "verses": {
                "68:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اجڈ ان سب کے پیچھے بدنام</h2>"
        },
        "14": {
            "verses": {
                "68:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اس واسطے کہ رکھتا ہے مال اور بیٹے</h2>"
        },
        "15": {
            "verses": {
                "68:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جب سنائے اس کو ہماری باتیں کہے یہ نقلیں ہیں پہلوں کی</h2>"
        },
        "16": {
            "verses": {
                "68:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اب داغ دیں گے ہم اس کو سونڈ پر</h2>"
        },
        "17": {
            "verses": {
                "68:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ہم نے ان کو جانچا ہے جیسے جانچا تھا باغ والوں کو جب ان سب نے قسم کھائی کہ اس کا میوہ توڑیں گے صبح ہوتے</p>"
        },
        "18": {
            "verses": {
                "68:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور انشاء اللہ نہ کہا</h2>"
        },
        "19": {
            "verses": {
                "68:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر پھیرا کر گیا اس پر کوئی پھیرے والا تیرے رب کی طرف سے اور وہ سوتے ہی رہے</p>"
        },
        "20": {
            "verses": {
                "68:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر صبح تک ہو رہا جیسے ٹوٹ چکا</h2>"
        },
        "21": {
            "verses": {
                "68:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر آپس میں بولے صبح ہوتے</h2>"
        },
        "22": {
            "verses": {
                "68:22": {
                    "id": 22
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کہ سویرے چلو اپنے کھیت پر اگر تم کو توڑنا ہے</h2>"
        },
        "23": {
            "verses": {
                "68:23": {
                    "id": 23
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر چلے اور آپس میں کہتے تھے چپکے چپکے</h2>"
        },
        "24": {
            "verses": {
                "68:24": {
                    "id": 24
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کہ اندر نہ آنے پائے اس میں آج تمہارے پاس کوئی محتاج</h2>"
        },
        "25": {
            "verses": {
                "68:25": {
                    "id": 25
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور سویرے چلے لپکتے ہوئے زور کے ساتھ</h2>"
        },
        "26": {
            "verses": {
                "68:26": {
                    "id": 26
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر جب اس کو دیکھا بولے ہم تو راہ بھول آئے نہیں</h2>"
        },
        "27": {
            "verses": {
                "68:27": {
                    "id": 27
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>ہماری تو قسمت پھوٹ گئی</h2>"
        },
        "28": {
            "verses": {
                "68:28": {
                    "id": 28
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بولا بچلا ان کا میں نے تم کو نہ کہا تھا کہ کیوں نہیں پاکی بولتے</p>"
        },
        "29": {
            "verses": {
                "68:29": {
                    "id": 29
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اللہ کی بولے پاک ذات ہے ہمارے رب کی ہم ہی تقصیر وار تھے</h2>"
        },
        "30": {
            "verses": {
                "68:30": {
                    "id": 30
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر منہ کر کر ایک دوسرے کی طرف لگے الا ہنا دینے</h2>"
        },
        "31": {
            "verses": {
                "68:31": {
                    "id": 31
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>بولے ہائے خرابی ہماری ہم ہی تھے حد سے بڑھنے والے</h2>"
        },
        "32": {
            "verses": {
                "68:32": {
                    "id": 32
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>شاید ہمارا رب بدل دے ہم کو اس سے بہتر ہم اپنے رب سے آرزو رکھتے ہیں</p>"
        },
        "33": {
            "verses": {
                "68:33": {
                    "id": 33
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یوں آتی ہے آفت اور آخرت کی آفت تو سب سے بڑی ہے اگر ان کو سمجھ ہوتی</p>"
        },
        "34": {
            "verses": {
                "68:34": {
                    "id": 34
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>البتہ ڈرنے والوں کو ان کے رب کے پاس باغ ہیں نعمت کے</h2>"
        },
        "35": {
            "verses": {
                "68:35": {
                    "id": 35
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کیا ہم کردیں گے حکم برداروں کو برابر گناہ گاروں کے</h2>"
        },
        "36": {
            "verses": {
                "68:36": {
                    "id": 36
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کیا ہوگیا تم کو کیسے ٹھہراتے ہو بات</h2>"
        },
        "37": {
            "verses": {
                "68:37": {
                    "id": 37
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کیا تمہارے پاس کوئی کتاب ہے جس میں پڑھ لیتے ہو</h2>"
        },
        "38": {
            "verses": {
                "68:38": {
                    "id": 38
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اس میں ملتا ہے تم کو جو تم پسند کرلو</h2>"
        },
        "39": {
            "verses": {
                "68:39": {
                    "id": 39
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا تم نے ہم سے قسمیں لے لی ہیں ٹھیک پہنچنے والی قیامت کے دن تک کہ تم کو ملے گا جو کچھ تم ٹھہراؤ گے</p>"
        },
        "40": {
            "verses": {
                "68:40": {
                    "id": 40
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پوچھ ان سے کونسا ان میں اس کا ذمہ لیتا ہے</h2>"
        },
        "41": {
            "verses": {
                "68:41": {
                    "id": 41
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا ان کے واسطے کوئی شریک ہیں پھر تو چاہئے لے آئیں اپنے اپنے شریکوں کو اگر وہ سچے ہیں</p>"
        },
