            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا چاہتے ہیں کچھ داؤ کرنا سو جو منکر ہیں وہی آتے ہیں داؤ میں</p>"
        },
        "43": {
