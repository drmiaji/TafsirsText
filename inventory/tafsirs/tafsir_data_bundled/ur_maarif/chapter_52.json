            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا ان کا کوئی حاکم ہے اللہ کے سوائے وہ اللہ پاک ہے ان کے شریک بنانے سے</p>"
        },
        "44": {
