            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر دیکھیں ایک تختہ آسمان سے گرتا ہوا کہیں یہ بادل ہے گاڑھا</p>"
        },
        "45": {
