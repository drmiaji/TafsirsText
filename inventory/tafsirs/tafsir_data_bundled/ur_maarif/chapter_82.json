            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور جب قبریں زیرو زبر کردی جائیں</h2>"
        },
        "5": {
            "verses": {
                "82:5": {
                    "id": 5
