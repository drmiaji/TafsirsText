                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جس صورت میں چاہا تجھ کو جوڑ دیا</h2>"
        },
        "9": {
            "verses": {
                "82:9": {
                    "id": 9
                }
