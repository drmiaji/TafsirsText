            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>ہرگز نہیں پر تم جھوٹ جانتے ہو انصاف کا ہونا</h2>"
        },
        "10": {
            "verses": {
