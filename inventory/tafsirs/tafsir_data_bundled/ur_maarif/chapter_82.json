            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جان لے ہر ایک جی جو کچھ کہ آگے بھیجا اور پیچھے چھوڑا</h2>"
        },
        "6": {
            "verses": {
