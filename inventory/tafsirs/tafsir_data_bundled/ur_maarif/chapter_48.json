            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر لڑتے تم سے کافر تو پھیرتے پیٹھ پھر نہ پاتے کوئی حمایتی اور نہ مددگار</p>"
        },
        "23": {
