            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور آسمان کی اور جیسا کہ اس کو بنایا</h2>"
        },
        "6": {
            "verses": {
                "91:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
