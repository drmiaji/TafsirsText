        "7": {
            "verses": {
                "91:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور جی کی اور جیسا کہ اس کو ٹھیک بنایا</h2>"
        },
        "8": {
            "verses": {
                "91:8": {
