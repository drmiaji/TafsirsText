            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ہم نے دی موسیٰ کو راہ کی سوجھ اور وارث کیا بنی اسرائیل کو کتاب کا</p>"
        },
