            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جب طوق پڑیں ان کی گردنوں میں اور زنجیریں بھی گھسیٹے جائیں</h2>"
        },
        "72": {
            "verses": {
                "40:72": {
                    "id": 72
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
