            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ بولے کیا نہ آتے تھے تمہارے پاس تمہارے رسول کھلی نشانیاں لے کر کہیں گے کیوں نہیں بولے پھر پکارو اور کچھ نہیں کافروں کا پکارنا مگر بھٹکنا۔</p>"
        },
        "51": {
            "verses": {
                "40:51": {
                    "id": 51
