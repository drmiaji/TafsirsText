            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ہم مدد کرتے ہیں اپنے رسولوں کی اور ایمان والوں کی دنیا کی زندگانی میں اور جب کھڑے ہوں گے گواہ</p>"
        },
