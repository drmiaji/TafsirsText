            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور دکھلاتا ہے تم کو اپنی نشانیاں پھر کون کون سی نشانیوں کو اپنے رب کی نہ مانوں گے</p>"
        },
        "82": {
            "verses": {
