                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جیسے حال ہوا قوم نوح کا اور عاد اور ثمود کا اور جو لوگ ان کے پیچھے ہوئے اور اللہ بےانصافی نہیں چاہتا بندوں پر</p>"
        },
        "32": {
            "verses": {
                "40:32": {
                    "id": 32
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور اے قوم میری میں ڈرتا ہوں کہ تم پر آئے دن ہانک پکار کا</h2>"
        },
        "33": {
            "verses": {
                "40:33": {
                    "id": 33
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جس دن بھاگو گے پیٹھ پھیر کر کوئی نہیں تم کو اللہ سے بچانے والا اور جس کو غلطی میں ڈالے اللہ تو کوئی نہیں اس کو سمجھانے والا</p>"
        },
        "34": {
            "verses": {
                "40:34": {
                    "id": 34
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور تمہارے پاس آ چکا ہے یوسف اس سے پہلے کھلی باتیں لے کر پھر تم رہے دھوکے ہی میں ان چیزوں سے جو وہ تمہارے پاس لیکر آیا یہاں تک کہ جب مر گیا لگے کہنے ہرگز نہ بھیجے گا اللہ اس کے بعد کوئی رسول اسی طرح بھٹکاتا ہے اللہ اس کو جو ہو بےباک شک کرنے والا</p>"
        },
        "35": {
            "verses": {
                "40:35": {
                    "id": 35
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ جو کہ جھگڑتے ہیں اللہ کی باتوں میں بغیر کسی سند کے جو پہنچی ہو ان کو بڑی بیزاری ہے اللہ کے یہاں اور ایمانداروں کے یہاں اسی طرح مہر کردیتا ہے اللہ ہر دل پر غرور والے سرکش کے</p>"
        },
        "36": {
            "verses": {
                "40:36": {
                    "id": 36
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور بولا فرعون کہ اے ہامان بنا میرے واسطے ایک اونچا محل شاید میں جا پہنچوں رستوں میں</p>"
        },
        "37": {
            "verses": {
                "40:37": {
                    "id": 37
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>رستوں میں آسمانوں کے پھر جھانک کر دیکھوں موسیٰ کے معبود کو اور میری اٹکل میں تو وہ جھوٹا ہے اور اسی طرح بھلے دکھلا دیئے فرعون کو اس کے برے کام اور روک دیا گیا سیدھی راہ سے اور جو داؤ تھا فرعون کا سو تباہ ہونے کے واسطے</p>"
        },
        "38": {
            "verses": {
                "40:38": {
                    "id": 38
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہا اسی ایماندار نے اے قوم راہ چلو میری پہنچا دوں تم کو نیکی کی راہ پر</p>"
        },
        "39": {
            "verses": {
                "40:39": {
                    "id": 39
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اے میری قوم یہ جو زندگی ہے دنیا کی سو کچھ برت لینا ہے اور وہ گھر جو پچھلا ہے وہی ہے جم کر رہنے کا گھر</p>"
        },
        "40": {
            "verses": {
                "40:40": {
                    "id": 40
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جس نے کی ہے برائی تو وہی بدلہ پائے گا اس کی برابر اور جس نے کی ہے بھلائی مرد ہو یا عورت اور وہ یقین رکھتا ہو سو وہ لوگ جائیں گے بہشت میں روزی پائیں گے وہاں بیشمار</p>"
        },
        "41": {
            "verses": {
                "40:41": {
                    "id": 41
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اے قوم مجھ کو کیا ہوا ہے بلاتا ہوں تم کو نجات کی طرف اور تم بلاتے ہو مجھ کو آگ کی طرف</p>"
        },
        "42": {
            "verses": {
                "40:42": {
                    "id": 42
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تم بلاتے ہو مجھ کو کہ منکر ہوجاؤں اللہ سے اور شریک ٹھہراؤں اس کا اس کو جس کی مجھ کو خبر نہیں اور میں بلاتا ہوں تم کو اس زبردست گناہ بخشنے والے کی طرف</p>"
        },
        "43": {
            "verses": {
                "40:43": {
                    "id": 43
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>آپ ہی ظاہر ہے کہ جس کی طرف تم مجھ کو بلاتے ہو اس کا بلاوا کہیں نہیں دنیا میں اور نہ آخرت میں اور یہ کہ ہم کو پھرجانا ہے اللہ کے پاس اور یہ کہ زیادتی والے وہی ہیں دوزخ کے لوگ</p>"
        },
        "44": {
            "verses": {
                "40:44": {
                    "id": 44
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو آگے یاد کرو گے جو میں کہتا ہوں تم کو اور میں سونپتا ہوں اپنا کام اللہ کو بیشک اللہ کی نگاہ میں ہیں سب بندے</p>"
        },
        "45": {
            "verses": {
                "40:45": {
                    "id": 45
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر بچا لیا موسیٰ کو اللہ نے برے داؤ سے جو وہ کرتے تھے اور الٹ پڑا فرعون والوں پر بری طرح کا عذاب</p>"
        },
        "46": {
            "verses": {
                "40:46": {
                    "id": 46
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ آگ ہے کہ دکھلا دیتے ہیں ان کو صبح اور شام اور جس دن قائم ہوگی قیامت حکم ہوگا داخل کرو فرعون والوں کو سخت سے سخت عذاب میں۔</p>"
        },
        "47": {
            "verses": {
                "40:47": {
                    "id": 47
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جب آپس میں جھگڑیں گے آگ کے اندر پھر کہیں گے کمزور غرور کرنے والوں کو ہم تھے تمہارے تابع پھر کچھ تم ہم پر سے اٹھا لو گے حصہ آگ کا</p>"
        },
        "48": {
            "verses": {
                "40:48": {
                    "id": 48
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کہیں گے جو غرور کرتے تھے ہم سب ہی پڑے ہوئے ہیں اس میں بیشک اللہ فیصلہ کرچکا بندوں میں</p>"
        },
        "49": {
            "verses": {
                "40:49": {
                    "id": 49
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہیں گے جو لوگ پڑے ہیں آگ میں دوزخ کے داروغوں کو مانگو اپنے رب سے کہ ہم پر ہلکا کر دے ایک دن تھوڑا عذاب</p>"
        },
        "50": {
