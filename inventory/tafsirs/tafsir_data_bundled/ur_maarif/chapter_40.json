            },
            "text": "<p>وہ اللہ ہے رب تمہارا ہر چیز بنانے والا کسی کی بندگی نہیں اس کے سوائے پھر کہاں سے پھرے جاتے ہو</p>"
        },
        "63": {
            "verses": {
                "40:63": {
                    "id": 63
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اسی طرح پھرے جاتے ہیں جو لوگ کہ اللہ کی باتوں سے منکر ہوتے رہتے ہیں</p>"
        },
        "64": {
            "verses": {
                "40:64": {
                    "id": 64
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اللہ ہے جس نے بنایا تمہارے لئے زمین کو ٹھہرنے کی جگہ اور آسمان کو عمارت اور صورت بنائی تمہاری تو اچھی بنائیں صورتیں تمہاری اور روزی دی تم کو ستھری چیزوں سے وہ اللہ ہے رب تمہارا سو بڑی برکت ہے اللہ کی جو رب ہے سارے جہان کا</p>"
        },
        "65": {
            "verses": {
                "40:65": {
                    "id": 65
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ ہے زندہ رہنے والا کسی کی بندگی نہیں اس کے سوائے سو اس کو پکارو خالص کر کر اس کی بندگی سب خوبی اللہ کو جو رب ہے سارے جہان کا</p>"
        },
        "66": {
            "verses": {
                "40:66": {
                    "id": 66
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تو کہہ کہ مجھ کو منع کردیا کہ پوجوں ان کو جن کو تم پکارتے ہو سوائے اللہ کے جب پہنچ چکیں میرے پاس کھلی نشانیاں میرے رب سے اور مجھ کو حکم ہوا کہ تابع رہوں جہان کے پروردگار کا</p>"
        },
        "67": {
            "verses": {
                "40:67": {
                    "id": 67
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہی ہے جس نے بنایا تم کو خاک سے پھر پانی کی بوند سے پھر خون جمے ہوئے سے پھر تم کو نکالتا ہے بچہ پھر جب تک کہ پہنچوں اپنے پورے زور کو پھر جب تک کہ ہوجاؤ بوڑھے اور کوئی تم میں ایسا ہے کہ مر جاتا ہے پہلے اس سے اور جب تک کہ پہنچوں لکھے وعدے کو اور تاکہ تم سوچوں</p>"
        },
        "68": {
            "verses": {
                "40:68": {
                    "id": 68
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہی ہے جو جلاتا ہے اور مارتا ہے پھر جب حکم کرے کسی کام کا تو یہی کہے اس کو کہ ہوجا وہ ہوجاتا ہے۔</p>"
        },
        "69": {
            "verses": {
                "40:69": {
                    "id": 69
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا تو نے نہ دیکھا ان کو جو جھگڑتے ہیں اللہ کی باتوں میں کہاں سے پھیرے جاتے ہیں</p>"
        },
        "70": {
            "verses": {
                "40:70": {
                    "id": 70
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ لوگ کہ جنہوں نے جھٹلایا اس کتاب کو اس کو جو بھیجا ہم نے اپنے رسولوں کے ساتھ سو آخر جان لیں گے</p>"
        },
        "71": {
            "verses": {
                "40:71": {
                    "id": 71
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
