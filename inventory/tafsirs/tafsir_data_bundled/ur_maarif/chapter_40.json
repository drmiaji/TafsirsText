                    "id": 82
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا پھرے نہیں وہ ملک میں کہ دیکھ لیتے کیسا انجام ہوا ان سے پہلوں کا وہ تھے ان سے زیادہ اور زور میں سخت اور نشانیوں میں جو چھوڑ گئے ہیں زمین پر پھر کام نہ آیا ان کے جو وہ کماتے تھے</p>"
        },
        "83": {
            "verses": {
                "40:83": {
                    "id": 83
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر جب پہنچے ان کے پاس رسول ان کے کھلی نشانیاں لے کر اترانے لگے اس پر جو ان کے پاس تھی خبر اور الٹ پڑی ان پر وہ چیز جس پر ٹھٹھا کرتے تھے</p>"
        },
        "84": {
