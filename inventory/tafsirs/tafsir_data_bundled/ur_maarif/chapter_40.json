                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جس دن کام نہ آئیں منکروں کو ان کے بہانے اور ان کو پھٹکارا ہے اور ان کے واسطے برا گھر</p>"
        },
