            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور قسم کھاتا ہوں جی کی کہ جو ملامت کرے برائی پر</h2>"
        },
        "3": {
            "verses": {
                "75:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کیا خیال رکھتا ہے آدمی کہ جمع نہ کریں گے ہم اس کی ہڈیاں</h2>"
        },
        "4": {
            "verses": {
                "75:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کیوں نہیں ہم ٹھیک کرسکتے ہیں اس کی پوریاں</h2>"
        },
        "5": {
            "verses": {
                "75:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>بلکہ چاہتا ہے آدمی کہ ڈھٹائی کرے اس کے سامنے</h2>"
        },
        "6": {
            "verses": {
                "75:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پوچھتا ہے کب ہوگا دن قیامت کا</h2>"
        },
        "7": {
            "verses": {
                "75:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر جب چندھیانے لگے آنکھ</h2>"
        },
        "8": {
            "verses": {
                "75:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور گہ جائے چاند</h2>"
        },
        "9": {
            "verses": {
                "75:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور اکٹھے ہوں سورج اور چاند</h2>"
        },
        "10": {
            "verses": {
                "75:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کہے گا آدمی اس دن کہاں چلا جاؤں بھاگ کر</h2>"
        },
        "11": {
            "verses": {
                "75:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کوئی نہیں کہیں نہیں ہے بچاؤ</h2>"
        },
        "12": {
            "verses": {
                "75:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>تیرے رب تک ہے اس دن جا ٹھہرنا</h2>"
        },
        "13": {
            "verses": {
                "75:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جتلا دیں گے انسان کو اس دن جو اس نے آگے بھیجا اور پیچھے چھوڑا</p>"
        },
        "14": {
            "verses": {
                "75:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>بلکہ آدمی اپنے واسطے آپ دلیل ہے</h2>"
        },
        "15": {
            "verses": {
                "75:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور پڑا لاڈالے اپنے بہانے</h2>"
        },
        "16": {
            "verses": {
                "75:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>نہ چلا تو اس کے پڑھنے پر اپنی زبان تاکہ جلدی اس کو سیکھ لے</h2>"
        },
        "17": {
            "verses": {
                "75:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>وہ تو ہمارا ذمہ ہے اس کو جمع رکھناتیرے سینہ میں</h2>"
        },
        "18": {
            "verses": {
                "75:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور پڑھنا تیری زبان سے پھر جب ہم پڑھنے لگیں فرشتہ کی زبانی تو ساتھ رہ اس کے پڑھنے کے</p>"
        },
        "19": {
            "verses": {
                "75:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر مقرر ہمارا ذمہ ہے اس کو کھول کر بتلانا</h2>"
        },
        "20": {
            "verses": {
                "75:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>کوئی نہیں پر تم چاہتے ہو جو جلد آئے</h2>"
        },
        "21": {
            "verses": {
                "75:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور چھوڑتے ہو جو دیر میں آئے</h2>"
        },
        "22": {
            "verses": {
                "75:22": {
                    "id": 22
                }
