            "text": "<h2>قسم کھاتا ہوں قیامت کے دن کی</h2>"
        },
        "2": {
            "verses": {
                "75:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
