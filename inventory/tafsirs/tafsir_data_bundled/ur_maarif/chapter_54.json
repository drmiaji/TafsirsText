{
    "chapter": 54,
    "verses": {
        "1": {
            "verses": {
                "54:1": {
                    "id": 1
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پاس آ لگی قیامت اور پھٹ گیا چاند</h2>"
        },
        "2": {
            "verses": {
                "54:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اگر وہ دیکھیں کوئی نشانی تو ٹلا جائیں اور کہیں یہ جادو ہے پہلے سے چلا آتا</p>"
        },
        "3": {
            "verses": {
                "54:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جھٹلایا اور چلے اپنی خوشی پر اور ہر کام ٹھہرا رکھا ہے وقت پر</p>"
        },
        "4": {
            "verses": {
                "54:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور پہنچ چکے ہیں ان کے پاس احوال جن میں ڈانٹ ہو سکتی ہے</h2>"
        },
        "5": {
            "verses": {
                "54:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پوری عقل کی بات ہے پھر ان میں کام نہیں کرتے ڈر سنانے والے</h2>"
        },
        "6": {
            "verses": {
                "54:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو تو ہٹ آ ان کی طرف سے جس دن پکارے پکارنے والا ایک ناگوار چیز کی طرف</p>"
        },
        "7": {
            "verses": {
                "54:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>آنکھیں جھکائے نکل پڑیں قبروں سے جیسے ٹڈی پھیلی ہوئی</h2>"
        },
        "8": {
            "verses": {
                "54:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>دوڑتے جائیں اس پکارنے والے کے پاس کہتے جائیں منکر یہ دن مشکل آیا۔</p>"
        },
        "9": {
            "verses": {
                "54:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جھٹلا چکی ہے ان سے پہلے نوح کی قوم پھر جھوٹا کہا ہمارے بندہ کو اور بولے دیوانہ ہے اور جھڑک لیا اس کو</p>"
        },
        "10": {
            "verses": {
                "54:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر پکارا اپنے رب کو کہ میں عاجز ہوگیا ہوں تو بدلہ لے</h2>"
        },
        "11": {
            "verses": {
                "54:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر ہم نے کھول دیئے دہانے آسمان کے پانی ٹوٹ کر برسنے والے سے</p>"
        },
        "12": {
            "verses": {
                "54:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور بہا دیئے زمین سے چشمے پھر مل گیا سب پانی ایک کام پر جو ٹھہر چکا تھا</p>"
        },
        "13": {
            "verses": {
                "54:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور ہم نے اس کو سوار کردیا ایک تختوں اور کیلوں والی پر</h2>"
        },
        "14": {
            "verses": {
                "54:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>بہتی تھی ہماری آنکھوں کے سامنے بدلہ لینے کو اس کی طرف سے جس کی قدر نہ جانی تھی</p>"
        },
        "15": {
            "verses": {
                "54:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور اس کو ہم نے رہنے دیا نشانی کیلئے پھر کوئی ہے سوچنے والا</h2>"
        },
        "16": {
            "verses": {
                "54:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر کیسا تھا میرا عذاب اور میرا کھڑ کھڑانا</h2>"
        },
        "17": {
            "verses": {
                "54:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور ہم نے آسان کردیا قرآن سمجھنے کو پھر ہے کوئی سوچنے والا۔</h2>"
        },
        "18": {
            "verses": {
                "54:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جھٹلایا عاد نے پھر کیسا ہوا میرا غذاب اور میرا کھڑ کھڑانا</h2>"
        },
        "19": {
            "verses": {
                "54:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>ہم نے بھیجی ان پر ہوا تند ایک نحوست کے دن جو چلے گئے</h2>"
        },
        "20": {
            "verses": {
                "54:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اکھاڑ مارا لوگوں کو گویا وہ جڑیں ہیں کجھور کی اکھڑی پڑی</h2>"
        },
        "21": {
            "verses": {
                "54:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر کیسا رہا میرا عذاب اور میرا کھڑ کھڑانا</h2>"
        },
        "22": {
            "verses": {
                "54:22": {
                    "id": 22
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور ہم نے آسان کردیا قرآن سمجھنے کو پھر ہے کوئی سوچنے والا</h2>"
        },
        "23": {
            "verses": {
                "54:23": {
                    "id": 23
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جھٹلایا ثمود نے ڈر سنانے والوں کو</h2>"
        },
        "24": {
            "verses": {
                "54:24": {
                    "id": 24
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>پھر کہنے لگے کیا ایک آدمی ہم میں کا اکیلا ہم اس کے کہے پر چلیں گے تو ہم غلطی میں پڑے اور سودا میں</p>"
        },
        "25": {
            "verses": {
                "54:25": {
                    "id": 25
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا اتری اسی پر نصیحت ہم سب میں سے کوئی نہیں یہ جھوٹا ہے بڑائی مارتا ہے</p>"
        },
        "26": {
            "verses": {
                "54:26": {
                    "id": 26
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اب جان لیں گے کل کو کون ہے جھوٹا بڑائی مارنے والا</h2>"
        },
        "27": {
            "verses": {
                "54:27": {
                    "id": 27
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ہم بھیجتے ہیں اونٹنی ان کے جانچنے کے واسطے سو انتظار کر ان کا اور سہتارہ</p>"
        },
        "28": {
            "verses": {
                "54:28": {
                    "id": 28
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور سنا دے ان کو کہ پانی کا بانٹا ہے ان میں ہر باری پر پہنچنا چاہئے</p>"
        },
        "29": {
            "verses": {
                "54:29": {
                    "id": 29
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر پکارا انہوں نے اپنے رفیق کو پھر ہاتھ چلایا اور کاٹ ڈالا</h2>"
        },
        "30": {
            "verses": {
                "54:30": {
                    "id": 30
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>پھر کیسا ہوا میرا عذاب اور میرا کھڑ کھڑانا</h2>"
        },
        "31": {
            "verses": {
                "54:31": {
                    "id": 31
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ہم نے بھیجی ان پر ایک چنگھاڑ پھر رہ گئے جیسے روندی ہوئی باڑ کانٹوں کی</p>"
        },
        "32": {
            "verses": {
                "54:32": {
                    "id": 32
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور ہم نے آسان کردیا قرآن سمجھنے کو پھر ہے کوئی سوچنے والا</h2>"
        },
        "33": {
            "verses": {
                "54:33": {
                    "id": 33
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>جھٹلایا لوط کی قوم نے ڈر سنانے والوں کو</h2>"
        },
        "34": {
            "verses": {
                "54:34": {
                    "id": 34
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ہم نے بھیجی ان پر آندھی پتھر برسانیوں سوائے لوط کے گھر کے ان کو ہم نے بچا دیا پچھلی رات سے</p>"
        },
        "35": {
            "verses": {
                "54:35": {
                    "id": 35
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>فضل سے اپنی طرف کے ہم یوں بدلہ دیتے ہیں اس کو جو حق مانے</h2>"
        },
        "36": {
            "verses": {
                "54:36": {
                    "id": 36
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور وہ ڈرا چکا تھا ان کو ہماری پکڑ سے پھر لگے مکرانے ڈرانے کو</p>"
        },
        "37": {
            "verses": {
                "54:37": {
                    "id": 37
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور اس سے لینے لگے اس کے مہمانوں کو پس ہم نے مٹا دیں ان کی آنکھیں اب چکھو میرا عذاب اور میرا ڈرانا</p>"
        },
        "38": {
            "verses": {
                "54:38": {
                    "id": 38
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور پڑا ان پر صبح کو سویرے عذاب جو ٹھہر چکا تھا</h2>"
        },
        "39": {
            "verses": {
                "54:39": {
                    "id": 39
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
