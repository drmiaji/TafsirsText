            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اب چکھو میرا عذاب اور میرا ڈرانا</h2>"
        },
        "40": {
            "verses": {
