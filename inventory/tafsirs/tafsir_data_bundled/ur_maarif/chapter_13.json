            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور کہتے ہیں کافر کیوں نہ اتری اس پر کوئی نشانی اس کے رب سے کہہ دے اللہ گمراہ کرتا ہے جس کو چاہے، اور راہ دکھلاتا ہے اپنی طرف اس کو جو رجوع ہوا</p>"
        },
        "28": {
            "verses": {
                "13:28": {
                    "id": 28
