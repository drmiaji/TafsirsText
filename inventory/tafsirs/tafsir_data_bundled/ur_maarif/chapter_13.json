            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ لوگ جو ایمان لائے اور چین پاتے ہیں ان کے دل اللہ کی یاد سے، سنتا ہے اللہ کی یاد ہی سے چین پاتے ہیں دل</p>"
        },
        "29": {
            "verses": {
