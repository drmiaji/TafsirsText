            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<h2>اور پہلے سے ہو رہے تھے اس کے اترنے سے پہلے ہی ناامید</h2>"
        },
        "50": {
            "verses": {
