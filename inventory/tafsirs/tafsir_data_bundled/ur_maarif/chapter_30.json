            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور نہ تو راہ سمجھائے اندھوں کو ان کے بھٹکنے سے، تو تو سنائے اسی کو جو یقین لائے ہماری باتوں پر سو وہ مسلمان ہوتے ہیں۔</p>"
        },
