            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو دیکھ لے اللہ کی مہربانی کی نشانیاں کیونکر زندہ کرتا ہے زمین کو اس کے مر گئے پیچھے، بیشک وہی ہے مردوں کو زندہ کرنے والا اور وہ ہر چیز کرسکتا ہے</p>"
        },
