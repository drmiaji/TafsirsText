            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اللہ ہے جس نے بنایا تم کو کمزوری سے پھر دیا کمزوری کے پیچھے زور پھر دے گا زور کے پیچھے کمزوری اور سفید بال بناتا ہے جو کچھ چاہے اور وہ ہے سب کچھ جانتا کرسکتا ،</p>"
        },
