{
    "chapter": 57,
    "verses": {
        "1": {
            "verses": {
                "57:1": {
                    "id": 1
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اللہ کی پاکی بولتا ہے جو کچھ ہے آسمانوں میں اور زمین میں اور وہی ہے زبردست حکمتوں والا</p>"
        },
        "2": {
            "verses": {
                "57:2": {
                    "id": 2
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اسی کے لئے ہے راج آسمانوں کا اور زمین کا جلاتا ہے اور مارتا ہے اور وہ سب کچھ کرسکتا ہے</p>"
        },
        "3": {
            "verses": {
                "57:3": {
                    "id": 3
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہی ہے سب سے پہلا اور سب سے پچھلا اور باہر اور اندر اور وہ سب کچھ جانتا ہے</p>"
        },
        "4": {
            "verses": {
                "57:4": {
                    "id": 4
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہی ہے جس نے بنائے آسمان اور زمین چھ دن میں پھر قائم ہوا تخت پر جانتا ہے جو اندر جاتا ہے زمین کے اور جو اس سے نکلتا ہے اور جو کچھ اترتا ہے آسمان سے اور جو کچھ اس میں چڑھتا ہے اور وہ تمہارے ساتھ ہے جہاں کہیں تم ہو اور اللہ جو تم کرتے ہو اس کو دیکھتا ہے</p>"
        },
        "5": {
            "verses": {
                "57:5": {
                    "id": 5
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اسی کے لئے ہے راج آسمانوں کا اور زمین کا اور اللہ ہی تک پہنچتے ہیں سب کام</p>"
        },
        "6": {
            "verses": {
                "57:6": {
                    "id": 6
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>داخل کرتا ہے رات کو دن میں اور داخل کرتا ہے دن کو رات میں اور اس کو خبر ہے جیوں کی بات کی۔</p>"
        },
        "7": {
            "verses": {
                "57:7": {
                    "id": 7
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یقین لاؤ اللہ پر اور اس کے رسول پر اور خرچ کرو اس میں سے جو تمہارے ہاتھ میں دیا ہے اپنا نائب کر کر سو جو لوگ تم میں یقین لائے ہیں اور خرچ کرتے ہیں ان کو بڑا ثواب ہے</p>"
        },
        "8": {
            "verses": {
                "57:8": {
                    "id": 8
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور تم کو کیا ہوا کہ یقین نہیں لاتے اللہ پر اور رسول بلاتا ہے تم کو کہ یقین لاؤ اپنے رب پر اور لے چکا ہے تم سے عہد پکا اگر ہو تم ماننے والے</p>"
        },
        "9": {
            "verses": {
                "57:9": {
                    "id": 9
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہی ہے جو اتارتا ہے اپنے بندے پر آیتیں صاف کہ نکال لائے تم کو اندھیروں سے اجالے میں اور اللہ تم پر نرمی کرنے والا ہے مہربان</p>"
        },
        "10": {
            "verses": {
                "57:10": {
                    "id": 10
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور تم کو کیا ہوا ہے کہ خرچ نہیں کرتے اللہ کی راہ میں اور اللہ ہی کو بچ رہتی ہے ہر شے آسمانوں اور زمین میں برابر نہیں تم میں جس نے کہ خرچ کیا فتح (مکہ) سے پہلے اور لڑائی کی ان لوگوں کا درجہ بڑا ہے ان سے جو کہ خرچ کریں اس کے بعد اور لڑائی کریں اور سب سے وعدہ کیا ہے اللہ نے خوبی کا اور اللہ کو خبر ہے جو کچھ تم کرتے ہو</p>"
        },
        "11": {
            "verses": {
                "57:11": {
                    "id": 11
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کون ہے ایسا کہ قرض دے اللہ کو اچھی طرح پھر وہ اس کو دونا کر دے اس کے واسطے اور اس کو ملے ثواب عزت کا۔</p>"
        },
        "12": {
            "verses": {
                "57:12": {
                    "id": 12
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جس دن تو دیکھے ایمان والے مردوں کو اور ایمان والی عورتوں کو دوڑتی ہوئے چلتی ہے ان کی روشنی ان کے آگے اور ان کے داہنے خوشخبری ہے تم کو آج کے دن باغ ہیں کہ نیچے بہتی ہیں جن کے نہریں سدا رہو ان میں یہ جو ہے یہی ہے بڑی مراد ملنی</p>"
        },
        "13": {
            "verses": {
                "57:13": {
                    "id": 13
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جس دن کہیں گے دغا باز مرد اور عورتیں ایمان والوں کو راہ دیکھو ہماری ہم بھی روشنی لے لیں تمہارے نور سے کوئی کہے گا لوٹ جاؤ پیچھے پھر ڈھونڈلو روشنی پھر کھڑی کردی جائے ان کے بیچ میں ایک دیوار جس میں ہوگا دروازہ اس کے اندر رحمت ہوگی اور باہر کی طرف عذاب</p>"
        },
        "14": {
            "verses": {
                "57:14": {
                    "id": 14
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>یہ ان کو پکاریں گے کیا ہم نے تھے تمہارے ساتھ کہیں گے کیوں نہیں لیکن تم نے بچلا دیا اپنے آپ کو اور راہ دیکھتے رہے اور دھوکے میں پڑے اور بہک گئے اپنے خیالوں پر یہاں تک کہ آپہنچا حکم اللہ کا اور تم کو بہکا دیا اللہ کے نام سے اس دغا باز نے</p>"
        },
        "15": {
            "verses": {
                "57:15": {
                    "id": 15
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>سو آج تم سے قبول نہ ہوگا فدیہ دینا اور نہ منکروں سے تم سب کا گھر دوزخ ہے وہی ہے رفیق تمہاری اور بری جگہ جا پہنچے</p>"
        },
        "16": {
            "verses": {
                "57:16": {
                    "id": 16
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کیا وقت نہیں آیا ایمان والوں کو کہ گڑ گڑائیں ان کے دل اللہ کی یاد سے اور جو اترا ہے سچا دین اور نہ ہوں ان جیسے جن کو کتاب ملی تھی اس سے پہلے پھر دراز گزری ان پر مدت پھر سخت ہوگئے ان کے دل اور بہت ان میں نافرمان ہیں</p>"
        },
        "17": {
            "verses": {
                "57:17": {
                    "id": 17
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جان رکھو کہ اللہ زندہ کرتا ہے زمین کو اس کے مر جانے کے بعد ہم نے کھول کر سنا دیئے تم کو پتے اگر تم کو سمجھ ہے</p>"
        },
        "18": {
            "verses": {
                "57:18": {
                    "id": 18
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تحقیق جو لوگ خیرات کرنے والے ہیں مرد اور عورتیں اور قرض دیتے ہیں اللہ کو اچھی طرح ان کو ملتا ہے دونا اور ان کو ثواب ہے عزت کا</p>"
        },
        "19": {
            "verses": {
                "57:19": {
                    "id": 19
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور جو لوگ یقین لائے اللہ پر اور اس کے سب رسولوں پر وہی ہیں سچے ایمان والے اور لوگوں کا احوال بتلانے والے اپنے رب کے پاس ان کے واسطے ہے ان کا ثواب اور ان کی روشنی اور جو لوگ منکر ہوئے اور جھٹلایا ہماری باتوں کو وہ ہیں دوزخ کے لوگ۔</p>"
        },
        "20": {
            "verses": {
                "57:20": {
                    "id": 20
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>جان رکھو کہ دنیا کی زندگانی یہی ہے کھیل اور تماشہ اور بناؤ اور بڑائیاں کرنی آپس میں اور بہتائیت ڈھونڈنی مال کی اور اولاد کی جیسے حالت ایک مینہ کی جو خوش لگا کسانوں کو اس کا سبزہ پھر زور پر آتا ہے پھر تو دیکھے زرد ہوگیا پھر ہوجاتا ہے روندا ہوا گھاس اور آخرت میں سخت عذاب ہے اور معافی بھی ہے اللہ سے اور رضا مندی اور دنیا کی زندگانی تو یہی ہے مال دغا کا</p>"
        },
        "21": {
            "verses": {
                "57:21": {
                    "id": 21
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>دوڑو اپنے رب کی معافی کی طرف کو اور بہشت کو جس کا پھیلاؤ ہے جیسے پھیلاؤ آسمان اور زمین کا تیار رکھی ہے واسطے ان کے جو یقین لائے اللہ پر اور اس کے رسولوں پر یہ فضل اللہ کا ہے دے اس کو جس کو چاہے اور اللہ کا فضل بڑا ہے۔</p>"
        },
        "22": {
            "verses": {
                "57:22": {
                    "id": 22
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>کوئی آفت نہیں پڑتی ملک میں اور نہ تمہاری جانوں میں جو لکھی نہ ہو ایک کتاب میں پہلے اس سے کہ پیدا کریں ہم اس کو دنیا میں بیشک یہ اللہ پر آسان ہے</p>"
        },
        "23": {
            "verses": {
                "57:23": {
                    "id": 23
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>تاکہ تم غم نہ کھایا کرو اس پر جو ہاتھ نہ آیا اور نہ شیخی کیا کرو اس پر جو تم کو اس نے دیا اور اللہ کو خوش نہیں آتا کوئی اترانے والا بڑائی مارنے والا</p>"
        },
        "24": {
            "verses": {
                "57:24": {
                    "id": 24
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>وہ جو کہ آپ نہ دیں اور سکھلائیں لوگوں کو بھی نہ دینا اور جو کوئی منہ موڑے تو اللہ آپ ہے بےپروا سب خوبیوں کے ساتھ موصوف۔</p>"
        },
        "25": {
            "verses": {
                "57:25": {
                    "id": 25
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>ہم نے بھیجے ہیں اپنے رسول نشانیاں دے کر اور اتاری ان کے ساتھ کتاب اور ترازو تاکہ لوگ سیدھے رہیں انصاف پر اور ہم نے اتارا لوہا اس میں سخت لڑائی ہے اور لوگوں کے کام چلتے ہیں اور تاکہ معلوم کرے اللہ کون مدد کرتا ہے اس کی اور اس کے رسولوں کی بن دیکھے بیشک اللہ زور آور ہے زبردست۔</p>"
        },
        "26": {
            "verses": {
                "57:26": {
                    "id": 26
                }
            },
            "resource_id": 148,
            "resource_name": "Tafsir Ur Maarif",
            "language_id": 38,
            "slug": "ur_maarif",
            "translated_name": {
                "name": "Tafsir Ur Maarif",
                "language_name": "english"
            },
            "text": "<p>اور ہم نے بھیجا نوح کو اور ابراہیم کو اور ٹھہرا دی دونوں کی اولاد میں پیغمبری اور کتاب پھر کوئی ان میں راہ پر ہے اور بہت ان میں نافرمان ہیں</p>"
        },
