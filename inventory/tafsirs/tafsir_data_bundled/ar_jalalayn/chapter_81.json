            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿بِأَیِّ ذَنۢبࣲ قُتِلَتۡ ۝٩﴾ وَقُرِئَ بِكَسْرِ التَّاء حِكَايَة لِمَا تُخَاطَب بِهِ وَجَوَابهَا أَنْ تَقُول قُتِلْت بلا ذنب</p>"
        },
        "10": {
            "verses": {
