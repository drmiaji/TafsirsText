            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنۡ﴾ مَا ﴿هُوَ إِلَّا ذِكۡرࣱ﴾ عِظَة ﴿لِّلۡعَـٰلَمِینَ ۝٢٧﴾ الإنس والجن</p>"
        },
