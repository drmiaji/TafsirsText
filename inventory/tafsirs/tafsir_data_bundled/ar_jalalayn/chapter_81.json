            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿مُّطَاعࣲ ثَمَّ﴾ تُطِيعهُ الْمَلَائِكَة فِي السَّمَاوَات ﴿أَمِینࣲ ۝٢١﴾ على الوحي</p>"
        },
        "22": {
            "verses": {
