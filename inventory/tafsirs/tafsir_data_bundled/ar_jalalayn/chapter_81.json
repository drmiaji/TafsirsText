            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِذَا ٱلۡجِبَالُ سُیِّرَتۡ ۝٣﴾ ذُهِبَ بِهَا عَنْ وَجْه الْأَرْض فَصَارَتْ هَبَاء مُنْبَثًّا</p>"
        },
        "4": {
