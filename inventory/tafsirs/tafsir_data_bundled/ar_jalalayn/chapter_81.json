            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِذَا ٱلنُّجُومُ ٱنكَدَرَتۡ ۝٢﴾ اِنْقَضَّتْ وَتَسَاقَطَتْ عَلَى الْأَرْض</p>"
        },
        "3": {
