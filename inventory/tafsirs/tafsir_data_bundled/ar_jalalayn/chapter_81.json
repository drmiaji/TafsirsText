            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿عَلِمَتۡ نَفۡسࣱ﴾ كُلّ نَفْس وَقْت هَذِهِ الْمَذْكُورَات وَهُوَ يَوْم الْقِيَامَة ﴿مَّاۤ أَحۡضَرَتۡ ۝١٤﴾ مِنْ خَيْر وشر</p>"
        },
        "15": {
            "verses": {
