            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَا هُوَ﴾ أَيْ الْقُرْآن ﴿بِقَوۡلِ شَیۡطَـٰنࣲ﴾ مُسْتَرِق السَّمْع ﴿رَّجِیمࣲ ۝٢٥﴾ مَرْجُوم</p>"
        },
        "26": {
