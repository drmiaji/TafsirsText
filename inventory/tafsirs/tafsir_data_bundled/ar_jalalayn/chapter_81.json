            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِذَا ٱلۡوُحُوشُ حُشِرَتۡ ۝٥﴾ جُمِعَتْ بَعْد الْبَعْث لِيَقْتَصّ لِبَعْضٍ مِنْ بَعْض ثُمَّ تَصِير تُرَابًا</p>"
        },
        "6": {
