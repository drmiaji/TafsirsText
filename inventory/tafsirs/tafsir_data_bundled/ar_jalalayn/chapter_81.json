            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِذَا ٱلصُّحُفُ﴾ صُحُف الْأَعْمَال ﴿نُشِرَتۡ ۝١٠﴾ بِالتَّخْفِيفِ وَالتَّشْدِيد فتحت وبسطت</p>"
        },
        "11": {
            "verses": {
