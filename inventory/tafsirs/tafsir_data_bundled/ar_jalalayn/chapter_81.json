            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِذَا ٱلۡبِحَارُ سُجِرَتۡ ۝٦﴾ بِالتَّخْفِيفِ وَالتَّشْدِيد أُوقِدَتْ فَصَارَتْ نارا</p>"
        },
        "7": {
