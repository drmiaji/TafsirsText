            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿لِمَن شَاۤءَ مِنكُمۡ﴾ بَدَل مِنْ الْعَالَمِينَ بِإِعَادَةِ الجار ﴿أَن یَسۡتَقِیمَ ۝٢٨﴾ باتباع الحق</p>"
        },
