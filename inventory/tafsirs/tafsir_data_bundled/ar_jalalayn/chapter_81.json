            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّهُۥ﴾ أَيْ الْقُرْآن ﴿لَقَوۡلُ رَسُولࣲ كَرِیمࣲ ۝١٩﴾ عَلَى اللَّه تَعَالَى وَهُوَ جِبْرِيل أُضِيفَ إِلَيْهِ لِنُزُولِهِ به</p>"
        },
        "20": {
            "verses": {
                "81:20": {
                    "id": 20
