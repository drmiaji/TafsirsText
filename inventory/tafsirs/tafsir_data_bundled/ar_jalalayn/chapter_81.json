            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِذَا ٱلۡجَنَّةُ أُزۡلِفَتۡ ۝١٣﴾ قُرِّبَتْ لِأَهْلِهَا لِيَدْخُلُوهَا وَجَوَاب إِذَا أَوَّل السُّورَة وَمَا عُطِفَ عَلَيْهَا</p>"
        },
        "14": {
            "verses": {
                "81:14": {
                    "id": 14
                }
