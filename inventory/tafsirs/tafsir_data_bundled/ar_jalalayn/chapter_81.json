            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلصُّبۡحِ إِذَا تَنَفَّسَ ۝١٨﴾ اِمْتَدَّ حَتَّى يَصِير نَهَارًا بينا</p>"
        },
        "19": {
            "verses": {
