            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِذَا ٱلۡجَحِیمُ﴾ النَّار ﴿سُعِرَتۡ ۝١٢﴾ بِالتَّخْفِيفِ وَالتَّشْدِيد أُجِّجَتْ</p>"
        },
        "13": {
            "verses": {
