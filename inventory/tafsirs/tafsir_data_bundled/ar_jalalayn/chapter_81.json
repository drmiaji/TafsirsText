            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِذَا ٱلۡعِشَارُ﴾ النُّوق الْحَوَامِل ﴿عُطِّلَتۡ ۝٤﴾ تُرِكَتْ بِلَا رَاعٍ أَوْ بِلَا حَلْب لِمَا دَهَاهُمْ مِنْ الْأَمْر وَإِنْ لَمْ يَكُنْ مَال أَعْجَب إِلَيْهِمْ منها</p>"
        },
        "5": {
            "verses": {
