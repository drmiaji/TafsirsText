            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِذَا ٱلسَّمَاۤءُ كُشِطَتۡ ۝١١﴾ نُزِعَتْ عَنْ أَمَاكِنهَا كَمَا يُنْزَع الْجِلْد عَنْ الشَّاة</p>"
        },
        "12": {
            "verses": {
