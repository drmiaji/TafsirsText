            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ذِی قُوَّةٍ﴾ أَيْ شَدِيد الْقُوَى ﴿عِندَ ذِی ٱلۡعَرۡشِ﴾ أَيْ اللَّه تَعَالَى ﴿مَكِینࣲ ۝٢٠﴾ ذِي مَكَانَة مُتَعَلِّق بِهِ عِنْد</p>"
        },
        "21": {
            "verses": {
