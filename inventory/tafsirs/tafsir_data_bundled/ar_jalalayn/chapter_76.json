{
    "chapter": 76,
    "verses": {
        "1": {
            "verses": {
                "76:1": {
                    "id": 1
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿هَلۡ﴾ قد ﴿أَتَىٰ عَلَى ٱلۡإِنسَـٰنِ﴾ آدم ﴿حِینࣱ مِّنَ ٱلدَّهۡرِ﴾ أربعون سنة ﴿لَمۡ یَكُن﴾ فيه ﴿شَیۡـࣰٔا مَّذۡكُورًا ۝١﴾ كان فيه مصورا من طين لا يذكر أو المراد بالإنسان الجنس وبالحين مدة الحمل</p>"
        },
        "2": {
            "verses": {
                "76:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّا خَلَقۡنَا ٱلۡإِنسَـٰنَ﴾ الجنس ﴿مِن نُّطۡفَةٍ أَمۡشَاجࣲ﴾ أخلاط أي من ماء الرجل وماء المرأة المختلطين الممتزجين ﴿نَّبۡتَلِیهِ﴾ نختبره بالتكليف والجملة مستأنفة أو حال مقدرة أي مريدين ابتلاءه حين تأهله ﴿فَجَعَلۡنَـٰهُ﴾ بسبب ذلك ﴿سَمِیعَۢا بَصِیرًا ۝٢﴾</p>"
        },
        "3": {
            "verses": {
                "76:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّا هَدَیۡنَـٰهُ ٱلسَّبِیلَ﴾ بينا له طريق الهدى ببعث الرسل ﴿إِمَّا شَاكِرࣰا﴾ أي مؤمنا ﴿وَإِمَّا كَفُورًا ۝٣﴾ حالان من المفعول أي بينا له في حال شكره أو كفره المقدرة وإما لتفصيل الأحوال</p>"
        },
        "4": {
            "verses": {
                "76:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّاۤ أَعۡتَدۡنَا﴾ هيأنا ﴿لِلۡكَـٰفِرِینَ سَلَـٰسِلَا۟﴾ يسحبون بها في النار ﴿وَأَغۡلَـٰلࣰا﴾ في أعناقهم تشد فيها السلاسل ﴿وَسَعِیرًا ۝٤﴾ نارا مسعرة أي مهيجة يعذبون بها</p>"
        },
        "5": {
            "verses": {
                "76:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّ ٱلۡأَبۡرَارَ﴾ جمع بر أو بار وهم المطيعون ﴿یَشۡرَبُونَ مِن كَأۡسࣲ﴾ هو إناء شرب الخمر وهي فيه والمراد من خمر تسمية للحال باسم المحل ومن للتبعيض ﴿كَانَ مِزَاجُهَا﴾ ما تمزج به ﴿كَافُورًا ۝٥﴾</p>"
        },
        "6": {
            "verses": {
                "76:6": {
                    "id": 6
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿عَیۡنࣰا﴾ بدل من كافورا فيها رائحته ﴿یَشۡرَبُ بِهَا﴾ منها ﴿عِبَادُ ٱللَّهِ﴾ أولياؤه ﴿یُفَجِّرُونَهَا تَفۡجِیرࣰا ۝٦﴾ يقودونها حيث شاءوا من منازلهم</p>"
        },
        "7": {
            "verses": {
                "76:7": {
                    "id": 7
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿یُوفُونَ بِٱلنَّذۡرِ﴾ في طاعة الله ﴿وَیَخَافُونَ یَوۡمࣰا كَانَ شَرُّهُۥ مُسۡتَطِیرࣰا ۝٧﴾ منتشرا</p>"
        },
        "8": {
            "verses": {
                "76:8": {
                    "id": 8
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَیُطۡعِمُونَ ٱلطَّعَامَ عَلَىٰ حُبِّهِۦ﴾ أي الطعام وشهوتهم له ﴿مِسۡكِینࣰا﴾ فقيرا ﴿وَیَتِیمࣰا﴾ لا أب له ﴿وَأَسِیرًا ۝٨﴾ يعني المحبوس بحق</p>"
        },
        "9": {
            "verses": {
                "76:9": {
                    "id": 9
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّمَا نُطۡعِمُكُمۡ لِوَجۡهِ ٱللَّهِ﴾ لطلب ثوابه ﴿لَا نُرِیدُ مِنكُمۡ جَزَاۤءࣰ وَلَا شُكُورًا ۝٩﴾ شكرا فيه علة الإطعام وهل تكلموا بذلك أو علمه الله منهم فأثنى عليهم به قولان</p>"
        },
        "10": {
            "verses": {
                "76:10": {
                    "id": 10
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّا نَخَافُ مِن رَّبِّنَا یَوۡمًا عَبُوسࣰا﴾ تكلح الوجوه فيه أي كريه المنظر لشدته ﴿قَمۡطَرِیرࣰا ۝١٠﴾ شديدا في ذلك</p>"
        },
        "11": {
            "verses": {
                "76:11": {
                    "id": 11
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَوَقَىٰهُمُ ٱللَّهُ شَرَّ ذَ ٰ⁠لِكَ ٱلۡیَوۡمِ وَلَقَّىٰهُمۡ﴾ أعطاهم ﴿نَضۡرَةࣰ﴾ حسنا وإضاءة في وجوههم ﴿وَسُرُورࣰا ۝١١﴾</p>"
        },
        "12": {
            "verses": {
                "76:12": {
                    "id": 12
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَجَزَىٰهُم بِمَا صَبَرُوا۟﴾ بصبرهم عن المعصية ﴿جَنَّةࣰ﴾ أدخلوها ﴿وَحَرِیرࣰا ۝١٢﴾ البسوه</p>"
        },
        "13": {
            "verses": {
                "76:13": {
                    "id": 13
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿مُّتَّكِـِٔینَ﴾ حال من مرفوع أدخلوها المقدر ﴿فِیهَا عَلَى ٱلۡأَرَاۤىِٕكِۖ﴾ السرر في الحجال ﴿لَا یَرَوۡنَ﴾ لا يجدون حال ثانية ﴿فِیهَا شَمۡسࣰا وَلَا زَمۡهَرِیرࣰا ۝١٣﴾ لا حرا ولا بردا وقيل الزمهرير القمر فهي مضيئة من غير شمس ولا قمر</p>"
        },
        "14": {
            "verses": {
                "76:14": {
                    "id": 14
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَدَانِیَةً﴾ قريبة عطف على محل لا يرون أي غير رائين ﴿عَلَیۡهِمۡ﴾ منهم ﴿ظِلَـٰلُهَا﴾ شجرها ﴿وَذُلِّلَتۡ قُطُوفُهَا تَذۡلِیلࣰا ۝١٤﴾ أدنيت ثمارها فينالها القائم والقاعد والمضطجع</p>"
        },
        "15": {
            "verses": {
                "76:15": {
                    "id": 15
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَیُطَافُ عَلَیۡهِم﴾ فيها ﴿بِـَٔانِیَةࣲ مِّن فِضَّةࣲ وَأَكۡوَابࣲ﴾ أقداح بلا عرى ﴿كَانَتۡ قَوَارِیرَا۠ ۝١٥﴾</p>"
        },
        "16": {
            "verses": {
                "76:16": {
                    "id": 16
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿قَوَارِیرَا۟ مِن فِضَّةࣲ﴾ أي أنها من فضة يرى باطنها من ظاهرها كالزجاج ﴿قَدَّرُوهَا﴾ أي الطائفون ﴿تَقۡدِیرࣰا ۝١٦﴾ على قدر ري الشاربين من غير زيادة ولا نقص وذلك ألذ الشراب</p>"
        },
        "17": {
            "verses": {
                "76:17": {
                    "id": 17
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَیُسۡقَوۡنَ فِیهَا كَأۡسࣰا﴾ خمرا ﴿كَانَ مِزَاجُهَا﴾ ما تمزج به ﴿زَنجَبِیلًا ۝١٧﴾</p>"
        },
        "18": {
            "verses": {
                "76:18": {
                    "id": 18
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿عَیۡنࣰا﴾ بدل من زنجبيلا ﴿فِیهَا تُسَمَّىٰ سَلۡسَبِیلࣰا ۝١٨﴾ يعنى أن ماءها كالزنجبيل الذى تستلذ به العرب سهل المساغ في الحلق</p>"
        },
        "19": {
            "verses": {
                "76:19": {
                    "id": 19
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَیَطُوفُ عَلَیۡهِمۡ وِلۡدَ ٰ⁠نࣱ مُّخَلَّدُونَ﴾ بصفة الولدان لا يشيبون ﴿إِذَا رَأَیۡتَهُمۡ حَسِبۡتَهُمۡ﴾ لحسنهم وانتشارهم في الخدمة ﴿لُؤۡلُؤࣰا مَّنثُورࣰا ۝١٩﴾ من سلكه أو من صدفه وهو أحسن منه في غير ذلك</p>"
        },
        "20": {
            "verses": {
                "76:20": {
                    "id": 20
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِذَا رَأَیۡتَ ثَمَّ﴾ أي وجدت الرؤية منك في الجنة ﴿رَأَیۡتَ﴾ جواب إذا ﴿نَعِیمࣰا﴾ لا يوصف ﴿وَمُلۡكࣰا كَبِیرًا ۝٢٠﴾ واسعا لا غاية له</p>"
        },
        "21": {
            "verses": {
                "76:21": {
                    "id": 21
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿عَـٰلِیَهُمۡ﴾ فوقهم فنصبه على الظرفية وهو خبر لمبتدأ بعد وفي قراءة بسكون الياء مبتدأ وما بعده خبر والضمير المتصل به للمعطوف عليهم ﴿ثِیَابُ سُندُسٍ﴾ حرير ﴿خُضۡرࣱ﴾ بالرفع ﴿وَإِسۡتَبۡرَقࣲۖ﴾ بالجر ما غلظ من الديباج فهو البطائن والسندس الظهائر وفي قراءة عكس ما ذكر فيهما وفي أخرى برفعهما وفي أخرى بجرهما ﴿وَحُلُّوۤا۟ أَسَاوِرَ مِن فِضَّةࣲ﴾ وفي موضع من ذهب للإيذان بأنهم يحلون من النوعين معا ومفرقا ﴿وَسَقَىٰهُمۡ رَبُّهُمۡ شَرَابࣰا طَهُورًا ۝٢١﴾ مبالغة في طهارته ونظافته بخلاف خمر الدنيا</p>"
        },
        "22": {
            "verses": {
                "76:22": {
                    "id": 22
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّ هَـٰذَا﴾ النعيم ﴿كَانَ لَكُمۡ جَزَاۤءࣰ وَكَانَ سَعۡیُكُم مَّشۡكُورًا ۝٢٢﴾</p>"
        },
        "23": {
            "verses": {
                "76:23": {
                    "id": 23
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّا نَحۡنُ﴾ تَأْكِيد لِاسْمِ إنَّ أَوْ فَصْل ﴿نَزَّلۡنَا عَلَیۡكَ ٱلۡقُرۡءَانَ تَنزِیلࣰا ۝٢٣﴾ خبر إن أي فصلناه ولم ننزله جملة واحدة</p>"
        },
        "24": {
            "verses": {
                "76:24": {
                    "id": 24
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَٱصۡبِرۡ لِحُكۡمِ رَبِّكَ﴾ عليك بتبليغ رسالته ﴿وَلَا تُطِعۡ مِنۡهُمۡ﴾ أي الكفار ﴿ءَاثِمًا أَوۡ كَفُورࣰا ۝٢٤﴾ أي عتبة بن ربيعة والوليد بن المغيرة قالا للنبي صلى الله عليه وسلم ارجع عن هذا الأمر ويجوز أن يراد كل آثم وكافر أي لا تطع أحدهما أيا كان فيما دعاك إليه من إثم أو كفر</p>"
        },
        "25": {
            "verses": {
                "76:25": {
                    "id": 25
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱذۡكُرِ ٱسۡمَ رَبِّكَ﴾ في الصلاة ﴿بُكۡرَةࣰ وَأَصِیلࣰا ۝٢٥﴾ يعني الفجر والظهر والعصر</p>"
        },
        "26": {
            "verses": {
                "76:26": {
                    "id": 26
                }
