                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿حمۤ ۝١﴾ اللَّه أَعْلَم بِمُرَادِهِ بِهِ</h2>"
        },
        "2": {
            "verses": {
                "44:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلۡكِتَـٰبِ﴾ الْقُرْآن ﴿ٱلۡمُبِینِ ۝٢﴾ الْمُظْهِر الْحَلَال مِنْ الْحَرَام</p>"
        },
        "3": {
            "verses": {
                "44:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّاۤ أَنزَلۡنَـٰهُ فِی لَیۡلَةࣲ مُّبَـٰرَكَةٍۚ﴾ هِيَ لَيْلَة الْقَدْر أَوْ لَيْلَة النِّصْف مِنْ شَعْبَان نَزَلَ فِيهَا مِنْ أُمّ الْكِتَاب مِنْ السَّمَاء السَّابِعَة إلَى سَمَاء الدُّنْيَا ﴿إِنَّا كُنَّا مُنذِرِینَ ۝٣﴾ مُخَوِّفِينَ به</p>"
        },
        "4": {
            "verses": {
                "44:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فِیهَا﴾ أَيْ فِي لَيْلَة الْقَدْر أَوْ لَيْلَة النِّصْف مِنْ شَعْبَان ﴿یُفۡرَقُ﴾ يُفْصَل ﴿كُلُّ أَمۡرٍ حَكِیمٍ ۝٤﴾ مُحَكَّم مِنْ الْأَرْزَاق وَالْآجَال وَغَيْرهمَا الَّتِي تَكُون فِي السَّنَة إلَى مِثْل تِلْكَ اللَّيْلَة</p>"
        },
        "5": {
            "verses": {
                "44:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَمۡرࣰا﴾ فَرْقًا ﴿مِّنۡ عِندِنَاۤۚ إِنَّا كُنَّا مُرۡسِلِینَ ۝٥﴾ الرُّسُل مُحَمَّدًا وَمَنْ قَبْله</p>"
        },
        "6": {
            "verses": {
                "44:6": {
                    "id": 6
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿رَحۡمَةࣰ﴾ رَأْفَة بِالْمُرْسَلِ إلَيْهِمْ ﴿مِّن رَّبِّكَۚ إِنَّهُۥ هُوَ ٱلسَّمِیعُ﴾ لأقوالهم ﴿ٱلۡعَلِیمُ ۝٦﴾ بأفعالهم</p>"
        },
        "7": {
            "verses": {
                "44:7": {
                    "id": 7
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿رَبُّ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِ وَمَا بَیۡنَهُمَاۤۖ﴾ بِرَفْعِ رَبّ خَبَر ثَالِث وَبِجَرِّهِ بَدَل مِنْ رَبّك ﴿إِن كُنتُم﴾ يَا أَهْل مَكَّة ﴿مُّوقِنِینَ ۝٧﴾ بِأَنَّهُ تَعَالَى رَبّ السَّمَاوَات والأرض فأيقنوا بأن محمدا رسوله</p>"
        },
        "8": {
            "verses": {
                "44:8": {
                    "id": 8
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿لَاۤ إِلَـٰهَ إِلَّا هُوَ یُحۡیِۦ وَیُمِیتُۖ رَبُّكُمۡ وَرَبُّ ءَابَاۤىِٕكُمُ ٱلۡأَوَّلِینَ ۝٨﴾</p>"
        },
        "9": {
            "verses": {
                "44:9": {
                    "id": 9
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿بَلۡ هُمۡ فِی شَكࣲّ﴾ مِنْ الْبَعْث ﴿یَلۡعَبُونَ ۝٩﴾ اسْتِهْزَاء بِك يَا مُحَمَّد فَقَالَ اللَّهُمَّ أَعِنِّي عليهم بسبع كسبع يوسف</p>"
        },
        "10": {
            "verses": {
                "44:10": {
                    "id": 10
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>قال تعالى ﴿فَٱرۡتَقِبۡ یَوۡمَ تَأۡتِی ٱلسَّمَاۤءُ بِدُخَانࣲ مُّبِینࣲ ۝١٠﴾ فَأَجْدَبَتْ الْأَرْض وَاشْتَدَّ بِهِمْ الْجُوع إلَى أَنْ رَأَوْا مِنْ شِدَّته كَهَيْئَةِ الدُّخَان بَيْن السَّمَاء وَالْأَرْض</p>"
        },
        "11": {
            "verses": {
                "44:11": {
                    "id": 11
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿یَغۡشَى ٱلنَّاسَۖ﴾ فَقَالُوا ﴿هَـٰذَا عَذَابٌ أَلِیمࣱ ۝١١﴾</h2>"
        },
        "12": {
            "verses": {
                "44:12": {
                    "id": 12
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿رَّبَّنَا ٱكۡشِفۡ عَنَّا ٱلۡعَذَابَ إِنَّا مُؤۡمِنُونَ ۝١٢﴾ مُصَدِّقُونَ نَبِيّك</p>"
        },
        "13": {
            "verses": {
                "44:13": {
                    "id": 13
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>قال تعالى ﴿أَنَّىٰ لَهُمُ ٱلذِّكۡرَىٰ﴾ أَيْ لَا يَنْفَعهُمْ الْإِيمَان عِنْد نُزُول الْعَذَاب ﴿وَقَدۡ جَاۤءَهُمۡ رَسُولࣱ مُّبِینࣱ ۝١٣﴾ بين الرسالة</p>"
        },
        "14": {
            "verses": {
                "44:14": {
                    "id": 14
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ تَوَلَّوۡا۟ عَنۡهُ وَقَالُوا۟ مُعَلَّمࣱ﴾ أَيْ يُعَلِّمهُ القرآن بشر ﴿مَّجۡنُونٌ ۝١٤﴾</p>"
        },
        "15": {
            "verses": {
                "44:15": {
                    "id": 15
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّا كَاشِفُوا۟ ٱلۡعَذَابِ﴾ أَيْ الْجُوع عَنْكُمْ زَمَنًا ﴿قَلِیلًاۚ﴾ فَكَشَفَ عَنْهُمْ ﴿إِنَّكُمۡ عَاۤىِٕدُونَ ۝١٥﴾ إلَى كُفْركُمْ فعادوا إليه</p>"
        },
        "16": {
            "verses": {
                "44:16": {
                    "id": 16
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>اذْكُرْ ﴿یَوۡمَ نَبۡطِشُ ٱلۡبَطۡشَةَ ٱلۡكُبۡرَىٰۤ﴾ هُوَ يَوْم بدر ﴿إِنَّا مُنتَقِمُونَ ۝١٦﴾ منهم والبطش الأخذ بقوة</p>"
        },
        "17": {
            "verses": {
                "44:17": {
                    "id": 17
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَلَقَدۡ فَتَنَّا﴾ بَلَوْنَا ﴿قَبۡلَهُمۡ قَوۡمَ فِرۡعَوۡنَ﴾ مَعَهُ ﴿وَجَاۤءَهُمۡ رَسُولࣱ﴾ هُوَ مُوسَى عَلَيْهِ السَّلَام ﴿كَرِیمٌ ۝١٧﴾ عَلَى اللَّه تَعَالَى</p>"
        },
        "18": {
            "verses": {
                "44:18": {
                    "id": 18
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَنۡ﴾ أَيْ بِأَنْ ﴿أَدُّوۤا۟ إِلَیَّ﴾ مَا أَدْعُوكُمْ إلَيْهِ مِنْ الْإِيمَان أَيْ أَظْهِرُوا إيمَانكُمْ لِي يَا ﴿عِبَادَ ٱللَّهِۖ إِنِّی لَكُمۡ رَسُولٌ أَمِینࣱ ۝١٨﴾ عَلَى مَا أُرْسِلْت بِهِ</p>"
        },
        "19": {
            "verses": {
                "44:19": {
                    "id": 19
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَن لَّا تَعۡلُوا۟﴾ تَتَجَبَّرُوا ﴿عَلَى ٱللَّهِۖ﴾ بِتَرْكِ طَاعَته ﴿إِنِّیۤ ءَاتِیكُم بِسُلۡطَـٰنࣲ﴾ بُرْهَان ﴿مُّبِینࣲ ۝١٩﴾ بَيِّن على رسالتي فتوعدوه بالرجم</p>"
        },
        "20": {
            "verses": {
                "44:20": {
                    "id": 20
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>فقال ﴿وَإِنِّی عُذۡتُ بِرَبِّی وَرَبِّكُمۡ أَن تَرۡجُمُونِ ۝٢٠﴾ بالحجارة</p>"
        },
        "21": {
            "verses": {
                "44:21": {
                    "id": 21
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِن لَّمۡ تُؤۡمِنُوا۟ لِی﴾ تُصَدِّقُونِي ﴿فَٱعۡتَزِلُونِ ۝٢١﴾ فَاتْرُكُوا أَذَايَ فَلَمْ يَتْرُكُوهُ</p>"
        },
        "22": {
            "verses": {
                "44:22": {
                    "id": 22
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَدَعَا رَبَّهُۥۤ أَنَّ﴾ أَيْ بِأَنَّ ﴿هَـٰۤؤُلَاۤءِ قَوۡمࣱ مُّجۡرِمُونَ ۝٢٢﴾ مشركون</p>"
        },
        "23": {
            "verses": {
                "44:23": {
                    "id": 23
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>فقال تعالى ﴿فَأَسۡرِ﴾ بِقَطْعِ الْهَمْزَة وَوَصْلهَا ﴿بِعِبَادِی﴾ بَنِي إسْرَائِيل ﴿لَیۡلًا إِنَّكُم مُّتَّبَعُونَ ۝٢٣﴾ يَتَّبِعكُمْ فِرْعَوْن وَقَوْمه</p>"
        },
        "24": {
            "verses": {
                "44:24": {
                    "id": 24
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱتۡرُكِ ٱلۡبَحۡرَ﴾ إذَا قَطَعْته أَنْتَ وَأَصْحَابك ﴿رَهۡوًاۖ﴾ سَاكِنًا مُنْفَرِجًا حَتَّى يَدْخُلهُ الْقِبْط ﴿إِنَّهُمۡ جُندࣱ مُّغۡرَقُونَ ۝٢٤﴾ فَاطْمَأَنَّ بِذَلِكَ فَأُغْرِقُوا</p>"
        },
        "25": {
            "verses": {
                "44:25": {
                    "id": 25
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿كَمۡ تَرَكُوا۟ مِن جَنَّـٰتࣲ﴾ بَسَاتِين ﴿وَعُیُونࣲ ۝٢٥﴾ تَجْرِي</p>"
        },
        "26": {
            "verses": {
                "44:26": {
                    "id": 26
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
