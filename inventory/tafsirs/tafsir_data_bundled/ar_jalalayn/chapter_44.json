            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿فِی جَنَّـٰتࣲ﴾ بساتين ﴿وَعُیُونࣲ ۝٥٢﴾</h2>"
        },
