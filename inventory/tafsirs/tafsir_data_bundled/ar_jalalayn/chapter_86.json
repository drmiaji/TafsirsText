            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلسَّمَاۤءِ وَٱلطَّارِقِ ۝١﴾ أَصْله كُلّ آتٍ لَيْلًا وَمِنْهُ النُّجُوم لِطُلُوعِهَا لَيْلًا</p>"
        },
        "2": {
            "verses": {
                "86:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَاۤ أَدۡرَىٰكَ﴾ أَعْلَمك ﴿مَا ٱلطَّارِقُ ۝٢﴾ مُبْتَدَأ وَخَبَر فِي مَحَلّ الْمَفْعُول الثَّانِي لَأَدْرَى وَمَا بَعْد مَا الْأُولَى خَبَرهَا وَفِيهِ تَعْظِيم لِشَأْنِ الطَّارِق الْمُفَسَّر بِمَا بَعْده هُوَ</p>"
        },
        "3": {
            "verses": {
                "86:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلنَّجۡمُ﴾ أَيْ الثُّرَيَّا أَوْ كُلّ نَجْم ﴿ٱلثَّاقِبُ ۝٣﴾ الْمُضِيء لِثَقْبِهِ الظَّلَام بِضَوْئِهِ وَجَوَاب الْقَسَم</p>"
        },
        "4": {
            "verses": {
                "86:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِن كُلُّ نَفۡسࣲ لَّمَا عَلَیۡهَا حَافِظࣱ ۝٤﴾ بِتَخْفِيفِ مَا فَهِيَ مَزِيدَة وَإِنْ مُخَفَّفَة مِنْ الثَّقِيلَة وَاسْمهَا مَحْذُوف أَيْ إِنَّهُ وَاللَّام فَارِقَة وَبِتَشْدِيدِهَا فَإِنْ نَافِيَة وَلَمَا بِمَعْنَى إِلَّا وَالْحَافِظ مِنْ الْمَلَائِكَة يَحْفَظ عَمَلهَا مِنْ خَيْر وَشَرّ</p>"
        },
        "5": {
            "verses": {
                "86:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَلۡیَنظُرِ ٱلۡإِنسَـٰنُ﴾ نَظَر اِعْتِبَار ﴿مِمَّ خُلِقَ ۝٥﴾ مِنْ أي شيء</p>"
        },
        "6": {
            "verses": {
                "86:6": {
                    "id": 6
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>جوابه ﴿خُلِقَ مِن مَّاۤءࣲ دَافِقࣲ ۝٦﴾ ذِي اِنْدِفَاق مِنْ الرَّجُل وَالْمَرْأَة فِي رَحِمهَا</p>"
        },
        "7": {
            "verses": {
                "86:7": {
                    "id": 7
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿یَخۡرُجُ مِنۢ بَیۡنِ ٱلصُّلۡبِ﴾ لِلرَّجُلِ ﴿وَٱلتَّرَاۤىِٕبِ ۝٧﴾ لِلْمَرْأَةِ وَهِيَ عِظَام الصَّدْر</p>"
        },
        "8": {
            "verses": {
                "86:8": {
                    "id": 8
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّهُۥ﴾ تَعَالَى ﴿عَلَىٰ رَجۡعِهِۦ﴾ بَعْث الْإِنْسَان بَعْد مَوْته ﴿لَقَادِرࣱ ۝٨﴾ فَإِذَا اِعْتَبَرَ أَصْله عَلِمَ أَنَّ الْقَادِر عَلَى ذَلِكَ قَادِر عَلَى بَعْثه</p>"
        },
        "9": {
            "verses": {
                "86:9": {
                    "id": 9
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿یَوۡمَ تُبۡلَى﴾ تُخْتَبَر وَتُكْشَف ﴿ٱلسَّرَاۤىِٕرُ ۝٩﴾ ضَمَائِر الْقُلُوب في العقائد والنبات</p>"
        },
        "10": {
            "verses": {
                "86:10": {
                    "id": 10
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَمَا لَهُۥ﴾ لِمُنْكِرِ الْبَعْث ﴿مِن قُوَّةࣲ﴾ يَمْتَنِع بِهَا مِنْ الْعَذَاب ﴿وَلَا نَاصِرࣲ ۝١٠﴾ يَدْفَعهُ عَنْهُ</p>"
        },
        "11": {
            "verses": {
                "86:11": {
                    "id": 11
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلسَّمَاۤءِ ذَاتِ ٱلرَّجۡعِ ۝١١﴾ الْمَطَر لِعَوْدِهِ كُلّ حِين</p>"
        },
        "12": {
            "verses": {
                "86:12": {
                    "id": 12
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَٱلۡأَرۡضِ ذَاتِ ٱلصَّدۡعِ ۝١٢﴾ الشَّقّ عَنْ النَّبَات</h2>"
        },
        "13": {
            "verses": {
                "86:13": {
                    "id": 13
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّهُۥ﴾ أَيْ الْقُرْآن ﴿لَقَوۡلࣱ فَصۡلࣱ ۝١٣﴾ يَفْصِل بَيْن الْحَقّ والباطل</p>"
        },
        "14": {
            "verses": {
                "86:14": {
                    "id": 14
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَا هُوَ بِٱلۡهَزۡلِ ۝١٤﴾ بِاللَّعِبِ وَالْبَاطِل</h2>"
        },
        "15": {
            "verses": {
                "86:15": {
                    "id": 15
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّهُمۡ﴾ أَيْ الْكُفَّار ﴿یَكِیدُونَ كَیۡدࣰا ۝١٥﴾ يَعْمَلُونَ الْمَكَايِد لِلنَّبِيِّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ</p>"
        },
        "16": {
            "verses": {
                "86:16": {
                    "id": 16
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَكِیدُ كَیۡدࣰا ۝١٦﴾ أَسْتَدْرِجهُمْ مِنْ حَيْثُ لَا يَعْلَمُونَ</p>"
        },
        "17": {
            "verses": {
                "86:17": {
                    "id": 17
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَمَهِّلِ﴾ يَا مُحَمَّد ﴿ٱلۡكَـٰفِرِینَ أَمۡهِلۡهُمۡ﴾ تَأْكِيد حَسَّنَهُ مُخَالَفَة اللَّفْظ أَيْ أَنْظِرْهُمْ ﴿رُوَیۡدَۢا ۝١٧﴾ قَلِيلًا وَهُوَ مصدر مؤكد لمعنى العالم مُصَغَّر رَوْد أَوْ أَرْوَاد عَلَى التَّرْخِيم وَقَدْ أَخَذَهُمْ اللَّه تَعَالَى بِبَدْرٍ وَنَسَخَ الْإِمْهَال بِآيَةِ السيف أي الأمر بالقتال والجهاد</p>"
        }
    }
