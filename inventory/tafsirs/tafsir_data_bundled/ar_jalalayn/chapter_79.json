                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلنَّـٰزِعَـٰتِ﴾ الْمَلَائِكَة تَنْزِع أَرْوَاح الْكُفَّار ﴿غَرۡقࣰا ۝١﴾ نَزْعًا بشدة</p>"
        },
        "2": {
            "verses": {
                "79:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلنَّـٰشِطَـٰتِ نَشۡطࣰا ۝٢﴾ الْمَلَائِكَة تَنْشِط أَرْوَاح الْمُؤْمِنِينَ أَيْ تسلها برفق</p>"
        },
        "3": {
            "verses": {
                "79:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلسَّـٰبِحَـٰتِ سَبۡحࣰا ۝٣﴾ الْمَلَائِكَة تَسْبَح مِنْ السَّمَاء بِأَمْرِهِ تَعَالَى أَيْ تَنْزِل</p>"
        },
        "4": {
            "verses": {
                "79:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَٱلسَّـٰبِقَـٰتِ سَبۡقࣰا ۝٤﴾ الْمَلَائِكَة تَسْبِق بِأَرْوَاحِ الْمُؤْمِنِينَ إِلَى الجنة</p>"
        },
        "5": {
            "verses": {
                "79:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَٱلۡمُدَبِّرَ ٰ⁠تِ أَمۡرࣰا ۝٥﴾ الْمَلَائِكَة تُدَبِّر أَمْر الدُّنْيَا أَيْ تَنْزِل بِتَدْبِيرِهِ وَجَوَاب هَذِهِ الْأَقْسَام مَحْذُوف أَيْ لَتُبْعَثُنَّ يَا كُفَّار مَكَّة وَهُوَ عَامِل فِي</p>"
        },
        "6": {
            "verses": {
                "79:6": {
                    "id": 6
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿یَوۡمَ تَرۡجُفُ ٱلرَّاجِفَةُ ۝٦﴾ النَّفْخَة الْأُولَى بِهَا يَرْجُف كُلّ شَيْء أَيْ يَتَزَلْزَل فَوُصِفَتْ بِمَا يَحْدُث منها</p>"
        },
        "7": {
            "verses": {
                "79:7": {
                    "id": 7
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿تَتۡبَعُهَا ٱلرَّادِفَةُ ۝٧﴾ النَّفْخَة الثَّانِيَة وَبَيْنهمَا أَرْبَعُونَ سَنَة وَالْجُمْلَة حَال مِنْ الرَّاجِفَة فَالْيَوْم وَاسِع لِلنَّفْخَتَيْنِ وَغَيْرهمَا فَصَحَّ ظَرْفِيَّته لِلْبَعْثِ الْوَاقِع عَقِب الثَّانِيَة</p>"
        },
        "8": {
            "verses": {
                "79:8": {
                    "id": 8
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿قُلُوبࣱ یَوۡمَىِٕذࣲ وَاجِفَةٌ ۝٨﴾ خَائِفَة قَلِقَة</h2>"
        },
        "9": {
            "verses": {
                "79:9": {
                    "id": 9
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿أَبۡصَـٰرُهَا خَـٰشِعَةࣱ ۝٩﴾ ذَلِيلَة لِهَوْلِ مَا تَرَى</h2>"
        },
        "10": {
            "verses": {
                "79:10": {
                    "id": 10
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿یَقُولُونَ﴾ أَيْ أَرْبَاب الْقُلُوب وَالْأَبْصَار اِسْتِهْزَاء وَإِنْكَارًا لِلْبَعْثِ ﴿أَءِنَّا﴾ بِتَحْقِيقِ الْهَمْزَتَيْنِ وَتَسْهِيل الثَّانِيَة وَإِدْخَال أَلِف بَيْنهمَا عَلَى الْوَجْهَيْنِ فِي الْمَوْضِعَيْنِ ﴿لَمَرۡدُودُونَ فِی ٱلۡحَافِرَةِ ۝١٠﴾ أَيْ أَنُرَدُّ بَعْد الْمَوْت إِلَى الْحَيَاة وَالْحَافِرَة اِسْم لِأَوَّلِ الْأَمْر وَمِنْهُ رَجَعَ فُلَان فِي حَافِرَته إِذَا رَجَعَ مِنْ حَيْثُ جَاءَ</p>"
        },
        "11": {
            "verses": {
                "79:11": {
                    "id": 11
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَءِذَا كُنَّا عِظَـٰمࣰا نَّخِرَةࣰ ۝١١﴾ وَفِي قِرَاءَة {نَّـٰخِرَةࣰ} بَالِيَة مُتَفَتِّتَة نَحْيَا</p>"
        },
        "12": {
            "verses": {
                "79:12": {
                    "id": 12
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿قَالُوا۟ تِلۡكَ﴾ أَيْ رَجْعَتنَا إِلَى الْحَيَاة ﴿إِذࣰا﴾ إن صحت ﴿كَرَّةٌ﴾ رجعة ﴿خَاسِرَةࣱ ۝١٢﴾ ذات خسران</p>"
        },
        "13": {
            "verses": {
                "79:13": {
                    "id": 13
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>قال تعالى ﴿فَإِنَّمَا هِیَ﴾ أَيْ الرَّادِفَة الَّتِي يَعْقُبهَا الْبَعْث ﴿زَجۡرَةࣱ﴾ نَفْخَة ﴿وَ ٰ⁠حِدَةࣱ ۝١٣﴾ فَإِذَا نُفِخَتْ</p>"
        },
        "14": {
            "verses": {
                "79:14": {
                    "id": 14
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَإِذَا هُم﴾ أَيْ كُلّ الْخَلَائِق ﴿بِٱلسَّاهِرَةِ ۝١٤﴾ بِوَجْهِ الأرض أحياء بعد ما كَانُوا بِبَطْنِهَا أَمْوَاتًا</p>"
        },
        "15": {
            "verses": {
                "79:15": {
                    "id": 15
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿هَلۡ أَتَىٰكَ﴾ يَا مُحَمَّد ﴿حَدِیثُ مُوسَىٰۤ ۝١٥﴾ عَامِل في</p>"
        },
        "16": {
            "verses": {
                "79:16": {
                    "id": 16
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِذۡ نَادَىٰهُ رَبُّهُۥ بِٱلۡوَادِ ٱلۡمُقَدَّسِ طُوًى ۝١٦﴾ اِسْم الوادي بالتنوين وتركه فقال</p>"
        },
        "17": {
            "verses": {
                "79:17": {
                    "id": 17
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ٱذۡهَبۡ إِلَىٰ فِرۡعَوۡنَ إِنَّهُۥ طَغَىٰ ۝١٧﴾ تَجَاوَزَ الْحَدّ في الكفر</p>"
        },
        "18": {
            "verses": {
                "79:18": {
                    "id": 18
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَقُلۡ هَل لَّكَ﴾ أَدْعُوك ﴿إِلَىٰۤ أَن تَزَكَّىٰ ۝١٨﴾ وَفِي قِرَاءَة بِتَشْدِيدِ الزَّاي بِإِدْغَامِ التَّاء الثَّانِيَة فِي الْأَصْل فِيهَا تَتَطَهَّر مِنْ الشِّرْك بِأَنْ تَشْهَد أَنْ لَا إِلَه إِلَّا اللَّه</p>"
        },
        "19": {
            "verses": {
                "79:19": {
                    "id": 19
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَهۡدِیَكَ إِلَىٰ رَبِّكَ﴾ أَدُلّك عَلَى مَعْرِفَته بِبُرْهَانٍ ﴿فَتَخۡشَىٰ ۝١٩﴾ فتخافه</p>"
        },
        "20": {
            "verses": {
                "79:20": {
                    "id": 20
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَأَرَىٰهُ ٱلۡـَٔایَةَ ٱلۡكُبۡرَىٰ ۝٢٠﴾ مِنْ آيَاته السَّبْع وَهِيَ الْيَد أَوْ الْعَصَا</p>"
        },
        "21": {
            "verses": {
                "79:21": {
                    "id": 21
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿فَكَذَّبَ﴾ فِرْعَوْن مُوسَى ﴿وَعَصَىٰ ۝٢١﴾ اللَّه تَعَالَى</h2>"
        },
        "22": {
            "verses": {
                "79:22": {
                    "id": 22
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ أَدۡبَرَ﴾ عَنْ الْإِيمَان ﴿یَسۡعَىٰ ۝٢٢﴾ فِي الْأَرْض بِالْفَسَادِ</p>"
        },
        "23": {
            "verses": {
                "79:23": {
                    "id": 23
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿فَحَشَرَ﴾ جَمَعَ السَّحَرَة وَجُنْده ﴿فَنَادَىٰ ۝٢٣﴾</h2>"
        },
        "24": {
            "verses": {
                "79:24": {
                    "id": 24
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿فَقَالَ أَنَا۠ رَبُّكُمُ ٱلۡأَعۡلَىٰ ۝٢٤﴾ لَا رَبّ فَوْقِي</h2>"
        },
        "25": {
            "verses": {
                "79:25": {
                    "id": 25
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَأَخَذَهُ ٱللَّهُ﴾ أَهْلَكَهُ بِالْغَرَقِ ﴿نَكَالَ﴾ عُقُوبَة ﴿ٱلۡـَٔاخِرَةِ﴾ أَيْ هَذِهِ الْكَلِمَة ﴿وَٱلۡأُولَىٰۤ ۝٢٥﴾ أَيْ قَوْله قَبْلهَا مَا عَلِمْت لَكُمْ مِنْ إِلَه غَيْرِي وَكَانَ بَيْنهمَا أَرْبَعُونَ سَنَة</p>"
        },
        "26": {
            "verses": {
                "79:26": {
                    "id": 26
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّ فِی ذَ ٰ⁠لِكَ﴾ الْمَذْكُور ﴿لَعِبۡرَةࣰ لِّمَن یَخۡشَىٰۤ ۝٢٦﴾ الله تعالى</p>"
        },
        "27": {
            "verses": {
                "79:27": {
                    "id": 27
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ءَأَنتُمۡ﴾ بِتَحْقِيقِ الْهَمْزَتَيْنِ وَإِبْدَال الثَّانِيَة أَلِفًا وَتَسْهِيلهَا وَإِدْخَال ألف بين المسهلة والأخرى وتركه أي مُنْكِرُو الْبَعْث ﴿أَشَدُّ خَلۡقًا أَمِ ٱلسَّمَاۤءُۚ﴾ أَشَدّ خَلْقًا ﴿بَنَىٰهَا ۝٢٧﴾ بَيَان لِكَيْفِيَّةِ خَلْقهَا</p>"
        },
