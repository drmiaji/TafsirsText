            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلۡأَرۡضَ بَعۡدَ ذَ ٰ⁠لِكَ دَحَىٰهَاۤ ۝٣٠﴾ بَسَطَهَا وَكَانَتْ مَخْلُوقَة قَبْل السَّمَاء مِنْ غَيْر دَحْو</p>"
        },
        "31": {
