            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿فَإِنَّ ٱلۡجَحِیمَ هِیَ ٱلۡمَأۡوَىٰ ۝٣٩﴾ مَأْوَاهُ</h2>"
        },
