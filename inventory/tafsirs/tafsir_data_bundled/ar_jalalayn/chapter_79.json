            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿یَوۡمَ یَتَذَكَّرُ ٱلۡإِنسَـٰنُ﴾ بَدَل مِنْ إِذَا ﴿مَا سَعَىٰ ۝٣٥﴾ فِي الدُّنْيَا مِنْ خَيْر وَشَرّ</p>"
        },
        "36": {
