            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فِیمَ﴾ فِي أَيّ شَيْء ﴿أَنتَ مِن ذِكۡرَىٰهَاۤ ۝٤٣﴾ أَيْ لَيسَ عِنْدك عِلْمهَا حَتَّى تَذْكُرهَا</p>"
        },
