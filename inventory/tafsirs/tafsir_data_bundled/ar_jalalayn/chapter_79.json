                "language_name": "english"
            },
            "text": "<p>﴿رَفَعَ سَمۡكَهَا﴾ تَفْسِير لِكَيْفِيَّةِ الْبِنَاء أَيْ جَعَلَ سَمْتهَا فِي جِهَة الْعُلُوّ رَفِيعًا وَقِيلَ سَمْكهَا سَقْفهَا ﴿فَسَوَّىٰهَا ۝٢٨﴾ جَعَلَهَا مُسْتَوِيَة بِلَا عَيْب</p>"
        },
        "29": {
            "verses": {
                "79:29": {
                    "id": 29
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
