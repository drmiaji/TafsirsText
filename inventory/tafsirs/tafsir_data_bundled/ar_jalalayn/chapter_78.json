            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿عَمَّ﴾ عَنْ أَيّ شَيْء ﴿یَتَسَاۤءَلُونَ ۝١﴾ يَسْأَل بَعْض قريش بعضا</p>"
        },
        "2": {
            "verses": {
                "78:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿عَنِ ٱلنَّبَإِ ٱلۡعَظِیمِ ۝٢﴾ بَيَان لِذَلِكَ الشَّيْء وَالِاسْتِفْهَام لِتَفْخِيمِهِ وَهُوَ مَا جَاءَ بِهِ النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ مِنْ الْقُرْآن الْمُشْتَمِل عَلَى البعث وغيره</p>"
        },
        "3": {
            "verses": {
                "78:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلَّذِی هُمۡ فِیهِ مُخۡتَلِفُونَ ۝٣﴾ فَالْمُؤْمِنُونَ يُثْبِتُونَهُ وَالْكَافِرُونَ ينكرونه</p>"
        },
        "4": {
            "verses": {
                "78:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿كَلَّا﴾ رَدْع ﴿سَیَعۡلَمُونَ ۝٤﴾ مَا يَحِلّ بِهِمْ عَلَى إنكارهم له</p>"
        },
        "5": {
            "verses": {
                "78:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ كَلَّا سَیَعۡلَمُونَ ۝٥﴾ تَأْكِيد وَجِيءَ فِيهِ بِثُمَّ لِلْإِيذَانِ بِأَنَّ الْوَعِيد الثَّانِي أَشَدّ مِنْ الْأَوَّل ثُمَّ أَوْمَأَ تَعَالَى إِلَى الْقُدْرَة عَلَى الْبَعْث فقال</p>"
        },
        "6": {
            "verses": {
                "78:6": {
                    "id": 6
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَلَمۡ نَجۡعَلِ ٱلۡأَرۡضَ مِهَـٰدࣰا ۝٦﴾ فِرَاشًا كَالْمَهْدِ</p>"
        },
        "7": {
            "verses": {
                "78:7": {
                    "id": 7
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلۡجِبَالَ أَوۡتَادࣰا ۝٧﴾ تَثْبُت بِهَا الْأَرْض كَمَا تَثْبُت الْخِيَام بِالْأَوْتَادِ وَالِاسْتِفْهَام لِلتَّقْرِيرِ</p>"
        },
        "8": {
            "verses": {
                "78:8": {
                    "id": 8
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَخَلَقۡنَـٰكُمۡ أَزۡوَ ٰ⁠جࣰا ۝٨﴾ ذُكُورًا وَإِنَاثًا</h2>"
        },
        "9": {
            "verses": {
                "78:9": {
                    "id": 9
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَجَعَلۡنَا نَوۡمَكُمۡ سُبَاتࣰا ۝٩﴾ رَاحَة لِأَبْدَانِكُمْ</h2>"
        },
        "10": {
            "verses": {
                "78:10": {
                    "id": 10
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَجَعَلۡنَا ٱلَّیۡلَ لِبَاسࣰا ۝١٠﴾ سَاتِرًا بِسَوَادِهِ</h2>"
        },
        "11": {
            "verses": {
                "78:11": {
                    "id": 11
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَجَعَلۡنَا ٱلنَّهَارَ مَعَاشࣰا ۝١١﴾ وَقْتًا لِلْمَعَايِشِ</h2>"
        },
        "12": {
            "verses": {
                "78:12": {
                    "id": 12
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَبَنَیۡنَا فَوۡقَكُمۡ سَبۡعࣰا﴾ سَبْع سَمَاوَات ﴿شِدَادࣰا ۝١٢﴾ جَمْع شَدِيدَة أَيْ قَوِيَّة مُحْكَمَة لَا يُؤَثِّر فِيهَا مرور الزمان</p>"
        },
        "13": {
            "verses": {
                "78:13": {
                    "id": 13
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَجَعَلۡنَا سِرَاجࣰا﴾ مُنِيرًا ﴿وَهَّاجࣰا ۝١٣﴾ وَقَّادًا يَعْنِي الشَّمْس</p>"
        },
        "14": {
            "verses": {
                "78:14": {
                    "id": 14
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَنزَلۡنَا مِنَ ٱلۡمُعۡصِرَ ٰ⁠تِ﴾ السَّحَابَات الَّتِي حَانَ لَهَا أَنْ تُمْطِر كَالْمُعْصِرِ الْجَارِيَة الَّتِي دَنَتْ مِنْ الْحَيْض ﴿مَاۤءࣰ ثَجَّاجࣰا ۝١٤﴾ صَبَّابًا</p>"
        },
        "15": {
            "verses": {
                "78:15": {
                    "id": 15
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿لِّنُخۡرِجَ بِهِۦ حَبࣰّا﴾ كَالْحِنْطَةِ ﴿وَنَبَاتࣰا ۝١٥﴾ كَالتِّينِ</p>"
        },
        "16": {
            "verses": {
                "78:16": {
                    "id": 16
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَجَنَّـٰتٍ﴾ بَسَاتِين ﴿أَلۡفَافًا ۝١٦﴾ مُلْتَفَّة جَمْع لَفِيف كَشَرِيفِ وَأَشْرَاف</p>"
        },
        "17": {
            "verses": {
                "78:17": {
                    "id": 17
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّ یَوۡمَ ٱلۡفَصۡلِ﴾ بَيْن الْخَلَائِق ﴿كَانَ مِیقَـٰتࣰا ۝١٧﴾ وَقْتًا لِلثَّوَابِ وَالْعِقَاب</p>"
        },
        "18": {
            "verses": {
                "78:18": {
                    "id": 18
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿یَوۡمَ یُنفَخُ فِی ٱلصُّورِ﴾ الْقَرْن بَدَل مِنْ يَوْم الْفَصْل أَوْ بَيَان لَهُ وَالنَّافِخ إِسْرَافِيل ﴿فَتَأۡتُونَ﴾ مِنْ قُبُوركُمْ إِلَى الْمَوْقِف ﴿أَفۡوَاجࣰا ۝١٨﴾ جَمَاعَات مختلفة</p>"
        },
        "19": {
            "verses": {
                "78:19": {
                    "id": 19
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَفُتِّحَتِ ٱلسَّمَاۤءُ﴾ بِالتَّشْدِيدِ وَالتَّخْفِيف شُقِّقَتْ لِنُزُولِ الْمَلَائِكَة ﴿فَكَانَتۡ أَبۡوَ ٰ⁠بࣰا ۝١٩﴾ ذَات أَبْوَاب</p>"
        },
        "20": {
            "verses": {
                "78:20": {
                    "id": 20
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَسُیِّرَتِ ٱلۡجِبَالُ﴾ ذُهِبَ بِهَا عَنْ أَمَاكِنهَا ﴿فَكَانَتۡ سَرَابًا ۝٢٠﴾ هَبَاء أَيْ مِثْله فِي خِفَّة سَيْرهَا</p>"
        },
        "21": {
            "verses": {
                "78:21": {
                    "id": 21
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّ جَهَنَّمَ كَانَتۡ مِرۡصَادࣰا ۝٢١﴾ رَاصِدَة أَوْ مُرْصَدَة</p>"
        },
        "22": {
            "verses": {
                "78:22": {
                    "id": 22
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿لِّلطَّـٰغِینَ﴾ الْكَافِرِينَ فَلَا يَتَجَاوَزُونَهَا ﴿مَـَٔابࣰا ۝٢٢﴾ مَرْجِعًا لَهُمْ فيدخلونها</p>"
        },
        "23": {
            "verses": {
                "78:23": {
                    "id": 23
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿لَّـٰبِثِینَ﴾ حَال مُقَدَّرَة أَيْ مُقَدَّرًا لُبْثهمْ ﴿فِیهَاۤ أَحۡقَابࣰا ۝٢٣﴾ دُهُورًا لَا نِهَايَة لَهَا جَمْع حُقْب بضم أوله</p>"
        },
        "24": {
            "verses": {
                "78:24": {
                    "id": 24
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿لَّا یَذُوقُونَ فِیهَا بَرۡدࣰا﴾ نَوْمًا فَإِنَّهُمْ لَا يَذُوقُونَهُ ﴿وَلَا شَرَابًا ۝٢٤﴾ مَا يُشْرَب تَلَذُّذًا</p>"
        },
        "25": {
            "verses": {
                "78:25": {
                    "id": 25
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِلَّا﴾ لَكِنْ ﴿حَمِیمࣰا﴾ مَاء حَارًّا غَايَة الْحَرَارَة ﴿وَغَسَاقࣰا ۝٢٥﴾ بالتخفيف والتشديد ما يسيل عن صَدِيد أَهْل النَّار فَإِنَّهُمْ يَذُوقُونَهُ جُوزُوا بِذَلِكَ</p>"
        },
        "26": {
            "verses": {
                "78:26": {
                    "id": 26
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿جَزَاۤءࣰ وِفَاقًا ۝٢٦﴾ مُوَافِقًا لِعَمَلِهِمْ فَلَا ذَنْب أَعْظَم مِنْ الْكُفْر وَلَا عَذَاب أَعْظَم مِنْ النَّار</p>"
        },
        "27": {
            "verses": {
                "78:27": {
                    "id": 27
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّهُمۡ كَانُوا۟ لَا یَرۡجُونَ﴾ يَخَافُونَ ﴿حِسَابࣰا ۝٢٧﴾ لِإِنْكَارِهِمْ البعث</p>"
        },
        "28": {
            "verses": {
                "78:28": {
                    "id": 28
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَكَذَّبُوا۟ بِـَٔایَـٰتِنَا﴾ الْقُرْآن ﴿كِذَّابࣰا ۝٢٨﴾ تَكْذِيبًا</p>"
        },
        "29": {
            "verses": {
                "78:29": {
                    "id": 29
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَكُلَّ شَیۡءٍ﴾ مِنْ الْأَعْمَال ﴿أَحۡصَیۡنَـٰهُ﴾ ضَبَطْنَاهُ ﴿كِتَـٰبࣰا ۝٢٩﴾ كَتْبًا فِي اللَّوْح الْمَحْفُوظ لِنُجَازِيَ عَلَيْهِ وَمِنْ ذَلِكَ تَكْذِيبهمْ بِالْقُرْآنِ</p>"
        },
        "30": {
            "verses": {
                "78:30": {
                    "id": 30
                }
            },
            "resource_id": 106,
