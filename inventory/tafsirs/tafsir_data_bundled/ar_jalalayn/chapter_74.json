            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّهَا﴾ أَيْ سَقَر ﴿لَإِحۡدَى ٱلۡكُبَرِ ۝٣٥﴾ الْبَلَايَا الْعِظَام</p>"
