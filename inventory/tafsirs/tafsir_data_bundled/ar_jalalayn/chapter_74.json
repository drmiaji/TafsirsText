            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿نَذِیرࣰا﴾ حَال مِنْ إحْدَى وَذُكِّرَ لِأَنَّهَا بِمَعْنَى العذاب ﴿لِّلۡبَشَرِ ۝٣٦﴾</p>"
        },
