            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿عَلَیۡهِمۡ نَارࣱ مُّؤۡصَدَةُۢ ۝٢٠﴾ بالمهمزة والواو بدله مطبقة</p>"
        }
    }
