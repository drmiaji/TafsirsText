            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلۡعَـٰدِیَـٰتِ﴾ الْخَيْل تَعْدُو فِي الْغَزْو وَتَضْبَح ﴿ضَبۡحࣰا ۝١﴾ هُوَ صَوْت أَجْوَافهَا إِذَا عَدَتْ</p>"
        },
        "2": {
            "verses": {
                "100:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَٱلۡمُورِیَـٰتِ﴾ الْخَيْل تُورِي النَّار ﴿قَدۡحࣰا ۝٢﴾ بِحَوَافِرِهَا إِذَا سَارَتْ فِي الْأَرْض ذَات الْحِجَارَة بِاللَّيْلِ</p>"
        },
        "3": {
            "verses": {
                "100:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَٱلۡمُغِیرَ ٰ⁠تِ صُبۡحࣰا ۝٣﴾ الْخَيْل تُغِير عَلَى الْعَدُوّ وَقْت الصُّبْح بِإِغَارَةِ أَصْحَابهَا</p>"
        },
        "4": {
            "verses": {
                "100:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَأَثَرۡنَ﴾ هَيَّجْنَ ﴿بِهِۦ﴾ بِمَكَانِ عَدْوهنَّ أَوْ بِذَلِكَ الْوَقْت ﴿نَقۡعࣰا ۝٤﴾ غُبَارًا بِشِدَّةِ حَرَكَتهنَّ</p>"
        },
        "5": {
            "verses": {
                "100:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَوَسَطۡنَ بِهِۦ﴾ بِالنَّقْعِ ﴿جَمۡعًا ۝٥﴾ مِنْ الْعَدْو أَيْ صِرْنَ وَسَطه وَعُطِفَ الْفِعْل عَلَى الِاسْم لِأَنَّهُ فِي تَأْوِيل الْفِعْل أَيْ وَاَللَّاتِي عَدَوْنَ فَأَوْرَيْن فأغرن</p>"
        },
        "6": {
            "verses": {
                "100:6": {
                    "id": 6
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّ ٱلۡإِنسَـٰنَ﴾ الْكَافِر ﴿لِرَبِّهِۦ لَكَنُودࣱ ۝٦﴾ لَكَفُور يَجْحَد نعمته تعالى</p>"
        },
        "7": {
            "verses": {
                "100:7": {
                    "id": 7
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِنَّهُۥ عَلَىٰ ذَ ٰ⁠لِكَ﴾ أَيْ كَنُوده ﴿لَشَهِیدࣱ ۝٧﴾ يَشْهَد عَلَى نَفْسه بِصُنْعِهِ</p>"
        },
        "8": {
            "verses": {
                "100:8": {
                    "id": 8
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِنَّهُۥ لِحُبِّ ٱلۡخَیۡرِ﴾ أَيْ الْمَال ﴿لَشَدِیدٌ ۝٨﴾ الْحُبّ لَهُ فَيَبْخَل بِهِ</p>"
        },
        "9": {
            "verses": {
                "100:9": {
                    "id": 9
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَفَلَا یَعۡلَمُ إِذَا بُعۡثِرَ﴾ أُثِيرَ وَأُخْرِجَ ﴿مَا فِی ٱلۡقُبُورِ ۝٩﴾ مِنْ الْمَوْتَى أَيْ بُعِثُوا</p>"
        },
        "10": {
            "verses": {
                "100:10": {
                    "id": 10
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَحُصِّلَ﴾ بُيِّنَ وَأُفْرِزَ ﴿مَا فِی ٱلصُّدُورِ ۝١٠﴾ الْقُلُوب مِنْ الْكُفْر وَالْإِيمَان</p>"
        },
        "11": {
            "verses": {
                "100:11": {
                    "id": 11
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّ رَبَّهُم بِهِمۡ یَوۡمَىِٕذࣲ لَّخَبِیرُۢ ۝١١﴾ لَعَالَم فَيُجَازِيهِمْ عَلَى كُفْرهمْ أُعِيدَ الضَّمِير جَمْعًا نَظَرًا لِمَعْنَى الْإِنْسَان وَهَذِهِ الْجُمْلَة دَلَّتْ عَلَى مَفْعُول يَعْلَم أَيْ إِنَّا نُجَازِيه وَقْت مَا ذَكَرَ وَتَعَلَّقَ خَبِير بِيَوْمَئِذ وَهُوَ تَعَالَى خَبِير دَائِمًا لِأَنَّهُ يوم المجازاة</p>"
        }
    }
}