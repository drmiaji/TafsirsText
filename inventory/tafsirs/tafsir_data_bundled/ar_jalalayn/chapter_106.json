            "text": "<h2>﴿لِإِیلَـٰفِ قُرَیۡشٍ ۝١﴾</h2>"
        },
        "2": {
            "verses": {
                "106:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِۦلَـٰفِهِمۡ﴾ تَأْكِيد وَهُوَ مَصْدَر آلَف بِالْمَدِّ ﴿رِحۡلَةَ ٱلشِّتَاۤءِ﴾ إِلَى الْيَمَن ﴿وَ﴾ رِحْلَة ﴿ٱلصَّیۡفِ ۝٢﴾ إِلَى الشَّام فِي كُلّ عَام يَسْتَعِينُونَ بِالرِّحْلَتَيْنِ لِلتِّجَارَةِ عَلَى الْمُقَام بِمَكَّة لِخِدْمَةِ الْبَيْت الَّذِي هُوَ فَخْرهمْ وَهُمْ وَلَد النَّضْر بْن كِنَانَة</p>"
        },
        "3": {
            "verses": {
                "106:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَلۡیَعۡبُدُوا۟﴾ تَعَلَّقَ بِهِ لِإِيلَافِ وَالْفَاء زَائِدَة ﴿رَبَّ هَـٰذَا ٱلۡبَیۡتِ ۝٣﴾</p>"
        },
        "4": {
            "verses": {
                "106:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلَّذِیۤ أَطۡعَمَهُم مِّن جُوعࣲ﴾ أَيْ مِنْ أَجْله ﴿وَءَامَنَهُم مِّنۡ خَوۡفِۭ ۝٤﴾ أَيْ مِنْ أَجْله وَكَانَ يُصِيبهُمْ الْجُوع لِعَدَمِ الزَّرْع بِمَكَّة وَخَافُوا جَيْش الفيل</p>"
        }
    }
