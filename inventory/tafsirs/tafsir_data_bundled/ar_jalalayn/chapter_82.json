            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿إِذَا ٱلسَّمَاۤءُ ٱنفَطَرَتۡ ۝١﴾ اِنْشَقَّتْ</h2>"
        },
        "2": {
            "verses": {
                "82:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِذَا ٱلۡكَوَاكِبُ ٱنتَثَرَتۡ ۝٢﴾ اِنْقَضَّتْ وَتَسَاقَطَتْ</p>"
        },
        "3": {
            "verses": {
                "82:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِذَا ٱلۡبِحَارُ فُجِّرَتۡ ۝٣﴾ فُتِحَ بَعْضهَا فِي بَعْض فَصَارَتْ بَحْرًا وَاحِدًا وَاخْتَلَطَ الْعَذْب بِالْمِلْحِ</p>"
        },
        "4": {
            "verses": {
                "82:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِذَا ٱلۡقُبُورُ بُعۡثِرَتۡ ۝٤﴾ قُلِبَ تُرَابهَا وَبُعِثَ مَوْتَاهَا وَجَوَاب إِذَا وَمَا عُطِفَ عَلَيْهَا</p>"
        },
        "5": {
            "verses": {
                "82:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿عَلِمَتۡ نَفۡسࣱ﴾ أَيْ كُلّ نَفْس وَقْت هَذِهِ الْمَذْكُورَات وَهُوَ يَوْم الْقِيَامَة ﴿مَّا قَدَّمَتۡ﴾ مِنْ الْأَعْمَال ﴿وَ﴾ مَا ﴿أَخَّرَتۡ ۝٥﴾ مِنْهَا فَلَمْ تَعْمَلهُ</p>"
        },
        "6": {
            "verses": {
                "82:6": {
                    "id": 6
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿یَـٰۤأَیُّهَا ٱلۡإِنسَـٰنُ﴾ الْكَافِر ﴿مَا غَرَّكَ بِرَبِّكَ ٱلۡكَرِیمِ ۝٦﴾ حَتَّى عَصَيْته</p>"
        },
        "7": {
            "verses": {
                "82:7": {
                    "id": 7
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلَّذِی خَلَقَكَ﴾ بَعْد أَنْ لَمْ تَكُنْ ﴿فَسَوَّىٰكَ﴾ جَعَلَك مُسْتَوِي الْخِلْقَة سَالِم الْأَعْضَاء ﴿فَعَدَلَكَ ۝٧﴾ بِالتَّخْفِيفِ وَالتَّشْدِيد جَعَلَك مُعْتَدِل الْخَلْق مُتَنَاسِب الْأَعْضَاء لَيْسَتْ يَد أَوْ رِجْل أَطْوَل مِنْ الْأُخْرَى</p>"
        },
        "8": {
            "verses": {
                "82:8": {
                    "id": 8
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿فِیۤ أَیِّ صُورَةࣲ مَّا﴾ صِلَة ﴿شَاۤءَ رَكَّبَكَ ۝٨﴾</h2>"
        },
        "9": {
            "verses": {
                "82:9": {
                    "id": 9
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿كَلَّا﴾ رَدْع عَنْ الِاغْتِرَار بِكَرَمِ اللَّه تَعَالَى ﴿بَلۡ تُكَذِّبُونَ﴾ أَيْ كُفَّار مَكَّة ﴿بِٱلدِّینِ ۝٩﴾ بِالْجَزَاءِ عَلَى الْأَعْمَال</p>"
        },
        "10": {
            "verses": {
                "82:10": {
                    "id": 10
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِنَّ عَلَیۡكُمۡ لَحَـٰفِظِینَ ۝١٠﴾ مِنْ الْمَلَائِكَة لِأَعْمَالِكُمْ</p>"
        },
        "11": {
            "verses": {
                "82:11": {
                    "id": 11
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿كِرَامࣰا﴾ عَلَى اللَّه ﴿كَـٰتِبِینَ ۝١١﴾ لَهَا</h2>"
        },
        "12": {
            "verses": {
                "82:12": {
                    "id": 12
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿یَعۡلَمُونَ مَا تَفۡعَلُونَ ۝١٢﴾ جَمِيعه</h2>"
        },
        "13": {
            "verses": {
                "82:13": {
                    "id": 13
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّ ٱلۡأَبۡرَارَ﴾ الْمُؤْمِنِينَ الصَّادِقِينَ فِي إِيمَانهمْ ﴿لَفِی نَعِیمࣲ ۝١٣﴾ جنة</p>"
        },
        "14": {
            "verses": {
                "82:14": {
                    "id": 14
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِنَّ ٱلۡفُجَّارَ﴾ الْكُفَّار ﴿لَفِی جَحِیمࣲ ۝١٤﴾ نَار مُحْرِقَة</p>"
        },
        "15": {
            "verses": {
                "82:15": {
                    "id": 15
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿یَصۡلَوۡنَهَا﴾ يَدْخُلُونَهَا وَيُقَاسُونَ حَرّهَا ﴿یَوۡمَ ٱلدِّینِ ۝١٥﴾ الْجَزَاء</p>"
        },
        "16": {
            "verses": {
                "82:16": {
                    "id": 16
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَا هُمۡ عَنۡهَا بِغَاۤىِٕبِینَ ۝١٦﴾ بِمُخْرَجِينَ</h2>"
        },
        "17": {
            "verses": {
                "82:17": {
                    "id": 17
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَاۤ أَدۡرَىٰكَ﴾ أَعْلَمَك ﴿مَا یَوۡمُ ٱلدِّینِ ۝١٧﴾</h2>"
        },
        "18": {
            "verses": {
                "82:18": {
                    "id": 18
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ مَاۤ أَدۡرَىٰكَ مَا یَوۡمُ ٱلدِّینِ ۝١٨﴾ تَعْظِيم لِشَأْنِهِ</p>"
        },
        "19": {
            "verses": {
                "82:19": {
                    "id": 19
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿یَوۡمُ﴾ بِالرَّفْعِ أَيْ هُوَ يَوْم ﴿لَا تَمۡلِكُ نَفۡسࣱ لِّنَفۡسࣲ شَیۡـࣰٔاۖ﴾ مِنْ الْمَنْفَعَة ﴿وَٱلۡأَمۡرُ یَوۡمَىِٕذࣲ لِّلَّهِ ۝١٩﴾ لَا أَمْر لِغَيْرِهِ فِيهِ أَيْ لَمْ يُمَكِّن أَحَدًا مِنْ التَّوَسُّط فِيهِ بِخِلَافِ الدُّنْيَا</p>"
        }
    }
}