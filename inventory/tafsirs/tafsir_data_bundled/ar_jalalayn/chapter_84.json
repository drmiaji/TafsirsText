            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿فَبَشِّرۡهُم﴾ أَخْبِرْهُمْ ﴿بِعَذَابٍ أَلِیمٍ ۝٢٤﴾ مُؤْلِم</h2>"
        },
        "25": {
            "verses": {
                "84:25": {
                    "id": 25
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِلَّا﴾ لكن ﴿ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ لَهُمۡ أَجۡرٌ غَیۡرُ مَمۡنُونِۭ ۝٢٥﴾ غَيْر مَقْطُوع وَلَا مَنْقُوص ولا يمن به عليه</p>"
        }
