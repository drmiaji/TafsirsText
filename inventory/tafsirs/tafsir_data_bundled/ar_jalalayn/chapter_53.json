            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَنَّهُۥ هُوَ أَغۡنَىٰ﴾ النَّاس بِالْكِفَايَةِ بِالْأَمْوَالِ ﴿وَأَقۡنَىٰ ۝٤٨﴾ أَعْطَى الْمَال الْمُتَّخَذ قِنْيَة</p>"
        },
        "49": {
            "verses": {
