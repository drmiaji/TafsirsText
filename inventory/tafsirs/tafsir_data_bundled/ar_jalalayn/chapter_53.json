            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَنَّهُۥ هُوَ رَبُّ ٱلشِّعۡرَىٰ ۝٤٩﴾ هُوَ كَوْكَب خَلْف الْجَوْزَاء كَانَتْ تُعْبَد فِي الْجَاهِلِيَّة</p>"
        },
        "50": {
            "verses": {
