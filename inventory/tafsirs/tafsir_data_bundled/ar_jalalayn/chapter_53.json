            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَلِلَّهِ ٱلۡـَٔاخِرَةُ وَٱلۡأُولَىٰ ۝٢٥﴾ أَيْ الدُّنْيَا فَلَا يَقَع فيها إلَّا مَا يُرِيدهُ تَعَالَى</p>"
        },
