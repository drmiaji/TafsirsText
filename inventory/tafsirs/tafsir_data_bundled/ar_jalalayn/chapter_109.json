            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَلَاۤ أَنتُمۡ عَـٰبِدُونَ﴾ فِي الِاسْتِقْبَال ﴿مَاۤ أَعۡبُدُ ۝٥﴾ عَلِمَ اللَّه مِنْهُمْ أَنَّهُمْ لَا يُؤْمِنُونَ وَإِطْلَاق مَا عَلَى اللَّه عَلَى وَجْه الْمُقَابَلَة</p>"
        },
        "6": {
            "verses": {
                "109:6": {
                    "id": 6
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
