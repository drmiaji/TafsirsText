            "text": "<h2>﴿قُلۡ یَـٰۤأَیُّهَا ٱلۡكَـٰفِرُونَ ۝١﴾</h2>"
        },
        "2": {
            "verses": {
                "109:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿لَاۤ أَعۡبُدُ﴾ فِي الْحَال ﴿مَا تَعۡبُدُونَ ۝٢﴾ مِنْ الأصنام</p>"
        },
        "3": {
            "verses": {
                "109:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَلَاۤ أَنتُمۡ عَـٰبِدُونَ﴾ فِي الْحَال ﴿مَاۤ أَعۡبُدُ ۝٣﴾ وَهُوَ اللَّه تَعَالَى وَحْده</p>"
        },
        "4": {
            "verses": {
                "109:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَلَاۤ أَنَا۠ عَابِدࣱ﴾ فِي الِاسْتِقْبَال ﴿مَّا عَبَدتُّمۡ ۝٤﴾</p>"
        },
        "5": {
            "verses": {
                "109:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
