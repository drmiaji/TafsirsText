                "language_name": "english"
            },
            "text": "<h2>﴿خَلَقَ ٱلۡإِنسَـٰنَ ۝٣﴾ أَيْ الْجِنْس</h2>"
        },
        "4": {
            "verses": {
                "55:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
