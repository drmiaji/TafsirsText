            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿كُلُّ مَنۡ عَلَیۡهَا﴾ أَيْ الْأَرْض مِنْ الْحَيَوَان ﴿فَانࣲ ۝٢٦﴾ هَالِك وَعَبَّرَ بِمَنْ تَغْلِيبًا لِلْعُقَلَاءِ</p>"
        },
        "27": {
            "verses": {
                "55:27": {
                    "id": 27
