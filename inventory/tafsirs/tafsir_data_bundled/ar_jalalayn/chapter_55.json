            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَیَبۡقَىٰ وَجۡهُ رَبِّكَ﴾ ذَاته ﴿ذُو ٱلۡجَلَـٰلِ﴾ الْعَظَمَة ﴿وَٱلۡإِكۡرَامِ ۝٢٧﴾ للمؤمنين بأنعمه عليهم</p>"
        },
