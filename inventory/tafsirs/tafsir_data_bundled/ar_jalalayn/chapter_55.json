            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَلَهُ ٱلۡجَوَارِ﴾ السُّفُن ﴿ٱلۡمُنشَـَٔاتُ﴾ الْمُحْدَثَات ﴿فِی ٱلۡبَحۡرِ كَٱلۡأَعۡلَـٰمِ ۝٢٤﴾ كالجبال عظما وارتفاعا</p>"
        },
        "25": {
            "verses": {
                "55:25": {
                    "id": 25
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
