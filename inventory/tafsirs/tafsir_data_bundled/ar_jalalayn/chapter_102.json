            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَلۡهَىٰكُمُ﴾ شَغَلَكُمْ عَنْ طَاعَة اللَّه ﴿ٱلتَّكَاثُرُ ۝١﴾ التَّفَاخُر بِالْأَمْوَالِ وَالْأَوْلَاد وَالرِّجَال</p>"
        },
        "2": {
            "verses": {
                "102:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿حَتَّىٰ زُرۡتُمُ ٱلۡمَقَابِرَ ۝٢﴾ بِأَنْ مُتُّمْ فَدُفِنْتُمْ فِيهَا أَوْ عَدَدْتُمْ الْمَوْتَى تَكَاثُرًا</p>"
        },
        "3": {
            "verses": {
                "102:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿كَلَّا﴾ رَدْع ﴿سَوۡفَ تَعۡلَمُونَ ۝٣﴾</h2>"
        },
        "4": {
            "verses": {
                "102:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ كَلَّا سَوۡفَ تَعۡلَمُونَ ۝٤﴾ سُوء عَاقِبَة تَفَاخُركُمْ عِنْد النَّزْع ثُمَّ فِي الْقَبْر</p>"
        },
        "5": {
            "verses": {
                "102:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿كَلَّا﴾ حَقًّا ﴿لَوۡ تَعۡلَمُونَ عِلۡمَ ٱلۡیَقِینِ ۝٥﴾ عِلْمًا يَقِينًا عَاقِبَة التَّفَاخُر مَا اِشْتَغَلْتُمْ بِهِ</p>"
        },
        "6": {
            "verses": {
                "102:6": {
                    "id": 6
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿لَتَرَوُنَّ ٱلۡجَحِیمَ ۝٦﴾ النَّار جَوَاب قَسَم مَحْذُوف وَحُذِفَ مِنْهُ لَام الْفِعْل وَعَيْنه وَأُلْقِيَتْ حَرَكَتهَا عَلَى الراء</p>"
        },
        "7": {
            "verses": {
                "102:7": {
                    "id": 7
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ لَتَرَوُنَّهَا﴾ تَأْكِيد ﴿عَیۡنَ ٱلۡیَقِینِ ۝٧﴾ مَصْدَر لِأَنَّ رَأَى وَعَايَنَ بِمَعْنًى وَاحِد</p>"
        },
        "8": {
            "verses": {
                "102:8": {
                    "id": 8
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ لَتُسۡـَٔلُنَّ﴾ حُذِفَ مِنْهُ نُون الرَّفْع لِتَوَالِي النُّونَات وَوَاو ضَمِير الْجَمْع لِالْتِقَاءِ السَّاكِنَيْنِ ﴿یَوۡمَىِٕذٍ﴾ يَوْم رُؤْيَتهَا ﴿عَنِ ٱلنَّعِیمِ ۝٨﴾ مَا يُلْتَذّ بِهِ في الدنيا من الصحة والفراغ والأمن والمطعم والمشرب وغير ذلك</p>"
        }
    }
}