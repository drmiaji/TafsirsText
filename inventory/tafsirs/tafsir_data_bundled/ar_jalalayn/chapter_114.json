            },
            "text": "<h2>﴿مَلِكِ ٱلنَّاسِ ۝٢﴾</h2>"
        },
        "3": {
            "verses": {
                "114:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِلَـٰهِ ٱلنَّاسِ ۝٣﴾ بَدَلَانِ أَوْ صِفَتَانِ أَوْ عَطْفَا بَيَان وَأَظْهَر الْمُضَاف إِلَيْهِ فِيهِمَا زِيَادَة لِلْبَيَانِ</p>"
        },
        "4": {
            "verses": {
                "114:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿مِن شَرِّ ٱلۡوَسۡوَاسِ﴾ الشَّيْطَان سُمِّيَ بِالْحَدَثِ لِكَثْرَةِ مُلَابَسَته لَهُ ﴿ٱلۡخَنَّاسِ ۝٤﴾ لِأَنَّهُ يَخْنِس وَيَتَأَخَّر عَنْ الْقَلْب كُلَّمَا ذُكِرَ اللَّه</p>"
        },
        "5": {
            "verses": {
                "114:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلَّذِی یُوَسۡوِسُ فِی صُدُورِ ٱلنَّاسِ ۝٥﴾ قُلُوبهمْ إِذَا غَفَلُوا عَنْ ذِكْر اللَّه</p>"
        },
        "6": {
            "verses": {
                "114:6": {
                    "id": 6
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿مِنَ ٱلۡجِنَّةِ وَٱلنَّاسِ ۝٦﴾ بَيَان لِلشَّيْطَانِ الْمُوَسْوِس أَنَّهُ جِنِّيّ وَإِنْسِيّ كَقَوْلِهِ تَعَالَى شَيَاطِين الْإِنْس وَالْجِنّ أَوْ مِنْ الْجِنَّة بَيَان لَهُ وَالنَّاس عَطْف عَلَى الْوَسْوَاس وَعَلَى كُلّ يَشْتَمِل شَرّ لَبِيد وَبَنَاته الْمَذْكُورِينَ وَاعْتَرَضَ الْأَوَّل بِأَنَّ النَّاس لَا يُوَسْوِس فِي صُدُورهمْ النَّاس إِنَّمَا يُوَسْوِس فِي صُدُورهمْ الْجِنّ وَأُجِيبَ بِأَنَّ النَّاس يُوَسْوِسَونَ أَيْضًا بِمَعْنَى يَلِيق بِهِمْ فِي الظَّاهِر ثُمَّ تَصِل وَسْوَسَتهمْ إِلَى الْقَلْب وَتَثْبُت فِيهِ بِالطَّرِيقِ الْمُؤَدِّي إلى ذلك والله تعالى أعلم</p>"
        }
