            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلَّیۡلِ إِذَا یَغۡشَىٰ ۝١﴾ بِظُلْمَتِهِ كُلّ مَا بَيْن السماء والأرض</p>"
        },
        "2": {
            "verses": {
                "92:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلنَّهَارِ إِذَا تَجَلَّىٰ ۝٢﴾ تَكَشَّفَ وَظَهَرَ وَإِذَا فِي الْمَوْضِعَيْنِ لِمُجَرَّدِ الظَّرْفِيَّة وَالْعَامِل فِيهَا فِعْل الْقَسَم</p>"
        },
        "3": {
            "verses": {
                "92:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَا﴾ بِمَعْنَى مَنْ أَوْ مَصْدَرِيَّة ﴿خَلَقَ ٱلذَّكَرَ وَٱلۡأُنثَىٰۤ ۝٣﴾ آدَم وَحَوَّاء وَكُلّ ذَكَر وَكُلّ أُنْثَى وَالْخُنْثَى الْمُشْكِل عِنْدنَا ذَكَر أَوْ أُنْثَى عِنْد اللَّه تَعَالَى فَيَحْنَث بِتَكْلِيمِهِ مَنْ حَلَفَ لَا يُكَلِّم ذَكَرًا وَلَا أُنْثَى</p>"
        },
        "4": {
            "verses": {
                "92:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّ سَعۡیَكُمۡ﴾ عَمَلكُمْ ﴿لَشَتَّىٰ ۝٤﴾ مُخْتَلِف فَعَامِل لِلْجَنَّةِ بِالطَّاعَةِ وَعَامِل لِلنَّارِ بِالْمَعْصِيَةِ</p>"
        },
        "5": {
            "verses": {
                "92:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿فَأَمَّا مَنۡ أَعۡطَىٰ﴾ حَقّ اللَّه ﴿وَٱتَّقَىٰ ۝٥﴾ اللَّه</h2>"
        },
        "6": {
            "verses": {
                "92:6": {
                    "id": 6
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَصَدَّقَ بِٱلۡحُسۡنَىٰ ۝٦﴾ أَيْ بِلَا إِلَه إِلَّا اللَّه في الموضعين</p>"
        },
        "7": {
            "verses": {
                "92:7": {
                    "id": 7
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿فَسَنُیَسِّرُهُۥ لِلۡیُسۡرَىٰ ۝٧﴾ لِلْجَنَّةِ</h2>"
        },
        "8": {
            "verses": {
                "92:8": {
                    "id": 8
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَمَّا مَنۢ بَخِلَ﴾ بِحَقِّ اللَّه ﴿وَٱسۡتَغۡنَىٰ ۝٨﴾ عَنْ ثوابه</p>"
        },
        "9": {
            "verses": {
                "92:9": {
                    "id": 9
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَكَذَّبَ بِٱلۡحُسۡنَىٰ ۝٩﴾</h2>"
        },
        "10": {
            "verses": {
                "92:10": {
                    "id": 10
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿فَسَنُیَسِّرُهُۥ﴾ نُهَيِّئهُ ﴿لِلۡعُسۡرَىٰ ۝١٠﴾ لِلنَّارِ</h2>"
        },
        "11": {
            "verses": {
                "92:11": {
                    "id": 11
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَا﴾ نَافِيَة ﴿یُغۡنِی عَنۡهُ مَالُهُۥۤ إِذَا تَرَدَّىٰۤ ۝١١﴾ فِي النَّار</p>"
        },
        "12": {
            "verses": {
                "92:12": {
                    "id": 12
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّ عَلَیۡنَا لَلۡهُدَىٰ ۝١٢﴾ لَتَبْيِين طَرِيق الْهُدَى مِنْ طَرِيق الضَّلَال لِيَمْتَثِل أَمْرنَا بِسُلُوكِ الْأَوَّل وَنَهْينَا عَنْ اِرْتِكَاب الثَّانِي</p>"
        },
        "13": {
            "verses": {
                "92:13": {
                    "id": 13
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِنَّ لَنَا لَلۡـَٔاخِرَةَ وَٱلۡأُولَىٰ ۝١٣﴾ أَيْ الدُّنْيَا فَمَنْ طَلَبَهُمَا مِنْ غَيْرنَا فَقَدْ أَخْطَأَ</p>"
        },
        "14": {
            "verses": {
                "92:14": {
                    "id": 14
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَأَنذَرۡتُكُمۡ﴾ خَوَّفْتُكُمْ يَا أَهْل مَكَّة ﴿نَارࣰا تَلَظَّىٰ ۝١٤﴾ بِحَذْفِ إِحْدَى التَّاءَيْنِ مِنْ الْأَصْل وَقُرِئَ بِثُبُوتِهَا أي تتوقد</p>"
        },
        "15": {
            "verses": {
                "92:15": {
                    "id": 15
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿لَا یَصۡلَىٰهَاۤ﴾ يَدْخُلهَا ﴿إِلَّا ٱلۡأَشۡقَى ۝١٥﴾ بِمَعْنَى الشَّقِيّ</p>"
        },
        "16": {
            "verses": {
                "92:16": {
                    "id": 16
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلَّذِی كَذَّبَ﴾ النَّبِيّ ﴿وَتَوَلَّىٰ ۝١٦﴾ عَنْ الْإِيمَان وَهَذَا الْحَصْر مُؤَوَّل لِقَوْلِهِ تَعَالَى {وَیَغۡفِرُ مَا دُونَ ذَ ٰ⁠لِكَ لِمَن یَشَاۤءُۚ} فَيَكُون الْمُرَاد الصِّلِيّ الْمُؤَبَّد</p>"
        },
        "17": {
            "verses": {
                "92:17": {
                    "id": 17
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَسَیُجَنَّبُهَا﴾ يُبْعَد عَنْهَا ﴿ٱلۡأَتۡقَى ۝١٧﴾ بِمَعْنَى التَّقِيّ</p>"
        },
        "18": {
            "verses": {
                "92:18": {
                    "id": 18
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلَّذِی یُؤۡتِی مَالَهُۥ یَتَزَكَّىٰ ۝١٨﴾ مُتَزَكِّيًا بِهِ عِنْد اللَّه تَعَالَى بِأَنْ يُخْرِجهُ لِلَّهِ تَعَالَى لَا رِيَاء وَلَا سُمْعَة فَيَكُون زَاكِيًا عِنْد اللَّه وَهَذَا نَزَلَ فِي الصِّدِّيق رَضِيَ اللَّه عَنْهُ لَمَّا اِشْتَرَى بِلَالًا الْمُعَذَّب عَلَى إِيمَانه وَأَعْتَقَهُ فَقَالَ الْكُفَّار إِنَّمَا فَعَلَ ذَلِكَ لِيَدٍ كَانَتْ لَهُ عِنْده فَنَزَلَتْ</p>"
        },
        "19": {
            "verses": {
                "92:19": {
                    "id": 19
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
