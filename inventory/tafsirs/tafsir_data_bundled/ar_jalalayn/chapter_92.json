            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعۡمَةࣲ تُجۡزَىٰۤ ۝١٩﴾</h2>"
        },
        "20": {
            "verses": {
                "92:20": {
                    "id": 20
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِلَّا﴾ لَكِنْ فَعَلَ ذَلِكَ ﴿ٱبۡتِغَاۤءَ وَجۡهِ رَبِّهِ ٱلۡأَعۡلَىٰ ۝٢٠﴾ أَيْ طَلَب ثَوَاب اللَّه</p>"
        },
        "21": {
            "verses": {
                "92:21": {
                    "id": 21
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَلَسَوۡفَ یَرۡضَىٰ ۝٢١﴾ بِمَا يُعْطَاهُ مِنْ الثَّوَاب فِي الْجَنَّة وَالْآيَة تَشْمَل مَنْ فَعَلَ مِثْل فِعْله رَضِيَ اللَّه تَعَالَى عَنْهُ فَيُبْعَد عَنْ النَّار ويثاب</p>"
        }
    }
