            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَرَءَیۡتَ ٱلَّذِی یُكَذِّبُ بِٱلدِّینِ ۝١﴾ بِالْجَزَاءِ وَالْحِسَاب أَيْ هَلْ عَرَفْته وَإِنْ لَمْ تَعْرِفهُ</p>"
        },
        "2": {
            "verses": {
                "107:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَذَ ٰ⁠لِكَ﴾ بِتَقْدِيرِ هُوَ بَعْد الْفَاء ﴿ٱلَّذِی یَدُعُّ ٱلۡیَتِیمَ ۝٢﴾ أَيْ يَدْفَعهُ بِعُنْفٍ عَنْ حَقّه</p>"
        },
        "3": {
            "verses": {
                "107:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَلَا یَحُضُّ﴾ نَفْسه وَلَا غَيْره ﴿عَلَىٰ طَعَامِ ٱلۡمِسۡكِینِ ۝٣﴾ أَيْ إِطْعَامه نَزَلَتْ فِي الْعَاصِي بن وائل أو الوليد بن المغيرة</p>"
        },
        "4": {
            "verses": {
                "107:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿فَوَیۡلࣱ لِّلۡمُصَلِّینَ ۝٤﴾</h2>"
        },
        "5": {
            "verses": {
                "107:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلَّذِینَ هُمۡ عَن صَلَاتِهِمۡ سَاهُونَ ۝٥﴾ غَافِلُونَ يُؤَخِّرُونَهَا عن وقتها</p>"
        },
        "6": {
            "verses": {
                "107:6": {
                    "id": 6
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلَّذِینَ هُمۡ یُرَاۤءُونَ﴾ فِي الصَّلَاة وَغَيْرهَا</h2>"
        },
        "7": {
            "verses": {
                "107:7": {
                    "id": 7
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَیَمۡنَعُونَ ٱلۡمَاعُونَ ۝٧﴾ كَالْإِبْرَةِ وَالْفَأْس والقدر والقصعة</p>"
        }
    }
