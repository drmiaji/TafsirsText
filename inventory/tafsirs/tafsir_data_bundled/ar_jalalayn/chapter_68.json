            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَإِنَّكَ لَعَلَىٰ خُلُقٍ﴾ دين ﴿عَظِیمࣲ ۝٤﴾</h2>"
        },
        "5": {
            "verses": {
                "68:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
