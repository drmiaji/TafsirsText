                "language_name": "english"
            },
            "text": "<p>﴿قَالَ أَوۡسَطُهُمۡ﴾ خَيْرهمْ ﴿أَلَمۡ أَقُل لَّكُمۡ لَوۡلَا﴾ هَلَّا ﴿تُسَبِّحُونَ ۝٢٨﴾ اللَّه تَائِبِينَ</p>"
        },
        "29": {
            "verses": {
                "68:29": {
                    "id": 29
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿قَالُوا۟ سُبۡحَـٰنَ رَبِّنَاۤ إِنَّا كُنَّا ظَـٰلِمِینَ ۝٢٩﴾ بِمَنْعِ الفقراء حقهم</p>"
        },
        "30": {
            "verses": {
                "68:30": {
                    "id": 30
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿فَأَقۡبَلَ بَعۡضُهُمۡ عَلَىٰ بَعۡضࣲ یَتَلَـٰوَمُونَ ۝٣٠﴾</h2>"
        },
        "31": {
            "verses": {
                "68:31": {
                    "id": 31
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿قَالُوا۟ یَـٰ﴾ للتنبيه ﴿وَیۡلَنَاۤ﴾ هلاكنا ﴿إِنَّا كُنَّا طَـٰغِینَ ۝٣١﴾</p>"
        },
        "32": {
            "verses": {
                "68:32": {
                    "id": 32
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿عَسَىٰ رَبُّنَاۤ أَن یُبَدِّلَنَا﴾ بِالتَّشْدِيدِ وَالتَّخْفِيف ﴿خَیۡرࣰا مِّنۡهَاۤ إِنَّاۤ إِلَىٰ رَبِّنَا رَ ٰ⁠غِبُونَ ۝٣٢﴾ لِيَقْبَل تَوْبَتنَا وَيَرُدّ عَلَيْنَا خَيْرًا مِنْ جَنَّتنَا رُوِيَ أَنَّهُمْ أُبْدِلُوا خَيْرًا مِنْهَا</p>"
        },
        "33": {
            "verses": {
                "68:33": {
                    "id": 33
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿كَذَ ٰ⁠لِكَ﴾ أَيْ مِثْل الْعَذَاب لِهَؤُلَاءِ ﴿ٱلۡعَذَابُۖ﴾ لِمَنْ خَالَفَ أَمْرنَا مِنْ كُفَّار مَكَّة وَغَيْرهمْ ﴿وَلَعَذَابُ ٱلۡـَٔاخِرَةِ أَكۡبَرُۚ لَوۡ كَانُوا۟ یَعۡلَمُونَ ۝٣٣﴾ عَذَابهَا مَا خَالَفُوا أَمْرنَا وَنَزَلَ لَمَّا قَالُوا إنْ بَعَثَنَا نعطى أفضل منكم</p>"
        },
        "34": {
            "verses": {
                "68:34": {
                    "id": 34
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّ لِلۡمُتَّقِینَ عِندَ رَبِّهِمۡ جَنَّـٰتِ ٱلنَّعِیمِ ۝٣٤﴾</p>"
        },
        "35": {
            "verses": {
                "68:35": {
                    "id": 35
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَفَنَجۡعَلُ ٱلۡمُسۡلِمِینَ كَٱلۡمُجۡرِمِینَ ۝٣٥﴾ أَيْ تَابِعِينَ لَهُمْ فِي العطاء</p>"
        },
        "36": {
            "verses": {
                "68:36": {
                    "id": 36
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿مَا لَكُمۡ كَیۡفَ تَحۡكُمُونَ ۝٣٦﴾ هَذَا الْحُكْم الْفَاسِد</p>"
        },
        "37": {
            "verses": {
                "68:37": {
                    "id": 37
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَمۡ﴾ أَيْ بَلْ أَ﴿لَكُمۡ كِتَـٰبࣱ﴾ مُنَزَّل ﴿فِیهِ تَدۡرُسُونَ ۝٣٧﴾ أي تقرؤون</p>"
        },
        "38": {
            "verses": {
                "68:38": {
                    "id": 38
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿إِنَّ لَكُمۡ فِیهِ لَمَا تَخَیَّرُونَ ۝٣٨﴾ تَخْتَارُونَ</h2>"
        },
        "39": {
            "verses": {
                "68:39": {
                    "id": 39
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَمۡ لَكُمۡ أَیۡمَـٰنٌ﴾ عُهُود ﴿عَلَیۡنَا بَـٰلِغَةٌ﴾ وَاثِقَة ﴿إِلَىٰ یَوۡمِ ٱلۡقِیَـٰمَةِ﴾ مُتَعَلِّق مَعْنَى بِعَلَيْنَا وَفِي هَذَا الْكَلَام مَعْنَى الْقَسَم أَيْ أَقْسَمْنَا لَكُمْ وَجَوَابه ﴿إِنَّ لَكُمۡ لَمَا تَحۡكُمُونَ ۝٣٩﴾ بِهِ لِأَنْفُسِكُمْ</p>"
        },
        "40": {
            "verses": {
                "68:40": {
                    "id": 40
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿سَلۡهُمۡ أَیُّهُم بِذَ ٰ⁠لِكَ﴾ الْحُكْم الَّذِي يَحْكُمُونَ بِهِ لِأَنْفُسِهِمْ مِنْ أَنَّهُمْ يُعْطُونَ فِي الْآخِرَة أَفَضْل مِنْ الْمُؤْمِنِينَ ﴿زَعِیمٌ ۝٤٠﴾ كَفِيل لَهُمْ</p>"
        },
        "41": {
            "verses": {
                "68:41": {
                    "id": 41
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَمۡ لَهُمۡ﴾ أَيْ عِنْدهمْ ﴿شُرَكَاۤءُ﴾ مُوَافِقُونَ لَهُمْ فِي هَذَا الْقَوْل يَكْفُلُونَ بِهِ لَهُمْ فَإِنْ كَانَ كَذَلِكَ ﴿فَلۡیَأۡتُوا۟ بِشُرَكَاۤىِٕهِمۡ﴾ الْكَافِلِينَ لَهُمْ بِهِ ﴿إِن كَانُوا۟ صَـٰدِقِینَ ۝٤١﴾</p>"
        },
        "42": {
            "verses": {
                "68:42": {
                    "id": 42
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>اذكر ﴿یَوۡمَ یُكۡشَفُ عَن سَاقࣲ﴾ هُوَ عِبَارَة عَنْ شِدَّة الْأَمْر يَوْم الْقِيَامَة لِلْحِسَابِ وَالْجَزَاء يُقَال كَشَفَتْ الْحَرْب عَنْ سَاق إذَا اشْتَدَّ الْأَمْر فِيهَا ﴿وَیُدۡعَوۡنَ إِلَى ٱلسُّجُودِ﴾ امْتِحَانًا لِإِيمَانِهِمْ ﴿فَلَا یَسۡتَطِیعُونَ ۝٤٢﴾ تَصِير ظُهُورهمْ طَبَقًا وَاحِدًا</p>"
        },
        "43": {
            "verses": {
                "68:43": {
                    "id": 43
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿خَـٰشِعَةً﴾ حَال مِنْ ضَمِير يَدْعُونَ أَيْ ذَلِيلَة ﴿أَبۡصَـٰرُهُمۡ﴾ لَا يَرْفَعُونَهَا ﴿تَرۡهَقُهُمۡ﴾ تَغْشَاهُمْ ﴿ذِلَّةࣱۖ وَقَدۡ كَانُوا۟ یُدۡعَوۡنَ﴾ فِي الدُّنْيَا ﴿إِلَى ٱلسُّجُودِ وَهُمۡ سَـٰلِمُونَ ۝٤٣﴾ فَلَا يَأْتُونَ بِهِ بِأَنْ لَا يُصَلُّوا</p>"
        },
        "44": {
            "verses": {
                "68:44": {
                    "id": 44
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَذَرۡنِی﴾ دَعْنِي ﴿وَمَن یُكَذِّبُ بِهَـٰذَا ٱلۡحَدِیثِۖ﴾ الْقُرْآن ﴿سَنَسۡتَدۡرِجُهُم﴾ نأخذهم قليلا قليلا ﴿مِّنۡ حَیۡثُ لَا یَعۡلَمُونَ ۝٤٤﴾</p>"
        },
        "45": {
            "verses": {
                "68:45": {
                    "id": 45
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَأُمۡلِی لَهُمۡۚ﴾ أَمْهِلْهُمْ ﴿إِنَّ كَیۡدِی مَتِینٌ ۝٤٥﴾ شَدِيد لا يطاق</p>"
        },
        "46": {
            "verses": {
                "68:46": {
                    "id": 46
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَمۡ﴾ بَلْ أَ ﴿تَسۡـَٔلُهُمۡ﴾ عَلَى تَبْلِيغ الرِّسَالَة ﴿أَجۡرࣰا فَهُم مِّن مَّغۡرَمࣲ﴾ مِمَّا يُعْطُونَكَهُ ﴿مُّثۡقَلُونَ ۝٤٦﴾ فَلَا يُؤْمِنُونَ لِذَلِكَ</p>"
        },
        "47": {
            "verses": {
                "68:47": {
                    "id": 47
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَمۡ عِندَهُمُ ٱلۡغَیۡبُ﴾ أَيْ اللَّوْح الْمَحْفُوظ الَّذِي فِيهِ الْغَيْب ﴿فَهُمۡ یَكۡتُبُونَ ۝٤٧﴾ مِنْهُ مَا يَقُولُونَ</p>"
        },
        "48": {
            "verses": {
                "68:48": {
                    "id": 48
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَٱصۡبِرۡ لِحُكۡمِ رَبِّكَ﴾ فِيهِمْ بِمَا يَشَاء ﴿وَلَا تَكُن كَصَاحِبِ ٱلۡحُوتِ﴾ فِي الضَّجَر وَالْعَجَلَة وَهُوَ يُونُس عَلَيْهِ السَّلَام ﴿إِذۡ نَادَىٰ﴾ دَعَا رَبّه ﴿وَهُوَ مَكۡظُومࣱ ۝٤٨﴾ مَمْلُوء غَمًّا فِي بَطْن الْحُوت</p>"
        },
        "49": {
            "verses": {
                "68:49": {
                    "id": 49
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿لَّوۡلَاۤ أَن تَدَ ٰ⁠رَكَهُۥ﴾ أدركه ﴿نِعۡمَةࣱ﴾ رحمة ﴿مِّن رَّبِّهِۦ لَنُبِذَ﴾ من بطن الحوت ﴿بِٱلۡعَرَاۤءِ﴾ بالأرض الفضاء ﴿وَهُوَ مَذۡمُومࣱ ۝٤٩﴾ لكنه رُحِم فَنُبِذَ غيرَ مذموم</p>"
        },
        "50": {
            "verses": {
                "68:50": {
                    "id": 50
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَٱجۡتَبَـٰهُ رَبُّهُۥ﴾ بالنبوة ﴿فَجَعَلَهُۥ مِنَ ٱلصَّـٰلِحِینَ ۝٥٠﴾ الأنبياء</p>"
        },
        "51": {
            "verses": {
                "68:51": {
                    "id": 51
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِن یَكَادُ ٱلَّذِینَ كَفَرُوا۟ لَیُزۡلِقُونَكَ﴾ بِضَمِّ الْيَاء وبفتحها ﴿بِأَبۡصَـٰرِهِمۡ﴾ يَنْظُرُونَ إلَيْك نَظَرًا شَدِيدًا يَكَاد أَنْ يَصْرَعك وَيُسْقِطك مِنْ مَكَانك ﴿لَمَّا سَمِعُوا۟ ٱلذِّكۡرَ﴾ الْقُرْآن ﴿وَیَقُولُونَ﴾ حَسَدًا ﴿إِنَّهُۥ لَمَجۡنُونࣱ ۝٥١﴾ بِسَبَبِ الْقُرْآن الَّذِي جَاءَ بِهِ</p>"
        },
