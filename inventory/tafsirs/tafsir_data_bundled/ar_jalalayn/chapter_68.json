            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿نۤۚ﴾ أَحَد حُرُوف الْهِجَاء اللَّه أَعْلَم بِمُرَادِهِ بِهِ ﴿وَٱلۡقَلَمِ﴾ الَّذِي كَتَبَ بِهِ الْكَائِنَات فِي اللَّوْح الْمَحْفُوظ ﴿وَمَا یَسۡطُرُونَ ۝١﴾ أَيْ الْمَلَائِكَة مِنْ الخير والصلاح</p>"
        },
        "2": {
            "verses": {
                "68:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿مَاۤ أَنتَ﴾ يَا مُحَمَّد ﴿بِنِعۡمَةِ رَبِّكَ بِمَجۡنُونࣲ ۝٢﴾ أَيْ انْتَفَى الْجُنُون عَنْك بِسَبَبِ إنْعَام رَبّك عَلَيْك بِالنُّبُوَّةِ وَغَيْرهَا وَهَذَا رَدّ لِقَوْلِهِمْ إنَّهُ مجنون</p>"
        },
        "3": {
            "verses": {
                "68:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
