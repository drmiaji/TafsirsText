                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلتِّینِ وَٱلزَّیۡتُونِ ۝١﴾ أَيْ الْمَأْكُولَيْنِ أَوْ جَبَلَيْنِ بِالشَّامِ ينبتان المأكولين</p>"
        },
        "2": {
            "verses": {
                "95:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَطُورِ سِینِینَ ۝٢﴾ الْجَبَل الَّذِي كَلَّمَ اللَّه تَعَالَى عَلَيْهِ مُوسَى وَمَعْنَى سِينِينَ الْمُبَارَك أَوْ الْحَسَن بِالْأَشْجَارِ الْمُثْمِرَة</p>"
        },
        "3": {
            "verses": {
                "95:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَهَـٰذَا ٱلۡبَلَدِ ٱلۡأَمِینِ ۝٣﴾ مَكَّة لِأَمْنِ النَّاس فِيهَا جاهلية وإسلاما</p>"
        },
        "4": {
            "verses": {
                "95:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿لَقَدۡ خَلَقۡنَا ٱلۡإِنسَـٰنَ﴾ الْجِنْس ﴿فِیۤ أَحۡسَنِ تَقۡوِیمࣲ ۝٤﴾ تعديل لصورته</p>"
        },
        "5": {
            "verses": {
                "95:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ رَدَدۡنَـٰهُ﴾ فِي بَعْض أَفْرَاده ﴿أَسۡفَلَ سَـٰفِلِینَ ۝٥﴾ كِنَايَة عَنْ الْهَرَم وَالضَّعْف فَيَنْقُص عَمَل الْمُؤْمِن عن زمن الشباب ويكون له أجره بقوله تعالى</p>"
        },
        "6": {
            "verses": {
                "95:6": {
                    "id": 6
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِلَّا﴾ لَكِنْ ﴿ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ فَلَهُمۡ أَجۡرٌ غَیۡرُ مَمۡنُونࣲ ۝٦﴾ مَقْطُوع وَفِي الْحَدِيث إِذَا بَلَغَ الْمُؤْمِن مِنْ الْكِبَر مَا يُعْجِزهُ عَنْ الْعَمَل كُتِبَ لَهُ مَا كَانَ يَعْمَل</p>"
        },
        "7": {
            "verses": {
                "95:7": {
                    "id": 7
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَمَا یُكَذِّبُكَ﴾ أَيّهَا الْكَافِر ﴿بَعۡدُ﴾ بَعْد مَا ذُكِرَ مِنْ خَلْق الْإِنْسَان فِي أَحْسَن صُورَة ثُمَّ رَدّه إِلَى أَرْذَل الْعُمُر الدَّالّ عَلَى الْقُدْرَة عَلَى الْبَعْث ﴿بِٱلدِّینِ ۝٧﴾ بِالْجَزَاءِ الْمَسْبُوق بِالْبَعْثِ وَالْحِسَاب أَيْ مَا يَجْعَلك مُكَذِّبًا بِذَلِكَ وَلَا جاعل له</p>"
        },
        "8": {
            "verses": {
                "95:8": {
                    "id": 8
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَلَیۡسَ ٱللَّهُ بِأَحۡكَمِ ٱلۡحَـٰكِمِینَ ۝٨﴾ هُوَ أَقْضَى الْقَاضِينَ وَحُكْمه بِالْجَزَاءِ مِنْ ذَلِكَ وَفِي الْحَدِيث مَنْ قَرَأَ وَالتِّين إِلَى آخِرهَا فَلْيَقُلْ بَلَى وَأَنَا على ذلك من الشاهدين</p>"
        }
