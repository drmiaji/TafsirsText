            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّ ٱلۡإِنسَـٰنَ﴾ الْجِنْس ﴿لَفِی خُسۡرٍ ۝٢﴾ فِي تِجَارَته</p>"
        },
        "3": {
            "verses": {
                "103:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِلَّا ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ﴾ فَلَيْسُوا فِي خُسْرَان ﴿وَتَوَاصَوۡا۟﴾ أَوْصَى بَعْضهمْ بَعْضًا ﴿بِٱلۡحَقِّ﴾ الْإِيمَان ﴿وَتَوَاصَوۡا۟ بِٱلصَّبۡرِ ۝٣﴾ على الطاعة وعن المعصية</p>"
        }
    }
