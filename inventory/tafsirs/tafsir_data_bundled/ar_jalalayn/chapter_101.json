            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلۡقَارِعَةُ ۝١﴾ الْقِيَامَة الَّتِي تَقْرَع الْقُلُوب بِأَهْوَالِهَا</p>"
        },
        "2": {
            "verses": {
                "101:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿مَا ٱلۡقَارِعَةُ ۝٢﴾ تَهْوِيل لِشَأْنِهَا وَهُمَا مُبْتَدَأ وَخَبَر خَبَر القارعة</p>"
        },
        "3": {
            "verses": {
                "101:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَاۤ أَدۡرَىٰكَ﴾ أَعْلَمَك ﴿مَا ٱلۡقَارِعَةُ ۝٣﴾ زِيَادَة تَهْوِيل لَهَا وَمَا الْأُولَى مُبْتَدَأ وَمَا بَعْدهَا خَبَره وَمَا الثَّانِيَة وَخَبَرهَا فِي مَحَلّ الْمَفْعُول الثَّانِي لأدرى</p>"
        },
        "4": {
            "verses": {
                "101:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿یَوۡمَ﴾ نَاصِبه دَلَّ عَلَيْهِ الْقَارِعَة أَيْ تَقْرَع ﴿یَكُونُ ٱلنَّاسُ كَٱلۡفَرَاشِ ٱلۡمَبۡثُوثِ ۝٤﴾ كَغَوْغَاء الْجَرَاد الْمُنْتَشِر يَمُوج بَعْضهمْ فِي بَعْض لِلْحِيرَةِ إِلَى أَنْ يدعوا للحساب</p>"
        },
        "5": {
            "verses": {
                "101:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَتَكُونُ ٱلۡجِبَالُ كَٱلۡعِهۡنِ ٱلۡمَنفُوشِ ۝٥﴾ كَالصُّوفِ الْمَنْدُوف فِي خِفَّة سَيْرهَا حَتَّى تَسْتَوِي مَعَ الْأَرْض</p>"
        },
        "6": {
            "verses": {
                "101:6": {
                    "id": 6
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَأَمَّا مَن ثَقُلَتۡ مَوَ ٰ⁠زِینُهُۥ ۝٦﴾ بِأَنْ رَجَحَتْ حَسَنَاته على سيئاته</p>"
        },
        "7": {
            "verses": {
                "101:7": {
                    "id": 7
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَهُوَ فِی عِیشَةࣲ رَّاضِیَةࣲ ۝٧﴾ فِي الْجَنَّة أَيْ ذَات رِضًى بِأَنْ يَرْضَاهَا أَيْ مَرْضِيَّة لَهُ</p>"
        },
        "8": {
            "verses": {
                "101:8": {
                    "id": 8
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَمَّا مَنۡ خَفَّتۡ مَوَ ٰ⁠زِینُهُۥ ۝٨﴾ بِأَنْ رَجَحَتْ سَيِّئَاته على حسناته</p>"
        },
        "9": {
            "verses": {
                "101:9": {
                    "id": 9
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿فَأُمُّهُۥ﴾ فمسكنه ﴿هَاوِیَةࣱ ۝٩﴾</h2>"
        },
        "10": {
            "verses": {
                "101:10": {
                    "id": 10
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَاۤ أَدۡرَىٰكَ مَا هِیَهۡ ۝١٠﴾ أي ما هاوية</h2>"
        },
        "11": {
            "verses": {
                "101:11": {
                    "id": 11
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>هي ﴿نَارٌ حَامِیَةُۢ ۝١١﴾ شَدِيدَة الْحَرَارَة وَهَاء {هِیَهۡ} لِلسَّكْتِ تُثْبَت وَصْلًا ووقفا وفي قراءة تحذف وصلا</p>"
        }
    }
}