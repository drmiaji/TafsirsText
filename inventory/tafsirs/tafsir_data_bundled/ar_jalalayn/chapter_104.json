            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَیۡلࣱ﴾ كَلِمَة عَذَاب أَوْ وَادٍ فِي جَهَنَّم ﴿لِّكُلِّ هُمَزَةࣲ لُّمَزَةٍ ۝١﴾ أَيْ كَثِير الْهَمْز وَاللَّمْز أَيْ الْغِيبَة نَزَلَتْ فِيمَنْ كَانَ يَغْتَاب النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ وَالْمُؤْمِنِينَ كَأُمَيَّة بْن خَلَف وَالْوَلِيد بْن الْمُغِيرَة وَغَيْرهمَا</p>"
        },
        "2": {
            "verses": {
                "104:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلَّذِی جَمَعَ﴾ بِالتَّخْفِيفِ وَالتَّشْدِيد ﴿مَالࣰا وَعَدَّدَهُۥ ۝٢﴾ أَحْصَاهُ وَجَعَلَهُ عُدَّة لِحَوَادِث الدَّهْر</p>"
        },
        "3": {
            "verses": {
                "104:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿یَحۡسَبُ﴾ لِجَهْلِهِ ﴿أَنَّ مَالَهُۥۤ أَخۡلَدَهُۥ ۝٣﴾ جَعَلَهُ خَالِدًا لا يموت</p>"
        },
        "4": {
            "verses": {
                "104:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿كَلَّاۖ﴾ رَدْع ﴿لَیُنۢبَذَنَّ﴾ جَوَاب قَسَم مَحْذُوف أَيْ لَيُطْرَحَنَّ ﴿فِی ٱلۡحُطَمَةِ ۝٤﴾ الَّتِي تُحَطِّم كُلّ مَا ألقي فيها</p>"
        },
        "5": {
            "verses": {
                "104:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَاۤ أَدۡرَىٰكَ﴾ أَعْلَمَك ﴿مَا ٱلۡحُطَمَةُ ۝٥﴾</h2>"
        },
        "6": {
            "verses": {
                "104:6": {
                    "id": 6
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿نَارُ ٱللَّهِ ٱلۡمُوقَدَةُ ۝٦﴾ الْمُسَعَّرَة</h2>"
        },
        "7": {
            "verses": {
                "104:7": {
                    "id": 7
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلَّتِی تَطَّلِعُ﴾ تُشْرِف ﴿عَلَى ٱلۡأَفۡـِٔدَةِ ۝٧﴾ الْقُلُوب فَتُحْرِقهَا وَأَلَمهَا أَشَدّ مِنْ أَلَم غَيْرهَا لِلُطْفِهَا</p>"
        },
        "8": {
            "verses": {
                "104:8": {
                    "id": 8
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّهَا عَلَیۡهِم﴾ جَمَعَ الضَّمِير رِعَايَة لِمَعْنَى كُلّ ﴿مُّؤۡصَدَةࣱ ۝٨﴾ بِالْهَمْزِ وَبِالْوَاوِ بَدَله مُطْبَقَة</p>"
        },
        "9": {
            "verses": {
                "104:9": {
                    "id": 9
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فِی عُمُدࣲ﴾ بِضَمِّ الْحَرْفَيْنِ وَبِفَتْحِهِمَا ﴿مُّمَدَّدَةِۭ ۝٩﴾ صِفَة لما قبله فتكون النار داخل العمد</p>"
        }
    }
