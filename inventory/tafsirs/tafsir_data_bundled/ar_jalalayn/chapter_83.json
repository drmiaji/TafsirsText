                "language_name": "english"
            },
            "text": "<h2>﴿كِتَـٰبࣱ مَّرۡقُومࣱ ۝٢٠﴾ مَخْتُوم</h2>"
        },
        "21": {
            "verses": {
                "83:21": {
                    "id": 21
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
