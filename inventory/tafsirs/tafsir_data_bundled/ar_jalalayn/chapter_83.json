            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَیۡلࣱ﴾ كَلِمَة عَذَاب أَوْ وَادٍ فِي جَهَنَّم ﴿لِّلۡمُطَفِّفِینَ ۝١﴾</p>"
        },
        "2": {
            "verses": {
                "83:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلَّذِینَ إِذَا ٱكۡتَالُوا۟ عَلَى﴾ أَيْ مِنْ ﴿ٱلنَّاسِ یَسۡتَوۡفُونَ ۝٢﴾ الكيل</p>"
        },
        "3": {
            "verses": {
                "83:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِذَا كَالُوهُمۡ﴾ أَيْ كَالُوا لَهُمْ ﴿أَو وَّزَنُوهُمۡ﴾ أَيْ وَزَنُوا لَهُمْ ﴿یُخۡسِرُونَ ۝٣﴾ يُنْقِصُونَ الْكَيْل أَوْ الوزن</p>"
        },
        "4": {
            "verses": {
                "83:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَلَا﴾ اِسْتِفْهَام تَوْبِيخ ﴿یَظُنُّ﴾ يَتَيَقَّن ﴿أُو۟لَـٰۤىِٕكَ أَنَّهُم مَّبۡعُوثُونَ ۝٤﴾</p>"
        },
        "5": {
            "verses": {
                "83:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿لِیَوۡمٍ عَظِیمࣲ ۝٥﴾ أَيْ فِيهِ وَهُوَ يَوْم الْقِيَامَة</h2>"
        },
        "6": {
            "verses": {
                "83:6": {
                    "id": 6
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿یَوۡمَ﴾ بَدَل مِنْ مَحَلّ لِيَوْمٍ فَنَاصِبه مَبْعُوثُونَ ﴿یَقُومُ ٱلنَّاسُ﴾ مِنْ قُبُورهمْ ﴿لِرَبِّ ٱلۡعَـٰلَمِینَ ۝٦﴾ الْخَلَائِق لِأَجْلِ أَمْره وَحِسَابه وَجَزَائِهِ</p>"
        },
        "7": {
            "verses": {
                "83:7": {
                    "id": 7
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿كَلَّاۤ﴾ حَقًّا ﴿إِنَّ كِتَـٰبَ ٱلۡفُجَّارِ﴾ أَيْ كِتَاب أَعْمَال الْكُفَّار ﴿لَفِی سِجِّینࣲ ۝٧﴾ قِيلَ هُوَ كِتَاب جَامِع لِأَعْمَالِ الشَّيَاطِين وَالْكَفَرَة وَقِيلَ هُوَ مَكَان أَسْفَل الْأَرْض السَّابِعَة وَهُوَ مَحَلّ إِبْلِيس وَجُنُوده</p>"
        },
        "8": {
            "verses": {
                "83:8": {
                    "id": 8
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَاۤ أَدۡرَىٰكَ مَا سِجِّینࣱ ۝٨﴾ مَا كِتَاب سِجِّين</h2>"
        },
        "9": {
            "verses": {
                "83:9": {
                    "id": 9
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿كِتَـٰبࣱ مَّرۡقُومࣱ ۝٩﴾ مختوم</h2>"
        },
        "10": {
            "verses": {
                "83:10": {
                    "id": 10
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَیۡلࣱ یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝١٠﴾</h2>"
        },
        "11": {
            "verses": {
                "83:11": {
                    "id": 11
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلَّذِینَ یُكَذِّبُونَ بِیَوۡمِ ٱلدِّینِ ۝١١﴾ الْجَزَاء بَدَل أَوْ بيان للمكذبين</p>"
        },
        "12": {
            "verses": {
                "83:12": {
                    "id": 12
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَا یُكَذِّبُ بِهِۦۤ إِلَّا كُلُّ مُعۡتَدٍ﴾ مُتَجَاوِز الْحَدّ ﴿أَثِیمٍ ۝١٢﴾ صِيغَة مُبَالَغَة</p>"
        },
        "13": {
            "verses": {
                "83:13": {
                    "id": 13
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِذَا تُتۡلَىٰ عَلَیۡهِ ءَایَـٰتُنَا﴾ الْقُرْآن ﴿قَالَ أَسَـٰطِیرُ ٱلۡأَوَّلِینَ ۝١٣﴾ الْحِكَايَات الَّتِي سُطِّرَتْ قَدِيمًا جَمَعَ أُسْطُورَة بِالضَّمِّ أَوْ إِسْطَارَة بِالْكَسْرِ</p>"
        },
        "14": {
            "verses": {
                "83:14": {
                    "id": 14
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿كَلَّاۖ﴾ رَدْع وَزَجْر لِقَوْلِهِمْ ذَلِكَ ﴿بَلۡۜ رَانَ﴾ غَلَبَ ﴿عَلَىٰ قُلُوبِهِم﴾ فَغَشِيَهَا ﴿مَّا كَانُوا۟ یَكۡسِبُونَ ۝١٤﴾ مِنْ الْمَعَاصِي فَهُوَ كَالصَّدَأِ</p>"
        },
        "15": {
            "verses": {
                "83:15": {
                    "id": 15
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿كَلَّاۤ﴾ حَقًّا ﴿إِنَّهُمۡ عَن رَّبِّهِمۡ یَوۡمَىِٕذࣲ﴾ يَوْم القيامة ﴿لَّمَحۡجُوبُونَ ۝١٥﴾ فلا يرونه</p>"
        },
        "16": {
            "verses": {
                "83:16": {
                    "id": 16
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ إِنَّهُمۡ لَصَالُوا۟ ٱلۡجَحِیمِ ۝١٦﴾ لَدَاخِلُو النَّار الْمُحْرِقَة</p>"
        },
        "17": {
            "verses": {
                "83:17": {
                    "id": 17
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ یُقَالُ﴾ لَهُمْ ﴿هَـٰذَا﴾ أَيْ الْعَذَاب ﴿ٱلَّذِی كُنتُم بِهِۦ تُكَذِّبُونَ ۝١٧﴾</p>"
        },
        "18": {
            "verses": {
                "83:18": {
                    "id": 18
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿كَلَّاۤ﴾ حَقًّا ﴿إِنَّ كِتَـٰبَ ٱلۡأَبۡرَارِ﴾ أَيْ كِتَاب أَعْمَال الْمُؤْمِنِينَ الصَّادِقِينَ فِي إِيمَانهمْ ﴿لَفِی عِلِّیِّینَ ۝١٨﴾ قِيلَ هُوَ كِتَاب جَامِع لِأَعْمَالِ الْخَيْر مِنْ الْمَلَائِكَة وَمُؤْمِنِي الثَّقَلَيْنِ وَقِيلَ هُوَ مَكَان فِي السَّمَاء السَّابِعَة تَحْت الْعَرْش</p>"
        },
        "19": {
            "verses": {
                "83:19": {
                    "id": 19
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَاۤ أَدۡرَىٰكَ﴾ أَعْلَمَك ﴿مَا عِلِّیُّونَ ۝١٩﴾ مَا كِتَاب عليين. هو</p>"
        },
        "20": {
