            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلسَّمَاۤءِ ذَاتِ ٱلۡبُرُوجِ ۝١﴾ الْكَوَاكِب اِثْنَيْ عَشَر بُرْجًا تَقَدَّمَتْ فِي الْفُرْقَان</p>"
        },
        "2": {
            "verses": {
                "85:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَٱلۡیَوۡمِ ٱلۡمَوۡعُودِ ۝٢﴾ يَوْم الْقِيَامَة</h2>"
        },
        "3": {
            "verses": {
                "85:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَشَاهِدࣲ﴾ يَوْم الْجُمْعَة ﴿وَمَشۡهُودࣲ ۝٣﴾ يَوْم عَرَفَة كَذَا فُسِّرَتْ الثَّلَاثَة فِي الْحَدِيث فَالْأَوَّل مَوْعُود بِهِ وَالثَّانِي شَاهِد بِالْعَمَلِ فِيهِ وَالثَّالِث تَشْهَدهُ النَّاس وَالْمَلَائِكَة وَجَوَاب الْقَسَم مَحْذُوف صَدْره تَقْدِيره لَقَدْ</p>"
        },
        "4": {
            "verses": {
                "85:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿قُتِلَ﴾ لُعِنَ ﴿أَصۡحَـٰبُ ٱلۡأُخۡدُودِ ۝٤﴾ الشَّقّ فِي الْأَرْض</p>"
        },
        "5": {
            "verses": {
                "85:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلنَّارِ﴾ بَدَل اِشْتِمَال مِنْهُ ﴿ذَاتِ ٱلۡوَقُودِ ۝٥﴾ مَا توقد به</p>"
        },
        "6": {
            "verses": {
                "85:6": {
                    "id": 6
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِذۡ هُمۡ عَلَیۡهَا﴾ حَوْلهَا عَلَى جَانِب الْأُخْدُود عَلَى الْكَرَاسِيّ ﴿قُعُودࣱ ۝٦﴾</p>"
        },
        "7": {
            "verses": {
                "85:7": {
                    "id": 7
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَهُمۡ عَلَىٰ مَا یَفۡعَلُونَ بِٱلۡمُؤۡمِنِینَ﴾ بِاَللَّهِ مِنْ تَعْذِيبهمْ بِالْإِلْقَاءِ فِي النَّار إِنْ لَمْ يَرْجِعُوا عَنْ إِيمَانهمْ ﴿شُهُودࣱ ۝٧﴾ حُضُور رُوِيَ أَنَّ اللَّه أَنْجَى الْمُؤْمِنِينَ الْمُلْقَيْنَ فِي النَّار بِقَبْضِ أَرْوَاحهمْ قَبْل وُقُوعهمْ فِيهَا وَخَرَجَتْ النَّار إِلَى مَنْ ثم فأحرقتهم</p>"
        },
        "8": {
            "verses": {
                "85:8": {
                    "id": 8
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَا نَقَمُوا۟ مِنۡهُمۡ إِلَّاۤ أَن یُؤۡمِنُوا۟ بِٱللَّهِ ٱلۡعَزِیزِ﴾ فِي مُلْكه ﴿ٱلۡحَمِیدِ ۝٨﴾ الْمَحْمُود</p>"
        },
        "9": {
            "verses": {
                "85:9": {
                    "id": 9
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلَّذِی لَهُۥ مُلۡكُ ٱلسَّمَـٰوَ ٰ⁠تِ وَٱلۡأَرۡضِۚ وَٱللَّهُ عَلَىٰ كُلِّ شَیۡءࣲ شَهِیدٌ ۝٩﴾ أَيْ مَا أَنْكَرَ الْكُفَّار عَلَى الْمُؤْمِنِينَ إِلَّا إِيمَانهمْ</p>"
        },
        "10": {
            "verses": {
                "85:10": {
                    "id": 10
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّ ٱلَّذِینَ فَتَنُوا۟ ٱلۡمُؤۡمِنِینَ وَٱلۡمُؤۡمِنَـٰتِ﴾ بِالْإِحْرَاقِ ﴿ثُمَّ لَمۡ یَتُوبُوا۟ فَلَهُمۡ عَذَابُ جَهَنَّمَ﴾ بِكُفْرِهِمْ ﴿وَلَهُمۡ عَذَابُ ٱلۡحَرِیقِ ۝١٠﴾ أَيْ عَذَاب إِحْرَاقهمْ الْمُؤْمِنِينَ فِي الْآخِرَة وَقِيلَ فِي الدُّنْيَا بِأَنْ أُخْرِجَتْ النَّار فأحرقتهم كما تقدم</p>"
        },
        "11": {
            "verses": {
                "85:11": {
                    "id": 11
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّ ٱلَّذِینَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ لَهُمۡ جَنَّـٰتࣱ تَجۡرِی مِن تَحۡتِهَا ٱلۡأَنۡهَـٰرُۚ ذَ ٰ⁠لِكَ ٱلۡفَوۡزُ ٱلۡكَبِیرُ ۝١١﴾</p>"
        },
        "12": {
            "verses": {
                "85:12": {
                    "id": 12
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّ بَطۡشَ رَبِّكَ﴾ بِالْكَفَّارِ ﴿لَشَدِیدٌ ۝١٢﴾ بِحَسْب إِرَادَته</p>"
        },
        "13": {
            "verses": {
                "85:13": {
                    "id": 13
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّهُۥ هُوَ یُبۡدِئُ﴾ الْخَلْق ﴿وَیُعِیدُ ۝١٣﴾ فَلَا يُعْجِزهُ ما يريد</p>"
        },
        "14": {
            "verses": {
                "85:14": {
                    "id": 14
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَهُوَ ٱلۡغَفُورُ﴾ لِلْمُذْنِبِينَ الْمُؤْمِنِينَ ﴿ٱلۡوَدُودُ ۝١٤﴾ الْمُتَوَدِّد إِلَى أوليائه بالكرامة</p>"
        },
        "15": {
            "verses": {
                "85:15": {
                    "id": 15
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ذُو ٱلۡعَرۡشِ﴾ خَالِقه وَمَالِكه ﴿ٱلۡمَجِیدُ ۝١٥﴾ بِالرَّفْعِ الْمُسْتَحِقّ لِكَمَالِ صِفَات الْعُلُوّ</p>"
        },
        "16": {
            "verses": {
                "85:16": {
                    "id": 16
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿فَعَّالࣱ لِّمَا یُرِیدُ ۝١٦﴾ لَا يُعْجِزهُ شَيْء</h2>"
        },
        "17": {
            "verses": {
                "85:17": {
                    "id": 17
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿هَلۡ أَتَىٰكَ﴾ يَا مُحَمَّد ﴿حَدِیثُ ٱلۡجُنُودِ ۝١٧﴾</h2>"
        },
        "18": {
            "verses": {
                "85:18": {
                    "id": 18
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فِرۡعَوۡنَ وَثَمُودَ ۝١٨﴾ بَدَل مِنْ الْجُنُود وَاسْتُغْنِيَ بِذِكْرِ فِرْعَوْن عَنْ أَتْبَاعه وَحَدِيثهمْ أَنَّهُمْ أُهْلِكُوا بِكُفْرِهِمْ وَهَذَا تَنْبِيه لِمَنْ كَفَرَ بِالنَّبِيِّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ وَالْقُرْآن لِيَتَّعِظُوا</p>"
        },
        "19": {
            "verses": {
                "85:19": {
                    "id": 19
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿بَلِ ٱلَّذِینَ كَفَرُوا۟ فِی تَكۡذِیبࣲ ۝١٩﴾ بِمَا ذُكِرَ</h2>"
        },
        "20": {
            "verses": {
                "85:20": {
                    "id": 20
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱللَّهُ مِن وَرَاۤىِٕهِم مُّحِیطُۢ ۝٢٠﴾ لَا عَاصِم لَهُمْ منه</p>"
        },
        "21": {
            "verses": {
                "85:21": {
                    "id": 21
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿بَلۡ هُوَ قُرۡءَانࣱ مَّجِیدࣱ ۝٢١﴾ عَظِيم</h2>"
        },
        "22": {
            "verses": {
                "85:22": {
                    "id": 22
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فِی لَوۡحࣲ﴾ هُوَ فِي الْهَوَاء فَوْق السَّمَاء السَّابِعَة ﴿مَّحۡفُوظِۭ ۝٢٢﴾ بِالْجَرِّ مِن الشَّيَاطِين وَمِنْ تَغْيِير شَيْء مِنْهُ طُوله مَا بَيْن السَّمَاء وَالْأَرْض وعرضه ما بين المشرق والمغرب وهو من درة بيضاء قاله ابن عباس رضي الله عنهما</p>"
        }
    }
