{
    "chapter": 88,
    "verses": {
        "1": {
            "verses": {
                "88:1": {
                    "id": 1
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿هَلۡ﴾ قَدْ ﴿أَتَىٰكَ حَدِیثُ ٱلۡغَـٰشِیَةِ ۝١﴾ الْقِيَامَة لِأَنَّهَا تَغْشَى الْخَلَائِق بِأَهْوَالِهَا</p>"
        },
        "2": {
            "verses": {
                "88:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وُجُوهࣱ یَوۡمَىِٕذٍ﴾ عَبَّرَ بِهَا عَنْ الذَّوَات فِي الْمَوْضِعَيْنِ ﴿خَـٰشِعَةٌ ۝٢﴾ ذَلِيلَة</p>"
        },
        "3": {
            "verses": {
                "88:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿عَامِلَةࣱ نَّاصِبَةࣱ ۝٣﴾ ذَات نَصَب وَتَعَب بِالسَّلَاسِلِ وَالْأَغْلَال</p>"
        },
        "4": {
            "verses": {
                "88:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿تَصۡلَىٰ﴾ بِفَتْحِ التَّاء وَضَمّهَا ﴿نَارًا حَامِیَةࣰ ۝٤﴾</h2>"
        },
        "5": {
            "verses": {
                "88:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿تُسۡقَىٰ مِنۡ عَیۡنٍ ءَانِیَةࣲ ۝٥﴾ شَدِيدَة الْحَرَارَة</h2>"
        },
        "6": {
            "verses": {
                "88:6": {
                    "id": 6
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿لَّیۡسَ لَهُمۡ طَعَامٌ إِلَّا مِن ضَرِیعࣲ ۝٦﴾ هُوَ نَوْع مِنْ الشَّوْك لَا تَرْعَاهُ دَابَّة لِخُبْثِهِ</p>"
        },
        "7": {
            "verses": {
                "88:7": {
                    "id": 7
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿لَّا یُسۡمِنُ وَلَا یُغۡنِی مِن جُوعࣲ ۝٧﴾</h2>"
        },
        "8": {
            "verses": {
                "88:8": {
                    "id": 8
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وُجُوهࣱ یَوۡمَىِٕذࣲ نَّاعِمَةࣱ ۝٨﴾ حَسَنَة</h2>"
        },
        "9": {
            "verses": {
                "88:9": {
                    "id": 9
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿لِّسَعۡیِهَا﴾ فِي الدُّنْيَا بِالطَّاعَةِ ﴿رَاضِیَةࣱ ۝٩﴾ فِي الْآخِرَة لَمَّا رَأَتْ ثَوَابه</p>"
        },
        "10": {
            "verses": {
                "88:10": {
                    "id": 10
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿فِی جَنَّةٍ عَالِیَةࣲ ۝١٠﴾ حسا ومعنى</h2>"
        },
        "11": {
            "verses": {
                "88:11": {
                    "id": 11
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿لَّا یُسۡمَعُ﴾ بِالْيَاءِ وَالتَّاء ﴿فِیهَا لَـٰغِیَةࣱ ۝١١﴾ أَيْ نَفْس ذَات لَغْو هَذَيَان مِنْ الْكَلَام</p>"
        },
        "12": {
            "verses": {
                "88:12": {
                    "id": 12
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿فِیهَا عَیۡنࣱ جَارِیَةࣱ ۝١٢﴾ بِالْمَاءِ بِمَعْنَى عُيُون</h2>"
        },
        "13": {
            "verses": {
                "88:13": {
                    "id": 13
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فِیهَا سُرُرࣱ مَّرۡفُوعَةࣱ ۝١٣﴾ ذَاتًا وَقَدْرًا وَمَحِلًّا</p>"
        },
        "14": {
            "verses": {
                "88:14": {
                    "id": 14
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَكۡوَابࣱ﴾ أَقْدَاح لَا عُرَا لَهَا ﴿مَّوۡضُوعَةࣱ ۝١٤﴾ عَلَى حَافَّات الْعُيُون مُعَدَّة لِشُرْبِهِمْ</p>"
        },
        "15": {
            "verses": {
                "88:15": {
                    "id": 15
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَنَمَارِقُ﴾ وَسَائِد ﴿مَصۡفُوفَةࣱ ۝١٥﴾ بَعْضهَا بِجَنْبِ بَعْض يُسْتَنَد إليها</p>"
        },
        "16": {
            "verses": {
                "88:16": {
                    "id": 16
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَزَرَابِیُّ﴾ بُسُط طَنَافِس لَهَا خَمْل ﴿مَبۡثُوثَةٌ ۝١٦﴾ مَبْسُوطَة</p>"
        },
        "17": {
            "verses": {
                "88:17": {
                    "id": 17
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَفَلَا یَنظُرُونَ﴾ أَيْ كُفَّار مَكَّة نَظَر اِعْتِبَار ﴿إِلَى ٱلۡإِبِلِ كَیۡفَ خُلِقَتۡ ۝١٧﴾</p>"
        },
        "18": {
            "verses": {
                "88:18": {
                    "id": 18
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَإِلَى ٱلسَّمَاۤءِ كَیۡفَ رُفِعَتۡ ۝١٨﴾</h2>"
        },
        "19": {
            "verses": {
                "88:19": {
                    "id": 19
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَإِلَى ٱلۡجِبَالِ كَیۡفَ نُصِبَتۡ ۝١٩﴾</h2>"
        },
        "20": {
            "verses": {
                "88:20": {
                    "id": 20
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِلَى ٱلۡأَرۡضِ كَیۡفَ سُطِحَتۡ ۝٢٠﴾ أَيْ بُسِطَتْ فَيَسْتَدِلُّونَ بِهَا عَلَى قُدْرَة اللَّه تَعَالَى وَوَحْدَانِيّته وَصُدِّرَتْ بِالْإِبِلِ لِأَنَّهُمْ أَشَدّ مُلَابَسَة لَهَا مِنْ غَيْرهَا وَقَوْله سُطِحَتْ ظَاهِر فِي أَنَّ الْأَرْض سَطْح وَعَلَيْهِ عُلَمَاء الشَّرْع لَا كُرَة كَمَا قَالَهُ أَهْل الْهَيْئَة وَإِنْ لَمْ يَنْقُض رُكْنًا مِنْ أركان الشرع</p>"
        },
        "21": {
            "verses": {
                "88:21": {
                    "id": 21
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَذَكِّرۡ﴾ هُمْ نِعَم اللَّه وَدَلَائِل تَوْحِيده ﴿إِنَّمَاۤ أَنتَ مُذَكِّرࣱ ۝٢١﴾</p>"
        },
        "22": {
            "verses": {
                "88:22": {
                    "id": 22
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿لَّسۡتَ عَلَیۡهِم بِمُصَۜیۡطِرٍ ۝٢٢﴾ وَفِي قِرَاءَة بِالصاد بَدَل السين أَيْ بِمُسَلَّطٍ وَهَذَا قَبْل الْأَمْر بِالْجِهَادِ</p>"
        },
        "23": {
            "verses": {
                "88:23": {
                    "id": 23
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِلَّا﴾ لَكِنْ ﴿مَن تَوَلَّىٰ﴾ أَعْرَضَ عَنْ الْإِيمَان ﴿وَكَفَرَ ۝٢٣﴾ بالقرآن</p>"
        },
        "24": {
            "verses": {
                "88:24": {
                    "id": 24
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَیُعَذِّبُهُ ٱللَّهُ ٱلۡعَذَابَ ٱلۡأَكۡبَرَ ۝٢٤﴾ عَذَاب الْآخِرَة وَالْأَصْغَر عَذَاب الدُّنْيَا بِالْقَتْلِ وَالْأَسْر</p>"
        },
        "25": {
            "verses": {
                "88:25": {
                    "id": 25
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿إِنَّ إِلَیۡنَاۤ إِیَابَهُمۡ ۝٢٥﴾ رُجُوعهمْ بَعْد الْمَوْت</h2>"
        },
        "26": {
            "verses": {
                "88:26": {
                    "id": 26
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ إِنَّ عَلَیۡنَا حِسَابَهُم ۝٢٦﴾ جَزَاءَهُمْ لَا نَتْرُكهُ أَبَدًا</p>"
        }
    }
}