            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿لِّتَسۡلُكُوا۟ مِنۡهَا سُبُلࣰا﴾ طُرُقًا ﴿فِجَاجࣰا ۝٢٠﴾ وَاسِعَة</p>"
        },
        "21": {
            "verses": {
                "71:21": {
                    "id": 21
                }
