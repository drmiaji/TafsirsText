                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّاۤ أَرۡسَلۡنَا نُوحًا إِلَىٰ قَوۡمِهِۦۤ أَنۡ أَنذِرۡ﴾ أَيْ بِإِنْذَارِ ﴿قَوۡمَكَ مِن قَبۡلِ أَن یَأۡتِیَهُمۡ﴾ إنْ لَمْ يُؤْمِنُوا ﴿عَذَابٌ أَلِیمࣱ ۝١﴾ مُؤْلِم فِي الدُّنْيَا وَالْآخِرَة</p>"
        },
        "2": {
            "verses": {
                "71:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿قَالَ یَـٰقَوۡمِ إِنِّی لَكُمۡ نَذِیرࣱ مُّبِینٌ ۝٢﴾ بَيِّن الْإِنْذَار</p>"
        },
        "3": {
            "verses": {
                "71:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَنِ﴾ أي بأن أقول لكم ﴿ٱعۡبُدُوا۟ ٱللَّهَ وَٱتَّقُوهُ وَأَطِیعُونِ ۝٣﴾</p>"
        },
        "4": {
            "verses": {
                "71:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿یَغۡفِرۡ لَكُم مِّن ذُنُوبِكُمۡ﴾ مِنْ زَائِدَة فَإِنَّ الْإِسْلَام يُغْفَر بِهِ مَا قَبْله أَوْ تَبْعِيضِيَّةٌ لِإِخْرَاجِ حُقُوق الْعِبَاد ﴿وَیُؤَخِّرۡكُمۡ﴾ بِلَا عَذَاب ﴿إِلَىٰۤ أَجَلࣲ مُّسَمًّىۚ﴾ أَجَل الْمَوْت ﴿إِنَّ أَجَلَ ٱللَّهِ﴾ بِعَذَابِكُمْ إنْ لَمْ تُؤْمِنُوا ﴿إِذَا جَاۤءَ لَا یُؤَخَّرُۚ لَوۡ كُنتُمۡ تَعۡلَمُونَ ۝٤﴾ ذَلِكَ لَآمَنْتُمْ</p>"
        },
        "5": {
            "verses": {
                "71:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿قَالَ رَبِّ إِنِّی دَعَوۡتُ قَوۡمِی لَیۡلࣰا وَنَهَارࣰا ۝٥﴾ أي دائما متصلا</p>"
        },
        "6": {
            "verses": {
                "71:6": {
                    "id": 6
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَلَمۡ یَزِدۡهُمۡ دُعَاۤءِیۤ إِلَّا فِرَارࣰا ۝٦﴾ عَنْ الْإِيمَان</p>"
        },
        "7": {
            "verses": {
                "71:7": {
                    "id": 7
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِنِّی كُلَّمَا دَعَوۡتُهُمۡ لِتَغۡفِرَ لَهُمۡ جَعَلُوۤا۟ أَصَـٰبِعَهُمۡ فِیۤ ءَاذَانِهِمۡ﴾ لِئَلَّا يَسْمَعُوا كَلَامِي ﴿وَٱسۡتَغۡشَوۡا۟ ثِیَابَهُمۡ﴾ غطوا رؤوسهم بِهَا لِئَلَّا يُنْظِرُونِي ﴿وَأَصَرُّوا۟﴾ عَلَى كُفْرهمْ ﴿وَٱسۡتَكۡبَرُوا۟﴾ تكبروا عن الإيمان ﴿ٱسۡتِكۡبَارࣰا ۝٧﴾</p>"
        },
        "8": {
            "verses": {
                "71:8": {
                    "id": 8
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ إِنِّی دَعَوۡتُهُمۡ جِهَارࣰا ۝٨﴾ أَيْ بِأَعْلَى صَوْتِي</p>"
        },
        "9": {
            "verses": {
                "71:9": {
                    "id": 9
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ إِنِّیۤ أَعۡلَنتُ لَهُمۡ﴾ صَوْتِي ﴿وَأَسۡرَرۡتُ﴾ الْكَلَام ﴿لَهُمۡ إِسۡرَارࣰا ۝٩﴾</p>"
        },
        "10": {
            "verses": {
                "71:10": {
                    "id": 10
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَقُلۡتُ ٱسۡتَغۡفِرُوا۟ رَبَّكُمۡ﴾ من الشرك ﴿إِنَّهُۥ كَانَ غَفَّارࣰا ۝١٠﴾</p>"
        },
        "11": {
            "verses": {
                "71:11": {
                    "id": 11
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿یُرۡسِلِ ٱلسَّمَاۤءَ﴾ الْمَطَر وَكَانُوا قَدْ مَنَعُوهُ ﴿عَلَیۡكُم مِّدۡرَارࣰا ۝١١﴾ كَثِير الدُّرُور</p>"
        },
        "12": {
            "verses": {
                "71:12": {
                    "id": 12
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَیُمۡدِدۡكُم بِأَمۡوَ ٰ⁠لࣲ وَبَنِینَ وَیَجۡعَل لَّكُمۡ جَنَّـٰتࣲ﴾ بَسَاتِين ﴿وَیَجۡعَل لَّكُمۡ أَنۡهَـٰرࣰا ۝١٢﴾ جارية</p>"
        },
        "13": {
            "verses": {
                "71:13": {
                    "id": 13
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿مَّا لَكُمۡ لَا تَرۡجُونَ لِلَّهِ وَقَارࣰا ۝١٣﴾ أَيْ تَأْمُلُونَ وَقَار اللَّه إيَّاكُمْ بِأَنْ تُؤْمِنُوا</p>"
        },
        "14": {
            "verses": {
                "71:14": {
                    "id": 14
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَقَدۡ خَلَقَكُمۡ أَطۡوَارًا ۝١٤﴾ جَمْع طَوْر وَهُوَ الْحَال فَطَوْرًا نُطْفَة وَطَوْرًا عَلَقَة إلَى تَمَام خَلْق الْإِنْسَان وَالنَّظَر فِي خَلْقه يُوجِب الْإِيمَان بِخَالِقِهِ</p>"
        },
        "15": {
            "verses": {
                "71:15": {
                    "id": 15
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَلَمۡ تَرَوۡا۟﴾ تَنْظُرُوا ﴿كَیۡفَ خَلَقَ ٱللَّهُ سَبۡعَ سَمَـٰوَ ٰ⁠تࣲ طِبَاقࣰا ۝١٥﴾ بَعْضهَا فَوْق بَعْض</p>"
        },
        "16": {
            "verses": {
                "71:16": {
                    "id": 16
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَجَعَلَ ٱلۡقَمَرَ فِیهِنَّ﴾ أَيْ فِي مَجْمُوعهنَّ الصَّادِق بِالسَّمَاءِ الدُّنْيَا ﴿نُورࣰا وَجَعَلَ ٱلشَّمۡسَ سِرَاجࣰا ۝١٦﴾ مِصْبَاحًا مُضِيئًا وَهُوَ أَقْوَى مِنْ نُور الْقَمَر</p>"
        },
        "17": {
            "verses": {
                "71:17": {
                    "id": 17
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱللَّهُ أَنۢبَتَكُم﴾ خَلَقَكُمْ ﴿مِّنَ ٱلۡأَرۡضِ﴾ إذْ خَلَقَ أباكم آدم منها ﴿نَبَاتࣰا ۝١٧﴾</p>"
        },
        "18": {
            "verses": {
                "71:18": {
                    "id": 18
