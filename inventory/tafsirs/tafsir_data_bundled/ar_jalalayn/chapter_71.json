            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ یُعِیدُكُمۡ فِیهَا﴾ مقبورين ﴿وَیُخۡرِجُكُمۡ﴾ للبعث ﴿إِخۡرَاجࣰا ۝١٨﴾</p>"
        },
        "19": {
