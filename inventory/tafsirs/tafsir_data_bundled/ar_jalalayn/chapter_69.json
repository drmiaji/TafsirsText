            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلۡحَاۤقَّةُ ۝١﴾ الْقِيَامَة الَّتِي يَحِقّ فِيهَا مَا أُنْكِرَ مِنْ الْبَعْث وَالْحِسَاب وَالْجَزَاء أَوْ الْمُظْهِرَة لِذَلِكَ</p>"
        },
        "2": {
            "verses": {
                "69:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿مَا ٱلۡحَاۤقَّةُ ۝٢﴾ تَعْظِيم لِشَأْنِهَا وَهُوَ مُبْتَدَأ وَخَبَر الحاقة</p>"
        },
        "3": {
            "verses": {
                "69:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَاۤ أَدۡرَىٰكَ﴾ أَعْلَمَك ﴿مَا ٱلۡحَاۤقَّةُ ۝٣﴾ زِيَادَة تَعْظِيم لِشَأْنِهَا فَمَا الْأُولَى مُبْتَدَأ وَمَا بَعْدهَا خَبَره وَمَا الثَّانِيَة وَخَبَرهَا فِي مَحَلّ الْمَفْعُول الثَّانِي لأدرى</p>"
        },
        "4": {
            "verses": {
                "69:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿كَذَّبَتۡ ثَمُودُ وَعَادُۢ بِٱلۡقَارِعَةِ ۝٤﴾ الْقِيَامَة لِأَنَّهَا تَقْرَع القلوب بأهوالها</p>"
        },
        "5": {
            "verses": {
                "69:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَأَمَّا ثَمُودُ فَأُهۡلِكُوا۟ بِٱلطَّاغِیَةِ ۝٥﴾ بِالصَّيْحَةِ الْمُجَاوِزَة لِلْحَدِّ في الشدة</p>"
        },
        "6": {
            "verses": {
                "69:6": {
                    "id": 6
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَمَّا عَادࣱ فَأُهۡلِكُوا۟ بِرِیحࣲ صَرۡصَرٍ﴾ شديد الصوت ﴿عَاتِیَةࣲ ۝٦﴾ قَوِيَّة شَدِيدَة عَلَى عَادٍ مَعَ قُوَّتهمْ وشدتهم</p>"
        },
        "7": {
            "verses": {
                "69:7": {
                    "id": 7
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿سَخَّرَهَا﴾ أَرْسَلَهَا بِالْقَهْرِ ﴿عَلَیۡهِمۡ سَبۡعَ لَیَالࣲ وَثَمَـٰنِیَةَ أَیَّامٍ﴾ أَوَّلهَا مِنْ صُبْح يَوْم الْأَرْبِعَاء لِثَمَانٍ بَقِينَ مِنْ شَوَّال وَكَانَتْ فِي عَجُز الشِّتَاء ﴿حُسُومࣰاۖ﴾ مُتَتَابِعَات شُبِّهَتْ بِتَتَابُعِ فِعْل الْحَاسِم فِي إعَادَة الْكَيّ عَلَى الدَّاء كَرَّة بَعْد أُخْرَى حَتَّى يَنْحَسِم ﴿فَتَرَى ٱلۡقَوۡمَ فِیهَا صَرۡعَىٰ﴾ مَطْرُوحِينَ هَالِكِينَ ﴿كَأَنَّهُمۡ أَعۡجَازُ﴾ أُصُول ﴿نَخۡلٍ خَاوِیَةࣲ ۝٧﴾ سَاقِطَة فارغة</p>"
        },
        "8": {
            "verses": {
                "69:8": {
                    "id": 8
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَهَلۡ تَرَىٰ لَهُم مِّنۢ بَاقِیَةࣲ ۝٨﴾ صفة نفس مقدرة أو التاء للمبالغة أي باق لا</p>"
        },
        "9": {
            "verses": {
                "69:9": {
                    "id": 9
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَجَاۤءَ فِرۡعَوۡنُ وَمَن قِبَلَهُۥ﴾ أَتْبَاعه وَفِي قِرَاءَة بِفَتْحِ الْقَاف وَسُكُون الْبَاء أَيْ مَنْ تَقَدَّمَهُ مِنْ الْأُمَم الْكَافِرَة ﴿وَٱلۡمُؤۡتَفِكَـٰتُ﴾ أَيْ أَهْلهَا وَهِيَ قُرَى قَوْم لُوط ﴿بِٱلۡخَاطِئَةِ ۝٩﴾ بِالْفِعْلَاتِ ذَات الْخَطَأ</p>"
        },
        "10": {
            "verses": {
                "69:10": {
                    "id": 10
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَعَصَوۡا۟ رَسُولَ رَبِّهِمۡ﴾ أَيْ لُوطًا وَغَيْره ﴿فَأَخَذَهُمۡ أَخۡذَةࣰ رَّابِیَةً ۝١٠﴾ زَائِدَة فِي الشِّدَّة عَلَى غَيْرهَا</p>"
        },
        "11": {
            "verses": {
                "69:11": {
                    "id": 11
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّا لَمَّا طَغَا ٱلۡمَاۤءُ﴾ عَلَا فَوْق كُلّ شَيْء مِنْ الْجِبَال وَغَيْرهَا زَمَن الطُّوفَان ﴿حَمَلۡنَـٰكُمۡ﴾ يَعْنِي آبَاءَكُمْ إذْ أَنْتُمْ فِي أَصْلَابهمْ ﴿فِی ٱلۡجَارِیَةِ ۝١١﴾ السَّفِينَة الَّتِي عَمِلَهَا نُوح وَنَجَا هُوَ وَمَنْ كَانَ مَعَهُ فِيهَا وَغَرِقَ الْآخَرُونَ</p>"
        },
        "12": {
            "verses": {
                "69:12": {
                    "id": 12
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿لِنَجۡعَلَهَا﴾ أَيْ هَذِهِ الْفَعْلَة وَهِيَ إنْجَاء الْمُؤْمِنِينَ وَإِهْلَاك الْكَافِرِينَ ﴿لَكُمۡ تَذۡكِرَةࣰ﴾ عِظَة ﴿وَتَعِیَهَاۤ﴾ وَلِتَحْفَظهَا ﴿أُذُنࣱ وَ ٰ⁠عِیَةࣱ ۝١٢﴾ حَافِظَة لِمَا تَسْمَع</p>"
        },
        "13": {
            "verses": {
                "69:13": {
                    "id": 13
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَإِذَا نُفِخَ فِی ٱلصُّورِ نَفۡخَةࣱ وَ ٰ⁠حِدَةࣱ ۝١٣﴾ لِلْفَصْلِ بَيْن الْخَلَائِق وَهِيَ الثَّانِيَة</p>"
        },
        "14": {
            "verses": {
                "69:14": {
                    "id": 14
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَحُمِلَتِ﴾ رفعت ﴿ٱلۡأَرۡضُ وَٱلۡجِبَالُ فَدُكَّتَا﴾ دقتا ﴿دَكَّةࣰ وَ ٰ⁠حِدَةࣰ ۝١٤﴾</p>"
        },
        "15": {
            "verses": {
                "69:15": {
                    "id": 15
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَیَوۡمَىِٕذࣲ وَقَعَتِ ٱلۡوَاقِعَةُ ۝١٥﴾ قَامَتْ الْقِيَامَة</p>"
        },
        "16": {
            "verses": {
                "69:16": {
                    "id": 16
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱنشَقَّتِ ٱلسَّمَاۤءُ فَهِیَ یَوۡمَىِٕذࣲ وَاهِیَةࣱ ۝١٦﴾ ضَعِيفَة</p>"
        },
        "17": {
            "verses": {
                "69:17": {
                    "id": 17
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلۡمَلَكُ﴾ يَعْنِي الْمَلَائِكَة ﴿عَلَىٰۤ أَرۡجَاۤىِٕهَاۚ﴾ جَوَانِب السَّمَاء ﴿وَیَحۡمِلُ عَرۡشَ رَبِّكَ فَوۡقَهُمۡ﴾ أَيْ الْمَلَائِكَة الْمَذْكُورِينَ ﴿یَوۡمَىِٕذࣲ ثَمَـٰنِیَةࣱ ۝١٧﴾ مِنْ الْمَلَائِكَة أَوْ مِنْ صُفُوفهمْ</p>"
        },
        "18": {
            "verses": {
                "69:18": {
                    "id": 18
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿یَوۡمَىِٕذࣲ تُعۡرَضُونَ﴾ لِلْحِسَابِ ﴿لَا تَخۡفَىٰ﴾ بِالتَّاءِ وَالْيَاء ﴿مِنكُمۡ خَافِیَةࣱ ۝١٨﴾ مِنْ السَّرَائِر</p>"
        },
        "19": {
            "verses": {
                "69:19": {
                    "id": 19
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَأَمَّا مَنۡ أُوتِیَ كِتَـٰبَهُۥ بِیَمِینِهِۦ فَیَقُولُ﴾ خِطَابًا لجماعته لما سر به ﴿هَاۤؤُمُ﴾ خذوا ﴿ٱقۡرَءُوا۟ كِتَـٰبِیَهۡ ۝١٩﴾ تَنَازَعَ فِيهِ {هَاۤؤُمُ} وَ{ٱقۡرَءُوا۟}</p>"
        },
        "20": {
            "verses": {
                "69:20": {
                    "id": 20
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿إِنِّی ظَنَنتُ﴾ تيقنت ﴿أَنِّی مُلَـٰقٍ حِسَابِیَهۡ ۝٢٠﴾</h2>"
        },
        "21": {
            "verses": {
                "69:21": {
                    "id": 21
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
