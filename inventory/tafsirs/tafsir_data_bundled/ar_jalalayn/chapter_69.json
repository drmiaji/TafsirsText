            },
            "text": "<p>﴿یَـٰلَیۡتَهَا﴾ أَيْ الْمَوْتَة فِي الدُّنْيَا ﴿كَانَتِ ٱلۡقَاضِیَةَ ۝٢٧﴾ القاطعة لحياتي بأن لا أبعث</p>"
        },
        "28": {
            "verses": {
                "69:28": {
                    "id": 28
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿مَاۤ أَغۡنَىٰ عَنِّی مَالِیَهۡۜ ۝٢٨﴾</h2>"
        },
        "29": {
            "verses": {
                "69:29": {
                    "id": 29
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿هَلَكَ عَنِّی سُلۡطَـٰنِیَهۡ ۝٢٩﴾ قُوَّتِي وَحُجَّتِي وَهَاء {كِتَـٰبِیَهۡ} وَ{حِسَابِیَهۡ} وَ{مَالِیَهۡۜ} وَ{سُلۡطَـٰنِیَهۡ} لِلسَّكْتِ تَثْبُت وَقْفًا وَوَصْلًا اتِّبَاعًا لِلْمُصْحَفِ الْإِمَام وَالنَّقْل وَمِنْهُمْ مَنْ حَذَفَهَا وصلا</p>"
        },
        "30": {
            "verses": {
                "69:30": {
                    "id": 30
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿خُذُوهُ﴾ خِطَاب لِخَزَنَةِ جَهَنَّم ﴿فَغُلُّوهُ ۝٣٠﴾ اجْمَعُوا يَدَيْهِ إلَى عُنُقه فِي الْغُلّ</p>"
        },
        "31": {
            "verses": {
                "69:31": {
                    "id": 31
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ ٱلۡجَحِیمَ﴾ النَّار الْمُحْرِقَة ﴿صَلُّوهُ ۝٣١﴾ أَدْخِلُوهُ</p>"
        },
        "32": {
            "verses": {
                "69:32": {
                    "id": 32
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ فِی سِلۡسِلَةࣲ ذَرۡعُهَا سَبۡعُونَ ذِرَاعࣰا﴾ بِذِرَاعِ الْمَلَك ﴿فَٱسۡلُكُوهُ ۝٣٢﴾ أَدْخِلُوهُ فِيهَا بَعْد إدْخَاله النَّار وَلَمْ تَمْنَع الْفَاء مِنْ تَعَلُّق الْفِعْل بِالظَّرْفِ الْمُتَقَدِّم</p>"
        },
        "33": {
            "verses": {
                "69:33": {
                    "id": 33
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿إِنَّهُۥ كَانَ لَا یُؤۡمِنُ بِٱللَّهِ ٱلۡعَظِیمِ ۝٣٣﴾</h2>"
        },
        "34": {
            "verses": {
                "69:34": {
                    "id": 34
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَلَا یَحُضُّ عَلَىٰ طَعَامِ ٱلۡمِسۡكِینِ ۝٣٤﴾</h2>"
        },
        "35": {
            "verses": {
                "69:35": {
                    "id": 35
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَلَیۡسَ لَهُ ٱلۡیَوۡمَ هَـٰهُنَا حَمِیمࣱ ۝٣٥﴾ قَرِيب يَنْتَفِع بِهِ</p>"
        },
        "36": {
            "verses": {
                "69:36": {
                    "id": 36
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَلَا طَعَامٌ إِلَّا مِنۡ غِسۡلِینࣲ ۝٣٦﴾ صَدِيد أَهْل النَّار أَوْ شَجَر فِيهَا</p>"
        },
        "37": {
            "verses": {
                "69:37": {
                    "id": 37
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿لَّا یَأۡكُلُهُۥۤ إِلَّا ٱلۡخَـٰطِـُٔونَ ۝٣٧﴾ الْكَافِرُونَ</p>"
        },
        "38": {
            "verses": {
                "69:38": {
                    "id": 38
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَلَاۤ﴾ زَائِدَة ﴿أُقۡسِمُ بِمَا تُبۡصِرُونَ ۝٣٨﴾ مِنْ الْمَخْلُوقَات</p>"
        },
        "39": {
            "verses": {
                "69:39": {
                    "id": 39
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَا لَا تُبۡصِرُونَ ۝٣٩﴾ مِنْهَا أَيْ بِكُلِّ مَخْلُوق</h2>"
        },
        "40": {
            "verses": {
                "69:40": {
                    "id": 40
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّهُۥ﴾ أَيْ الْقُرْآن ﴿لَقَوۡلُ رَسُولࣲ كَرِیمࣲ ۝٤٠﴾ أَيْ قاله رسالة عن الله تعالى</p>"
        },
        "41": {
            "verses": {
                "69:41": {
                    "id": 41
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَا هُوَ بِقَوۡلِ شَاعِرࣲۚ قَلِیلࣰا مَّا تُؤۡمِنُونَ ۝٤١﴾</p>"
        },
        "42": {
            "verses": {
                "69:42": {
                    "id": 42
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَلَا بِقَوۡلِ كَاهِنࣲۚ قَلِیلࣰا مَّا تَذَكَّرُونَ ۝٤٢﴾ بِالتَّاءِ وَالْيَاء فِي الْفِعْلَيْنِ وَمَا مَزِيدَة مُؤَكَّدَة وَالْمَعْنَى أَنَّهُمْ آمَنُوا بِأَشْيَاء يَسِيرَة وَتَذْكُرُوهَا مِمَّا أَتَى بِهِ النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ مِنْ الْخَيْر وَالصِّلَة وَالْعَفَاف فَلَمْ تُغْنِ عَنْهُمْ شَيْئًا</p>"
        },
        "43": {
            "verses": {
                "69:43": {
                    "id": 43
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>بَلْ هُوَ ﴿تَنزِیلࣱ مِّن رَّبِّ ٱلۡعَـٰلَمِینَ ۝٤٣﴾</h2>"
        },
        "44": {
            "verses": {
                "69:44": {
                    "id": 44
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَلَوۡ تَقَوَّلَ﴾ أَيْ النَّبِيّ ﴿عَلَیۡنَا بَعۡضَ ٱلۡأَقَاوِیلِ ۝٤٤﴾ بِأَنْ قَالَ عَنَّا مَا لَمْ نَقُلْهُ</p>"
        },
        "45": {
            "verses": {
                "69:45": {
                    "id": 45
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿لَأَخَذۡنَا﴾ لِنَلِنَا ﴿مِنۡهُ﴾ عِقَابًا ﴿بِٱلۡیَمِینِ ۝٤٥﴾ بِالْقُوَّةِ وَالْقُدْرَة</p>"
        },
        "46": {
            "verses": {
                "69:46": {
                    "id": 46
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ لَقَطَعۡنَا مِنۡهُ ٱلۡوَتِینَ ۝٤٦﴾ نِيَاط الْقَلْب وَهُوَ عِرْق مُتَّصِل بِهِ إذَا انْقَطَعَ مَاتَ صَاحِبه</p>"
        },
        "47": {
            "verses": {
                "69:47": {
                    "id": 47
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَمَا مِنكُم مِّنۡ أَحَدٍ﴾ هُوَ اسْم مَا ومِنْ زَائِدَة لِتَأْكِيدِ النَّفْي ومِنْكُمْ حَال مِنْ أَحَد ﴿عَنۡهُ حَـٰجِزِینَ ۝٤٧﴾ مَانِعِينَ خَبَر مَا وَجُمِعَ لِأَنَّ أَحَدًا فِي سِيَاق النَّفْي بِمَعْنَى الْجَمْع وَضَمِير عَنْهُ لِلنَّبِيِّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ أَيْ لَا مَانِع لَنَا عَنْهُ مِنْ حَيْثُ العقاب</p>"
        },
        "48": {
            "verses": {
                "69:48": {
                    "id": 48
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَإِنَّهُۥ﴾ أي القرآن ﴿لَتَذۡكِرَةࣱ لِّلۡمُتَّقِینَ ۝٤٨﴾</h2>"
        },
        "49": {
            "verses": {
                "69:49": {
                    "id": 49
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِنَّا لَنَعۡلَمُ أَنَّ مِنكُم﴾ أَيّهَا النَّاس ﴿مُّكَذِّبِینَ ۝٤٩﴾ بالقرآن ومصدقين</p>"
        },
        "50": {
            "verses": {
                "69:50": {
                    "id": 50
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِنَّهُۥ﴾ أَيْ الْقُرْآن ﴿لَحَسۡرَةٌ عَلَى ٱلۡكَـٰفِرِینَ ۝٥٠﴾ إذَا رَأَوْا ثَوَاب الْمُصَدِّقِينَ وَعِقَاب الْمُكَذِّبِينَ بِهِ</p>"
        },
        "51": {
            "verses": {
                "69:51": {
                    "id": 51
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِنَّهُۥ﴾ أَيْ الْقُرْآن ﴿لَحَقُّ ٱلۡیَقِینِ ۝٥١﴾ أَيْ الْيَقِين الحق</p>"
        },
        "52": {
            "verses": {
                "69:52": {
                    "id": 52
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَسَبِّحۡ﴾ نَزِّهْ ﴿بِٱسۡمِ﴾ الْبَاء زَائِدَة ﴿رَبِّكَ ٱلۡعَظِیمِ ۝٥٢﴾ سبحانه</p>"
        }
