            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿سَبِّحِ ٱسۡمَ رَبِّكَ﴾ أَيْ نَزِّهْ رَبّك عَمَّا لَا يَلِيق بِهِ وَاسْم زَائِد ﴿ٱلۡأَعۡلَى ۝١﴾ صِفَة لربك</p>"
        },
        "2": {
            "verses": {
                "87:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلَّذِی خَلَقَ فَسَوَّىٰ ۝٢﴾ مخلوقه وجعله مُتَنَاسِب الْأَجْزَاء غَيْر مُتَفَاوِت</p>"
        },
        "3": {
            "verses": {
                "87:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلَّذِی قَدَّرَ﴾ مَا شَاءَ ﴿فَهَدَىٰ ۝٣﴾ إِلَى مَا قَدَّرَهُ مِنْ خَيْر وَشَرّ</p>"
        },
        "4": {
            "verses": {
                "87:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَٱلَّذِیۤ أَخۡرَجَ ٱلۡمَرۡعَىٰ ۝٤﴾ أَنْبَتَ الْعُشْب</h2>"
        },
        "5": {
            "verses": {
                "87:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَجَعَلَهُۥ﴾ بَعْد الْخُضْرَة ﴿غُثَاۤءً﴾ جَافًّا هَشِيمًا ﴿أَحۡوَىٰ ۝٥﴾ أَسْوَد يَابِسًا</p>"
        },
        "6": {
            "verses": {
                "87:6": {
                    "id": 6
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿سَنُقۡرِئُكَ﴾ الْقُرْآن ﴿فَلَا تَنسَىٰۤ ۝٦﴾ مَا تَقْرَؤُهُ</h2>"
        },
        "7": {
            "verses": {
                "87:7": {
                    "id": 7
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِلَّا مَا شَاۤءَ ٱللَّهُۚ﴾ أَنْ تَنْسَاهُ بِنَسْخِ تِلَاوَته وَحُكْمه وَكَانَ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ يَجْهَر بِالْقِرَاءَةِ مَعَ قِرَاءَة جِبْرِيل خَوْف النِّسْيَان فَكَأَنَّهُ قِيلَ لَهُ لَا تَعْجَل بِهَا إِنَّك لَا تَنْسَى فَلَا تُتْعِب نَفْسك بِالْجَهْرِ بِهَا ﴿إِنَّهُۥ﴾ تَعَالَى ﴿یَعۡلَمُ ٱلۡجَهۡرَ﴾ مِنْ الْقَوْل وَالْفِعْل ﴿وَمَا یَخۡفَىٰ ۝٧﴾ مِنْهُمَا</p>"
        },
        "8": {
            "verses": {
                "87:8": {
                    "id": 8
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَنُیَسِّرُكَ لِلۡیُسۡرَىٰ ۝٨﴾ لِلشَّرِيعَةِ السَّهْلَة وَهِيَ الْإِسْلَام</p>"
        },
        "9": {
            "verses": {
                "87:9": {
                    "id": 9
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَذَكِّرۡ﴾ عِظْ بِالْقُرْآنِ ﴿إِن نَّفَعَتِ ٱلذِّكۡرَىٰ ۝٩﴾ مِنْ تَذْكِرَة الْمَذْكُور فِي سَيَذَّكَّرُ يَعْنِي وَإِنْ لَمْ تَنْفَع وَنَفْعهَا لِبَعْضٍ وَعَدَم النَّفْع لِبَعْضٍ آخَر</p>"
        },
        "10": {
            "verses": {
                "87:10": {
                    "id": 10
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿سَیَذَّكَّرُ﴾ بِهَا ﴿مَن یَخۡشَىٰ ۝١٠﴾ يَخَاف اللَّه تَعَالَى كآية فذكر بالقرآن من يخاف وعيد</p>"
        },
        "11": {
            "verses": {
                "87:11": {
                    "id": 11
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَیَتَجَنَّبُهَا﴾ أَيْ الذِّكْرَى أَيْ يَتْرُكهَا جَانِبًا لَا يَلْتَفِت إِلَيْهَا ﴿ٱلۡأَشۡقَى ۝١١﴾ بِمَعْنَى الشَّقِيّ أَيْ الْكَافِر</p>"
        },
        "12": {
            "verses": {
                "87:12": {
                    "id": 12
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلَّذِی یَصۡلَى ٱلنَّارَ ٱلۡكُبۡرَىٰ ۝١٢﴾ هِيَ نَار الْآخِرَة وَالصُّغْرَى نَار الدُّنْيَا</p>"
        },
        "13": {
            "verses": {
                "87:13": {
                    "id": 13
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ لَا یَمُوتُ فِیهَا﴾ فيستريح ﴿وَلَا یَحۡیَىٰ ۝١٣﴾ حياة هنيئة</p>"
        },
        "14": {
            "verses": {
                "87:14": {
                    "id": 14
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿قَدۡ أَفۡلَحَ﴾ فَازَ ﴿مَن تَزَكَّىٰ ۝١٤﴾ تَطَهَّرَ بِالْإِيمَانِ</p>"
        },
        "15": {
            "verses": {
                "87:15": {
                    "id": 15
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَذَكَرَ ٱسۡمَ رَبِّهِۦ﴾ مكبرا ﴿فَصَلَّىٰ ۝١٥﴾ الصلوات الْخَمْس وَذَلِكَ مِنْ أُمُور الْآخِرَة وَكَفَّار مَكَّة معرضون عنها</p>"
        },
        "16": {
            "verses": {
                "87:16": {
                    "id": 16
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿بَلۡ یُؤۡثِرُونَ﴾ بِالْفَوْقَانِيَّةِ وَالتَّحْتَانِيَّة ﴿ٱلۡحَیَوٰةَ ٱلدُّنۡیَا ۝١٦﴾ عَلَى الْآخِرَة</p>"
        },
        "17": {
            "verses": {
                "87:17": {
                    "id": 17
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلۡـَٔاخِرَةُ﴾ الْمُشْتَمِلَة عَلَى الْجَنَّة ﴿خَیۡرࣱ وَأَبۡقَىٰۤ ۝١٧﴾</p>"
        },
        "18": {
            "verses": {
                "87:18": {
                    "id": 18
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّ هَـٰذَا﴾ إفلاح من تزكى وكون الآخرة خيرا ﴿لَفِی ٱلصُّحُفِ ٱلۡأُولَىٰ ۝١٨﴾ أَيْ الْمُنَزَّلَة قَبْل الْقُرْآن</p>"
        },
        "19": {
            "verses": {
                "87:19": {
                    "id": 19
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿صُحُفِ إِبۡرَ ٰ⁠هِیمَ وَمُوسَىٰ ۝١٩﴾ وَهِيَ عَشْر صُحُف لِإِبْرَاهِيم والتوراة لموسى</p>"
        }
    }
}