            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿یَوۡمَ﴾ مَعْمُول لَوَاقِع ﴿تَمُورُ ٱلسَّمَاۤءُ مَوۡرࣰا ۝٩﴾ تَتَحَرَّك وتدور</p>"
        },
        "10": {
            "verses": {
                "52:10": {
                    "id": 10
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَتَسِیرُ ٱلۡجِبَالُ سَیۡرࣰا ۝١٠﴾ تَصِير هَبَاء مَنْثُورًا وَذَلِكَ فِي يَوْم الْقِيَامَة</p>"
        },
        "11": {
            "verses": {
                "52:11": {
                    "id": 11
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
