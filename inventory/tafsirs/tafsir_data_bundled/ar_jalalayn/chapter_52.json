            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَوَیۡلࣱ﴾ شدة عذاب ﴿یَوۡمَىِٕذࣲ لِّلۡمُكَذِّبِینَ ۝١١﴾ للرسل</p>"
        },
        "12": {
            "verses": {
                "52:12": {
                    "id": 12
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلَّذِینَ هُمۡ فِی خَوۡضࣲ﴾ بَاطِل ﴿یَلۡعَبُونَ ۝١٢﴾ أَيْ يَتَشَاغَلُونَ بِكُفْرِهِمْ</p>"
        },
        "13": {
            "verses": {
                "52:13": {
                    "id": 13
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿یَوۡمَ یُدَعُّونَ إِلَىٰ نَارِ جَهَنَّمَ دَعًّا ۝١٣﴾ يُدْفَعُونَ بِعُنْفٍ بَدَل مِنْ يَوْم تَمُور وَيُقَال لَهُمْ تَبْكِيتًا</p>"
        },
        "14": {
            "verses": {
                "52:14": {
                    "id": 14
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿هَـٰذِهِ ٱلنَّارُ ٱلَّتِی كُنتُم بِهَا تُكَذِّبُونَ ۝١٤﴾</h2>"
        },
        "15": {
            "verses": {
                "52:15": {
                    "id": 15
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَفَسِحۡرٌ هَـٰذَاۤ﴾ الْعَذَاب الَّذِي تَرَوْنَ كَمَا كُنْتُمْ تقولون في الوحي هذا سحر ﴿أَمۡ أَنتُمۡ لَا تُبۡصِرُونَ ۝١٥﴾</p>"
        },
        "16": {
            "verses": {
                "52:16": {
                    "id": 16
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ٱصۡلَوۡهَا فَٱصۡبِرُوۤا۟﴾ عَلَيْهَا ﴿أَوۡ لَا تَصۡبِرُوا۟﴾ صَبْركُمْ وَجَزَعكُمْ ﴿سَوَاۤءٌ عَلَیۡكُمۡۖ﴾ لِأَنَّ صَبْركُمْ لَا يَنْفَعكُمْ ﴿إِنَّمَا تُجۡزَوۡنَ مَا كُنتُمۡ تَعۡمَلُونَ ۝١٦﴾ أَيْ جَزَاءَهُ</p>"
        },
        "17": {
            "verses": {
                "52:17": {
                    "id": 17
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿إِنَّ ٱلۡمُتَّقِینَ فِی جَنَّـٰتࣲ وَنَعِیمࣲ ۝١٧﴾</h2>"
        },
        "18": {
            "verses": {
                "52:18": {
                    "id": 18
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَـٰكِهِینَ﴾ مُتَلَذِّذِينَ ﴿بِمَاۤ﴾ مَصْدَرِيَّة ﴿ءَاتَىٰهُمۡ﴾ أَعْطَاهُمْ ﴿رَبُّهُمۡ وَوَقَىٰهُمۡ رَبُّهُمۡ عَذَابَ ٱلۡجَحِیمِ ۝١٨﴾ عَطْفًا عَلَى آتَاهُمْ أَيْ بِإِتْيَانِهِمْ وَوِقَايَتهمْ وَيُقَال لَهُمْ</p>"
        },
        "19": {
            "verses": {
                "52:19": {
                    "id": 19
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿كُلُوا۟ وَٱشۡرَبُوا۟ هَنِیۤـَٔۢا﴾ حَال أَيْ مُهَنَّئِينَ ﴿بِمَا﴾ الباء سببية ﴿كُنتُمۡ تَعۡمَلُونَ ۝١٩﴾</p>"
        },
        "20": {
            "verses": {
                "52:20": {
                    "id": 20
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿مُتَّكِـِٔینَ﴾ حَال مِنْ الضَّمِير الْمُسْتَكِن فِي قَوْله {فِی جَنَّـٰتࣲ} ﴿عَلَىٰ سُرُرࣲ مَّصۡفُوفَةࣲۖ﴾ بَعْضهَا إلَى جَنْب بَعْض ﴿وَزَوَّجۡنَـٰهُم﴾ عُطِفَ عَلَى جَنَّات أَيْ قَرَنَّاهُمْ ﴿بِحُورٍ عِینࣲ ۝٢٠﴾ عِظَام الْأَعْيُن حِسَانهَا</p>"
        },
        "21": {
            "verses": {
                "52:21": {
                    "id": 21
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلَّذِینَ ءَامَنُوا۟﴾ مبتدأ ﴿وَأَتۡبَعۡنَـٰهُمۡ﴾ وَفِي قِرَاءَة {وَٱتَّبَعَتۡهُمۡ} مَعْطُوف عَلَى {ءَامَنُوا۟} ﴿ذُرِّیَّـٰتِهِم﴾ وَفِي قِرَاءَة {ذُرِّیَّتُهُم} الصِّغَار وَالْكِبَار ﴿بِإِیمَـٰنٍ﴾ مِنْ الكبار ومن أولادهم الصغار والخبر ﴿أَلۡحَقۡنَا بِهِمۡ ذُرِّیَّـٰتِهِمۡ﴾ الْمَذْكُورِينَ فِي الْجَنَّة فَيَكُونُونَ فِي دَرَجَتهمْ وَإِنْ لَمْ يَعْمَلُوا تَكْرِمَة لِلْآبَاءِ بِاجْتِمَاعِ الْأَوْلَاد إلَيْهِمْ ﴿وَمَاۤ أَلَتۡنَـٰهُم﴾ بِفَتْحِ اللَّام وَكَسْرهَا نَقَصْنَاهُمْ ﴿مِّنۡ عَمَلِهِم مِّن﴾ زَائِدَة ﴿شَیۡءࣲۚ﴾ يُزَاد فِي عَمَل الْأَوْلَاد ﴿كُلُّ ٱمۡرِىِٕۭ بِمَا كَسَبَ﴾ مِنْ عَمَلٍ خَيْر أَوْ شَرّ ﴿رَهِینࣱ ۝٢١﴾ مَرْهُون يُؤَاخَذ بِالشَّرِّ ويجازي بالخير</p>"
        },
        "22": {
            "verses": {
                "52:22": {
                    "id": 22
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَمۡدَدۡنَـٰهُم﴾ زِدْنَاهُمْ فِي وَقْت بَعْد وَقْت ﴿بِفَـٰكِهَةࣲ وَلَحۡمࣲ مِّمَّا یَشۡتَهُونَ ۝٢٢﴾ وَإِنْ لَمْ يُصَرِّحُوا بِطَلَبِهِ</p>"
        },
        "23": {
            "verses": {
                "52:23": {
                    "id": 23
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿یَتَنَـٰزَعُونَ﴾ يَتَعَاطَوْنَ بَيْنهمْ ﴿فِیهَا﴾ أَيْ الْجَنَّة ﴿كَأۡسࣰا﴾ خَمْرًا ﴿لَّا لَغۡوࣱ فِیهَا﴾ أَيْ بِسَبَبِ شُرْبهَا يَقَع بَيْنهمْ ﴿وَلَا تَأۡثِیمࣱ ۝٢٣﴾ بِهِ يَلْحَقهُمْ بِخِلَافِ خمر الدنيا</p>"
        },
        "24": {
            "verses": {
                "52:24": {
                    "id": 24
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَیَطُوفُ عَلَیۡهِمۡ﴾ لِلْخِدْمَةِ ﴿غِلۡمَانࣱ﴾ أَرِقَّاء ﴿لَّهُمۡ كَأَنَّهُمۡ﴾ حُسْنًا وَلَطَافَة ﴿لُؤۡلُؤࣱ مَّكۡنُونࣱ ۝٢٤﴾ مَصُون فِي الصَّدَف لِأَنَّهُ فِيهَا أَحْسَن مِنْهُ فِي غَيْرهَا</p>"
        },
        "25": {
            "verses": {
                "52:25": {
                    "id": 25
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَقۡبَلَ بَعۡضُهُمۡ عَلَىٰ بَعۡضࣲ یَتَسَاۤءَلُونَ ۝٢٥﴾ يَسْأَل بَعْضهمْ بَعْضًا عَمَّا كَانُوا عَلَيْهِ وَمَا وَصَلُوا إلَيْهِ تَلَذُّذًا وَاعْتِرَافًا بِالنِّعْمَةِ</p>"
        },
        "26": {
            "verses": {
                "52:26": {
                    "id": 26
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿قَالُوۤا۟﴾ إيمَاء إلَى عِلَّة الْوُصُول ﴿إِنَّا كُنَّا قَبۡلُ فِیۤ أَهۡلِنَا﴾ فِي الدُّنْيَا ﴿مُشۡفِقِینَ ۝٢٦﴾ خَائِفِينَ مِنْ عَذَاب اللَّه</p>"
        },
        "27": {
            "verses": {
