            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَمَنَّ ٱللَّهُ عَلَیۡنَا﴾ بِالْمَغْفِرَةِ ﴿وَوَقَىٰنَا عَذَابَ ٱلسَّمُومِ ۝٢٧﴾ النَّار لِدُخُولِهَا فِي الْمَسَامّ وَقَالُوا إيمَاء أَيْضًا</p>"
        },
        "28": {
            "verses": {
                "52:28": {
                    "id": 28
