            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّ عَذَابَ رَبِّكَ لَوَ ٰ⁠قِعࣱ ۝٧﴾ لَنَازِل بِمُسْتَحِقِّهِ</p>"
        },
        "8": {
            "verses": {
