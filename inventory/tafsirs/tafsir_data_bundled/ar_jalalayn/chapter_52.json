            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَلۡیَأۡتُوا۟ بِحَدِیثࣲ﴾ مُخْتَلَق ﴿مِّثۡلِهِۦۤ إِن كَانُوا۟ صَـٰدِقِینَ ۝٣٤﴾ في قولهم</p>"
        },
        "35": {
