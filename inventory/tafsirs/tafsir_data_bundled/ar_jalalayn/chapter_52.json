            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَٱلسَّقۡفِ ٱلۡمَرۡفُوعِ ۝٥﴾ أَيْ السَّمَاء</h2>"
        },
        "6": {
