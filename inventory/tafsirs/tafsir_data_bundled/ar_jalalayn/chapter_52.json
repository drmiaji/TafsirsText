            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿قُلۡ تَرَبَّصُوا۟﴾ هَلَاكِي ﴿فَإِنِّی مَعَكُم مِّنَ ٱلۡمُتَرَبِّصِینَ ۝٣١﴾ هَلَاككُمْ فَعُذِّبُوا بِالسَّيْفِ يَوْم بَدْر وَالتَّرَبُّص الِانْتِظَار</p>"
        },
        "32": {
            "verses": {
                "52:32": {
                    "id": 32
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَمۡ تَأۡمُرُهُمۡ أَحۡلَـٰمُهُم﴾ عُقُولهمْ ﴿بِهَـٰذَاۤۚ﴾ قَوْلهمْ لَهُ سَاحِر كَاهِن مَجْنُون أَيْ لَا تَأْمُرهُمْ بِذَلِكَ ﴿أَمۡ﴾ بَلْ ﴿هُمۡ قَوۡمࣱ طَاغُونَ ۝٣٢﴾ بِعِنَادِهِمْ</p>"
        },
        "33": {
            "verses": {
                "52:33": {
                    "id": 33
