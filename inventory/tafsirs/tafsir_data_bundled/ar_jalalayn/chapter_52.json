            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿مَّا لَهُۥ مِن دَافِعࣲ ۝٨﴾ عَنْهُ</h2>"
        },
        "9": {
            "verses": {
                "52:9": {
                    "id": 9
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
