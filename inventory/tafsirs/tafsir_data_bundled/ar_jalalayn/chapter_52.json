            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَمۡ تَسۡـَٔلُهُمۡ أَجۡرࣰا﴾ على ما جئتهم بِهِ مِنْ الدِّين ﴿فَهُم مِّن مَّغۡرَمࣲ﴾ غُرْم ذَلِكَ ﴿مُّثۡقَلُونَ ۝٤٠﴾ فَلَا يُسْلِمُونَ</p>"
        },
        "41": {
            "verses": {
                "52:41": {
                    "id": 41
