                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَٱلۡبَحۡرِ ٱلۡمَسۡجُورِ ۝٦﴾ أَيْ الْمَمْلُوء</h2>"
        },
        "7": {
            "verses": {
