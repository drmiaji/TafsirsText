            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّا كُنَّا مِن قَبۡلُ﴾ أَيْ فِي الدُّنْيَا ﴿نَدۡعُوهُۖ﴾ نَعْبُدهُ مُوَحِّدِينَ ﴿إِنَّهُۥ﴾ بِالْكَسْرِ اسْتِئْنَافًا وَإِنْ كَانَ تَعْلِيلًا مَعْنَى وَبِالْفَتْحِ تَعْلِيلًا لَفْظًا ﴿هُوَ ٱلۡبَرُّ﴾ الْمُحْسِن الصَّادِق فِي وَعْده ﴿ٱلرَّحِیمُ ۝٢٨﴾ الْعَظِيم الرحمة</p>"
        },
        "29": {
            "verses": {
