            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَمۡ عِندَهُمۡ خَزَاۤىِٕنُ رَبِّكَ﴾ مِنْ النُّبُوَّة وَالرِّزْق وَغَيْرهمَا فَيَخُصُّوا مَنْ شَاءُوا بِمَا شَاءُوا ﴿أَمۡ هُمُ ٱلۡمُصَۣیۡطِرُونَ﴾ الْمُتَسَلِّطُونَ الْجَبَّارُونَ وَفِعْله سَيْطَرَ وَمِثْله بيطر وبيقر</p>"
        },
        "38": {
            "verses": {
