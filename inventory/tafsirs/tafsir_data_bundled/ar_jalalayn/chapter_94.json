            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَلَمۡ نَشۡرَحۡ﴾ إستفهام تقرر أَيْ شَرَحْنَا ﴿لَكَ﴾ يَا مُحَمَّد ﴿صَدۡرَكَ ۝١﴾ بِالنُّبُوَّةِ وغيرها</p>"
        },
        "2": {
            "verses": {
                "94:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَوَضَعۡنَا﴾ حَطَطْنَا ﴿عَنكَ وِزۡرَكَ ۝٢﴾</h2>"
        },
        "3": {
            "verses": {
                "94:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلَّذِیۤ أَنقَضَ﴾ أَثْقَل ﴿ظَهۡرَكَ ۝٣﴾ وَهَذَا كَقَوْلِهِ تَعَالَى {لِّیَغۡفِرَ لَكَ ٱللَّهُ مَا تَقَدَّمَ مِن ذَنۢبِكَ}</p>"
        },
        "4": {
            "verses": {
                "94:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَرَفَعۡنَا لَكَ ذِكۡرَكَ ۝٤﴾ بِأَنْ تُذْكَر مَعَ ذِكْرِي فِي الْأَذَان وَالْإِقَامَة وَالتَّشَهُّد وَالْخُطْبَة وَغَيْرهَا</p>"
        },
        "5": {
            "verses": {
                "94:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿فَإِنَّ مَعَ ٱلۡعُسۡرِ﴾ الشِّدَّة ﴿یُسۡرًا ۝٥﴾ سُهُولَة</h2>"
        },
        "6": {
            "verses": {
                "94:6": {
                    "id": 6
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّ مَعَ ٱلۡعُسۡرِ یُسۡرࣰا ۝٦﴾ وَالنَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ قَاسَى مِنْ الْكُفَّار شِدَّة ثُمَّ حَصَلَ لَهُ الْيُسْر بِنَصْرِهِ عَلَيْهِمْ</p>"
        },
        "7": {
            "verses": {
                "94:7": {
                    "id": 7
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَإِذَا فَرَغۡتَ﴾ مِنْ الصَّلَاة ﴿فَٱنصَبۡ ۝٧﴾ اِتْعَبْ فِي الدعاء</p>"
        },
        "8": {
            "verses": {
                "94:8": {
                    "id": 8
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَإِلَىٰ رَبِّكَ فَٱرۡغَب ۝٨﴾ تضرع</h2>"
        }
    }
}