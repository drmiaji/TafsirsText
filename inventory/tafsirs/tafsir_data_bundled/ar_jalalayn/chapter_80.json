            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَأُمِّهِۦ وَأَبِیهِ ۝٣٥﴾</h2>"
        },
        "36": {
            "verses": {
                "80:36": {
                    "id": 36
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَصَـٰحِبَتِهِۦ﴾ زَوْجَته ﴿وَبَنِیهِ ۝٣٦﴾ يَوْم بَدَل مِنْ إِذَا وجوابها دل عليها</p>"
        },
        "37": {
            "verses": {
                "80:37": {
                    "id": 37
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿لِكُلِّ ٱمۡرِئࣲ مِّنۡهُمۡ یَوۡمَىِٕذࣲ شَأۡنࣱ یُغۡنِیهِ ۝٣٧﴾ حَال يَشْغَلهُ عَنْ شَأْن غَيْره أَيْ اِشْتَغَلَ كُلّ واحد بنفسه</p>"
        },
        "38": {
            "verses": {
                "80:38": {
                    "id": 38
                }
            },
