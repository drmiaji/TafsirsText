            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿مَّتَـٰعࣰا﴾ مُتْعَة أَوْ تَمْتِيعًا كَمَا تَقَدَّمَ فِي السُّورَة قَبْلهَا ﴿لَّكُمۡ وَلِأَنۡعَـٰمِكُمۡ ۝٣٢﴾ تَقَدَّمَ فِيهَا أَيْضًا</p>"
        },
        "33": {
            "verses": {
                "80:33": {
                    "id": 33
                }
            },
