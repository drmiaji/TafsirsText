            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أُو۟لَـٰۤىِٕكَ﴾ أَهْل هَذِهِ الْحَالَة ﴿هُمُ ٱلۡكَفَرَةُ ٱلۡفَجَرَةُ ۝٤٢﴾ أي الجامعون بين الكفر والفجور</p>"
        }
