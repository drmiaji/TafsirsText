            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ضَاحِكَةࣱ مُّسۡتَبۡشِرَةࣱ ۝٣٩﴾ فَرِحَة وَهُمْ الْمُؤْمِنُونَ</p>"
        },
        "40": {
            "verses": {
