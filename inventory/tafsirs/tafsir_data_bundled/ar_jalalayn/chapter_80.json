            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿تَرۡهَقُهَا﴾ تَغْشَاهَا ﴿قَتَرَةٌ ۝٤١﴾ ظُلْمَة وَسَوَاد</h2>"
        },
        "42": {
