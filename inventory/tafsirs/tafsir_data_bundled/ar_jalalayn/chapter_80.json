                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿عَبَسَ﴾ النَّبِيّ كَلَحَ وَجْهه ﴿وَتَوَلَّىٰۤ ۝١﴾ أَعْرَضَ لِأَجْلِ</p>"
        },
        "2": {
            "verses": {
                "80:2": {
                    "id": 2
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَن جَاۤءَهُ ٱلۡأَعۡمَىٰ ۝٢﴾ عَبْد اللَّه بْن أُمّ مَكْتُوم فَقَطَعَهُ عَمَّا هُوَ مَشْغُول بِهِ مِمَّنْ يَرْجُو إِسْلَامه مِنْ أَشْرَاف قُرَيْش الَّذِينَ هُوَ حَرِيص عَلَى إِسْلَامهمْ وَلَمْ يَدْرِ الْأَعْمَى أَنَّهُ مَشْغُول بِذَلِكَ فَنَادَاهُ عَلِّمْنِي مِمَّا عَلَّمَك اللَّه فَانْصَرَفَ النَّبِيّ صَلَّى اللَّه عَلَيْهِ وَسَلَّمَ إِلَى بَيْته فَعُوتِبَ فِي ذَلِكَ بِمَا نَزَلَ فِي هَذِهِ السُّورَة فَكَانَ بَعْد ذَلِكَ يَقُول لَهُ إِذَا جَاءَ مَرْحَبًا بِمَنْ عَاتَبَنِي فِيهِ رَبِّي وَيَبْسُط لَهُ رِدَاءَهُ</p>"
        },
        "3": {
            "verses": {
                "80:3": {
                    "id": 3
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَا یُدۡرِیكَ﴾ يُعْلِمك ﴿لَعَلَّهُۥ یَزَّكَّىٰۤ ۝٣﴾ فِيهِ إِدْغَام التَّاء فِي الْأَصْل فِي الزَّاي أَيْ يَتَطَهَّر مِنْ الذُّنُوب بِمَا يَسْمَع مِنْك</p>"
        },
        "4": {
            "verses": {
                "80:4": {
                    "id": 4
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿أَوۡ یَذَّكَّرُ﴾ فِيهِ إدْغَام التَّاء فِي الْأَصْل فِي الذَّال أَيْ يَتَّعِظ ﴿فَتَنفَعُهُ ٱلذِّكۡرَىٰۤ ۝٤﴾ الْعِظَة الْمَسْمُوعَة مِنْك وَفِي قِرَاءَة بِنَصْبِ {تَنفَعَهُ} جَوَاب الترجي</p>"
        },
        "5": {
            "verses": {
                "80:5": {
                    "id": 5
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿أَمَّا مَنِ ٱسۡتَغۡنَىٰ ۝٥﴾ بِالْمَالِ</h2>"
        },
        "6": {
            "verses": {
                "80:6": {
                    "id": 6
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَأَنتَ لَهُۥ تَصَدَّىٰ ۝٦﴾ وَفِي قِرَاءَة بِتَشْدِيدِ الصَّاد بِإِدْغَامِ التَّاء الثَّانِيَة فِي الْأَصْل فِيهَا تُقْبِل وتتعرض</p>"
        },
        "7": {
            "verses": {
                "80:7": {
                    "id": 7
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَا عَلَیۡكَ أَلَّا یَزَّكَّىٰ ۝٧﴾ يُؤْمِن</h2>"
        },
        "8": {
            "verses": {
                "80:8": {
                    "id": 8
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَأَمَّا مَن جَاۤءَكَ یَسۡعَىٰ ۝٨﴾ حَال مِنْ فَاعِل جاء</h2>"
        },
        "9": {
            "verses": {
                "80:9": {
                    "id": 9
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَهُوَ یَخۡشَىٰ ۝٩﴾ اللَّه حَال مِنْ فَاعِل يَسْعَى وهو الأعمى</p>"
        },
        "10": {
            "verses": {
                "80:10": {
                    "id": 10
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَأَنتَ عَنۡهُ تَلَهَّىٰ ۝١٠﴾ فِيهِ حَذْف التَّاء الْأُخْرَى فِي الْأَصْل أَيْ تَتَشَاغَل</p>"
        },
        "11": {
            "verses": {
                "80:11": {
                    "id": 11
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿كَلَّاۤ﴾ لَا تَفْعَل مِثْل ذَلِكَ ﴿إِنَّهَا﴾ أَيْ السُّورَة أَوْ الْآيَات ﴿تَذۡكِرَةࣱ ۝١١﴾ عِظَة لِلْخَلْقِ</p>"
        },
        "12": {
            "verses": {
                "80:12": {
                    "id": 12
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿فَمَن شَاۤءَ ذَكَرَهُۥ ۝١٢﴾ حَفِظَ ذَلِكَ فَاتَّعَظَ بِهِ</h2>"
        },
        "13": {
            "verses": {
                "80:13": {
                    "id": 13
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فِی صُحُفࣲ﴾ خَبَر ثَانٍ لِأَنَّهَا وَمَا قَبْله اِعْتِرَاض ﴿مُّكَرَّمَةࣲ ۝١٣﴾ عِنْد اللَّه</p>"
        },
        "14": {
            "verses": {
                "80:14": {
                    "id": 14
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿مَّرۡفُوعَةࣲ﴾ فِي السَّمَاء ﴿مُّطَهَّرَةِۭ ۝١٤﴾ مُنَزَّهَة عَنْ مَسّ الشياطين</p>"
        },
        "15": {
            "verses": {
                "80:15": {
                    "id": 15
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿بِأَیۡدِی سَفَرَةࣲ ۝١٥﴾ كَتَبَة يَنْسَخُونَهَا مِنْ اللَّوْح الْمَحْفُوظ</p>"
        },
        "16": {
            "verses": {
                "80:16": {
                    "id": 16
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿كِرَامِۭ بَرَرَةࣲ ۝١٦﴾ مُطِيعِينَ لِلَّهِ تَعَالَى وَهُمْ الْمَلَائِكَة</p>"
        },
        "17": {
            "verses": {
                "80:17": {
                    "id": 17
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿قُتِلَ ٱلۡإِنسَـٰنُ﴾ لُعِنَ الْكَافِر ﴿مَاۤ أَكۡفَرَهُۥ ۝١٧﴾ اِسْتِفْهَام تَوْبِيخ أَيْ مَا حَمَلَهُ عَلَى الْكُفْر</p>"
        },
        "18": {
            "verses": {
                "80:18": {
                    "id": 18
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿مِنۡ أَیِّ شَیۡءٍ خَلَقَهُۥ ۝١٨﴾ اِسْتِفْهَام تَقْرِير ثُمَّ بينه فقال</p>"
        },
        "19": {
            "verses": {
                "80:19": {
                    "id": 19
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿مِن نُّطۡفَةٍ خَلَقَهُۥ فَقَدَّرَهُۥ ۝١٩﴾ عَلَقَة ثُمَّ مُضْغَة إِلَى آخِر خَلْقه</p>"
        },
        "20": {
            "verses": {
                "80:20": {
                    "id": 20
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ ٱلسَّبِیلَ﴾ أَيْ طَرِيق خُرُوجه مِنْ بَطْن أمه ﴿یَسَّرَهُۥ ۝٢٠﴾</p>"
        },
        "21": {
            "verses": {
                "80:21": {
                    "id": 21
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ أَمَاتَهُۥ فَأَقۡبَرَهُۥ ۝٢١﴾ جَعَلَهُ فِي قَبْر يَسْتُرهُ</p>"
        },
        "22": {
            "verses": {
                "80:22": {
                    "id": 22
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿ثُمَّ إِذَا شَاۤءَ أَنشَرَهُۥ ۝٢٢﴾ لِلْبَعْثِ</h2>"
        },
        "23": {
            "verses": {
                "80:23": {
                    "id": 23
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿كَلَّا﴾ حَقًّا ﴿لَمَّا یَقۡضِ﴾ لَمْ يَفْعَل ﴿مَاۤ أَمَرَهُۥ ۝٢٣﴾ بِهِ رَبّه</p>"
        },
        "24": {
            "verses": {
                "80:24": {
                    "id": 24
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿فَلۡیَنظُرِ ٱلۡإِنسَـٰنُ﴾ نَظَر اِعْتِبَار ﴿إِلَىٰ طَعَامِهِۦۤ ۝٢٤﴾ كَيْف قُدِّرَ وَدُبِّرَ لَهُ</p>"
        },
        "25": {
            "verses": {
                "80:25": {
                    "id": 25
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
            "language_id": 38,
            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿أَنَّا صَبَبۡنَا ٱلۡمَاۤءَ﴾ مِنْ السَّحَاب ﴿صَبࣰّا ۝٢٥﴾</h2>"
        },
        "26": {
            "verses": {
                "80:26": {
                    "id": 26
                }
