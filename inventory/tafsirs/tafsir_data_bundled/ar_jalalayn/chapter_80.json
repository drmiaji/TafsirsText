            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿ثُمَّ شَقَقۡنَا ٱلۡأَرۡضَ﴾ بِالنَّبَاتِ ﴿شَقࣰّا ۝٢٦﴾</h2>"
        },
        "27": {
            "verses": {
                "80:27": {
                    "id": 27
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
