            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وُجُوهࣱ یَوۡمَىِٕذࣲ مُّسۡفِرَةࣱ ۝٣٨﴾ مُضِيئَة</h2>"
        },
        "39": {
            "verses": {
                "80:39": {
                    "id": 39
                }
