            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَحَدَاۤىِٕقَ غُلۡبࣰا ۝٣٠﴾ بَسَاتِين كَثِيرَة الْأَشْجَار</h2>"
        },
        "31": {
            "verses": {
                "80:31": {
                    "id": 31
                }
            },
