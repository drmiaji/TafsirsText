            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿فَأَنۢبَتۡنَا فِیهَا حَبࣰّا ۝٢٧﴾ كَالْحِنْطَةِ وَالشَّعِير</h2>"
        },
        "28": {
            "verses": {
