            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿وَعِنَبࣰا وَقَضۡبࣰا ۝٢٨﴾ هُوَ الْقَتّ الرَّطْب</h2>"
        },
        "29": {
            "verses": {
