            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿یَوۡمَ یَفِرُّ ٱلۡمَرۡءُ مِنۡ أَخِیهِ ۝٣٤﴾</h2>"
        },
        "35": {
            "verses": {
                "80:35": {
                    "id": 35
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
