            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<p>﴿وَفَـٰكِهَةࣰ وَأَبࣰّا ۝٣١﴾ مَا تَرْعَاهُ الْبَهَائِم وَقِيلَ التِّبْن</p>"
        },
        "32": {
