            "slug": "ar_jalalayn",
            "translated_name": {
                "name": "Tafsir Ar Jalalayn",
                "language_name": "english"
            },
            "text": "<h2>﴿فَإِذَا جَاۤءَتِ ٱلصَّاۤخَّةُ ۝٣٣﴾ النفخة الثانية</h2>"
        },
        "34": {
            "verses": {
                "80:34": {
                    "id": 34
                }
            },
            "resource_id": 106,
            "resource_name": "Tafsir Ar Jalalayn",
