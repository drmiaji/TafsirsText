{
    "chapter": 107,
    "verses": {
        "1": {
            "verses": {
                "107:1": {
                    "id": 1
                }
            },
            "resource_id": 142,
            "resource_name": "Tafsir Tl Mokhtasar",
            "language_id": 38,
            "slug": "tl_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tl Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Nakakilala ka ba sa nagpapasinungaling sa pagganti sa Araw ng Pagbangon?</p>"
        },
        "2": {
            "verses": {
                "107:2": {
                    "id": 2
                }
            },
            "resource_id": 142,
            "resource_name": "Tafsir Tl Mokhtasar",
            "language_id": 38,
            "slug": "tl_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tl Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Sapagkat siya ay yaong tumutulak sa ulila nang may kagaspangan palayo sa pangangailangan nito,</p>"
        },
        "3": {
            "verses": {
                "107:3": {
                    "id": 3
                }
            },
            "resource_id": 142,
            "resource_name": "Tafsir Tl Mokhtasar",
            "language_id": 38,
            "slug": "tl_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tl Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>at hindi nag-uudyok sa sarili niya at hindi nag-uudyok sa iba sa kanya sa pagpapakain sa maralita.</p>"
        },
        "4": {
            "verses": {
                "107:4": {
                    "id": 4
                }
            },
            "resource_id": 142,
            "resource_name": "Tafsir Tl Mokhtasar",
            "language_id": 38,
            "slug": "tl_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tl Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>Kaya kapahamakan at pagdurusa ay ukol sa mga tagapagdasal,</h2>"
        },
        "5": {
            "verses": {
                "107:5": {
                    "id": 5
                }
            },
            "resource_id": 142,
            "resource_name": "Tafsir Tl Mokhtasar",
            "language_id": 38,
            "slug": "tl_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tl Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>na sila sa pagdarasal nila ay mga naglilibang, hindi pumapansin dito hanggang sa matapos ang oras nito,</p>"
        },
        "6": {
            "verses": {
                "107:6": {
                    "id": 6
                }
            },
            "resource_id": 142,
            "resource_name": "Tafsir Tl Mokhtasar",
            "language_id": 38,
            "slug": "tl_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tl Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>na sila ay nagpapakitang-tao sa pagdarasal nila at mga gawa nila: hindi nagpapakawagas ng gawain nila para kay Allāh,</p>"
        },
        "7": {
            "verses": {
                "107:7": {
                    "id": 7
                }
            },
            "resource_id": 142,
            "resource_name": "Tafsir Tl Mokhtasar",
            "language_id": 38,
            "slug": "tl_mokhtasar",
            "translated_name": {
                "name": "Tafsir Tl Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>at nagkakait ng pagtulong sa iba pa sa kanila ng bagay na walang kapinsalaan sa pagtulong sa pamamagitan nito.</p>"
        }
    }
}