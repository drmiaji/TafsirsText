            "translated_name": {
                "name": "Tafsir Tl Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>at hindi ako sasamba sa sinamba ninyo na mga anito,</h2>"
        },
        "5": {
            "verses": {
