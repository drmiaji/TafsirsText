{
    "chapter": 82,
    "verses": {
        "1": {
            "verses": {
                "82:1": {
                    "id": 1
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>১. যখন আসমান থেকে ফিরিশতাদের অবতরণের ফলে তা বিদীর্ণ হবে।</h2>"
        },
        "2": {
            "verses": {
                "82:2": {
                    "id": 2
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>২. যখন নক্ষত্ররাজি বিক্ষিপ্তভাবে ঝরে পড়বে।</h2>"
        },
        "3": {
            "verses": {
                "82:3": {
                    "id": 3
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>৩. যখন সমুদ্রগুলোকে একটির উপর অপরটিকে খুলে দেয়ার ফলে উদ্বেলিত হবে।</p>"
        },
        "4": {
            "verses": {
                "82:4": {
                    "id": 4
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>৪. যখন মৃতদেরকে পুনরুত্থান দেয়ার ফলে কবরের মাটি উলট-পালট হবে।</p>"
        },
        "5": {
            "verses": {
                "82:5": {
                    "id": 5
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>৫. তখন সবাই জানতে পারবে যে, সে পূর্বে কী আমল প্রেরণ করেছে। আর পেছনে কী আমল ছেড়ে এসেছে।</p>"
        },
        "6": {
            "verses": {
                "82:6": {
                    "id": 6
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>৬. হে রবকে অস্বীকারকারী মানুষ! কোন্ বস্তু তোমাকে তোমার সেই মহামহিম রবের নির্দেশ লঙ্ঘন করতে বাধ্য করলো। যখন তিনি অনুগ্রহপূর্বক তোমাকে পাকড়াও না করে অবকাশ দিলেন?!</p>"
        },
        "7": {
            "verses": {
                "82:7": {
                    "id": 7
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>৭. যিনি তোমাকে অনস্তিত্ব থেকে অস্তিত্বে এনেছেন এবং তোমাকে সুবিন্যস্ত ও সুসামঞ্জস্য করেছেন।</p>"
        },
        "8": {
            "verses": {
                "82:8": {
                    "id": 8
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>৮. তিনি নিজ পছন্দসই আকৃতিতে তোমাকে সৃষ্টি করেছেন এবং তিনি তোমাকে গাধা, বানর কিংবা কুকুর প্রভৃতির আকৃতিতে না বানিয়ে তোমার উপর অনুগ্রহ করেছেন।</p>"
        },
        "9": {
            "verses": {
                "82:9": {
                    "id": 9
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>৯. হে ধোকাগ্রস্তরা! ব্যাপারটি তোমরা যেমন ধারণা করেছো তেমন নয়। বরং তোমরা পরকাল দিবস সস্পর্কে বিশ্বাস রাখো না বিধায় তোমরা এর উদ্দেশ্যে আমল করো না।</p>"
        },
        "10": {
            "verses": {
                "82:10": {
                    "id": 10
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>১০. অবশ্যই তোমাদের উপর সংরক্ষক ফিরিশতাগণ নিযুক্ত রয়েছেন।</h2>"
        },
        "11": {
            "verses": {
                "82:11": {
                    "id": 11
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>১১. তাঁরা আল্লাহর নিকট সম্মানিত। তাঁরা তোমাদের আমলসমূহ লিপিবদ্ধ করেন।</p>"
        },
        "12": {
            "verses": {
                "82:12": {
                    "id": 12
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>১২. তোমরা যা করো তারা তা জানার ভিত্তিতেই লিপিবদ্ধ করে।</h2>"
        },
        "13": {
            "verses": {
                "82:13": {
                    "id": 13
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>১৩. নিশ্চয়ই যারা বেশী বেশী পুণ্য ও আনুগত্যের কাজ করে তারা কিয়ামত দিবসে স্থায়ী উপভোগে থাকবে।</p>"
        },
        "14": {
            "verses": {
                "82:14": {
                    "id": 14
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>১৪. পক্ষান্তরে পাপীরা প্রজ্জ্বলিত আগুনে থাকবে।</h2>"
        },
        "15": {
            "verses": {
                "82:15": {
                    "id": 15
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>১৫. তারা প্রতিদান দিবসে তাতে প্রবেশ করবে এবং এর উত্তাপ আস্বাদন করবে।</p>"
        },
        "16": {
            "verses": {
                "82:16": {
                    "id": 16
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>১৬. তারা সেখান থেকে বের হবে না। বরং তারা তথায় চিরকাল অবস্থান করবে।</p>"
        },
        "17": {
            "verses": {
                "82:17": {
                    "id": 17
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>১৭. হে রাসূল! আপনি কি জানেন, বিচার দিবস কী?!</h2>"
        },
        "18": {
            "verses": {
                "82:18": {
                    "id": 18
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>১৮. আবার বলছি! আপনি কি জানেন, বিচার দিবস কী?!</h2>"
        },
        "19": {
            "verses": {
                "82:19": {
                    "id": 19
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>১৯. সে দিন কেউ কারো উপকার করতে সক্ষম হবে না। বরং সে দিনের সকল কর্তৃত্ব হবে কেবল আল্লাহর। তিনি সে দিন তাঁর ইচ্ছা মাফিক তসরুপ করবেন।</p>"
        }
    }
}