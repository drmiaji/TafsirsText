            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>১. হে রাসূল! যখন আপনার দীনের জন্য আল্লাহর সাহায্য-সহযোগিতা আসবে এবং সেই সাথে আসবে মক্কা বিজয়।</p>"
        },
        "2": {
            "verses": {
                "110:2": {
                    "id": 2
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>২. উপরন্তু আপনি যখন লোকদেরকে দলে দলে ইসলামে প্রবেশ করতে দেখবেন।</p>"
        },
        "3": {
            "verses": {
                "110:3": {
                    "id": 3
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>৩. তখন আপনি জেনে নিবেন যে, এটি আপনার সাথে আগত মিশনের পরিসমাপ্তির প্রতি ইঙ্গিত। তাই আপনি নিজ প্রতিপালকের পক্ষ থেকে প্রাপ্ত সাহায্য ও বিজয়ের নিআমতের শুকরিয়া স্বরূপ তাঁর প্রশংসাজড়িত পবিত্রতা বর্ণনা করুন এবং তাঁর নিকট ক্ষমা চান। নিশ্চয়ই তিনি অধিকহারে তাওবা কবুলকারী। তিনি তাঁর বান্দাদের তাওবা কবুল করেন ও তাদেরকে ক্ষমা করেন।</p>"
        }
    }
}