            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>৪১. সেগুলোকে কালিমা অচ্ছন্ন করবে।</h2>"
        },
        "42": {
            "verses": {
                "80:42": {
                    "id": 42
                }
