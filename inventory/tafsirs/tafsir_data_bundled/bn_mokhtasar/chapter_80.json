            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>৩৫. তেমনিভাবে তার মাতা-পিতা থেকে।</h2>"
        },
        "36": {
            "verses": {
                "80:36": {
                    "id": 36
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
