            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>৩৯. আল্লাহ তাদের উদ্দেশ্যে যে সব রহমত প্রস্তুত রেখেছেন এর ফলে সহাস্য ও প্রফুল্ল।</p>"
        },
        "40": {
            "verses": {
                "80:40": {
                    "id": 40
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
