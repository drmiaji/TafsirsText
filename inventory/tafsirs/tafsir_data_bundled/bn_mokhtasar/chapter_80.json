            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>৪০. পক্ষান্তরে হতভাগাদের চেহারা সে দিন হবে ধূলায় ধূসরিত।</h2>"
        },
        "41": {
            "verses": {
