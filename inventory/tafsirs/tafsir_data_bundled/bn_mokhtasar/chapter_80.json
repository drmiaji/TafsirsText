            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>৪২. উপরোক্ত অবস্থা হবে তাদের যারা কুফরী ও পাপাচারে লিপ্ত থাকবে।</p>"
        }
