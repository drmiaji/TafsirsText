            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>৩৮. সে দিন সৌভাগ্যবানদের চেহারা হবে সমুজ্জ্ব¡ল।</h2>"
        },
        "39": {
            "verses": {
                "80:39": {
                    "id": 39
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
