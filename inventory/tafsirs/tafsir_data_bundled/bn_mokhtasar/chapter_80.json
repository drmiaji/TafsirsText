            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>৩৬. তার স্ত্রী-সন্তান থেকে।</h2>"
        },
        "37": {
            "verses": {
                "80:37": {
                    "id": 37
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>৩৭. সে দিনের গুরুতর অবস্থার দরুন প্রত্যেকে অন্যদের কথা বাদ দিয়ে নিজেকে নিয়ে ব্যস্ত হয়ে পড়বে।</p>"
        },
        "38": {
            "verses": {
                "80:38": {
                    "id": 38
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
