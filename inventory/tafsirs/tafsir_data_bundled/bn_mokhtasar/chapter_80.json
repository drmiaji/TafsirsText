                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>৩১. আরো উৎপন্ন করলাম ফলমূল ও তাদের পশুখাদ্য।</h2>"
        },
        "32": {
            "verses": {
                "80:32": {
                    "id": 32
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>৩২. তাদের ও তাদের পশুগুলোর উপভোগের নিমিত্তে।</h2>"
        },
        "33": {
            "verses": {
                "80:33": {
                    "id": 33
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>৩৩. অতঃপর যখন শ্রবণশক্তি হরণকারী দ্বিতীয় শিঙ্গাধ্বনি এসে পড়বে।</p>"
        },
        "34": {
            "verses": {
                "80:34": {
                    "id": 34
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>৩৪. সে দিন নিজ ভাই তার ভাই থেকে পলায়ন করবে।</h2>"
        },
        "35": {
            "verses": {
                "80:35": {
                    "id": 35
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
