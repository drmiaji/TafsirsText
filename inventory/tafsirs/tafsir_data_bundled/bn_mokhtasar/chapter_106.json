            },
            "text": "<h2>১. কুরাইশবাসীর অভ্যাস ও আসক্তির ফলে।</h2>"
        },
        "2": {
            "verses": {
                "106:2": {
                    "id": 2
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>২. শীতকালে নিরাপদে ইয়েমেনের প্রতি ভ্রমণ ও গ্রীষ্মকালে সিরিয়ার প্রতি ভ্রমণ।</p>"
        },
        "3": {
            "verses": {
                "106:3": {
                    "id": 3
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>৩. তাই তারা যেন এককভাবে এ সম্মানিত গৃহের প্রতিপালকের ইবাদাত করে এবং তাঁর সাথে কাউকে শরীক না করে। যিনি তাদের জন্য উক্ত ভ্রমণকে সহজ করে দিয়েছেন।</p>"
        },
        "4": {
            "verses": {
                "106:4": {
                    "id": 4
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>৪. উপরন্তু যিনি তাদেরকে ক্ষুধায় অন্ন যোগিয়েছেন এবং আরবদের মনে তাঁর ঘর ও এর প্রতিবেশীদের সম্মান ঢেলে দিয়ে তাদেরকে ভয়-ভীতি থেকে নিরাপদ করেছেন।</p>"
        }
    }
