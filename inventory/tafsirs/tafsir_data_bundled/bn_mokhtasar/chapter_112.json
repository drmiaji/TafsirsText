            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>৪. না তাঁর সৃষ্টিতে তাঁর কোন সমতুল্য রয়েছে।</h2>"
        }
    }
