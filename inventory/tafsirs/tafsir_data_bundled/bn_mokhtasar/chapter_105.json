            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>৩. তাদের বিরুদ্ধে তিনি ঝাঁকে ঝাঁকে পাখি প্রেরণ করলেন।</h2>"
        },
        "4": {
            "verses": {
