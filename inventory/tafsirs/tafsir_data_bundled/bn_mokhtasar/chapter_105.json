            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>৪. যেগুলো তাদের উপর পোড়া মাটির পাথর নিক্ষেপ করে।</h2>"
        },
