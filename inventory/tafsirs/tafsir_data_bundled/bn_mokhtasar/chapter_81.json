{
    "chapter": 81,
    "verses": {
        "1": {
            "verses": {
                "81:1": {
                    "id": 1
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>১. সূর্য যখন গুটানো হবে ও তার জ্যোতি নিষ্প্রভ হবে।</h2>"
        },
        "2": {
            "verses": {
                "81:2": {
                    "id": 2
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>২. যখন নক্ষত্ররাজি খসে পড়ে তা জ্যোতিহীন হবে।</h2>"
        },
        "3": {
            "verses": {
                "81:3": {
                    "id": 3
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>৩. পর্বতসমূহকে যখন তার অবস্থান থেকে সরিয়ে দেয়া হবে।</h2>"
        },
        "4": {
            "verses": {
                "81:4": {
                    "id": 4
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>৪. যখন তাদের সর্বাপেক্ষা উৎকৃষ্ট সম্পদ পূর্ণগর্ভা উষ্ট্রী উপেক্ষিতা হবে।</p>"
        },
        "5": {
            "verses": {
                "81:5": {
                    "id": 5
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>৫. বন্য পশুগুলোকে যখন মানুষের সাথে একই মাঠে সমবেত করা হবে।</h2>"
        },
        "6": {
            "verses": {
                "81:6": {
                    "id": 6
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>৬. সমুদ্রগুলোকে যখন এমনভাবে প্রজ্জ্বলিত করা হবে যার ফলে সেগুলো অগ্নিতে রূপান্তরিত হবে।</p>"
        },
        "7": {
            "verses": {
                "81:7": {
                    "id": 7
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>৭. যখন ভালো-মন্দ আত্মাসমূহকে সেগুলোর ন্যায় আত্মাসমূহের সাথে মিলিয়ে দেয়া হবে।</p>"
        },
        "8": {
            "verses": {
                "81:8": {
                    "id": 8
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>৮. যখন জীবন্ত প্রোথিত কণ্যা সন্তানকে আল্লাহ জিজ্ঞেস করবেন।</h2>"
        },
        "9": {
            "verses": {
                "81:9": {
                    "id": 9
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>৯. কোন্ অপরাধে হত্যাকারী তোমাকে হত্যা করেছিলো?!</h2>"
        },
        "10": {
            "verses": {
                "81:10": {
                    "id": 10
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>১০. যখন বান্দাদের আমলনামা উম্মোচিত করা হবে। যেন প্রত্যেকে তার নিজ আমলনামা পড়তে পারে।</p>"
        },
        "11": {
            "verses": {
                "81:11": {
                    "id": 11
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>১১. যখন আসমানের আবরণকে ছাগলের ছালের মতো তুলে ফেলা হবে।</h2>"
        },
        "12": {
            "verses": {
                "81:12": {
                    "id": 12
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>১২. যখন জাহান্নামের অগ্নিকে প্রজ্জ্বলিত করা হবে।</h2>"
        },
        "13": {
            "verses": {
                "81:13": {
                    "id": 13
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>১৩. জান্নাতকে যখন মুত্তাকীদের উদ্দেশ্যে নিকটবর্তী করা হবে।</h2>"
        },
        "14": {
            "verses": {
                "81:14": {
                    "id": 14
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>১৪. এ সব যে দিন সংঘটিত হবে সে দিন প্রত্যেকে জানতে পারবে, সে আমল হিসাবে এ দিনের জন্য অগ্রিম কী পাঠিয়েছে।</p>"
        },
        "15": {
            "verses": {
                "81:15": {
                    "id": 15
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>১৫. আল্লাহ রাত্রিকালীন সময়ে প্রকাশ পাওয়ার পূর্বে সুপ্ত তারকাসমূহের শপথ করলেন।</p>"
        },
        "16": {
            "verses": {
                "81:16": {
                    "id": 16
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>১৬. যেগুলো নিজ নিজ আকাশে ফজরের পূর্ব পর্যন্ত চলমান থাকে এবং ফজরের পর নিজ নিজ আশ্রয়স্থলে হরিণের মতো অদৃশ্য হয়।</p>"
        },
        "17": {
            "verses": {
                "81:17": {
                    "id": 17
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>১৭. তিনি রাতের আগমনের শুরু ও তার বিদায়ের শেষ ভাগের শপথ করলেন।</p>"
        },
        "18": {
            "verses": {
                "81:18": {
                    "id": 18
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>১৮. তিনি শপথ করলেন প্রভাতের যখন তার আলো বিকশিত হয়।</h2>"
        },
        "19": {
            "verses": {
                "81:19": {
                    "id": 19
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>১৯. অবশ্যই নবী মুহাম্মাদ (সাল্লাল্লাহু আলাইহি ওয়াসাল্লাম) এর উপর অবতীর্ণ এ কুরআন আল্লাহর কালাম। যা তাঁর নিকট পৌঁছিয়েছেন আল্লাহর বিশ্বস্ত ফিরিশতা জিব্রীল (আলাইহিস-সালাম)।</p>"
        },
        "20": {
            "verses": {
                "81:20": {
                    "id": 20
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>২০. যিনি মহা শক্তিধর, আরশের মহান মালিকের নিকট মহা মর্যাদাবান।</p>"
        },
        "21": {
            "verses": {
                "81:21": {
                    "id": 21
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>২১. আসমনাবাসীরা যাঁর আনুগত্য করে। যিনি ওহী পৌঁছানোর কাজে বিশ্বস্ত।</p>"
        },
        "22": {
            "verses": {
                "81:22": {
                    "id": 22
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>২২. তোমাদের নিত্য সাথী যাঁর বিবেক, আমনতদারিতা ও সততা তোমাদের সামনে সুস্পষ্ট তিনি আদৗ উন্মাদ নন। যেমনটি তোমরা অপবাদ স্বরূপ দাবি করে থাকো।</p>"
        },
        "23": {
            "verses": {
                "81:23": {
                    "id": 23
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>২৩. তোমাদের সাথী নিশ্চয়ই জিব্রীলকে তাঁর আসল আকৃতিতে আকাশের সুস্পষ্ট দিগন্তে দেখেছেন।</p>"
        },
        "24": {
            "verses": {
                "81:24": {
                    "id": 24
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>২৪. তিনি তোমাদের নিকট যা পৌঁছে দিতে আদিষ্ট হয়েছেন তা পৌঁছে দেয়ার ব্যাপারে কৃপণ নন। না তিনি এর জন্য কোন প্রতিদান গ্রহণ করেন যেমনটি করে থাকে গণকরা।</p>"
        },
        "25": {
            "verses": {
                "81:25": {
                    "id": 25
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>২৫. না এ কুরআন আল্লাহর রহমত থেকে বিতাড়িত শয়তানের বাণী।</h2>"
        },
        "26": {
            "verses": {
                "81:26": {
                    "id": 26
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>২৬. সুতরাং এতো সব প্রমাণের পরও তোমরা এটি আল্লাহর পক্ষ থেকে অবতীর্ণ নয় বলে অস্বীকৃতির আর কোন্ পথ অবলম্বন করবে?!</p>"
        },
        "27": {
            "verses": {
                "81:27": {
                    "id": 27
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>২৭. কুরআন তো কেবল জিন ও ইনসানের উদ্দেশ্যে উপদেশ ও সতর্কবাণী।</p>"
        },
        "28": {
            "verses": {
                "81:28": {
                    "id": 28
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>২৮. তোমাদের মধ্যকার যে ব্যক্তি সত্যের পথে থাকতে উচ্ছুক তার উদ্দেশ্যে।</p>"
        },
        "29": {
            "verses": {
                "81:29": {
                    "id": 29
                }
            },
            "resource_id": 120,
            "resource_name": "Tafsir Bn Mokhtasar",
            "language_id": 38,
            "slug": "bn_mokhtasar",
            "translated_name": {
                "name": "Tafsir Bn Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>২৯. তোমরা সরল পথে চলা কিংবা না চলা কোনটারই ইচ্ছা করতে পারো না যদি সকল সৃষ্টির প্রতিপালক তা না চান।</p>"
        }
    }
}