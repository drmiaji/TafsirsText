                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَضَلَّ أَعْمَالَهُمْ﴾ أَحْبَطَهَا، وَأَبْطَلَهَا.</h2>"
        },
        "2": {
            "verses": {
                "47:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿كَفَّرَ﴾ أَزَالَ، وَمَحَا.</h2>\n<p>﴿بَالَهُمْ﴾ حَالَهُمْ وَشَأْنَهُمْ فِي الدُّنْيَا والآخِرَةِ.</p>"
        },
        "3": {
            "verses": {
                "47:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْبَاطِلَ﴾ الشَّيْطَانَ.</h2>"
        },
        "4": {
            "verses": {
                "47:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَضَرْبَ الرِّقَابِ﴾ اضْرِبُوا مِنْهُمُ الأَعْنَاقَ.</h2>\n<p>﴿أَثْخَنْتُمُوهُمْ﴾ أَضْعَفْتُمُوهُمْ بِكَثْرَةِ القِتَالِ، وَكَسَرْتُمْ شَوْكَتَهُمْ.</p>\n<h2>﴿فَشُدُّوا الْوَثَاقَ﴾ أَحْكِمُوا قَيْدَ الأَسْرَى.</h2>\n<p>﴿مَنًّا﴾ تَمُنُّونَ عَلَيْهِمْ بِإِطْلاَقِ الأَسْرَى مِنْ غَيْرِ عِوَضٍ.</p>\n<p>﴿فِدَاءً﴾ تَطْلُبُونَ مِنْهُمْ فِدْيَةً تُخَلِّصُهُمْ مِنَ الأَسْرِ.</p>\n<p>﴿حَتَّى تَضَعَ الْحَرْبُ أَوْزَارَهَا﴾ أَثْقَالَها؛ وَالمُرَادُ: حَتَّى تَنْتَهِيَ الحَرْبُ.</p>\n<h2>﴿لِيَبْلُوَ﴾ لِيَخْتَبِرَ.</h2>\n<h2>﴿يُضِلَّ أَعْمَالَهُمْ﴾ يُبْطِلَ ثَوَابَ أَعْمَالِهِمْ.</h2>"
        },
        "5": {
            "verses": {
                "47:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بَالَهُمْ﴾ شَأْنَهُمْ فِي الدُّنْيَا وَالآخِرَةِ.</h2>"
        },
        "6": {
            "verses": {
                "47:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿عَرَّفَهَا لَهُمْ﴾ بَيَّنَهَا لَهُمْ؛ فَيَهْتَدُونَ إِلَى مَسَاكِنِهِمْ فِيهَا مِنْ غَيْرِ اسْتِدْلاَلٍ.</p>"
        },
        "7": {
            "verses": {
                "47:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَيُثَبِّتْ أَقْدَامَكُمْ﴾ يُثَبِّتْكُمْ عِنْدَ القِتَالِ، وَيُقَوِّ قُلُوبَكُمْ.</p>"
        },
        "8": {
            "verses": {
                "47:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَتَعْسًا﴾ هَلاَكًا، وَخَيْبَةً.</h2>\n<h2>﴿وَأَضَلَّ أَعْمَالَهُمْ﴾ أَذْهَبَ ثَوَابَ أَعْمَالِهِمْ.</h2>"
        },
