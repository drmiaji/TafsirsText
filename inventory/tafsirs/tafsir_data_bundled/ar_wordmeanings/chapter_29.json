                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بَدَأَ الْخَلْقَ﴾ أَنْشَأَهُ.</h2>"
        },
        "21": {
            "verses": {
                "29:21": {
                    "id": 21
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿تُقْلَبُونَ﴾ تُرَدُّونَ، وَتُرْجَعُونَ.</h2>"
        },
        "22": {
            "verses": {
                "29:22": {
                    "id": 22
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿بِمُعْجِزِينَ﴾ فَائِتِينَ مِنْ عَذَابِهِ بِالهَرَبِ وَغَيْرِهِ.</p>"
        },
        "23": {
            "verses": {
