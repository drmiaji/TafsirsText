                "language_name": "english"
            },
            "text": "<h2>﴿أَكْبَرُ﴾ أَعْظَمُ وَأَفْضَلُ مِنْ كُلِّ شَيْءٍ.</h2>"
        },
        "46": {
            "verses": {
