            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أَجَلَ اللَّهِ﴾ الوَقْتَ الَّذِي حَدَّدَهُ اللهُ لِلْبَعْثِ.</p>"
        },
