            },
            "text": "<p>...</p>"
        },
        "25": {
            "verses": {
                "29:25": {
                    "id": 25
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مَوَدَّةَ بَيْنِكُمْ﴾ تَتَحَابُّونَ عَلَى عِبَادَتِهَا، وتَتَوَادُّونَ عَلَى خِدْمَتِهَا.</p>\n<h2>﴿يَكْفُرُ﴾ يَتَبَرَّأُ.</h2>\n<h2>﴿وَمَأْوَاكُمُ﴾ مَصِيرُكُمْ.</h2>"
        },
        "26": {
            "verses": {
                "29:26": {
                    "id": 26
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مُهَاجِرٌ﴾ تَارِكٌ دَارَ قَوْمِي إِلَى أَرْضِ الشَّامِ المُبَارَكَةِ.</p>"
        },
        "27": {
            "verses": {
                "29:27": {
                    "id": 27
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أَجْرَهُ فِي الدُّنْيَا﴾ بِالذِّكْرِ الحَسَنِ، وَالوَلَدِ الصَّالِحِ وَالنُّبُوَّةِ فِي ذُرِّيَّتِهِ.</p>"
        },
        "28": {
            "verses": {
                "29:28": {
                    "id": 28
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "29": {
            "verses": {
                "29:29": {
                    "id": 29
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَتَقْطَعُونَ السَّبِيلَ﴾ تَقْطَعُونَ طُرُقَ المُسَافِرِينَ بِفِعْلِكُمُ الفَاحِشَةَ بِهِمْ.</p>\n<h2>﴿نَادِيكُمُ﴾ مَجْلِسِكُمُ الَّذِي تَجْتَمِعُونَ فِيهِ.</h2>\n<p>﴿الْمُنْكَرَ﴾ الأَعْمَالَ المُنْكَرَةَ؛ كَالسُّخْرِيَةِ مِنَ النَّاسِ، وَقَذْفِ المَارَّةِ.</p>"
        },
        "30": {
            "verses": {
                "29:30": {
                    "id": 30
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "31": {
            "verses": {
                "29:31": {
                    "id": 31
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿بِالْبُشْرَى﴾ بِالخَبَرِ السَّارِّ، وَهُوَ: البِشَارَةُ بِإِسْحَاقَ عليه السلام.</p>"
        },
        "32": {
            "verses": {
                "29:32": {
                    "id": 32
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْغَابِرِينَ﴾ البَاقِينَ فِي العَذَابِ.</h2>"
        },
        "33": {
            "verses": {
                "29:33": {
                    "id": 33
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿سِيءَ بِهِمْ﴾ سَاءَهُ مَجِيئُهُمْ خَوْفًا عَلَيْهِمْ مِنْ قَوْمِهِ أَنْ يَفْعَلُوا بِهِمُ الفَاحِشَةَ.</p>\n<p>﴿وَضَاقَ بِهِمْ ذَرْعًا﴾ ضَاقَ صَدْرُهُ، وَحَزِنَ خَوْفًا عَلَيْهِمْ.</p>"
        },
        "34": {
            "verses": {
                "29:34": {
                    "id": 34
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿رِجْزًا﴾ عَذَابًا شَدِيدًا.</h2>"
        },
        "35": {
            "verses": {
                "29:35": {
                    "id": 35
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿تَرَكْنَا مِنْهَا﴾ أَبْقَيْنَا مِنْ دِيَارِهِمْ.</h2>\n<h2>﴿آيَةً بَيِّنَةً﴾ آثَارًا وَاضِحَةً.</h2>"
        },
        "36": {
            "verses": {
                "29:36": {
                    "id": 36
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَارْجُوا الْيَوْمَ الآخِرَ﴾ اطْلُبُوا بِعِبَادَتِكُمْ جَزَاءَ الآخِرَةِ.</p>\n<h2>﴿وَلاَ تَعْثَوْا﴾ لاَ تُكْثِرُوا الفَسَادَ.</h2>"
        },
        "37": {
            "verses": {
                "29:37": {
                    "id": 37
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الرَّجْفَةُ﴾ الزَّلْزَلَةُ الشَّدِيدَةُ.</h2>\n<h2>﴿جَاثِمِينَ﴾ صَرْعَى هَالِكِينَ.</h2>"
        },
        "38": {
            "verses": {
                "29:38": {
                    "id": 38
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مُسْتَبْصِرِينَ﴾ عَارِفِينَ بِكُفْرِهِمْ مُعْجَبِينَ بِهِ.</h2>"
        },
        "39": {
            "verses": {
                "29:39": {
                    "id": 39
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَا كَانُوا سَابِقِينَ﴾ فَائِتِينَ مِنْ عَذَابِ اللهِ.</h2>"
        },
