            "text": "<h2>﴿فَنَبَذْنَاهُمْ فِي الْيَمِّ﴾ طَرَحْنَاهُمْ فِي البَحْرِ.</h2>\n<h2>﴿مُلِيمٌ﴾ آتٍ بِمَا يُلامُ عَلَيْهِ.</h2>"
        },
        "41": {
            "verses": {
                "51:41": {
                    "id": 41
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الْعَقِيمَ﴾ الَّتِي لاَ بَرَكَةَ فِيهَا، وَلاَ تَأْتِي بِخَيْرٍ.</p>"
        },
        "42": {
            "verses": {
