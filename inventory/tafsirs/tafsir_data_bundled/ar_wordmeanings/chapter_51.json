            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَرَاغَ﴾ مَالَ، وَعَدَلَ بِخُفْيَةٍ.</h2>"
        },
        "27": {
            "verses": {
