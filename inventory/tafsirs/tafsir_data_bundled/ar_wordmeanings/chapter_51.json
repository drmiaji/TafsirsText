                "language_name": "english"
            },
            "text": "<p>﴿إِنَّهُ لَحَقٌّ﴾ إِنَّ مَا وَعَدَكُمْ بِهِ مِنَ الجَزَاءِ لَحَقٌّ ثَابِتٌ.</p>"
        },
        "24": {
            "verses": {
                "51:24": {
                    "id": 24
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
