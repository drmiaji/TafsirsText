            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فِيهَا آيَةً﴾ فِي قَرْيَتِهِمْ أَثَرًا مِنَ العَذَابِ بَاقِيًا؛ عَلاَمَةً عَلَى قُدْرَةِ اللهِ.</p>"
        },
        "38": {
            "verses": {
                "51:38": {
                    "id": 38
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَفِي مُوسَى﴾ فِي إِرْسَالِنَا مُوسَى عليه السلام: آيَةٌ لِلَّذِينَ يَخَافُونَ العَذَابَ.</p>\n<h2>﴿بِسُلْطَانٍ مُبِينٍ﴾ بِآيَاتٍ، وَمُعْجِزَاتٍ ظَاهِرَةٍ.</h2>"
        },
        "39": {
            "verses": {
                "51:39": {
                    "id": 39
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَتَوَلَّى بِرُكْنِهِ﴾ أَعْرَضَ فِرْعَوْنُ؛ مُغْتَرًّا بِقُوَّتِهِ وَجَانِبِهِ.</p>"
        },
        "40": {
            "verses": {
