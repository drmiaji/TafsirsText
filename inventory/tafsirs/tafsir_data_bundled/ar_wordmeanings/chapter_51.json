                    "id": 42
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَا تَذَرُ﴾ مَا تَدَعُ.</h2>\n<h2>﴿كَالرَّمِيمِ﴾ كَالشَّيْءِ البَالِي.</h2>"
        },
        "43": {
            "verses": {
                "51:43": {
                    "id": 43
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿تَمَتَّعُوا حَتَّى حِينٍ﴾ انْتَفِعُوا بِحَيَاتِكُمْ حَتَّى تَنْتَهِيَ آجَالُكُمْ.</p>"
        },
        "44": {
            "verses": {
