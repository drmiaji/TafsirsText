            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَبِالأَسْحَارِ﴾ آخِرِ اللَّيْلِ، قُبَيْلَ الفَجْرِ.</h2>"
        },
        "19": {
            "verses": {
                "51:19": {
                    "id": 19
                }
            },
