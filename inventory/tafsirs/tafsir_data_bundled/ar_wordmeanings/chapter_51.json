            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَالذَّارِيَاتِ﴾ قَسَمٌ بِالرِّيَاحِ، المُثِيرَاتِ لِلتُّرَابِ.</p>"
        },
        "2": {
            "verses": {
                "51:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَالْحَامِلاَتِ وِقْرًا﴾ فَالسُّحُبِ الحَامِلاَتِ ثِقَلاً عَظِيمًا مِنَ المَاءِ.</p>"
        },
        "3": {
            "verses": {
                "51:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَالْجَارِيَاتِ يُسْرًا﴾ فَالسُّفُنِ الَّتِي تَجْرِي فِي البِحَارِ بِيُسْرٍ.</p>"
        },
        "4": {
            "verses": {
                "51:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَالْمُقَسِّمَاتِ أَمْرًا﴾ فَالمَلاَئِكَةِ الَّتِي تُقَسِّمُ أَمْرَ اللهِ فِي خَلْقِهِ.</p>"
        },
        "5": {
            "verses": {
                "51:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "6": {
            "verses": {
                "51:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الدِّينَ﴾ الحِسَابَ، وَالجَزَاءَ.</h2>"
        },
        "7": {
            "verses": {
                "51:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿ذَاتِ الْحُبُكِ﴾ ذَاتِ الخَلْقِ الحَسَنِ، وَذَاتِ الطُّرُقِ الَّتِي تَسِيرُ فِيهَا الكَوَاكِبُ.</p>"
        },
        "8": {
            "verses": {
                "51:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿قَوْلٍ مُخْتَلِفٍ﴾ مُتَنَاقِضٍ، مُضْطَرِبٍ فِي القُرْآنِ وَالرَّسُولِ صلّى الله عليه وسلّم.</p>"
        },
        "9": {
            "verses": {
                "51:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿يُؤْفَكُ عَنْهُ﴾ يُصْرَفُ عَنِ القُرْآنِ وَالرَّسُولِ صلّى الله عليه وسلّم.</p>"
        },
        "10": {
            "verses": {
                "51:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿قُتِلَ الْخَرَّاصُونَ﴾ قُتِلَ، وَلُعِنَ الكَذَّابُونَ، الظَّانُّونَ غَيْرَ الحَقِّ.</p>"
        },
        "11": {
            "verses": {
                "51:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿غَمْرَةٍ﴾ جَهْلٍ يَغْمُرُهُمْ.</h2>\n<h2>﴿سَاهُونَ﴾ غَافِلُونَ عَنْ أَمْرِ الآخِرَةِ.</h2>"
        },
        "12": {
            "verses": {
                "51:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَسْأَلُونَ﴾ سُؤَالَ اسْتِبْعَادٍ وَإِنْكَارٍ.</h2>\n<h2>﴿أَيَّانَ يَوْمُ الدِّينِ﴾ مَتَى يَوْمُ الجَزَاءِ؟!</h2>"
        },
        "13": {
            "verses": {
                "51:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يُفْتَنُونَ﴾ يُحْرَقُونَ، وَيُعَذَّبُونَ.</h2>"
        },
        "14": {
            "verses": {
                "51:14": {
                    "id": 14
