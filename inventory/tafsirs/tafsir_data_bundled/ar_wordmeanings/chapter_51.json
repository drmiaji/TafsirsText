            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مُسَوَّمَةً﴾ مُعَلَّمَةً بِأَنَّهَا لِعَذَابِ المُسْرِفِينَ.</p>"
        },
