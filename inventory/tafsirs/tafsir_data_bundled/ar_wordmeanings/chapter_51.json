            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مُنْكَرُونَ﴾ غُرَبَاءُ لاَ تُعْرَفُونَ.</h2>"
        },
        "26": {
            "verses": {
