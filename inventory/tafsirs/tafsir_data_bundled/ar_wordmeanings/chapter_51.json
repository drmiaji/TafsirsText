            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿ضَيْفِ إِبْرَاهِيمَ﴾ أَضْيَافِهِ مِنَ المَلاَئِكَةِ.</h2>"
        },
        "25": {
            "verses": {
