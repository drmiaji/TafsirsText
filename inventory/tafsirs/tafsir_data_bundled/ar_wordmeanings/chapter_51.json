            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَعَتَوْا﴾ تَكَبَّرُوا، وَعَصَوْا.</h2>\n<h2>﴿الصَّاعِقَةُ﴾ الصَّيْحَةُ المُهْلِكَةُ.</h2>"
        },
