            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لاَ تُبْقِي﴾ لاَ تَتْرُكُ لَحْمًا.</h2>\n<h2>﴿وَلاَ تَذَرُ﴾ لاَ تَتْرُكُ عَظْمًا.</h2>"
        },
        "29": {
            "verses": {
                "74:29": {
                    "id": 29
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لَوَّاحَةٌ لِلْبَشَرِ﴾ مُحْرِقَةٌ لِلْجُلُودِ، مُغَيِّرَةٌ لِلْبَشَرَةِ.</p>"
        },
