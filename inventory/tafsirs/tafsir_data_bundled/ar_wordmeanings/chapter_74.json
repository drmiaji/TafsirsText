            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿سَأُصْلِيهِ سَقَرَ﴾ سَأُدْخِلُهُ جَهَنَّمَ؛ كَيْ يَصْلَى حَرَّهَا.</p>"
        },
        "27": {
            "verses": {
