            },
            "text": "<p>...</p>"
        },
        "3": {
            "verses": {
                "74:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَرَبَّكَ فَكَبِّرْ﴾ اخْصُصْ رَبَّكَ بِالتَّكْبِيرِ وَالتَّعْظِيمِ.</p>"
        },
        "4": {
            "verses": {
                "74:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَثِيَابَكَ فَطَهِّرْ﴾ طَهِّرْ نَفْسَكَ مِنَ المَعَاصِي وَالآثَامِ.</p>"
        },
        "5": {
            "verses": {
                "74:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَالرُّجْزَ﴾ الأَصْنَامَ، وَأَعْمَالَ الشِّرْكِ.</h2>"
        },
        "6": {
            "verses": {
                "74:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَلاَ تَمْنُنْ تَسْتَكْثِرُ﴾ لاَ تُعْطِ العَطِيَّةَ، كَيْ تَلْتَمِسَ أَكْثَرَ مِنْهَا.</p>"
        },
        "7": {
            "verses": {
                "74:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "8": {
            "verses": {
                "74:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿نُقِرَ فِي النَّاقُورِ﴾ نُفِخَ فِي الصُّورِ نَفْخَةُ البَعْثِ.</p>"
        },
        "9": {
            "verses": {
