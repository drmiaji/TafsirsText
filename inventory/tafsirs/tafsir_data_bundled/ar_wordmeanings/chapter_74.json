                "language_name": "english"
            },
            "text": "<p>﴿الْمُدَّثِّرُ﴾ أَصْلُهُ: المُتَدَثِّرُ، وَهُوَ المُتَغَطِّي بِثِيَابِهِ.</p>"
        },
        "2": {
            "verses": {
