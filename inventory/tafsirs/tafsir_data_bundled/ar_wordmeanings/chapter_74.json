            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "11": {
            "verses": {
                "74:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَحِيدًا﴾ فَرِيدًا لاَ مَالَ لَهُ، وَلاَ وَلَدَ، وَالمُرَادُ بِهِ: (الوَلِيدُ بْنُ المَغِيرَةِ).</p>"
        },
        "12": {
            "verses": {
                "74:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَمْدُودًا﴾ مَبْسُوطًا وَاسِعًا.</h2>"
        },
        "13": {
            "verses": {
                "74:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿شُهُودًا﴾ حُضُورًا مَعَهُ فِي مَكَّةَ لاَ يَغِيبُونَ عَنْهُ.</p>"
        },
        "14": {
            "verses": {
                "74:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَهَّدْتُّ لَهُ تَمْهِيدًا﴾ يَسَّرْتُ لَهُ سُبُلَ العَيْشِ تَيْسِيرًا.</p>"
        },
        "15": {
            "verses": {
                "74:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "16": {
            "verses": {
                "74:16": {
                    "id": 16
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "17": {
            "verses": {
                "74:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿سَأُرْهِقُهُ صَعُودًا﴾ سَأُكَلِّفُهُ عَذَابًا شَاقًّا لاَ رَاحَةَ لَهُ فِيهِ.</p>"
        },
        "18": {
            "verses": {
                "74:18": {
                    "id": 18
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وقَدَّرَ﴾ هَيَّأَ مَا يَقُولُهُ فِي الطَّعْنِ فِي القُرْآنِ، وَمَنْ جَاءَ بِهِ.</p>"
        },
        "19": {
            "verses": {
                "74:19": {
                    "id": 19
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَقُتِلَ﴾ غُلِبَ وَقُهِرَ.</h2>"
        },
        "20": {
            "verses": {
                "74:20": {
                    "id": 20
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
