            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿نَظَرَ﴾ تَأَمَّلَ فِيمَا هَيَّأَ مِنَ الطَّعْنِ.</h2>"
        },
        "22": {
            "verses": {
                "74:22": {
                    "id": 22
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿عَبَسَ﴾ قَطَّبَ وَجْهَهُ.</h2>\n<p>﴿وَبَسَرَ﴾ اشْتَدَّ فِي العُبُوسِ لَمَّا ضَاقَتْ عَلَيْهِ الحِيَلُ فِي الطَّعْنِ.</p>"
        },
        "23": {
            "verses": {
                "74:23": {
                    "id": 23
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَدْبَرَ﴾ رَجَعَ مُعْرِضًا عَنِ الحَقِّ.</h2>"
        },
        "24": {
            "verses": {
                "74:24": {
                    "id": 24
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يُؤْثَرُ﴾ يُنْقَلُ عَنِ الأَوَّلِينَ.</h2>"
        },
        "25": {
            "verses": {
                "74:25": {
                    "id": 25
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
