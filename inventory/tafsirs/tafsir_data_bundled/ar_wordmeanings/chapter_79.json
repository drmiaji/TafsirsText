            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿بِالسَّاهِرَةِ﴾ بِوَجْهِ الأَرْضِ أَحْيَاءً بَعْدَ أَنْ كَانُوا فِي بَطْنِهَا.</p>"
        },
