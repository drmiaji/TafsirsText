            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿دَحَاهَا﴾ بَسَطَهَا، وَأَوْدَعَ فِيهَا مَنَافِعَهَا.</h2>"
        },
