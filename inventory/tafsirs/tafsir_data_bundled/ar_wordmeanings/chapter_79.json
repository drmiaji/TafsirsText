                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَالنَّازِعَاتِ﴾ قَسَمٌ بِالمَلاَئِكَةِ تَنْزِعُ أَرْوَاحَ الكُفَّارِ.</p>\n<h2>﴿غَرْقًا﴾ نَزْعًا شَدِيدًا.</h2>"
        },
        "2": {
            "verses": {
                "79:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَالنَّاشِطَاتِ﴾ قَسَمٌ بِالمَلاَئِكَةِ تَسُلُّ أَرْوَاحَ المُؤْمِنِينَ بِرِفْقٍ.</p>"
        },
        "3": {
            "verses": {
                "79:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَالسَّابِحَاتِ﴾ قَسَمٌ بِالمَلاَئِكَةِ الَّتِي تَسْبَحُ فِي نُزُولِهَا مِنَ السَّمَاءِ، وَصُعُودِها إِلَيْهَا.</p>"
        },
        "4": {
            "verses": {
                "79:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَالسَّابِقَاتِ﴾ قَسَمٌ بِالمَلاَئِكَةِ الَّتِي تَسْبِقُ الشَّيَاطِينَ بِالوَحْيِ إِلَى الأَنْبِيَاءِ؛ لِئَلاَّ تَسْتَرِقَهُ.</p>"
        },
        "5": {
            "verses": {
                "79:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَالْمُدَبِّرَاتِ أَمْرًا﴾ قَسَمٌ بِالمَلاَئِكَةِ المُنَفِّذَاتِ أَمْرَ اللهِ، وَجَوابُ القَسَمِ مَحْذُوفٌ، وَتَقْدِيرُهُ: لَتُبْعَثُنَّ.</p>"
        },
        "6": {
            "verses": {
                "79:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿تَرْجُفُ الرَّاجِفَةُ﴾ تَضْطَرِبُ الأَرْضُ بِالنَّفْخَةِ الأُولَى: نَفْخَةِ الصَّعْقِ.</p>"
        },
        "7": {
            "verses": {
                "79:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿تَتْبَعُهَا الرَّادِفَةُ﴾ تَلِيهَا نَفْخَةٌ أُخْرَى لِلْبَعْثِ.</p>"
        },
        "8": {
            "verses": {
                "79:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَاجِفَةٌ﴾ خَائِفَةٌ، مُضْطَرِبَةٌ.</h2>"
        },
        "9": {
            "verses": {
                "79:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿خَاشِعَةٌ﴾ ذَلِيلَةٌ مِنْ هَوْلِ مَا تُشَاهِدُ.</h2>"
        },
        "10": {
            "verses": {
                "79:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الْحَافِرَةِ﴾ الحَالَةِ الَّتِي كُنَّا عَلَيْهَا فِي الأَرْضِ.</p>"
        },
        "11": {
            "verses": {
                "79:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿نَخِرَةً﴾ بَالِيَةً.</h2>"
        },
        "12": {
            "verses": {
                "79:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿كَرَّةٌ خَاسِرَةٌ﴾ رَجْعَةٌ خَائِبَةٌ ذَاتُ خُسْرَانٍ.</h2>"
        },
        "13": {
            "verses": {
                "79:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
