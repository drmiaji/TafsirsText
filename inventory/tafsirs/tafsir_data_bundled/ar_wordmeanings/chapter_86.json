            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿دَافِقٍ﴾ مُنْصَبٍّ بِسُرْعَةٍ فِي الرَّحِمِ.</h2>"
        },
        "7": {
            "verses": {
                "86:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الصُّلْبِ﴾ الظَّهْرِ.</h2>\n<h2>﴿وَالتَّرَائِبِ﴾ عِظَامِ الصَّدْرِ.</h2>"
        },
        "8": {
            "verses": {
                "86:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿رَجْعِهِ﴾ رَدِّهِ حَيًّا بَعْدَ المَوْتِ.</h2>"
        },
        "9": {
            "verses": {
                "86:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿تُبْلَى السَّرَائِرُ﴾ تُخْتَبَرُ، وَتُكْشَفُ ضَمَائِرُ القُلُوبِ.</p>"
        },
