            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿إِنْ كُلُّ نَفْسٍ لَمَّا﴾ مَا كُلُّ نَفْسٍ إِلاَّ.</h2>\n<h2>﴿حَافِظٌ﴾ مَلَكٌ يَحْفَظُ أَعْمَالَهَا.</h2>"
        },
        "5": {
            "verses": {
                "86:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
