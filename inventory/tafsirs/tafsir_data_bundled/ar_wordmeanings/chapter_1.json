            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الصِّرَاطَ الْمُسْتَقِيمَ﴾ الطَّرِيقَ الَّذِي لاَ عِوَجَ فِيهِ؛ وَهُوَ الإِسْلاَمُ.</p>"
        },
        "7": {
