            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَرَدُّوا أَيْدِيَهُمْ فِي أَفْوَاهِهِمْ﴾ عَضُّوا أَيْدِيَهُمْ؛ تَغَيُّظًا عَلَى الرُّسُلِ وَدِينِهِمْ.</p>\n<h2>﴿مُرِيبٍ﴾ مُوجِبٍ لِلرِّيبَةِ، وَالشَّكِّ.</h2>"
        },
        "10": {
            "verses": {
                "14:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَاطِرِ﴾ مُنْشِئِ ومُبْدِعِ.</h2>\n<h2>﴿بِسُلْطَانٍ﴾ بِحُجَّةٍ، وَدَلِيلٍ.</h2>"
        },
        "11": {
