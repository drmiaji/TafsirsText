            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿بِأَيَّامِ اللَّهِ﴾ نِعَمِهِ وَنِقَمِهِ الَّتِي قَدَّرَهَا فِي الأَيَّامِ.</p>"
        },
        "6": {
            "verses": {
                "14:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَسُومُونَكُمْ﴾ يُذِيقُونَكُمْ.</h2>"
        },
        "7": {
            "verses": {
                "14:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿تَأَذَّنَ﴾ أَعْلَمَ إِعْلامًا مُؤَكَّدًا.</h2>"
        },
        "8": {
            "verses": {
