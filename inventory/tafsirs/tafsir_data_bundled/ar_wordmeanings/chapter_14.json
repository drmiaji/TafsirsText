            },
            "text": "<h2>﴿سَوَاءٌ عَلَيْنَا﴾ يَسْتَوِي عَلَيْنَا وَعَلَيْكُمْ.</h2>\n<h2>﴿مَحِيصٍ﴾ مَهْرَبٍ.</h2>"
        },
        "22": {
            "verses": {
                "14:22": {
                    "id": 22
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿سُلْطَانٍ﴾ حُجَّةٍ وَقُوَّةٍ أَقْهَرُكُمْ بِهَا عَلَى اتِّبَاعِي.</p>\n<h2>﴿بِمُصْرِخِكُمْ﴾ بِمُغِيثِكُمْ.</h2>\n<h2>﴿كَفَرْتُ﴾ تَبَرَّأْتُ.</h2>"
        },
        "23": {
            "verses": {
                "14:23": {
                    "id": 23
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
