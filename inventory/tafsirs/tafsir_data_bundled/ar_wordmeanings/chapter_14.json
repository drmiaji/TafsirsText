                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَقَامِي﴾ مَوْقِفَهُ بَيْنَ يَدَيَّ لِلْحِسَابِ.</h2>"
        },
        "15": {
            "verses": {
                "14:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَاسْتَفْتَحُوا﴾ اسْتَنْصَرَ الرُّسُلُ بِاللهِ عَلَى الظَّالِمِينَ.</p>\n<h2>﴿وَخَابَ﴾ هَلَكَ، وَخَسِرَ.</h2>"
        },
        "16": {
            "verses": {
                "14:16": {
                    "id": 16
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَرَائِهِ﴾ أَمَامِهِ.</h2>\n<p>﴿صَدِيدٍ﴾ القَيْحِ وَالدَّمِ الَّذِي يَسِيلُ مِنْ أَجْسَادِ أَهْلِ النَّارِ.</p>"
        },
        "17": {
            "verses": {
                "14:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَتَجَرَّعُهُ﴾ يُحَاوِلُ ابْتِلاعَهُ.</h2>\n<p>﴿وَلا يَكَادُ يُسِيغُهُ﴾ لا يَسْتَطِيعُ ابْتِلاعَهُ؛ لِحَرَارَتِهِ وَقَذَارَتِهِ.</p>\n<h2>﴿وَمِنْ وَرَائِهِ﴾ مِنْ بَعْدِهِ.</h2>"
        },
        "18": {
            "verses": {
                "14:18": {
                    "id": 18
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَوْمٍ عَاصِفٍ﴾ شَدِيدِ هُبُوبِ الرِّيحِ.</h2>"
        },
