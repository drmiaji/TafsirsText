            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿إِلاَّ بَلاَغًا﴾ لَكِنْ أَمْلِكُ أَنْ أُبَلِّغَكُمْ.</h2>"
        },
