                "language_name": "english"
            },
            "text": "<h2>﴿نَفَرٌ﴾ جَمَاعَةٌ.</h2>\n<p>﴿عَجَبًا﴾ يُتَعَجَّبُ مِنْهُ فِي فَصَاحَتِهِ، وَبَلاَغَتِهِ، وَمَعَانِيهِ.</p>"
        },
        "2": {
            "verses": {
                "72:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الرُّشْدِ﴾ الحَقِّ، وَالهُدَى.</h2>"
        },
        "3": {
            "verses": {
                "72:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿جَدُّ رَبِّنَا﴾ عَظَمَةُ رَبِّنَا، وَجَلاَلُهُ، وَغِنَاهُ.</h2>\n<h2>﴿صَاحِبَةً﴾ زَوْجَةً.</h2>"
        },
        "4": {
            "verses": {
                "72:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿سَفِيهُنَا﴾ إِبْلِيسُ.</h2>\n<p>﴿شَطَطًا﴾ قَوْلاً بَعِيدًا عَنِ الحَقِّ مِنْ دَعْوَى الصَّاحِبَةِ وَالوَلَدِ.</p>"
        },
        "5": {
            "verses": {
                "72:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "6": {
            "verses": {
                "72:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَعُوذُونَ﴾ يَسْتَجِيرُونَ، وَيَسْتَعِيذُونَ.</h2>\n<h2>﴿رَهَقًا﴾ طُغْيانًا، وَسَفَهًا.</h2>"
        },
        "7": {
            "verses": {
                "72:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَأَنَّهُمْ ظَنُّوا﴾ وَأَنَّ كُفَّارَ الإِنْسِ حَسِبُوا.</h2>"
        },
        "8": {
            "verses": {
                "72:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لَمَسْنَا السَّمَاءَ﴾ طَلَبْنَا بُلُوغَ السَّمَاءِ؛ لاِسْتِرَاقِ السَّمْعِ.</p>\n<p>﴿وَشُهُبًا﴾ نُجُومًا مُحْرِقَةً؛ وَذَلِكَ لَمَّا بُعِثَ النَّبِيُّ صلّى الله عليه وسلّم.</p>"
        },
        "9": {
            "verses": {
                "72:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مَقَاعِدَ لِلسَّمْعِ﴾ مَوَاضِعَ؛ لِنَسْتَمِعَ إِلَى أَخْبَارِهَا.</p>\n<h2>﴿رَصَدًا﴾ أُرْصِدَ لَهُ؛ لِيُرْمَى بِهِ.</h2>"
        },
        "10": {
            "verses": {
                "72:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿رَشَدًا﴾ خَيْرًا، وَصَلاَحًا، وَرَحْمَةً.</h2>"
        },
        "11": {
            "verses": {
                "72:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿طَرَائِقَ قِدَدًا﴾ فِرَقًا وَمَذَاهِبَ مُخْتَلِفَةً.</h2>"
        },
        "12": {
            "verses": {
                "72:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿ظَنَنَّا﴾ أَيْقَنَّا.</h2>\n<p>﴿لَنْ نُعْجِزَ اللَّهَ﴾ لَنْ نَفُوتَهُ، وَنُفْلِتَ مِنْ قَبْضَتِهِ.</p>"
        },
        "13": {
            "verses": {
                "72:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بَخْسًا﴾ نُقْصَانًا مِنْ حَسَنَاتِهِ.</h2>\n<p>﴿وَلاَ رَهَقًا﴾ وَلاَ ظُلْمًا يَلْحَقُهُ بِزِيَادَةٍ فِي سَيِّئَاتِهِ.</p>"
        },
        "14": {
            "verses": {
                "72:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الْقَاسِطُونَ﴾ الجَائِرُونَ، الظَّالِمُونَ الَّذِينَ حَادُوا عَنِ الحَقِّ.</p>\n<p>﴿تَحَرَّوْا رَشَدًا﴾ قَصَدُوا طَرِيقَ الحَقِّ، وَاجْتَهَدُوا فِي اخْتِيَارِهِ.</p>"
        },
        "15": {
            "verses": {
                "72:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "16": {
            "verses": {
                "72:16": {
                    "id": 16
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَلَّوِِ اسْتَقَامُوا﴾ وَأَنَّهُ لَوِ اسْتَقَامَ الكُفَّارُ.</p>\n<h2>﴿الطَّرِيقَةِ﴾ دِينِ الإِسْلاَمِ.</h2>\n<h2>﴿غَدَقًا﴾ كَثِيرًا.</h2>"
        },
        "17": {
            "verses": {
                "72:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لِنَفْتِنَهُمْ فِيهِ﴾ لِنَخْتَبِرَهُمْ كَيْفَ يَشْكُرُونَ نِعَمَ اللهِ عَلَيْهِمْ.</p>\n<h2>﴿يَسْلُكْهُ﴾ يُدْخِلْهُ.</h2>\n<h2>﴿صَعَدًا﴾ شَدِيدًا شَاقًّا.</h2>"
        },
        "18": {
            "verses": {
