            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يُجِيرَنِي﴾ يُنْقِذَنِي.</h2>\n<h2>﴿مُلْتَحَدًا﴾ مَلْجَأً أَفِرُّ إِلَيْهِ مِنْ عَذَابِهِ.</h2>"
        },
        "23": {
            "verses": {
