            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَالْمُورِيَاتِ قَدْحًا﴾ فَالمُوقِدَاتِ بِحَوَافِرِهَا النَّارَ مِنْ شِدَّةِ عَدْوِهَا.</p>"
        },
        "3": {
            "verses": {
                "100:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَالْمُغِيرَاتِ صُبْحًا﴾ فَالخَيْلِ الَّتِي تُغِيرُ وَتُبَاغِتُ العَدُوَّ صَبَاحًا.</p>"
        },
        "4": {
            "verses": {
                "100:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَأَثَرْنَ﴾ فَهَيَّجْنَ.</h2>\n<h2>﴿نَقْعًا﴾ غُبَارًا.</h2>"
        },
        "5": {
            "verses": {
                "100:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَوَسَطْنَ بِهِ جَمْعًا﴾ فَتَوَسَّطْنَ بِرُكْبَانِهِنَّ جُمُوعَ الأَعْدَاءِ.</p>"
        },
