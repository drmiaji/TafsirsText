            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فِي شَأْنٍ﴾ أَيْ: أَمْرٍ فَيُعِزُّ وَيُذِلُّ، وَيُعْطِي وَيَمْنَعُ، وَيُحْيِي وَيُمِيتُ.</p>"
        },
