            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَانٍ﴾ هَالِكٌ.</h2>"
        },
        "27": {
            "verses": {
                "55:27": {
                    "id": 27
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿ذُو الْجَلاَلِ﴾ صَاحِبُ العَظَمَةِ، وَالكِبْرِيَاءِ.</h2>\n<h2>﴿وَالإِكْرَامِ﴾ الفَضْلِ، وَالجُودِ.</h2>"
        },
        "28": {
            "verses": {
                "55:28": {
                    "id": 28
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
