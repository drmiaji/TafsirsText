            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الْبَيَانَ﴾ النُّطْقَ بِأَنْ يُبِينَ عَمَّا فِي نَفْسِهِ بِالنُّطْقِ.</p>"
        },
        "5": {
            "verses": {
                "55:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿بِحُسْبَانٍ﴾ يَجْرِيَانِ مَتَعَاقِبَيْنِ، بِحِسَابٍ مُتْقَنٍ لاَ يَضْطَرِبُ.</p>"
        },
        "6": {
            "verses": {
                "55:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَالنَّجْمُ﴾ الكَوْكَبُ فِي السَّمَاءِ.</h2>"
        },
        "7": {
            "verses": {
                "55:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَوَضَعَ الْمِيزَانَ﴾ وَضَعَ فِي الأَرْضِ العَدْلَ.</h2>"
        },
        "8": {
            "verses": {
                "55:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَلاَّ تَطْغَوْا﴾ لِئَلاَّ تَعْتَدُوا، وَتَخُونُوا.</h2>"
        },
        "9": {
            "verses": {
                "55:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بِالْقِسْطِ﴾ بِالعَدْلِ.</h2>\n<h2>﴿وَلاَ تُخْسِرُوا﴾ وَلاَ تَنْقُصُوا.</h2>"
        },
        "10": {
            "verses": {
                "55:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَضَعَهَا لِلأَنَامِ﴾ مَهَّدَهَا؛ لِيَسْتَقِرَّ عَلَيْهَا الخَلْقُ.</p>"
        },
        "11": {
            "verses": {
                "55:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الأَكْمَامِ﴾ الأَوْعِيَةِ الَّتِي يَكُونُ مِنْهَا التَّمْرُ.</p>"
        },
        "12": {
            "verses": {
                "55:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَالْحَبُّ ذُو الْعَصْفِ﴾ وَفِيهَا الحَبُّ ذُو القِشْرِ وَالتِّبْنِ؛ رِزْقًا لَكُمْ وَلأَِنْعَامِكُمْ.</p>\n<h2>﴿وَالرَّيْحَانُ﴾ كُلُّ نَبْتٍ طَيِّبِ الرَّائِحَةِ.</h2>"
        },
        "13": {
            "verses": {
                "55:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "14": {
            "verses": {
                "55:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الإِنْسَانَ﴾ آدَمَ عليه السلام.</h2>\n<h2>﴿صَلْصَالٍ﴾ طِينٍ يَابِسٍ يُسْمَعُ لَهُ صَلْصَلَةٌ.</h2>\n<p>﴿كَالْفَخَّارِ﴾ هُوَ الطِّينُ الَّذِي يُطْبَخُ لِيَتَحَجَّرَ.</p>"
        },
        "15": {
            "verses": {
                "55:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْجَآنَّ﴾ إِبْلِيسَ.</h2>\n<p>﴿مَارِجٍ مِنْ نَارٍ﴾ لَهَبِ النَّارِ المُخْتَلِطِ بَعْضُهُ بِبَعْضٍ.</p>"
        },
        "16": {
            "verses": {
                "55:16": {
                    "id": 16
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿آلاَءِ رَبِّكُمَا﴾ نِعَمِ رَبِّكُمَا.</h2>\n<h2>﴿تُكَذِّبَانِ﴾ يَا مَعْشَرَ الإِنْسِ وَالجِنِّ.</h2>"
        },
        "17": {
            "verses": {
                "55:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الْمَشْرِقَيْنِ﴾ مَشْرِقِ الشَّمْسِ؛ فِي الشِّتَاءِ، وَالصَّيْفِ.</p>\n<p>﴿الْمَغْرِبَيْنِ﴾ مَغْرِبِ الشَّمْسِ؛ فِي الشِّتَاءِ، وَالصَّيْفِ.</p>"
        },
        "18": {
            "verses": {
                "55:18": {
                    "id": 18
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "19": {
            "verses": {
                "55:19": {
                    "id": 19
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مَرَجَ الْبَحْرَيْنِ﴾ خَلَطَ مَاءَ البَحْرَيْنِ: العَذْبَ، وَالمَالِحَ.</p>"
        },
        "20": {
            "verses": {
                "55:20": {
                    "id": 20
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بَرْزَخٌ﴾ حَاجِزٌ.</h2>\n<p>﴿لاَ يَبْغِيَانِ﴾ لاَ يَطْغَى أَحَدُهُمَا عَلَى الآخَرِ، وَيَذْهَبُ بِخَصَائِصِهِ.</p>"
        },
