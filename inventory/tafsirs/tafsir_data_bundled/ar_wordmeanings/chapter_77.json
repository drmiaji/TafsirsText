            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿رَوَاسِيَ شَامِخَاتٍ﴾ جِبَالاً ثَوَابِتَ، مُرْتَفِعَاتٍ.</h2>\n<h2>﴿فُرَاتًا﴾ عَذْبًا، سَائِغًا.</h2>"
        },
