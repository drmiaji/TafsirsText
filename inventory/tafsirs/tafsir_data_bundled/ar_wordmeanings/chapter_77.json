            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَالْمُرْسَلاَتِ عُرْفًا﴾ قَسَمٌ بِالرِّيَاحِ حِينَ تَهُبُّ مُتَتَابِعَةً يَقْفُو بَعْضُهَا أَثَرَ بَعْضٍ.</p>"
        },
        "2": {
            "verses": {
                "77:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَالْعَاصِفَاتِ عَصْفًا﴾ قَسَمٌ بِالرِّيَاحِ شَدِيدَةِ الهُبُوبِ المُهْلِكَةِ.</p>"
        },
        "3": {
            "verses": {
                "77:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَالنَّاشِرَاتِ نَشْرًا﴾ قَسَمٌ بِالمَلاَئِكَةِ المُوكَلِينَ بِالسُّحُبِ يَسُوقُونَها حَيْثُ شَاءَ اللهُ.</p>"
        },
        "4": {
            "verses": {
                "77:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَالْفَارِقَاتِ فَرْقًا﴾ قَسَمٌ بِالمَلاَئِكَةِ الَّتِي تَنْزِلُ بِما يَفْرِقُ بَيْنَ الحَقِّ، وَالبَاطِلِ.</p>"
        },
        "5": {
            "verses": {
                "77:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَالْمُلْقِيَاتِ ذِكْرًا﴾ قَسَمٌ بِالمَلاَئِكَةِ الَّتِي تَتَلَقَّى الوَحْيَ مِنَ اللهِ، وَتَنْزِلُ بِهِ عَلَى الأَنْبِيَاءِ.</p>"
        },
        "6": {
            "verses": {
                "77:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿عُذْرًا﴾ إِعْذَارًا مِنَ اللهِ إِلَى خَلْقِهِ.</h2>\n<h2>﴿نُذْرًا﴾ لِلإِنْذَارِ مِنَ اللهِ إلَى خَلْقِهِ.</h2>"
        },
        "7": {
            "verses": {
                "77:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿تُوعَدُونَ﴾ مِنْ أَمْرِ القِيَامَةِ وَمَا فِيهَا مِنْ جَزَاءٍ، وَحِسَابٍ.</p>"
        },
        "8": {
            "verses": {
                "77:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿طُمِسَتْ﴾ مُحِيَتْ، وَذَهَبَ نُورُهَا.</h2>"
        },
        "9": {
            "verses": {
                "77:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فُرِجَتْ﴾ تَصَدَّعَتْ، وَتَشَقَّقَتْ.</h2>"
        },
        "10": {
            "verses": {
                "77:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿نُسِفَتْ﴾ تَطَايَرَتْ، وَتَنَاثَرَتْ.</h2>"
        },
        "11": {
            "verses": {
                "77:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أُقِّتَتْ﴾ عُيِّنَ لَهُمْ وَقْتٌ وَأَجَلٌ، لِلْفَصْلِ بَيْنَهُمْ وَبَيْنَ أُمَمِهِمْ.</p>"
        },
        "12": {
            "verses": {
                "77:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لأَِيِّ يَوْمٍ أُجِّلَتْ﴾ لأَِيِّ يَوْمٍ عَظِيمٍ أُخِّرَتِ الرُّسُلُ.</p>"
        },
        "13": {
            "verses": {
                "77:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لِيَوْمِ الْفَصْلِ﴾ لِيَوْمٍ يُفْصَلُ فِيهِ وَيُقْضَى بَيْنَ الخَلاَئِقِ.</p>"
        },
        "14": {
            "verses": {
                "77:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
