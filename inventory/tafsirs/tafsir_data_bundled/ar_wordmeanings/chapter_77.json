            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿قَرَارٍ مَكِينٍ﴾ مَكَانٍ حَصِينٍ مُتَمَكِّنٍ.</h2>"
        },
        "22": {
