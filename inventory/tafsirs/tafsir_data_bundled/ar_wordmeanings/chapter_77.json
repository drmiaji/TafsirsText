            "text": "<h2>﴿مَاءٍ مَهِينٍ﴾ ضَعِيفٍ حَقِيرٍ؛ وَهُوَ النُّطْفَةُ.</h2>"
        },
        "21": {
            "verses": {
                "77:21": {
                    "id": 21
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
