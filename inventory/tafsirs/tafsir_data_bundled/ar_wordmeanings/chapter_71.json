            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مِمَّا خَطِيئَاتِهِمْ﴾ بِسَبَبِ ذُنُوبِهِمْ.</h2>"
        },
        "26": {
            "verses": {
