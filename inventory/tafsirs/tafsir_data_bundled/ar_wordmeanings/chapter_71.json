                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿السَّمَاءَ﴾ المَطَرَ.</h2>\n<h2>﴿مِدْرَارًا﴾ مُتَتَابِعًا، غَزِيرًا.</h2>"
        },
        "12": {
            "verses": {
                "71:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿جَنَّاتٍ﴾ بَسَاتِينَ.</h2>"
        },
        "13": {
            "verses": {
                "71:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لاَ تَرْجُونَ لِلَّهِ وَقَارًا﴾ لاَ تَخَافُونَ عَظَمَةَ اللهِ.</p>"
        },
        "14": {
            "verses": {
                "71:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أَطْوَارًا﴾ عَلَى مَرَاحِلَ مُخْتَلِفَةٍ: نُطْفَةً، ثُمَّ عَلَقَةً، وَهَكَذَا.</p>"
        },
        "15": {
            "verses": {
                "71:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿طِبَاقًا﴾ مُتَطَابِقَةً بَعْضُهَا فَوْقَ بَعْضٍ.</h2>"
        },
        "16": {
            "verses": {
                "71:16": {
                    "id": 16
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿سِرَاجًا﴾ مِصْبَاحًا مُضِيئًا، وَفِيهِ حَرَارَةٌ؛ كَالسِّرَاجِ.</p>"
        },
        "17": {
            "verses": {
                "71:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَنْبَتَكُمْ﴾ أَنْشَأَ أَصْلَكُمْ.</h2>"
        },
