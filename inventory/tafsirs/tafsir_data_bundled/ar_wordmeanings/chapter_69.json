                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿قُطُوفُهَا﴾ ثِمَارُهَا.</h2>\n<p>﴿دَانِيَةٌ﴾ قَرِيبَةٌ يَتَنَاوَلُهَا القَاعِدُ وَالمُضْطَجِعُ.</p>"
        },
        "24": {
            "verses": {
                "69:24": {
                    "id": 24
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿هَنِيئًا﴾ غَيْرَ مُنَغَّصٍ، وَلاَ مُكَدَّرٍ.</h2>\n<h2>﴿أَسْلَفْتُمْ﴾ قَدَّمْتُمْ.</h2>"
        },
