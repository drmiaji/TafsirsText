            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَا حِسَابِيَهْ﴾ مَا جَزَائِي.</h2>"
        },
        "27": {
            "verses": {
                "69:27": {
                    "id": 27
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿كَانَتِ الْقَاضِيَةَ﴾ المَوْتَةَ القَاطِعَةَ لأَِمْرِي، وَلَمْ أُبْعَثْ.</p>"
        },
        "28": {
            "verses": {
                "69:28": {
                    "id": 28
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَا أَغْنَى﴾ مَا نَفَعَنِي.</h2>"
        },
        "29": {
            "verses": {
                "69:29": {
                    "id": 29
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿هَلَكَ عَنِّي﴾ ذَهَبَ عَنِّي.</h2>\n<h2>﴿سُلْطَانِيَهْ﴾ حُجَّتِي، وقُوَّتِي.</h2>"
        },
        "30": {
            "verses": {
                "69:30": {
                    "id": 30
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَغُلُّوهُ﴾ اجْمَعُوا يَدَيْهِ إِلَى عُنُقِهِ بِالأَغْلاَلِ.</p>"
        },
        "31": {
            "verses": {
                "69:31": {
                    "id": 31
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿صَلُّوهُ﴾ أَدْخِلُوهُ، وَأَحْرِقُوهُ بِهَا.</h2>"
        },
        "32": {
            "verses": {
