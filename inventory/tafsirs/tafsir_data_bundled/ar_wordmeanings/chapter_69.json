            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿بِالْقَارِعَةِ﴾ بِالقِيَامَةِ الَّتِي تَقْرَعُ القُلُوبَ بِأَهْوَالِهَا.</p>"
        },
        "5": {
            "verses": {
                "69:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿بِالطَّاغِيَةِ﴾ بِالصَّيْحَةِ الَّتِي جَاوَزَتِ الحَدَّ فِي شِدَّتِهَا.</p>"
        },
        "6": {
            "verses": {
                "69:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿صَرْصَرٍ﴾ بَارِدَةٍ.</h2>\n<h2>﴿عَاتِيَةٍ﴾ شَدِيدَةِ الهُبُوبِ.</h2>"
        },
        "7": {
            "verses": {
                "69:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿سَخَّرَهَا عَلَيْهِمْ﴾ سَلَّطَهَا عَلَيْهِمْ.</h2>\n<h2>﴿حُسُومًا﴾ مُتَتَابِعَةً؛ لاَ تَفْتُرُ، وَلاَ تَنْقَطِعُ.</h2>\n<h2>﴿صَرْعَى﴾ مَوْتَى.</h2>\n<h2>﴿أَعْجَازُ نَخْلٍ﴾ أُصُولُ نَخْلٍ.</h2>\n<h2>﴿خَاوِيَةٍ﴾ خَرِبَةٍ مُتَآكِلَةِ الأَجْوَافِ.</h2>"
        },
        "8": {
            "verses": {
                "69:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "9": {
            "verses": {
                "69:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَالْمُؤْتَفِكَاتُ﴾ أَهْلُ قُرَى قَوْمِ لُوطٍ الَّذِينَ انْقَلَبَتْ بِهِمْ دِيَارُهُمْ.</p>\n<h2>﴿بِالْخَاطِئَةِ﴾ بِالفَعَلاَتِ ذَاتِ الخَطَإِ الجَسِيمِ.</h2>"
        },
        "10": {
            "verses": {
                "69:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿رَابِيَةً﴾ بَالِغَةً فِي الشِّدَّةِ.</h2>"
        },
        "11": {
            "verses": {
                "69:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿طَغَى الْمَاءُ﴾ جَاوَزَ المَاءُ حَدَّهُ، وَارْتَفَعَ فَوْقَ كُلِّ شَيْءٍ.</p>\n<p>﴿الْجَارِيَةِ﴾ السَّفِينَةِ الَّتِي صَنَعَهَا نُوحٌ عليه السلام، تَجْرِي فِي المَاءِ.</p>"
        },
        "12": {
            "verses": {
                "69:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَتَعِيَهَا﴾ تَحْفَظَهَا.</h2>"
        },
        "13": {
            "verses": {
                "69:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الصُّورِ﴾ القَرْنِ الَّذِي يَنْفُخُ فِيهِ إِسْرَافِيلُ عليه السلام.</p>\n<p>﴿نَفْخَةٌ وَاحِدَةٌ﴾ هِيَ: النَّفْخَةُ الأُولَى الَّتِي يَكُونُ بِهَا هَلاَكُ العَالَمِ.</p>"
        },
        "14": {
            "verses": {
                "69:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَحُمِلَتِ﴾ رُفِعَتْ مِنْ أَمَاكِنِهَا.</h2>\n<h2>﴿فَدُكَّتَا﴾ دُقَّتَا، وَكُسِّرَتَا.</h2>"
        },
        "15": {
            "verses": {
                "69:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَقَعَتِ الْوَاقِعَةُ﴾ قَامَتِ القِيَامَةُ.</h2>"
        },
        "16": {
            "verses": {
                "69:16": {
                    "id": 16
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَاهِيَةٌ﴾ ضَعِيفَةٌ، مُسْتَرْخِيَةٌ.</h2>"
        },
        "17": {
            "verses": {
                "69:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَالْمَلَكُ﴾ المَلاَئِكَةُ.</h2>\n<h2>﴿أَرْجَائِهَا﴾ جَوَانِبِهَا، وَأَطْرَافِهَا.</h2>"
        },
        "18": {
            "verses": {
                "69:18": {
                    "id": 18
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿تُعْرَضُونَ﴾ عَلَى اللهِ لِلْجَزَاءِ وَالحِسَابِ.</h2>"
        },
        "19": {
            "verses": {
                "69:19": {
                    "id": 19
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿هَاؤُمُ﴾ خُذُوا.</h2>"
        },
        "20": {
            "verses": {
                "69:20": {
                    "id": 20
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
