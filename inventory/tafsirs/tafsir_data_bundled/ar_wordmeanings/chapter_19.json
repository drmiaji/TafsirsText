            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَلْيَمْدُدْ﴾ فَلْيُمْهِلْهُ، وَلْيُمْلِ لَهُ؛ اسْتِدْرَاجًا.</p>"
        },
