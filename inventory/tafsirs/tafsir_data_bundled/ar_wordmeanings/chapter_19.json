            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿قَرْنٍ﴾ أُمَّةٍ.</h2>\n<h2>﴿أَثَاثًا﴾ مَتَاعًا.</h2>\n<h2>﴿وَرِئْيًا﴾ مَنْظَرًا، وَمَرْأًى.</h2>"
        },
