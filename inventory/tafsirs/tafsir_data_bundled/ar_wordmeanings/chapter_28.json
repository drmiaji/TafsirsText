            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَنَبَذْنَاهُمْ فِي الْيَمِّ﴾ فَأَلْقَيْنَاهُمْ وَأَغْرَقْنَاهُمْ فِي البَحْرِ.</p>"
        },
        "41": {
            "verses": {
