            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿سِحْرَانِ تَظَاهَرَا﴾ تَعَاوَنَا، يَقْصِدُونَ التَّوْرَاةَ وَالقُرْآنَ.</p>"
        },
