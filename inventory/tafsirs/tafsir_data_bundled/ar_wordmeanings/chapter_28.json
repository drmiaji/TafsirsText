                "language_name": "english"
            },
            "text": "<h2>﴿قُرَّةُ عَيْنٍ لِي﴾ مَصْدَرُ سُرُورٍ لِي.</h2>"
        },
        "10": {
            "verses": {
                "28:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَارِغًا﴾ خَالِيًا مِنْ كُلِّ شَيْءٍ إِلاَّ هَمَّ مُوسَى عليه السلام.</p>\n<h2>﴿لَتُبْدِي بِهِ﴾ تُصَرِّحُ بِأَنَّهُ ابْنُهَا.</h2>"
        },
        "11": {
            "verses": {
                "28:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿قُصِّيهِ﴾ تَتَبَّعِي أَثَرَهُ.</h2>\n<h2>﴿عَنْ جُنُبٍ﴾ عَنْ بُعْدٍ.</h2>"
        },
        "12": {
            "verses": {
                "28:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿يَكْفُلُونَهُ لَكُمْ﴾ يَقُومُونَ بِتَرْبِيَتِهِ وَإِرْضَاعِهِ.</p>"
        },
