            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿سَنَشُدُّ عَضُدَكَ﴾ سَنُقَوِّيكَ، وَنُعِينُكَ.</h2>\n<h2>﴿سُلْطَاناً﴾ حُجَّةً، أَوْ تَسَلُّطًا، وَغَلَبَةً.</h2>\n<p>﴿فَلاَ يَصِلُونَ إِلَيْكُمَا﴾ فَلاَ يُصِيبُكُمَا مِنْهُمْ سُوءٌ.</p>\n<h2>﴿بِآيَاتِنَا﴾ بِسَبَبِ آيَاتِنَا.</h2>"
        },
        "36": {
            "verses": {
                "28:36": {
                    "id": 36
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مُفْتَرىً﴾ مُخْتَلَقٌ، تَنْسُبُهُ إِلَى اللهِ كَذِبًا.</h2>"
        },
