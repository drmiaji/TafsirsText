            },
            "text": "<h2>﴿مُعْجِزِينَ﴾ فَائِتِينَ مِنَ العَذَابِ بِالهَرَبِ.</h2>"
        },
        "58": {
            "verses": {
                "24:58": {
                    "id": 58
                }
