            "text": "<p>﴿نُورُ السَّمَاوَاتِ وَالأَرْضِ﴾ أَيْ: هُوَ نُورٌ، وَكِتَابُهُ نُورٌ، وَبِهِ اسْتَنَارَتِ السَّمَاوَاتُ وَالأَرْضُ، يُدَبِّرُ الأَمْرَ فِيهِمَا، وَيَهْدِي أَهْلَهُمَا.</p>\n<p>﴿كَمِشْكَاةٍ﴾ هِيَ: الكُوَّةُ فِي الحَائِطِ غَيْرُ النَّافِذَةِ.</p>\n<h2>﴿دُرِّيٌّ﴾ مُضِيءٌ.</h2>"
        },
        "36": {
            "verses": {
                "24:36": {
                    "id": 36
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فِي بُيُوتٍ﴾ هَذَا النُّورُ فِي مَسَاجِدَ.</h2>\n<h2>﴿تُرْفَعَ﴾ تُعَظَّمَ بِالتَّعْمِيرِ، وَالتَّطْهِيرِ.</h2>\n<h2>﴿بِالْغَدُوِّ وَالآصَالِ﴾ أَوَّلِ النَّهَارِ، وَآخِرِهِ.</h2>"
        },
        "37": {
            "verses": {
                "24:37": {
                    "id": 37
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿يَوْمًا تَتَقَلَّبُ فِيهِ الْقُلُوبُ﴾ أَيْ: بَيْنَ الرَّجَاءِ، وَالخَوْفِ.</p>"
        },
        "38": {
            "verses": {
                "24:38": {
                    "id": 38
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿بِغَيْرِ حِسَابٍ﴾ بِلاَ عَدٍّ، وَيُعْطَى مِنَ الأَجْرِ مَا لاَ يَبْلُغُهُ عَمَلُ العَامِلِ.</p>"
        },
        "39": {
            "verses": {
                "24:39": {
                    "id": 39
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿كَسَرَابٍ﴾ هُوَ مَا يُشَاهَدُ كَالمَاءِ عَلَى الأَرْضِ المُسْتَوِيَةِ فِي الظَّهِيرَةِ.</p>\n<h2>﴿بِقِيعَةٍ﴾ الأَرْضُ المُنْخَفِضَةُ المُسْتَوِيَةُ.</h2>"
        },
        "40": {
            "verses": {
                "24:40": {
                    "id": 40
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لُجِّيٍّ﴾ عَمِيقٍ.</h2>\n<h2>﴿يَغْشَاهُ﴾ يَعْلُوهُ.</h2>"
        },
        "41": {
            "verses": {
                "24:41": {
                    "id": 41
