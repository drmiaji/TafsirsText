            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مَا مَلَكْتُمْ مَفَاتِحَهُ﴾ البَيُوتِ الَّتِي وُكِّلْتُمْ بِحِفْظِهَا فِي غَيْبَةِ أَصْحَابِهَا.</p>\n<h2>﴿أَشْتَاتًا﴾ مُتَفَرِّقِينَ.</h2>"
        },
        "62": {
            "verses": {
