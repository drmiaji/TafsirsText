            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أَمْرٍ جَامِعٍ﴾ أَمْرٍ مُهِمٍّ مِنْ مَصَالِحِ المُسْلِمِينَ جُمِعُوا لَهُ.</p>"
        },
        "63": {
