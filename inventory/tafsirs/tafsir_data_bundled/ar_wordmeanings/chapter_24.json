            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿جَهْدَ أَيْمَانِهِمْ﴾ مُجْتَهِدِينَ فِي الحَلِفِ الأَيْمَان.</p>\n<p>﴿طَاعَةٌ مَعْرُوفَةٌ﴾ طَاعَتُكُمْ مَعْرُوفَةٌ بِأَنَّهَا بِاللِّسَانِ فَقَطْ.</p>"
        },
        "54": {
            "verses": {
                "24:54": {
                    "id": 54
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿عَلَيْهِ مَا حُمِّلَ﴾ عَلَى الرَّسُولِ فِعْلُ مَا أُمِرَ بِهِ مِنْ تَبْلِيغِ الرِّسَالَةِ.</p>\n<p>﴿وَعَلَيْكُمْ مَا حُمِّلْتُمْ﴾ عَلَيْكُمْ فِعْلُ مَا كُلِّفْتُمْ بِهِ مِنَ الاِمْتِثَالِ.</p>"
        },
