            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿النَّشْأَةَ الأُخْرَى﴾ إِعَادَةَ خَلْقِهِمْ بَعْدَ فَنَائِهِمْ.</p>"
        },
        "48": {
            "verses": {
                "53:48": {
                    "id": 48
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أَغْنَى وَأَقْنَى﴾ مَلَّكَهُمُ الأَمْوَالَ، وَأَرْضَاهُمْ بِمَا أَعْطَاهُمْ.</p>"
        },
        "49": {
            "verses": {
                "53:49": {
                    "id": 49
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الشِّعْرَى﴾ نَجْمٍ مُضِيءٍ كَانَ أَهْلُ الجَاهِلِيَّةِ يَعْبُدُونَهُ مِنْ دُونِ اللهِ.</p>"
        },
        "50": {
            "verses": {
                "53:50": {
                    "id": 50
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿عَادًا الأُولَى﴾ قَوْمَ هُودٍ عليه السلام.</h2>"
        },
        "51": {
            "verses": {
                "53:51": {
                    "id": 51
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَثَمُودَ﴾ قَوْمَ صَالِحٍ عليه السلام.</h2>"
        },
        "52": {
            "verses": {
                "53:52": {
                    "id": 52
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
