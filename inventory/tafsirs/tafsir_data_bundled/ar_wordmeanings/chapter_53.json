        },
        "53": {
            "verses": {
                "53:53": {
                    "id": 53
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَالْمُؤْتَفِكَةَ﴾ مَدَائِنَ قَوْمِ لُوطٍ عليه السلام، سُمِّيَتْ بِذَلِكَ؛ لأَِنَّ اللهَ قَلَبَهَا عَلَى أَهْلِهَا.</p>\n<h2>﴿أَهْوَى﴾ أَسْقَطَهَا إِلَى الأَرْضِ بَعْدَ رَفْعِهَا.</h2>"
        },
        "54": {
            "verses": {
                "53:54": {
                    "id": 54
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَغَشَّاهَا﴾ فَأَلْبَسَهَا مِنَ الحِجَارَةِ.</h2>"
        },
        "55": {
            "verses": {
                "53:55": {
                    "id": 55
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿آلاَءِ رَبِّكَ﴾ نِعَمِ رَبِّكَ.</h2>\n<h2>﴿تَتَمَارَى﴾ تَتَشَكَّكُ أَيُّهَا الإِنْسَانُ المُكَذِّبُ.</h2>"
        },
        "56": {
            "verses": {
                "53:56": {
                    "id": 56
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿هَذَا نَذِيرٌ﴾ مُحَمَّدٌ صلّى الله عليه وسلّم مُنْذِرٌ بِالحَقِّ كَمَنْ سَبَقَهُ.</p>"
        },
        "57": {
            "verses": {
                "53:57": {
                    "id": 57
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَزِفَتِ﴾ قَرُبَتْ، وَدَنَا وَقْتُهَا.</h2>\n<p>﴿الآزِفَةُ﴾ القِيَامَةُ، سُمِّيَتْ بِذَلِكَ؛ لِقُرْبِ مِيعَادِهَا.</p>"
        },
        "58": {
            "verses": {
                "53:58": {
                    "id": 58
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿كَاشِفَةٌ﴾ نَفْسٌ تَدْفَعُ أَهْوَالَهَا، وَتَطَّلِعُ عَلَى وَقْتِ وُقُوعِهَا.</p>"
        },
