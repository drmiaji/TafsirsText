            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَالنَّجْمِ إِذَا هَوَى﴾ قَسَمٌ بِالثُّرَيَّا إِذَا غَابَتْ.</p>"
        },
        "2": {
            "verses": {
                "53:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَا ضَلَّ﴾ مَا حَادَ عَنِ الحَقِّ.</h2>\n<h2>﴿وَمَا غَوَى﴾ مَا اعْتَقَدَ بَاطِلاً قَطُّ.</h2>"
        },
        "3": {
            "verses": {
                "53:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "4": {
            "verses": {
                "53:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿إِنْ هُوَ﴾ أَيِ: القُرْآنُ، وَالسُّنَّةُ.</h2>"
        },
        "5": {
            "verses": {
                "53:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿شَدِيدُ الْقُوَى﴾ مَلَكٌ شَدِيدُ القُوَّةِ؛ وَهُوَ جِبْرِيلُ عليه السلام.</p>"
        },
        "6": {
            "verses": {
                "53:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿ذُو مِرَّةٍ﴾ صَاحِبُ قُوَّةٍ ، وَمَنْظَرٍ حَسَنٍ.</h2>\n<p>﴿فَاسْتَوَى﴾ ظَهَرَ مُسْتَوِيًا عَلَى صُورَتِهِ الحَقِيقِيَّةِ لِلرَّسُولِ صلّى الله عليه وسلّم.</p>"
        },
        "7": {
            "verses": {
                "53:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بِالأُفُقِ الأَعْلَى﴾ أُفُقِ الشَّمْسِ عِنْدَ مَطْلَعِهَا.</h2>"
        },
        "8": {
            "verses": {
                "53:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿دَنَا﴾ اقْتَرَبَ جِبْرِيلُ عليه السلام مِنْ نَبِيِّنَا مُحَمَّدٍ صلّى الله عليه وسلّم.</p>\n<h2>﴿فَتَدَلَّى﴾ زَادَ فِي القُرْبِ.</h2>"
        },
        "9": {
            "verses": {
                "53:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿قَابَ قَوْسَيْنِ﴾ كَانَ دُنُوُّهُ مِقْدَارَ قَوْسَيْنِ.</h2>"
        },
        "10": {
            "verses": {
                "53:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿عَبْدِهِ﴾ عَبْدِ اللهِ؛ وَهُوَ نَبِيُّنَا مُحَمَّدٌ صلّى الله عليه وسلّم.</p>"
        },
        "11": {
            "verses": {
                "53:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "12": {
            "verses": {
                "53:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أَفَتُمَارُونَهُ﴾ أَتُكَذِّبُونَ مُحَمَّدًا صلّى الله عليه وسلّم؛ فَتُجَادِلُونَهُ؟!</p>"
        },
        "13": {
            "verses": {
                "53:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿نَزْلَةً أُخْرَى﴾ مَرَّةً أُخْرَى فِي صُورَتِهِ الخِلْقِيَّةِ.</p>"
        },
        "14": {
            "verses": {
                "53:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿سِدْرَةِ الْمُنْتَهَى﴾ شَجَرَةِ نَبِقٍ فِي السَّمَاءِ السَّابِعَةِ، يَنْتَهِي إِلَيْهَا مَا يُعْرَجُ بِهِ مِنَ الأَرْضِ، وَيَنْتَهِي إِلَيْهَا مَا يُهْبَطُ بِهِ مِنْ فَوْقِهَا.</p>"
        },
        "15": {
            "verses": {
                "53:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
