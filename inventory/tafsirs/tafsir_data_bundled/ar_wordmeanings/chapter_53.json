            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مَا زَاغَ الْبَصَرُ﴾ مَا مَالَ بَصَرُهُ يَمِينًا، وَلاَ شِمَالاً.</p>\n<h2>﴿وَمَا طَغَى﴾ مَا جَاوَزَ مَا أُمِرَ بِرُؤْيَتِهِ.</h2>"
        },
        "18": {
            "verses": {
                "53:18": {
                    "id": 18
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لَقَدْ رَأَى﴾ لَيْلَةَ المِعْرَاجِ.</h2>"
        },
        "19": {
            "verses": {
                "53:19": {
                    "id": 19
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿اللاََّّتَ وَالْعُزَّى﴾ اسْمَانِ لِصَنَمَيْنِ كَانُوا يَعْبُدُونَهُمَا فِي الجَاهِلِيَّةِ.</p>"
        },
        "20": {
            "verses": {
                "53:20": {
                    "id": 20
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَنَاةَ﴾ اسْمَ صَنَمٍ كَانُوا يَعْبُدُونَهُ فِي الجَاهِلِيَّةِ.</p>"
        },
