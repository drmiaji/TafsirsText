            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَكْدَى﴾ تَوَقَّفَ عَنِ العَطَاءِ، وَقَطَعَ مَعْرُوفَهُ بُخْلاً.</p>"
        },
