            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَلاَ تَغُرَّنَّكُمُ﴾ لاَ تَخْدَعَنَّكُمْ، وَلاَ تُلْهِيَنَّكُمْ.</p>\n<h2>﴿الْغَرُورُ﴾ الشَّيْطَانُ.</h2>"
        },
        "6": {
            "verses": {
