            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَلاَ تَذْهَبْ نَفْسُكَ﴾ فَلاَ تُهْلِكْهَا.</h2>\n<h2>﴿حَسَرَاتٍ﴾ حُزْنًا عَلَى كُفْرِ هَؤُلاَءِ الضَّالِّينَ.</h2>"
        },
        "9": {
            "verses": {
                "35:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَتُثِيرُ﴾ تُحَرِّكُ.</h2>\n<h2>﴿مَيِّتٍ﴾ مُجْدِبٍ.</h2>"
        },
        "10": {
            "verses": {
                "35:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْعِزَّةَ﴾ الشَّرَفَ، وَالمَنَعَةَ.</h2>\n<p>﴿الْكَلِمُ الطَّيِّبُ﴾ الكَلاَمُ الحَسَنُ؛ وَهُوَ ذِكْرُ اللهِ.</p>\n<h2>﴿يَبُورُ﴾ يَفْسُدُ، وَيَبْطُلُ.</h2>"
        },
        "11": {
            "verses": {
                "35:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَزْوَاجًا﴾ ذُكُورًا وَإِنَاثًا.</h2>\n<h2>﴿مُعَمَّرٍ﴾ طَوِيلِ العُمُرِ.</h2>\n<h2>﴿فِي كِتَابٍ﴾ هُوَ: اللَّوْحُ المَحْفُوظُ.</h2>"
        },
        "12": {
            "verses": {
                "35:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فُرَاتٌ﴾ شَدِيدُ العُذُوبَةِ.</h2>\n<h2>﴿سَائِغٌ﴾ سَهْلٌ مُرُورُهُ فِي الحَلْقِ.</h2>\n<h2>﴿أُجَاجٌ﴾ شَدِيدُ المُلُوحَةِ.</h2>\n<h2>﴿لَحْمًا طَرِيًّا﴾ هُوَ: السَّمَكُ.</h2>\n<h2>﴿حِلْيَةً﴾ هِيَ: اللُّؤْلُؤُ، وَالمَرْجَانُ.</h2>\n<h2>﴿الْفُلْكَ﴾ السُّفُنَ.</h2>\n<h2>﴿مَوَاخِرَ﴾ تَشُقُّ المِيَاهَ.</h2>"
        },
        "13": {
            "verses": {
                "35:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿يُولِجُ﴾ يُدْخِلُ مِنْ سَاعَاتِ اللَّيْلِ فِي النَّهَارِ، وَالعَكْسُ، فَتَحْدُثُ الزِّيَادَةُ وَالنَّقْصُ فِيهِمَا.</p>\n<h2>﴿وَسَخَّرَ﴾ ذَلَّلَ.</h2>\n<h2>﴿لأَِجَلٍ مُسَمّىً﴾ لِوَقْتٍ مَعْلُومٍ مُقَدَّرٍ.</h2>\n<p>﴿قِطْمِيرٍ﴾ هِيَ: القِشْرَةُ الرَّقِيقَةُ البَيْضَاءُ عَلَى النَّوَاةِ.</p>"
        },
        "14": {
            "verses": {
                "35:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَكْفُرُونَ بِشِرْكِكُمْ﴾ يَتَبَرَّؤُونَ مِنْكُمْ.</h2>"
        },
