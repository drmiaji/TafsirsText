            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿نَكِيرِ﴾ إِنْكَارِي عَلَيْهِمْ، وَعُقُوبَتِي لَهُمْ.</h2>"
        },
        "27": {
            "verses": {
                "35:27": {
                    "id": 27
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿جُدَدٌ﴾ ذَاتُ طَرَائِقَ وَخُطُوطٍ مُخْتَلِفَةِ الأَلْوَانِ.</p>\n<h2>﴿وَغَرَابِيبُ سُودٌ﴾ شَدِيدَةُ السَّوَادِ؛ كَالأَغْرِبَةِ.</h2>"
        },
