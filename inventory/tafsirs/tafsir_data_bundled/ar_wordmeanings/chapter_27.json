            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الصُّورِ﴾ القَرْنِ الَّذِي يَنْفُخُ فِيهِ إِسْرَافِيلُ عليه السلام.</p>\n<h2>﴿دَاخِرِينَ﴾ صَاغِرِينَ أَذِلاَّءَ.</h2>"
        },
        "88": {
            "verses": {
