                "language_name": "english"
            },
            "text": "<h2>﴿لَتُلَقَّى﴾ لَتَتَلَقَّى.</h2>\n<h2>﴿مِنْ لَدُنْ﴾ من عِنْدِ.</h2>"
        },
        "7": {
            "verses": {
                "27:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿آنَسْتُ﴾ أَبْصَرْتُ.</h2>\n<h2>﴿بِشِهَابٍ قَبَسٍ﴾ بِشُعْلَةِ نَارٍ.</h2>\n<h2>﴿تَصْطَلُونَ﴾ تَسْتَدْفِئُونَ بِهَا مِنَ البَرْدِ.</h2>"
        },
        "8": {
            "verses": {
                "27:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بُورِكَ﴾ قَدِّسَ وَطَهِّرَ.</h2>\n<p>﴿وَسُبْحَانَ اللهِ﴾ تَنْزِيهًا لِلهِ عَمَّا لاَ يَلِيقُ بِهِ.</p>"
        },
        "9": {
            "verses": {
                "27:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
