            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الْمَدِينَةِ﴾ مَدِينَةِ صَالِحٍ عليه السلام ، وَهِيَ الحِجْرُ شَمَالَ غَرْبِ الجَزِيرَةِ العَرَبِيَّةِ.</p>"
        },
        "49": {
            "verses": {
                "27:49": {
                    "id": 49
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿تَقَاسَمُوا﴾ حَلَفَ كُلُّ وَاحِدٍ مِنْهُمْ لِلآخَرِ.</h2>\n<p>﴿لَنُبَيِّتَنَّهُ﴾ لَنَأْتِيَنَّهُ بِاللَّيْلِ بَغْتَةً فَنَقْتُلُهُ.</p>\n<h2>﴿لِوَلِيِّهِ﴾ قَرِيبِهِ الَّذِي يُطَالِبُ بِدَمِهِ.</h2>"
        },
