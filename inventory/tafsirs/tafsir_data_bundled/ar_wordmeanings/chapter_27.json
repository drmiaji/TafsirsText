            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لاَ يَحْطِمَنَّكُمْ﴾ لاَ يُهْلِكَنَّكُمْ.</h2>"
        },
