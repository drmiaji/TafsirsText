            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿تَهْتَزُّ﴾ تَتَحَرَّكُ فِي خِفَّةٍ.</h2>\n<h2>﴿جَآنٌّ﴾ حَيَّةٌ خَفِيفَةٌ.</h2>\n<h2>﴿مُدْبِرًا﴾ هَارِبًا.</h2>\n<h2>﴿يُعَقِّبْ﴾ يَرْجِعْ عَلَى عَقِبِهِ.</h2>"
        },
        "11": {
            "verses": {
                "27:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿إِلاَّ مَنْ ظَلَمَ﴾ لَكِنْ مَنْ ظَلَمَ نَفْسَهُ.</h2>"
        },
        "12": {
            "verses": {
                "27:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿جَيْبِكَ﴾ فَتْحَةِ القَمِيصِ الَّتِي يَدْخُلُ مِنْهَا الرَّأْسُ.</p>\n<h2>﴿مِنْ غَيْرِ سُوءٍ﴾ مِنْ غَيْرِ بَرَصٍ وَلاَ مَرَضٍ.</h2>"
        },
        "13": {
            "verses": {
                "27:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿آيَاتُنَا﴾ مُعْجِزَاتُنَا.</h2>\n<h2>﴿مُبْصِرَةً﴾ ظَاهِرَةً بَيِّنَةً.</h2>\n<h2>﴿مُبِينٍ﴾ وَاضِحٍ بَيِّنٍ.</h2>"
        },
