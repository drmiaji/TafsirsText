            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿هَلْ أَتَى﴾ قَدْ مَضَى.</h2>\n<h2>﴿حِينٌ﴾ زَمَنٌ طَوِيلٌ.</h2>"
        },
        "2": {
            "verses": {
                "76:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أَمْشَاجٍ﴾ مُخْتَلِطَةٍ مِنْ مَاءِ الرَّجُلِ وَمَاءِ المَرْأَةِ.</p>\n<h2>﴿نَبْتَلِيهِ﴾ نَخْتَبِرُهُ بِالأَوَامِرِ، وَالنَّوَاهِي.</h2>"
        },
        "3": {
            "verses": {
                "76:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿هَدَيْنَاهُ السَّبِيلَ﴾ بَيَّنَّا لَهُ طَرِيقَ الخَيْرِ، وَالشَّرِّ.</p>"
        },
        "4": {
            "verses": {
                "76:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿سَلاَسِلَ﴾ قُيُودًا مِنْ حَدِيدٍ تُشَدُّ بِهَا أَرْجُلُهُمْ.</p>\n<p>﴿وَأَغْلاَلاً﴾ تُغَلُّ وَتُجْمَعُ بِهَا أَيْدِيهِمْ إِلَى أَعْنَاقِهِمْ.</p>\n<h2>﴿وَسَعِيرًا﴾ نَارًا يُحْرَقُونَ بِهَا.</h2>"
        },
        "5": {
            "verses": {
                "76:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿كَأْسٍ﴾ إِنَاءِ شُرْبِ الخَمْرِ، وَفِيهَا خَمْرٌ.</h2>\n<p>﴿مِزَاجُهَا كَافُورًا﴾ مَخْلُوطَةً بِأَحْسَنِ أَنْوَاعِ الطِّيبِ، وَهُوَ مَاءُ الكَافُورِ.</p>"
        },
        "6": {
            "verses": {
                "76:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَشْرَبُ بِهَا﴾ يَشْرَبُونَ مُتَلَذِّذِينَ بِهَا.</h2>\n<p>﴿يُفَجِّرُونَهَا﴾ يُجْرُونَهَا إِجْرَاءً سَهْلاً حَيْثُ شَاؤُوا.</p>"
        },
        "7": {
            "verses": {
                "76:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿بِالنَّذْرِ﴾ بِمَا أَوْجَبُوا عَلَى أَنْفُسِهِمْ مِنَ الطَّاعَاتِ.</p>\n<h2>﴿مُسْتَطِيرًا﴾ فَاشِيًا مُنْتَشِرًا عَلَى النَّاسِ.</h2>"
        },
        "8": {
            "verses": {
                "76:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَيَتِيمًا﴾ طِفْلاً مَاتَ وَالِدُهُ قَبْلَ بُلُوغِهِ، وَلاَ مَالَ لَهُ.</p>\n<h2>﴿وَأَسِيرًا﴾ المَأْخُوذَ فِي الحَرْبِ.</h2>"
        },
        "9": {
            "verses": {
                "76:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "10": {
            "verses": {
                "76:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿عَبُوسًا﴾ تَكْلَحُ فِيهِ الوُجُوهُ لِهَوْلِهِ.</h2>\n<h2>﴿قَمْطَرِيرًا﴾ شَدِيدَ العُبُوسِ.</h2>"
        },
        "11": {
            "verses": {
                "76:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَلَقَّاهُمْ﴾ أَعْطَاهُمْ.</h2>\n<h2>﴿نَضْرَةً﴾ حُسْنًا وَنُورًا.</h2>"
        },
        "12": {
            "verses": {
                "76:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "13": {
            "verses": {
                "76:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الأَرَائِكِ﴾ الأَسِرَّةِ المُزَيَّنَةِ بِفَاخِرِ الثِّيَابِ، وَالسُّتُورِ.</p>\n<h2>﴿زَمْهَرِيرًا﴾ شِدَّةَ بَرْدٍ.</h2>"
        },
        "14": {
            "verses": {
                "76:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَدَانِيَةً﴾ قَرِيبَةً أَشْجَارُهَا.</h2>\n<h2>﴿وَذُلِّلَتْ قُطُوفُهَا﴾ سُهِّلَ لَهُمْ أَخْذُ ثِمَارِهَا.</h2>"
        },
        "15": {
            "verses": {
                "76:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿قَوَارِيرَا﴾ مِنَ الزُّجَاجِ.</h2>"
        },
        "16": {
            "verses": {
                "76:16": {
                    "id": 16
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿قَدَّرُوهَا﴾ قَدَّرَهَا السُّقَاةُ عَلَى مِقْدَارِ مَا يَشْتَهِي الشَّارِبُونَ.</p>"
        },
        "17": {
            "verses": {
                "76:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿كَأْسًا﴾ إِنَاءً مَمْلُوءًا خَمْرًا.</h2>"
        },
        "18": {
            "verses": {
                "76:18": {
                    "id": 18
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿تُسَمَّى سَلْسَبِيلاً﴾ سُمِّيَتْ بِذَلِكَ؛ لِسَلاَسَةِ شُرْبِهَا، وَسُهُولَةِ مَسَاغِهِ.</p>"
        },
        "19": {
            "verses": {
                "76:19": {
                    "id": 19
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وِلْدَانٌ مُخَلَّدُونَ﴾ غِلْمَانٌ لِلْخِدْمَةِ دَائِمُونَ عَلَى حَالِهِمْ.</p>\n<p>﴿لُؤْلُؤًا﴾ كَاللُّؤْلُؤِ المُفَرَّقِ المُضِيءِ؛ لِحُسْنِهِمْ، وَصَفَاءِ أَلْوَانِهِمْ.</p>"
        },
        "20": {
            "verses": {
                "76:20": {
                    "id": 20
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِذَا رَأَيْتَ ثَمَّ﴾ وَإِذَا أَبْصَرْتَ أَيَّ مَكَانٍ فِي الجَنَّةِ.</p>"
        },
        "21": {
            "verses": {
                "76:21": {
                    "id": 21
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿عَالِيَهُمْ﴾ يَعْلُوهُمْ.</h2>\n<p>﴿ثِيَابُ سُنْدُسٍ﴾ الحَرِيرُ الرَّقِيقُ الأَخْضَرُ؛ وَهَذَا بَاطِنُ الثِّيَابِ.</p>\n<p>﴿وَإِسْتَبْرَقٌ﴾ الحَرِيرُ الغَلِيظُ؛ وَهَذَا ظَاهِرُ الثِّيَابِ.</p>\n<h2>﴿طَهُورًا﴾ لاَ رِجْسَ فِيهِ، وَلاَ دَنَسَ.</h2>"
        },
        "22": {
            "verses": {
                "76:22": {
                    "id": 22
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿سَعْيُكُمْ﴾ عَمَلُكُمُ الصَّالِحُ فِي الدُّنْيَا.</h2>"
        },
