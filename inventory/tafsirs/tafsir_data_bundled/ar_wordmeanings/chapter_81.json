            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿رَجِيمٍ﴾ مَرْجُومٍ، مَطْرُودٍ مِنْ رَحْمَةِ اللهِ.</h2>"
        },
