            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿إِنْ هُوَ﴾ مَا هُوَ.</h2>\n<h2>﴿لِلْعَالَمِينَ﴾ الإِنْسِ، وَالجِنِّ.</h2>"
        },
