                "81:23": {
                    "id": 23
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿رَآهُ بِالأُفُقِ﴾ رَأَى نَبِيُّنَا مُحَمَّدٌ صلّى الله عليه وسلّم جِبْرِيلَ عليه السلام فِي الأُفُقِ عَلَى صُورَتِهِ الَّتِي خُلِقَ عَلَيْهَا.</p>"
        },
        "24": {
            "verses": {
                "81:24": {
                    "id": 24
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿بِضَنِينٍ﴾ بِبَخِيلٍ فِي تَبْلِيغِ الوَحْيِ، وَفِي قِرَاءَةٍ: (بِظَنِينٍ)، أَيْ: مُتَّهَمٍ عَلَى الْوَحْيِ.</p>"
        },
        "25": {
            "verses": {
