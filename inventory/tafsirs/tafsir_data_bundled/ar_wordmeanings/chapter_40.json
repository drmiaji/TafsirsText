            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بِالْكِتَابِ﴾ بِالقُرْآنِ.</h2>"
        },
        "71": {
            "verses": {
                "40:71": {
                    "id": 71
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَالسَّلاَسِلُ﴾ القُيُودُ فِي الأَرْجُلِ.</h2>"
        },
        "72": {
            "verses": {
                "40:72": {
                    "id": 72
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْحَمِيمِ﴾ المَاءِ الَّذِي بَلَغَ غَايَةَ الحَرَارَةِ.</h2>\n<h2>﴿يُسْجَرُونَ﴾ يُوقَدُ عَلَيْهِمْ.</h2>"
        },
