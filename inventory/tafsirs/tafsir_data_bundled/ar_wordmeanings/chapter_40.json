                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿عُذْتُ﴾ اسْتَجَرْتُ.</h2>"
        },
        "28": {
            "verses": {
                "40:28": {
                    "id": 28
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مُسْرِفٌ﴾ مُتَجَاوِزٌ لِلْحَدِّ بِتَرْكِ الحَقِّ، وَاتِّبَاعِ البَاطِلِ.</p>"
        },
        "29": {
            "verses": {
                "40:29": {
                    "id": 29
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿ظَاهِرِينَ﴾ غَالِبِينَ عَالِينَ.</h2>\n<h2>﴿بَأْسِ اللَّهِ﴾ عَذَابِ اللهِ.</h2>\n<h2>﴿مَا أُرِيكُمْ﴾ مَا أُشِيرُ عَلَيْكُمْ.</h2>\n<h2>﴿أَهْدِيكُمْ﴾ أَدْعُوكُمْ.</h2>\n<h2>﴿سَبِيلَ الرَّشَادِ﴾ طَرِيقَ الحَقِّ وَالصَّوَابِ.</h2>"
        },
        "30": {
            "verses": {
                "40:30": {
                    "id": 30
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الأَحْزَابِ﴾ الأُمَمِ المُتَحَزِّبَةِ عَلَى أَنْبِيَائِهَا، المُعَادِيَةِ لَهُمْ.</p>"
        },
        "31": {
            "verses": {
                "40:31": {
                    "id": 31
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿دَأْبِ قَوْمِ نُوحٍ﴾ عَادَتِهِمْ فِي الكُفْرِ وَالتَّكْذِيبِ.</p>"
        },
        "32": {
            "verses": {
                "40:32": {
                    "id": 32
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿يَوْمَ التَّنَادِ﴾ يَوْمَ القِيَامَةِ الَّذِي يُنَادِي النَّاسُ فِيهِ بَعْضُهُمْ بَعْضًا.</p>"
        },
        "33": {
            "verses": {
                "40:33": {
                    "id": 33
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مُدْبِرِينَ﴾ هَارِبِينَ.</h2>\n<h2>﴿عَاصِمٍ﴾ مَانِعٍ يَمْنَعُكُمْ.</h2>"
        },
        "34": {
            "verses": {
                "40:34": {
                    "id": 34
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿شَكٍّ﴾ رِيبَةٍ.</h2>\n<h2>﴿هَلَكَ﴾ مَاتَ.</h2>\n<h2>﴿مُسْرِفٌ﴾ مُتَجَاوِزٌ لِلْحَدِّ فِي الضَّلاَلِ.</h2>\n<h2>﴿مُرْتَابٌ﴾ شَاكٌّ فِي اللهِ.</h2>"
        },
        "35": {
            "verses": {
                "40:35": {
                    "id": 35
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿سُلْطَانٍ﴾ حُجَّةٍ.</h2>\n<h2>﴿يَطْبَعُ﴾ يَخْتِمُ.</h2>"
        },
        "36": {
            "verses": {
                "40:36": {
                    "id": 36
                }
            },
