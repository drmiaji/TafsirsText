            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لاَ جَرَمَ﴾ حَقًّا.</h2>\n<p>﴿لَيْسَ لَهُ دَعْوَةٌ﴾ لاَ يَسْتَحِقُّ الدَّعْوَةَ إِلَى عِبَادَتِهِ، وَلاَ يُلْجَأُ إِلَيْهِ؛ لِعَجْزِهِ.</p>\n<h2>﴿مَرَدَّنَا﴾ مَرْجِعَنَا، وَمَصِيرَنَا.</h2>"
        },
        "44": {
            "verses": {
                "40:44": {
                    "id": 44
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَأُفَوِّضُ﴾ أَعْتَصِمُ، وَأَلْجَأُ، وَأَتَوَكَّلُ.</h2>"
        },
        "45": {
            "verses": {
                "40:45": {
                    "id": 45
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿سَيِّئَاتِ مَا مَكَرُوا﴾ عُقُوبَاتِ مَكْرِهِمْ مِنْ إِرَادَةِ إِهْلاَكِهِ.</p>\n<h2>﴿وَحَاقَ﴾ نَزَلَ، وَأَحَاطَ.</h2>"
        },
        "46": {
            "verses": {
                "40:46": {
                    "id": 46
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿غُدُوًّا وَعَشِيًّا﴾ أَوَّلَ النَّهَارِ، وَآخِرَهُ.</h2>"
        },
        "47": {
            "verses": {
                "40:47": {
                    "id": 47
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَتَحَآجُّونَ﴾ يَتَخَاصَمُونَ.</h2>\n<h2>﴿مُغْنُونَ﴾ دَافِعُونَ.</h2>"
        },
        "48": {
