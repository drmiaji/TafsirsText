            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿دَاخِرِينَ﴾ صَاغِرِينَ، حَقِيرِينَ.</h2>"
        },
        "61": {
            "verses": {
                "40:61": {
                    "id": 61
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لِتَسْكُنُوا﴾ لِتَرْتَاحُوا.</h2>\n<h2>﴿مُبْصِرًا﴾ مُضِيئًا.</h2>"
        },
        "62": {
            "verses": {
                "40:62": {
                    "id": 62
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَأَنَّى تُؤْفَكُونَ﴾ كَيْفَ تُصْرَفُونَ عَنِ الإِيمَانِ بِهِ؟!</p>"
        },
        "63": {
            "verses": {
                "40:63": {
                    "id": 63
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يُؤْفَكُ﴾ يُصْرَفُ.</h2>"
        },
        "64": {
            "verses": {
                "40:64": {
                    "id": 64
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَتَبَارَكَ﴾ تَكَاثَرَ خَيْرُهُ وَفَضْلُهُ.</h2>"
        },
        "65": {
            "verses": {
