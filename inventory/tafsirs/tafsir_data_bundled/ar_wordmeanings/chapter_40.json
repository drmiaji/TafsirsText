            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَنْ أُسْلِمَ﴾ أَنْ أَخْضَعَ وَأَنْقَادَ بِالطَّاعَةِ.</h2>"
        },
        "67": {
            "verses": {
                "40:67": {
                    "id": 67
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿عَلَقَةٍ﴾ الدَّمِ الغَلِيظِ؛ المُتَعَلِّقِ بِجِدَارِ الرَّحِمِ، وَهُوَ أَحَدُ أَطْوَارِ الجَنِينِ.</p>\n<h2>﴿لِتَبْلُغُوا أَشُدَّكُمْ﴾ لِتَتَكَامَلَ قُوَّتُكُمْ.</h2>\n<p>﴿أَجَلاً مُسَمّىً﴾ مُدَّةً مُقَدَّرَةً تَنْتَهِي بِهَا أَعْمَارُكُمْ.</p>"
        },
        "68": {
            "verses": {
                "40:68": {
                    "id": 68
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "69": {
            "verses": {
                "40:69": {
                    "id": 69
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أَنَّى يُصْرَفُونَ﴾ كَيْفَ يَعْدِلُونَ عَنْهَا مَعْ صِحَّتِهَا؟!</p>"
        },
        "70": {
