            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَقِهِمُ السَّيِّئَاتِ﴾ اصْرِفْ عَنْهُمْ سُوءَ عَاقِبَةِ سَيِّئَاتِهِمْ.</p>"
        },
        "10": {
            "verses": {
                "40:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يُنَادَوْنَ﴾ يَدْعُوهُمْ خَزَنَةُ جَهَنَّمَ.</h2>\n<h2>﴿لَمَقْتُ اللَّهِ﴾ المَقْتُ: البُغْضُ الشَّدِيدُ.</h2>"
        },
        "11": {
            "verses": {
                "40:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أَمَتَّنَا اثْنَتَيْنِ﴾ مَرَّةً قَبْلَ نَفْخِ الأَرْوَاحِ فِي الأَجِنَّةِ، وَمَرَّةً حِينَ انْقَضَى أَجَلُنَا.</p>\n<p>﴿وَأَحْيَيْتَنَا اثْنَتَيْنِ﴾ مَرَّةً فِي الدُّنْيَا، وَمَرَّةً فِي الآخِرَةِ.</p>\n<h2>﴿سَبِيلٍ﴾ طَرِيقٍ نَخْرُجُ بِهِ مِنَ النَّارِ.</h2>"
        },
        "12": {
            "verses": {
