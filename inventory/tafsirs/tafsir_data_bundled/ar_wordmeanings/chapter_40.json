            "text": "<h2>﴿ذِي الطَّوْلِ﴾ صَاحِبِ الإِنْعَامِ وَالتَّفَضُّلِ.</h2>\n<h2>﴿الْمَصِيرُ﴾ المَرْجِعُ.</h2>"
        },
        "4": {
            "verses": {
                "40:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَلاَ يَغْرُرْكَ﴾ فَلاَ يَخْدَعْكَ.</h2>\n<p>﴿تَقَلُّبُهُمْ﴾ تَنَقُّلُهُمْ وَتَرَدُّدُهُمْ بِأَنْوَاعِ التِّجَارَاتِ وَالنَّعِيمِ.</p>"
        },
        "5": {
            "verses": {
                "40:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَالأَحْزَابُ﴾ الأُمَمُ المُتَحَزِّبَةُ عَلَى رُسُلِهِمْ، مُعْلِنِينَ الحَرْبَ عَلَيْهِمْ.</p>\n<h2>﴿لِيَأْخُذُوهُ﴾ لِيَقْتُلُوهُ.</h2>\n<h2>﴿لِيُدْحِضُوا﴾ لِيُبْطِلُوا.</h2>"
        },
        "6": {
            "verses": {
                "40:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿حَقَّتْ﴾ وَجَبَتْ.</h2>"
        },
        "7": {
            "verses": {
                "40:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿سَبِيلَكَ﴾ طَرِيقَكَ؛ وَهُوَ الإِسْلاَمُ.</h2>\n<h2>﴿وَقِهِمُ﴾ جَنِّبْهُمْ.</h2>"
        },
        "8": {
            "verses": {
