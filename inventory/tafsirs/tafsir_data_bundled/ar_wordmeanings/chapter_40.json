                "language_name": "english"
            },
            "text": "<h2>﴿ضَلاَلٍ﴾ ضَيَاعٍ؛ فَلاَ يُقْبَلُ، وَلاَ يُسْتَجَابُ.</h2>"
        },
        "51": {
            "verses": {
                "40:51": {
                    "id": 51
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الأَشْهَادُ﴾ مَنْ يَشْهَدُونَ عَلَى المُكَذِّبِينَ؛ مِنَ المَلاَئِكَةِ وَالأَنْبِيَاءِ وَالمُؤْمِنِينَ.</p>"
        },
        "52": {
            "verses": {
                "40:52": {
                    "id": 52
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَعْذِرَتُهُمْ﴾ عُذْرُهُمْ.</h2>\n<h2>﴿اللَّعْنَةُ﴾ الطَّرْدُ وَالإِبْعَادُ مِنْ رَحْمَةِ اللهِ.</h2>"
        },
        "53": {
            "verses": {
                "40:53": {
                    "id": 53
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْكِتَابَ﴾ التَّوْرَاةَ.</h2>"
        },
        "54": {
            "verses": {
                "40:54": {
                    "id": 54
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لأُِولِي الأَلْبَابِ﴾ لأَِصْحَابِ العُقُولِ السَّلِيمَةِ.</h2>"
        },
        "55": {
            "verses": {
                "40:55": {
                    "id": 55
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَسَبِّحْ بِحَمْدِ رَبِّكَ﴾ نَزِّهْ رَبَّكَ وَاحْمَدْهُ.</h2>\n<p>﴿بِالْعَشِيِّ وَالإِبْكَارِ﴾ فِي آخِرِ النَّهَارِ، وَأَوَّلِهِ.</p>"
        },
        "56": {
            "verses": {
                "40:56": {
                    "id": 56
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿سُلْطَانٍ﴾ حُجَّةٍ بَيِّنَةٍ.</h2>\n<h2>﴿إِنْ فِي﴾ مَا فِي.</h2>\n<p>﴿مَا هُمْ بِبَالِغِيهِ﴾ لَيْسُوا بِوَاصِلِينَ لِلْعُلُوِّ عَلَيْكَ، وَلاَ لِلْفَضْلِ الَّذِي خَصَّكَ اللهُ بِهِ.</p>\n<h2>﴿فَاسْتَعِذْ﴾ اعْتَصِمْ.</h2>"
        },
        "57": {
            "verses": {
                "40:57": {
                    "id": 57
                }
            },
