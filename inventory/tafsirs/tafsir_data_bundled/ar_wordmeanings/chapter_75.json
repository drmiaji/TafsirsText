                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "4": {
            "verses": {
                "75:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿نُسَوِّيَ بَنَانَهُ﴾ نَجْعَلَ أَصَابِعَ يَدَيْهِ وَرِجْلَيْهِ شَيْئًا مُسْتَوِيًا؛ كَخُفِّ البَعِيرِ، أَوْ نُعِيدَ خَلْقَهَا كَمَا كَانَتْ.</p>"
        },
        "5": {
            "verses": {
                "75:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "6": {
            "verses": {
                "75:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَيَّانَ﴾ مَتَى؟</h2>"
        },
        "7": {
            "verses": {
                "75:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿بَرِقَ الْبَصَرُ﴾ تَحَيَّرَ البَصَرُ وَدُهِشَ لأَِهْوَالِ القِيَامَةِ.</p>"
        },
        "8": {
            "verses": {
                "75:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "9": {
            "verses": {
                "75:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَجُمِعَ الشَّمْسُ وَالْقَمَرُ﴾ قُرِنَ بَيْنَهُمَا فِي الطُّلُوعِ مِنَ المَغْرِبِ مُظْلِمَيْنِ.</p>"
        },
        "10": {
            "verses": {
                "75:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "11": {
            "verses": {
                "75:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لاَ وَزَرَ﴾ لاَ مَلْجَأَ وَلاَ مَنْجَى لَهُ مِنَ اللهِ.</h2>"
        },
        "12": {
            "verses": {
                "75:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْمُسْتَقَرُّ﴾ المَرْجِعُ، وَالمَصِيرُ.</h2>"
        },
        "13": {
            "verses": {
                "75:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "14": {
            "verses": {
                "75:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿عَلَى نَفْسِهِ بَصِيرَةٌ﴾ شَاهِدٌ تَنْطِقُ جَوَارِحُهُ بِعَمَلِهِ.</p>"
        },
        "15": {
            "verses": {
                "75:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَلَوْ أَلْقَى مَعَاذِيرَهُ﴾ لَوْ جَاءَ بِكُلِّ مَعْذِرَةٍ يَعْتَذِرُ بِهَا، مَا قُبِلَتْ.</p>"
        },
        "16": {
            "verses": {
                "75:16": {
                    "id": 16
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لِتَعْجَلَ بِهِ﴾ لِتَسْتَعْجِلَ حِفْظَ مَا يُوحَى إِلَيْكَ.</p>"
        },
        "17": {
            "verses": {
                "75:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿جَمْعَهُ﴾ فِي صَدْرِكَ.</h2>\n<h2>﴿وَقُرْآنَهُ﴾ قِرَاءَتَهُ بِلِسَانِكَ مَتَى شِئْتَ.</h2>"
        },
        "18": {
            "verses": {
                "75:18": {
                    "id": 18
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَاتَّبِعْ قُرْآنَهُ﴾ اسْتَمِعْ لِقِرَاءَتِهِ مِنْ جِبْرِيلَ، ثُمَّ اقْرَأْهُ كَمَا أَقْرَأَكَ.</p>"
        },
        "19": {
            "verses": {
                "75:19": {
                    "id": 19
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بَيَانَهُ﴾ تَفْسِيرَ مَا أَشْكَلَ عَلَيْكَ فَهْمُهُ.</h2>"
        },
        "20": {
            "verses": {
                "75:20": {
                    "id": 20
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
