                    "id": 36
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿سُدىً﴾ هَمَلاً لاَ يُؤْمَرُ، وَلاَ يُحَاسَبُ.</h2>"
        },
        "37": {
            "verses": {
                "75:37": {
                    "id": 37
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يُمْنَى﴾ يُصَبُّ فِي الرَّحِمِ.</h2>"
        },
        "38": {
            "verses": {
                "75:38": {
                    "id": 38
                }
