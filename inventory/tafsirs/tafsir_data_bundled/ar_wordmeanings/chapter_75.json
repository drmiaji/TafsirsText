            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿نَاضِرَةٌ﴾ مُشْرِقَةٌ، حَسَنَةٌ.</h2>"
        },
        "23": {
            "verses": {
                "75:23": {
                    "id": 23
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿نَاظِرَةٌ﴾ تَرَى رَبَّهَا فِي الجَنَّةِ.</h2>"
        },
        "24": {
            "verses": {
                "75:24": {
                    "id": 24
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بَاسِرَةٌ﴾ عَابِسَةٌ، كَالِحَةٌ.</h2>"
        },
        "25": {
            "verses": {
                "75:25": {
                    "id": 25
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَاقِرَةٌ﴾ مُصِيبَةٌ عَظِيمَةٌ تَقْصِمُ فَقَارَ الظَّهْرِ.</h2>"
        },
        "26": {
            "verses": {
                "75:26": {
                    "id": 26
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿كَلاَّ﴾ حَقًّا.</h2>\n<p>﴿بَلَغَتِ التَّرَاقِيَ﴾ وَصَلَتِ الرُّوحُ إِلَى أَعَالِي الصَّدْرِ.</p>"
        },
        "27": {
            "verses": {
                "75:27": {
                    "id": 27
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَنْ رَاقٍ﴾ هَلْ مِنْ رَاقٍ يَرْقِيهِ، وَيَشْفِيهِ؟</h2>"
        },
        "28": {
            "verses": {
                "75:28": {
                    "id": 28
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَظَنَّ﴾ أَيْقَنَ المُحْتَضِرُ.</h2>"
        },
        "29": {
            "verses": {
                "75:29": {
                    "id": 29
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَالْتَفَّتِ السَّاقُ بِالسَّاقِ﴾ اتَّصَلَتْ شِدَّةُ آخِرِ الدُّنْيَا بِشِدَّةِ أَوَّلِ الآخِرَةِ، وَالْتَفَّتْ إِحْدَى سَاقَيْهِ بِالأُخْرَى عِنْدَ المَوْتِ.</p>"
        },
        "30": {
            "verses": {
                "75:30": {
                    "id": 30
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْمَسَاقُ﴾ سَوْقُ العِبَادِ لِلْجَزَاءِ.</h2>"
        },
        "31": {
            "verses": {
                "75:31": {
                    "id": 31
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "32": {
            "verses": {
                "75:32": {
                    "id": 32
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَتَوَلَّى﴾ أَعْرَضَ عَنِ الإِيمَانِ.</h2>"
        },
        "33": {
            "verses": {
                "75:33": {
                    "id": 33
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَتَمَطَّى﴾ يَتَبَخْتَرُ فِي مِشْيَتِهِ مُخْتَالاً.</h2>"
        },
        "34": {
            "verses": {
                "75:34": {
                    "id": 34
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أَوْلَى لَكَ فَأَوْلَى﴾ كَلِمَةُ وَعِيدٍ، أَيْ: هَلاَكٌ لَكَ فَهَلاَكٌ.</p>"
        },
        "35": {
            "verses": {
                "75:35": {
                    "id": 35
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "36": {
