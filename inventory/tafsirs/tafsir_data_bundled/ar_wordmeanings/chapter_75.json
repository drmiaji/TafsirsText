                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لاَ أُقْسِمُ﴾ أُقْسِمُ، وَ(لاَ): تَأْكِيدٌ لِلْقَسَمِ.</h2>"
        },
        "2": {
            "verses": {
                "75:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿اللَّوَّامَةِ﴾ النَّفْسِ الَّتِي تَلُومُ صَاحِبَهَا.</h2>"
        },
        "3": {
            "verses": {
                "75:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
