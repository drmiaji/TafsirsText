            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿بِالْغَيْبِ﴾ يَخْشَوْنَهُ وَهُمْ غَائِبُونَ عَنْ أَعْيُنِ النَّاسِ، وَيَخْشَوْنَ العَذَابَ قَبْلَ مُعَايَنَتِهِ.</p>"
        },
        "13": {
            "verses": {
