            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَنْشَأَكُمْ﴾ أَوْجَدَكُمْ.</h2>"
        },
        "24": {
            "verses": {
                "67:24": {
                    "id": 24
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
