                "language_name": "english"
            },
            "text": "<h2>﴿فَسُحْقًا﴾ بُعْدًا.</h2>"
        },
        "12": {
            "verses": {
                "67:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
