            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿تَبَارَكَ﴾ تَعَالَى، وَتَعاظَمَ، وَتَكَاثَرَ خَيْرُهُ وَبِرُّهُ.</p>"
        },
        "2": {
            "verses": {
                "67:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لِيَبْلُوَكُمْ﴾ لِيَخْتَبِرَكُمْ.</h2>\n<h2>﴿أَحْسَنُ عَمَلاً﴾ أَخْلَصُهُ، وَأَصْوَبُهُ.</h2>"
        },
        "3": {
            "verses": {
                "67:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿طِبَاقًا﴾ بَعْضُهَا فَوْقَ بَعْضٍ، مِنْ غَيْرِ مُمَاسَّةٍ.</h2>\n<h2>﴿تَفَاوُتٍ﴾ اخْتِلاَفٍ، وَتَبَايُنٍ.</h2>\n<h2>﴿فُطُورٍ﴾ شُقُوقٍ، وَصُدُوعٍ.</h2>"
        },
        "4": {
            "verses": {
                "67:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ ارْجِعِ الْبَصَرَ كَرَّتَيْنِ﴾ أَعِدِ النَّظَرَ مَرَّةً بَعْدَ مَرَّةٍ.</p>\n<h2>﴿يَنْقَلِبْ﴾ يَرْجِعْ.</h2>\n<h2>﴿خَاسِئًا﴾ ذَلِيلاً صَاغِرًا.</h2>\n<h2>﴿حَسِيرٌ﴾ مُتْعَبٌ، كَلِيلٌ.</h2>"
        },
        "5": {
            "verses": {
                "67:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿رُجُومًا لِلشَّيَاطِينِ﴾ شُهُبًا مُحْرِقَةً لِمُسْتَرِقِي السَّمْعِ مِنَ الشَّيَاطِينِ.</p>\n<h2>﴿وَأَعْتَدْنَا﴾ أَعْدَدْنَا.</h2>"
        },
        "6": {
            "verses": {
                "67:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْمَصِيرُ﴾ المَرْجِعُ، وَالمَآلُ.</h2>"
        },
        "7": {
            "verses": {
                "67:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿شَهِيقًا﴾ صَوْتًا مُنْكَرًا.</h2>\n<h2>﴿تَفُورُ﴾ تَغْلِي غَلَيَانًا شَدِيدًا.</h2>"
        },
        "8": {
            "verses": {
                "67:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿تَمَيَّزُ مِنَ الْغَيظِ﴾ تَتَمَزَّقُ مِنْ شِدَّةِ غَضَبِهَا عَلَى الكُفَّارِ.</p>\n<h2>﴿فَوْجٌ﴾ جَمَاعَةٌ.</h2>\n<h2>﴿نَذِيرٌ﴾ رَسُولٌ يُحَذِّرُكُمْ هَذَا العَذَابَ.</h2>"
        },
        "9": {
            "verses": {
                "67:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿إِنْ أَنْتُمْ﴾ مَا أَنْتُمْ.</h2>"
        },
        "10": {
            "verses": {
                "67:10": {
                    "id": 10
                }
            },
