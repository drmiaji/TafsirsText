            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿النَّبَإِ الْعَظِيمِ﴾ الخَبَرِ العَظِيمِ؛ وَهُوَ القُرْآنُ الَّذِي فِيهِ خَبَرُ البَعْثِ.</p>"
        },
