            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مِهَادًا﴾ مُمَهَّدَةً كَالفِرَاشِ.</h2>"
        },
        "7": {
            "verses": {
                "78:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَوْتَادًا﴾ تُثَبِّتُ الأَرْضَ.</h2>"
        },
        "8": {
            "verses": {
                "78:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَزْوَاجًا﴾ أَصْنَافًا: ذُكُورًا وَإِنَاثًا.</h2>"
        },
        "9": {
            "verses": {
                "78:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿سُبَاتًا﴾ رَاحَةً لأِبْدَانِكُمْ، وَقَطْعًا لأَعْمَالِكُمْ.</p>"
        },
        "10": {
            "verses": {
                "78:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لِبَاسًا﴾ سَاتِرًا لَكُمْ بِظُلْمَتِهِ؛ كَاللِّبَاسِ.</h2>"
        },
        "11": {
            "verses": {
                "78:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَعَاشًا﴾ تُحَصِّلُونَ فِيهِ مَا تَعِيشُونَ بِهِ.</h2>"
        },
        "12": {
            "verses": {
                "78:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "13": {
            "verses": {
                "78:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿سِرَاجًا وَهَّاجًا﴾ مِصْبَاحًا وَقَّادًا، مُضِيئًا.</h2>"
        },
        "14": {
            "verses": {
                "78:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْمُعْصِرَاتِ﴾ السُّحُبِ المُمْطِرَةِ.</h2>\n<h2>﴿ثَجَّاجًا﴾ مُنْصَبًّا بِكَثْرَةٍ.</h2>"
        },
        "15": {
            "verses": {
                "78:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "16": {
            "verses": {
                "78:16": {
                    "id": 16
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَجَنَّاتٍ أَلْفَافًا﴾ بَسَاتِينَ مُلْتَفَّةً أَشْجَارُهَا.</p>"
        },
        "17": {
            "verses": {
                "78:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مِيقَاتًا﴾ وَقْتًا، وَمِيعَادًا لِلفَصْلِ بَيْنَ الخَلْقِ.</h2>"
        },
        "18": {
            "verses": {
                "78:18": {
                    "id": 18
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الصُّورِ﴾ القَرْنِ الَّذِي يَنْفُخُ فِيهِ إِسْرَافِيلُ عليه السلام.</p>"
        },
        "19": {
            "verses": {
                "78:19": {
                    "id": 19
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أَبْوَابًا﴾ ذَاتَ أَبْوَابٍ كَثِيرَةٍ؛ لِنُزُولِ المَلاَئِكَةِ.</p>"
        },
        "20": {
            "verses": {
                "78:20": {
                    "id": 20
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَسُيِّرَتِ﴾ نُسِفَتْ بَعْدَ ثُبُوتِهَا.</h2>\n<h2>﴿سَرَابًا﴾ كَالسَّرَابِ الَّذِي لاَ حَقِيقَةَ لَهُ.</h2>"
        },
        "21": {
            "verses": {
                "78:21": {
                    "id": 21
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مِرْصَادًا﴾ تَرْصُدُ أَهْلَهَا، وَتَرْقُبُهُمْ.</h2>"
        },
        "22": {
            "verses": {
                "78:22": {
                    "id": 22
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "23": {
            "verses": {
                "78:23": {
                    "id": 23
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَحْقَابًا﴾ دُهُورًا لاَ تَنْقَطِعُ.</h2>"
        },
        "24": {
            "verses": {
                "78:24": {
                    "id": 24
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بَرْدًا﴾ مَا يُبَرِّدُ حَرَّ النَّارِ عَلَى أَجْسَادِهِمْ.</h2>"
        },
        "25": {
            "verses": {
                "78:25": {
                    "id": 25
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿حَمِيمًا﴾ مَاءً حَارًّا بِالِغًا نِهَايَةَ الحَرَارَةِ.</h2>\n<h2>﴿وَغَسَّاقًا﴾ صَدِيدَ أَهْلِ النَّارِ.</h2>"
        },
        "26": {
            "verses": {
                "78:26": {
                    "id": 26
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وِفَاقًا﴾ عَادِلاً، مُوَافِقًا لأَعْمَالِهِمْ.</h2>"
        },
        "27": {
            "verses": {
                "78:27": {
                    "id": 27
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لاَ يَرْجُونَ﴾ لاَ يَخَافُونَ.</h2>"
        },
        "28": {
            "verses": {
                "78:28": {
                    "id": 28
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "29": {
            "verses": {
                "78:29": {
                    "id": 29
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أَحْصَيْنَاهُ﴾ حَفِظْنَاهُ، وَضَبَطْنَاهُ مَكْتُوبًا فِي اللَّوْحِ المَحْفُوظِ.</p>"
        },
        "30": {
            "verses": {
                "78:30": {
                    "id": 30
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "31": {
            "verses": {
                "78:31": {
                    "id": 31
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مَفَازًا﴾ فَوْزًا بِدُخُولِهِمُ الجَنَّةَ، أَوْ مَكَانًا يَفُوزُونَ بِهِ؛ وَهُوَ الجَنَّةُ.</p>"
        },
        "32": {
            "verses": {
                "78:32": {
                    "id": 32
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿حَدَائِقَ﴾ بَسَاتِينَ عَظِيمَةً قَدْ أَحْدَقَتْ بِهَا الأَشْجَارُ.</p>"
        },
        "33": {
            "verses": {
                "78:33": {
                    "id": 33
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَكَوَاعِبَ﴾ حَدِيثَاتِ السِّنِّ، نَوَاهِدَ.</h2>\n<h2>﴿أَتْرَابًا﴾ مُسْتَوِيَاتٍ فِي سِنٍّ وَاحِدَةٍ.</h2>"
        },
        "34": {
            "verses": {
                "78:34": {
                    "id": 34
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿دِهَاقًا﴾ مَمْلُوءَةً خَمْرًا.</h2>"
        },
        "35": {
            "verses": {
                "78:35": {
                    "id": 35
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لَغْوًا﴾ بَاطِلاً مِنَ القَوْلِ.</h2>"
        },
        "36": {
            "verses": {
                "78:36": {
                    "id": 36
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿حِسَابًا﴾ كَثِيرًا، كَافِيًا لَهُمْ.</h2>"
        },
        "37": {
            "verses": {
                "78:37": {
                    "id": 37
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿خِطَابًا﴾ كَلاَمًا، وَسُؤَالاً إِلاَّ بإِذْنِهِ.</h2>"
        },
        "38": {
            "verses": {
                "78:38": {
                    "id": 38
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الرُّوحُ﴾ جِبْرِيلُ عليه السلام.</h2>\n<h2>﴿صَفًّا﴾ مُصْطَفِّينَ.</h2>\n<h2>﴿لاَ يَتَكَلَّمُونَ﴾ لاَ يَشْفَعُونَ.</h2>\n<h2>﴿صَوَابًا﴾ حَقًّا، وَسَدَادًا.</h2>"
        },
        "39": {
            "verses": {
                "78:39": {
                    "id": 39
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْحَقُّ﴾ الَّذِي لاَ رَيْبَ فِي وُقُوعِهِ.</h2>\n<h2>﴿مَآبًا﴾ مرْجِعًا بِالعَمَلِ الصَّالِحِ.</h2>"
        },
        "40": {
