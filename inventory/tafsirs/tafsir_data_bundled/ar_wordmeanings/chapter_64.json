                "language_name": "english"
            },
            "text": "<h2>﴿وَالنُّورِ﴾ القُرْآنِ.</h2>"
        },
        "9": {
            "verses": {
                "64:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لِيَوْمِ الْجَمْعِ﴾ يَوْمِ القِيَامَةِ الَّذِي يُحْشَرُ فِيهِ الأَوَّلُونَ وَالآخِرُونَ.</p>\n<p>﴿يَوْمُ التَّغَابُنِ﴾ يَظْهَرُ فِيهِ خَسَارَةُ الكُفَّارِ، وَغَبْنُهُمْ، بِتَرْكِهِمُ الإِيمَانَ.</p>\n<h2>﴿يُكَفِّرْ﴾ يَمْحُ.</h2>"
        },
        "10": {
            "verses": {
                "64:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
