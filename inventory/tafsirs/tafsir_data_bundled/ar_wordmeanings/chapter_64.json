            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بِإِذْنِ اللَّهِ﴾ بِقَضَائِهِ، وَقَدَرِهِ.</h2>\n<p>﴿يَهْدِ قَلْبَهُ﴾ يُوَفِّقْهُ لِلتَّسْلِيمِ بِالقَضَاءِ، وَالصَّبْرِ عَلَى المَقْدُورِ.</p>"
        },
        "12": {
            "verses": {
                "64:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿تَوَلَّيْتُمْ﴾ أَعْرَضْتُمْ عَنْ طَاعَةِ الرَّسُولِ صلّى الله عليه وسلّم.</p>"
        },
        "13": {
            "verses": {
                "64:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَلْيَتَوَكَّلِ﴾ فَلْيَعْتَمِدْ، وَلْيُفَوِّضْ.</h2>"
        },
        "14": {
            "verses": {
                "64:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿عَدُوًّا لَكُمْ﴾ بِصَدِّكُمْ عَنِ سَبِيلِ اللهِ، وَتَثْبِيطِكُمْ عَنْ طَاعَةِ اللهِ.</p>\n<h2>﴿تَعْفُوا﴾ تَتَجَاوَزُوا عَنْ سَيِّئَاتِهِمْ.</h2>\n<h2>﴿وَتَصْفَحُوا﴾ تُعْرِضُوا عَنْهَا.</h2>\n<h2>﴿وَتَغْفِرُوا﴾ تَسْتُرُوهَا عَلَيْهِمْ.</h2>"
        },
        "15": {
            "verses": {
                "64:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فِتْنَةٌ﴾ بَلاَءٌ، وَاخْتِبَارٌ لَكُمْ.</h2>"
        },
        "16": {
            "verses": {
                "64:16": {
                    "id": 16
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَنْ يُوقَ شُحَّ نَفْسِهِ﴾ يُكْفَ بُخْلَهَا الشَّدِيدَ، وَطَمَعَهَا بِمَا فِي أَيْدِي النَّاسِ.</p>"
        },
