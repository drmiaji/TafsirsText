                    "id": 26
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَقَامٍ كَرِيمٍ﴾ مَنَازِلَ جَمِيلَةٍ.</h2>"
        },
        "27": {
            "verses": {
                "44:27": {
                    "id": 27
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَنَعْمَةٍ﴾ عِيشَةٍ، وَتَنَعُّمٍ.</h2>\n<h2>﴿فَاكِهِينَ﴾ نَاعِمِينَ مُتْرَفِينَ.</h2>"
        },
        "28": {
            "verses": {
                "44:28": {
                    "id": 28
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿قَوْمًا آخَرِينَ﴾ هُمْ: بَنُو إِسْرَائِيلَ؛ خَلَفُوا الأَقْبَاطَ علَى بِلاَدِهِمْ.</p>"
        },
        "29": {
            "verses": {
                "44:29": {
                    "id": 29
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مُنْظَرِينَ﴾ مُؤَخَّرِينَ عَنِ العُقُوبَةِ.</h2>"
        },
        "30": {
            "verses": {
                "44:30": {
                    "id": 30
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الْعَذَابِ الْمُهِينِ﴾ المُذِلِّ؛ وَهُوَ قَتْلُ أَبْنَائِهِمْ، وَاسْتِخْدَامُ نِسَائِهِمْ.</p>"
        },
        "31": {
            "verses": {
                "44:31": {
                    "id": 31
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿عَالِيًا﴾ مُتَكَبِّرًا جَبَّارًا.</h2>"
        },
        "32": {
            "verses": {
                "44:32": {
                    "id": 32
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿اخْتَرْنَاهُمْ﴾ اصْطَفَيْنَاهُمْ.</h2>\n<h2>﴿عَلَى الْعَالَمِينَ﴾ عَالَمِي زَمَانِهِمْ.</h2>"
        },
        "33": {
            "verses": {
                "44:33": {
                    "id": 33
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿بَلاَءٌ مُبِينٌ﴾ اخْتِبَارٌ بَيْنَ الرَّخَاءِ، وَالشِّدَّةِ.</p>"
        },
        "34": {
            "verses": {
