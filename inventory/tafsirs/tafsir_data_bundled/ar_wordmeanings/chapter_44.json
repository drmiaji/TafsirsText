                "language_name": "english"
            },
            "text": "<p>﴿لَيْلَةٍ مُبَارَكَةٍ﴾ هِيَ: لَيْلَةُ القَدْرِ مِنْ شَهْرِ رَمَضَانَ.</p>"
        },
        "4": {
            "verses": {
                "44:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿يُفْرَقُ﴾ يُقْضَى وَيُفْصَلُ مِنَ اللَّوْحِ المَحْفُوظِ إِلَى الكَتَبَةِ مِنَ المَلاَئِكَةِ.</p>\n<p>﴿أَمْرٍ حَكِيمٍ﴾ أَمْرٍ مُحْكَمٍ؛ مِنَ الآجَالِ، وَالأَرْزَاقِ، فِي تِلْكَ السَّنَةِ.</p>"
        },
