                "language_name": "english"
            },
            "text": "<h2>﴿فَارْتَقِبْ﴾ انْتَظِرْ بِهَؤُلاَءِ المُشْرِكِينَ.</h2>"
        },
        "11": {
            "verses": {
                "44:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَغْشَى﴾ يَعُمُّ.</h2>"
        },
        "12": {
            "verses": {
                "44:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "13": {
            "verses": {
                "44:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أَنَّى لَهُمُ الذِّكْرَى﴾ كَيْفَ يَكُونُ لَهُمُ التَّذَكُّرُ وَالاِتِّعَاظُ؟!</p>\n<p>﴿رَسُولٌ مُبِينٌ﴾ بَيِّنُ الرِّسَالَةِ؛ وَهُوَ نَبِيُّنَا مُحَمَّدٌ صلّى الله عليه وسلّم.</p>"
        },
        "14": {
            "verses": {
                "44:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿تَوَلَّوْا﴾ أَعْرَضُوا.</h2>\n<h2>﴿مُعَلَّمٌ﴾ عَلَّمَهُ بَشَرٌ، أَوْ شَيْطَانٌ.</h2>"
        },
        "15": {
            "verses": {
                "44:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "16": {
            "verses": {
                "44:16": {
                    "id": 16
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الْبَطْشَةَ الْكُبْرَى﴾ العَذَابَ الأَكْبَرَ يَوْمَ القِيَامَةِ.</p>"
        },
        "17": {
            "verses": {
                "44:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَتَنَّا﴾ اخْتَبَرْنَا وَابْتَلَيْنَا.</h2>"
        },
        "18": {
            "verses": {
                "44:18": {
                    "id": 18
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أَدُّوا إِلَيَّ﴾ سَلِّمُوا لِي عِبَادَ اللهِ مِنْ بَنِي إِسْرَائِيلَ.</p>"
        },
        "19": {
            "verses": {
                "44:19": {
                    "id": 19
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَأَنْ لاَ تَعْلُوا﴾ أَلاَّ تَتَكَبَّرُوا.</h2>\n<h2>﴿بِسُلْطَانٍ﴾ بِبُرْهَانٍ، وَحُجَّةٍ.</h2>"
        },
        "20": {
            "verses": {
                "44:20": {
                    "id": 20
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿عُذْتُ﴾ اسْتَجَرْتُ.</h2>\n<h2>﴿أَنْ تَرْجُمُونِ﴾ أَنْ تَقْتُلُونِي رَجْمًا بِالحِجَارَةِ.</h2>"
        },
        "21": {
            "verses": {
