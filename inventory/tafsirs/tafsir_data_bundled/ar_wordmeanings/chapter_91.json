            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿طَحَاهَا﴾ بَسَطَهَا.</h2>"
        },
        "7": {
            "verses": {
                "91:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿سَوَّاهَا﴾ أَكْمَلَ خَلْقَهَا؛ لأِدَاءِ مُهِمَّتِهَا.</h2>"
        },
        "8": {
            "verses": {
                "91:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَأَلْهَمَهَا﴾ بَيَّنَ لَهَا.</h2>\n<p>﴿فُجُورَهَا وَتَقْوَاهَا﴾ طَرِيقَ الخَيْرِ، وَطَرِيقَ الشَّرِّ.</p>"
        },
        "9": {
            "verses": {
                "91:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿زَكَّاهَا﴾ طَهَّرَهَا وَنَمَّاهَا بِالطَّاعَةِ.</h2>"
        },
        "10": {
            "verses": {
                "91:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿خَابَ﴾ خَسِرَ.</h2>\n<h2>﴿دَسَّاهَا﴾ أَخْفَى نَفْسَهُ، وَنَقَصَهَا بِالمَعَاصِي.</h2>"
        },
        "11": {
            "verses": {
                "91:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿بِطَغْوَاهَا﴾ بِسَبَبِ طُغْيَانِهَا، وَتَجَاوُزِهَا الحَدَّ فِي العِصْيَانِ.</p>"
        },
        "12": {
            "verses": {
                "91:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿انْبَعَثَ﴾ نَهَضَ مُسْرِعًا؛ لِعَقْرِ النَّاقَةِ.</h2>\n<p>﴿أَشْقَاهَا﴾ أَكْثَرُهُمْ شَقَاوَةً، وَتَمَرُّدًا؛ وَهُوَ قُدَارُ بْنُ سَالِفٍ.</p>"
        },
        "13": {
            "verses": {
                "91:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿نَاقَةَ اللَّهِ وَسُقْيَاهَا﴾ احْذَرُوا نَاقَةَ اللهِ أَنْ تَمَسُّوهَا بِسُوءٍ، وَأَنْ تَعْتَدُوا عَلَى سَقْيِهَا.</p>"
        },
        "14": {
            "verses": {
                "91:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَعَقَرُوهَا﴾ فَنَحَرُوهَا.</h2>\n<h2>﴿فَدَمْدَمَ﴾ فَأَطْبَقَ عَلَيْهِمُ العُقُوبَةَ.</h2>\n<p>﴿فَسَوَّاهَا﴾ عَمَّهُمْ بِالعُقُوبَةِ؛ فَلَمْ يُفْلِتْ مِنْهُمْ أَحَدٌ.</p>"
        },
        "15": {
            "verses": {
                "91:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿عُقْبَاهَا﴾ عَاقِبَةَ مَا نَزَلَ بِهِمْ مِنَ العُقُوبَةِ.</h2>"
        }
    }
}