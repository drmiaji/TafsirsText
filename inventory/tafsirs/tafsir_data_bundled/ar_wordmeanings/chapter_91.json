            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَضُحَاهَا﴾ قَسَمٌ بِإِشِرَاقِ الشَّمْسِ ضُحًى.</h2>"
        },
        "2": {
            "verses": {
                "91:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿تَلاَهَا﴾ تَبِعَ الشَّمْسَ فِي الطُّلُوعِ وَالأُفُولِ.</h2>"
        },
        "3": {
            "verses": {
                "91:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿جَلاَّهَا﴾ كَشَفَ ظُلْمَةَ اللَّيْلِ وَأَزَالَهَا.</h2>"
        },
        "4": {
            "verses": {
                "91:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَغْشَاهَا﴾ يُغَطِّي الأَرْضَ بِظُلْمَتِهِ.</h2>"
        },
        "5": {
            "verses": {
                "91:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
