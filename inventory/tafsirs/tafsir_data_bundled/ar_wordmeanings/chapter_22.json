            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْعَاكِفُ فِيهِ﴾ المُقِيمُ فِيهِ.</h2>\n<h2>﴿وَالْبَادِ﴾ القَادِمُ إِلَيْهِ.</h2>\n<h2>﴿يُرِدْ﴾ يَهُمَّ.</h2>\n<h2>﴿بِإِلْحَادٍ بِظُلْمٍ﴾ بِمَيْلٍ عَنِ الحَقِّ ظُلْمًا.</h2>"
        },
        "26": {
            "verses": {
                "22:26": {
                    "id": 26
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بَوَّأْنَا﴾ هَيَّأْنَا، وَبَيَّنَّا.</h2>"
        },
        "27": {
            "verses": {
                "22:27": {
                    "id": 27
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَأَذِّنْ﴾ نادِ وَأَعْلِمْ رَافِعًا صَوْتَكَ.</h2>\n<h2>﴿رِجَالاً﴾ يَمْشُونَ عَلَى أَقْدَامِهِمْ ؛ جَمْعُ رَاجِلٍ.</h2>\n<p>﴿ضَامِرٍ﴾ البَعِيرِ خَفِيفِ اللَّحْمِ مِنَ الأَعْمَالِ لاَ مِنَ الهُزَالِ.</p>\n<h2>﴿فَجٍّ عَمِيقٍ﴾ طَرِيقٍ بَعِيدٍ.</h2>"
        },
        "28": {
            "verses": {
                "22:28": {
                    "id": 28
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أَيَّامٍ مَعْلُومَاتٍ﴾ هِيَ: عَشْرُ ذِي الحِجَّةِ، وَثَلاَثَةُ أَيَّامٍ بَعْدَهُ.</p>\n<h2>﴿الْبَائِسَ الْفَقِيرَ﴾ الَّذِي اشْتَدَّ فَقْرُهُ.</h2>"
        },
        "29": {
            "verses": {
                "22:29": {
                    "id": 29
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لْيَقْضُوا تَفَثَهُمْ﴾ لِيُكْمِلُوا حَجَّهُمْ بِإِحْلاَلِهِمْ مِنْ إِحْرَامِهِمْ وَإِزَالَةِ وَسَخِ أَبْدَانِهِمْ.</p>\n<h2>﴿نُذُورَهُمْ﴾ الحَجَّ، وَالعُمْرَةَ، وَالهَدَايَا.</h2>\n<p>﴿الْعَتِيقِ﴾ القَدِيمِ الَّذِي أَعْتَقَهُ اللهُ، مِنْ تَسَلُّطِ الجَبَّارِينَ عَلَيْهِ.</p>"
        },
        "30": {
            "verses": {
                "22:30": {
                    "id": 30
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿حُرُمَاتِ اللَّهِ﴾ شَعَائِرَ الدِّينِ، وَمَنَاسِكَ الحَجِّ.</p>\n<p>﴿الرِّجْسَ مِنَ الأَوْثَانِ﴾ القَذَارَةَ الَّتِي هِيَ: الأَوْثَانُ.</p>\n<h2>﴿قَوْلَ الزُّورِ﴾ الكَذِبَ وَالاِفْتِرَاءَ عَلَى اللهِ.</h2>"
        },
        "31": {
            "verses": {
                "22:31": {
                    "id": 31
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿حُنَفَاءَ لِلَّهِ﴾ مُسْتَقِيمِينَ عَلَى الإِخْلاَصِ مَائِلِينَ عَنِ الشِّرْكِ.</p>\n<h2>﴿سَحِيقٍ﴾ بَعِيدٍ مُهْلِكٍ.</h2>"
        },
