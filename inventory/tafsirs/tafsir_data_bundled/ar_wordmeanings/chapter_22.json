            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿صِرَاطِ الْحَمِيدِ﴾ طَرِيقِ الإِسْلاَمِ المَحْمُودِ.</h2>"
        },
        "25": {
            "verses": {
                "22:25": {
                    "id": 25
