                "language_name": "english"
            },
            "text": "<h2>﴿تَوَلاَّهُ﴾ اتَّخَذَهُ وَلِيًّا وَتَبِعَهُ.</h2>"
        },
        "5": {
            "verses": {
                "22:5": {
                    "id": 5
