                "language_name": "english"
            },
            "text": "<p>﴿شَعَائِرَ اللَّهِ﴾ مَا أَشْعَرْتُمْ بِهِ، وَأَعْلَمْتُمْ؛ مِنْ أَعْمَالِ الحَجِّ وَالذَّبَائِحِ الَّتِي تُنْحَرُ فِيهِ.</p>"
        },
        "33": {
            "verses": {
                "22:33": {
                    "id": 33
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لَكُمْ فِيهَا مَنَافِعُ﴾ يَحِلُّ الاِنْتِفَاعُ بِهَا بِالرُّكُوبِ، وَشُرْبِ اللَّبَنِ.</p>\n<h2>﴿مَحِلُّهَا﴾ وَقْتُ ذَبْحِهَا.</h2>\n<h2>﴿الْبَيْتِ الْعَتِيقِ﴾ الحَرَمِ.</h2>"
        },
        "34": {
            "verses": {
                "22:34": {
                    "id": 34
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مَنْسَكًا﴾ نُسُكًا وَعِبَادَةً؛ بِذَبْحِ الأَنْعَامِ تَقَرُّبًا لِلَّهِ.</p>\n<h2>﴿الْمُخْبِتِينَ﴾ الخَاضِعِينَ المُتَوَاضِعِينَ.</h2>"
        },
        "35": {
            "verses": {
                "22:35": {
                    "id": 35
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَجِلَتْ﴾ خَافَتْ.</h2>"
        },
        "36": {
            "verses": {
                "22:36": {
                    "id": 36
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَالْبُدْنَ﴾ الإِبِلَ، جَمْعُ بَدَنَةٍ.</h2>\n<h2>﴿شَعَائِرِ اللَّهِ﴾ أَعْلاَمِ دِينِهِ.</h2>\n<p>﴿صَوَآفَّ﴾ قَائِمَاتٍ؛ قَدْ صُفَّتْ ثَلاَثٌ مِنْ قَوَائِمِهَا، وَقُيِّدَتِ الرَّابِعَةُ.</p>\n<h2>﴿وَجَبَتْ﴾ سَقَطَتْ عَلَى الأَرْضِ بَعْدَ النَّحْرِ.</h2>\n<h2>﴿الْقَانِعَ﴾ الفَقِيرَ الَّذِي لَمْ يَسْأَلْ تَعَفُّفًا.</h2>\n<h2>﴿وَالْمُعْتَرَّ﴾ الَّذِي يَسْأَلُ لِحَاجَتِهِ.</h2>"
        },
        "37": {
            "verses": {
                "22:37": {
                    "id": 37
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَنَالَ اللَّهَ﴾ يَصِلَ إِلَى اللهِ.</h2>"
        },
        "38": {
            "verses": {
