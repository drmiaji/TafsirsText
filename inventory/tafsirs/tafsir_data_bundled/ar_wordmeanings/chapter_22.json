                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يُحَلَّوْنَ﴾ يُزَيَّنُونَ.</h2>"
        },
        "24": {
            "verses": {
                "22:24": {
                    "id": 24
