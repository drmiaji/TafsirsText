            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَوَدَّةً﴾ مَحَبَّةً.</h2>"
        },
        "8": {
            "verses": {
                "60:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿تَبَرُّوهُمْ﴾ تُكْرِمُوهُمْ.</h2>\n<h2>﴿وَتُقْسِطُوا﴾ تَعْدِلُوا فِيهِمْ.</h2>\n<h2>﴿الْمُقْسِطِينَ﴾ العَادِلِينَ.</h2>"
        },
        "9": {
            "verses": {
                "60:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَظَاهَرُوا﴾ عَاوَنُوا.</h2>\n<h2>﴿أَنْ تَوَلَّوْهُمْ﴾ أَنْ تَنْصُرُوهُمْ، وَتَوَدُّوهُمْ.</h2>"
        },
        "10": {
            "verses": {
                "60:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَامْتَحِنُوهُنَّ﴾ فَاخْتَبِرُوهُنَّ؛ لِتَعْلَمُوا صِدْقَ إِيمَانِهِنَّ.</p>\n<p>﴿وَآتُوهُمْ مَا أَنْفَقُوا﴾ وَأَعْطُوا أَزْوَاجَ اللاَّتِي أَسْلَمْنَ مِثْلَ مَا أَنْفَقُوا عَلَيْهِنَّ مِنَ المُهُورِ.</p>\n<h2>﴿جُنَاحَ﴾ إِثْمَ.</h2>\n<h2>﴿أُجُورَهُنَّ﴾ مُهُورَهُنَّ.</h2>\n<p>﴿بِعِصَمِ الْكَوَافِرِ﴾ بِعُقُودِ نِكَاحِ زَوْجَاتِكُمُ الكَافِرَاتِ.</p>\n<p>﴿وَاسْأَلُوا مَا أَنْفَقْتُمْ﴾ وَاطْلُبُوا مِنَ المُشْرِكِينَ مُهُورَ نِسَائِكُمُ المُرْتَدَّاتِ اللَّوَاتِي لَحِقْنَ بِهِمْ.</p>"
        },
        "11": {
            "verses": {
                "60:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِنْ فَاتَكُمْ شَيْءٌ مِنْ أَزْوَاجِكُمْ﴾ انْفَلَتَتْ وَاحِدَةٌ بِرِدَّةٍ.</p>\n<p>﴿فَعَاقَبْتُمْ﴾ فَظَفِرْتُمْ بِالكُفَّارِ، وَغَنِمْتُمْ مِنْهُمْ.</p>"
        },
        "12": {
            "verses": {
                "60:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يُبَايِعْنَكَ﴾ يُعَاهِدْنَكَ.</h2>\n<p>﴿بِبُهْتَانٍ يَفْتَرِينَهُ﴾ بِأَنْ يُلْحِقْنَ بِأَزْوَاجِهِنَّ أَوْلاَدًا لَيْسُوا مِنْهُمْ.</p>"
        },
        "13": {
            "verses": {
                "60:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لاَ تَتَوَلَّوْا﴾ لاَ تَجْعَلُوهُمْ أَوْلِيَاءَ، وَأَخِلاَّءَ.</p>"
        }
