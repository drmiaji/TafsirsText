                "language_name": "english"
            },
            "text": "<h2>﴿أَولِيَاءَ﴾ خُلَصَاءَ وَأَحِبَّاءَ.</h2>\n<h2>﴿تُلْقُونَ﴾ تُفْضُونَ.</h2>\n<h2>﴿أَنْ تُؤْمِنُوا﴾ لأَِجْلِ إِيمَانِكُمْ.</h2>\n<h2>﴿ضَلَّ سَوَاءَ السَّبِيْلِ﴾ أَخْطَأَ طَرِيقَ الهُدَى.</h2>"
        },
        "2": {
            "verses": {
                "60:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَثْقَفُوكُمْ﴾ يَظْفَرُوا بِكُمْ.</h2>\n<h2>﴿وَيَبْسُطُوا﴾ يَمُدُّوا.</h2>"
        },
        "3": {
            "verses": {
                "60:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿يَفْصِلُ بَيْنَكُمْ﴾ يُفَرِّقُ بَيْنَ المُطِيعِينَ، وَالعَاصِينَ.</p>"
        },
        "4": {
            "verses": {
                "60:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أُسْوَةٌ﴾ قُدْوَةٌ.</h2>\n<h2>﴿بُرَآءُ﴾ بَرِيئُونَ.</h2>\n<p>﴿إِلاَّ قَوْلَ إِبْرَاهِيمَ﴾ لَكِنْ لاَ تَقْتَدُوا بِإِبْرَاهِيمَ حِينَ قَالَ.</p>\n<h2>﴿أَنَبْنَا﴾ رَجَعْنَا بِالتَّوْبَةِ، وَالطَّاعَةِ.</h2>\n<h2>﴿الْمَصِيرُ﴾ المَرْجِعُ.</h2>"
        },
        "5": {
            "verses": {
                "60:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فِتْنَةً لِلَّذِينَ كَفَرُوا﴾ بِعَذَابِكَ لَنَا، أَوْ تَسْلِيطِ الكُفَّارِ عَلَيْنَا، فَيَقُولُونَ: لَوْ كَانَ هَـؤُلاَءِ عَلَى حَقٍّ، مَا أَصَابَهُمُ العَذَابُ، فَيَزْدَادُوا كُفْرًا.</p>"
        },
        "6": {
            "verses": {
                "60:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَرْجُو اللَّهَ﴾ يَطْمَعُ فِي الخَيْرِ مِنَ اللهِ.</h2>\n<p>﴿يَتَوَلَّ﴾ يُعْرِضْ عَنِ الاِقْتِدَاءِ بِالأَنْبِيَاءِ، وَيُوَالِ أَعْدَاءَ اللهِ.</p>\n<p>﴿الْحَمِيدُ﴾ المَحْمُودُ فِي ذَاتِهِ، وَصِفَاتِهِ، وَأَفْعَالِهِ.</p>"
        },
        "7": {
            "verses": {
                "60:7": {
                    "id": 7
                }
            },
