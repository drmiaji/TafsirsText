            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لَصَالُو الْجَحِيمِ﴾ لَدَاخِلُو النَّارِ يُقَاسُونَ حَرَّهَا.</p>"
        },
