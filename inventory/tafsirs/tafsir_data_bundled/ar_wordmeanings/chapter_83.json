            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مَرْقُومٌ﴾ مَكْتُوبٌ كَالرَّقْمِ فِي الثَّوْبِ لاَ يُمْحَى.</p>"
        },
