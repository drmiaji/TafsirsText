                "language_name": "english"
            },
            "text": "<p>﴿سَفَرَةٍ﴾ مَلاَئِكَةٍ كَتَبَةٍ يَقُومُونَ بِالسِّفَارَةِ بَيْنَ اللهِ وَخَلْقِهِ.</p>"
        },
        "16": {
            "verses": {
                "80:16": {
                    "id": 16
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بَرَرَةٍ﴾ مُطِيعِينَ للهِ لاَ يَعْصُونَهُ.</h2>"
        },
        "17": {
            "verses": {
                "80:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿قُتِلَ الإنْسَانُ﴾ لُعِنَ الكَافِرُ، وَعُذِّبَ.</h2>\n<h2>﴿مَا أَكْفَرَهُ﴾ مَا أَشَدَّ كُفْرَهُ!</h2>"
        },
        "18": {
            "verses": {
                "80:18": {
                    "id": 18
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "19": {
            "verses": {
                "80:19": {
                    "id": 19
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿نُطْفَةٍ﴾ مَاءٍ قَلِيلٍ مَهِينٍ؛ وَهُوَ المَنِيُّ.</h2>\n<h2>﴿فَقَدَّرَهُ﴾ خَلَقَهُ أَطْوَارًا.</h2>"
        },
        "20": {
            "verses": {
                "80:20": {
                    "id": 20
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿السَّبِيلَ يَسَّرَهُ﴾ سَهَّلَ لَهُ طَرِيقَ خُرُوجِهِ مِنْ بَطْنِ أُمِّهِ، وَبَيَّنَ لَهُ طَرِيقَ الخَيْرِ وَالشَّرِّ.</p>"
        },
        "21": {
            "verses": {
                "80:21": {
                    "id": 21
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَأَقْبَرَهُ﴾ جَعَلَ لَهُ مَكَانًا يُقْبَرُ فِيهِ.</h2>"
        },
        "22": {
            "verses": {
                "80:22": {
                    "id": 22
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَنْشَرَهُ﴾ أَحْيَاهُ.</h2>"
        },
        "23": {
            "verses": {
                "80:23": {
                    "id": 23
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لَمَّا يَقْضِ مَا أَمَرَهُ﴾ لَمْ يُؤَدِّ الكَافِرُ مَا أَمَرَهُ اللهُ بِهِ مِنَ الإِيمَانِ وَالطَّاعَةِ.</p>"
        },
