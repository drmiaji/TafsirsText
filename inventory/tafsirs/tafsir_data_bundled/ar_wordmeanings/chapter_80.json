            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أَنْ جَاءَهُ الأَعْمَى﴾ لِأَجْلِ مَجِيءِ عَبْدِ اللهِ بْنِ أُمِّ مُكْتُومٍ رضي الله عنه.</p>"
        },
