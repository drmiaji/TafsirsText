        "4": {
            "verses": {
                "73:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَرَتِّلِ﴾ اقْرَأْ بِتُؤَدَةٍ وَتَمَهُّلٍ؛ مُبَيِّنًا الحُرُوفَ وَالوُقُوفَ.</p>"
        },
        "5": {
            "verses": {
                "73:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿ثَقِيلاً﴾ عَظِيمًا، مُشْتَمِلاً عَلَى الأَوَامِرِ وَالنَّوَاهِي.</p>"
        },
        "6": {
            "verses": {
                "73:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿نَاشِئَةَ اللَّيْلِ﴾ العِبَادَةَ الَّتِي تَنْشَأُ فِي جَوْفِ اللَّيْلِ بَعْدَ النَّوْمِ.</p>\n<h2>﴿هِيَ أَشَدُّ وَطْءًا﴾ أَشَدُّ تَأْثِيرًا فِي القَلْبِ.</h2>\n<p>﴿وَأَقْوَمُ قِيلاً﴾ أَبْيَنُ قَوْلاً؛ لِحُضُورِ القَلْبِ، وَقِلَّةِ الشَّوَاغِلِ.</p>"
        },
        "7": {
            "verses": {
                "73:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿سَبْحًا﴾ تَصَرُّفًا، وَتَقَلُّبًا فِي مَصَالِحِكَ.</h2>"
        },
        "8": {
            "verses": {
                "73:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَتَبَتَّلْ﴾ انْقَطِعْ لِعِبَادَتِهِ.</h2>"
        },
        "9": {
            "verses": {
                "73:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَكِيلاً﴾ تُفَوِّضُ أُمُورَكَ إِلَيْهِ، وَتَعْتَمِدُ عَلَيْهِ.</p>"
        },
        "10": {
            "verses": {
                "73:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿هَجْرًا جَمِيلاً﴾ أَعْرِضْ عَنْهُمْ؛ تارِكًا الاِنْتِقَامَ مِنْهُمْ.</p>"
        },
        "11": {
            "verses": {
                "73:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أُولِي النَّعْمَةِ﴾ أَصْحَابَ النَّعِيمِ وَالتَّرَفِ.</h2>\n<p>﴿وَمَهِّلْهُمْ قَلِيلاً﴾ أَجِّلْهُمْ زَمَنًا قَلِيلاً بِتَأْخِيرِ العَذَابِ عَنْهُمْ.</p>"
        },
        "12": {
            "verses": {
                "73:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَنْكَالاً﴾ قُيُودًا ثَقِيلَةً.</h2>"
        },
        "13": {
            "verses": {
                "73:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿ذَا غُصَّةٍ﴾ يَنْشَبُ فِي الحُلُوقِ، لاَ يُسْتَسَاغُ؛ لِكَرَاهَتِهِ.</p>"
        },
        "14": {
            "verses": {
                "73:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿تَرْجُفُ﴾ تَضْطَرِبُ.</h2>\n<h2>﴿كَثِيبًا﴾ رَمْلاً مُجْتَمِعًا.</h2>\n<h2>﴿مَهِيلاً﴾ سَائِلاً مُتَنَاثِرًا.</h2>"
        },
        "15": {
            "verses": {
