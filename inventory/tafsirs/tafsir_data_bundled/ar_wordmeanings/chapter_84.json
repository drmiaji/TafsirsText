            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿انْشَقَّتْ﴾ تَصَدَّعَتْ، وَتَفَطَّرَتْ بِالغَمَامِ يَوْمَ القِيَامَةِ.</p>"
        },
        "2": {
            "verses": {
                "84:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَأَذِنَتْ لِرَبِّهَا﴾ أَطَاعَتْ لِأَمْرِ رَبِّهَا.</h2>\n<h2>﴿وَحُقَّتْ﴾ وَحُقَّ لَهَا أَنْ تُطِيعَ.</h2>"
        },
        "3": {
            "verses": {
                "84:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مُدَّتْ﴾ بُسِطَتْ، وَوُسِّعَتْ، وَدُكَّتْ جِبَالُهَا.</h2>"
        },
        "4": {
            "verses": {
                "84:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَأَلْقَتْ﴾ قَذَفَتْ مَا فِي بَطْنِهَا مِنَ الأَمْوَاتِ.</h2>"
        },
        "5": {
            "verses": {
                "84:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "6": {
            "verses": {
                "84:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿كَادِحٌ إِلَى رَبِّكَ﴾ سَاعٍ إِلَى اللهِ، وَعَامِلٌ بِالخَيْرِ أَوِ الشَّرِّ.</p>"
        },
        "7": {
            "verses": {
                "84:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿كِتَابَهُ﴾ صَحِيفَةَ عَمَلِهِ.</h2>"
        },
