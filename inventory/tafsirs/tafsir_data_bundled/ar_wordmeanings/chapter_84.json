                "language_name": "english"
            },
            "text": "<p>﴿يَدْعُو ثُبُورًا﴾ يَدْعُو بِالهَلاَكِ قَائِلاً: وَاثُبُورَاهْ!</p>"
        },
        "12": {
            "verses": {
                "84:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَيَصْلَى سَعِيرًا﴾ يَدْخُلُ النَّارَ يُقَاسِي حَرَّهَا.</h2>"
        },
        "13": {
            "verses": {
