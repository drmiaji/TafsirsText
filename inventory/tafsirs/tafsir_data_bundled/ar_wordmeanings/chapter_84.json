            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَلاَ أُقْسِمُ﴾ أُقْسِمُ، وَ(لاَ): لِتَأْكِيدِ القَسَمِ.</h2>\n<h2>﴿بِالشَّفَقِ﴾ بِاحْمِرَارِ الأُفُقِ عِنْدَ الغُرُوبِ.</h2>"
        },
        "17": {
            "verses": {
                "84:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَسَقَ﴾ جَمَعَ.</h2>"
        },
        "18": {
            "verses": {
                "84:18": {
                    "id": 18
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿اتَّسَقَ﴾ تَكَامَلَ نُورُهُ، وَأَبْدَرَ.</h2>"
        },
        "19": {
            "verses": {
                "84:19": {
                    "id": 19
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿طَبَقًا عَنْ طَبَقٍ﴾ أَطْوَارًا مُتَعَدِّدَةً، وَأَحْوَالاً مُتَبَايِنَةً: نُطْفَةً، ثُمَّ عَلَقَةً، وَهَكَذَا.</p>"
        },
