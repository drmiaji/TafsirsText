{
    "chapter": 89,
    "verses": {
        "1": {
            "verses": {
                "89:1": {
                    "id": 1
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَالْفَجْرِ﴾ قَسَمٌ بِالوَقْتِ المَعْرُوفِ أَوَّلَ النَّهَارِ.</p>"
        },
        "2": {
            "verses": {
                "89:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَلَيَالٍ عَشْرٍ﴾ قَسَمٌ بِلَيَالِي عَشْرِ ذِي الحِجَّةِ الأُوَلِ، وَمَا شَرُفَتْ بِهِ مِنْ أَعْمَالٍ.</p>"
        },
        "3": {
            "verses": {
                "89:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَالشَّفْعِ وَالْوَتْرِ﴾ قَسَمٌ بِكُلِّ زَوْجٍ، وَفَرْدٍ.</h2>"
        },
        "4": {
            "verses": {
                "89:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿يَسْرِ﴾ يَسْرِي بِظَلاَمِهِ، وَجَوَابُ القَسَمِ مَحْذُوفٌ، تَقْدِيرُهُ: لَتُبْعَثُنَّ.</p>"
        },
        "5": {
            "verses": {
                "89:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لِذِي حْجِرٍ﴾ لِصَاحِبِ عَقْلٍ.</h2>"
        },
        "6": {
            "verses": {
                "89:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "7": {
            "verses": {
                "89:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿إِرَمَ﴾ قَبِيلَةِ إِرَمَ؛ نِسْبَةً إِلَى جَدِّهِمْ.</h2>\n<p>﴿ذَاتِ الْعِمَادِ﴾ صَاحِبَةِ القُوَّةِ، وَالأَبْنِيَةِ المَرْفُوعَةِ عَلَى الأَعْمِدَةِ.</p>"
        },
        "8": {
            "verses": {
                "89:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "9": {
            "verses": {
                "89:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿جَابُوا﴾ قَطَعُوا.</h2>\n<p>﴿بِالْوَادِ﴾ وَادِي القُرَى شَمَالَ غَرْبِ الجَزِيرَةِ العَرَبِيَّةِ.</p>"
        },
        "10": {
            "verses": {
                "89:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿ذِي الأَوْتَادِ﴾ صَاحِبِ الجُنُودِ الَّذِينَ ثَبَّتُوا مُلْكَهُ.</p>"
        },
        "11": {
            "verses": {
                "89:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿طَغَوْا﴾ تَجَاوَزُوا الحَدَّ فِي الإِفْسَادِ.</h2>"
        },
        "12": {
            "verses": {
                "89:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "13": {
            "verses": {
                "89:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿سَوْطَ عَذَابٍ﴾ عَذَابًا شَدِيدًا.</h2>"
        },
        "14": {
            "verses": {
                "89:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لَبِالْمِرْصَادِ﴾ يَرْقُبُ العَاصِينَ، وَيُمْهِلُهُمْ، ثُمَّ يَأْخُذُهُمْ.</p>"
        },
        "15": {
            "verses": {
                "89:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿ابْتَلاَهُ﴾ اخْتَبَرَهُ بِالنِّعْمَةِ.</h2>"
        },
        "16": {
            "verses": {
                "89:16": {
                    "id": 16
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَقَدَرَ﴾ ضَيَّقَ.</h2>"
        },
        "17": {
            "verses": {
                "89:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْيَتِيمَ﴾ الَّذِي مَاتَ أَبُوهُ قَبْلَ بُلُوغِهِ.</h2>"
        },
        "18": {
            "verses": {
                "89:18": {
                    "id": 18
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿ولاَ تَحَآضُّونَ﴾ لاَ يَحُثُّ بَعْضُكُمْ بَعْضًا.</h2>"
        },
        "19": {
            "verses": {
                "89:19": {
                    "id": 19
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿التُّرَاثَ﴾ المِيرَاثَ.</h2>\n<h2>﴿لَمًّا﴾ شَدِيدًا.</h2>"
        },
        "20": {
            "verses": {
                "89:20": {
                    "id": 20
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿جَمًّا﴾ مُفْرِطًا.</h2>"
        },
        "21": {
            "verses": {
                "89:21": {
                    "id": 21
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿دُكَّتِ﴾ زُلْزِلَتْ.</h2>"
        },
        "22": {
            "verses": {
                "89:22": {
                    "id": 22
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَجَاءَ رَبُّكَ﴾ جَاءَ رَبُّكَ لِفَصْلِ القَضَاءِ بَيْنَ العِبَادِ مَجِيئًا يَلِيقُ بِجَلاَلِهِ.</p>\n<h2>﴿وَالْمَلَكُ﴾ المَلاَئِكَةُ.</h2>\n<h2>﴿صَفًّا صَفًّا﴾ صُفُوفًا كَثِيرَةً.</h2>"
        },
        "23": {
            "verses": {
                "89:23": {
                    "id": 23
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَنَّى لَهُ الذِّكْرَى﴾ لاَ يَنْفَعُهُ التَّذَكُّرُ؛ فَقَدْ فَاتَ أَوَانُهُ.</p>"
        },
        "24": {
            "verses": {
