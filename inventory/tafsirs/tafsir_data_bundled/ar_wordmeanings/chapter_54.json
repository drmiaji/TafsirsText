            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَسُعُرٍ﴾ عَذَابٍ.</h2>"
        },
        "48": {
            "verses": {
                "54:48": {
                    "id": 48
                }
