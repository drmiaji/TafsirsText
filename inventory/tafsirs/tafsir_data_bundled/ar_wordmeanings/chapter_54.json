                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَانْشَقَّ الْقَمَرُ﴾ انْفَلَقَ القَمَرُ فَلْقَتَيْنِ؛ مُعْجِزَةً لِلنَّبِيِّ صلّى الله عليه وسلّم، عِنْدَمَا سَأَلَهُ المُشْرِكُونَ آيَةً.</p>"
        },
        "2": {
            "verses": {
                "54:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مُسْتَمِرٌّ﴾ بَاطِلٌ مُضْمَحِلٌّ، أَوْ قَوِيٌّ دَائِمٌ.</h2>"
        },
        "3": {
            "verses": {
                "54:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مُسْتَقِرٌّ﴾ مُنْتَهٍ إِلَى غَايَةٍ يَسْتَقِرُّ عَلَيْهَا.</h2>"
        },
        "4": {
            "verses": {
                "54:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مُزْدَجَرٌ﴾ كِفَايَةٌ لِرَدْعِهِمْ عَنْ كُفْرِهِمْ.</h2>"
        },
        "5": {
            "verses": {
