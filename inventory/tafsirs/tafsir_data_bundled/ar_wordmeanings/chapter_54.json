            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فِي الزُّبُرِ﴾ مَكْتُوبٌ فِي الكُتُبِ الَّتِي بِيَدِ الحَفَظَةِ.</p>"
        },
        "53": {
