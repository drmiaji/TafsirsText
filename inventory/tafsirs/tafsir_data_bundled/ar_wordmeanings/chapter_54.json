            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَشْيَاعَكُمْ﴾ أَشْبَاهَكُمْ فِي الكُفْرِ.</h2>\n<h2>﴿مُدَّكِرٍ﴾ مُتَّعِظٍ.</h2>"
        },
        "52": {
            "verses": {
                "54:52": {
