            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿إِلاَّ وَاحِدَةٌ﴾ إِلاَّ قَوْلَةٌ وَاحِدَةٌ، وَهِيَ: «كُنْ».</p>\n<p>﴿كَلَمْحٍ بِالْبَصَرِ﴾ سَرِيعٍ لاَ يَتَأَخَّرُ كَطَرْفَةِ العَيْنِ.</p>"
        },
        "51": {
            "verses": {
                "54:51": {
                    "id": 51
                }
            },
            "resource_id": 116,
