                "language_name": "english"
            },
            "text": "<h2>﴿آلَ فِرْعَوْنَ﴾ أَتْبَاعَهُ، وَقَوْمَهُ.</h2>\n<h2>﴿النُّذُرُ﴾ الإِنْذَارُ بِالعُقُوبَةِ.</h2>"
        },
        "42": {
            "verses": {
