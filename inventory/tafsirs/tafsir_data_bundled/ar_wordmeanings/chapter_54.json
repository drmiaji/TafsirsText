            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مُسْتَطَرٌ﴾ مَسْطُورٌ مَكْتُوبٌ فِي صَحَائِفِ أَعْمَالِهِمْ.</p>"
        },
