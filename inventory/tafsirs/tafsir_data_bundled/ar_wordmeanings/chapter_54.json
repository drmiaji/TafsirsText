            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أَدْهَى وَأَمَرُّ﴾ أَعْظَمُ وَأَشَدُّ مَرَارَةً مِمَّا لَحِقَهُمْ مِنَ العَذَابِ فِي بَدْرٍ.</p>"
        },
        "47": {
