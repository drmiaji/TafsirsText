                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿شَيْءٍ نُكُرٍ﴾ أَمْرٍ فَظِيعٍ مُنْكَرٍ؛ وَهُوَ مَوْقِفُ الحِسَابِ.</p>"
        },
        "7": {
            "verses": {
                "54:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿خُشَّعًا﴾ ذَلِيلَةً مِنْ شِدَّةِ الهَوْلِ.</h2>\n<h2>﴿الأَجْدَاثِ﴾ القُبُورِ.</h2>"
        },
        "8": {
            "verses": {
                "54:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مُهْطِعِينَ﴾ مُسْرِعِينَ.</h2>"
        },
        "9": {
            "verses": {
                "54:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَازْدُجِرَ﴾ زُجِرَ، وَنُهِرَ عَنْ تَبْلِيغِ الدَّعْوَةِ.</h2>"
        },
        "10": {
            "verses": {
                "54:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَغْلُوبٌ﴾ ضَعِيفٌ عَنْ مُقَاوَمَتِهِمْ.</h2>"
        },
        "11": {
            "verses": {
                "54:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مُنْهَمِرٍ﴾ مُتَدَفِّقٍ.</h2>"
        },
        "12": {
            "verses": {
                "54:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَفَجَّرْنَا﴾ شَقَقْنَا.</h2>\n<p>﴿فَالْتَقَى الْمَاءُ﴾ أَيِ: الْتَقَى مَاءُ السَّمَاءِ وَالمَاءُ المُتَفَجِّرُ مِنَ الأَرْضِ.</p>\n<p>﴿قُدِرَ﴾ قَدَّرَهُ الله فِي الأَزَلِ؛ وَهُوَ إِهْلاَكُهُمْ بِالطُّوفَانِ.</p>"
        },
        "13": {
            "verses": {
                "54:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿عَلَى ذَاتِ أَلْوَاحٍ وَدُسُرٍ﴾ سَفِينَةٍ ذَاتِ أَلْوَاحٍ، وَمَسَامِيرَ شُدَّتْ بِهَا.</p>"
        },
        "14": {
            "verses": {
                "54:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿بِأَعْيُنِنَا﴾ بِمَرْأًى مِنَّا، وَحِفْظٍ، وَفِيهَا: إِثْبَاتُ صِفَةِ العَيْنَيْنِ للهِ تَعَالَى؛ كَمَا يَلِيقُ بِجَلاَلِهِ.</p>\n<p>﴿جَزَاءً﴾ أُغْرِقُوا انْتِصَارًا مِنَّا لِنُوحٍ عليه السلام، وَعُقُوبَةً لَهُمْ عَلَى كُفْرِهِمْ.</p>\n<h2>﴿لِمَنْ كَانَ كُفِرَ﴾ هُوَ: نُوحٌ عليه السلام.</h2>"
        },
        "15": {
            "verses": {
                "54:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿تَرَكْنَاهَا آيَةً﴾ أَبْقَيْنَا قِصَّةَ نُوحٍ عليه السلام، وَعُقُوبَةَ قَوْمِهِ؛ عِبْرَةً، وَدَلِيلاً عَلَى قُدْرَتِنَا.</p>\n<h2>﴿مُدَّكِرٍ﴾ مُعْتَبَرٍ، وَمُتَّعَظٍ.</h2>"
        },
        "16": {
            "verses": {
                "54:16": {
                    "id": 16
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَنُذُرِ﴾ إِنْذَارِي.</h2>"
        },
