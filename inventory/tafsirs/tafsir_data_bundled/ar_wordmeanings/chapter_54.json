            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿عَزِيزٍ﴾ غَالِبٍ، قَوِيٍّ لاَ يُغْلَبُ.</h2>"
        },
        "43": {
            "verses": {
                "54:43": {
                    "id": 43
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الزُّبُرِ﴾ الكُتُبِ المُنَزَّلَةِ عَلَى الأَنْبِيَاءِ عليهما السلام.</p>"
        },
        "44": {
            "verses": {
                "54:44": {
                    "id": 44
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿نَحْنُ جَمِيعٌ مُنْتَصِرٌ﴾ جَمَاعَةٌ مُنْتَصِرَةٌ لاَ يَغْلِبُنَا مَنْ أَرَادَنَا بِسُوءٍ.</p>"
        },
        "45": {
            "verses": {
                "54:45": {
                    "id": 45
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْجَمْعُ﴾ جَمَاعَةُ كُفَّارِ مَكَّةَ.</h2>\n<p>﴿وَيُوَلُّونَ الدُّبُرَ﴾ يَفِرُّونَ مُنْهَزِمِينَ، قَدْ وَلَّوْكُمْ أَدْبَارَهُمْ؛ وَقَدْ حَصَلَ هَذَا فِي غَزْوَةِ بَدْرٍ.</p>"
        },
        "46": {
            "verses": {
                "54:46": {
                    "id": 46
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
