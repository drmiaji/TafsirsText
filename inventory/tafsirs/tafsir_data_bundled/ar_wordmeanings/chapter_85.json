            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بَطْشَ﴾ انْتقَامَ.</h2>"
        },
        "13": {
            "verses": {
                "85:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يُبْدِىءُ﴾ يَخْلُقُ الخَلْقَ ابْتِدَاءً.</h2>\n<h2>﴿وَيُعِيدُ﴾ يُحْيِيهِمْ بَعْدَ مَوْتِهِمْ.</h2>"
        },
        "14": {
            "verses": {
                "85:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْوَدُودُ﴾ المُحِبُّ لِأَوْلِيَائِهِ، المَحْبُوبُ لَهُمْ.</h2>"
        },
        "15": {
            "verses": {
                "85:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْمَجِيدُ﴾ العَظِيمُ.</h2>"
        },
