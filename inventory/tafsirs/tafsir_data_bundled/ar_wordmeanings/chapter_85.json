                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿ذَاتِ الْبُرُوجِ﴾ ذَاتِ المَنَازِلِ الَّتِي تَمُرُّ بِهَا الشَّمْسُ، وَالقَمَرُ.</p>"
        },
        "2": {
            "verses": {
                "85:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَالْيَوْمِ الْمَوْعُودِ﴾ هُوَ: يَوْمُ القِيَامَةِ.</h2>"
        },
        "3": {
            "verses": {
                "85:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَشَاهِدٍ وَمَشْهُودٍ﴾ أَقْسَمَ اللهُ بِكُلِّ شَاهِدٍ يَشْهَدُ، وَبِكُلِّ مَا يُشْهَدُ عَلَيْهِ.</p>"
        },
        "4": {
            "verses": {
                "85:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿قُتِلَ﴾ لُعِنَ، وَعُذِّبَ، وَهَلَكَ.</h2>\n<p>﴿أَصْحَابُ الأُخْدُودِ﴾ الَّذِينَ شَقُّوا فِي الأَرْضِ شَقًّا عَظِيمًا؛ لِإِحْرَاقِ المُؤْمِنِينَ.</p>"
        },
        "5": {
            "verses": {
                "85:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْوَقُودِ﴾ مَا تُشْعَلُ وَتُوقَدُ بِهِ النَّارُ.</h2>"
        },
        "6": {
            "verses": {
                "85:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "7": {
            "verses": {
                "85:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿شُهُودٌ﴾ حُضُورٌ.</h2>"
        },
        "8": {
            "verses": {
                "85:8": {
                    "id": 8
                }
