            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَتَنُوا﴾ حَرَّقُوا بِالنَّارِ.</h2>\n<h2>﴿الْحَرِيقِ﴾ العَذَابُ المُحْرِقُ.</h2>"
        },
        "11": {
            "verses": {
                "85:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
