            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَحَاقَ بِهِمْ﴾ نَزَلَ بِهِمْ.</h2>"
        },
        "34": {
            "verses": {
                "45:34": {
                    "id": 34
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿نَنْسَاكُمْ﴾ نَتْرُكُكُمْ فِي العَذَابِ.</h2>\n<h2>﴿وَمَأْوَاكُمُ﴾ مَنْزِلُكُمْ وَمَقَرُّكُمْ.</h2>"
        },
        "35": {
            "verses": {
                "45:35": {
                    "id": 35
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَغَرَّتْكُمُ﴾ خَدَعَتْكُمْ.</h2>\n<p>﴿وَلاَ هُمْ يُسْتَعْتَبُونَ﴾ لاَ يُطْلَبُ مِنْهُمْ أَنْ يُرْضُوا رَبَّهُمْ بِالتَّوْبَةِ، وَالطَّاعَةِ.</p>"
        },
