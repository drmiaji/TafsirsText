            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿إِنْ نَظُنُّ إِلاَّ ظَنًّا﴾ مَا نَتَوَقَّعُ وُقُوعَهَا إِلاَّ تَوَهُّمًا.</p>"
        },
        "33": {
            "verses": {
