                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لاَ يَرْجُونَ أَيَّامَ اللَّهِ﴾ لاَ يَتَوَقَّعُونَ وَقَائِعَهُ وَعَذَابَهُ بِأَعْدَائِهِ.</p>"
        },
        "15": {
            "verses": {
                "45:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "16": {
            "verses": {
                "45:16": {
                    "id": 16
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْكِتَابَ﴾ التَّوْرَاةَ، وَالإِنْجِيلَ.</h2>\n<h2>﴿وَالْحُكْمَ﴾ تَحْكِيمَهُمَا.</h2>"
        },
        "17": {
            "verses": {
                "45:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿بَيِّنَاتٍ مِنَ الأَمْرِ﴾ شَرَائِعَ وَاضِحَاتٍ فِي الحَلاَلِ، وَالحَرَامِ، وَدَلاَلاَتٍ تُبَيِّنُ الحَقَّ مِنَ البَاطِلِ.</p>\n<h2>﴿بَغْيًا بَيْنَهُمْ﴾ حَسَدًا وَعَدَاوَةً بَيْنَهُمْ.</h2>"
        },
        "18": {
            "verses": {
                "45:18": {
                    "id": 18
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿شَرِيعَةٍ مِنَ الأَمْرِ﴾ مِنْهَاجٍ وَاضِحٍ مِنْ أَمْرِ الدِّينِ.</p>"
        },
        "19": {
            "verses": {
                "45:19": {
                    "id": 19
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لَنْ يُغْنُوا عَنْكَ﴾ لَنْ يَدْفَعُوا عَنْكَ.</h2>"
        },
        "20": {
            "verses": {
                "45:20": {
                    "id": 20
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بَصَائِرُ﴾ يُبْصِرُ بِهِ النَّاسُ الحَقَّ.</h2>"
        },
        "21": {
            "verses": {
                "45:21": {
                    "id": 21
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَمْ حَسِبَ﴾ بَلْ ظَنَّ.</h2>\n<h2>﴿اجْتَرَحُوا﴾ اكْتَسَبُوا.</h2>"
        },
        "22": {
            "verses": {
