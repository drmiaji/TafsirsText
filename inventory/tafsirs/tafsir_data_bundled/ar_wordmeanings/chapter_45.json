            },
            "text": "<h2>﴿يَبُثُّ﴾ يَنْشُرُ، وَيُفَرِّقُ.</h2>"
        },
        "5": {
            "verses": {
                "45:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَتَصْرِيفِ الرِّيَاحِ﴾ تَقْلِيبِهَا فِي مَهَابِّهَا لِمَنْفَعَتِكُمْ.</p>"
        },
        "6": {
            "verses": {
