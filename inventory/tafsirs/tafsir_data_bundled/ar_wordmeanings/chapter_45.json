            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَيْلٌ﴾ هَلاَكٌ، وَدَمَارٌ.</h2>\n<h2>﴿أَفَّاكٍ﴾ كَذَّابٍ.</h2>\n<h2>﴿أَثِيمٍ﴾ كَثِيرِ الإِثْمِ.</h2>"
        },
        "8": {
            "verses": {
