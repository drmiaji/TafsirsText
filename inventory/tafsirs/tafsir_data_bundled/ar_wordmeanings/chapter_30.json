            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿قَانِتُونَ﴾ مُطِيعُونُ مُنْقَادُونَ لأِمْرِهِ.</h2>"
        },
        "27": {
            "verses": {
                "30:27": {
                    "id": 27
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَلَهُ الْمَثَلُ الأَعْلَى﴾ الوَصْفُ الأَعْلَى فِي كُلِّ مَا يُوصَفُ بِهِ.</p>"
        },
        "28": {
            "verses": {
                "30:28": {
                    "id": 28
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَأَنْتُمْ فِيهِ سَوَاءٌ﴾ مُتَسَاوُونَ.</h2>"
        },
        "29": {
            "verses": {
                "30:29": {
                    "id": 29
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
