            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَبْسُطُ﴾ يُوسِعُ.</h2>\n<h2>﴿وَيَقْدِرُ﴾ يُضَيَّقُ.</h2>"
        },
