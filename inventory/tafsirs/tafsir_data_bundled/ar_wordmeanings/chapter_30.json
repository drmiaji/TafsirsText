                "language_name": "english"
            },
            "text": "<p>﴿لِلْعَالِمِينَ﴾ جَمْعُ عَالِم، وَهُمْ ذَوُو العِلْمِ وَالبَصِيرَةِ.</p>"
        },
        "23": {
            "verses": {
