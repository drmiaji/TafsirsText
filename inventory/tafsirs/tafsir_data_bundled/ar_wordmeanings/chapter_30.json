            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَابْتِغَاؤُكُمْ مِنْ فَضْلِهِ﴾ طَلَبُكُمْ لِلرِّزْقِ فِي النَّهَارِ.</p>"
        },
        "24": {
            "verses": {
                "30:24": {
                    "id": 24
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿خَوْفًا وَطَمَعًا﴾ تَخَافُونَ مِنَ الصَّوَاعِقِ، وَتَطْمَعُونَ فِي الغَيْثِ.</p>"
        },
