            "text": "<h2>﴿غُلِبَتِ الرُّومُ﴾ هَزَمَتْ فَارِسُ الرُّومَ.</h2>"
        },
        "3": {
            "verses": {
                "30:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَدْنَى الأَرْضِ﴾ أَقْرَبِ أَرْضِ الشَّامِ إِلَى فَارِسَ.</h2>\n<h2>﴿غَلَبِهِمْ﴾ كَوْنِهِمْ مَغْلُوبِينَ.</h2>"
        },
        "4": {
            "verses": {
