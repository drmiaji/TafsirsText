            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿قَنَطُوا﴾ يَئِسُوا مِنْ نُزُولِهِ.</h2>\n<h2>﴿وَيَنْشُرُ رَحْمَتَهُ﴾ يَبْسُطُ مَطَرَهُ.</h2>\n<h2>﴿الْوَلِيُّ﴾ الَّذِي يَتَوَلَّى عِبَادَهُ بِإِحْسَانِهِ.</h2>"
        },
        "29": {
            "verses": {
                "42:29": {
                    "id": 29
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بَثَّ﴾ فَرَّقَ، وَنَشَرَ.</h2>\n<p>﴿دَآبَّةٍ﴾ مَا يَدُبُّ عَلَى الأَرْضِ؛ مِنْ إِنْسٍ، وَحَيَوَانٍ، وَغَيْرِهِمَا.</p>"
        },
