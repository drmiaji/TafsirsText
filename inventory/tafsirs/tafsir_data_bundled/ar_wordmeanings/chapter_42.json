                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَتَفَطَّرْنَ﴾ يَتَشَقَّقْنَ.</h2>"
        },
        "6": {
            "verses": {
                "42:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَوْلِيَاءَ﴾ آلِهَةً يَتَوَلَّوْنَهَا، وَيَعْبُدُونَهَا.</h2>\n<h2>﴿حَفِيظٌ﴾ رَقِيبٌ عَتِيدٌ.</h2>"
        },
        "7": {
            "verses": {
                "42:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أُمَّ الْقُرَى﴾ مَكَّةَ؛ وَالمُرَادُ أَهْلُهَا.</h2>\n<h2>﴿لاَ رَيْبَ فِيهِ﴾ لاَ شَكَّ فِي مَجِيئِهِ.</h2>"
        },
        "8": {
            "verses": {
                "42:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أُمَّةً وَاحِدَةً﴾ مُجْتَمِعِينَ عَلَى الهُدَى.</h2>"
        },
        "9": {
            "verses": {
                "42:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "10": {
            "verses": {
                "42:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَإِلَيْهِ أُنِيبُ﴾ إِلَيْهِ أَرْجِعُ فِي كُلِّ الأُمُورِ.</h2>"
        },
        "11": {
            "verses": {
                "42:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَاطِرُ﴾ خَالِقُ، وَمُبْدِعُ.</h2>\n<p>﴿وَمِنَ الأَنْعَامِ أَزْوَاجًا﴾ أَنْوَاعًا؛ ذُكُورًا، وَإِنَاثًا.</p>\n<h2>﴿يَذْرَؤُكُمْ فِيهِ﴾ يُكَثِّرُكُمْ؛ بِسَبَبِ التَّزْوِيجِ.</h2>"
        },
        "12": {
            "verses": {
                "42:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مَقَالِيدُ السَّمَاوَاتِ﴾ مِلْكُهَا، وَمَفَاتِيحُ خَزَائِنِهَا.</p>\n<h2>﴿يَبْسُطُ﴾ يُوسِعُ.</h2>\n<h2>﴿وَيَقْدِرُ﴾ يُضَيِّقُ.</h2>"
        },
        "13": {
            "verses": {
                "42:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿كَبُرَ﴾ عَظُمَ.</h2>\n<h2>﴿يَجْتَبِي إِلَيْهِ﴾ يَصْطَفِي لِتَوْحِيدِهِ، وَدِينِهِ.</h2>\n<h2>﴿يُنِيبُ﴾ يَرْجِعُ إِلَيْهِ بِالطَّاعَةِ.</h2>"
        },
        "14": {
            "verses": {
                "42:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بَغْيًا﴾ عِنَادًا، وَظُلْمًا.</h2>\n<h2>﴿كَلِمَةٌ سَبَقَتْ﴾ بِتَأْخِيرِ العَذَابِ.</h2>\n<h2>﴿الْكِتَابَ﴾ التَّوْرَاةَ، وَالإِنْجِيلَ.</h2>\n<p>﴿مُرِيبٍ﴾ مُوقِعٍ فِي الرِّيبَةِ، وَالاِخْتِلاَفِ المَذْمُومِ.</p>"
        },
        "15": {
            "verses": {
                "42:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَلِذَلِكَ فَادْعُ﴾ قُمْ بِالدَّعْوَةِ إِلَى ذَلِكَ الدِّينِ.</p>\n<p>﴿لاَ حُجَّةَ بَيْنَنَا وَبَيْنَكُمْ﴾ لاَ جِدَالَ بَيْنَنَا وَبَيْنَكُمْ؛ بَعْدَمَا تَبَيَّنَ الحَقُّ.</p>\n<h2>﴿الْمَصِيرُ﴾ المَرْجِعُ.</h2>"
        },
        "16": {
            "verses": {
                "42:16": {
                    "id": 16
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يُحَآجُّونَ فِي اللَّهِ﴾ يُخَاصِمُونَ فِي دِينِ اللهِ.</h2>\n<h2>﴿دَاحِضَةٌ﴾ ذَاهِبَةٌ بَاطِلَةٌ.</h2>"
        },
        "17": {
            "verses": {
                "42:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بِالْحَقِّ﴾ بِالصِّدْقِ.</h2>\n<h2>﴿وَالْمِيزَانَ﴾ العَدْلَ.</h2>"
        },
        "18": {
            "verses": {
                "42:18": {
                    "id": 18
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مُشْفِقُونَ مِنْهَا﴾ خَائِفُونَ مِنْ قِيَامِهَا.</h2>\n<h2>﴿يُمَارُونَ﴾ يُجَادِلُونَ.</h2>"
        },
