            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿إِلاَّ الْمَوَدَّةَ فِي الْقُرْبَى﴾ لاَ تُؤْذُونِي فِي تَبْلِيغِ الدَّعْوَةِ؛ لِمَا بَيْنِي وَبَيْنَكُمْ مِنَ القَرَابَةِ.</p>\n<h2>﴿يَقْتَرِفْ حَسَنَةً﴾ يَكْتَسِبْ طَاعَةً.</h2>"
        },
        "24": {
            "verses": {
                "42:24": {
                    "id": 24
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
