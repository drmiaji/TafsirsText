            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿كَلِمَةُ الْفَصْلِ﴾ قَضَاؤُهُ بِإِمْهَالِهِمْ وَعَدَمِ مُعَاجَلَتِهِمْ بِالعُقُوبَةِ.</p>"
        },
