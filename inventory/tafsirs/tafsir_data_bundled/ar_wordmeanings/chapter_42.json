            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿افْتَرَى﴾ اخْتَلَقَ.</h2>\n<h2>﴿يَخْتِمْ﴾ يَطْبَعْ.</h2>"
        },
