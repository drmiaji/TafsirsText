            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَعَدَّدَهُ﴾ أَحْصَاهُ.</h2>"
        },
        "3": {
            "verses": {
                "104:3": {
                    "id": 3
