                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَحْسَبُ﴾ يَظُنُّ.</h2>\n<h2>﴿أَخْلَدَهُ﴾ أَبْقَاهُ خَالِدًا فِي الدُّنْيَا.</h2>"
        },
        "4": {
            "verses": {
                "104:4": {
                    "id": 4
