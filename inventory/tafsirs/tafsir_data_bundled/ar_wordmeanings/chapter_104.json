            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿كَلاَّ﴾ لَيْسَ الأَمْرُ كَمَا يَظُنُّ.</h2>\n<h2>﴿لَيُنْبَذَنَّ﴾ لَيُطْرَحَنَّ.</h2>\n<p>﴿الْحُطَمَةِ﴾ النَّارِ الَّتِي تَهْشِمُ كُلَّ مَا يُلْقَى فِيهَا.</p>"
        },
