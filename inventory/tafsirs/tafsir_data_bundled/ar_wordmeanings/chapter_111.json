            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَا أَغْنَى عَنْهُ﴾ مَا دَفَعَ عَنْهُ الخَسَارَ.</h2>\n<h2>﴿وَمَا كَسَبَ﴾ وَهُوَ وَلَدُهُ.</h2>"
        },
        "3": {
            "verses": {
                "111:3": {
