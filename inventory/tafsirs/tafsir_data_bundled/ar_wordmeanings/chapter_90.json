                "language_name": "english"
            },
            "text": "<h2>﴿لاَ أُقْسِمُ﴾ أُقْسِمُ، وَ(لاَ): لِتَأْكِيدِ القَسَمِ.</h2>\n<h2>﴿الْبَلَدِ﴾ مَكَّةَ.</h2>"
        },
        "2": {
            "verses": {
                "90:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿حِلٌّ﴾ يَحِلُّ لَكَ مَا تَصْنَعُ بِهِ مِنَ المُقَاتَلَةِ، وَقَدْ أَنْجَزَ اللهُ لَهُ هَذَا الوَعْدَ فِي فَتْحِ مَكَّةَ.</p>"
        },
        "3": {
            "verses": {
                "90:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَوَالِدٍ وَمَا وَلَدَ﴾ قَسَمٌ بِكُلِّ وَالِدٍ، وَبِكُلِّ مَوْلُودٍ، وَمِنْهُمْ آدَمُ عليه السلام وَذُرِّيَّتُهُ.</p>"
        },
        "4": {
            "verses": {
                "90:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿كَبَدٍ﴾ شِدَّةٍ وَعَنَاءٍ مِنْ مُكَابَدَةِ الدُّنْيَا.</h2>"
        },
