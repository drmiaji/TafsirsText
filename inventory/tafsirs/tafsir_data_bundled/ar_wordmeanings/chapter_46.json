            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿افْتَرَاهُ﴾ اخْتَلَقَهُ.</h2>\n<h2>﴿تُفِيضُونَ فِيهِ﴾ تَقُولُونَ فِي القُرْآنِ.</h2>"
        },
        "9": {
            "verses": {
                "46:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿بِدْعًا مِنَ الرُّسُلِ﴾ أَوَّلَ رُسُلِ اللهِ إِلَى خَلْقِهِ.</p>"
        },
        "10": {
            "verses": {
                "46:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَرَأَيْتُمْ﴾ أَخْبِرُونِي.</h2>\n<p>﴿وَشَهِدَ شَاهِدٌ﴾ كَعَبْدِ اللهِ بْنِ سَلاَمٍ رضي الله عنه.</p>"
        },
        "11": {
            "verses": {
                "46:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿إِفْكٌ قَدِيمٌ﴾ كَذِبٌ مَأْثُورٌ عَنِ النَّاسِ الأَقْدَمِينَ.</p>"
        },
        "12": {
            "verses": {
                "46:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿إِمَامًا﴾ هَادِيًا يَأْتَمُّونَ بِهِ، وَيَعْمَلُونَ.</h2>\n<h2>﴿مُصَدِّقٌ﴾ لِكُتُبٍ قَبْلَهُ.</h2>"
        },
        "13": {
            "verses": {
                "46:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿اسْتَقَامُوا﴾ ثَبَتُوا عَلَى الإِيمَانِ وَالطَّاعَةِ.</h2>"
        },
        "14": {
            "verses": {
