                "language_name": "english"
            },
            "text": "<p>﴿وَأَجَلٍ مُسَمّىً﴾ هُوَ: وَقْتُ فَنَائِهِمَا إِذَا قَامَتِ القِيَامَةُ.</p>"
        },
        "4": {
            "verses": {
                "46:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لَهُمْ شِرْكٌ﴾ شِرْكَةٌ وَنَصِيبٌ مَعَ اللهِ تَعَالَى فِي خَلْقِ السَّمَاوَاتِ.</p>\n<h2>﴿أَثَارَةٍ﴾ بَقِيَّةٍ.</h2>"
        },
        "5": {
            "verses": {
                "46:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَنْ أَضَلُّ﴾ لاَ أَحَدَ أَضَلُّ، وَأَجْهَلُ.</h2>"
        },
        "6": {
            "verses": {
