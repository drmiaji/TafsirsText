                "language_name": "english"
            },
            "text": "<h2>﴿عَارِضًا﴾ سَحَابًا عَرَضًا فِي أُفُقِ السَّمَاءِ.</h2>"
        },
        "25": {
            "verses": {
                "46:25": {
                    "id": 25
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿تُدَمِّرُ﴾ تُهْلِكُ.</h2>\n<h2>﴿كُلَّ شَيْءٍ﴾ مَرَّتْ بِهِ مِمَّا أُرْسِلَتْ بِهَلاَكِهِ.</h2>"
        },
        "26": {
            "verses": {
                "46:26": {
                    "id": 26
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَكَّنَّاهُمْ﴾ أَقْدَرْنَاهُمْ، وَبَسَطْنَا لَهُمْ.</h2>\n<p>﴿فِيمَا إِنْ مَكَّنَاكُمْ فِيهِ﴾ فِي الَّذِي لَمْ نُمَكِّنْكُمْ فِيهِ.</p>\n<h2>﴿وَحَاقَ﴾ نَزَلَ.</h2>"
        },
        "27": {
            "verses": {
                "46:27": {
                    "id": 27
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَصَرَّفْنَا الآيَاتِ﴾ بَيَّنَّا لَهُمْ أَنْوَاعَ الحُجَجِ، وَكَرَّرْنَاهَا لَهُمْ.</p>"
        },
        "28": {
            "verses": {
                "46:28": {
                    "id": 28
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَلَوْلاَ﴾ هَلاَّ.</h2>\n<h2>﴿قُرْبَاناً﴾ يَتَقَرَّبُونَ بِهَا إِلَى رَبِّهِمْ.</h2>\n<h2>﴿إِفْكُهُمْ﴾ كَذِبُهُمْ.</h2>\n<h2>﴿يَفْتَرُونَ﴾ يَكْذِبُونَ.</h2>"
        },
        "29": {
            "verses": {
                "46:29": {
                    "id": 29
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿صَرَفْنَا﴾ بَعَثْنَا وَوَجَّهْنَا نَحْوَكَ.</h2>\n<p>﴿قُضِيَ﴾ فَرَغَ رَسُولُ اللهِ صلّى الله عليه وسلّم مِنْ تِلاَوَتِهِ.</p>\n<h2>﴿مُنْذِرِينَ﴾ مُحَذِّرِينَ مِنْ بَأْسِ اللهِ.</h2>"
        },
        "30": {
