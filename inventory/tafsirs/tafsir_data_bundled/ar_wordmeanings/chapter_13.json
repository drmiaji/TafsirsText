            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿تَغِيضُ الأَرْحَامُ﴾ تَنْقُصُهُ الأَرْحَامُ؛ فَيَسْقُطُ قَبْلَ تَمَامِهِ.</p>"
        },
