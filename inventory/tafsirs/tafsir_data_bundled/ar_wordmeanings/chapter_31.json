            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَهْناً﴾ ضَعْفًا.</h2>\n<h2>﴿وَفِصَالُهُ﴾ فِطَامُهُ عَنِ الرَّضَاعَةِ.</h2>"
        },
        "15": {
            "verses": {
                "31:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿سَبِيلَ﴾ طَرِيقَ.</h2>\n<h2>﴿أَنَابَ﴾ رَجَعَ، وَتَابَ.</h2>"
        },
        "16": {
            "verses": {
                "31:16": {
                    "id": 16
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مِثْقَالَ﴾ وَزْنَ، وَمِقْدَارَ.</h2>\n<p>﴿حَبَّةٍ مِنْ خَرْدَلٍ﴾ حَبَّةٍ صَغِيرَةٍ مُتَنَاهِيَةٍ فِي الصِّغَرِ.</p>\n<p>﴿يَأْتِ بِهَا اللَّهُ﴾ يَأْتِ بِهَا يَوْمَ القِيَامَةِ، وَيُحَاسِبْ عَلَيْهَا.</p>"
        },
        "17": {
            "verses": {
                "31:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مِنْ عَزْمِ الأُمُورِ﴾ مِنَ الأُمُورِ الَّتِي يَنْبَغِي الحِرْصُ عَلَيْهَا.</p>"
        },
        "18": {
            "verses": {
                "31:18": {
                    "id": 18
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَلاَ تُصَعِّرْ خَدَّكَ﴾ لاَ تُمِلْ وَجْهَكَ كِبْرًا وَتَعَاظُمًا.</p>\n<h2>﴿مَرَحًا﴾ مُخْتَالاً مُتَبَخْتِرًا.</h2>\n<h2>﴿مُخْتَالٍ﴾ مُتَكَبِّرٍ بِفِعْلِهِ.</h2>\n<h2>﴿فَخُورٍ﴾ مُتَكَبِّرٍ بِقَوْلِهِ.</h2>"
        },
        "19": {
            "verses": {
                "31:19": {
                    "id": 19
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَاقْصِدْ﴾ تَوَاضَعْ، وَكُنْ بَيْنَ المُسْرِعِ، وَالمُبْطِئِ.</p>\n<h2>﴿وَاغْضُضْ﴾ اخْفِضْ.</h2>\n<h2>﴿أَنْكَرَ﴾ أَقْبَحَ، وَأَبْغَضَ.</h2>"
        },
        "20": {
            "verses": {
                "31:20": {
                    "id": 20
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿سَخَّرَ لَكُمْ﴾ ذَلَّلَ لَكُمْ.</h2>\n<h2>﴿وَأَسْبَغَ﴾ عَمَّكُمْ بِنِعَمِهِ.</h2>"
        },
        "21": {
            "verses": {
