            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لاَغِيَةً﴾ لاَ كَلِمَةَ لَغْوٍ وَاحِدَةً، وَلاَ نَفْسًا تَلْغُو وَتَهْذِي.</p>"
        },
        "12": {
            "verses": {
