            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْغَاشِيَةِ﴾ القِيَامَةِ تَغْشَى النَّاسَ بِأَهْوَالِهَا.</h2>"
        },
        "2": {
            "verses": {
                "88:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿خَاشِعَةٌ﴾ ذَلِيلَةٌ مُنْكَسِرَةٌ.</h2>"
        },
        "3": {
            "verses": {
                "88:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿عَامِلَةٌ نَاصِبَةٌ﴾ مُجْهَدَةٌ بِالعَمَلِ وَالتَّعَبِ فِي النَّارِ.</p>"
        },
        "4": {
            "verses": {
                "88:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿تَصْلَى نَارًا﴾ تَدْخُلُ نَارًا، وَتُقَاسِي حَرَّهَا.</h2>\n<h2>﴿حَامِيَةً﴾ شَدِيدَةَ التَّوَهُّجِ.</h2>"
        },
        "5": {
            "verses": {
                "88:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿آنِيَةٍ﴾ شَدِيدَةِ الحَرَارَةِ.</h2>"
        },
        "6": {
            "verses": {
                "88:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿ضَرِيعٍ﴾ نَبْتٍ خَبِيثٍ ذِي شَوْكٍ، لاَ تَرْعَاهُ الدَّوَابُّ.</p>"
        },
        "7": {
            "verses": {
                "88:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
