                "language_name": "english"
            },
            "text": "<h2>﴿ذِي الْمَعَارِجِ﴾ صَاحِبِ العُلُوِّ وَالجَلاَلِ.</h2>"
        },
        "4": {
            "verses": {
                "70:4": {
                    "id": 4
