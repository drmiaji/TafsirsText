                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَفَصِيلَتِهِ﴾ عَشِيرَتِهِ.</h2>\n<h2>﴿تُؤْوِيهِ﴾ تَضُمُّهُ، ويَنْتَمِي إِلَيْهَا.</h2>"
        },
        "14": {
            "verses": {
                "70:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "15": {
            "verses": {
                "70:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿كَلاَّ﴾ لَيْسَ الأَمْرُ كَمَا تَتَمَنَّاهُ أَيُّهَا الكَافِرُ مِنْ حُصُولِ الاِفْتِدَاءِ.</p>\n<h2>﴿لَظَى﴾ جَهَنَّمُ تَتَلَهَّبُ نَارُهَا، وَتَتَلَظَّى.</h2>"
        },
        "16": {
            "verses": {
                "70:16": {
                    "id": 16
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿نَزَّاعَةً لِلشَّوَى﴾ تَنْزِعُ بِشِدَّةِ حَرِّهَا جِلْدَةَ الرَّأْسِ، وَسَائِرَ أَطْرَافِ البَدَنِ.</p>"
        },
        "17": {
            "verses": {
                "70:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "18": {
            "verses": {
                "70:18": {
                    "id": 18
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَأَوْعَى﴾ أَمْسَكَ مَالَهُ فِي وِعَاءٍ، وَلَمْ يُؤَدِّ حَقَّ اللهِ فِيهِ.</p>"
        },
        "19": {
            "verses": {
                "70:19": {
                    "id": 19
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿هَلُوعًا﴾ يَجْزَعُ عِنْدَ المُصِيبَةِ، وَيَمْنَعُ إِذَا أَصَابَهُ الخَيْرُ، وتَفْسِيرُ الهَلُوعِ جَاءَ فِي الآيَتَيْنِ بَعْدَهَا.</p>"
        },
        "20": {
            "verses": {
                "70:20": {
                    "id": 20
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿جَزُوعًا﴾ كَثِيرَ الأَسَى وَالحُزْنِ.</h2>"
        },
        "21": {
            "verses": {
                "70:21": {
                    "id": 21
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْخَيْرُ﴾ المَالُ، وَاليُسْرُ.</h2>"
        },
