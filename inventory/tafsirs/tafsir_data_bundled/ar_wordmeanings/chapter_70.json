            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْعَادُونَ﴾ المُتَجَاوِزُونَ الحَلاَلَ إِلَى الحَرَامِ.</h2>"
        },
        "32": {
