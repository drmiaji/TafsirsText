            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بِيَوْمِ الدِّينِ﴾ يَوْمِ الجَزَاءِ وَالحِسَابِ.</h2>"
        },
