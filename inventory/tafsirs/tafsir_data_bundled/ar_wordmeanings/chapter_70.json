            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَالْمَحْرُومِ﴾ مَنْ يَتَعَفَّفُ عَنِ السُّؤَالِ.</h2>"
        },
        "26": {
            "verses": {
