            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿تَعْرُجُ﴾ تَصْعَدُ.</h2>\n<h2>﴿وَالرُّوحُ﴾ جِبْرِيلُ عليه السلام.</h2>"
        },
        "5": {
            "verses": {
                "70:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿صَبْرًا جَمِيلاً﴾ لاَ جَزَعَ فِيهِ، وَلاَ شَكْوَى مِنْهُ لِغَيْرِ اللهِ.</p>"
        },
        "6": {
            "verses": {
