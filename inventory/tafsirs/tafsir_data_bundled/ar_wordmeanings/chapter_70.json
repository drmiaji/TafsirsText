                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿كَالْمُهْلِ﴾ مِثْلَ حُثَالَةِ الزَّيْتِ.</h2>"
        },
        "9": {
            "verses": {
                "70:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿كَالْعِهْنِ﴾ كَالصُّوفِ المَصْبُوغِ المَنْفُوشِ الَّذِي ذَرَتْهُ الرَِّيحُ.</p>"
        },
        "10": {
            "verses": {
                "70:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿حَمِيمٌ﴾ قَرِيبٌ.</h2>"
        },
        "11": {
            "verses": {
                "70:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿يُبَصَّرُونَهُمْ﴾ يُشَاهِدُ بَعْضُهُمْ بَعْضًا، وَيَعْرِفُهُ وَلاَ يُكَلِّمُهُ.</p>"
        },
        "12": {
            "verses": {
                "70:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
