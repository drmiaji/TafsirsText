            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿رَاغِبُونَ﴾ طَالِبُونَ الخَيْرَ.</h2>"
        },
        "33": {
            "verses": {
                "68:33": {
                    "id": 33
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿كَذَلِكَ الْعَذَابُ﴾ مِثْلَ ذَلِكَ العِقَابِ الَّذِي عَاقَبْنَاهُمْ بِهِ نُعَاقِبُ كُلَّ مَنْ بَخِلَ، وَخَالَفَ أَمْرَ اللهِ.</p>"
        },
