                "68:30": {
                    "id": 30
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿يَتَلاَوَمُونَ﴾ يَلُومُ بَعْضُهُمْ بَعْضًا عَلَى مَا قَصَدُوهُ مِنْ مَنْعٍ لِلْمَسَاكِينِ.</p>"
        },
