            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿تُدْهِنُ﴾ تُلاَيِنُ، وَتُصَانِعُ.</h2>"
        },
        "10": {
            "verses": {
                "68:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿حَلاَّفٍ﴾ كَثِيرِ الحَلِفِ.</h2>\n<h2>﴿مَهِينٍ﴾ كَذَّابٍ، حَقِيرٍ.</h2>"
        },
        "11": {
            "verses": {
                "68:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿هَمَّازٍ﴾ مُغْتَابٍ لِلنَّاسِ.</h2>\n<p>﴿مَشَّاءٍ بِنَمِيمٍ﴾ يَمْشِي بِالنَّمِيمَةٍ، وَهِيَ: نَقْلُ الحَدِيثِ بَيْنَ النَّاسِ عَلَى وَجْهِ الإِفْسَادِ.</p>"
        },
        "12": {
            "verses": {
                "68:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "13": {
            "verses": {
                "68:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿عُتُلٍّ﴾ فَاحِشٍ، لَئِيمٍ، غَلِيظٍ فِي كُفْرِهِ.</h2>\n<h2>﴿زَنِيمٍ﴾ مَنْسُوبٍ لِغَيْرِ أَبِيهِ.</h2>"
        },
        "14": {
            "verses": {
                "68:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَنْ كَانَ﴾ مِنْ أَجْلِ أَنَّهُ كَانَ.</h2>"
        },
        "15": {
            "verses": {
                "68:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَسَاطِيرُ الأَوَّلِينَ﴾ أَبَاطِيلُهُمْ، وَخُرَافَاتُهُمْ.</h2>"
        },
        "16": {
            "verses": {
                "68:16": {
                    "id": 16
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿سَنَسِمُهُ﴾ سَنَجْعَلُ لَهُ عَلاَمَةً لاَ تُفَارِقُهُ.</h2>\n<h2>﴿الْخُرْطُومِ﴾ أَنْفِهِ.</h2>"
        },
        "17": {
            "verses": {
                "68:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بَلَوْنَاهُمْ﴾ اخْتَبَرْنَاهُمْ.</h2>\n<h2>﴿الْجَنَّةِ﴾ الحَدِيقَةِ.</h2>\n<h2>﴿لَيَصْرِمُنَّهَا﴾ لَيَقْطَعُنَّ ثِمَارَ حَدِيقَتِهَا.</h2>"
        },
        "18": {
            "verses": {
                "68:18": {
                    "id": 18
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَلاَ يَسْتَثْنُونَ﴾ وَلاَ يَنْوُونَ اسْتِثْنَاءَ حِصَّةِ المَسَاكِينِ، وَلَمْ يَقُولُوا: إِنْ شَاءَ اللهُ.</p>"
        },
        "19": {
            "verses": {
                "68:19": {
                    "id": 19
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَطَافَ عَلَيْهَا﴾ أَحَاطَ نَازِلاً عَلَيْهَا.</h2>\n<h2>﴿طَائِفٌ﴾ نَارٌ أَحْرَقَتْهَا.</h2>"
        },
        "20": {
            "verses": {
                "68:20": {
                    "id": 20
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿كَالصَّرِيمِ﴾ كَاللَّيْلِ المُظْلِمِ.</h2>"
        },
        "21": {
            "verses": {
                "68:21": {
                    "id": 21
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَتَنَادَوْا﴾ نَادَى بَعْضُهُمْ بَعْضًا.</h2>"
        },
        "22": {
            "verses": {
                "68:22": {
                    "id": 22
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَنِ اغْدُوا﴾ اذْهَبُوا مُبَكِّرِينَ.</h2>\n<h2>﴿حَرْثِكُمْ﴾ مَزْرَعَتِكُمْ.</h2>\n<h2>﴿صَارِمِينَ﴾ مُصِرِّينَ عَلَى قَطْعِ الثِّمَارِ.</h2>"
        },
        "23": {
            "verses": {
                "68:23": {
                    "id": 23
                }
            },
            "resource_id": 116,
