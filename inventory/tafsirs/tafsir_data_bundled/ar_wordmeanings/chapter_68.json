            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَيْمَانٌ﴾ عُهُودٌ، وَمَوَاثِيقُ.</h2>\n<p>﴿إِنَّ لَكُمْ لَمَا تَحْكُمُونَ﴾ إِنَّهُ سَيَحْصُلُ لَكُمْ مَا تُرِيدُونَ، وَتشْتَهُونَ.</p>"
        },
        "40": {
            "verses": {
