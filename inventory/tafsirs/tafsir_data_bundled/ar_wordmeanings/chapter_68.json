            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَوْسَطُهُمْ﴾ أَعْدَلُهُمْ، وَخَيْرُهُمْ عَقْلاً وَدِينًا.</h2>\n<p>﴿لَوْلاَ تُسَبِّحُونَ﴾ هَلاَّ تَذْكُرُونَ اللهَ، وَتَسْتَغْفِرُونَهُ؛ مِنْ فِعْلِكُمْ، وَخُبْثِ نِيَّتِكُمْ.</p>"
        },
        "29": {
            "verses": {
                "68:29": {
                    "id": 29
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "30": {
