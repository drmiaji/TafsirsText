            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَا لَهَا﴾ مَا الَّذِي حَدَثَ لَهَا؟</h2>"
        },
        "4": {
            "verses": {
                "99:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿تُحَدِّثُ أَخْبَارَهَا﴾ تُخْبِرُ الأَرْضُ بِمَا عُمِلَ عَلَيْهَا.</p>"
        },
        "5": {
            "verses": {
                "99:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿بِأَنَّ رَبَّكَ أَوْحَى لَهَا﴾ بِسَبَبِ أَنَّ رَبَّكَ أَمَرَهَا بِأَنْ تُخْبِرَ.</p>"
        },
        "6": {
            "verses": {
                "99:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَصْدُرُ النَّاسُ﴾ يَرْجِعُونَ عَنْ مَوْقِفِ الحِسَابِ.</h2>\n<h2>﴿أَشْتَاتًا﴾ أَصْنافًا مُتَفَرِّقِينَ.</h2>\n<p>﴿لِيُرَوْا أَعْمَالَهُمْ﴾ لِيُرِيَهُمُ اللهُ مَا عَمِلُوا، وَيُجَازِيَهُمْ عَلَيْهِ.</p>"
        },
        "7": {
            "verses": {
