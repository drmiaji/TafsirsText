            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَثْقَالَهَا﴾ مَا فِي بَطْنِهَا مِنَ المَوْتَى والكُنُوزِ.</h2>"
        },
        "3": {
            "verses": {
