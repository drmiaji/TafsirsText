            "text": "<h2>﴿أَلَمْ تَرَ﴾ أَلَمْ تَعْلَمْ؟</h2>\n<p>﴿بِأَصْحَابِ الْفِيلِ﴾ وَهُمْ: أَبْرَهَةُ الحَبَشِيُّ، وَجَيْشُهُ الَّذِينَ أَرَادُوا تَدْمِيرَ الكَعْبَةِ.</p>"
        },
        "2": {
            "verses": {
                "105:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿كَيْدَهُمْ﴾ تَدْبِيرَهُمْ وَسَعْيَهُمْ لِتَخْرِيبِ الكَعْبَةِ.</p>\n<h2>﴿تَضْلِيلٍ﴾ تَضْيِيعٍ، وَإِبْطَالٍ، وَخَسَارٍ.</h2>"
        },
        "3": {
            "verses": {
