            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿ضَلَلْنَا فِي الأَرْضِ﴾ تَحَوَّلْنَا تُرَابًا بَعْدَ المَوْتِ.</p>"
        },
