            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الْمَأْوَى﴾ الَّتِي يَأْوُونَ إِلَيْهَا، وَيُقِيمُونَ بِهَا.</p>\n<h2>﴿نُزُلاً﴾ ضِيَافَةً لَهُمْ.</h2>"
        },
