            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الْجُرُزِ﴾ اليَابِسَةِ، الغَلِيظَةِ الَّتِي لاَ نَبَاتَ فِيهَا.</p>"
        },
