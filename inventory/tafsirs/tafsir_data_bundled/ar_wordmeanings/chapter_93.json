            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿ضَآلاًّ﴾ لاَ تَدْرِي الوَحْيَ، وَلاَ تَعْلَمُ القُرْآنَ.</h2>"
        },
        "8": {
            "verses": {
                "93:8": {
                    "id": 8
                }
