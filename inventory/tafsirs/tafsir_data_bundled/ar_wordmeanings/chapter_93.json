            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿سَجَى﴾ غَطَّى الكَوْنَ بِظَلاَمِهِ، وَسَكَنَ.</h2>"
        },
