            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَلاَ تَقْهَرْ﴾ لاَ تُسِئْ مُعَامَلَتَهُ، وَتَأْخُذْ مَالَهُ.</p>"
        },
        "10": {
            "verses": {
                "93:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
