                "language_name": "english"
            },
            "text": "<h2>﴿مُنْفَكِّينَ﴾ تَارِكِينَ كُفْرَهُمْ.</h2>\n<p>﴿الْبَيِّنَةُ﴾ العَلاَمَةُ الَّتِي وُعِدُوا بِهَا فِي الكُتُبِ السَّابِقَةِ.</p>"
        },
        "2": {
            "verses": {
                "98:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿رَسُولٌ مِنَ اللَّهِ﴾ أَيْ: وَالبَيِّنَةُ رَسُولٌ مِنَ اللهِ.</p>\n<h2>﴿يَتْلُو﴾ يَقْرَأُ.</h2>\n<p>﴿مُطَهَّرَةً﴾ مُنَزَّهَةً مِنَ البَاطِلِ، مَحْفُوظَةً مِنَ الشَّيَاطِينِ.</p>"
        },
        "3": {
            "verses": {
                "98:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿كُتُبٌ قَيِّمَةٌ﴾ أَخْبَارٌ صَادِقَةٌ، وَأَوَامِرُ عَادِلَةٌ.</p>"
        },
        "4": {
            "verses": {
                "98:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿تَفَرَّقَ﴾ اخْتَلَفَ.</h2>\n<h2>﴿أُوتُوا الْكِتَابَ﴾ اليَهُودُ وَالنَّصَارَى.</h2>\n<p>﴿الْبَيِّنَةُ﴾ مِنْ بَعْدِ مَا تَبَيَّنُوا أَنَّهُ نَبِيٌّ حَقًّا، تَفَرَّقُوا، وَكَانُوا مُجْتَمِعِينَ عَلَى صِحَّةِ نُبُوَّتِهِ قَبْلَ ذَلِكَ.</p>"
        },
        "5": {
            "verses": {
                "98:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مُخْلِصِينَ﴾ قَاصِدِينَ وَجْهَ اللهِ وَحْدَهُ.</h2>\n<h2>﴿حُنَفَاءَ﴾ مَائِلِينَ عَنِ الشِّرْكِ إِلَى الإِيمَانِ.</h2>\n<h2>﴿الْقَيِّمَةِ﴾ الاِسْتِقَامَةِ.</h2>"
        },
