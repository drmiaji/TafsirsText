            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿صِرَاطًا مُسْتَقِيمًا﴾ طَرِيقًّا، وَدِينًا لاَ عِوَجَ فِيهِ.</p>"
        },
