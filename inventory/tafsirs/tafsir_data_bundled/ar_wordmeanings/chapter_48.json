            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿حَرَجٌ﴾ إِثْمٌ فِي تَرْكِ الجِهَادِ.</h2>"
        },
        "18": {
            "verses": {
                "48:18": {
                    "id": 18
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يُبَايِعُونَكَ﴾ بَيْعَةَ الرِّضْوَانِ بِالحُدَيْبِيَةِ.</h2>\n<h2>﴿السَّكِينَةَ﴾ الطُّمَأْنِينَةَ، وَالثَّبَاتَ.</h2>\n<h2>﴿فَتْحًا قَرِيبًا﴾ فَتْحَ خَيْبَرَ.</h2>"
        },
