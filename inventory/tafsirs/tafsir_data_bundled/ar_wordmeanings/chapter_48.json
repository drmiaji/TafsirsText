                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أَحَاطَ اللَّهُ بِهَا﴾ قَادِرٌ عَلَيْهَا قَدْ وَعَدَكُمْ بِهَا، وَسَيُنْجِزُ وَعْدَهُ.</p>"
        },
        "22": {
            "verses": {
                "48:22": {
                    "id": 22
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لَوَلَّوُا الأَدْبَارَ﴾ لاَنْهَزَمُوا، وَوَلَّوْكُمْ ظُهُورَهُمْ.</p>"
        },
        "23": {
            "verses": {
                "48:23": {
                    "id": 23
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿سُنَّةَ اللَّهِ﴾ طَرِيقَتَهُ بِنَصْرِ جُنْدِهِ، وَهَزِيمَةِ أَعْدَائِهِ.</p>"
        },
        "24": {
            "verses": {
                "48:24": {
                    "id": 24
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بِبَطْنِ مَكَّةَ﴾ بِالحُدَيْبِيَةِ قُرْبَ مَكَّةَ.</h2>\n<p>﴿أَظْفَرَكُمْ﴾ أَقْدَرَكُمْ عَلَيْهِمْ؛ فَأَمْسَكْتُمْ بِهِمْ، وَكَانُوا ثَمَانِينَ رَجُلاً.</p>"
        },
        "25": {
            "verses": {
                "48:25": {
                    "id": 25
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَالْهَدْيَ﴾ البُدْنَ الَّتِي سَاقَهَا رَسُولُ اللهِ صلّى الله عليه وسلّم فِي عَامِ الحُدَيْبِيَةِ؛ لِيُهْدِيَهَا فِي الحَرَمِ.</p>\n<h2>﴿مَعْكُوفًا﴾ مَحْبُوسًا.</h2>\n<p>﴿مَحِلَّهُ﴾ المَكَانَ الَّذِي يَحِلُّ فِيهِ نَحْرُهُ؛ وَهُوَ الحَرَمُ.</p>\n<p>﴿رِجَالٌ مُؤْمِنُونَ﴾ مُسْتَضْعَفُونَ، مُسْتَخْفُونَ بِإِيمَانِهِمْ.</p>\n<p>﴿تَطَؤُوهُمْ﴾ خَشْيَةَ أَنْ تُهْلِكُوهُمْ إِذَا حَارَبْتُمُ الكُفَّارَ.</p>\n<h2>﴿مَعَرَّةٌ﴾ إِثْمٌ، وَعَيْبٌ، وَغَرَامَةٌ.</h2>\n<p>﴿تَزَيَّلُوا﴾ تَمَيَّزَ هَؤُلاَءِ المُسْتَضْعَفُونَ عَنِ الكُفَّارِ.</p>"
        },
        "26": {
            "verses": {
                "48:26": {
                    "id": 26
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْحَمِيَّةَ﴾ الأَنَفَةَ.</h2>\n<h2>﴿سَكِينَتَهُ﴾ الاِطْمِئْنَانَ والوَقَارَ.</h2>\n<h2>﴿كَلِمَةَ التَّقْوَى﴾ هِيَ: لاَ إِلَهَ إِلاَّ اللهُ.</h2>"
        },
        "27": {
            "verses": {
                "48:27": {
                    "id": 27
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَتْحًا قَرِيبًا﴾ هُوَ: صُلْحُ الحُدَيْبِيَةِ، وَفَتْحُ خَيْبَرَ.</p>"
        },
        "28": {
            "verses": {
                "48:28": {
                    "id": 28
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بِالْهُدَى﴾ بِالبَيَانِ الوَاضِحِ، وَالعِلْمِ النَّافِعِ.</h2>\n<p>﴿لِيُظْهِرَهُ عَلَى الدِّينِ كُلِّهِ﴾ لِيُعْلِيَهُ عَلَى المِلَلِ كُلِّهَا.</p>"
        },
        "29": {
            "verses": {
                "48:29": {
                    "id": 29
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿سِيمَاهُمْ﴾ عَلاَمَتُهُمْ.</h2>\n<h2>﴿مَثَلُهُمْ﴾ صِفَتُهُمْ.</h2>\n<h2>﴿شَطْأَهُ﴾ سَاقَهُ، وَفَرْعَهُ.</h2>\n<h2>﴿فَآزَرَهُ﴾ قَوَّى ذَلِكَ الشَّطْءُ الزَّرْعَ.</h2>\n<h2>﴿فَاسْتَغْلَظَ﴾ صَارَ غَلِيظًا.</h2>\n<p>﴿فَاسْتَوَى عَلَى سُوقِهِ﴾ قَوِيَ، وَاسْتَوَى قَائِمًا عَلَى سِيقَانِهِ.</p>\n<p>﴿الزُّرَّاعَ﴾ الزَّارِعِينَ الَّذِينَ زَرَعُوهُ، وَهَذَا مَثَلٌ ضَرَبَه اللهُ لأَِصْحَابِ النَّبِيِّ صلّى الله عليه وسلّم وَأَنَّهُمْ يَبْدَؤُونَ قِلَّةً ضُعَفَاءَ، ثُمَّ يَكْثُرُونَ وَيَقْوَوْنَ.</p>"
        }
    }
}