                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿جُنُودٌ﴾ هُمُ: الأَحْزَابُ حِينَ اجْتَمَعُوا فِي غَزْوَةِ الخَنْدَقِ.</p>"
        },
        "10": {
            "verses": {
                "33:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿زَاغَتِ الأَبْصَارُ﴾ شَخَصَتِ الأَبْصَارُ؛ حَيْرَةً وَدَهْشَةً.</p>\n<p>﴿الظُّنُونَا﴾ تَظُنُّونَ أَنَّ اللهَ لاَ يَنْصُرُ دِينَهُ وَنَبِيَّهُ.</p>"
        },
        "11": {
            "verses": {
                "33:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿ابْتُلِيَ﴾ امْتُحِنَ.</h2>\n<h2>﴿وَزُلْزِلُوا﴾ اضْطَرَبُوا.</h2>"
        },
        "12": {
            "verses": {
                "33:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَرَضٌ﴾ شَكٌّ، وَضَعْفُ إِيمَانٍ.</h2>\n<h2>﴿غُرُورًا﴾ بَاطِلاً خَادِعًا.</h2>"
        },
        "13": {
            "verses": {
                "33:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَثْرِبَ﴾ هُوَ: الاِسْمُ الجَاهِلِيُّ لِلْمَدِينَةِ.</h2>\n<p>﴿لاَ مُقَامَ لَكُمْ﴾ لاَ إِقَامَةَ لَكُمْ فِي مَعْرَكَةٍ خَاسِرَةٍ.</p>\n<h2>﴿عَوْرَةٌ﴾ غَيْرُ مُحَصَّنَةٍ.</h2>"
        },
        "14": {
            "verses": {
                "33:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَقْطَارِهَا﴾ جَوَانِبِ المَدِينَةِ.</h2>\n<p>﴿الْفِتْنَةَ﴾ الشِّرْكَ باللهِ، والرُّجُوعَ عَنِ الإِسْلاَمِ.</p>\n<h2>﴿لأََتَوْهَا﴾ لَأَجَابُوا إِلَى ذَلِكَ مُبَادِرِينَ.</h2>\n<h2>﴿تَلَبَّثُوا﴾ تَأَخَّرُوا.</h2>"
        },
        "15": {
            "verses": {
                "33:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
