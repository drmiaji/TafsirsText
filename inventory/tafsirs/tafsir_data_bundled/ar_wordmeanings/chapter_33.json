            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لاَ يُوَلُّونَ الأَدْبَارَ﴾ لاَ يَفِرُّونَ مِنَ المَعْرَكَةِ.</p>"
        },
