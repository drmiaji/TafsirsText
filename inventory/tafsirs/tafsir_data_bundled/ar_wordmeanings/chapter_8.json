                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مُوهِنُ﴾ مُضْعِفُ.</h2>"
        },
        "19": {
            "verses": {
                "8:19": {
                    "id": 19
