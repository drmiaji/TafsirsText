            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فِتْنَةٌ﴾ اخْتِبَارٌ، وَابْتِلاَءٌ؛ أَتُطِيعُونَهُ، وَتَشْكُرُونَهُ، أَمْ تَنْشَغِلُونَ بِهَا عَنْهُ؟</p>"
        },
        "29": {
            "verses": {
