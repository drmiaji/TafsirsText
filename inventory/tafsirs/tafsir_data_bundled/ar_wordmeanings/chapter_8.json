            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَلِيُبْلِيَ الْمُؤْمِنِينَ﴾ لِيُنْعِمَ عَلَيْهِمْ بِالنَّصْرِ وَالأَجْرِ.</p>"
        },
        "18": {
