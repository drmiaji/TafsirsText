            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿بِالْغَيْبِ﴾ عِنْدَمَا يَغِيبُ عَنِ النَّاسِ، لاَ يَرَاهُ إلاَّ اللهُ.</p>"
        },
        "12": {
            "verses": {
                "36:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَآثَارَهُمْ﴾ مَا سَنُّوهُ، وَأَبْقَوْهُ مِنْ خَيْرٍ وَشَرٍّ.</p>\n<p>﴿إِمَامٍ مُبِينٍ﴾ كِتَابٍ وَاضِحٍ؛ وَهُوَ: اللَّوْحُ المَحْفُوظُ.</p>"
        },
