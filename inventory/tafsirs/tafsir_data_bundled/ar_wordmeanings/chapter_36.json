            "text": "<h2>﴿تَطَيَّرْنَا بِكُمْ﴾ تَشَاءَمْنَا بِكُمْ.</h2>"
        },
        "19": {
            "verses": {
                "36:19": {
                    "id": 19
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿طَائِرُكُمْ مَعَكُمْ﴾ شُؤْمُكُمْ، وَأَعْمَالُكُمْ مِنَ الشِّرْكِ وَالشَّرِّ مَعَكُمْ، وَمَرْدُودَةٌ عَلَيْكُمْ.</p>\n<h2>﴿أَإِنْ ذُكِّرْتُمْ﴾ أَإِنْ وُعِظْتُمْ تَشَاءَمْتُمْ؟!</h2>"
        },
