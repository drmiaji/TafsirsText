            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الصُّورِ﴾ القَرْنِ الَّذِي يَنْفُخُ فِيهِ إِسْرَافِيلُ عليه السلام.</p>\n<h2>﴿الأَجْدَاثِ﴾ القُبُورِ.</h2>\n<h2>﴿يَنْسِلُونَ﴾ يُسْرِعُونَ فِي الخُرُوجِ.</h2>"
        },
        "52": {
            "verses": {
                "36:52": {
                    "id": 52
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَرْقَدِنَا﴾ قُبُورِنَا.</h2>"
        },
        "53": {
            "verses": {
                "36:53": {
                    "id": 53
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿صَيْحَةً وَاحِدَةً﴾ نَفْخَةً وَاحِدَةً فِي القَرْنِ.</h2>\n<h2>﴿مُحْضَرُونَ﴾ مَاثِلُونَ لِلْحِسَابِ.</h2>"
        },
