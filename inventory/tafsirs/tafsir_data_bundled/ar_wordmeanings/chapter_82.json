                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بِالدِّينِ﴾ يَوْمِ الجَزَاءِ، وَالحِسَابِ.</h2>"
        },
        "10": {
            "verses": {
                "82:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لَحَافِظِينَ﴾ لَمَلاَئِكَةً رُقَبَاءَ يَكْتُبُونَ أَعْمَالَكُمْ.</p>"
        },
