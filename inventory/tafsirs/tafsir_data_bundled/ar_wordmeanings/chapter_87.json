            "text": "<p>﴿سَبِّحِ اسْمَ رَبِّكَ﴾ نَزِّهْ رَبَّكَ ذَاكِرًا اسْمَهُ بِلِسَانِكَ.</p>\n<p>﴿الأَعْلَى﴾ الَّذِي لَهُ عُلُوُّ الذَّاتِ، وَعُلُوُّ القَدْرِ، وَعُلُوُّ القَهْرِ.</p>"
        },
        "2": {
            "verses": {
                "87:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَسَوَّى﴾ أَتْقَنَ خَلْقَهُ، وَأَحْسَنَهُ.</h2>"
        },
        "3": {
            "verses": {
                "87:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَهَدَى﴾ يَسَّرَ لَهُ مَا يُنَاسِبُهُ.</h2>"
        },
        "4": {
            "verses": {
                "87:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
