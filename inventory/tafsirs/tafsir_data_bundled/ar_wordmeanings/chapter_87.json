            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْمَرْعَى﴾ الكَلَأَ الأَخْضَرَ.</h2>"
        },
        "5": {
            "verses": {
                "87:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿غُثَاءً﴾ هَشِيمًا جَافًّا.</h2>\n<h2>﴿أَحْوَى﴾ مُتَغَيِّرًا.</h2>"
        },
