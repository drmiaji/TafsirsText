            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّ عَلَيْنَا لَلْهُدَى﴾ عَلَيْنَا أَنْ نُبَيِّنَ طَرِيقَ الهُدَى؛ فَضْلاً مِنَّا وَرَحْمَةً.</p>"
        },
