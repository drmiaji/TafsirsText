            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿نَجْوَى ثَلاَثَةٍ﴾ تَنَاجِي ثَلاَثَةٍ بِحَدِيثِ سِرٍّ.</h2>"
        },
        "8": {
            "verses": {
                "58:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿بِمَا لَمْ يُحَيِّكَ بِهِ اللَّهُ﴾ قَالُوا لَكَ: السَّامُ عَلَيْكُمْ، أَيِ: المَوْتُ لَكَ.</p>\n<h2>﴿لَوْلاَ﴾ هَلاَّ.</h2>\n<h2>﴿حَسْبُهُمْ﴾ كَافِيَتُهُمْ.</h2>\n<h2>﴿الْمَصِيرُ﴾ المَرْجِعُ، وَالمَآلُ.</h2>"
        },
        "9": {
            "verses": {
                "58:9": {
                    "id": 9
                }
            },
