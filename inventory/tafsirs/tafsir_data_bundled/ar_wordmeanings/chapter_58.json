            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَأَشْفَقْتُمْ﴾ أَخَشِيتُمُ الفَقْرَ؟</h2>"
        },
        "14": {
            "verses": {
                "58:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الَّذِينَ تَوَلَّوْا قَوْمًا﴾ المُنَافِقِينَ اتَّخَذُوا اليَهُودَ أَصْدِقَاءَ، وَوَالَوْهُمْ.</p>"
        },
