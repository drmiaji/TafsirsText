            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّمَا النَّجْوَى﴾ التَّحَدُّثُ بِخُفْيَةٍ بِالإِثْمِ وَالعُدْوَانِ.</p>"
        },
        "11": {
            "verses": {
                "58:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿تَفَسَّحُوا﴾ لِيُوسِعْ بَعْضُكُمْ لِبَعْضٍ فِي المَجَالِسِ.</p>\n<p>﴿انْشُزُوا﴾ قُومُوا مِنْ مَجَالِسِكُمْ لأَِمْرٍ فِيهِ خَيْرٌ لَكُمْ.</p>"
        },
        "12": {
            "verses": {
