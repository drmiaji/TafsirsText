            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يُحَآدُّونَ﴾ يُخَالِفُونَ، وَيُشَاقُّونَ.</h2>\n<h2>﴿الأَذَلِّينَ﴾ الأَذِلاَّءِ المَغْلُوبِينَ المُهَانِينَ.</h2>"
        },
        "21": {
            "verses": {
                "58:21": {
                    "id": 21
