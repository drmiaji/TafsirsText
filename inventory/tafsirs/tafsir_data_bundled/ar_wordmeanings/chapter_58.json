            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لأََغْلِبَنَّ﴾ لَأَنْتَصِرَنَّ.</h2>\n<h2>﴿عَزِيزٌ﴾ غَالِبٌ لاَ يُغْلَبُ.</h2>"
        },
        "22": {
