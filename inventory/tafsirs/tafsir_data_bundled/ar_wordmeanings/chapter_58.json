            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿اسْتَحْوَذَ﴾ غَلَبَ، وَاسْتَوْلَى.</h2>"
        },
        "20": {
            "verses": {
                "58:20": {
                    "id": 20
