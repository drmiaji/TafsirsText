            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مُنِيبٍ﴾ تَائِبٍ، مُقْبِلٍ عَلَى الطَّاعَةِ.</h2>"
        },
        "34": {
            "verses": {
                "50:34": {
                    "id": 34
                }
