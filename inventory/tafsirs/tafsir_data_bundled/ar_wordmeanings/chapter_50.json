            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَصْحَابُ الأَيْكَةِ﴾ أَصْحَابُ الشَّجَرِ الكَثِيفِ المُلْتَفِّ بَعْضُهُ عَلَى بَعْضٍ؛ وَهُمْ قَوْمُ شُعَيْبٍ عليه السلام.</p>\n<h2>﴿فَحَقَّ وَعِيدِ﴾ وَجَبَ نُزُولُ العَذَابِ عَلَى الجَمِيعِ.</h2>"
        },
        "15": {
            "verses": {
                "50:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَفَعَيِينَا﴾ أَفَعَجَزْنَا، وَضَعُفَتْ قُدْرَتُنَا؟!</h2>\n<p>﴿بِالْخَلْقِ الأَوَّلِ﴾ خَلْقِهِمُ الَّذِي خَلَقْنَاهُ أَوَّلَ مَرَّةٍ، بَعْدَ أَنْ لَمْ يَكُونُوا شَيْئًا.</p>\n<h2>﴿لَبْسٍ﴾ حَيْرَةٍ، وَشَكٍّ.</h2>"
        },
        "16": {
            "verses": {
                "50:16": {
                    "id": 16
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿حَبْلِ الْوَرِيدِ﴾ عِرْقٍ فِي العُنُقِ، مُتَّصِلٍ بِالقَلْبِ.</p>"
        },
        "17": {
            "verses": {
                "50:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْمُتَلَقِّيَانِ﴾ المَلَكَانِ المُتَرَصِّدَانِ.</h2>"
        },
        "18": {
            "verses": {
                "50:18": {
                    "id": 18
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿رَقِيبٌ عَتِيدٌ﴾ مَلَكٌ يَرْقُبُ قَوْلَهُ وَيَكْتُبُُهُ، حَاضِرٌ مُعَدٌّ لِذَلِكَ.</p>"
        },
        "19": {
            "verses": {
                "50:19": {
                    "id": 19
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿سَكْرَةُ الْمَوْتِ﴾ شِدَّةُ المَوْتِ، وَغَمْرَتُهُ.</h2>\n<h2>﴿تَحِيدُ﴾ تَهْرُبُ، وَتَرُوغُ.</h2>"
        },
        "20": {
            "verses": {
                "50:20": {
                    "id": 20
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الصُّورِ﴾ القَرْنِ الَّذِي يَنْفُخُ فِيهِ إِسْرَافِيلُ عليه السلام.</p>"
        },
        "21": {
            "verses": {
                "50:21": {
                    "id": 21
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿سَائِقٌ وَشَهِيدٌ﴾ مَلَكَانِ أَحَدُهُمَا يَسُوقُهَا إِلَى المَحْشَرِ، وَالآخَرُ يَشْهَدُ عَلَيْهَا بِمَا عَمِلَتْ.</p>"
        },
        "22": {
            "verses": {
                "50:22": {
                    "id": 22
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿غِطَاءَكَ﴾ حِجَابَ غَفْلَتِكَ عَنِ الآخِرَةِ.</h2>\n<h2>﴿حَدِيدٌ﴾ شَدِيدٌ قَوِيٌّ.</h2>"
        },
        "23": {
            "verses": {
                "50:23": {
                    "id": 23
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿قَرِينُهُ﴾ المَلَكُ الكَاتِبُ الَّذِي يَشْهَدُ عَلَيْهِ.</h2>\n<p>﴿هَذَا مَا لَدَيَّ عَتِيدٌ﴾ مَا عِنْدِي مِنْ دِيوَانِ عَمَلِهِ: مُعَدٌّ مَحْفُوظٌ حَاضِرٌ.</p>"
        },
        "24": {
            "verses": {
                "50:24": {
                    "id": 24
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَلْقِيَا﴾ اطْرَحَا أَيُّهَا المَلَكَانِ.</h2>"
        },
        "25": {
            "verses": {
                "50:25": {
                    "id": 25
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مُعْتَدٍ﴾ ظَالِمٍ، مُتَجَاوِزٍ لِلْحَدِّ.</h2>\n<h2>﴿مُرِيبٍ﴾ شَاكٍّ فِي وَعْدِ الله وَوَعِيدِهِ.</h2>"
        },
        "26": {
            "verses": {
