                "language_name": "english"
            },
            "text": "<h2>﴿الرَّسِّ﴾ البِئْرِ.</h2>"
        },
        "13": {
            "verses": {
                "50:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
