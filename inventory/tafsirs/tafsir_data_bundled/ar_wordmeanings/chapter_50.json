            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿بِسَلاَمٍ﴾ دُخُولاً مَقْرُونًا بِالسَّلاَمَةِ مِنَ الآفَاتِ.</p>"
        },
