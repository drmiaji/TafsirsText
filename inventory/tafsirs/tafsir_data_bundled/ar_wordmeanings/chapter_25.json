                "language_name": "english"
            },
            "text": "<h2>﴿مَتَابًا﴾ رُجُوعًا صَحِيحًا.</h2>"
        },
        "72": {
            "verses": {
                "25:72": {
                    "id": 72
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لاَ يَشْهَدُونَ الزُّورَ﴾ لاَ يَشْهَدُونَ بِالكَذِبِ، وَلاَ يَحْضُرُونَ مَجَالِسَ الكَذِبِ.</p>\n<p>﴿مَرُّوا بِاللَّغْوِ﴾ مَرُّوا بِأَهْلِ البَاطِلِ وَالكَلاَمِ القَبِيحِ وَمَا لاَ يَنْفَعُ.</p>\n<h2>﴿كِرَامًا﴾ مُعْرِضِينَ مُنْكِرِينَ يَتَنَزَّهُونَ عَنْهُ.</h2>"
        },
        "73": {
            "verses": {
                "25:73": {
                    "id": 73
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لَمْ يَخِرُّوا﴾ لَمْ يَقَعُوا سُجُودًا غَافِلِينَ، بَلْ سَجَدُوا مُطِيعِينَ.</p>"
        },
        "74": {
            "verses": {
                "25:74": {
                    "id": 74
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿قُرَّةَ أَعْيُنٍ﴾ تَقَرُّ بِهِمْ عُيُونُنَا، وَبِهِمْ نَأْنَسُ وَنَفْرَحُ.</p>\n<h2>﴿إِمَامًا﴾ قُدْوَةً يُقْتَدَى بِه فِي الخَيْرِ.</h2>"
        },
        "75": {
            "verses": {
                "25:75": {
                    "id": 75
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْغُرْفَةَ﴾ أَعْلَى مَنَازِلِ الجَنَّةِ.</h2>\n<p>﴿وَسَلاَمًا﴾ تَسْلِيمًا مِنَ المَلاَئِكَةِ، وَسَلاَمَةً مِنَ الآفَاتِ.</p>"
        },
        "76": {
