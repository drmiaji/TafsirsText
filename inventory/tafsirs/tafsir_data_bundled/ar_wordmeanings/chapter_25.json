            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَجَاهِدْهُمْ بِهِ﴾ بَلِّغْهُمُ القُرْآنَ بَاذِلاً وُسْعَكَ.</p>\n<h2>﴿جِهَادًا كَبِيرًا﴾ لاَ يُخِالِطُهُ فُتُورٌ.</h2>"
        },
        "53": {
            "verses": {
                "25:53": {
                    "id": 53
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَرَجَ﴾ خَلَطَ.</h2>\n<h2>﴿فُرَاتٌ﴾ شَدِيدُ العُذُوبَةِ.</h2>\n<h2>﴿أُجَاجٌ﴾ شَدِيدُ المُلُوحَةِ.</h2>\n<p>﴿بَرْزَخًا﴾ حَاجِزًا يَمْنَعُ إِفْسَادَ أَحَدِهِمَا لِلآخَرِ.</p>\n<p>﴿وَحِجْرًا مَحْجُورًا﴾ سِتْرًا يَمْنَعُ وُصُولَ أَحَدِهِمَا إِلَى الآخَرِ.</p>"
        },
        "54": {
            "verses": {
                "25:54": {
                    "id": 54
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿المَاءِ﴾ مَنِيِّ الرَّجُلِ وَالمَرْأَةِ.</h2>\n<h2>﴿نَسَبًا﴾ قَرَابَةَ النَّسَبِ.</h2>\n<h2>﴿وَصِهْرًا﴾ قَرَابَةَ المُصَاهَرَةِ.</h2>"
        },
        "55": {
            "verses": {
                "25:55": {
                    "id": 55
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿ظَهِيرًا﴾ مُعِينًا لِلشَّيْطَانِ عَلَى رَبِّهِ؛ بِالشِّرْكِ، مُظَاهِرًا لَهُ فِي المَعْصِيَةِ.</p>"
        },
