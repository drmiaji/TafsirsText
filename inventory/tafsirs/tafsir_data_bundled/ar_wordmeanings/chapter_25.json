            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بُرُوجًا﴾ نُجُومًا كِبَارًا بِمَنَازِلِهَا.</h2>\n<h2>﴿سِرَاجًا﴾ شَمْسًا مُضِيئَةً.</h2>"
        },
        "62": {
            "verses": {
                "25:62": {
                    "id": 62
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿خِلْفَةً﴾ مُتَعَاقِبِينَ يَخْلُفُ أَحَدُهُمَا الآخَرَ.</h2>"
        },
        "63": {
            "verses": {
                "25:63": {
                    "id": 63
                }
