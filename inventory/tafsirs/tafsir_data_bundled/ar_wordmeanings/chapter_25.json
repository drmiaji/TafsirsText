            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لِبَاسًا﴾ سَاتِرًا لَكُمْ بِظَلاَمِهِ.</h2>\n<h2>﴿سُبَاتًا﴾ رَاحَةً لأِبْدَانِكُمْ.</h2>\n<h2>﴿نُشُورًا﴾ وَقْتًا لِلاِنْتِشَارِ وَالسَّعْيِ فِي الأَرْضِ.</h2>"
        },
        "48": {
            "verses": {
                "25:48": {
                    "id": 48
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بُشْرًا﴾ مُبَشِّرَاتٍ بِالرَّحْمَةِ، وَهِيَ المَطَرُ.</h2>"
        },
        "49": {
            "verses": {
