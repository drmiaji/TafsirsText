            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَقْتُرُوا﴾ يُضَيِّقُوا فِي النَّفَقَةِ.</h2>\n<h2>﴿قَوَامًا﴾ وَسَطًا.</h2>"
        },
