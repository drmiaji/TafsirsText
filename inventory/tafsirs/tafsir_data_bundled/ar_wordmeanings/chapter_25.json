            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الأَمْثَالَ﴾ الحُجَجَ.</h2>\n<h2>﴿تَبَّرْنَا﴾ أَهْلَكْنَا وَدَمَّرْنَا.</h2>"
        },
        "40": {
