                "language_name": "english"
            },
            "text": "<h2>﴿أَثَامًا﴾ عِقَابًا.</h2>"
        },
        "69": {
            "verses": {
                "25:69": {
                    "id": 69
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
