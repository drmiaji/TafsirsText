            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿غَرَامًا﴾ مُلاَزِمًا؛ كَالغَرِيمِ (وَهُوَ الدَّائِنُ) يُلاَزِمُ غَرِيمَهُ.</p>"
        },
