            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿تَبَارَكَ﴾ كَثُرَ خَيْرُهُ، وَعَظُمَتْ بَرَكَتُهُ، وَكَمُلَتْ صِفَاتُهُ.</p>\n<p>﴿الْفُرْقَانَ﴾ القُرْآنَ الفَارِقَ بَيْنَ الحَقِّ، وَالبَاطِلِ.</p>"
        },
        "2": {
            "verses": {
                "25:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَقَدَّرَهُ﴾ سَوَّاهُ عَلَى مَا يُنَاسِبُ مِنَ الخَلْقِ.</h2>"
        },
        "3": {
            "verses": {
                "25:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿نُشُورًا﴾ بَعْثًا بَعْدَ المَوْتِ.</h2>"
        },
        "4": {
            "verses": {
                "25:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿إِفْكٌ افْتَرَاهُ﴾ كَذِبٌ اخْتَرَعَهُ مِنْ عِنْدِ نَفْسِهِ.</p>\n<h2>﴿وَزُورًا﴾ كَذِبًا شَنِيعًا.</h2>"
        },
        "5": {
            "verses": {
                "25:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أَسَاطِيرُ الأَوَّلِينَ﴾ أَحَادِيثُ الأُمَمِ القَدِيمَةِ المُسَطَّرَةُ فِي كُتُبِهِمْ.</p>\n<h2>﴿بُكْرَةً وَأَصِيلاً﴾ أَوَّلَ النَّهَارِ، وَآخِرَهُ.</h2>"
        },
        "6": {
            "verses": {
                "25:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
