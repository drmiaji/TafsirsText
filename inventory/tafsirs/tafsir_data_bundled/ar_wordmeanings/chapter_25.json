            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿سَعِيرًا﴾ نَارًا حَارَّةً تُسَعَّرُ بِهِمْ.</h2>"
        },
        "12": {
            "verses": {
                "25:12": {
                    "id": 12
