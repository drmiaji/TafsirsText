            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَزَفِيرًا﴾ صَوْتًا شَدِيدًا مِنْ شِدَّةِ الغَيْظِ.</h2>"
        },
        "13": {
            "verses": {
                "25:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مُقَرَّنِينَ﴾ قُرِنَتْ أَيْدِيهُمْ بِالسَّلاَسِلِ إِلَى أَعْنَاقِهِمْ.</p>\n<h2>﴿ثُبُورًا﴾ هَلاَكًا.</h2>"
        },
