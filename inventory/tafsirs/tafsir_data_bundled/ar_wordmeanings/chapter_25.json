            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿صَرْفًا﴾ دَفْعًا لِلْعَذَابِ.</h2>"
        },
        "20": {
            "verses": {
                "25:20": {
                    "id": 20
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فِتْنَةً﴾ ابْتِلاَءً، وَاخْتِبَارًا.</h2>"
        },
        "21": {
            "verses": {
                "25:21": {
                    "id": 21
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لاَ يَرْجُونَ لِقَاءَنَا﴾ لاَ يُؤْمِنُونَ بِاليَوْمِ الآخِرِ.</p>\n<h2>﴿وَعَتَوا﴾ تَجَاوَزُوا الحَدَّ فِي الطُّغْيَانِ.</h2>"
        },
        "22": {
            "verses": {
                "25:22": {
                    "id": 22
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿حِجْرًا مَحْجُورًا﴾ تَقُولُ المَلاَئِكَةُ لَهُمُ: الجَنَّةُ مَكَانٌ مُحَرَّمٌ عَلَيْكُمْ.</p>"
        },
        "23": {
            "verses": {
                "25:23": {
                    "id": 23
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿هَبَاءً﴾ كَالهَبَاءِ، وَهُوَ مَا يُرَى فِي ضَوْءِ الشَّمْسِ مِنْ خَفِيفِ الغُبَارِ.</p>"
        },
        "24": {
            "verses": {
