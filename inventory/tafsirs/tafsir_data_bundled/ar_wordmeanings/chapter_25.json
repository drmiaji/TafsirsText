            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿كَادَ لَيُضِلُّنَا﴾ قَارَبَ أَنْ يَصْرِفَنَا عَنْ عِبَادَةِ أَصْنَامِنَا.</p>"
        },
