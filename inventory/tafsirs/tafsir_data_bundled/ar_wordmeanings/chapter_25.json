            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مَدَّ الظِّلَّ﴾ بَسَطَهُ مِنْ طُلُوعِ الفَجْرِ إِلَى طُلُوعِ الشَّمْسِ.</p>\n<h2>﴿سَاكِناً﴾ ثَابِتًا مُسْتَقِرًّا.</h2>"
        },
        "46": {
            "verses": {
                "25:46": {
                    "id": 46
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
