            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿صَرَّفْنَاهُ﴾ أَنْزَلْنَا المَطَرَ عَلَى أَرْضٍ دُونَ أُخْرَى.</p>"
        },
        "51": {
