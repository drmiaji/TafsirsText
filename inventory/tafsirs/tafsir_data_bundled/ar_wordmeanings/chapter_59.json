            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿كَمَثَلِ الشَّيْطَانِ﴾ مَثَلُ المُنَافِقِينَ فِي وَعْدِهِمُ اليَهُودَ بِالنَّصْرِ وَخِذْلاَنِهِمْ لَهُمْ كَمَثَلِ الشَّيْطَانِ.</p>"
        },
