                "language_name": "english"
            },
            "text": "<p>﴿سَبَّحَ لِلَّهِ﴾ نَزَّهَ اللهَ عَمَّا لاَ يَلِيقُ بِهِ جَلَّ جَلاَلُهُ وَمَجَّدَهُ.</p>"
        },
        "2": {
            "verses": {
                "59:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَهْلِ الْكِتَابِ﴾ هُمْ يَهُودُ بَنِي النَّضِيرِ.</h2>\n<p>﴿لأَِوَّلِ الْحَشْرِ﴾ فِي أَوَّلِ إِخْرَاجٍ، وَإِجْلاَءٍ إِلَى الشَّامِ.</p>\n<h2>﴿لَمْ يَحْتَسِبُوا﴾ لَمْ يَخْطُرْ لَهُمْ بِبَالٍ.</h2>\n<h2>﴿وَقَذَفَ﴾ أَلْقَى.</h2>\n<h2>﴿الرُّعْبَ﴾ الخَوْفَ الشَّدِيدَ.</h2>\n<p>﴿يَاأُولِي الأَبْصَارِ﴾ يَا أَصْحَابَ البَصَائِرِ السَّلِيمَةِ.</p>"
        },
        "3": {
            "verses": {
                "59:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْجَلاَءَ﴾ الخُرُوجَ مِنْ دِيَارِهِمْ.</h2>"
        },
        "4": {
            "verses": {
                "59:4": {
                    "id": 4
