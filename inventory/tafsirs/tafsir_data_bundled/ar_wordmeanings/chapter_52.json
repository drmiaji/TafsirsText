            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَحْلاَمُهُمْ﴾ عُقُولُهُمْ.</h2>\n<h2>﴿طَاغُونَ﴾ مُتَجَاوِزُونَ الحَدَّ فِي العِصْيَانِ.</h2>"
        },
        "33": {
