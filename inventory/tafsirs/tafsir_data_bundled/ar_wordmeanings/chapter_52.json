            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَالسَّقْفِ الْمَرْفُوعِ﴾ قَسَمٌ بِالسَّمَاءِ.</h2>"
        },
