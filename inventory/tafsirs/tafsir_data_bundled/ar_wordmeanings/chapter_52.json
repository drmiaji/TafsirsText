            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مُشْفِقِينَ﴾ خَائِفِينَ مِنَ العَذَابِ.</h2>"
        },
        "27": {
            "verses": {
                "52:27": {
                    "id": 27
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿عَذَابَ السَّمُومِ﴾ عَذَابَ النَّارِ الَّتِي تَنْفُذُ فِي المَسَامِّ.</p>"
        },
        "28": {
            "verses": {
                "52:28": {
                    "id": 28
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْبَرُّ﴾ المُحْسِنُ، كَثِيرُ الخَيْرِ.</h2>"
        },
        "29": {
            "verses": {
                "52:29": {
                    "id": 29
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿بِنِعْمَةِ رَبِّكَ﴾ بِسَبَبِ إِنْعَامِ اللهِ عَلَيْكَ بِالنُّبُوَّةِ، وَرَجَاحَةِ العَقْلِ.</p>\n<h2>﴿بِكَاهِنٍ﴾ يَدَّعِي عِلْمَ الغَيْبِ.</h2>"
        },
        "30": {
            "verses": {
                "52:30": {
                    "id": 30
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَمْ﴾ بَلْ.</h2>\n<h2>﴿نَتَرَبَّصُ بِهِ﴾ نَنْتَظِرُ بِهِ.</h2>\n<p>﴿رَيْبَ الْمَنُونِ﴾ نُزُولَ المَوْتِ، وَحَوَادِثَ الدَّهْرِ.</p>"
        },
