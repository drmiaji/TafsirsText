            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فِي رَقٍّ مَنْشُورٍ﴾ فِي صُحُفٍ مَنْشُورَةٍ، مَبْسُوطَةٍ.</h2>"
        },
        "4": {
            "verses": {
                "52:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَالْبَيْتِ الْمَعْمُورِ﴾ قَسَمٌ بِالبَيْتِ المَعْمُورِ بِالمَلاَئِكَةِ الَّذِينَ يَطُوفُونَ بِهِ دَائِمًا، وَهُوَ فِي السَّمَاءِ بِحِذَاءِ الكَعْبَةِ، يَطُوفُ بِهِ كُلَّ يَوْمٍ سَبْعُونَ أَلْفَ مَلَكٍ.</p>"
        },
        "5": {
            "verses": {
                "52:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
