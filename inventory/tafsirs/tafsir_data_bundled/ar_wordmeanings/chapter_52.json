            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿تَقَوَّلَهُ﴾ اخْتَلَقَ القُرْآنَ مِنْ عِنْدِ نَفْسِهِ.</h2>"
        },
