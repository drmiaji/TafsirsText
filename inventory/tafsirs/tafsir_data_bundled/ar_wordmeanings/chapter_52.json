            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَكِتَابٍ مَسْطُورٍ﴾ قَسَمٌ بِالقُرْآنِ المَكْتُوبِ.</h2>"
        },
        "3": {
            "verses": {
                "52:3": {
                    "id": 3
