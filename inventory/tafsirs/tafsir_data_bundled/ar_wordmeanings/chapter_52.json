            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مَصْفُوفَةٍ﴾ مُتَقَابِلَةٍ، وَبَعْضُهَا إِلَى جَنْبِ بَعْضٍ.</p>\n<h2>﴿بِحُورٍ﴾ نِسَاءٍ بِيضٍ.</h2>\n<h2>﴿عِينٍ﴾ وَاسِعَاتِ العُيُونِ، حِسَانِهَا.</h2>"
        },
        "21": {
            "verses": {
                "52:21": {
                    "id": 21
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَا أَلَتْنَاهُمْ﴾ مَا نَقَصْنَا الآبَاءَ بِهَذَا الإِلْحَاقِ.</p>\n<p>﴿رَهِينٌ﴾ مَرْهُونٌ بِعَمَلِهِ، لاَ يَحْمِلُ ذَنْبَ غَيْرِهِ.</p>"
        },
        "22": {
            "verses": {
                "52:22": {
                    "id": 22
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "23": {
            "verses": {
                "52:23": {
                    "id": 23
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿يَتَنَازَعُونَ﴾ يَتَعَاطَوْنَ بَيْنَهُمْ، وَيُنَاوِلُ بَعْضُهُمْ بَعْضًا.</p>\n<h2>﴿كَأْسًا﴾ مِنَ الخَمْرِ.</h2>\n<p>﴿لاَ لَغْوٌ فِيهَا﴾ لاَ كَلاَمٌ سَاقِطٌ أَثْنَاءَ شُرْبِهَا.</p>\n<p>﴿وَلاَ تَأْثِيمٌ﴾ وَلاَ يَقَعُ بِسَبَبِهَا إِثْمٌ فِي قَوْلٍ أَوْ فِعْلٍ.</p>"
        },
        "24": {
            "verses": {
                "52:24": {
                    "id": 24
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَكْنُونٌ﴾ مَصُونٌ، مَسْتُورٌ فِي أَصْدَافِهِ.</h2>"
        },
