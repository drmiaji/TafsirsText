                "language_name": "english"
            },
            "text": "<h2>﴿بِالْعَشِيِّ﴾ عَصْرًا.</h2>\n<p>﴿الصَّافِنَاتُ﴾ الخُيُولُ الوَاقِفَةُ عَلَى ثَلاَثِ قَوَائِمَ، وَتَرْفَعُ الرَّابِعَةَ؛ لِنَجَابَتِهَا وَخِفَّتِهَا.</p>\n<h2>﴿الْجِيَادُ﴾ الخُيُولُ الأَصِيلَةُ السَّرِيعَةُ.</h2>"
        },
        "32": {
            "verses": {
                "38:32": {
                    "id": 32
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَحْبَبْتُ حُبَّ الْخَيْرِ﴾ آثَرْتُ حُبَّ المَالِ.</h2>\n<p>﴿تَوَارَتْ بِالْحِجَابِ﴾ غَابَتِ الشَّمْسُ، أَوْ غَابَتِ الخَيْلُ عَنْ عَيْنِهِ.</p>"
        },
        "33": {
            "verses": {
                "38:33": {
                    "id": 33
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَطَفِقَ﴾ شَرَعَ.</h2>\n<p>﴿مَسْحًا بِالسُّوقِ وَالأَعْنَاقِ﴾ يَمْسَحُ سِيقَانَهَا وَأَعْنَاقَهَا، أَوْ يَقْطَعُهَا بِالسَّيْفِ تَقَرُّبًا إِلَى اللهِ.</p>"
        },
        "34": {
            "verses": {
                "38:34": {
                    "id": 34
                }
