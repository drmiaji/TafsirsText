            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَلْيَرْتَقُوا فِي الأَسْبَابِ﴾ فَلْيَأْخُذُوا بِالأَسْبَابِ المُوصِلَةِ إِلَى السَّمَاءِ، وَلْيَمْنَعُوا الوَحْيَ.</p>"
        },
        "11": {
            "verses": {
                "38:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿جُنْدٌ مَا﴾ جُنُودٌ قَلِيلُونَ حَقِيرُونَ.</h2>"
        },
        "12": {
            "verses": {
                "38:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿ذُو الأَوْتَادِ﴾ صَاحِبُ الجُنُودِ، وَالقُوَّةِ العَظِيمَةِ.</p>"
        },
        "13": {
            "verses": {
                "38:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَصْحَابُ الأَيْكَةِ﴾ أَصْحَابُ الأَشْجَارِ وَالبَسَاتِينِ؛ وَهُمْ قَوْمُ شُعَيْبٍ عليه السلام.</p>"
        },
        "14": {
            "verses": {
                "38:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَحَقَّ عِقَابِ﴾ فَوَجَبَ العِقَابُ عَلَيْهِمْ.</h2>"
        },
        "15": {
            "verses": {
                "38:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَا يَنْظُرُ﴾ مَا يَنْتَظِرُ.</h2>\n<h2>﴿صَيْحَةً وَاحِدَةً﴾ نَفْخَةَ القِيَامَةِ.</h2>\n<h2>﴿فَوَاقٍ﴾ رُجُوعٍ.</h2>"
        },
        "16": {
            "verses": {
                "38:16": {
                    "id": 16
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿قِطَّنَا﴾ نَصِيبَنَا مِنَ العَذَابِ.</h2>"
        },
        "17": {
            "verses": {
                "38:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿ذَا الأَيدِ﴾ صَاحِبَ القَُوَّةِ عَلَى الطَّاعَةِ، وَفِي الحَربِ.</p>\n<h2>﴿أَوَّابٌ﴾ كَثِيرُ الرُّجُوعِ إِلَى مَا يُرضِي اللهَ.</h2>"
        },
        "18": {
            "verses": {
                "38:18": {
                    "id": 18
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بِالْعَشِيِّ﴾ آخِرِ النَّهَارِ.</h2>\n<h2>﴿وَالإِشْرَاقِ﴾ أَوَّلِ النَّهَارِ.</h2>"
        },
        "19": {
            "verses": {
                "38:19": {
                    "id": 19
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَحْشُورَةً﴾ مَجْمُوعَةً.</h2>\n<h2>﴿أَوَّابٌ﴾ مُطِيعٌ.</h2>"
        },
        "20": {
            "verses": {
                "38:20": {
                    "id": 20
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَشَدَدْنَا مُلْكَهُ﴾ قَوَّيْنَا مُلْكَهُ بِالهَيْبَةِ، وَالتَّمْكِينِ، وَالنَّصْرِ.</p>\n<h2>﴿الْحِكْمَةَ﴾ النُّبُوَّةَ.</h2>\n<p>﴿وَفَصْلَ الْخِطَابِ﴾ البَيَانَ الشَّافِيَ وَالفَصْلَ فِي الكَلاَمِ وَالحُكْمِ.</p>"
        },
        "21": {
            "verses": {
                "38:21": {
                    "id": 21
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿نَبَأُ﴾ خَبَرُ.</h2>\n<h2>﴿الْخَصْمِ﴾ المُتَخَاصِمِينَ.</h2>\n<h2>﴿الْمِحْرَابَ﴾ مَكَانَ عِبَادَتِهِ.</h2>"
        },
        "22": {
            "verses": {
                "38:22": {
                    "id": 22
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَفَزِعَ﴾ ارْتَاعَ.</h2>\n<h2>﴿وَلاَ تُشطِط﴾ لاَ تَجُر فِي حُكمِكَ، وَلاَ تَظلِم.</h2>\n<h2>﴿سَوَاءِ الصِّرَاطِ﴾ وَسَطِ الطَّرِيقِ الصَّوَابِ.</h2>"
        },
        "23": {
            "verses": {
                "38:23": {
                    "id": 23
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَكفِلنِيهَا﴾ أَعطِنِيهَا، وَانزِل لِي عَنهَا.</h2>\n<p>﴿وَعَزَّنِي فِي الْخِطَابِ﴾ غَلَبَنِي فِي الكَلاَمِ، وَاشْتَدَّ عَلَيَّ فِيهِ.</p>"
        },
        "24": {
            "verses": {
                "38:24": {
                    "id": 24
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الخُلَطَاءِ﴾ الشُّرَكَاءِ.</h2>\n<h2>﴿لَيَبْغِي﴾ لَيَعْتَدِي.</h2>\n<h2>﴿وَظَنَّ﴾ أَيْقَنَ.</h2>\n<h2>﴿فَتَنَّاهُ﴾ ابْتَلَيْنَاهُ، وَامْتَحَنَّاهُ.</h2>\n<h2>﴿وَخَرَّ رَاكِعًا﴾ سَجَدَ لِلَّهِ تَعَالَى.</h2>\n<h2>﴿وَأَنَابَ﴾ رَجَعَ، وَتَابَ.</h2>"
        },
        "25": {
            "verses": {
                "38:25": {
                    "id": 25
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لَزُلفَى﴾ لَقُربَى وَمَكَانَةً.</h2>\n<h2>﴿مَآبٍ﴾ مَرجِعٍ.</h2>"
        },
