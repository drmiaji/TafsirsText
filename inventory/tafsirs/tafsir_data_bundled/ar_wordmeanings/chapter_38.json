                "language_name": "english"
            },
            "text": "<p>﴿أَوَّابٌ﴾ كَثِيرُ الرُّجُوعِ إِلَى اللهِ بِالتَّوْبَةِ، وَالطَّاعَةِ.</p>"
        },
        "31": {
            "verses": {
                "38:31": {
                    "id": 31
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
