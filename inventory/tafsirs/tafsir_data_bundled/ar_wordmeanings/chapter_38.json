                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿ذِي الذِّكْرِ﴾ المُشْتَمِلِ عَلَى تَذْكِيرِ النَّاسِ بِمَا هُمْ عَنْهُ غَافِلُونَ.</p>"
        },
        "2": {
            "verses": {
                "38:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿عِزَّةٍ﴾ تَكَبُّرٍ، وَحَمِيَّةٍ.</h2>\n<h2>﴿وَشِقَاقٍ﴾ مُخَالَفَةٍ، وَعِنَادٍ.</h2>"
        },
        "3": {
            "verses": {
                "38:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿كَمْ أَهْلَكْنَا﴾ كَثِيرًا مِنَ الأُمَمِ أَهْلَكْنَا.</h2>\n<h2>﴿قَرْنٍ﴾ أُمَّةٍ سَابِقَةٍ.</h2>\n<p>﴿وَلاَتَ حِينَ مَنَاصٍ﴾ لَيْسَ الوَقْتُ وَقْتَ فِرَارٍ وَخَلاَصٍ.</p>"
        },
        "4": {
            "verses": {
