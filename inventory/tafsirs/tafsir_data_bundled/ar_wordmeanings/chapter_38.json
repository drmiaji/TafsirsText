            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿عُجَابٌ﴾ عَجِيبٌ.</h2>"
        },
        "6": {
            "verses": {
                "38:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْمَلأَُ﴾ الأَشْرَافُ، وَكِبَارُ القَوْمِ.</h2>\n<h2>﴿امْشُوا﴾ اسْتَمِرُّوا عَلَى دِينِكُمْ، وَشِرْكِكُمْ.</h2>\n<p>﴿لَشَيْءٌ يُرَادُ﴾ مُدَبَّرٌ يُقْصَدُ مِنْهُ التَّرَؤُّسُ، وَالسِّيَادَةُ.</p>"
        },
        "7": {
            "verses": {
                "38:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْمِلَّةِ الآخِرَةِ﴾ دِينِ آبَائِنَا وَدِينِ النَّصَارَى.</h2>\n<h2>﴿اخْتِلاَقٌ﴾ كَذِبٌ، وَافْتِرَاءٌ.</h2>"
        },
        "8": {
            "verses": {
                "38:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
