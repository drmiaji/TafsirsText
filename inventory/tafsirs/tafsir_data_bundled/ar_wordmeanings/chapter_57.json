            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مِمَّا جَعَلَكُمْ مُسْتَخْلَفِينَ فِيهِ﴾ مِنَ المَالِ الَّذِي جَعَلَكُمْ خُلَفَاءَ فِي التَّصَرُّفِ فِيهِ.</p>"
        },
