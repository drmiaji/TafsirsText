            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لَعِبٌ﴾ تَلْعَبُ بِهَا الأَبْدَانُ.</h2>\n<h2>﴿وَلَهْوٌ﴾ تَلْهُو بِهَا القُلُوبُ.</h2>\n<p>﴿الْكُفَّارَ﴾ الزُّرَّاعَ، سُمُّوا بِذَلِكَ؛ لأَِنَّهُمْ يَسْتُرُونَ الحَبَّ فِي التُّرَابِ.</p>\n<h2>﴿يَهِيجُ﴾ يَيْبَسُ.</h2>\n<h2>﴿حُطَامًا﴾ فُتَاتًا مُتَهَشِّمًا.</h2>"
        },
        "21": {
            "verses": {
                "57:21": {
                    "id": 21
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿سَابِقُوا﴾ سَارِعُوا مُسَارَعَةَ المُتَسَابِقِينَ فِي المِضْمَارِ.</p>"
        },
        "22": {
            "verses": {
                "57:22": {
                    "id": 22
                }
