            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿كِتَابٍ﴾ هُوَ: اللَّوْحُ المَحْفُوظُ.</h2>\n<h2>﴿نَبْرَأَهَا﴾ نَخْلُقَ هَذِهِ المَخْلُوقَاتِ.</h2>"
        },
        "23": {
            "verses": {
                "57:23": {
                    "id": 23
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿تَأْسَوْا﴾ تَحْزَنُوا.</h2>\n<h2>﴿تَفْرَحُوا﴾ فَرَحَ بَطَرٍ، وَاخْتِيَالٍ.</h2>\n<h2>﴿مُخْتَالٍ﴾ مُتَكَبِّرٍ.</h2>\n<h2>﴿فَخُورٍ﴾ مُتَطَاوِلٍ بِهِ يَفْخَرُ عَلَى النَّاسِ.</h2>"
        },
        "24": {
            "verses": {
                "57:24": {
                    "id": 24
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الْحَمِيدُ﴾ المَحْمُودُ عَلَى كَمَالِ صِفَاتِهِ، وَجَمِيلِ فِعَالِهِ.</p>"
        },
        "25": {
            "verses": {
                "57:25": {
                    "id": 25
                }
