            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الصِّدِّيقُونَ﴾ المُبَالِغُونَ فِي التَّصْدِيقِ.</h2>\n<h2>﴿وَالشُّهَدَاءُ﴾ الَّذِينَ قُتِلُوا فِي سَبِيلِ اللهِ.</h2>"
        },
        "20": {
            "verses": {
                "57:20": {
                    "id": 20
                }
