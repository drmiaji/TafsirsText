            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿كِفْلَيْنِ﴾ ضِعْفَيْنِ.</h2>"
        },
        "29": {
            "verses": {
                "57:29": {
                    "id": 29
                }
            },
            "resource_id": 116,
