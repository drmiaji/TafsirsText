            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَغُضُّونَ﴾ يَخْفِضُونَ.</h2>\n<p>﴿امْتَحَنَ اللَّهُ قُلُوبَهُمْ﴾ اخْتَبَرَهَا، وَصَفَّاهَا، وَأَخْلَصَهَا لِتَقْوَاهُ.</p>"
        },
        "4": {
            "verses": {
                "49:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿يُنَادُونَكَ﴾ يُنَادِيكَ الأَعْرَابُ بِصَوْتٍ مُرْتَفِعٍ، غَلِيظٍ، جَافٍ.</p>\n<h2>﴿الْحُجُرَاتِ﴾ حُجُرَاتِ زَوْجَاتِهِ صلّى الله عليه وسلّم.</h2>"
        },
        "5": {
            "verses": {
