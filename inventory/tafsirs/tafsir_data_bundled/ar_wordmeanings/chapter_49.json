            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَنْ تَحْبَطَ﴾ كَرَاهَةَ أَنْ تَبْطُلَ.</h2>"
        },
        "3": {
            "verses": {
                "49:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
