                "language_name": "english"
            },
            "text": "<h2>﴿بِنَبَإٍ﴾ بِخَبَرٍ.</h2>\n<h2>﴿فَتَبَيَّنُوا﴾ فَتَثَبَّتُوا مِنْ خَبَرِهِ.</h2>\n<h2>﴿أَنْ تُصِيبُوا﴾ خَشْيَةَ أَنْ تُصِيبُوا.</h2>"
        },
        "7": {
            "verses": {
                "49:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لَعَنِتُّمْ﴾ لَأَدَّى إِلَى مَشَقَّتِكُمْ، وَعَنَتِكُمْ.</h2>"
        },
        "8": {
            "verses": {
                "49:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
