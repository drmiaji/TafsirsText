            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَقَبَائِلَ﴾ القَبِيلَةُ: الجَمَاعَةُ دُونَ الشَّعْبِ.</h2>"
        },
        "14": {
            "verses": {
