                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مُعْجِزِينَ﴾ مُشَاقِّينَ اللهَ، مُغَالِبِينَ أَمْرَهُ.</h2>\n<p>﴿عَذَابٌ مِنْ رِجْزٍ أَلِيمٌ﴾ أَسْوَأُ العَذَابِ، وَأَشَدُّهُ أَلَمًا.</p>"
        },
        "6": {
            "verses": {
                "34:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿صِرَاطِ﴾ طَرِيقِ.</h2>"
        },
        "7": {
            "verses": {
                "34:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مُزِّقْتُمْ﴾ مُتُّمْ، وَتَفَرَّقَتْ أَجْسَادُكُمْ فِي الأَرْضِ.</p>"
        },
        "8": {
            "verses": {
                "34:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَفْتَرَى﴾ أَخْتَلَقَ؟</h2>\n<h2>﴿جِنَّةٌ﴾ جُنُونٌ.</h2>"
        },
        "9": {
            "verses": {
                "34:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿نَخْسِفْ بِهِمُ﴾ نُغَيِّبْهُمْ فِي الأَرْضِ.</h2>\n<h2>﴿كِسَفًا﴾ قِطَعًا مِنَ العَذَابِ.</h2>\n<h2>﴿مُنِيبٍ﴾ رَاجِعٍ إِلَى رَبِّهِ بِالتَّوْبَةِ وَالطَّاعَةِ.</h2>"
        },
        "10": {
            "verses": {
                "34:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَضْلاً﴾ نُبُوَّةً، وَعِلْمًا، وَكِتَابًا وَمُلْكًا.</h2>\n<h2>﴿أَوِّبِي مَعَهُ﴾ سَبِّحِي مَعَهُ.</h2>"
        },
        "11": {
            "verses": {
                "34:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿سَابِغَاتٍ﴾ دُرُوعًا تَامَّاتٍ وَاسِعَاتٍ.</h2>\n<p>﴿وَقَدِّرْ فِي السَّرْدِ﴾ قَدِّرِ المَسَامِيرَ فِي حِلَقِ الدُّرُوعِ بِأَلاَّ تَكُونَ الحِلَقُ صَغِيرَةً ضَعِيفَةً، وَلاَ كَبِيرَةً ثَقِيلَةً.</p>"
        },
        "12": {
            "verses": {
                "34:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿غُدُوُّهَا شَهْرٌ﴾ جَرَيَانُهَا مِنْ أَوَّلِ النَّهَارِ إِلَى انْتِصَافِهِ مَسِيرَةُ شَهْرٍ بِالسَّيْرِ المُعْتَادِ.</p>\n<p>﴿وَرَوَاحُهَا شَهْرٌ﴾ جَرَيَانُهَا مِنْ مُنْتَصَفِ النَّهَارِ إِلَى اللَّيْلِ مَسِيرَةُ شَهْرٍ بِالسَّيْرِ المُعْتَادِ.</p>\n<h2>﴿وَأَسَلْنَا﴾ أَذَبْنَا.</h2>\n<p>﴿عَيْنَ الْقِطْرِ﴾ عَيْنَ النُّحَاسِ، فَيَسِيلُ لَهُ النُّحَاسُ كَالمَاءِ.</p>\n<h2>﴿يَزِغْ﴾ يَعْدِلْ، وَيَمِلْ.</h2>"
        },
        "13": {
            "verses": {
                "34:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَحَارِيبَ﴾ مَسَاجِدَ لِلْعِبَادَةِ.</h2>\n<h2>﴿وَتَمَاثِيلَ﴾ صُوَرٍ مِنْ نُحَاسٍ وَزُجَاجٍ.</h2>\n<p>﴿وَجِفَانٍ كَالْجَوَابِ﴾ قِصَاعٍ كَبِيرَةٍ؛ كَالأَحْوَاضِ الَّتِي يَجْتَمِعُ فِيهَا المَاءُ.</p>\n<p>﴿رَاسِيَاتٍ﴾ قُدُورٍ ثَابِتَاتٍ لاَ تَتَحَرَّكُ مِنْ أَمَاكِنِهَا لِعِظَمِهَا.</p>"
        },
        "14": {
            "verses": {
                "34:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿دَآبَّةُ الأَرْضِ﴾ الأَرَضَةُ الَّتِي تَأْكُلُ الخَشَبَ.</h2>\n<h2>﴿مِنْسَأَتَهُ﴾ عَصَاهُ الَّتِي كَانَ مُتَّكِئًا عَلَيْهَا.</h2>\n<h2>﴿خَرَّ﴾ وَقَعَ عَلَى الأَرْضِ مَيِّتًا.</h2>\n<p>﴿الْعَذَابِ الْمُهِينِ﴾ العَمَلِ الشَّاقِّ الَّذِي كَلَّفَهُمْ بِهِ سُلَيْمَانُ عليه السلام.</p>"
        },
        "15": {
            "verses": {
                "34:15": {
                    "id": 15
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لِسَبَإٍ﴾ قَبِيلَةٍ بِاليَمَنِ سُمُّوا بِاسْمِ جَدِّهِمْ.</h2>\n<h2>﴿آيَةٌ﴾ دَلاَلَةٌ عَلَى قُدْرَتِنَا.</h2>\n<h2>﴿جَنَّتَانِ﴾ بُسْتَانَانِ.</h2>\n<p>﴿بَلْدَةٌ طَيِّبَةٌ﴾ كَرِيمَةُ التُّرْبَةِ، طَيِّبَةُ الهَوَاءِ.</p>"
        },
        "16": {
            "verses": {
                "34:16": {
                    "id": 16
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿سَيْلَ الْعَرِمِ﴾ السَّيْلَ الجَارِفَ الشَّدِيدَ الَّذِي خَرَّبَ السَّدَّ، وَأَغْرَقَ البَسَاتِينَ.</p>\n<h2>﴿ذَوَاتَيْ﴾ صَاحِبَتَيْ.</h2>\n<h2>﴿أُكُلٍ خَمْطٍ﴾ ثَمَرٍ مُرٍّ، كَرِيهِ الطَّعْمِ.</h2>\n<p>﴿وَأَثْلٍ﴾ شَجَرٍ مَعْرُوفٍ شَبِيهٍ بِالطَّرْفَاءِ، لاَ ثَمَرَ لَهُ.</p>\n<h2>﴿سِدْرٍ﴾ شَجَرِ النَّبَقِ، كَثِيرِ الشَّوْكِ.</h2>"
        },
        "17": {
            "verses": {
