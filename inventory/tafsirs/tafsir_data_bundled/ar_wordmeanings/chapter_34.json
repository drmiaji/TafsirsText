            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مِعْشَارَ مَا آتَيْنَاهُمْ﴾ عُشْرَ مَا أَعْطَيْنَاكُمْ مِنَ القُوَّةِ وَالنِّعَمِ.</p>\n<h2>﴿نَكِيرِ﴾ إِنْكَارِي عَلَيْهِمْ.</h2>"
        },
        "46": {
