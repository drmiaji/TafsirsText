            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿بِأَشْيَاعِهِمْ﴾ أَمْثَالِهِمْ مِنْ كُفَّارِ الأُمَمِ السَّابِقَةِ.</p>\n<h2>﴿مُرِيبٍ﴾ مُحْدِثٍ لِلرِّيبَةِ وَالقَلَقِ.</h2>"
        }
