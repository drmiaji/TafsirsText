            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَنَّى لَهُمُ التَّنَاوُشُ﴾ كَيْفَ لَهُمْ تَنَاوُلُ الإِيمَانِ، وَهُمْ فِي الآخِرَةِ؟</p>"
        },
        "53": {
            "verses": {
                "34:53": {
                    "id": 53
                }
