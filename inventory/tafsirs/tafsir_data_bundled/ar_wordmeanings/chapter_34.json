            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَيَقْذِفُونَ بِالْغَيْبِ﴾ يَرْمُونَ بِالظُّنُونِ الكَاذِبَةِ.</p>"
        },
        "54": {
