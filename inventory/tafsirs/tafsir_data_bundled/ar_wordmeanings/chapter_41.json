                "41:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أَكِنَّةٍ﴾ أَغْطِيَةٍ مَانِعَةٍ مِنْ فَهْمِ مَا تَدْعُونَا إِلَيْهِ.</p>\n<h2>﴿وَقْرٌ﴾ صَمَمٌ، وَثِقَلٌ.</h2>"
        },
        "6": {
            "verses": {
                "41:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿فَاسْتَقِيمُوا إِلَيْهِ﴾ اسْلُكُوا الطَّرِيقَ المُوصِلَ إِلَيْهِ.</p>\n<h2>﴿وَوَيلٌ﴾ هَلاَكٌ، وَعَذَابٌ.</h2>"
        },
        "7": {
            "verses": {
                "41:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
