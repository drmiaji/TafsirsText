            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "8": {
            "verses": {
                "41:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿غَيْرُ مَمْنُونٍ﴾ غَيْرُ مَقْطُوعٍ، وَلاَ مَمْنُوعٍ.</h2>"
        },
        "9": {
            "verses": {
                "41:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَنْدَادًا﴾ شُرَكَاءَ، وَنُظَرَاءَ.</h2>"
        },
        "10": {
            "verses": {
                "41:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿رَوَاسِيَ﴾ جِبَالاً ثَوَابِتَ.</h2>\n<h2>﴿أَقْوَاتَهَا﴾ أَرْزَاقَ أَهْلِهَا.</h2>\n<p>﴿فِي أَرْبَعَةِ أَيَّامٍ﴾ يَوْمَانِ لِخَلْقِ الأَرْضِ، وَيَوَمْانِ لِخَلْقِ الرَّوَاسِي، وَتقْدِيرِ الأَقْوَاتِ.</p>\n<p>﴿سَوَاءً﴾ فِي تَمَامِ أَرْبَعَةِ أَيَّامٍ مُسْتَوِيَةٍ؛ بِلاَ زِيَادَةٍ، وَلاَ نُقْصَانٍ.</p>"
        },
        "11": {
            "verses": {
                "41:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿اسْتَوَى﴾ قَصَدَ.</h2>"
        },
        "12": {
            "verses": {
                "41:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَقَضَاهُنَّ﴾ فَخَلَقَهُنَّ ، وَأَبْدَعَهُنَّ.</h2>\n<h2>﴿بِمَصَابِيحَ﴾ بِنُجُومٍ مُضِيئَةٍ.</h2>\n<h2>﴿وَحِفْظًا﴾ حَرَسًا مِنَ الشَّيَاطِينِ.</h2>"
        },
        "13": {
            "verses": {
                "41:13": {
                    "id": 13
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَنْذَرْتُكُمْ﴾ خَوَّفْتُكُمْ.</h2>\n<h2>﴿صَاعِقَةً﴾ عَذَابًا هَائِلاً.</h2>"
        },
