            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿صَرْصَرًا﴾ شَدِيدَةَ البُرُودَةِ، عَالِيَةَ الصَّوْتِ.</h2>\n<h2>﴿نَحِسَاتٍ﴾ مَشْؤُومَاتٍ.</h2>\n<h2>﴿الْخِزْيِ﴾ الذُّلِّ وَالهَوَانِ.</h2>"
        },
        "17": {
            "verses": {
                "41:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَهَدَيْنَاهُمْ﴾ فَبَيَّنَّا لَهُمْ سَبِيلَ الحَقِّ.</h2>\n<h2>﴿فَاسْتَحَبُّوا﴾ فَاخْتَارُوا.</h2>\n<h2>﴿الْهُونِ﴾ المُهِينِ.</h2>"
        },
