            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿تَسْتَتِرُونَ﴾ تَسْتَخْفُونَ عِنْدَ ارْتِكَابِكُمُ المَعَاصِيَ.</p>\n<h2>﴿أَنْ يَشْهَدَ﴾ خَوْفًا مِنْ أَنْ يَشْهَدَ.</h2>"
        },
        "23": {
            "verses": {
                "41:23": {
                    "id": 23
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَرْدَاكُمْ﴾ أَهْلَكَكُمْ.</h2>"
        },
        "24": {
            "verses": {
                "41:24": {
                    "id": 24
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَثْوىً﴾ مَأْوًى وَمَسْكَنٌ.</h2>\n<h2>﴿يَسْتَعْتِبُوا﴾ يَطْلُبُوا العُتْبَى وَهِيَ المَغْفِرَةُ.</h2>\n<p>﴿فَمَا هُمْ مِنَ الْمُعْتَبِينَ﴾ مَا هُمْ مِنَ المُجَابِينَ إِلَى مَا طَلَبُوا.</p>"
        },
        "25": {
            "verses": {
                "41:25": {
                    "id": 25
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَقَيَّضْنَا﴾ هَيَّأْنَا.</h2>\n<p>﴿قُرَنَاءَ﴾ مُصَاحِبِينَ مِنْ شَيَاطِينِ الإِنْسِ وَالجِنِّ.</p>\n<p>﴿وَحَقَّ عَلَيْهِمُ الْقَوْلُ﴾ وَجَبَ عَلَيْهِمُ الوَعِيدُ بِالعَذَابِ.</p>\n<h2>﴿خَلَتْ﴾ مَضَتْ.</h2>"
        },
        "26": {
            "verses": {
                "41:26": {
                    "id": 26
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَالْغَوْا فِيهِ﴾ ائْتُوا بِاللَّغْوِ؛ مِنَ الصَّفِيرِ، وَالصِّيَاحِ، وَالجَلَبَةِ، عِنْدَ قِرَاءَتِهِ.</p>"
        },
