                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الأَسْفَلِينَ﴾ فِي الدَّرْكِ الأَسْفَلِ مِنَ النَّارِ.</h2>"
        },
        "30": {
            "verses": {
                "41:30": {
                    "id": 30
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿اسْتَقَامُوا﴾ ثَبَتُوا عَلَى الحَقِّ عِلْمًا، وَعَمَلاً.</h2>\n<h2>﴿تَتَنَزَّلُ عَلَيْهِمُ﴾ تَنْزِلُ عِنْدَ المَوْتِ.</h2>"
        },
        "31": {
            "verses": {
                "41:31": {
                    "id": 31
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أَوْلِيَاؤُكُمْ﴾ أَنْصَارُكُمْ.</h2>\n<h2>﴿تَدَّعُونَ﴾ تَطْلُبُونَ.</h2>"
        },
        "32": {
            "verses": {
                "41:32": {
                    "id": 32
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿نُزُلاً﴾ ضِيَافَةً، وَإِنْعَامًا.</h2>"
        },
        "33": {
            "verses": {
                "41:33": {
                    "id": 33
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَنْ أَحْسَنُ﴾ لاَ أَحَدَ أَفْضَلُ.</h2>"
        },
        "34": {
            "verses": {
                "41:34": {
                    "id": 34
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَلِيٌّ حَمِيمٌ﴾ قَرِيبٌ لَكَ، شَفِيقٌ عَلَيْكَ.</h2>"
        },
        "35": {
            "verses": {
                "41:35": {
                    "id": 35
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَا يُلَقَّاهَا﴾ مَا يُوَفَّقُ لَهَا.</h2>\n<p>﴿ذُو حَظٍّ عَظِيمٍ﴾ صَاحِبُ نَصِيبٍ وَافِرٍ؛ مِنَ السَّعَادَةِ، وَالخُلُقِ، وَالخَيْرِ.</p>"
        },
