            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لَبِسَبِيلٍ﴾ لَبِطَرِيقٍ.</h2>\n<p>﴿مُقِيمٍ﴾ ثَابِتٍ يَرَاهُ المُسَافِرُونَ، المَارُّونَ بِهَا.</p>"
        },
        "77": {
            "verses": {
