            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿سُكِّرَتْ﴾ سُحِرَتْ.</h2>"
        },
        "16": {
            "verses": {
                "15:16": {
                    "id": 16
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بُرُوجًا﴾ مَنَازِلَ لِلْكَوَاكِبِ تَنْزِلُ فِيهَا.</h2>"
        },
        "17": {
            "verses": {
                "15:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿رَجِيمٍ﴾ مَطْرُودٍ مِنْ رَحْمَةِ اللهِ.</h2>"
        },
        "18": {
            "verses": {
                "15:18": {
                    "id": 18
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿اسْتَرَقَ السَّمْعَ﴾ اخْتَلَسَ الوَحْيَ مِنَ السَّمَاءِ الدُّنْيَا.</p>\n<h2>﴿فَأَتْبَعَهُ﴾ فَأَدْرَكَهُ.</h2>\n<h2>﴿شِهَابٌ﴾ كَوْكَبٌ مُضِيءٌ مُحْرِقٌ.</h2>"
        },
        "19": {
            "verses": {
                "15:19": {
                    "id": 19
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿رَوَاسِيَ﴾ رَاسِيَةً تُثَبِّتُهَا.</h2>"
        },
        "20": {
            "verses": {
                "15:20": {
                    "id": 20
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مَعَايِشَ﴾ مَا تَعِيشُونَ بِهِ مِنْ مَعَادِنَ، وَحِجَارَةٍ، وَنَبَاتٍ.</p>"
        },
