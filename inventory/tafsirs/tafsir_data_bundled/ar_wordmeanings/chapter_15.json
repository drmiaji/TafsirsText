            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿نَارِ السَّمُومِ﴾ نَارٍ شَدِيدَةِ الحَرَارَةِ لاَ دُخَانَ لَهَا.</p>"
