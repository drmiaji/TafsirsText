            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أَصْحَابُ الأَيْكَةِ﴾ الأَيْكَةُ: الشَّجْرَةُ المُلْتَفَّةُ، وَأَصْحَابُ الأيْكَةِ: قَوْمُ شُعَيْبٍ.</p>"
        },
        "79": {
            "verses": {
                "15:79": {
                    "id": 79
                }
