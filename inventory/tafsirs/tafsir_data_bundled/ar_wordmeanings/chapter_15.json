            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لَبِإِمَامٍ مُبِينٍ﴾ لَفِي طَرِيقٍ وَاضِحٍ يَمُرُّ بِهَا النَّاسُ.</p>"
        },
        "80": {
            "verses": {
                "15:80": {
                    "id": 80
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أَصْحَابُ الْحِجْرِ﴾ سُكَّانُ وَادِي الحِجْرِ، وَهُمْ ثَمُودُ، وَنَبِيُّهُمْ صَالِحٌ.</p>"
        },
