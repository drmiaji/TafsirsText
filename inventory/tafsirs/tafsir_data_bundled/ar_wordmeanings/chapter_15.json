            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿سَبْعًا مِنَ الْمَثَانِي﴾ سَبْعَ آيَاتٍ تُكَرَّرَ فِي كُلِّ صَلاَةٍ، وَهِيَ الفَاتِحَةُ.</p>"
        },
