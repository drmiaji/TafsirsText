                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَحُورٌ عِينٌ﴾ نِسَاءٌ بِيضٌ وَاسِعَاتُ الأَعْيُنِ حِسَانُهَا.</p>"
        },
        "23": {
            "verses": {
                "56:23": {
                    "id": 23
