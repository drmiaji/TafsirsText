                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿سَمُومٍ﴾ رِيحٍ حَارَّةٍ مِنْ حَرِّ نَارِ جَهَنَّمَ، تَأْخُذُ بِأَنْفَاسِهِمْ.</p>\n<h2>﴿وَحَمِيمٍ﴾ مَاءٍ حَارٍّ يَغْلِي.</h2>"
        },
        "43": {
            "verses": {
                "56:43": {
                    "id": 43
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَحْمُومٍ﴾ دُخَانٍ شَدِيدِ السَّوَادِ.</h2>"
        },
        "44": {
            "verses": {
                "56:44": {
                    "id": 44
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لاَ بَارِدٍ وَلاَ كَرِيمٍ﴾ لاَ بَارِدِ المَنْزِلِ، وَلاَ طَيِّبِ المَنْظَرِ.</p>"
        },
        "45": {
            "verses": {
                "56:45": {
                    "id": 45
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مُتْرَفِينَ﴾ مُتَنَعِّمِينَ مُنْهَمِكِينَ فِي الشَّهَوَاتِ.</p>"
        },
        "46": {
            "verses": {
                "56:46": {
                    "id": 46
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الْحِنْثِ الْعَظِيمِ﴾ الذَّنْبِ العَظِيمِ؛ وَهُوَ الشِّرْكُ بِاللهِ.</p>"
        },
        "47": {
            "verses": {
                "56:47": {
                    "id": 47
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
