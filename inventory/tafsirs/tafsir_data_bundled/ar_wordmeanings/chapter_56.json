            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَوْضُونَةٍ﴾ مَنْسُوجَةٍ بِالذَّهَبِ.</h2>"
        },
        "16": {
            "verses": {
