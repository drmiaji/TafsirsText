                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْمَشْأَمَةِ﴾ الشِّمَالِ.</h2>"
        },
        "10": {
            "verses": {
                "56:10": {
                    "id": 10
