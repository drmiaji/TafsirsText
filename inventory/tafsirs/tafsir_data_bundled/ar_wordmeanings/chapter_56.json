                "language_name": "english"
            },
            "text": "<h2>﴿ثُلَّةٌ﴾ جَمَاعَةٌ كَثِيرَةٌ.</h2>\n<p>﴿الأَوَّلِينَ﴾ صَدْرُ هَذِهِ الأُمَّةِ وَغَيْرِهِمْ مِنَ الأُمَمِ الأُخْرَى.</p>"
        },
        "14": {
            "verses": {
                "56:14": {
                    "id": 14
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الآخِرِينَ﴾ آخِرِ هَذِهِ الأُمَّةِ.</h2>"
        },
        "15": {
            "verses": {
                "56:15": {
                    "id": 15
                }
