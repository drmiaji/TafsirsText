                "language_name": "english"
            },
            "text": "<h2>﴿سِدْرٍ مَخْضُودٍ﴾ شَجَرِ النَّبِقِ لاَ شَوْكَ فِيهِ.</h2>"
        },
        "29": {
            "verses": {
                "56:29": {
                    "id": 29
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَطَلْحٍ مَنْضُودٍ﴾ مَوْزٍ مُتَرَاكِبٍ بَعْضُهُ عَلَى بَعْضٍ، أَوْ هُوَ شَجَرُ الطَّلْحِ المَعْرُوفُ، وَهُوَ أَعْظَمُ أشْجَارِ العَرَبِ.</p>"
        },
        "30": {
            "verses": {
