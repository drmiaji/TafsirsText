            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَظِلٍّ مَمْدُودٍ﴾ ظِلٍّ دَائِمٍ لاَ يَزُولُ.</h2>"
        },
        "31": {
            "verses": {
