                "language_name": "english"
            },
            "text": "<h2>﴿الْوَاقِعَةُ﴾ القِيَامَةُ.</h2>"
        },
        "2": {
            "verses": {
                "56:2": {
                    "id": 2
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لَيْسَ لِوَقْعَتِهَا﴾ لَيْسَ لِوُقُوعِهَا، وَقِيَامِهَا.</h2>\n<h2>﴿كَاذِبَةٌ﴾ نَفْسٌ تُكَذِّبُ بِذَلِكَ.</h2>"
        },
        "3": {
            "verses": {
                "56:3": {
                    "id": 3
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿خَافِضَةٌ رَافِعَةٌ﴾ تَخْفِضُ الكُفَّارَ فِي النَّارِ، وَتَرْفَعُ المُؤْمِنِينَ فِي الجَنَّةِ.</p>"
        },
        "4": {
            "verses": {
                "56:4": {
                    "id": 4
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿رُجَّتِ﴾ حُرِّكَتْ.</h2>\n<h2>﴿رَجًّا﴾ تَحْرِيكًا شَدِيدًا.</h2>"
        },
        "5": {
            "verses": {
                "56:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَبُسَّتِ﴾ فُتِّتَتْ.</h2>"
        },
        "6": {
            "verses": {
                "56:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
