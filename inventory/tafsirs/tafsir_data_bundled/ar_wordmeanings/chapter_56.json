            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الْحَمِيمِ﴾ مَاءٍ مُتَنَاهٍ فِي الحَرَارَةِ.</h2>"
        },
        "55": {
            "verses": {
                "56:55": {
                    "id": 55
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿شُرْبَ الْهِيمِ﴾ كَشُرْبِ الإِبِلِ العِطَاشِ الَّتِي لاَ تَرْوَى لِدَاءٍ يُصِيبُهَا.</p>"
        },
        "56": {
            "verses": {
                "56:56": {
                    "id": 56
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿نُزُلُهُمْ﴾ مَا أُعِدَّ لَهُمْ مِنَ الجَزَاءِ.</h2>\n<h2>﴿يَوْمَ الدِّينِ﴾ يَوْمَ الجَزَاءِ، وَالحِسَابِ.</h2>"
        },
        "57": {
            "verses": {
                "56:57": {
                    "id": 57
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَلَوْلاَ تُصَدِّقُونَ﴾ هَلاَّ تُصَدِّقُونَ بِالبَعْثِ؟!</h2>"
        },
        "58": {
            "verses": {
                "56:58": {
                    "id": 58
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مَا تُمْنُونَ﴾ النُّطَفَ الَّتِي تَقْذِفُونَهَا فِي أَرْحَامِ نِسَائِكُمْ.</p>"
        },
        "59": {
            "verses": {
                "56:59": {
                    "id": 59
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
