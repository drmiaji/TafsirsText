                "56:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وِلْدَانٌ مُخَلَّدُونَ﴾ غِلْمَانٌ لِلْخِدْمَةِ لاَ يَهْرَمُونَ، وَلاَ يَمُوتُونَ.</p>"
        },
        "18": {
            "verses": {
                "56:18": {
                    "id": 18
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بِأَكْوَابٍ﴾ أَقْدَاحٍ لاَ عُرَى لَهَا، وَلاَ خَرَاطِيمَ.</h2>\n<h2>﴿وَأَبَارِيقَ﴾ أَوَانٍ لَهَا عُرًى، وَخَرَاطِيمُ.</h2>\n<h2>﴿وَكَأْسٍ﴾ خَمْرٍ، أَوْ قَدَحٍ فِيهِ خَمْرٌ.</h2>\n<h2>﴿مِنْ مَعِينٍ﴾ خَمْرٍ جَارِيَةٍ فِي الجَنَّةِ.</h2>"
        },
        "19": {
            "verses": {
                "56:19": {
                    "id": 19
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لاَ يُصَدَّعُونَ عَنْهَا﴾ لاَ تُصَدَّعُ مِنْهَا رُؤُوسُهُمْ.</p>\n<h2>﴿وَلاَ يُنْزِفُونَ﴾ لاَ تَذْهَبُ بِعُقُولِهِمْ.</h2>"
        },
