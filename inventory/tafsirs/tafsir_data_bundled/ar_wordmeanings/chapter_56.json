            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿حُطَامًا﴾ هَشِيمًا؛ لاَ يُنْتَفَعُ بِهِ فِي مَطْعَمٍ.</h2>\n<h2>﴿فَظَلْتُمْ﴾ أَصْبَحْتُمْ.</h2>\n<h2>﴿تَفَكَّهُونَ﴾ تَتَعَجَّبُونَ مِمَّا نَزَلَ بِزَرْعِكُمْ.</h2>"
        },
        "66": {
            "verses": {
                "56:66": {
                    "id": 66
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّا لَمُغْرَمُونَ﴾ تَقُولُونَ: إِنَّا لَخَاسِرُونَ مُعَذَّبُونَ.</p>"
        },
        "67": {
            "verses": {
                "56:67": {
                    "id": 67
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
