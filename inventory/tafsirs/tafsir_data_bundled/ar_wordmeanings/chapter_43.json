                "language_name": "english"
            },
            "text": "<p>﴿أَمْ أَبْرَمُوا أَمْرًا﴾ أَحْكَمُوا أَمْرًا فِي كَيْدِ نَبِيِّنَا مُحَمَّدٍ صلّى الله عليه وسلّم.</p>"
        },
        "80": {
