                    "id": 52
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَهِينٌ﴾ ضَعِيفٌ لاَ عِزَّ لَهُ.</h2>\n<h2>﴿وَلاَ يَكَادُ يُبِينُ﴾ لاَ يَكَادُ يُفْصِحُ فِي كَلاَمِهِ.</h2>"
        },
        "53": {
            "verses": {
                "43:53": {
                    "id": 53
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مُقْتَرِنِينَ﴾ مَقْرُونِينَ مَعَهُ يُصَدِّقُونَهُ.</h2>"
        },
        "54": {
            "verses": {
                "43:54": {
                    "id": 54
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَاسْتَخَفَّ قَوْمَهُ﴾ اسْتَخَفَّ بِعُقُولِهِمْ.</h2>"
        },
        "55": {
            "verses": {
                "43:55": {
                    "id": 55
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿آسَفُونَا﴾ أَغْضَبُونَا.</h2>"
        },
        "56": {
            "verses": {
                "43:56": {
                    "id": 56
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿سَلَفًا﴾ قُدْوَةً لِمَنْ يَعْمَلُ مِثْلَ عَمَلِهِمْ؛ فَيَسْتَحِقُّ العُقُوبَةَ.</p>\n<h2>﴿وَمَثَلاً﴾ عِظَةً، وَعِبْرَةً.</h2>"
        },
        "57": {
            "verses": {
                "43:57": {
                    "id": 57
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَصِدُّونَ﴾ يَضِجُّونَ وَيَصِيحُونَ، فَرَحًا، وَجَذَلاً.</h2>"
        },
        "58": {
            "verses": {
                "43:58": {
                    "id": 58
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿خَصِمُونَ﴾ شَدِيدُو الخُصُومَةِ بِالبَاطِلِ.</h2>"
        },
        "59": {
            "verses": {
                "43:59": {
                    "id": 59
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَثَلاً﴾ عِبْرَةً، وَآيَةً.</h2>"
        },
        "60": {
            "verses": {
                "43:60": {
                    "id": 60
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿لَجَعَلْنَا مِنْكُمْ﴾ لَجَعَلْنَا بَدَلَكُمْ.</h2>\n<p>﴿يَخْلُفُونَ﴾ يَخْلُفُ بَعْضُهُمْ بَعْضًا، بَدَلاً مِنْ بَنِي آدَمَ.</p>"
        },
        "61": {
            "verses": {
                "43:61": {
                    "id": 61
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿لَعِلْمٌ لِلسَّاعَةِ﴾ إِنَّ نُزُولَ عِيسَى عليه السلام لَدَلِيلٌ عَلَى قُرْبِ وُقُوعِ السَّاعَةِ.</p>\n<h2>﴿فَلاَ تَمْتَرُنَّ﴾ لاَ تَشُكُّوا.</h2>\n<p>﴿صِرَاطٌ مُسْتَقِيمٌ﴾ طَرِيقٌ قَوِيمٌ إِلَى الجَنَّةِ لاَ عِوَجَ فِيهِ.</p>"
        },
        "62": {
