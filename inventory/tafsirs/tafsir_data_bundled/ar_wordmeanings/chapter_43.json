                "43:48": {
                    "id": 48
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿آيَةٍ﴾ حُجَّةٍ عَلَى صِدْقِ دَعْوَتِهِ.</h2>\n<p>﴿بِالْعَذَابِ﴾ مِنَ الجَرَادِ، وَالقُمَّلِ، وَالضَّفَادِعِ، وَنَحْوِهَا.</p>"
        },
        "49": {
            "verses": {
                "43:49": {
                    "id": 49
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿السَّاحِرُ﴾ العَالِمُ (وَكَانَ السَّاحِرُ فِيهِمْ عَظِيمًا يُوَقِّرُونَهُ، وَلَمْ يَكُنْ صِفَةَ ذَمٍّ).</p>\n<p>﴿بِمَا عَهِدَ عِنْدَكَ﴾ بِعَهْدِهِ الَّذِي عَهِدَ إِلَيْكَ، وَمَا خَصَّكَ بِهِ مِنَ الفَضَائِلِ.</p>"
        },
        "50": {
            "verses": {
                "43:50": {
                    "id": 50
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَنْكُثُونَ﴾ يَغْدِرُونَ، وَيُصِرُّونَ عَلَى الكُفْرِ.</h2>"
        },
        "51": {
            "verses": {
                "43:51": {
                    "id": 51
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
