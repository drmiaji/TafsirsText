            "text": "<h2>﴿أُمِّ الْكِتَابِ﴾ اللَّوْحِ المَحْفُوظِ.</h2>\n<h2>﴿لَعَلِيٌّ﴾ رَفِيعُ الشَّأْنِ.</h2>\n<h2>﴿حَكِيمٌ﴾ مُحْكَمٌ، وَذُو حِكْمَةٍ بَالِغَةٍ.</h2>"
        },
        "5": {
            "verses": {
                "43:5": {
                    "id": 5
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿أَفَنَضْرِبُ عَنْكُمُ الذِّكْرَ صَفْحًا﴾ أَفَنُعْرِضُ عَنْكُمْ، وَنَتْرُكُ تَذْكِيرَكُمْ بِالقُرْآنِ؟!</p>\n<h2>﴿أَنْ كُنْتُمْ﴾ بِسَبَبِ أَنْ كُنْتُمْ.</h2>"
        },
        "6": {
            "verses": {
                "43:6": {
                    "id": 6
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿وَكَمْ أَرْسَلْنَا﴾ كَثِيرًا مِنَ الأَنْبِيَاءِ أَرْسَلْنَا.</p>"
        },
        "7": {
            "verses": {
                "43:7": {
                    "id": 7
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "8": {
            "verses": {
                "43:8": {
                    "id": 8
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بَطْشًا﴾ قُوَّةً.</h2>\n<p>﴿وَمَضَى مَثَلُ الأَوَّلِينَ﴾ سَبَقَ فِي القُرْآنِ أَحَادِيثُ إِهْلاَكِهِمْ.</p>"
        },
        "9": {
            "verses": {
                "43:9": {
                    "id": 9
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "10": {
            "verses": {
                "43:10": {
                    "id": 10
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿مَهْدًا﴾ فِرَاشًا مُمَهَّدًا.</h2>\n<h2>﴿سُبُلاً﴾ طُرُقًا لِمَعَاشِكُمْ تَسْلُكُونَهَا.</h2>"
        },
        "11": {
            "verses": {
                "43:11": {
                    "id": 11
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿بِقَدَرٍ﴾ بِمِقْدَارٍ، وَوَزْنٍ مَعْلُومٍ.</h2>\n<h2>﴿فَأَنْشَرْنَا﴾ أَحْيَيْنَا.</h2>\n<h2>﴿مَيْتًا﴾ مُقْفِرَةً مِنَ النَّبَاتِ.</h2>"
        },
        "12": {
            "verses": {
                "43:12": {
                    "id": 12
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿الأَزْوَاجَ﴾ الأَصْنَافَ؛ مِنْ نَبَاتٍ، وَحَيَوَانٍ.</h2>\n<h2>﴿الْفُلْكِ﴾ السُّفُنِ.</h2>"
        },
        "13": {
            "verses": {
                "43:13": {
                    "id": 13
                }
