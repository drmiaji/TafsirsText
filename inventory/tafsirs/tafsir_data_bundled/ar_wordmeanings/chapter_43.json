            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿وَأَصْفَاكُمْ﴾ خَصَّكُمْ.</h2>"
        },
        "17": {
            "verses": {
                "43:17": {
                    "id": 17
                }
