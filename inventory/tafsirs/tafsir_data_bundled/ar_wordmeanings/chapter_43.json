            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿رَحْمَةَ رَبِّكَ﴾ النُّبُوَّةَ.</h2>\n<h2>﴿سُخْرِيًّا﴾ مُسَخَّرًا فِي العَمَلِ.</h2>\n<h2>﴿وَرَحْمَةُ رَبِّكَ﴾ الجَنَّةُ.</h2>"
        },
        "33": {
            "verses": {
                "43:33": {
                    "id": 33
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أُمَّةً وَاحِدَةً﴾ جَمَاعَةً وَاحِدَةً عَلَى الكُفْرِ.</h2>\n<h2>﴿وَمَعَارِجَ﴾ سَلاَلِمَ مِنْ فِضَّةٍ.</h2>\n<h2>﴿يَظْهَرُونَ﴾ يَصْعَدُونَ.</h2>"
        },
