            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿يَنْظُرُونَ﴾ يَنْتَظِرُونَ.</h2>\n<h2>﴿بَغْتَةً﴾ فَجْأَةً.</h2>"
        },
