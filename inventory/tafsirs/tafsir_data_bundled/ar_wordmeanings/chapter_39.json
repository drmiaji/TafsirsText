            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مِنْ كُلِّ مَثَلٍ﴾ مِنْ أَمْثَالِ القُرُونِ الخَالِيَةِ، وَأَمْثَالِ التَّوْحِيدِ وَالشِّرْكِ وَغَيْرِهَا.</p>"
        },
        "28": {
            "verses": {
                "39:28": {
                    "id": 28
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿عِوَجٍ﴾ اضْطِرَابٍ، وَلَبْسٍ.</h2>"
        },
        "29": {
            "verses": {
                "39:29": {
                    "id": 29
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿رَجُلاً﴾ عَبْدًا مَمْلُوكًا.</h2>\n<h2>﴿مُتَشَاكِسُونَ﴾ مُتَنَازِعُونَ.</h2>\n<h2>﴿سَلَمًا﴾ خَالِصًا.</h2>\n<h2>﴿لِرَجُلٍ﴾ لِمَالِكٍ وَاحِدٍ.</h2>"
        },
