            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿ظُلَلٌ مِنَ النَّارِ﴾ أَطْبَاقٌ مِنْ عَذَابِ النَّارِ كَهَيْئَةِ الظُّلَلِ المَبْنِيَّةِ.</p>"
        },
        "17": {
            "verses": {
                "39:17": {
                    "id": 17
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿الطَّاغُوتَ﴾ المَعْبُودَاتِ مِنْ دُونِ اللهِ؛ مِنَ الأَوْثَانِ وَالشَّيَاطِينِ.</p>\n<p>﴿وَأَنَابُوا﴾ رَجَعُوا إِلَى اللهِ بِالتَّوْبَةِ، وَالطَّاعَةِ.</p>\n<p>﴿الْبُشْرَى﴾ الذِّكْرُ الحَسَنُ، وَالتَّوْفِيقُ فِي الدُّنْيَا، وَالجَنَّةُ فِي الآخِرَةِ.</p>"
        },
        "18": {
            "verses": {
                "39:18": {
                    "id": 18
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿أُولُو الأَلْبَابِ﴾ أَصْحَابُ العُقُولِ السَّدِيدَةِ.</h2>"
        },
        "19": {
            "verses": {
                "39:19": {
                    "id": 19
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿حَقَّ عَلَيْهِ﴾ وَجَبَ عَلَيْهِ.</h2>"
        },
        "20": {
            "verses": {
                "39:20": {
                    "id": 20
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿غُرَفٌ﴾ مَنَازِلُ رَفِيعَةٌ عَالِيَةٌ فِي الجَنَّةِ.</h2>"
        },
        "21": {
            "verses": {
                "39:21": {
                    "id": 21
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَسَلَكَهُ يَنَابِيعَ﴾ أَدْخَلَهُ فِي عُيُونٍ وَمَجَارٍ.</h2>\n<h2>﴿يَهِيجُ﴾ يَيْبَسُ.</h2>\n<h2>﴿حُطَامًا﴾ مُتَكَسِّرًا مُتَفَتِّتًا.</h2>\n<h2>﴿لأُِوْلِي الأَلْبَابِ﴾ لأَِصْحَابِ العُقُولِ السَّلِيمَةِ.</h2>"
        },
        "22": {
            "verses": {
                "39:22": {
                    "id": 22
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<h2>﴿فَوَيْلٌ﴾ هَلاَكٌ، وَحَسْرَةٌ.</h2>"
        },
        "23": {
            "verses": {
                "39:23": {
                    "id": 23
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿مُتَشَابِهًا﴾ يُشْبِهُ بَعْضُهُ بَعْضًا فِي الحُسْنِ وَالإِحْكَامِ.</p>\n<p>﴿مَثَانِيَ﴾ تُثَنَّى وَتُكَرَّرُ فِيهِ الأَحْكَامُ وَالقِصَصُ وَالحُجَجُ.</p>\n<h2>﴿تَقْشَعِرُّ﴾ تَضْطَرِبُ، وَتَرْتَعِدُ.</h2>\n<h2>﴿تَلِينُ﴾ تَسْكُنُ، وَتَطْمَئِنُّ.</h2>"
        },
        "24": {
            "verses": {
                "39:24": {
                    "id": 24
                }
            },
            "resource_id": 116,
            "resource_name": "Tafsir Ar Wordmeanings",
            "language_id": 38,
            "slug": "ar_wordmeanings",
            "translated_name": {
                "name": "Tafsir Ar Wordmeanings",
                "language_name": "english"
            },
            "text": "<p>﴿يَتَّقِي بِوَجْهِهِ﴾ يُلْقَى فِي النَّارِ مَغْلُولاً، فَيَتَلَقَّاهَا بِوَجْهِهِ.</p>"
        },
