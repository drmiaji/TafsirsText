{
    "chapter": 80,
    "verses": {
        "1": {
            "verses": {
                "80:1": {
                    "id": 1
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ৰাছুল ছাল্লাল্লাহু আলাইহি অছাল্লামৰ মুখত ক্ৰোধৰ প্ৰভাৱ অনুভূত হৈছিল আৰু তেওঁ মুখ খন আনফালে উভতাই লৈছিল।</p>"
        },
        "2": {
            "verses": {
                "80:2": {
                    "id": 2
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>কাৰণ তেখেতৰ ওচৰত আব্দুল্লাহ বিন উম্মে মাকতুম মাৰ্গদৰ্শন লবলৈ আহিছিল আৰু তেওঁ এজন অন্ধ ব্যক্তি আছিল। আচলতে তেওঁ সেই সময়ত আহিছিল যেতিয়া তেখেতে মুশ্বৰিক সকলৰ উচ্চ স্তৰীয় নেতৃবৰ্গ সকলৰ লগত কথা-বাৰ্তা পাতি আছিল। আৰু তেখেতে সিহঁতৰ হিদায়তৰ আশাত আছিল।</p>"
        },
        "3": {
            "verses": {
                "80:3": {
                    "id": 3
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>(হে ৰাছুল) আপোনাক কিহে জনাব, বুধহয় অন্ধ ব্যক্তিজনে পাপৰ পৰা পৱিত্ৰ হবলৈ আহিছে।</p>"
        },
        "4": {
            "verses": {
                "80:4": {
                    "id": 4
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>অথবা আপোনাৰ বক্তব্য শুনি উপকৃত হব।</h2>"
        },
        "5": {
            "verses": {
                "80:5": {
                    "id": 5
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আনহাতে যিয়ে নিজৰ ধনৰ নিচাত পৰি নিজকে অমুখাপেক্ষী বুলি ভাৱে, আৰু ঈমানৰ পৰা তথা আপুনি লৈ অহা চৰীয়তক মানিবলৈ অৱহেলা কৰিছে।</p>"
        },
        "6": {
            "verses": {
                "80:6": {
                    "id": 6
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আপুনি তাৰ পিছত লাগিছে আৰু তাৰ প্ৰতি ধ্যান কেন্দ্ৰিত কৰি আছে।</p>"
        },
        "7": {
            "verses": {
                "80:7": {
                    "id": 7
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>যদি সি নিজ গুনাহৰ পৰা পৱিত্ৰ নহয় তেন্তে আপোনাৰ কি ক্ষতি হব?</h2>"
        },
        "8": {
            "verses": {
                "80:8": {
                    "id": 8
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আনহাতে যি ব্যক্তিয়ে কল্যাণ কামনাৰে আপোনাৰ ওচৰলৈ দৌৰি আহে।</h2>"
        },
        "9": {
            "verses": {
                "80:9": {
                    "id": 9
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু তেওঁ নিজ প্ৰতিপলকক ভয় কৰে।</h2>"
        },
        "10": {
            "verses": {
                "80:10": {
                    "id": 10
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>গতিকে আপুনি তেওঁৰ প্ৰতি ধ্যান দিয়াৰ পৰিৱৰ্তে মুশ্বৰিকসকলৰ নেতৃবৰ্গৰ প্ৰতি মনোনিবেশ কৰিলে।</p>"
        },
        "11": {
            "verses": {
                "80:11": {
                    "id": 11
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>প্ৰকৃততে বিষয়টো তেনেকুৱা নহয়, দৰাচলতে এয়া এক প্ৰকাৰ শিক্ষা তথা উপদেশ তাৰ বাবে যিয়ে ইয়াক গ্ৰহণ কৰে।</p>"
        },
        "12": {
            "verses": {
                "80:12": {
                    "id": 12
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এতেকে যিয়ে আল্লাহক স্মৰণ কৰিব বিচাৰে সি যেন স্মৰণ কৰে আৰু এই কুৰআনত থকা উপদেশ যাতে গ্ৰহণ কৰে।</p>"
        },
        "13": {
            "verses": {
                "80:13": {
                    "id": 13
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এই কুৰআন ফিৰিস্তাসকলৰ ওচৰত থকা সন্মানিত ছহিফাত লিপিবদ্ধ আছে।</p>"
        },
        "14": {
            "verses": {
                "80:14": {
                    "id": 14
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এখন উচ্চ স্থানত ৰখা আছে আৰু এয়া হৈছে পৱিত্ৰ, ইয়াক আৱৰ্জনা তথা অপৱিত্ৰতাই চুব নোৱাৰে।</p>"
        },
        "15": {
            "verses": {
                "80:15": {
                    "id": 15
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু এইখন আছে সংবাদ বাহক ৰূপে কাম কৰা ফিৰিস্তাসকলৰ হাতত।</h2>"
        },
        "16": {
            "verses": {
                "80:16": {
                    "id": 16
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেওঁলোক নিজ প্ৰতিপালকৰ ওচৰত সন্মানিত । অধিক কল্যাণ তথা অধিক আনুগত্যকাৰী।</p>"
        },
        "17": {
            "verses": {
                "80:17": {
                    "id": 17
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>কাফিৰ মানুহৰ প্ৰতি ধিক্কাৰ, সিহঁতে আল্লাহ তাআলাৰ প্ৰতি কিমান যে ঘোৰ অকৃতজ্ঞ!</p>"
        },
        "18": {
            "verses": {
                "80:18": {
                    "id": 18
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিহঁতক আল্লাহ তাআলাই কি বস্তুৰে সৃষ্টি কৰিছে যাৰ কাৰণে সিহঁতে অহংকাৰ কৰে আৰু আল্লাহ তাআলাৰ অকৃতজ্ঞতা কৰে?</p>"
        },
        "19": {
            "verses": {
                "80:19": {
                    "id": 19
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সামান্য পানীৰ দ্বাৰা সিহঁতক সৃষ্টি কৰিছে আৰু তাৰ পিছত স্তৰে স্তৰে বনাইছে।</p>"
        },
        "20": {
            "verses": {
                "80:20": {
                    "id": 20
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>এই স্তৰবোৰৰ পিছত মাকৰ গৰ্ভৰ পৰা ওলাবলৈ সহজ কৰি দিছে।</h2>"
        },
        "21": {
            "verses": {
                "80:21": {
                    "id": 21
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ পিছত পৃথিৱীত তাৰ বাবে নিৰ্ধাৰিত কৰা আয়ুস শেষ হোৱাৰ পিছত মৃত্যু দিছে আৰু তাৰ বাবে কবৰ বনাইছে যাৰ ভিতৰত পুনৰ জীৱিত হোৱা লৈকে থাকিব লাগিব।</p>"
        },
        "22": {
            "verses": {
                "80:22": {
                    "id": 22
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আকৌ যেতিয়া ইচ্ছা কৰিব তেতিয়া তাক হিচাপ-নিকাচৰ বাবে আৰু প্ৰতিদান দিয়াৰ বাবে পুনৰ্ত্থান কৰিব।</p>"
        },
        "23": {
            "verses": {
                "80:23": {
                    "id": 23
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ঘটনা তেনে নহয় যিদৰে কাফিৰ সকলে বুজিছে যে, সিহঁতে নিজ প্ৰতিপালকৰ অধিকাৰ আদায় কৰিছে। বৰং আল্লাহ তাআলাই সিহঁতৰ বাবে অনিবাৰ্য কৰা কৰ্মবোৰ আদায় কৰা নাই।</p>"
        },
        "24": {
            "verses": {
                "80:24": {
                    "id": 24
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আল্লাহৰ অকৃতজ্ঞতাকাৰী কাফিৰসকলে লক্ষ্য কৰা উচিত যে, সিহঁতে কৰা ভোজনবোৰ কৰ পৰা কেনেকৈ প্ৰাপ্ত হয়।</p>"
        },
        "25": {
            "verses": {
                "80:25": {
                    "id": 25
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ইয়াৰ মূল হৈছে সেই পানী, যিটো আকাশৰ পৰা অধিক মাত্ৰাত বৰ্ষণ হয়।</p>"
        },
        "26": {
            "verses": {
                "80:26": {
                    "id": 26
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আকৌ আমি ভূমিত ফাট মেলাইছো যাৰ পৰা অঙ্কুৰণবোৰ মাটি ফালি ওপৰলৈ ওলাই আহে।</p>"
        },
        "27": {
            "verses": {
                "80:27": {
                    "id": 27
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>তাৰ পিছত আমি (ধান), গম, মাকৈ আদি গছ গজাইছো।</h2>"
        },
        "28": {
            "verses": {
                "80:28": {
                    "id": 28
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু তাৰ ভিতৰত আঙুৰ আৰু সেউজীয়া ঘাঁহ গজাইছো যাতে সিহঁতৰ জীৱ-জন্তুৱে খাদ্য হিচাপে খাব পাৰে।</p>"
        },
        "29": {
            "verses": {
                "80:29": {
                    "id": 29
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু আমি তাৰ ভিতৰত জয়তুন আৰু খেজুৰ গছ গজাইছো।</h2>"
        },
        "30": {
            "verses": {
                "80:30": {
                    "id": 30
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
