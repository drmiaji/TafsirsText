{
    "chapter": 87,
    "verses": {
        "1": {
            "verses": {
                "87:1": {
                    "id": 1
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আপোনাৰ প্ৰতিপালকৰ পৱিত্ৰতা বৰ্ণনা কৰক, যিজন তেওঁৰ সৃষ্টিৰ পৰা বহু ঊৰ্দ্ধত আৰু আল্লাহক সন্মান সহকাৰে মুখেৰে উচ্চাৰণ কৰি স্মৰণ কৰক।</p>"
        },
        "2": {
            "verses": {
                "87:2": {
                    "id": 2
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যিজনে মানুহক সঠিকৰূপে সৃষ্টি কৰিছে আৰু উত্তম আকাৰ আকৃতি প্ৰদান কৰিছে।</p>"
        },
        "3": {
            "verses": {
                "87:3": {
                    "id": 3
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যিজনে সকলো সৃষ্টিৰ প্ৰকাৰ, বৰ্গ আৰু বিশেষতা নিৰ্ধাৰণ কৰিছে আৰু প্ৰত্যেক সৃষ্টিক তাৰ বাবে উচিত তথা অনুকূলীয় বস্তু প্ৰদান কৰিছে।</p>"
        },
        "4": {
            "verses": {
                "87:4": {
                    "id": 4
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু যিজনে তোমালোকৰ জন্তুৰ বাবে মাটিৰ পৰা ঘাঁহ- বন গজাইছে।</h2>"
        },
        "5": {
            "verses": {
                "87:5": {
                    "id": 5
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আকৌ সেই সেউজীয়া ঘাঁহবোৰ শুকাই কলা বৰণৰ আহাৰ বনাইছে।</h2>"
        },
        "6": {
            "verses": {
                "87:6": {
                    "id": 6
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে ৰাছুল! অনতিপলমে আমি আপোনাক কোৰআন পাঠ কৰাম আৰু আপোনাৰ অন্তৰত বহাই দিম তাৰ পিছত আপুনি তাক কেতিয়াও নাপাৰিব। গতিকে আপুনি জিব্ৰীলৰ আগে আগে কোৰআন নপঢ়িব, যিদৰে আপুনি পাহৰি যোৱাৰ ভয়ত আগে আগে পঢ়ে।</p>"
        },
        "7": {
            "verses": {
                "87:7": {
                    "id": 7
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>কেৱল যাক আল্লাহে কিবা হিকমতৰ কাৰণে পাহৰাব বিচাৰে। নিশ্চয় আল্লাহ প্ৰকাশ্য আৰু অপ্ৰকাশ্য সকলো জানে। তেওঁৰ পৰা কোনো বস্তু গোপন নহয়।</p>"
        },
        "8": {
            "verses": {
                "87:8": {
                    "id": 8
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আমি আপোনাৰ বাবে আল্লাহে সন্তুষ্ট হোৱা আমলবোৰ সহজ কৰি দিম, যিবোৰে জান্নাতত প্ৰৱেশ কৰাব।</p>"
        },
        "9": {
            "verses": {
                "87:9": {
                    "id": 9
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আপুনি মানুহক কোৰআনৰ দ্বাৰা উপদেশ দিয়ক যাৰ অহী আপোনাৰ প্ৰতি কৰিছো আৰু স্মৰণ কৰাওক যেতিয়ালৈকে স্মৰণ শুনাৰ শক্তি আছে।</p>"
        },
        "10": {
            "verses": {
                "87:10": {
                    "id": 10
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আপোনাৰ উপদেশ আৰু শিক্ষাৰ পৰা সেই ব্যক্তি নিশ্চয় শিক্ষা গ্ৰহণ কৰিব যিয়ে আল্লাহক ভয় কৰে। কিয়নো সিহঁতেই উপদেশৰ পৰা উপকৃত হয়।</p>"
        },
        "11": {
            "verses": {
                "87:11": {
                    "id": 11
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু কাফিৰ সকলে উপদেশৰ পৰা পলায়ন কৰিবই, কিয়নো পৰকালত জাহান্নামত প্ৰৱেশ কৰোৱা সকলৰ ভিতৰত সিহঁত সৱাতোকৈ হতভাগ্য হব।</p>"
        },
        "12": {
            "verses": {
                "87:12": {
                    "id": 12
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যিয়ে জাহান্নামৰ ভীষণ জুইত প্ৰৱেশ কৰিব আৰু তাৰ তাপৰ সন্মুখীন হৈ থাকিব।</p>"
        },
        "13": {
            "verses": {
                "87:13": {
                    "id": 13
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ পিছত সিহঁতে জাহান্নামত চিৰ দিনৰ বাবে প্ৰৱেশ কৰিব যাৰ ভিতৰত শাস্তিৰ পৰা মুক্তি পাবলৈ মৃত্যু কেতিয়াও নাহিব আৰু কোনো সন্মানজনক তথা আৰামদায়ক জীৱনো নাপাব।</p>"
        },
        "14": {
            "verses": {
                "87:14": {
                    "id": 14
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>সেই ব্যক্তি সফল হৈছে যিয়ে শ্বিৰ্ক আৰু পাপৰ পৰা পৱিত্ৰ হৈছে।</h2>"
        },
        "15": {
            "verses": {
                "87:15": {
                    "id": 15
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেওঁলোকৰ প্ৰতিপালকে শিকোৱা যিকিৰ- আযকাৰৰ দ্বাৰা তেওঁলোকে নিজ প্ৰতিপালকক স্মৰণ কৰিছে আৰু যিদৰে ছালাত আদায় কৰিবলৈ আদেশ দিছে সেইদৰেই আদায় কৰিছে।</p>"
        },
        "16": {
            "verses": {
                "87:16": {
                    "id": 16
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>বৰং তোমালোকে পাৰ্থিৱ জীৱনক অগ্ৰাধিকাৰ দিয়া আৰু ইয়াক পৰকালৰ ওপৰত প্ৰাধান্য দিয়া, অথচ দুয়োটাৰ মাজত আকাশ- পাতালৰ দৰে পাৰ্থক্য আছে।</p>"
        },
        "17": {
            "verses": {
                "87:17": {
                    "id": 17
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>অথচ পৰকালৰ জীৱন পৃথিৱী আৰু তাৰ মাজত থকা সুখ, সামগ্ৰীতকৈ উত্তম আৰু চিৰস্থায়ী। কিয়নো তাত থকা অৱদানবোৰ কেতিয়াওঁ শেষ নহয়।</p>"
        },
        "18": {
            "verses": {
                "87:18": {
                    "id": 18
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ওপৰোল্লেখিত যিবোৰ আদেশ আৰু সংবাদ আমি তোমালোকৰ বাবে বৰ্ণনা কৰিলোঁ, সেইবোৰ কোৰআন অৱতীৰ্ণ হোৱাৰ পূৰ্বেও আকাশৰ পৰা অৱতীৰ্ণ হোৱা অন্যান্য গ্ৰন্থবোৰত মজুত আছিল।</p>"
        },
        "19": {
            "verses": {
                "87:19": {
                    "id": 19
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সেই ছহীফাসমূহ হৈছে ইব্ৰাহিম আৰু মুছা আলাইহিমুছ ছালামৰ প্ৰতি অৱতীৰ্ণ ছহীফা।</p>"
        }
    }
}