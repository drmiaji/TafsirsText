{
    "chapter": 69,
    "verses": {
        "1": {
            "verses": {
                "69:1": {
                    "id": 1
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আল্লাহ তাআলাই পুনৰুত্থানৰ সময়ৰ কথা উল্লেখ কৰিছে, যিটো সকলোৱে অতিক্ৰম কৰিব লাগিব।</p>"
        },
        "2": {
            "verses": {
                "69:2": {
                    "id": 2
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আকৌ এই প্ৰশ্নৰ মাধ্যমেৰে পুনৰুত্থানৰ গুৰুত্ব বৃদ্ধি কৰিছে যে, সেই অৱশ্যম্ভাৱী ঘটনাটো কি?</p>"
        },
        "3": {
            "verses": {
                "69:3": {
                    "id": 3
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু কিহে আপোনাক জনাব যে সেই অৱশ্যাম্ভাৱী ঘটনাটো কি?</h2>"
        },
        "4": {
            "verses": {
                "69:4": {
                    "id": 4
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ছলেহ আলাইহিছ ছালামৰ সম্প্ৰদায় ছামুদ আৰু হুদ আলাইহিছ ছালামৰ সম্প্ৰদায় আদ জাতিয়ে ক্বিয়ামতক অস্বীকাৰ কৰিছিল, যি ক্বিয়ামতৰ ভয়-ভীতিয়ে মানুহক কপাই তুলিব।</p>"
        },
        "5": {
            "verses": {
                "69:5": {
                    "id": 5
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সেয়ে ছামুদ সম্প্ৰদায়ক আল্লাহে অতি তীব্ৰ আৰু ভয়ানক শব্দৰ জৰিয়তে ধংস কৰি দিছে।</p>"
        },
        "6": {
            "verses": {
                "69:6": {
                    "id": 6
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু আদ সম্প্ৰদায়ক আল্লাহে ধ্বংস কৰিছে অতি ঠাণ্ডা প্ৰবল ধুমুহাৰ দ্বাৰা।</p>"
        },
        "7": {
            "verses": {
                "69:7": {
                    "id": 7
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আল্লহে ইয়াক সাত ৰাতি আৰু আঠ দিনৰ বাবে প্ৰেৰিত কৰিছিল। যিয়ে সিহঁতক ধংস কৰিছিল। ফলত আপুনি দেখিবলৈ পালেহেঁতেন যে সিহঁত ধংসৰ পিছত মাটিৰ ওপৰত নিজ এলাকাত এনেকৈ পৰি আছে যেনিবা মাটিৰ ওপৰত জৰাজীৰ্ণ খেজুৰ গছৰ কাণ্ডহে।</p>"
        },
        "8": {
            "verses": {
                "69:8": {
                    "id": 8
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সেয়েহে এই শাস্তিৰ পিছত সিহঁতৰ মাজৰ কাৰোবাক আপুনি দেখিবলৈ পাইছেনে?</p>"
        },
        "9": {
            "verses": {
                "69:9": {
                    "id": 9
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ফিৰআউন, তাৰ পূৰ্বৱৰ্তীসকলে আৰু ওলোটাই দিয়া জনপদবাসী অৰ্থাৎ লুত আলাইহিছ ছালামৰ সম্প্ৰদায়ৰ লোকে শ্বিৰ্ক আৰু অবাধ্যতাত লিপ্ত হৈছিল।</p>"
        },
        "10": {
            "verses": {
                "69:10": {
                    "id": 10
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু সিহঁতৰ মাজৰ প্ৰত্যেকেই নিজ ৰাছুলৰ লগত অবাধ্য আচৰণ কৰিছিল আৰু তেওঁক অস্বীকাৰ কৰিছিল। ফলত আল্লহে সিহঁতক তাতকৈ অধিক কঠোৰভাৱে গ্ৰেপ্তাৰ কৰিছিল, যাৰ দ্বাৰা সিহঁতক ধ্বংস কৰা হৈছে।</p>"
        },
        "11": {
            "verses": {
                "69:11": {
                    "id": 11
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যেতিয়া পানী বিপদৰ সীমা চেৰাই গৈছিল তেতিয়া আমি তোমালোকৰ পূৰ্বপুৰুষ সকলক সেই নাৱত আৰোহণ কৰাইছিলো যিটো নূহ আলাইহিছ ছালামে আমাৰ আদেশমৰ্মে তৈয়াৰ কৰিছিল।</p>"
        },
        "12": {
            "verses": {
                "69:12": {
                    "id": 12
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যাতে আমি নাও আৰু ইয়াৰ কাহিনীক এক শিক্ষাৰ সামগ্ৰী হিচাপে চিহ্নিত কৰি দিও যে, কাফিৰবিলাকৰ ধংস আৰু মুমিনসকলক মুক্তিৰ প্ৰমাণ হিচাপে দেখাব পৰা যায় আৰু ইয়াক এনেকুৱা কাণে যাতে মনত ৰাখিব পাৰে যিয়ে শুনা মাত্ৰকে মনত ৰাখে।</p>"
        },
        "13": {
            "verses": {
                "69:13": {
                    "id": 13
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ পিছত যেতিয়া শিঙাত ফুঁ দিয়া কাৰ্যত নিযুক্ত ফিৰিস্তাই শিঙাত এটা ফুঁ মাৰিব। অৰ্থাৎ এইটো হব দ্বিতীয় ফুঁ।</p>"
        },
        "14": {
            "verses": {
                "69:14": {
                    "id": 14
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু পৃথিৱী তথা পাহাৰসমূহক উঠাই নিয়া হব আৰু মাত্ৰ এটা আঘাত কৰা হব, ফলত পৃথিৱী তথা তাৰ ওপৰত থকা পাহাৰসমূহ চূৰ্ণ- বিচূৰ্ণ হৈ যাব।</p>"
        },
        "15": {
            "verses": {
                "69:15": {
                    "id": 15
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>যিদিনাখন এইবোৰ হব সিদিনাই ক্বিয়ামত সংঘটিত হ’ব।</h2>"
        },
        "16": {
            "verses": {
                "69:16": {
                    "id": 16
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু সিদিনাখন আকাশ বিদীৰ্ণ হব যাতে তাৰ ফাটেৰে ফিৰিস্তাসকল অৱতীৰ্ণ হব পাৰে। সিদিনাখন ই দূৰ্বল হৈ যাব, যদিও ই আছিল অতি মজবুত।</p>"
        },
        "17": {
            "verses": {
                "69:17": {
                    "id": 17
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিদিনাখন ফিৰিস্তাসকলে আকাশৰ বিভিন্ন প্ৰান্তত আৰু চোকে কোণে থাকিব। আৰু সেই ভীষণ দিনত আঠজন নিকটৱৰ্তী ফিৰিস্তাই তোমাৰ প্ৰতিপালকৰ আৰছক বহন কৰি থাকিব।</p>"
        },
        "18": {
            "verses": {
                "69:18": {
                    "id": 18
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিদিনাখন তোমালোকক (হে মানৱ) আল্লাহৰ সন্মুখত উপস্থিত কৰা হ’ব। তোমালোকৰ কোনো কথাই আল্লাহৰ পৰা গোপন হৈ নাথাকিব। বৰং আল্লাহে তোমালোকৰ সকলো কথাই জানে।</p>"
        },
        "19": {
            "verses": {
                "69:19": {
                    "id": 19
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ পিছত সেই ব্যক্তি, যাক তাৰ কৰ্মপত্ৰ তাৰ সোঁ হাতত দিয়া হব তেওঁ আনন্দ আৰু সন্তুষ্ট হৈ কবঃ লোৱা, মোৰ কৰ্মপত্ৰ পঢ়ি চোৱা।</p>"
        },
        "20": {
            "verses": {
                "69:20": {
                    "id": 20
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>মই পৃথিৱীত জানিছিলো আৰু বিশ্বাস কৰিছিলো যে মোক পুনৰ জীৱিত কৰা হ’ব আৰু নিজৰ কৰ্মৰ প্ৰতিফল বা পৰিণাম পাব লাগিব।</p>"
        },
        "21": {
            "verses": {
                "69:21": {
                    "id": 21
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এতেকে তেওঁ উত্ফুল্লিত আৰু আনন্দময় জীৱনত থাকিব। কিয়নো তেওঁ প্ৰত্যেক ফালে চিৰস্থায়ী অনুগ্ৰহ দেখিবলৈ পাব।</p>"
        },
        "22": {
            "verses": {
                "69:22": {
                    "id": 22
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এনেকুৱা জান্নাতত থাকিব যিটো মৰ্যদা আৰু স্থানৰ ক্ষেত্ৰতো সুউচ্চ আৰু সন্মানিত।</p>"
        },
        "23": {
            "verses": {
                "69:23": {
                    "id": 23
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>তাৰ ফল-মূলবোৰ ভক্ষণকাৰীৰ অতি ওচৰত থাকিব।</h2>"
        },
        "24": {
            "verses": {
                "69:24": {
                    "id": 24
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিহঁতক সন্মান স্বৰূপ কোৱা হ’বঃ এইবোৰ খোৱা আৰু পান কৰা। যাৰ ভিতৰত কোনো কষ্ট নাই। সেই সত্কৰ্মৰ বিনিময়ত যিবোৰ তোমালোকে বিগত দিনত কৰি আহিছা।</p>"
        },
        "25": {
            "verses": {
                "69:25": {
                    "id": 25
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু সেই ব্যক্তি যাক তাৰ কৰ্মপত্ৰ বাওঁ হাতত দিয়া হব তেওঁ অতি লজ্জিত হৈ কবঃ হায়. যদি মোক মোৰ আমলনামা দিয়া নহলহেঁতেন! কিয়নো তাৰ ভিতৰত ইমান পাপ কৰ্ম আছে যিবোৰ মোক শাস্তিৰ অধিকাৰী প্ৰমাণিত কৰে।</p>"
        },
        "26": {
            "verses": {
                "69:26": {
                    "id": 26
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু হায়! যদি মই নাজানিলোহেঁতেন যে মোৰ হিচাপ কি হ’ব?</h2>"
        },
        "27": {
            "verses": {
                "69:27": {
                    "id": 27
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হায়! সেই মৃত্যু যিটো এবাৰ মোলৈ আহিছিল সেইটোৱে যদি এনেকুৱা হলেহেঁতেন যে তাৰ পিছত কেতিয়াও উত্থাপন কৰা নহলেহেঁতেন।</p>"
        },
        "28": {
            "verses": {
                "69:28": {
                    "id": 28
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>মোৰ ধন- সম্পদে আল্লাহৰ শাস্তিৰ পৰা ৰক্ষা কৰিব নোৱাৰিলে।</h2>"
        },
        "29": {
            "verses": {
                "69:29": {
                    "id": 29
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>মোৰ প্ৰমাণ তথা সেই শক্তি আৰু সন্মান, মোৰ পৰা বিলুপ্ত হৈ গল যাৰ প্ৰতি মই নিৰ্ভৰ কৰিছিলো।</p>"
        },
        "30": {
            "verses": {
                "69:30": {
                    "id": 30
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু কোৱা হ’বঃ (হে ফিৰিস্থাসকল) তাক ধৰা, তাৰ হাত ডিঙিৰ সৈতে বান্ধি দিয়া।</p>"
        },
        "31": {
            "verses": {
                "69:31": {
                    "id": 31
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ পিছত তাক জাহান্নামত নিক্ষেপ কৰা, যাতে ইয়াৰ উত্তাপ ভোগ কৰিব পাৰে।</p>"
        },
        "32": {
            "verses": {
                "69:32": {
                    "id": 32
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ পিছত তাক এনেকুৱা শিকলিৰে বান্ধি থোৱা, যাৰ দৈৰ্ঘ সত্তৰ হাত।</p>"
        },
        "33": {
            "verses": {
                "69:33": {
                    "id": 33
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>নিশ্চিয় সি মহান আল্লাহৰ প্ৰতি ঈমান আনা নাছিল।</h2>"
        },
        "34": {
            "verses": {
                "69:34": {
                    "id": 34
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>মিছকিনসকলক খাদ্য খোওৱাবলৈ অন্য মানুহক উত্সাহিত কৰা নাছিল।</h2>"
        },
        "35": {
            "verses": {
                "69:35": {
                    "id": 35
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এতেকে ক্বিয়ামতৰ দিনা তেওঁৰ কোনো নিকটৱৰ্তী নাথাকিব, যিয়ে তাক শাস্তিৰ পৰা ৰক্ষা কৰিব পাৰিব।</p>"
        },
        "36": {
            "verses": {
                "69:36": {
                    "id": 36
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু তাৰ খাদ্যৰ বাবে জাহান্নামীসকলৰ শৰীৰৰ পৰা ওলোৱা পুঁজৰ বাহিৰে আন কোনো খাদ্য নাথাকিব।</p>"
        },
        "37": {
            "verses": {
                "69:37": {
                    "id": 37
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>এইটো হৈছে পাপী আৰু অপৰাধীবিলাকৰ খাদ্য।</h2>"
        },
        "38": {
            "verses": {
                "69:38": {
                    "id": 38
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আল্লাহ তাআলাই সেইবোৰ বস্তুৰ শপত কৰিছে যিবোৰ তোমালোকে দেখি আছা।</p>"
        },
        "39": {
            "verses": {
                "69:39": {
                    "id": 39
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু সেই বস্তুৰ শপত কৰিছে যিবোৰ তোমালোকে দেখা নোপোৱা।</h2>"
        },
        "40": {
            "verses": {
                "69:40": {
                    "id": 40
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>নিশ্চয় কোৰআন আল্লাহৰ বাণী। যিটো মানুহৰ আগত তেওঁৰ সন্মানিত ৰাছুলে পঢ়ি শুনাইছে।</p>"
        },
        "41": {
            "verses": {
                "69:41": {
                    "id": 41
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু এয়া কোনো কবিৰ কথা নহয়। কিয়নো এয়া কোনো কবিতাৰ ৰূপত নহয়। তোমালোকে খুবেই কম ঈমান পোষণ কৰা।</p>"
        },
        "42": {
            "verses": {
                "69:42": {
                    "id": 42
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু এয়া কোনো গণকৰ কথাও নহয়। কিয়নো গণকৰ কথা এই কোনআনৰ পৰা পৰিপূৰ্ণ ভিন্ন। তোমালোকে খুবেই কম উপদেশ গ্ৰহণ কৰা।</p>"
        },
        "43": {
            "verses": {
                "69:43": {
                    "id": 43
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>বৰং এয়া সকলো সৃষ্টিৰ প্ৰতিপালকৰ তৰফৰ পৰা অৱতীৰ্ণ কৰা গ্ৰন্থ।</p>"
        },
        "44": {
            "verses": {
                "69:44": {
                    "id": 44
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যদি মুহাম্মদ চাল্লাল্লাহু আলাইহি অছাল্লামে আমাৰ নামত কোনো মনেসজা কথা কলেহঁতেন যিটো মই কোৱা নাই।</p>"
        },
        "45": {
            "verses": {
                "69:45": {
                    "id": 45
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেন্তে আমি তাৰ পৰা প্ৰতিশোধ ললোহেঁতেন। আৰু তেখেতৰ সোঁ হাত নিজ শক্তি আৰু সামৰ্থৰ সৈতে ধৰিলোহেঁতেন।</p>"
        },
        "46": {
            "verses": {
                "69:46": {
                    "id": 46
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ পিছত তেখেতৰ হৃদপিণ্ডৰ শিৰা কাটি দিলোহঁতেন। যিটো তেখেতৰ অন্তৰৰ লগত সংযোগ।</p>"
        },
        "47": {
            "verses": {
                "69:47": {
                    "id": 47
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এতেকে তোমালোকৰ মাজত কোনো ৰক্ষাকাৰী নাই, যিয়ে তেওঁক আমাৰ পৰা ৰক্ষা কৰিব। গতিকে তোমালোকৰ কাৰণে তেখেতে মোৰ প্ৰতি কোনো মনেসজা কথা ৰচনা কৰিব সেয়া অসম্ভৱ।</p>"
        },
        "48": {
            "verses": {
                "69:48": {
                    "id": 48
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>নিশ্চয় এই কোৰআন সেই সকলৰ বাবে শিক্ষা আৰু উপদেশ, যিসকলে নিজ প্ৰতিপালকৰ আদেশ পালন কৰি তেওঁৰ নিষেধকৃত বস্তুৰ পৰা বিৰত থাকি তেওঁক ভয় কৰে।</p>"
        },
        "49": {
            "verses": {
                "69:49": {
                    "id": 49
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু আমি নিশ্চয় জানো যে. তোমালোকৰ মাজৰ কিছুমানে এই কোৰআন অস্বীকাৰ কৰে।</p>"
        },
        "50": {
            "verses": {
                "69:50": {
                    "id": 50
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>নিশ্চিতৰূপে কোৰআন অস্বীকাৰ কৰাটো ক্বিয়ামতৰ দিনা ডাঙৰ অনুশোচনাৰ কাৰণ হ’ব।</p>"
        },
        "51": {
            "verses": {
                "69:51": {
                    "id": 51
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু কোৰআন পৰিপূৰ্ণ সুনিশ্চিত সত্য। যিটো আল্লাহৰ তৰফৰ পৰা অৱতীৰ্ণ গ্ৰন্থ হোৱাত কোনো সন্দেহ আৰু সংশয় নাই।</p>"
        },
        "52": {
            "verses": {
                "69:52": {
                    "id": 52
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এতেকে হে ৰাছুল, আপুনি আপোনাৰ প্ৰতিপালকৰ পৱিত্ৰতা বৰ্ণনা কৰি সেইবোৰ বিষয় নাকচ কৰক যিবোৰ তেওঁৰ সন্মানৰ পৰিপন্থী। আৰু আপোনাৰ প্ৰতিপালকৰ নামত তছবীহ পাঠ কৰক।</p>"
        }
    }
}