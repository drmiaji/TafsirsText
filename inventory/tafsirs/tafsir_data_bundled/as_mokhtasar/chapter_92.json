{
    "chapter": 92,
    "verses": {
        "1": {
            "verses": {
                "92:1": {
                    "id": 1
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আল্লাহ তাআলাই ৰাতিৰ শপত কৰিছে, যেতিয়া ই তাৰ অন্ধাকাৰৰ জৰিয়তে আকাশ আৰু পৃথিৱীৰ মাজত সকলো বস্তুক আৱৰি ধৰে।</p>"
        },
        "2": {
            "verses": {
                "92:2": {
                    "id": 2
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু দিনৰ শপত কৰিছে, যেতিয়া ই প্ৰকাশ হয় আৰু স্পষ্ট হয়।</h2>"
        },
        "3": {
            "verses": {
                "92:3": {
                    "id": 3
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু তেওঁৰ সৃষ্টিৰ দুটা প্ৰকাৰৰ শপত কৰিছে, মতা- মাইকিৰ।</h2>"
        },
        "4": {
            "verses": {
                "92:4": {
                    "id": 4
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে মানৱ, নিশ্চয় তোমালোকৰ প্ৰয়াস বেলেগ বেলেগ প্ৰকাৰৰ। কিছুমান সৎ প্ৰয়াস, যিবোৰ জান্নাতত প্ৰৱেশ কৰাৰ মাধ্যম আৰু কিছুমান অসৎ প্ৰয়াস, যিবোৰ জাহান্নামত প্ৰৱেশ কৰাৰ মাধ্যম।</p>"
        },
        "5": {
            "verses": {
                "92:5": {
                    "id": 5
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এতেকে যিয়ে য'ত খৰচ কৰা জৰুৰীভাৱে, সি তাত খৰচ কৰিছে যেনে- যাকাত, আহাৰ- ভোজন, আৰু কাফফাৰা আদি। আৰু আল্লাহ তাআলাই যাৰ পৰা বিৰত থাকিবলৈ কৈছে, তাৰ পৰা দূৰত্ব অৱলম্বন কৰিছে।</p>"
        },
        "6": {
            "verses": {
                "92:6": {
                    "id": 6
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু আল্লাহ তাআলাই পৰিণামৰ যি প্ৰতিশ্ৰুতি কৰিছে সেয়া পূৰ্ণ কৰিছে।</p>"
        },
        "7": {
            "verses": {
                "92:7": {
                    "id": 7
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আমি তাৰ বাবে সত্কৰ্ম কৰাৰ আৰু আল্লাহৰ পথত খৰচ কৰা সহজ কৰি দিম।</p>"
        },
        "8": {
            "verses": {
                "92:8": {
                    "id": 8
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু সেই ব্যক্তি যিয়ে তাৰ সম্পদ ব্যয় কৰাৰ ক্ষেত্ৰত কৃপণালী কৰে আৰু জৰুৰী কামত খৰচ নকৰে আৰু ধন-সম্পদৰ লালসাত আল্লাহক অৱহেলা কৰে আৰু আল্লাহৰ পৰা তাৰ কৰুণা বিচৰা নাই।</p>"
        },
        "9": {
            "verses": {
                "92:9": {
                    "id": 9
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু আল্লাহ তাআলাই তাৰ পথত ধন খৰচ কৰাৰ প্ৰতি যি পৰিণাম প্ৰদানৰ প্ৰতিশ্ৰুতি দিছে তাক অস্বীকাৰ কৰিছে।</p>"
        },
        "10": {
            "verses": {
                "92:10": {
                    "id": 10
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেন্তে আমি তাৰ বাবে বেয়া কাম সহজ কৰি দিম আৰু ভাল কাম কৰা জটিল কৰি দিম।</p>"
        },
        "11": {
            "verses": {
                "92:11": {
                    "id": 11
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যেতিয়া সি ধ্বংস হব আৰু জাহান্নামত প্ৰৱেশ কৰিব তেতিয়া তাৰ ধন-সম্পদ তাৰ কোনো কামত নাহিব, যাক সি কৃপণালি কৰি জমা কৰি ৰাখিছিল।</p>"
        },
        "12": {
            "verses": {
                "92:12": {
                    "id": 12
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>কেৱল সত্য আৰু মিথ্যাৰ পথ পৰিচয় কৰাই দিয়াই আমাৰ দায়িত্ব।</h2>"
        },
        "13": {
            "verses": {
                "92:13": {
                    "id": 13
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>পাৰ্থিৱ আৰু পৰকালৰ জীৱন আমাৰ হাতত। আমি উভয়ৰ মাজত যি বিচাৰো পৰিৱৰ্তন কৰোঁ। আৰু এয়া আমাৰ অবিহনে আন কাৰো জৰিয়তে হব নোৱাৰে।</p>"
        },
        "14": {
            "verses": {
                "92:14": {
                    "id": 14
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে মানৱ, যদি তোমালোকে আল্লাহক অৱজ্ঞা কৰা তেন্তে আমি তোমালোকক উত্তপ্ত জুইৰ পৰা সতৰ্ক কৰি দিছো।</p>"
        },
        "15": {
            "verses": {
                "92:15": {
                    "id": 15
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যাৰ ভিতৰত কেৱল হতভাগ্য ব্যক্তিহে জ্বলিব অৰ্থাৎ কাফিৰ ব্যক্তি।</p>"
        },
        "16": {
            "verses": {
                "92:16": {
                    "id": 16
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যিয়ে ৰাছুল চাল্লাল্লাহু আলাইহি অছাল্লামে আনা সংবাদ অস্বীকাৰ কৰিছে আৰু আল্লাহৰ আজ্ঞা পালনৰ পৰা মুখ ঘূৰাই ফুৰিছে।</p>"
        },
        "17": {
            "verses": {
                "92:17": {
                    "id": 17
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু ইয়াৰ পৰা পৰম মুত্তাক্বী ব্যক্তিক অৰ্থাৎ আবু বকৰ চিদ্দীক ৰাদ্বিয়াল্লাহু আনহুক বচাই লোৱা হব।</p>"
        },
        "18": {
            "verses": {
                "92:18": {
                    "id": 18
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>যিয়ে তাৰ ধন সৎ পথত পাপৰ পৰা পবিত্ৰ হবলৈ দান কৰে।</h2>"
        },
        "19": {
            "verses": {
                "92:19": {
                    "id": 19
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু তেওঁ তাৰ ধন-সম্পদ এই কাৰণে ব্যয় নকৰে যে তাৰ প্ৰতি কাৰো অনুগ্ৰহ আছে, যাক আদায় কৰি আছে।</p>"
        },
        "20": {
            "verses": {
                "92:20": {
                    "id": 20
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেওঁ যি ধন ব্যয় কৰে ইয়াৰ একমাত্ৰ উদ্দেশ্য হৈছে, তেওঁৰ প্ৰতিপালকৰ সন্তুষ্টি লাভ কৰা, যিজন নিজ সৃষ্টিতকৈ বহু ঊৰ্দ্ধত।</p>"
        },
        "21": {
            "verses": {
                "92:21": {
                    "id": 21
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু তেওঁ নিশ্চয় সেই প্ৰচুৰ পৰিণামৰ প্ৰতি সন্তুষ্ট হৈ যাব, যিবোৰ আল্লাহ তাআলাই তেওঁক দান কৰিব।</p>"
        }
    }
}