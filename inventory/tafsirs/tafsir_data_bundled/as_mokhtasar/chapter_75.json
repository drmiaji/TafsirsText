{
    "chapter": 75,
    "verses": {
        "1": {
            "verses": {
                "75:1": {
                    "id": 1
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আল্লাহে ক্বিয়ামতৰ দিনৰ শপত কৰিছে। যিদিনাখন মানুহে বিশ্বজগতৰ ৰব্ব আল্লাহৰ সন্মুখত থিয় হ'ব।</p>"
        },
        "2": {
            "verses": {
                "75:2": {
                    "id": 2
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু পবিত্ৰ আত্মাৰ শপত কৰিছো। যিটোৱে মানুহক ভাল কামত অৱহেলা কৰিলে নিন্দা কৰে আৰু বেয়া কাম কৰিলে ভৰ্ত্সনা কৰে। এই দুয়োটা বিষয়ৰ শপত কৰি কৈছে যে, তেওঁ মানুহক হিচাপ-নিকাচ আৰু প্ৰতিফল প্ৰদান কৰাৰ বাবে নিশ্চয় জীৱিত কৰিব।</p>"
        },
        "3": {
            "verses": {
                "75:3": {
                    "id": 3
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>মানুহে ভাবে নেকি যে, আমি মানুহক মৃত্যুৰ পিছত পুনৰুত্থান কৰি তাৰ হাড়সমূহক একত্ৰিত কৰিব নোৱাৰিম?</p>"
        },
        "4": {
            "verses": {
                "75:4": {
                    "id": 4
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>কিয় নোৱাৰিম? আমি সেইবোৰ একত্ৰিত কৰি তাৰ আঙুলিবোৰৰ গাঁঠিও পূৰ্বৰ দৰে সঠিকভাৱে বনোৱাৰ ক্ষমতা ৰাখো।</p>"
        },
        "5": {
            "verses": {
                "75:5": {
                    "id": 5
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>বৰং মানুহে পুনৰুত্থানক অস্বীকাৰ কৰি এইটোৱে বিচাৰে যে, আগলৈও কোনো বাধা- বিঘিনি নোহোৱাকৈ কুকৰ্ম কৰিয়ে থাকিব।</p>"
        },
        "6": {
            "verses": {
                "75:6": {
                    "id": 6
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিহঁতে ক্বিয়ামতৰ দিনক বহুত দূৰ বুলি ভাবি কয় যে, ক্বিয়ামত কেতিয়া আহিব।</p>"
        },
        "7": {
            "verses": {
                "75:7": {
                    "id": 7
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যেতিয়া চকুৱে সেই বস্তু দেখি আশ্চৰ্য হব, যিবোৰ সিহঁতে পৃথিৱীত অস্বীকাৰ কৰিছিল।</p>"
        },
        "8": {
            "verses": {
                "75:8": {
                    "id": 8
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>চন্দ্ৰৰ কিৰণ নোহোৱা হ'ব।</h2>"
        },
        "9": {
            "verses": {
                "75:9": {
                    "id": 9
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>সূৰ্য আৰু চন্দ্ৰক যেতিয়া একত্ৰিত কৰা হ'ব।</h2>"
        },
        "10": {
            "verses": {
                "75:10": {
                    "id": 10
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>সিদিনাখন পাপিষ্ঠ লোকে ক'ব যে, পলোৱাৰ স্থান ক'ত?</h2>"
        },
        "11": {
            "verses": {
                "75:11": {
                    "id": 11
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিদিনাখন পলায়নৰ কোনো স্থান নাথাকিব। এনেকুৱা কোনো আশ্ৰয়স্থল বিচাৰি নাপাব, য'ত পাপিষ্ঠবিলাকে আশ্ৰয় পাব আৰু ৰক্ষা পোৱাৰ কোনো স্থানো নাথাকিব য'ত গৈ নিজকে ৰক্ষা কৰিব পাৰিব।</p>"
        },
        "12": {
            "verses": {
                "75:12": {
                    "id": 12
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে ৰাছুল, সিদিনাখন আপোনাৰ প্ৰতিপালকলৈ হিচাপ- নিকাচ আৰু পৰিণামৰ কাৰণে উভতি যাব লাগিব।</p>"
        },
        "13": {
            "verses": {
                "75:13": {
                    "id": 13
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিদিনাখন মানুহক সেই সকলো কৰ্মৰ বিষয়ে অৱগত কৰোৱা হব। যিবোৰ তেওঁ আগলৈ পঠিয়াইছিল আৰু যি তেওঁ পিছফালে এৰি থৈ আহিছে।</p>"
        },
        "14": {
            "verses": {
                "75:14": {
                    "id": 14
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>বৰং মানুহ নিজেই নিজৰ প্ৰতি সাক্ষী হ'ব। কিয়নো স্বয়ং তেওঁৰ নিজ শৰীৰৰ অংগবোৰৰ দ্বাৰা কৰা পাপসমূহৰ সাক্ষী দিব।</p>"
        },
        "15": {
            "verses": {
                "75:15": {
                    "id": 15
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যদিও সি বিভিন্ন ধৰণৰ বাহানাৰ জৰিয়তে এইটো প্ৰমাণ কৰিব বিচাৰিব যে, সি কোনো পাপ কৰা নাই, কিন্তু ইয়াৰ দ্বাৰা কোনো উপকাৰ নহ'ব।</p>"
        },
        "16": {
            "verses": {
                "75:16": {
                    "id": 16
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে ৰাছুল, কোৰআন আয়ত্ত্ব কৰাৰ সময়ত আপোনাৰ জিভা এই ভয়ত দ্ৰুত সঞ্চালন নকৰিব যে, সেয়া আপোনাৰ স্মৃতিৰ পৰা ওলাই যাব।</p>"
        },
        "17": {
            "verses": {
                "75:17": {
                    "id": 17
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>নিশ্চয় আপোনাৰ অন্তৰত একত্ৰিত কৰা আৰু সঠিক হিচাপে পাঠ কৰোৱাৰ দায়িত্ব আমাৰেই।</p>"
        },
        "18": {
            "verses": {
                "75:18": {
                    "id": 18
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আমাৰ বাৰ্তাবাহক জিব্ৰীলে যেতিয়া আপোনাৰ ওচৰত তিলাৱত কৰিব, তেতিয়া আপুনি মনে মনে থাকিব আৰু মনোযোগ সহকাৰে শুনিব।</p>"
        },
        "19": {
            "verses": {
                "75:19": {
                    "id": 19
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>তাৰ পিছত ইয়াৰ বৰ্ণনাৰ দায়িত্বও আমাৰেই।</h2>"
        },
        "20": {
            "verses": {
                "75:20": {
                    "id": 20
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>কেতিয়াও নহয়, বিষয়টো তেনেকুৱা নহয় যিদৰে তোমালোকে ভাবিছা যে, পুনৰুত্থান অসম্ভৱ। কিয়নো তোমালোকে জানা যে, যিয়ে তোমালোকক প্ৰথম বাৰ সৃষ্টি কৰিছে তেওঁ তোমালোকৰ মৃত্যুৰ পিছত তোমালোকক জীৱিত কৰাত অক্ষম নহয়। আচলতে তোমালোকে পুনৰুত্থানক অস্বীকাৰ কৰাৰ কাৰণ হৈছে তোমালোকে ধ্বংসশীল পৃথিৱীক অতিমাত্ৰা ভাল পোৱা।</p>"
        },
        "21": {
            "verses": {
                "75:21": {
                    "id": 21
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু তোমালোকে পৰকালক এৰি দিয়া। যিটো আল্লাহৰ আদেশ পালন কৰি আৰু তেওঁৰ নিষিদ্ধ বস্তুৰ পৰা বিৰত থাকি অৰ্জন কৰিব পৰা যায়।</p>"
        },
        "22": {
            "verses": {
                "75:22": {
                    "id": 22
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিদিনাখন মুমিনসকল আৰু ভাগ্যৱান লোকৰ মুখমণ্ডল উজ্জ্বল হ'ব। তাৰ পৰা জ্যোতি প্ৰবাহিত হব।</p>"
        },
        "23": {
            "verses": {
                "75:23": {
                    "id": 23
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিদিনাখন সিহঁতৰ প্ৰতিপালকক চাই থাকিব আৰু তাৰ আনন্দ উপভোগ কৰি থাকিব।</p>"
        },
        "24": {
            "verses": {
                "75:24": {
                    "id": 24
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু কাফিৰ আৰু দুৰ্ভাগ্যৱান বিলাকৰ মুখমণ্ডল সিদিনাখন নিৰাশ আৰু উদাসীন হ'ব।</p>"
        },
        "25": {
            "verses": {
                "75:25": {
                    "id": 25
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু সিহঁতৰ বিশ্বাস হৈ যাব যে, সিহঁতৰ প্ৰতি ডাঙৰ আৰু কঠোৰ শাস্তি আহিব।</p>"
        },
        "26": {
            "verses": {
                "75:26": {
                    "id": 26
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>বিষয়টো তেনেকুৱা নহয় যিদৰে মুশ্বৰিকবিলাকে ভাবিছে যে. যেতিয়া সিহঁতৰ মৃত্যু হব তেতিয়া সিহঁতে শাস্তিৰ সন্মুখীন নহব। আৰু যেতিয়া তোমালোকৰ মাজত কাৰো প্ৰাণ তাৰ কণ্ঠগত হ'ব।</p>"
        },
        "27": {
            "verses": {
                "75:27": {
                    "id": 27
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু মানুহে পৰস্পৰে কবঃ কোনে ইয়াৰ নিৰাময়ৰ বাবে জৰা- ফুকা কৰিব।</p>"
        },
        "28": {
            "verses": {
                "75:28": {
                    "id": 28
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু মুমূৰ্ষু ব্যক্তিৰ বিশ্বাস হৈ যাব যে, এয়া পৃথিৱীৰ পৰা চিৰ বিদায়ৰ সময়।</p>"
        },
        "29": {
            "verses": {
                "75:29": {
                    "id": 29
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু পৃথিৱীৰ অন্ত আৰু পৰকালৰ সূচনাৰ এই মূহুৰ্তত বহুতো কঠিনতা একত্ৰিত হৈ যাব।</p>"
        },
        "30": {
            "verses": {
                "75:30": {
                    "id": 30
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>এইবোৰ হোৱাৰ পিছত, মৃত ব্যক্তিক আল্লাহৰ ফালে লৈ যোৱা হ'ব।</h2>"
        },
        "31": {
            "verses": {
                "75:31": {
                    "id": 31
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এতেকে কাফিৰ বিলাকে কেৱল ৰাছুল চাল্লাল্লাহু আলাইহি অছাল্লামক অস্বীকাৰ কৰাই নহয় বৰং পৱিত্ৰ আল্লাহৰ ছালাতো আদায় কৰা নাছিল।</p>"
        },
        "32": {
            "verses": {
                "75:32": {
                    "id": 32
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>বৰং সি ৰাছুলে আনা সংবাদ সমূহ অস্বীকাৰ কৰিছে আৰু তাৰ পৰা মুখ ঘূৰাই লৈছে।</p>"
        },
        "33": {
            "verses": {
                "75:33": {
                    "id": 33
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ পিছত এই কাফিৰ অহংকাৰ কৰি উদ্ধত অৱস্থাত নিজৰ পৰিয়ালৰ ওচৰত গৈছিল।</p>"
        },
        "34": {
            "verses": {
                "75:34": {
                    "id": 34
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>গতিকে আল্লাহে কাফিৰক ধমক দি কৈছে যে, আল্লাহৰ শাস্তি তাৰ নিকটৱৰ্তী হৈছে।</p>"
        },
        "35": {
            "verses": {
                "75:35": {
                    "id": 35
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ পিছত আল্লাহে এই বাক্য গুৰুত্ব দিয়াৰ বাবে দুহাৰিছে। সেয়ে কৈছেঃ (আকৌ দুৰ্ভোগ তোমাৰ বাবে আৰু দুৰ্ভোগ।)</p>"
        },
        "36": {
            "verses": {
                "75:36": {
                    "id": 36
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>মানুহে ভাবিছে নেকি যে, আল্লাহে তাক চৰীয়তৰ অনুসাৰী নবনোৱাকৈ সোধাই এৰি দিব?</p>"
        },
        "37": {
            "verses": {
                "75:37": {
                    "id": 37
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>মানুহ এটা সময়ত মাকৰ গৰ্ভাশয়ত স্খলিত হোৱা বীৰ্যৰ শুক্ৰানুবিন্দু নাছিল নে?</p>"
        },
        "38": {
            "verses": {
                "75:38": {
                    "id": 38
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ পিছত সেইটো ৰক্তপিণ্ডত পৰিণত হয়। তাৰ পিছত আল্লাহে তাক সৃষ্টি কৰে আৰু সুঠাম আৰু সম্পূৰ্ণ মানুহ বনায়।</p>"
        },
        "39": {
            "verses": {
                "75:39": {
                    "id": 39
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>তাৰ পৰা তেওঁ যোৰ যোৰ হিচাপে নৰ-নাৰী বনায়।</h2>"
        },
        "40": {
            "verses": {
                "75:40": {
                    "id": 40
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যিয়ে মানুহক এটোপাল বীৰ্যৰ পৰা, তাৰ পিছত ৰক্তপিণ্ডৰ পৰা সৃষ্টি কৰিছে তেওঁ মৃত লোকক হিচাপ-নিকাচ আৰু পৰিণাম বা প্ৰতিদানৰ বাবে জীৱিত কৰাৰ ক্ষমতা নাইনে? কিয় নহয়, নিশ্চয় তেওঁৰ এই ক্ষমতা আছে।</p>"
        }
    }
}