            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে ৰাছুল, আমি আপোনাক প্ৰচুৰ কল্যাণ প্ৰদান কৰিছো। তাৰ মাজৰ এটা অন্যতম হৈছে জান্নাতৰ নদী আল-কাউছাৰ।</p>"
        },
        "2": {
            "verses": {
                "108:2": {
                    "id": 2
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>গতিকে এই অনুগ্ৰহ বা অৱদানৰ প্ৰতি আল্লাহৰ কৃতজ্ঞতা পালন কৰি কেৱল তাৰ বাবেই ছালাত আদায় কৰক আৰু কোৰবানী কৰক। যিহেতু সাধাৰণ মুশ্বৰিক সকলৰ অৱস্থা হৈছে সিহঁতৰ মূৰ্তিবোৰৰ বাবে কুৰবানী বা জন্তু বলিদান কৰি সিহঁতৰ নৈকট্য লাভ কৰাত উঠি পৰি লাগি থাকে।</p>"
        },
        "3": {
            "verses": {
