{
    "chapter": 83,
    "verses": {
        "1": {
            "verses": {
                "83:1": {
                    "id": 1
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>জোখ-মাখত কম দিয়া সকলৰ বাবে ধ্বংস আৰু ক্ষতি আছে।</h2>"
        },
        "2": {
            "verses": {
                "83:2": {
                    "id": 2
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু যিহঁতে লোৱাৰ সময়ত সঠিক জোখ- মাখ কৰি লয়। অলপো কম নলয়।</h2>"
        },
        "3": {
            "verses": {
                "83:3": {
                    "id": 3
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যেতিয়া মানুহক দিয়ে তেতিয়া জোখ-মাখত কমকৈ দিয়ে। আচলতে ৰাছুল চাল্লাল্লাহু আলাইহি অছল্লামে যেতিয়া মদিনালৈ হিজৰত কৰিছিল তেতিয়া মদীনাবাসীৰ এনেকুৱা অৱস্থা আছিল।</p>"
        },
        "4": {
            "verses": {
                "83:4": {
                    "id": 4
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এনেকুৱা কু-কৰ্মী সকলে পুনৰ জীৱিত হৈ আল্লাহৰ আগত থিয় হব লাগিব বুলি বিশ্বাস নকৰে নেকি?</p>"
        },
        "5": {
            "verses": {
                "83:5": {
                    "id": 5
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হিচাপ- নিকাচ আৰু পৰিণামৰ দিৱসটো হৈছে এক মহাদিৱস, কিয়নো তাত কঠিন পৰীক্ষা আৰু ভয়াৱহ পৰিস্থিতিৰে পাৰ হব লাগিব।</p>"
        },
        "6": {
            "verses": {
                "83:6": {
                    "id": 6
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিদিনাখন সকলো সৃষ্টিয়ে হিচাপ- নিকাচৰ বাবে আল্লাহৰ আগত থিয় হব।</p>"
        },
        "7": {
            "verses": {
                "83:7": {
                    "id": 7
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>বিষয়টো তেনেকুৱা নহয় যিদৰে তোমালোকে ভাবিছা যে, মৃত্যুৰ পিছত জীৱিত হব নালাগিব। নিশ্চয় কাফিৰ আৰু মুনাফিক সকলৰ দৰে কু- কৰ্মী সকলৰ কৰ্ম পত্ৰ নিম্নভূমিৰ সংকীৰ্ণ স্থানত আছে।</p>"
        },
        "8": {
            "verses": {
                "83:8": {
                    "id": 8
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>হে ৰাছুল ! আপোনাক কিহে জনাব যে, ছিজ্জীন কি?</h2>"
        },
        "9": {
            "verses": {
                "83:9": {
                    "id": 9
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিহঁতৰ কৰ্ম পত্ৰ এনেদৰে লিখা হব যে সেয়া কেতিয়াও মচি নাযাব আৰু তাৰ ভিতৰত কোনো ধৰণৰ কম-বেছি নহব।</p>"
        },
        "10": {
            "verses": {
                "83:10": {
                    "id": 10
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>সিদিনাখন অস্বীকাৰকাৰী সকলৰ বাবে আছে ক্ষতি আৰু ধ্বংস।</h2>"
        },
        "11": {
            "verses": {
                "83:11": {
                    "id": 11
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যিহঁতে পৰিণামৰ দিন অস্বীকাৰ কৰে, যিদিনা আল্লাহ তাআলাই তাৰ বান্দাসকলক সিহঁতে কৰা কৰ্মৰ প্ৰতিদান দিব।</p>"
        },
        "12": {
            "verses": {
                "83:12": {
                    "id": 12
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু সেই দিৱসটোক কেৱল সিহঁতেই অস্বীকাৰ কৰে, যিসকল আল্লাহৰ সীমালংঘনকাৰী আৰু অতি পাপী ব্যক্তি।</p>"
        },
        "13": {
            "verses": {
                "83:13": {
                    "id": 13
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যেতিয়া তেওঁলোকৰ আগত ৰাছুলৰ প্ৰতি প্ৰেৰিত আয়াতবোৰ পাঠ কৰা হয়, তেতিয়া সিহঁতে কয়ঃ এয়া বিগত সমুদায়ৰ কল্প-কাহানী, আল্লাহৰ পক্ষৰ পৰা অৱতীৰ্ণ নহয়।</p>"
        },
        "14": {
            "verses": {
                "83:14": {
                    "id": 14
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>বিষয়টো তেনেকুৱা নহয় যিদৰে এই অস্বীকাৰকাৰী সকলে ভাবিছে। বৰঞ্চ সত্য কথা হৈছে এওঁলোকৰ বিবেকৰ ওপৰত কু-কৰ্মৰ আৱৰণ পৰিছে। গতিকে এওঁলোকে অন্তৰেৰে সত্যৰ পৰ্যবেক্ষণ কৰিব নোৱাৰে।</p>"
        },
        "15": {
            "verses": {
                "83:15": {
                    "id": 15
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এয়া সত্য যে, সিহঁতক ক্বিয়ামতৰ দিনা নিজ প্ৰতিপালকৰ দৰ্শনৰ পৰা বঞ্চিত কৰা হব।</p>"
        },
        "16": {
            "verses": {
                "83:16": {
                    "id": 16
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু সিহঁত জাহান্নামত প্ৰবেশ কৰি তাৰ উত্তাপৰ সন্মুখীন হব।</h2>"
        },
        "17": {
            "verses": {
                "83:17": {
                    "id": 17
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ পিছত ক্বিয়ামতৰ দিনা সিহঁতক ধমক দি কোৱা হবঃ এতিয়া তোমালোকে যি শাস্তি ভোগ কৰি আছা এইটো সেই শাস্তি যিটো পৃথিৱীত তোমালোকৰ ৰাছুলে তোমালোকক অৱগত কৰিছিল কিন্তু তোমালোকে তাক অস্বীকাৰ কৰিছিলা।</p>"
        },
        "18": {
            "verses": {
                "83:18": {
                    "id": 18
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>বিষয়টো তেনেকুৱা নহয় যিদৰে তোমালোকে ভাবিছা যে, হিচাপ- নিকাচ আৰু প্ৰতিদান একোৱেই নাই। নিশ্চয় সৎ লোকৰ কৰ্মপত্ৰ ইল্লিয়্যীনত আছে।</p>"
        },
        "19": {
            "verses": {
                "83:19": {
                    "id": 19
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>হে ৰাছুল ! আপোনাক কিহে জনাব যে, ইল্লিয়্যীন কি?</h2>"
        },
        "20": {
            "verses": {
                "83:20": {
                    "id": 20
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিহঁতৰ কৰ্ম পত্ৰ এনেদৰে লিখা হব যে সেয়া কেতিয়াও মচি নাযাব আৰু তাৰ ভিতৰত কোনো ধৰণৰ কম-বেছি নহব।</p>"
        },
        "21": {
            "verses": {
                "83:21": {
                    "id": 21
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এই কৰ্ম পত্ৰৰ ওচৰত প্ৰত্যেক আকাশৰ নিকটৱৰ্তী ফিৰিস্তা উপস্থিত থাকে।</p>"
        },
        "22": {
            "verses": {
                "83:22": {
                    "id": 22
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>নিশ্চয় অধিক আনুগত্যকাৰী সকলে ক্বিয়ামতৰ দিনা এনেকুৱা নিয়ামতৰ মাজত থাকিব যিটো হব চিৰস্থায়ী।</p>"
        },
        "23": {
            "verses": {
                "83:23": {
                    "id": 23
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সুসজ্জিত আসনত বহি তেওঁলোকৰ প্ৰতিপালক তথা সকলো বস্তুৰ ফালে চাই থাকিব যিবোৰে তেওঁলোকৰ মন জয় কৰিব।</p>"
        },
        "24": {
            "verses": {
                "83:24": {
                    "id": 24
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আপুনি যেতিয়া তেওঁলোকক দেখিবলৈ পাব, তেতিয়া তেওঁলোকৰ মুখমণ্ডলৰ সৌন্দৰ্য আৰু সতেজ দেখিয়েই আপুনি তেওঁলোকৰ জীৱন আনন্দময় হোৱাৰ অনুমান কৰিব পাৰিব।</p>"
        },
        "25": {
            "verses": {
                "83:25": {
                    "id": 25
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেওঁলোকক তেওঁলোকৰ সেৱকে মোহৰ মাৰি থোৱা বিশুদ্ধ পানীয় সেৱন কৰাব।</p>"
        },
        "26": {
            "verses": {
                "83:26": {
                    "id": 26
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ পৰা অন্তলৈকে মিছক বা কস্তুৰিৰ সুগন্ধি আহি থাকিব। এই মহত্বপূৰ্ণ পৰিণামৰ বাবে প্ৰতিযোগীতাৰ ইচ্ছুক সকলে প্ৰতিযোগীতাৰ বাবে প্ৰয়াস কৰিব লাগে। গতিকে এনেকুৱা কাম কৰিব লাগে যাৰ প্ৰতি আল্লাহ তাআলাই সন্তুষ্ট হয় আৰু এনেকুৱা কামৰ পৰা বিৰত থাকিব লাগে যাৰ প্ৰতি আল্লাহ তাআলাই অসন্তুষ্ট হয়।</p>"
        },
        "27": {
            "verses": {
                "83:27": {
                    "id": 27
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু এই মোহৰাবদ্ধ পানীয়ৰ লগত তাছনীম নিজৰাৰ পানী মিশ্ৰিত হব।</h2>"
        },
        "28": {
            "verses": {
                "83:28": {
                    "id": 28
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
