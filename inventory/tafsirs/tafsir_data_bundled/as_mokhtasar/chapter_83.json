            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এইটো জান্নাতত থকা আটাইতকৈ উচ্চ স্থানৰ এটা নিজৰা। যাৰ বিশুদ্ধ পানী আল্লাহৰ নিকটৱৰ্তী বান্দাসকলে সেৱন কৰিব। যিহেতু অন্য সকলো ঈমানদাৰে তাৰ মিশ্ৰিত পানী সেৱন কৰিব।</p>"
        },
        "29": {
            "verses": {
                "83:29": {
                    "id": 29
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
