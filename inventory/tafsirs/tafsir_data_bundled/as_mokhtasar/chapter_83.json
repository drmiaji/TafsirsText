            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যেতিয়া মুমিনসকলৰ ওচৰেদি গৈছিল তেতিয়া ঠাট্টা আৰু উপহাস স্বৰূপে পৰস্পৰে চকু টিপি ইংগিত দিছিল।</p>"
        },
        "31": {
            "verses": {
                "83:31": {
                    "id": 31
                }
