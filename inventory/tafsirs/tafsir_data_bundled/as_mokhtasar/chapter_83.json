            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>নিশ্চয় যিহঁতে কুফুৰীৰ পথত অটুট থাকি অপৰাধ কৰিছে সিহঁতে মুমিনসলক ঠাট্টা কৰি উপহাস কৰিছিল।</p>"
        },
        "30": {
            "verses": {
                "83:30": {
                    "id": 30
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
