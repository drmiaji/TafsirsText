{
    "chapter": 70,
    "verses": {
        "1": {
            "verses": {
                "70:1": {
                    "id": 1
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>মুশ্বৰিক বিলাকৰ মাজৰ এজন ব্যক্তিয়ে স্বয়ং নিজৰ বাবে আৰু নিজ জাতিৰ বিৰুদ্ধে উপহাস স্বৰূপে শাস্তি বিচাৰিছিল। অথচ সেই শাস্তি ক্বিয়ামতৰ দিনা আহিবই।</p>"
        },
        "2": {
            "verses": {
                "70:2": {
                    "id": 2
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আল্লাহক অস্বীকাৰকাৰী বিলাকৰ বাবে। এই শাস্তি কোনেও দূৰ কৰিব নোৱাৰে।</p>"
        },
        "3": {
            "verses": {
                "70:3": {
                    "id": 3
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আল্লাহৰ তৰফৰ পৰা, যিয়ে উচ্চতা, পদ মৰ্যদা, উত্কৃষ্টতাৰে বিশেষিত আৰু অনুগ্ৰহৰ গৰাকী।</p>"
        },
        "4": {
            "verses": {
                "70:4": {
                    "id": 4
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যাৰ ফালে ফিৰিস্তা আৰু জিব্ৰীল আলাইহিছ ছালামে সেই স্তৰ সমূহৰ মাধ্যমেৰে ক্বিয়ামতৰ দিনা উঠিব। যিটো বহুত দীঘল দিন হ’ব, যাৰ পৰিমাণ পঞ্চাছ হাজাৰ বছৰ হ’ব।</p>"
        },
        "5": {
            "verses": {
                "70:5": {
                    "id": 5
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে ৰাছুল, আপুনি ধৈৰ্য ধাৰণ কৰক। হতাশ নহব আৰু মুখেৰে অভিযোগমূলক কোনো শব্দ নুলিয়াব।</p>"
        },
        "6": {
            "verses": {
                "70:6": {
                    "id": 6
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>সিহঁতে এই শাস্তিক বহুত দূৰত তথা অসম্ভৱ বুলি ভাবে।</h2>"
        },
        "7": {
            "verses": {
                "70:7": {
                    "id": 7
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু আমি ইয়াক নিচেই ওচৰত তথা নিশ্চিতৰূপে চাই আছো।</h2>"
        },
        "8": {
            "verses": {
                "70:8": {
                    "id": 8
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>যিদিনা আকাশ গলিত তাম, সোণ আদিৰ দৰে হ’ব।</h2>"
        },
        "9": {
            "verses": {
                "70:9": {
                    "id": 9
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু পাহাৰবোৰ শূন্যত উৰি থকা কপাহৰ দৰে পাতল হ’ব।</h2>"
        },
        "10": {
            "verses": {
                "70:10": {
                    "id": 10
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু কোনো নিকটৱৰ্তী বন্ধুৱে নিকটৱৰ্তী বন্ধুৰ খবৰ নলব। কিয়নো প্ৰত্যেক ব্যক্তি নিজৰ বাবে ব্যস্ত থাকিব।</p>"
        },
        "11": {
            "verses": {
                "70:11": {
                    "id": 11
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>প্ৰত্যেকে নিজৰ ওচৰ সম্বন্ধ আৰু বন্ধুক দেখিব আৰু কোনেও কাৰো পৰা গোপন নাথাকিব। ইয়াৰোপৰি পৰিস্থিতি ইমান ভয়াৱহ হ’ব যে, কোনেও কাকো সোধ-পোচ কৰাৰ সময় নাপাব। তথা যিয়ে জাহান্নামৰ অধিকাৰী হ’ব, সি নিজৰ পৰিৱৰ্তে নিজ সন্তানক শাস্তিৰ বাবে দিব বিচাৰিব।</p>"
        },
        "12": {
            "verses": {
                "70:12": {
                    "id": 12
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু তাৰ স্ত্ৰী তথা ভাতৃক শাস্তিৰ বিনিময়ত দিব বিচাৰিব।</h2>"
        },
        "13": {
            "verses": {
                "70:13": {
                    "id": 13
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু তাৰ নিকটৱৰ্তী আত্মীয় স্বজনক শাস্তিৰ পৰিবৰ্তে দিব বিচাৰিব। যিয়ে কঠিন পৰিস্থিতিত তাৰ লগত থিয় দিছিল।</p>"
        },
        "14": {
            "verses": {
                "70:14": {
                    "id": 14
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু পৃথিৱীত থকা মানুহ, জিন আদিক শাস্তিৰ বিনিময়ত দিব বিচাৰিব যাতে ইয়াৰ বিনিময়ত সি শাস্তিৰ পৰা ৰক্ষা পায় আৰু জাহান্নামৰ শাস্তিৰ পৰা মু্ক্তি প্ৰদান কৰে।</p>"
        },
        "15": {
            "verses": {
                "70:15": {
                    "id": 15
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ঘটনা তেনে নহয় যিদৰে এই অপৰাধীবিলাকে কামনা কৰে। এইটো জাহান্নামৰ লেলিহান জুই।</p>"
        },
        "16": {
            "verses": {
                "70:16": {
                    "id": 16
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>যাৰ তাপে মূৰৰ ছাল খহাই পেলাব।</h2>"
        },
        "17": {
            "verses": {
                "70:17": {
                    "id": 17
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>জাহান্নামে তাক মাতিব যিয়ে সত্যৰ প্ৰতি পৃষ্ঠ প্ৰদৰ্শন কৰিছিল আৰু মুখ ঘূৰাই আঁতৰি গৈছিল। সত্যক মানি লোৱা নাছিল আৰু তাৰ প্ৰতি আমলো কৰা নাছিল।</p>"
        },
        "18": {
            "verses": {
                "70:18": {
                    "id": 18
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু ধন সঞ্চয় কৰিছিল আৰু তাৰ পৰা আল্লাহৰ পথত ব্যয় কৰাত কৃপণালি কৰিছিল।</p>"
        },
        "19": {
            "verses": {
                "70:19": {
                    "id": 19
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>নিশ্চয় মানুহক অতি লোভী হিচাপে সৃষ্টি কৰা হৈছে।</h2>"
        },
        "20": {
            "verses": {
                "70:20": {
                    "id": 20
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যেতিয়া বেমাৰ বা দৰিদ্ৰতা আদিৰ ৰূপত কোনো দুখ পায়, তেতিয়া অধৈৰ্যশীল হৈ পৰে।</p>"
        },
        "21": {
            "verses": {
                "70:21": {
                    "id": 21
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যেতিয়া স্বচল আৰু ধনী ৰূপে কোনো আনন্দময় বস্তু পায়, তেতিয়া আল্লাহৰ পথত খৰচ কৰিবলৈ কৃপণালী কৰে।</p>"
        },
        "22": {
            "verses": {
                "70:22": {
                    "id": 22
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>কিন্তু ছালাত আদায়কাৰী সকলৰ বাহিৰে। এতেকে তেওঁলোক এই কু আচৰণৰ পৰা সুৰক্ষিত।</p>"
        },
        "23": {
            "verses": {
                "70:23": {
                    "id": 23
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যিসকলে নিয়মিত ছালাত আদায় কৰে। কেতিয়াও তাৰ প্ৰতি অৱহেলা নকৰে। তেওঁলোকে সদায় সেয়া নিৰ্ধাৰিত সময়তে আদায় কৰে।</p>"
        },
        "24": {
            "verses": {
                "70:24": {
                    "id": 24
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু যিসকলৰ ধন- সম্পদত অনিবাৰ্য আৰু নিশ্চিত ভাগ আছে।</h2>"
        },
        "25": {
            "verses": {
                "70:25": {
                    "id": 25
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যিটো তেওঁ মগনীয়াক দি দিয়ে আৰু তাকো দিয়ে যিয়ে কোনো কাৰণ বশতঃ ধনৰ পৰ বঞ্চিত বা নিৰ্ধন হৈছে।</p>"
        },
        "26": {
            "verses": {
                "70:26": {
                    "id": 26
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যিয়ে ক্বিয়ামতৰ দিনক সত্য বুলি মানে। যিদিনাখন প্ৰত্যেক ব্যক্তিক আল্লাহে সেই পৰিণাম দিব যাৰ তেওঁ অধীকাৰী বা হক্বদাৰ।</p>"
        },
        "27": {
            "verses": {
                "70:27": {
                    "id": 27
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যিয়ে নিজ প্ৰতিপালকৰ শাস্তিক ভয় কৰে। লগতে তেওঁ সত্কৰ্মও কৰে।</p>"
        },
        "28": {
            "verses": {
                "70:28": {
                    "id": 28
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>নিশ্চয় তেওঁলোকৰ প্ৰতিপালকৰ শাস্তি ভয়াৱহ। কোনো জ্ঞানী ব্যক্তি তেওঁৰ শাস্তিৰ পৰা নিশ্চিন্তিত হব নোৱাৰে।</p>"
        },
        "29": {
            "verses": {
                "70:29": {
                    "id": 29
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যিসকলে নিজৰ যৌনাঙ্গসমূহৰ হিফাজত কৰে। সেয়া উলঙ্গ কৰাৰ পৰা বিৰত থাকে আৰু নিৰ্লজ্জতাৰ কৰ্মবোৰৰ পৰা বিৰত থাকে।</p>"
        },
        "30": {
            "verses": {
                "70:30": {
                    "id": 30
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>কিন্তু সিহঁতৰ পত্নী আৰু অধিকাৰভুক্ত দাসীৰ বাহিৰে। কিয়নো সিহঁতৰ সৈতে মিলনৰ মাধ্যমত উপকৃত হোৱা কোনো নিন্দনীয় বিষয় নহয়।</p>"
        },
        "31": {
            "verses": {
                "70:31": {
                    "id": 31
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এতেকে যিসকলে নিজ স্ত্ৰী আৰু অধিকাৰভুক্ত দাসীৰ বাহিৰে আন কাৰোবাৰ সৈতে মনোকামনা পূৰণ কৰিব বিচাৰে বা লাভান্বিত হব বিচাৰে, তেন্তে সিহঁতেই আল্লাহৰ সীমালঙ্ঘনকাৰী।</p>"
        },
        "32": {
            "verses": {
                "70:32": {
                    "id": 32
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যিসকলে ধন- সম্পদ, গোপন কথা, প্ৰতিশ্ৰুতি আদি আমানত ৰক্ষা কৰে। লগতে মানুহৰ লগত কৰা প্ৰতিশ্ৰুতি ৰক্ষা কৰে। আমানতৰ খিয়ানত বা বিৰুদ্ধাচৰণ নকৰে আৰু প্ৰতিশ্ৰুতিও ভংগ নকৰে।</p>"
        },
        "33": {
            "verses": {
                "70:33": {
                    "id": 33
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যিসকলে সঠিকৰূপে নিজৰ সাক্ষ্যদানত অটল থাকে। যাৰ সাক্ষ্যদানত কোনো আত্মীয়-স্বজন তথা শত্ৰুৰ প্ৰভাৱ নপৰে।</p>"
        },
        "34": {
            "verses": {
                "70:34": {
                    "id": 34
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যিসকলে নিজৰ ছালাতৰ হিফাজত কৰে, আৰু সময় মতে আদায় কৰে। পৱিত্ৰতাৰ প্ৰতি পৰিপূৰ্ণ মনোযোগ দিয়ে। ধৈৰ্য আৰু শান্তিপূৰ্ণভাৱে আদায় কৰে। কোনো বস্তুৱেই তেওঁলোকক ছালাতৰ প্ৰতি অৱহেলা, ব্যস্ততা বা অমনোযোগী কৰিব নোৱাৰে।</p>"
        },
        "35": {
            "verses": {
                "70:35": {
                    "id": 35
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এইবোৰ বৈশিষ্ট্যৰ অধিকাৰী ব্যক্তিসকলক জান্নাতত সন্মানিত হৈ থাকিব। কিয়নো তেওঁলোকে চিৰস্থায়ী অনুগ্ৰহসমূহ প্ৰাপ্ত হব। আৰু আল্লাহৰ চেহেৰা বা মুখ মণ্ডল চাবলৈ সৌভাগ্য প্ৰাপ্ত হ’ব।</p>"
        },
        "36": {
            "verses": {
                "70:36": {
                    "id": 36
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে ৰাছুল, আপোনাৰ সম্প্ৰদায়ৰ এই মুশ্বৰিক বিলাকক কিহে টানি আনিছে যে, সিহঁতে আপোনাৰ ফালে দৌৰি আহি আছে। আপোনাক অস্বীকাৰ কৰিবলৈ?</p>"
        },
        "37": {
            "verses": {
                "70:37": {
                    "id": 37
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিহঁতে সোঁ ফালৰ পৰা আৰু বাওঁ ফালৰ পৰা দলে দলে আহি আপোনাক আৱৰি ধৰিছে।</p>"
        },
        "38": {
            "verses": {
                "70:38": {
                    "id": 38
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিহঁতৰ প্ৰত্যেকেই এই আশা কৰে নেকি যে, আল্লাহ তাআলাই সিহঁতক কুফুৰীৰ প্ৰতি অটুট থকাৰ পাছতো অনুগ্ৰহমূলক জান্নাতত প্ৰৱেশ কৰাব আৰু সিহঁতে তাৰ ভিতৰত চিৰস্থায়ী অনুগ্ৰহসমূহৰ দ্বাৰা লাভান্বিত হ’ব?</p>"
        },
        "39": {
            "verses": {
                "70:39": {
                    "id": 39
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>বিষয়টো তেনেকুৱা নহয় যিদৰে সিহঁতে ভাবিছে। আমি সিহঁতক যিটোৰে সৃষ্টি কৰিছো সেইটো সিহঁতে জানে। কিয়নো আমি সিহঁতক তুচ্ছ পানীৰে সৃষ্টি কৰিছো। গতিকে সিহঁত অতি দূৰ্বল। নিজৰ লাভ- ক্ষতিৰো গৰাকী নহয়। গতিকে সিহঁতে গৌৰৱ কেনেকৈ কৰে?</p>"
        },
        "40": {
            "verses": {
                "70:40": {
                    "id": 40
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আল্লাহে স্বয়ং নিজৰেই শপত খাইছে, সূৰ্য আৰু চন্দ্ৰৰ উদয়স্থলসমূহ আৰু অস্তাচলসমূহৰ তেৱেঁই প্ৰতিপালক, আৰু গোটেই তাৰকাৰাজিৰ প্ৰতিপালক। (এইবোৰৰ শপত খাই তেওঁ কৈছে) নিশ্চয় আমি সক্ষম।</p>"
        },
        "41": {
            "verses": {
                "70:41": {
                    "id": 41
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>কথা হল, সিহঁতক ধংস কৰি সিহঁতৰ পৰিৱৰ্তে এনেকুৱা মানুহক আনিব যিসকলে আল্লাহৰ আনুগত্য কৰিব। আৰু যেতিয়া ইচ্ছা কৰিম ধংস কৰি দিম আৰু ইহঁতৰ পৰিৱৰ্তে অন্য লোকক আনিম। এই বিষয়ে আমি অক্ষম নহয়।</p>"
        },
        "42": {
            "verses": {
                "70:42": {
                    "id": 42
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>গতিকে হে ৰাছুল, আপুনি সিহঁতক এৰি দিয়ক, সিহঁতে ক্বিয়ামতলৈকে অসত্য আৰু পথভ্ৰষ্টতাত লিপ্ত হৈ থাকক আৰু সাংসাৰিক জীৱনত খেলি থাকক। যাৰ প্ৰতিশ্ৰুতি সিহঁতক কোৰআনত দিয়া হৈছিল।</p>"
        },
        "43": {
            "verses": {
                "70:43": {
                    "id": 43
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যিদিনাখন সিহঁতে কবৰৰ পৰা এনেদৰে তীব্ৰ গতিত দৌৰি ওলাব যেন পৰস্পৰে দৌৰ প্ৰতিযোগীতা কৰি আছে।</p>"
        },
        "44": {
            "verses": {
                "70:44": {
                    "id": 44
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিহঁতৰ দৃষ্টিসমূহ অৱনত অৱস্থাত থাকিব। লজ্জাই সিহঁতক আৱৰি ধৰিব। এইটো সেই দিন যাৰ কথা সিহঁতক পৃথিৱীত দিয়া হৈছিল আৰু সিহঁতে তাৰ প্ৰতি অলপো ধ্যান দিয়া নাছিল।</p>"
        }
    }
}