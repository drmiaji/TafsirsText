{
    "chapter": 55,
    "verses": {
        "1": {
            "verses": {
                "55:1": {
                    "id": 1
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>কৰুণাময়, যিজন প্রশস্ত দয়াৰ অধিকাৰী।</h2>"
        },
        "2": {
            "verses": {
                "55:2": {
                    "id": 2
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেৱেঁই মানুহৰ বাবে সহজ কৰি দিছে কোৰআন মুখস্থ কৰা আৰু ইয়াৰ অর্থ অনুধাৱন কৰা।</p>"
        },
        "3": {
            "verses": {
                "55:3": {
                    "id": 3
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেৱেঁই মানুহক পূর্ণাঙ্গ ৰূপে আৰু অতি সুন্দৰ সৌষ্ঠৱত সৃষ্টি কৰিছে।</p>"
        },
        "4": {
            "verses": {
                "55:4": {
                    "id": 4
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেৱেঁই মানুহক কথা আৰু লিখাৰ মাধ্যমত মনৰ ভাৱ প্রকাশ কৰাৰ পদ্ধতি শিকাইছে।</p>"
        },
        "5": {
            "verses": {
                "55:5": {
                    "id": 5
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেৱেঁই সূর্য্য আৰু চন্দ্রক নির্ধাৰণ কৰিছে। উভয়ে নিপুণভাৱে পৰিচালিত। যাতে মানুহে বছৰৰ সংখ্যা আৰু হিচাপ ৰাখিব পাৰে।</p>"
        },
        "6": {
            "verses": {
                "55:6": {
                    "id": 6
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>কাণ্ডহীন তৃণলতা আৰু বৃক্ষৰাজি উভয়েই মহান আল্লাহৰ উদ্দেশ্যে অনুগত আৰু অবনমিত হৈ ছাজদাহ কৰে।</p>"
        },
        "7": {
            "verses": {
                "55:7": {
                    "id": 7
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেৱেঁই আকাশক পৃথিৱীৰ ওপৰত চাদ হিচাপে উত্থিত কৰিছে। লগতে পৃথিৱীত ন্যায় বিচাৰ স্থাপন কৰিছে আৰু বান্দাসকলক এই বিষয়ে নির্দেশও দিছে।</p>"
        },
        "8": {
            "verses": {
                "55:8": {
                    "id": 8
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেওঁ ন্যায় বিচাৰ স্থাপন কৰিছে এইকাৰণে যে, হে মানৱ সমাজ! যাতে তোমালোকে অবিচাৰ কৰিব নোৱাৰা। লগতে যাতে ওজন আৰু মাপত তোমালোকে খিয়ানত কৰিব নোৱাৰা।</p>"
        },
        "9": {
            "verses": {
                "55:9": {
                    "id": 9
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তোমালোকে পৰস্পৰৰ মাজত ওজন কৰি দিয়াৰ সময়ত ন্যায় প্ৰতিষ্ঠা কৰিবা, আনক ওজন কৰি দিওঁতে কমকৈ নিদিবা।</p>"
        },
        "10": {
            "verses": {
                "55:10": {
                    "id": 10
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেৱেঁই সৃষ্টিৰ স্থিৰতাৰ উদ্দেশ্যে পৃথিৱীক বসবাস উপযোগী হিচাপে স্থাপন কৰিছে।</p>"
        },
        "11": {
            "verses": {
                "55:11": {
                    "id": 11
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>য’ত আছে ফলদায়ক বৃক্ষৰাজি আৰু শাখা বিশিষ্ট খেজুৰ গছ, য’ত জোকা জোকা খেজুৰ ফলে।</p>"
        },
        "12": {
            "verses": {
                "55:12": {
                    "id": 12
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>লগতে তাত আছে বাকলিযুক্ত শস্য যেনেঃ গম আৰু জৱ আদি, আৰু আছে সুগন্ধিযুক্ত তৃণলতা।</p>"
        },
        "13": {
            "verses": {
                "55:13": {
                    "id": 13
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে মানৱ ও জিন জাতি! তোমালোকৰ ওপৰত আল্লাহৰ অসংখ্য অনুগ্ৰহ আছে, তাৰে কোনটো কোনটো অস্বীকাৰ কৰিবা?</p>"
        },
        "14": {
            "verses": {
                "55:14": {
                    "id": 14
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেৱেঁই আদম (আলাইহিচ্ছালাম)ক পোৰা মাটি সদৃশ ঠনঠনীয়া শুকান মাটিৰে সৃষ্টি কৰিছে।</p>"
        },
        "15": {
            "verses": {
                "55:15": {
                    "id": 15
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু জিনসকলৰ পিতাক ধোঁৱাবিহীন লেলিহান অগ্নিশিখাৰে সৃষ্টি কৰিছে।</p>"
        },
        "16": {
            "verses": {
                "55:16": {
                    "id": 16
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে মানৱ ও জিন জাতি! তোমালোকৰ ওপৰত আল্লাহৰ অসংখ্য অনুগ্ৰহ আছে, তাৰে কোনটো কোনটো অস্বীকাৰ কৰিবা?</p>"
        },
        "17": {
            "verses": {
                "55:17": {
                    "id": 17
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেৱেঁই শীত আৰু গ্রীষ্মকালত সূর্যৰ দুয়ো উদয়াচল আৰু দুয়ো অস্তাচলৰ প্ৰতিপালক।</p>"
        },
        "18": {
            "verses": {
                "55:18": {
                    "id": 18
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে মানৱ ও জিন জাতি! তোমালোকৰ ওপৰত আল্লাহৰ অসংখ্য অনুগ্ৰহ আছে, তাৰে কোনটো কোনটো অস্বীকাৰ কৰিবা?</p>"
        },
        "19": {
            "verses": {
                "55:19": {
                    "id": 19
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আল্লাহে মিঠা আৰু লুণীয়া উভয় সাগৰকে মিলিত কৰে, বাহ্যিক দৃষ্টিত মিশ্ৰিত দেখা যায়।</p>"
        },
        "20": {
            "verses": {
                "55:20": {
                    "id": 20
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>কিন্তু দুয়ো সাগৰৰ মাজত আছে এনেকুৱা এখন পর্দা, যিখনে পৰস্পৰক মিশ্ৰিত হ’বলৈ বাধা দিয়ে। ফলত পানীৰ মিঠা অংশ মিঠা থাকে আৰু লুণীয়া অংশ লুণীয়া হৈয়ে থাকে।</p>"
        },
        "21": {
            "verses": {
                "55:21": {
                    "id": 21
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে মানৱ ও জিন জাতি! তোমালোকৰ ওপৰত আল্লাহৰ অসংখ্য অনুগ্ৰহ আছে, তাৰে কোনটো কোনটো অস্বীকাৰ কৰিবা?</p>"
        },
        "22": {
            "verses": {
                "55:22": {
                    "id": 22
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>উভয় সাগৰৰ সঙ্গমস্থলত উৎপন্ন হয় সৰু-ডাঙৰ মুকুতা।</h2>"
        },
        "23": {
            "verses": {
                "55:23": {
                    "id": 23
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে মানৱ ও জিন জাতি! তোমালোকৰ ওপৰত আল্লাহৰ অসংখ্য অনুগ্ৰহ আছে, তাৰে কোনটো কোনটো অস্বীকাৰ কৰিবা?</p>"
        },
        "24": {
            "verses": {
                "55:24": {
                    "id": 24
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সাগৰৰ মাজত চলাচল কৰা পৰ্বত সদৃশ নৌযানবোৰ একমাত্ৰ পৱিত্ৰ আল্লাহৰেই নিয়ন্ত্ৰণাধীন।</p>"
        },
        "25": {
            "verses": {
                "55:25": {
                    "id": 25
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে মানৱ ও জিন জাতি! তোমালোকৰ ওপৰত আল্লাহৰ অসংখ্য অনুগ্ৰহ আছে, তাৰে কোনটো কোনটো অস্বীকাৰ কৰিবা?</p>"
        },
        "26": {
            "verses": {
                "55:26": {
                    "id": 26
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>ভূপৃষ্ঠত থকা সকলো জীৱ-জন্তু নিশ্চিতভাৱে ধ্বংসশীল।</h2>"
        },
        "27": {
            "verses": {
                "55:27": {
                    "id": 27
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে ৰাছুল! কেৱল আপোনাৰ প্ৰতিপালকৰ চেহেৰাই অৱশিষ্ট থাকিব। তেওঁ নিজ বান্দাসকলৰ ওপৰত মহিমাময় আৰু মহা অনুগ্রহশীল। ফলত তেওঁক কেতিয়াও ধ্বংসই স্পৰ্শ নকৰিব।</p>"
        },
        "28": {
            "verses": {
                "55:28": {
                    "id": 28
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
