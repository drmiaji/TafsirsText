{
    "chapter": 88,
    "verses": {
        "1": {
            "verses": {
                "88:1": {
                    "id": 1
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে নবী! আপোনাৰ ওচৰত সেই ক্বিয়ামতৰ খবৰ আহি পাইছেনে, যাৰ ভয় মানুহৰ প্ৰতি আৱৰি ধৰিব?</p>"
        },
        "2": {
            "verses": {
                "88:2": {
                    "id": 2
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ক্বিয়ামতৰ দিনা মানুহ দুই ভাগত বিভক্ত হব, সৌভাগ্যশালী আৰু দূৰ্ভাগ্যশালী। গতিকে দূৰ্ভাগ্যবান ব্যক্তিৰ মুখ মণ্ডল অপমানিত অৱনত থাকিব।</p>"
        },
        "3": {
            "verses": {
                "88:3": {
                    "id": 3
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেওঁলোকক যি হাতকড়ি আৰু শিকলীৰে বান্ধা হব তাক খুলিবলৈ চেষ্টা কৰি থাকোতে ক্লান্ত হৈ পৰিব।</p>"
        },
        "4": {
            "verses": {
                "88:4": {
                    "id": 4
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সেইবোৰ চেহেৰা উত্তপ্ত জুইত প্ৰৱেশ কৰি তাৰ প্ৰচণ্ড তাপৰ বেদনা ভোগ কৰিব।</p>"
        },
        "5": {
            "verses": {
                "88:5": {
                    "id": 5
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>সিহঁতক অতি উত্তপ্ত উতলা নিজৰাৰ পানী পান কৰিবলৈ দিব।</h2>"
        },
        "6": {
            "verses": {
                "88:6": {
                    "id": 6
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিহঁতৰ বাবে কাঁইটবিশিষ্ট খাদ্যৰ বাহিৰে আন কোনা বস্তু নাথাকিব। যিটো শুকাই গলে বিষাক্ত হয়। যাৰ নাম হৈছে শ্বিবৰিক্ব।</p>"
        },
        "7": {
            "verses": {
                "88:7": {
                    "id": 7
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সেয়া তাৰ ভক্ষণকাৰীক শকত হবলৈও নিদিয়ে আৰু ক্ষুধা নিবৃত্ত কৰিবলৈও নিদিয়ে।</p>"
        },
        "8": {
            "verses": {
                "88:8": {
                    "id": 8
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সেই দিনা সৌভাগ্যবান লোকৰ মুখমণ্ডলবোৰ আনন্দিত আৰু উত্ফুল্লিত হৈ পৰিব।</p>"
        },
        "9": {
            "verses": {
                "88:9": {
                    "id": 9
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেওঁলোকে পৃথিৱীত কৰা কৰ্মৰ প্ৰতি সন্তুষ্ট হব। কিয়নো তেওঁলোকে কৰ্মৰ প্ৰতিদান সঞ্চিত আৰু অধিক বৃদ্ধি অৱস্থাত দেখিবলৈ পাব।</p>"
        },
        "10": {
            "verses": {
                "88:10": {
                    "id": 10
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এনেকুৱা জান্নাতত থাকিব যিটো মৰ্যদা আৰু স্থানৰ ক্ষেত্ৰতো সুউচ্চ আৰু সন্মানিত।</p>"
        },
        "11": {
            "verses": {
                "88:11": {
                    "id": 11
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>জান্নাতত কোনোধৰণৰ বেয়া কথা, অনৰ্থক কথা আদি শুনিবলৈ নাপাব।</h2>"
        },
        "12": {
            "verses": {
                "88:12": {
                    "id": 12
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সেই জান্নাতত নিজৰা প্ৰবাহিত হব। তেওঁলোকে ইয়াক যিফালে ইচ্ছা কৰিব প্ৰবাহিত কৰাব পাৰিব।</p>"
        },
        "13": {
            "verses": {
                "88:13": {
                    "id": 13
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>তাত থাকিব ওখ ওখ সিংহাসন।</h2>"
        },
        "14": {
            "verses": {
                "88:14": {
                    "id": 14
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>পান কৰিবলৈ বহুতো পানপাত্ৰ প্ৰস্তুত থাকিব।</h2>"
        },
        "15": {
            "verses": {
                "88:15": {
                    "id": 15
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু গাৰুসমূহ শাৰী শাৰীকৈ ৰখা থাকিব।</h2>"
        },
        "16": {
            "verses": {
                "88:16": {
                    "id": 16
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু ইফালে-সিফালে পাৰি থোৱা হ'ব বহুতো দলিচা।</h2>"
        },
        "17": {
            "verses": {
                "88:17": {
                    "id": 17
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ইহঁতে উটক ধ্যানসহকাৰে নেদেখে নেকি যে, আল্লাহ তাআলাই কেনেকৈ ইয়াক সৃষ্টি কৰিছে আৰু আদম সন্তানৰ অধীন কৰিছে?</p>"
        },
        "18": {
            "verses": {
                "88:18": {
                    "id": 18
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু তেওঁলোকে আকাশলৈ নাচায় কিয়, কেনেকৈ তাক উৰ্দ্ধত স্থাপন কৰিছে, যিটোক তেওঁলোকৰ ওপৰত এটা সুৰক্ষিত চাদ হিচাপে স্থাপন কৰিছে, যিটো তেওঁলোকৰ ওপৰত খহি নপৰিব।</p>"
        },
        "19": {
            "verses": {
                "88:19": {
                    "id": 19
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু পাহাৰবোৰক দেখে নে যে, আল্লাহ তাআলাই সেইবোৰক কেনেকৈ প্ৰতিষ্ঠিত কৰিছে আৰু তাৰ দ্বাৰা পৃথিৱীখনক মজবুত কৰিছে যাতে মানুহক লৈ লৰচৰ কৰিব নোৱাৰে।</p>"
        },
        "20": {
            "verses": {
                "88:20": {
                    "id": 20
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু পৃথিৱীৰ ফালে দেখে নে, আল্লাহ তাআলাই ইয়াক কেনেকৈ বিস্তিৃত কৰিছে আৰু মানুহ থকাৰ উপযোগী বনাইছে?</p>"
        },
        "21": {
            "verses": {
                "88:21": {
                    "id": 21
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে ৰাছুল! গতিকে আপুনি ইহঁতক উপদেশ দিয়ক আল্লাহৰ শাস্তিৰ পৰা ভয় প্ৰদৰ্শন কৰোৱাওক। কিয়নো আপুনি কেৱল এজন উপদেশ প্ৰদানকাৰী। সিহঁতক উপদেশ দিয়াৰ বাহিৰে আপোনাৰ ওপৰত আন কোনো দায়িত্ব নাই। আনহাতে ঈমান আনিব নে নাই, সেয়া কেৱল আল্লাহৰ হাতত।</p>"
        },
        "22": {
            "verses": {
                "88:22": {
                    "id": 22
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আপুনি সিহঁতৰ প্ৰতি দাৰোগা ৰূপে নিযুক্ত নহয় যে, সিহঁতক ঈমান আনিবলৈ জবৰদস্তি কৰিব।</p>"
        },
        "23": {
            "verses": {
                "88:23": {
                    "id": 23
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>কিন্তু সিহঁতৰ মাজৰ পৰা যিয়ে ঈমানৰ পৰা মুখ ঘূৰাই লব, আৰু আল্লাহ তথা ৰাছুলক অস্বীকাৰ কৰিব।</p>"
        },
        "24": {
            "verses": {
                "88:24": {
                    "id": 24
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>গতিকে ক্বিয়ামতৰ দিনা আল্লাহে তাক সৱাতোকৈ ডাঙৰ শাস্তি প্ৰদান কৰিব। ফলত তাক জাহান্নামত চিৰকালৰ বাবে নিক্ষেপ কৰিব।</p>"
        },
        "25": {
            "verses": {
                "88:25": {
                    "id": 25
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>নিশ্চয় সিহঁতৰ মৃত্যুৰ পিছত, কেৱল আমাৰ ফালেই সিহঁতৰ প্ৰত্যাৱৰ্তন।</p>"
        },
        "26": {
            "verses": {
                "88:26": {
                    "id": 26
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ পিছত সিহঁতৰ আমলৰ হিচাপ-নিকাচ আমাৰেই দায়িত্ব। আপোনাৰ আৰু আপোনাৰ বাহিৰে আন কাৰো এই দায়িত্ব নহয়।</p>"
        }
    }
}