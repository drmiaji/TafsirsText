            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>বান্দাসকলে যি যি কৰ্ম কৰে সেয়া সংৰক্ষক ফিৰিস্তাসকলে পুথিত লিপিবদ্ধ কৰি ৰাখে। একোৱেই তেওঁলোকৰ পৰা এৰা নপৰে।</p>"
        },
        "53": {
            "verses": {
                "54:53": {
                    "id": 53
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
