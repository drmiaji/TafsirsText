            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আদ সম্প্রদায়েও সিহঁতৰ নবী হূদ আলাইহিচ্ছালামক মিথ্যাৰোপ কৰিছিল। এতেকে হে মক্কাৰ অধিবাসীসকল! ভাৱি চোৱা, সিহঁতৰ বাবে মোৰ শাস্তি কেনেকুৱা আছিল?! লগতে সিহঁতৰ শাস্তিৰ মাধ্যমত অন্যান্য লোকসকলক দিয়া মোৰ সতৰ্ক-সংকেত কেনেকুৱা আছিল?!</p>"
        },
        "19": {
            "verses": {
                "54:19": {
                    "id": 19
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
