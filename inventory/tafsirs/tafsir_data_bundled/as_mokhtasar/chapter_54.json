            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>নিশ্চয় আল্লাহৰ আদেশ পালন কৰা আৰু তেওঁৰ নিষেধকৃত বিষয়ৰ পৰা বিৰত থকা মুত্ত্বাক্বীসকলে জান্নাতৰ মাজত আৰু প্ৰবাহিত নদ-নদীসমূহৰ মাজত তেওঁৰ নিয়ামতসমূহ উপভোগ কৰিব।</p>"
        },
        "55": {
