{
    "chapter": 79,
    "verses": {
        "1": {
            "verses": {
                "79:1": {
                    "id": 1
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আল্লাহ তাআলা ফিৰিস্তাৰ শপত খাইছে যিসকল বহুত কঠোৰ আৰু নিৰ্দয় হিচাপে কাফিৰ সকলৰ জান কবজ কৰে।</p>"
        },
        "2": {
            "verses": {
                "79:2": {
                    "id": 2
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু আল্লাহ তাআলাই সেই ফিৰিস্তাৰ শপত খাইছে যিয়ে সহজ আৰু সৰলতাৰ সৈতে ইমানদাৰ সকলৰ জান কবজ কৰে।</p>"
        },
        "3": {
            "verses": {
                "79:3": {
                    "id": 3
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু আল্লাহ তাআলাই সেই সকল ফিৰিস্তাৰ শপত খাইছে যিসকলে আল্লাহৰ আদেশ অনুযায়ী আকাশৰ পৰা পৃথিৱী লৈ উৰি ফুৰে।</p>"
        },
        "4": {
            "verses": {
                "79:4": {
                    "id": 4
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু আল্লাহ তাআলাই সেই সকল ফিৰিস্তাৰ শপত খাইছে যিসকলে তেওঁৰ আদেশ পালনত আনতকৈ বেছি আগুৱাই যায়।</p>"
        },
        "5": {
            "verses": {
                "79:5": {
                    "id": 5
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু আল্লাহ তাআলাই সেই সকল ফিৰিস্তাৰ শপত খাইছে যিসকলে আল্লাহৰ ফয়চালা লাগু কৰে যেনে, যি সকল ফিৰিস্তাই বান্দাৰ আমল লিখাত নিবদ্ধ। আল্লাহ তাআলাই এই সকল ফিৰিস্তাৰ শপত কৰি কৈছে যে, তেওঁ মানুহক হিচাপ-নিকাচ আৰু উচিত পৰিণাম দিবলৈ নিশ্চিত ভাৱে জীৱিত কৰি উঠাব।</p>"
        },
        "6": {
            "verses": {
                "79:6": {
                    "id": 6
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>যিদিনাখন শিঙাত প্ৰথম বাৰ ফুঁ দিয়াৰ সময়ত পৃথিৱী কঁপি উঠিব।</h2>"
        },
        "7": {
            "verses": {
                "79:7": {
                    "id": 7
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>এই ফুঁ দিয়াৰ পিছত আকৌ দ্বিতীয় ফুঁ দিয়া হব।</h2>"
        },
        "8": {
            "verses": {
                "79:8": {
                    "id": 8
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>সেইদিনা কাফিৰ আৰু ফাছিক্বসকলৰ অন্তৰ ভীতিগ্ৰস্থ হ'ব।</h2>"
        },
        "9": {
            "verses": {
                "79:9": {
                    "id": 9
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>সিহঁতৰ চকুত অপমানৰ চিন দেখা যাব।</h2>"
        },
        "10": {
            "verses": {
                "79:10": {
                    "id": 10
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিহঁতে কৈছিল – মৃত্যুৰ পিছত আমি পুনৰ পৃথিৱীৰ জীৱনলৈ ওভতিম নেকি?</p>"
        },
        "11": {
            "verses": {
                "79:11": {
                    "id": 11
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>যেতিয়া আমাৰ হাড়বোৰ গেলি-পচি যাব, তাৰ পিছতো ওভতিম নেকি?</h2>"
        },
        "12": {
            "verses": {
                "79:12": {
                    "id": 12
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিহঁতে কয়ঃ যদি আমি ওভতিব লাগে তেন্তে এয়া হব ক্ষতিকৰ প্ৰত্যাৱৰ্তন, যিটোত সদায় ওভোতা ব্যক্তি ক্ষতিগ্ৰস্ত হয়।</p>"
        },
        "13": {
            "verses": {
                "79:13": {
                    "id": 13
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>পুনৰ জীৱিত কৰা কাম অতি সহজ। বৰং এয়া হৈছে শিঙাত ফুঁ দিয়া কাৰ্যত নিযুক্ত ফিৰিস্তাৰ এটা মাত্ৰ তীব্ৰ শব্দ।</p>"
        },
        "14": {
            "verses": {
                "79:14": {
                    "id": 14
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেতিয়া হঠাৎ সকলো লোক জীৱিত হৈ পৃথিৱীৰ ওপৰত আহিব যিহেতু আগতে পৃথিৱীৰ ভিতৰত মৃত অৱস্থাত আছিল।</p>"
        },
        "15": {
            "verses": {
                "79:15": {
                    "id": 15
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>(হে ৰাছুল) আপোনাৰ ওচৰত মুছাৰ সৈতে তেওঁৰ প্ৰতিপালক আৰু তেওঁৰ শত্ৰু ফিৰআউনৰ সৈতে হোৱা ঘটনাটো আহি পাইছেনে?</p>"
        },
        "16": {
            "verses": {
                "79:16": {
                    "id": 16
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>যেতিয়া তেওঁৰ প্ৰতিপালকে তেওঁক তুৱা উপত্যকাত মাতিছিল।</h2>"
        },
        "17": {
            "verses": {
                "79:17": {
                    "id": 17
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আল্লাহ তাআলাই তেওঁক যি কৈছিল তাৰ ভিতৰত এয়াও আছিল যে- ফিৰআউনৰ ওচৰলৈ যোৱা। সি অত্যাচাৰ আৰু অভিমানৰ চৰম সীমা অতিক্ৰম কৰিছে।</p>"
        },
        "18": {
            "verses": {
                "79:18": {
                    "id": 18
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু তাক কোৱা (হে ফিৰ আউন) তুমি কুফুৰী আৰু পাপৰ পৰা পৱিত্ৰ হবলৈ নিবিচৰা নেকি?</p>"
        },
        "19": {
            "verses": {
                "79:19": {
                    "id": 19
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু তোমাৰ প্ৰতিপালকৰ পথ প্ৰদৰ্শন কৰো যিয়ে তোমাক সৃষ্টি কৰিছে আৰু তোমাক চোৱা-চিতা কৰিছে। এতেকে তুমি তাক ভয় কৰিবা নে? আৰু এনেকুৱা কাম কৰিবানে যিবোৰে তেওঁক সন্তুষ্টু কৰে আৰু তেওঁক অসন্তুষ্ট কৰা কামৰ পৰা বিৰত থাকিবানে?</p>"
        },
        "20": {
            "verses": {
                "79:20": {
                    "id": 20
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ পিছত মুছা (আলাইহিছ ছালামে) তেওঁৰ প্ৰতিপালক তৰফৰ পৰা ৰাছুল হোৱাৰ ডাঙৰ নিদৰ্শন দেখুৱালে। এই নিদৰ্শন হল হাত আৰু লাঠিৰ নিদৰ্শন।</p>"
        },
        "21": {
            "verses": {
                "79:21": {
                    "id": 21
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেতিয়া ফিৰআউনৰ তৰফৰ পৰা এই প্ৰতিক্ৰিয়া প্ৰকাশ পাইছিল যে, সি এই নিদৰ্শনাৱলী অস্বীকাৰ কৰিলে আৰু মুছা (আলাইহিছ ছালাম)ৰ আদেশ অৱমাননা কৰিলে।</p>"
        },
        "22": {
            "verses": {
                "79:22": {
                    "id": 22
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ পিছত সত্যৰ বিৰোধিতা কৰি তথা আল্লাহৰ অবাধ্যতাত আগুৱাই গৈ মুছা আলাইহিচ্ছালামে লৈ অহা বাৰ্তাৰ প্ৰতি ঈমান পোষণৰ পৰা মুখ ঘূৰাই ল'লে।</p>"
        },
        "23": {
            "verses": {
                "79:23": {
                    "id": 23
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ইয়াৰ পিছত তাৰ সম্প্ৰদায়ক আৰু তাৰ অনুসাৰীসকলক একত্ৰিত কৰিলে যাতে মুছা আলাইহিচ্ছালামক পৰাজিত কৰিব পাৰে। আৰু এই বুলি ঘোষণা দিলে।</p>"
        },
        "24": {
            "verses": {
                "79:24": {
                    "id": 24
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>মই তোমালোকৰ পৰম প্ৰতিপালক। গতিকে মোৰ বাহিৰে তোমালোকে কাৰো অনুসৰণ কৰিব নোৱাৰিবা।</p>"
        },
        "25": {
            "verses": {
                "79:25": {
                    "id": 25
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>অৱশেষত আল্লাহ তাআলাই তাক কৰায়ত্ব কৰিলে আৰু তাক সাগৰত ডুবাই পৃথিৱীত শাস্তি বিহিলে আৰু পৰকালত তাক কঠোৰ শাস্তি দিয়া হব।</p>"
        },
        "26": {
            "verses": {
                "79:26": {
                    "id": 26
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আমি ফিৰআউনক যি শাস্তি দিছো তাৰ পৰা সেইসকল লোকে শিক্ষা গ্ৰহন কৰে যিসকলে আল্লাহক ভয় কৰে। কিয়নো তেনে লোকেই উপদেশৰ দ্বাৰা উপকৃত হয়।</p>"
        },
        "27": {
            "verses": {
                "79:27": {
                    "id": 27
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে পুনৰ জীৱন অস্বীকাৰকাৰী সকল! আল্লাহ তাআলাৰ বাবে তোমালোকক সৃষ্টি কৰা কঠিন নে আকাশ সৃষ্টি কৰাটো তেওঁৰ ওচৰত বেছি কঠিন, যিটোক আল্লাহে সৃষ্টি কৰিছে?</p>"
        },
        "28": {
            "verses": {
                "79:28": {
                    "id": 28
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ওপৰ পৃষ্ঠ উচ্চ বনাইছে আৰু তাক সমানকৈ বনাইছে যাৰ ভিতৰত কোনো ছিদ্ৰ, ফাট, ত্ৰুটি নাই।</p>"
        },
        "29": {
            "verses": {
                "79:29": {
                    "id": 29
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যেতিয়া সূৰ্য মাৰ যায় তেতিয়া তেৱেঁই ৰাতিক অন্ধকাৰ বনায়। আৰু সূৰ্য উদয় হলে তেৱেঁই পোহৰ প্ৰকট কৰে।</p>"
        },
        "30": {
            "verses": {
                "79:30": {
                    "id": 30
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আকাশ সৃষ্টিৰ পিছত পৃথিৱীখনক প্ৰসাৰিত কৰিছে আৰু ইয়াৰ ভিতৰত ৰাখিছে ইয়াৰ উপকাৰসমূহ।</p>"
        },
        "31": {
            "verses": {
                "79:31": {
                    "id": 31
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু তাৰ পৰা স্ৰোত ৰূপে বৈ যোৱা পানী উলিয়াইছে। আৰু এনেকুৱা ঘাঁহ উলিয়াইছে যিবোৰ জীৱ-জন্তুৱে খাব পাৰে।</p>"
        },
        "32": {
            "verses": {
                "79:32": {
                    "id": 32
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু পৰ্বতবোৰক পৃথিৱীৰ ওপৰত মজবুত কৈ থিয় কৰিছে।</h2>"
        },
        "33": {
            "verses": {
                "79:33": {
                    "id": 33
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>(হে মানৱ) এইবোৰ তোমালোকৰ আৰু তোমালোকৰ জীৱ-জন্তুৰ বাবে জীৱনোপকৰণ। এতেকে সেই সত্তা যিজনে এই সকলোবোৰ বস্তু সৃষ্টি কৰিছে, তেওঁ তোমালোকক পুনৰ সৃষ্টি কৰিবলৈ অক্ষম নহয়।</p>"
        },
        "34": {
            "verses": {
                "79:34": {
                    "id": 34
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যেতিয়া দ্বিতীয় বাৰ শিঙাত ফুঁ দিয়া হব, যাৰ ভাগৰতাই সকলো বস্তুক আৱৰি ধৰিব আৰু ক্বিয়ামত প্ৰতিষ্ঠিত হব।</p>"
        },
        "35": {
            "verses": {
                "79:35": {
                    "id": 35
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যিদিনাখন ক্বিয়ামত প্ৰতিষ্ঠিত হব, সেইদিনা মানুহে নিজ নিজ কৰ্ম স্মৰণ কৰিব, ভালেই হওঁক বা বেয়া।</p>"
        },
        "36": {
            "verses": {
                "79:36": {
                    "id": 36
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু জাহান্নামক আনা হব আৰু তাক দৰ্শনকাৰীৰ চকুৰ আগত আনি দিয়া হব।</p>"
        },
        "37": {
            "verses": {
                "79:37": {
                    "id": 37
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>এতেকে যিসকলে পথভ্ৰষ্টতাৰ সীমা অতিক্ৰম কৰিছে।</h2>"
        },
        "38": {
            "verses": {
                "79:38": {
                    "id": 38
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু পৃথিৱীৰ ক্ষণস্থায়ী জীৱনক পৰকালৰ চিৰস্থায়ী জীৱনৰ ওপৰত অগ্ৰধিকাৰ দিছে।</p>"
        },
        "39": {
            "verses": {
                "79:39": {
                    "id": 39
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>জাহান্নামেই হব সিহঁতৰ ঠিকনা, যত সিহঁতে থাকিব।</h2>"
        },
        "40": {
            "verses": {
                "79:40": {
                    "id": 40
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যিয়ে নিজ প্ৰতিপালকৰ আগত থিয় হবলৈ ভয় কৰে আৰু আল্লাহ তাআলাই হাৰাম কৰা মন পছন্দ বস্তুৰ পৰা নিজকে বিৰত ৰাখে। তেওঁলোকৰ ঠিকনা হব জান্নাত, যত তেওঁলোকে বসবাস কৰিব।</p>"
        },
        "41": {
            "verses": {
                "79:41": {
                    "id": 41
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যিয়ে নিজ প্ৰতিপালকৰ আগত থিয় হবলৈ ভয় কৰে আৰু আল্লাহ তাআলাই হাৰাম কৰা মন পছন্দ বস্তুৰ পৰা নিজকে বিৰত ৰাখে। তেওঁলোকৰ ঠিকনা হব জান্নাত, যত তেওঁলোকে বসবাস কৰিব।</p>"
        },
        "42": {
            "verses": {
                "79:42": {
                    "id": 42
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে ৰাছুল! পুনৰ জীৱন অস্বীকাৰ কাৰী সকলে আপোনাক সোধে যে, ক্বিয়ামত কেতিয়া হব?</p>"
        },
        "43": {
            "verses": {
                "79:43": {
                    "id": 43
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এই বিষয়ে সিহঁতক কব পৰা আপোনাৰ জ্ঞান নাই। আৰু এয়া আপোনাৰ দায়িত্বও নহয়। আপোনাৰ কৰ্তব্য কেৱল ইয়াৰ বাবে প্ৰস্তুতি লোৱা।</p>"
        },
        "44": {
            "verses": {
                "79:44": {
                    "id": 44
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ক্বিয়ামতৰ জ্ঞান কেৱল তোমাৰ প্ৰতিপালকৰ ওচৰত আছে, তাৰ বাহিৰে আন কাৰো ওচৰত নাই।</p>"
        },
        "45": {
            "verses": {
                "79:45": {
                    "id": 45
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আপুনি কেৱল সেই ব্যক্তিৰ বাবে সতৰ্ককাৰী যিয়ে ক্বিয়ামতক ভয় কৰে, কিয়নো কেৱল সেই ব্যক্তিয়েই আপোনাৰ সাৱধান বাণীৰ পৰা উপকৃত হব।</p>"
        },
        "46": {
            "verses": {
                "79:46": {
                    "id": 46
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যিদিনাখন সিহঁতে ক্বিয়ামতক নিজ চকুৰে দেখা পাব, সিদিনা সিহঁতে এনেকুৱা অনুভৱ কৰিব যেনিবা সিহঁতে পৃথিৱীত এটা সন্ধিয়া বা এটা প্ৰভাতহে কটাইছে।</p>"
        }
    }
}