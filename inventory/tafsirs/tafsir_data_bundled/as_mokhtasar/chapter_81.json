{
    "chapter": 81,
    "verses": {
        "1": {
            "verses": {
                "81:1": {
                    "id": 1
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যেতিয়া সূৰ্যৰ অস্তিত্ব সংকীৰ্ণ কৰি দিয়া হব আৰু সূৰ্যৰ পোহৰ সমাপ্ত কৰি দিয়া হব।</p>"
        },
        "2": {
            "verses": {
                "81:2": {
                    "id": 2
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু যেতিয়া খহি পৰিব আৰু তাৰ পোহৰ শেষ হৈ যাব।</h2>"
        },
        "3": {
            "verses": {
                "81:3": {
                    "id": 3
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু পৰ্বতবোৰক তাৰ স্থানৰ পৰা চলমান কৰি দিয়া হ'ব।</h2>"
        },
        "4": {
            "verses": {
                "81:4": {
                    "id": 4
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যিবোৰ গৰ্ভৱতী উটকলৈ গৰাকীয়ে গৌৰৱ কৰে, সেইসময়ত সেইবোৰ উটক অযত্নে এৰি দিয়া হ'ব।</p>"
        },
        "5": {
            "verses": {
                "81:5": {
                    "id": 5
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যেতিয়া বনৰীয়া জন্তুবোৰক মানুহৰ লগত একে স্থানত একত্ৰিত কৰা হ'ব।</p>"
        },
        "6": {
            "verses": {
                "81:6": {
                    "id": 6
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যেতিয়া সাগৰবোৰক উদগনি দিয়া হব, ফলত সেইবোৰ জুইত পৰিণত হ'ব।</p>"
        },
        "7": {
            "verses": {
                "81:7": {
                    "id": 7
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যেতিয়া প্ৰাণবোৰক তেওঁলোকৰ লগত মিলিত কৰা হব যিবোৰ তাৰ সমান হব। গতিকে পাপীৰ লগত পাপী আৰু সদাচাৰৰ লগত সদাচাৰক মিলিত কৰা হ'ব।</p>"
        },
        "8": {
            "verses": {
                "81:8": {
                    "id": 8
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু যেতিয়া জীৱন্ত সমাধিস্থ কন্যা শিশুক সোধা হ'ব।</h2>"
        },
        "9": {
            "verses": {
                "81:9": {
                    "id": 9
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>তোমাৰ হত্যাকাৰীয়ে তোমাক কি কাৰণত হত্যা কৰিছিল?</h2>"
        },
        "10": {
            "verses": {
                "81:10": {
                    "id": 10
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যেতিয়া বান্দাৰ আমাল নামা খুলি দিয়া হব, যাতে প্ৰত্যেক ব্যক্তিয়ে নিজ নিজ আমল নামা (কৰ্ম পত্ৰ) পঢ়িব পাৰে।</p>"
        },
        "11": {
            "verses": {
                "81:11": {
                    "id": 11
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যেতিয়া আকাশৰ আৱৰণ খুলি দিয়া হব যিদৰে ছাগলীৰ ছাল খুলা হয়।</p>"
        },
        "12": {
            "verses": {
                "81:12": {
                    "id": 12
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু যেতিয়া জাহান্নামক ভীষণ ভাৱে প্ৰজ্জ্বলিত কৰা হ'ব।</h2>"
        },
        "13": {
            "verses": {
                "81:13": {
                    "id": 13
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু যেতিয়া জান্নাতক মুত্তাক্বীসকলৰ ওচৰত ৰখা হ'ব।</h2>"
        },
        "14": {
            "verses": {
                "81:14": {
                    "id": 14
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যেতিয়া এইবোৰ সংঘটিত হব, তেতিয়া প্ৰত্যেক ব্যক্তিয়ে জানিব যে, তেওঁ সেই দিনৰ বাবে কি আমল আগবঢ়াইছে।</p>"
        },
        "15": {
            "verses": {
                "81:15": {
                    "id": 15
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আল্লাহ তাআলাই সেইবোৰ নক্ষত্ৰৰ শপত খাইছে যিবোৰ ৰাতিত প্ৰকাশ হোৱাৰ আগতে লোকাই থাকে।</p>"
        },
        "16": {
            "verses": {
                "81:16": {
                    "id": 16
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যিবোৰ নিজ নিজ অক্ষ ৰেখাত ঘূৰি থাকে আৰু প্ৰভাত অহাৰ লগে লগে তেনেদৰে লুকাই যায় যিদৰে হৰিণে নিজৰ ঘৰত সোমায়।</p>"
        },
        "17": {
            "verses": {
                "81:17": {
                    "id": 17
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু ৰাতিৰ প্ৰথম ভাগ যেতিয়া আহে আৰু ৰাতিৰ শেষ ভাগ যেতিয়া যাবলৈ ধৰে আল্লাহ তাআলাই ইয়াৰো শপত খাইছে।</p>"
        },
        "18": {
            "verses": {
                "81:18": {
                    "id": 18
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যেতিয়া পুৱাৰ ভাগত পোহৰ প্ৰসাৰিত হয়, আল্লাহ তাআলাই সেই সময়ৰ শপত খাইছে।</p>"
        },
        "19": {
            "verses": {
                "81:19": {
                    "id": 19
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>নিশ্চয় মুহাম্মদ চাল্লাল্লাহু আলাইহি অছাল্লামৰ প্ৰতি অৱতীৰ্ণ হোৱা কোৰআন আল্লাহ তাআলাৰ বাণী। যাক আমানতদাৰ ফিৰিস্তা অৰ্থাৎ জিব্ৰীল আলাইহিছ ছালামে পৌঁছাইছে। আল্লাহ তাআলাই তেখেতক এই দায়িত্ব অৰ্পন কৰিছিল।</p>"
        },
        "20": {
            "verses": {
                "81:20": {
                    "id": 20
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেওঁ অতি শক্তিশালী আৰু আকাশৰ গৰাকীৰ ওচৰত তেওঁ মৰ্যদা সম্পন্ন।</p>"
        },
        "21": {
            "verses": {
                "81:21": {
                    "id": 21
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আকাশবাসী সকল তেখেতৰ কথা মানে আৰু তেখেতক প্ৰত্যাদেশ পৌঁছাবলৈ যি দায়িত্ব অৰ্পণ কৰা হৈছে সেয়া আমানতদাৰীৰ সৈতে পালন কৰিছে।</p>"
        },
        "22": {
            "verses": {
                "81:22": {
                    "id": 22
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু মুহাম্মদ চাল্লাল্লাহু আলাইহি অছাল্লাম যিয়ে তোমালোকৰ লগত থাকে, যাৰ বিবেক, আমানতদাৰী আৰু সততাৰ বিষয়ে তোমালেকে ভালদৰে পৰিচিত। তেওঁ কোনো উন্মাদ নহয়, যিদৰে তোমালোকে দাবী কৰা।</p>"
        },
        "23": {
            "verses": {
                "81:23": {
                    "id": 23
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু তোমালোকৰ সঙ্গীয়ে তেখেতক দিগন্তত তেখেতৰ প্ৰকৃত ৰূপত স্পষ্ট ভাৱে দেখিছে।</p>"
        },
        "24": {
            "verses": {
                "81:24": {
                    "id": 24
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু তোমালকৰ সঙ্গী কৃপণও নহয় যে, যি বস্তু পৌঁছাবলৈ তেখেতক নিযুক্ত কৰা হৈছে সেয়া পৌঁছাবলৈ কৃপণালী কৰিব বা জ্যোতিষীৰ দৰে তোমালোকৰ পৰা বিনিময় বিচাৰিব।</p>"
        },
        "25": {
            "verses": {
                "81:25": {
                    "id": 25
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু এই কোৰআন আল্লাহৰ ৰহমতৰ পৰা বঞ্চিত কোনো অভিশপ্ত চয়তাৰ বাণী নহয়।</p>"
        },
        "26": {
            "verses": {
                "81:26": {
                    "id": 26
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এই প্ৰমাণবোৰৰ পিছত এয়া আল্লাহৰ বাণী বুলি অস্বীকাৰ কৰাৰ কোনটো ৰাস্তা থাকিব পাৰে।</p>"
        },
        "27": {
            "verses": {
                "81:27": {
                    "id": 27
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>কোৰআন জিন আৰু মানুহৰ বাবে কেৱল স্মৰণকাৰী আৰু উপদেশ বাণীহে।</h2>"
        },
        "28": {
            "verses": {
                "81:28": {
                    "id": 28
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তোমালোকৰ মাজৰ পৰা সেই ব্যক্তিৰ বাবে যিয়ে সত্যৰ পথত চলিব বিচাৰে।</p>"
        },
        "29": {
            "verses": {
                "81:29": {
                    "id": 29
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তুমি সত্য বা অসত্য পথৰ প্ৰতি চলিবলৈ ইচ্ছা কৰিব নোৱাৰিবা, যেতিয়ালৈকে আল্লাহে নিবিচাৰে। যিয়ে গোটেই জগতৰ পালন কৰ্তা।</p>"
        }
    }
