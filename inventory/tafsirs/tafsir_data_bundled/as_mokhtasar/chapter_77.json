{
    "chapter": 77,
    "verses": {
        "1": {
            "verses": {
                "77:1": {
                    "id": 1
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>ঘোঁৰাৰ দৰে প্ৰচণ্ড বেগত চলা বতাহৰ আল্লাহে শপত কৰিছে।</h2>"
        },
        "2": {
            "verses": {
                "77:2": {
                    "id": 2
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু প্ৰচণ্ড বেগত চলা ধুমুহাৰো শপত কৰিছে।</h2>"
        },
        "3": {
            "verses": {
                "77:3": {
                    "id": 3
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু সেই বতাহৰ শপত কৰিছে যিয়ে মেঘক সঞ্চালন বা প্ৰসাৰ কৰে।</h2>"
        },
        "4": {
            "verses": {
                "77:4": {
                    "id": 4
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু সেই ফিৰিস্তাসকলৰ শপত কৰিছে যিসকলে সত্য আৰু অসত্যৰ মাজত সুস্পষ্টৰূপে পাৰ্থক্যকাৰী বস্তুৰ সৈতে অৱতৰণ হয়।</p>"
        },
        "5": {
            "verses": {
                "77:5": {
                    "id": 5
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু সেই ফিৰিস্তাসকলৰ শপত কৰিছে, যিসকলে অহীৰ সৈতে অৱতৰণ কৰে।</h2>"
        },
        "6": {
            "verses": {
                "77:6": {
                    "id": 6
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যিয়ে অহী লৈ অৱতৰণ কৰে। আল্লাহৰ তৰফৰ পৰা মানুহৰ ওজৰ-আপত্তি সমাপ্ত কৰাৰ কাৰণে আৰু মানুহক আল্লাহৰ শাস্তিৰ পৰা সতৰ্ক কৰিবলৈ।</p>"
        },
        "7": {
            "verses": {
                "77:7": {
                    "id": 7
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>নিশ্চয় তোমালোকক যিটোৰ প্ৰতিশ্ৰুতি দিয়া হৈছে, যেনে- পুনৰুত্থান, হিচাপ- নিকাচ আৰু পৰিণাম বা প্ৰতিফল সেয়া বাস্তৱায়িত হ'বই।</p>"
        },
        "8": {
            "verses": {
                "77:8": {
                    "id": 8
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>এতেকে যেতিয়া নক্ষত্ৰসমূহৰ পোহৰ সমাপ্ত হব আৰু জ্যোতিহীন হ'ব।</h2>"
        },
        "9": {
            "verses": {
                "77:9": {
                    "id": 9
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>যেতিয়া আকাশখন ফাঁটি যাব, যাতে তাৰ পৰা ফিৰিস্তাসকল নামি আহে।</h2>"
        },
        "10": {
            "verses": {
                "77:10": {
                    "id": 10
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যেতিয়া পৰ্বতসমূহক স্থানচ্যূত কৰা হব আৰু চুৰ্ণ- বিচুৰ্ণ হৈ ধূলিত পৰিণিত হ'ব।</p>"
        },
        "11": {
            "verses": {
                "77:11": {
                    "id": 11
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু ৰাছুলসকলক এটা নিৰ্ধাৰিত সময়ৰ বাবে একত্ৰিত কৰা হ'ব।</h2>"
        },
        "12": {
            "verses": {
                "77:12": {
                    "id": 12
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এক ভীষণ দিনৰ বাবে ইহঁতক স্থগিত ৰখা হৈছে। যাতে নিজ সম্প্ৰদায়ৰ বিৰুদ্ধে সাক্ষী দিয়ে।</p>"
        },
        "13": {
            "verses": {
                "77:13": {
                    "id": 13
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>বান্দাসকলৰ মাজত ফয়চালাৰ দিনৰ বাবে। সেই দিনা স্পষ্ট হৈ যাব যে, কোন সত্যবাদী আৰু কোন অসত্যবাদী তথা কোন সৌভাগ্যশালী আৰু কোন দূৰ্ভাগ্যশালী।</p>"
        },
        "14": {
            "verses": {
                "77:14": {
                    "id": 14
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>হে ৰাছুল ! আপোনাক কিহে জনাব যে বিচাৰ দিৱস কি?</h2>"
        },
        "15": {
            "verses": {
                "77:15": {
                    "id": 15
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিদিনা অস্বীকাৰকাৰী বিলাকৰ বাবে আছে ধ্বংস, শাস্তি আৰু ক্ষতি। যিবিলাকে ৰাছুলসকলে আল্লাহৰ তৰফৰ পৰা অনা সংবাদসমূহক অস্বীকাৰ কৰে।</p>"
        },
        "16": {
            "verses": {
                "77:16": {
                    "id": 16
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আমি বিগত জাতিবোৰক ধ্বংস কৰা নাইনে, যেতিয়া সিহঁতে আল্লাহক অস্বীকাৰ কৰিছিল আৰু তেওঁৰ ৰাছুলসকলক অস্বীকাৰ কৰিছিল?</p>"
        },
        "17": {
            "verses": {
                "77:17": {
                    "id": 17
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ পিছত পৰৱৰ্তীসকলকো সিহঁতৰ অনুগামী বনাম আৰু সিহঁতৰ দৰেই ইহঁতকো ধ্বংস কৰিম।</p>"
        },
        "18": {
            "verses": {
                "77:18": {
                    "id": 18
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সেই সম্প্ৰদায়ৰ দৰে আমি এই অপৰাধী অস্বীকাৰকাৰী বিলাককো ধ্বংস কৰিম যিহঁতে মুহাম্মদ চাল্লাল্লাহু আলাইহি অছাল্লামে লৈ অহা চৰীয়তক অস্বীকাৰ কৰে।</p>"
        },
        "19": {
            "verses": {
                "77:19": {
                    "id": 19
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সেই দিনা সেইসকলৰ বাবে আছে ধ্বংস, শাস্তি আৰু ক্ষতি, যিসকলে অন্যায়কাৰী সকলৰ শাস্তিক অস্বীকাৰ কৰে।</p>"
        },
        "20": {
            "verses": {
                "77:20": {
                    "id": 20
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে মানৱজাতি, আমি তোমালোকক অলপ তুচ্ছ পানীৰে সৃষ্টি কৰা নাইনে?</p>"
        },
        "21": {
            "verses": {
                "77:21": {
                    "id": 21
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ পিছত আমি সেই পানী এক সুৰক্ষিত স্থান অৰ্থাৎ মাকৰ গৰ্ভাশয়ত ৰাখিছো।</p>"
        },
        "22": {
            "verses": {
                "77:22": {
                    "id": 22
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এটা জ্ঞাত আৰু নিৰ্দিষ্ট সময় লৈকে। অৰ্থাৎ মাকৰ গৰ্ভাশয়ত থকা সময়।</p>"
        },
        "23": {
            "verses": {
                "77:23": {
                    "id": 23
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ পিছত আমি শিশুৰ ৰং- ৰূপ আৰু বৈশিষ্ট্য আদি নিৰ্ধাৰণ কৰিছো। গতিকে আমি এই সকলো বস্তুৰ কিমান ভাল নিৰ্ধাৰণকাৰী।</p>"
        },
        "24": {
            "verses": {
                "77:24": {
                    "id": 24
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সেই দিনা সেইসকলৰ বাবে আছে ধ্বংস, শাস্তি আৰু ক্ষতি, যিসকলে আল্লাহৰ ক্ষমতাক অস্বীকাৰ কৰে।</p>"
        },
        "25": {
            "verses": {
                "77:25": {
                    "id": 25
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>সকলোকে একত্ৰিত কৰিব পৰাকৈ আমি পৃথিৱীখনক সৃষ্টি কৰা নাইনে?</h2>"
        },
        "26": {
            "verses": {
                "77:26": {
                    "id": 26
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>জীৱিত লোকসকলৰ থকা- মেলা আৰু আবাদ হোৱা তথা মৃতসকলক দাফনৰ বাবে সুবিধা দিব পৰাকৈ।</p>"
        },
        "27": {
            "verses": {
                "77:27": {
                    "id": 27
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু তাৰ ওপৰত স্থাপন কৰিছো মজবুত আৰু ওখ ওখ পৰ্বতমালা, যিবোৰে ইয়াক লৰচৰৰ পৰা ৰক্ষা কৰে আৰু হে মানৱ, তোমালোকক মিঠা পানী পান কৰাইছো। গতিকে যিয়ে এইবোৰ সৃষ্টি কৰিছে তেওঁ তোমালোকক পুনৰ্জীৱিত কৰিবলৈ অক্ষম নহয়।</p>"
        },
        "28": {
            "verses": {
                "77:28": {
                    "id": 28
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সেই দিনা সেইসকলৰ বাবে আছে ধ্বংস, শাস্তি আৰু ক্ষতি, যিসকলে আল্লাহৰ অনুগ্ৰহবোৰক অস্বীকাৰ কৰে।</p>"
        },
        "29": {
            "verses": {
                "77:29": {
                    "id": 29
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু ৰাছুলসকলে লৈ অহা সংবাদসমূহক অস্বীকাৰ কৰা ব্যক্তিসকলক কোৱা হবঃ হে অস্বীকাৰকাৰী সকল, তোমালোকে সেই শাস্তিৰ ফালে গতি কৰা, যিটোক অস্বীকাৰ কৰিছিলা।</p>"
        },
        "30": {
            "verses": {
                "77:30": {
                    "id": 30
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>গতি কৰা সেই জাহান্নামৰ জুইৰ ধোঁৱাৰ ছাঁৰ ফালে, যিটো তিনিটা শাখাত বিভক্ত।</p>"
        },
        "31": {
            "verses": {
                "77:31": {
                    "id": 31
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সেই ছাঁৰ শীতলতা নাথাকিব আৰু জুইৰ শিখা আৰু তাপ তোমালোকৰ ওচৰত আহিবলৈ বাধাও দিব নোৱাৰে।</p>"
        },
        "32": {
            "verses": {
                "77:32": {
                    "id": 32
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সেই জুয়ে ফিৰিঙতি উৎক্ষেপন কৰিব। প্ৰত্যেক ফিৰিঙতি বৃহত অট্টালিকাৰ দৰে বিশাল আকৃতিৰ হ'ব।</p>"
        },
        "33": {
            "verses": {
                "77:33": {
                    "id": 33
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সেই উৎক্ষেপন কৰা ফিৰিঙতিবোৰ কলা বৰণৰ উটৰ দৰে কলা হ'ব আৰু বিশালতা হ'ব।</p>"
        },
        "34": {
            "verses": {
                "77:34": {
                    "id": 34
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সেই দিনা সেইসকলৰ বাবে আছে ধ্বংস, শাস্তি আৰু ক্ষতি, যিসকলে আল্লাহৰ শাস্তিক অস্বীকাৰ কৰে।</p>"
        },
        "35": {
            "verses": {
                "77:35": {
                    "id": 35
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>এয়া এনেকুৱা দিন, যিদিনা সিহঁতে একোৱেই ক'ব নোৱাৰিব।</h2>"
        },
        "36": {
            "verses": {
                "77:36": {
                    "id": 36
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু সিহঁতক নিজ প্ৰতিপালকৰ আগত কুফুৰী আৰু পাপসমূহৰ বিষয়ে কোনো ধৰণৰ অজুহাত দাঙি ধৰাৰো অনুমতি দিয়া নহ'ব।</p>"
        },
        "37": {
            "verses": {
                "77:37": {
                    "id": 37
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সেই দিনা সেইসকলৰ বাবে আছে ধ্বংস, শাস্তি আৰু ক্ষতি, যিসকলে এই দিৱসৰ সংবাদসমূহক অস্বীকাৰ কৰে।</p>"
        },
        "38": {
            "verses": {
                "77:38": {
                    "id": 38
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এই দিনটো হৈছে সৃষ্টিৰ মাজত বিচাৰ-ফয়চালাৰ দিন, আমি তোমালোকক আৰু পূৰ্বৱৰ্তীসকলক একেই স্থানত একত্ৰিত কৰিছো।</p>"
        },
        "39": {
            "verses": {
                "77:39": {
                    "id": 39
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যদি তোমালোকৰ ওচৰত আল্লাহৰ শাস্তিৰ পৰা মুক্তি পোৱাৰ কোনো উপায় আছে তেন্তে মোৰ বিৰুদ্ধে পৰীক্ষা কৰি চোৱা।</p>"
        },
        "40": {
            "verses": {
                "77:40": {
                    "id": 40
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সেই দিনা সেইসকলৰ বাবে আছে ধ্বংস, শাস্তি আৰু ক্ষতি, যিসকলে বিচাৰ-ফয়চালাৰ দিৱসক অস্বীকাৰ কৰে।</p>"
        },
        "41": {
            "verses": {
                "77:41": {
                    "id": 41
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>নিশ্চয় যিসকলে নিজ প্ৰতিপালকৰ আদেশসমূহ পালন কৰি আৰু তেওঁৰ নিষেধকৃত বস্তুসমূহৰ পৰা বিৰত থাকি তেওঁক ভয় কৰে, তেওঁলোকে অৱস্থান কৰিব জান্নাতৰ ছাঁ প্ৰদানকাৰী গছৰ তলত আৰু প্ৰবাহিত মিঠা পানীৰ নিজৰাৰ কাষত।</p>"
        },
        "42": {
            "verses": {
                "77:42": {
                    "id": 42
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তথা তেওঁলোকে বিচৰা ফলমূলৰ মাজত থাকিব, যিবোৰ খাবলৈ তেওঁলোকে ইচ্ছা কৰিব।</p>"
        },
        "43": {
            "verses": {
                "77:43": {
                    "id": 43
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু তেওঁলোকক কোৱা হবঃ উত্তম আৰু পৱিত্ৰ বস্তু খাই থাকা লগতে বিশুদ্ধ পানীয় পান কৰি থাকা যিটো প্ৰত্যেক অপছন্দনীয়ৰ পৰা পবিত্ৰ। এয়া দৰাচলতে সেই সত্কৰ্মসমূহৰ প্ৰতিফল যিবোৰ তোমালোকে পৃথিৱীত কৰিছিলা।</p>"
        },
        "44": {
            "verses": {
                "77:44": {
                    "id": 44
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এনেকুৱা প্ৰতিফল যিটো আমি তোমালোকক দিছো, তেনেকুৱা প্ৰতিফল আমি সেই সকল লোকক দিওঁ, যিসকলে উত্তমৰূপে নিজৰ আমল কৰে।</p>"
        },
        "45": {
            "verses": {
                "77:45": {
                    "id": 45
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সেই দিনা সেইসকলৰ বাবে আছে ধ্বংস, শাস্তি আৰু ক্ষতি, যিসকলে মুত্তাক্বীসকলৰ লগত কৰা আল্লাহৰ প্ৰতিশ্ৰুতিক অস্বীকাৰ কৰে।</p>"
        },
        "46": {
            "verses": {
                "77:46": {
                    "id": 46
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু সেই অস্বীকাৰকাৰী সকলক কোৱা হবঃ খোৱা আৰু পৃথিৱীৰ কিছু সুখ খন্তেক সময় উপভোগ কৰা। নিশ্চয় তোমালোক অপৰাধী, কাৰণ তোমালোকে আল্লাহৰ লগত কুফুৰী কৰিছা আৰু তেওঁৰ ৰাছুলসকলক অস্বীকাৰ কৰিছা।</p>"
        },
        "47": {
            "verses": {
                "77:47": {
                    "id": 47
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সেই দিনা সেইসকলৰ বাবে আছে ধ্বংস, শাস্তি আৰু ক্ষতি, যিসকলে প্ৰতিদান দিৱসৰ প্ৰতিদানক অস্বীকাৰ কৰে।</p>"
        },
        "48": {
            "verses": {
                "77:48": {
                    "id": 48
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যেতিয়া এই অস্বীকাৰকাৰী সকলক কোৱা হয় যে, আল্লাহৰ বাবে ছালাত আদায় কৰা, তেতিয়া সিহঁতে আল্লাহৰ বাবে ছালাত আদায় নকৰে।</p>"
        },
        "49": {
            "verses": {
                "77:49": {
                    "id": 49
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিদিনা অস্বীকাৰকাৰী বিলাকৰ বাবে আছে ধ্বংস, শাস্তি আৰু ক্ষতি। যিবিলাকে ৰাছুলসকলে আল্লাহৰ তৰফৰ পৰা অনা সংবাদসমূহক অস্বীকাৰ কৰে।</p>"
        },
        "50": {
            "verses": {
                "77:50": {
                    "id": 50
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>গতিকে যেতিয়া সিহঁতে নিজৰ প্ৰতিপালকৰ তৰফৰ পৰা অৱতীৰ্ণ হোৱা কোৰআনৰ প্ৰতি ঈমান অনা নাই তেন্তে ইয়াৰ বাহিৰে আৰু কিহৰ প্ৰতি ঈমান আনিব।</p>"
        }
    }
}