{
    "chapter": 101,
    "verses": {
        "1": {
            "verses": {
                "101:1": {
                    "id": 1
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>সেই ভয়াৱহ সময়, যিয়ে মানুহৰ অন্তৰক কম্পিত কৰিব।</h2>"
        },
        "2": {
            "verses": {
                "101:2": {
                    "id": 2
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>মানুহৰ অন্তৰ কপোৱা সেই ভয়াৱহ সময়টোনো কি?</h2>"
        },
        "3": {
            "verses": {
                "101:3": {
                    "id": 3
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে ৰাছুল আপোনাক কিহে জনাব যে অন্তৰ কপোৱা সেই সময় কি? নিশ্চিতৰূপে সেয়া হৈছে ক্বিয়ামতৰ সময়।</p>"
        },
        "4": {
            "verses": {
                "101:4": {
                    "id": 4
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যিদিনাখন অন্তৰবোৰ ভীতিপ্ৰদ হব সেইদিনা মানুহ বিক্ষিপ্ত কীট- পতঙ্গৰ দৰে হব।</p>"
        },
        "5": {
            "verses": {
                "101:5": {
                    "id": 5
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু পৰ্বতবোৰ ধূনা ঊণৰ দৰে পাতল আৰু তীব্ৰ গতিত চলিবলৈ ধৰিব।</h2>"
        },
        "6": {
            "verses": {
                "101:6": {
                    "id": 6
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>এতেকে যাৰ ভাল কৰ্ম, বেয়া কৰ্মতকৈ অধিক হব।</h2>"
        },
        "7": {
            "verses": {
                "101:7": {
                    "id": 7
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>তেওঁ জান্নাতত মনে বিচৰা দৰে আনন্দ লাভ কৰিব।</h2>"
        },
        "8": {
            "verses": {
                "101:8": {
                    "id": 8
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু যাৰ বেয়া কৰ্ম, ভাল কৰ্মতকৈ অধিক হব।</h2>"
        },
        "9": {
            "verses": {
                "101:9": {
                    "id": 9
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>ফলত ক্বিয়ামতৰ দিনা তাৰ ঠিকনা আৰু স্থান হব জাহান্নাম।</h2>"
        },
        "10": {
            "verses": {
                "101:10": {
                    "id": 10
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>হে ৰাছুল, আপুনি কি জানে সেইটো কি?</h2>"
        },
        "11": {
            "verses": {
                "101:11": {
                    "id": 11
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>সেয়া হৈছে অত্যন্ত উত্তপ্ত অগ্নিকুণ্ড।</h2>"
        }
    }
}