            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>কোনো মানুহেই আনৰ গুনাহৰ বোজা বহন নকৰিব।</h2>"
        },
        "39": {
            "verses": {
                "53:39": {
                    "id": 39
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
