{
    "chapter": 53,
    "verses": {
        "1": {
            "verses": {
                "53:1": {
                    "id": 1
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আল্লাহে তৰাৰ শপত খাইছে, যেতিয়া ই সৰি পৰে।</h2>"
        },
        "2": {
            "verses": {
                "53:2": {
                    "id": 2
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আল্লাহৰ ৰাছুল মুহাম্মদ চাল্লাল্লাহু আলাইহি অছাল্লাম হিদায়তৰ পথৰ পৰা আঁতৰি যোৱা নাই, তথা বিভ্ৰান্তও হোৱা নাই, বৰং তেওঁ সঠিক পথত প্ৰতিষ্ঠিত হৈ আছে।</p>"
        },
        "3": {
            "verses": {
                "53:3": {
                    "id": 3
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু তেওঁ প্ৰবৃত্তিৰ অনুসৰণ কৰি এই কোৰআন নকয়।</h2>"
        },
        "4": {
            "verses": {
                "53:4": {
                    "id": 4
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এই কোৰআন হৈছে অহী। আল্লাহে জিব্ৰীল আলাইহিইচ্ছালামৰ মাধ্যমত তেওঁৰ ওচৰলৈ এই অহী প্ৰেৰণ কৰে।</p>"
        },
        "5": {
            "verses": {
                "53:5": {
                    "id": 5
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>শক্তিশালী ফিৰিস্তাই অৰ্থাৎ জিব্ৰীল আলাইহিচ্ছালামে তেওঁক শিকায়।</p>"
        },
        "6": {
            "verses": {
                "53:6": {
                    "id": 6
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>জিব্ৰীল আলাইহিচ্ছালাম হৈছে উৎকৃষ্ট আকৃতিৰ অধিকাৰী। আল্লাহে তেওঁক যি আকৃতিত সৃষ্টি কৰিছে সেই আকৃতিতেই তেওঁ নবী চাল্লাল্লাহু আলাইহি অছাল্লামৰ সন্মুখত প্ৰকট হৈছিল।</p>"
        },
        "7": {
            "verses": {
                "53:7": {
                    "id": 7
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>তেতিয়া জিব্ৰীল আলাইহিচ্ছালাম আছিল আকাশৰ ঊৰ্দ্ধদিগন্তত।</h2>"
        },
        "8": {
            "verses": {
                "53:8": {
                    "id": 8
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ইয়াৰ পিছত তেওঁ নবী চাল্লাল্লাহু আলাইহি অছাল্লামৰ নিকটৱৰ্তী হৈছিল, তথা আৰু ওচৰ চাপি আহিছিল।</p>"
        },
        "9": {
            "verses": {
                "53:9": {
                    "id": 9
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেওঁ নবী চাল্লাল্লাহু আলাইহি অছাল্লামৰ পৰা দুখন ধেনুৰ দূৰত্বত অৱস্থান কৰিছিল অথবা তাতোকৈ কম দূৰত্বত।</p>"
        },
        "10": {
            "verses": {
                "53:10": {
                    "id": 10
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেতিয়া জিব্ৰীল আলাইহিচ্ছালামে আল্লাহৰ বান্দা মুহাম্মদ চাল্লাল্লাহু আলাইহি অছাল্লামক যি অহী দিবলগীয়া আছিল সেয়া দিলে।</p>"
        },
        "11": {
            "verses": {
                "53:11": {
                    "id": 11
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>মুহাম্মদ চাল্লাল্লাহু আলাইহি অছাল্লামে যি যি দেখিছে, তেওঁৰ অন্তৰে সেয়া অস্বীকাৰ কৰা নাই।</p>"
        },
        "12": {
            "verses": {
                "53:12": {
                    "id": 12
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে মুশ্বৰিকসকল! তোমালোকে মুহাম্মদ চাল্লাল্লাহু আলাইহি অছাল্লামৰ সৈতে সেইবোৰ বিষয়লৈ বিতৰ্ক কৰা নেকি, যিবোৰ আল্লাহে তেওঁক ‘ইছৰা’ৰ ৰাতি দেখুৱাইছে?</p>"
        },
        "13": {
            "verses": {
                "53:13": {
                    "id": 13
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>মুহাম্মদ চাল্লাল্লাহু আলাইহি অছাল্লামে জিব্ৰীল আলাইহিচ্ছালামক আৰু এবাৰ প্ৰকৃত আকৃতিত দেখা পাইছিল ইছৰাৰ ৰাতিত।</p>"
        },
        "14": {
            "verses": {
                "53:14": {
                    "id": 14
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ছিদৰাতুল মুনতাহাৰ ওচৰত। সেয়া হৈছে সপ্তম আকাশত থকা এজোপা প্ৰকাণ্ড বৃক্ষ।</p>"
        },
        "15": {
            "verses": {
                "53:15": {
                    "id": 15
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>এই গছজোপাৰ ওচৰতেই আছে জান্নাতুল মা’ওৱা।</h2>"
        },
        "16": {
            "verses": {
                "53:16": {
                    "id": 16
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আল্লাহৰ আদেশত বিশাল বস্তু এটাই যেতিয়া ছিদৰাক আচ্ছাদিত কৰিছিল, যিটোৰ বাস্তৱিকতা সম্পৰ্কে একমাত্ৰ আল্লাহেই অৱগত।</p>"
        },
        "17": {
            "verses": {
                "53:17": {
                    "id": 17
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেখেত চাল্লাল্লাহু আলাইহি অছাল্লামৰ দৃষ্টি সোঁৱে-বাঁওৱেও যোৱা নাছিল, আৰু যি দেখিবলৈ আদেশ দিয়া হৈছিল সেই সীমা অতিক্ৰমও কৰা নাছিল।</p>"
        },
        "18": {
            "verses": {
                "53:18": {
                    "id": 18
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>নিশ্চয় মুহাম্মদ চাল্লাল্লাহু আলাইহি অছাল্লামে মিৰাজৰ ৰাতি তেওঁৰ প্ৰতিপালকৰ মহা নিদৰ্শনসমূহ প্ৰত্যক্ষ কৰিছে, যিবোৰে মহান আল্লাহৰ ক্ষমতাৰ প্ৰমাণ বহন কৰে। এতেকে তেওঁ জান্নাত, জাহান্নাম আৰু অন্যান্য কেইবাটাও বস্তু দেখিছে।</p>"
        },
        "19": {
            "verses": {
                "53:19": {
                    "id": 19
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে মুশ্বৰিকসকল! আল্লাহৰ বাহিৰে তোমালোকে উপাসনা কৰা লাত আৰু উঝঝা সম্পৰ্কে তোমালোকৰ ধাৰণা কি?!</p>"
        },
        "20": {
            "verses": {
                "53:20": {
                    "id": 20
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু তোমালোকৰ তৃতীয় মূৰ্তি মানাত সম্পৰ্কে ধাৰণা কি? কোৱাচোন তোমালোকে, এইবোৰে তোমালোকক কোনো উপকাৰ বা অপকাৰ কৰিব পাৰিবনে?!</p>"
        },
        "21": {
            "verses": {
                "53:21": {
                    "id": 21
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে মুশ্বৰিকসকল! তোমালোকে নিজৰ বাবে পুত্ৰ সন্তান পছন্দ কৰা, অথচ পৱিত্ৰ আল্লাহৰ বাবে তোমালোকে কন্যা সন্তান নিৰ্ধাৰণ কৰা, যিটোক তোমালোকে অপছন্দ কৰা?!</p>"
        },
        "22": {
            "verses": {
                "53:22": {
                    "id": 22
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এই বন্টন যিটো তোমালোকে নিজৰ প্ৰবৃত্তিৰ চাহিদা অনুসাৰে কৰিছা, সেইটো নিশ্চিতভাৱে অসঙ্গত বন্টন।</p>"
        },
        "23": {
            "verses": {
                "53:23": {
                    "id": 23
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এই মূৰ্ত্তিবোৰ দৰাচলতে অৰ্থহীন নামৰ বাহিৰে আন একো নহয়। এইবোৰৰ মাজত উপাস্য হোৱাৰ কোনো যোগ্যতা নাই। এইবোৰ নাম তোমালোকে আৰু তোমালোকৰ পিতৃ-পুৰুষসকলে নিজৰ ফালৰ পৰা নামকৰণ কৰিছা, ইয়াৰ সপক্ষে আল্লাহে কোনো প্ৰমাণ অৱতীৰ্ণ কৰা নাই। মুশ্বৰিকসকলে আক্বীদাৰ ক্ষেত্ৰত কেৱল অনুমান আৰু নিজৰ মনৰ চাহিদাৰহে অনুসৰণ কৰে, যিটোক চয়তানে সিহঁতৰ অন্তৰত শোভনীয় কৰি দিয়ে। অথচ নবী চাল্লাল্লাহু আলাইহি অছাল্লামৰ মাধ্যমত সিহঁতৰ ওচৰলৈ আল্লাহৰ ফালৰ পৰা হিদায়ত আহি পৰিছে। তথাপিও সিহঁতে ইয়াক আঁকোৱালি লোৱা নাই।</p>"
        },
        "24": {
            "verses": {
                "53:24": {
                    "id": 24
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>মানুহৰ এই আশা পূৰণ হ’বনে যে, এই মূৰ্তিবোৰে আল্লাহৰ ওচৰত মধ্যস্ততা কৰিব?!</p>"
        },
