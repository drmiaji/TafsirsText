            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>শীঘ্ৰেই কিয়ামতৰ দিনা তাৰ আমলনামা দেখুৱা হ’ব।</h2>"
        },
        "41": {
            "verses": {
                "53:41": {
