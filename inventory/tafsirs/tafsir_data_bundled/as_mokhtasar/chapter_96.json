{
    "chapter": 96,
    "verses": {
        "1": {
            "verses": {
                "96:1": {
                    "id": 1
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে ৰাছুল, আপোনাৰ প্ৰতিপালকে আপোনাৰ প্ৰতি যি প্ৰত্যাদেশ প্ৰেৰণ কৰে সেয়া পঢ়ক। আপোনাৰ সেই প্ৰতিপালকৰ নামৰ সৈতে আৰম্ভ কৰক যিজনে সকলো সৃষ্টিকে সৃজন কৰিছে।</p>"
        },
        "2": {
            "verses": {
                "96:2": {
                    "id": 2
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যিয়ে মানুহক এক ৰক্তপিণ্ডৰ পৰা সৃষ্টি কৰিছে, যিটো প্ৰথমতে পানীৰ টোপাল আছিল।</p>"
        },
        "3": {
            "verses": {
                "96:3": {
                    "id": 3
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে ৰাছুল, আপোনাৰ প্ৰতিপালকে আপোনাৰ প্ৰতি যি প্ৰত্যাদেশ প্ৰেৰণ কৰে সেয়া পঢ়ক। আৰু আপোনাৰ প্ৰতিপালক অতি দয়ালু। যাৰ দয়াৰ আগত কাৰো দয়াৰ তুলনা নাই। তেওঁ বহুত দাতা আৰু উপকাৰকাৰী।</p>"
        },
        "4": {
            "verses": {
                "96:4": {
                    "id": 4
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>যিয়ে কলমৰ দ্বাৰা লিখা-মেলা কৰা শিকাইছে।</h2>"
        },
        "5": {
            "verses": {
                "96:5": {
                    "id": 5
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>মানুহে যি জনা নাছিল সেয়া তেৱেঁই শিকাইছে।</h2>"
        },
        "6": {
            "verses": {
                "96:6": {
                    "id": 6
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সত্য কথা হৈছে এই যে, দুষ্ট মানুহ যেনে- আবু জাহাল, আল্লাহ তাআলাৰ অবাধ্যতা কৰি তেওঁৰ সীমালংঘন কৰে।</p>"
        },
        "7": {
            "verses": {
                "96:7": {
                    "id": 7
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ ওচৰত ধন-সম্পত্তি আছে কাৰণে সি নিজকে স্বনিৰ্ভৰশীল বুলি ভাৱে।</p>"
        },
        "8": {
            "verses": {
                "96:8": {
                    "id": 8
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে মানৱ, নিশ্চয় ক্বিয়ামতৰ দিনা তোমাৰ প্ৰতিপালকৰ ফালে ওভতিব লাগিব। যত তেওঁ প্ৰত্যেক ব্যক্তিকেই তাৰ প্ৰতিদান দিব, যাৰ সি অধিকাৰী।</p>"
        },
        "9": {
            "verses": {
                "96:9": {
                    "id": 9
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আপুনি আবু জাহালৰ ঘটনাৰ পৰা কিবা আশ্চৰ্যজনক দেখিছে নেকি, যিয়ে বাধা দিয়ে।</p>"
        },
        "10": {
            "verses": {
                "96:10": {
                    "id": 10
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আমাৰ বান্দা মুহাম্মদ চাল্লাল্লাহু আলাইহি অছাল্লামক যেতিয়া তেওঁ কাবাৰ ওচৰত ছালাত আদায় কৰে।</p>"
        },
        "11": {
            "verses": {
                "96:11": {
                    "id": 11
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>চোৱাচোন! যি ব্যক্তিক প্ৰতিৰোধ কৰা হৈ আছে, তেওঁ যদি নিজ প্ৰতিপালকৰ হিদায়তৰ ওপৰত থাকে (তেন্তে তোমালোকে কৰা বিৰোধিতাৰ কি লাভ?</p>"
        },
        "12": {
            "verses": {
                "96:12": {
                    "id": 12
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>অথবা মানুহক আল্লাহৰ আদেশসমূহ পালন কৰি আৰু তেওঁ নিষেধ কৰা বস্তুসমূহৰ পৰা বিৰত ৰাখি, কেৱল তেওঁকেই ভয় কৰাৰ আদেশ দিয়ে, এনেকুৱা ব্যক্তিক প্ৰতিৰোধ কৰা উচিত নে?</p>"
        },
        "13": {
            "verses": {
                "96:13": {
                    "id": 13
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আপোনাৰ কি ধাৰণা, যদি এই প্ৰতিৰোধকাৰী ব্যক্তিয়ে, ৰাছুলে আনা সংবাদৰ অস্বীকাৰ কৰে আৰু তাৰ পৰা মুখ ঘূৰাই লয়। সি আল্লাহক ভয় নকৰে নে?</p>"
        },
        "14": {
            "verses": {
                "96:14": {
                    "id": 14
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এই বান্দাক ছালাত আদায় কৰিবলৈ বাধা প্ৰদান কৰা ব্যক্তিয়ে জানেনে যে, সি যি কৰি আছে, আল্লাহে সেয়া দেখি আছে। তাৰ পৰা কোনো কৰ্ম লোকাই নাথাকে?</p>"
        },
        "15": {
            "verses": {
                "96:15": {
                    "id": 15
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ঘটনা তেনে নহয় যিদৰে এই মূৰ্খই ভাবিছে। যদি সি আমাৰ বান্দাক কষ্ট দিয়ে আৰু তেওঁক অস্বীকাৰ কৰাৰ পৰা বিৰত নাথাকে তেন্তে আমি তাৰ আগচুলি ধৰি চোঁচৰাই জাহান্নামত প্ৰৱেশ কৰাম।</p>"
        },
        "16": {
            "verses": {
                "96:16": {
                    "id": 16
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সেই আগচুলিৰ গৰাকীজনে কথা কলে, মিছা মাতে আৰু কৰ্ম কৰিলে পাপ কৰে।</p>"
        },
        "17": {
            "verses": {
                "96:17": {
                    "id": 17
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যেতিয়া তাৰ আগচুলি ধৰি অগ্নিৰ ফালে টনা হব তেতিয়া নিজৰ লগৰীয়া আৰু লগত বহা সকলক মাতিব আৰু শাস্তিৰ পৰা পৰিত্ৰাণ পাবলৈ সিহঁতৰ সহায় বিচাৰিব।</p>"
        },
        "18": {
            "verses": {
                "96:18": {
                    "id": 18
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আমিও জাহান্নামৰ শক্তিশালী ফিৰিস্তাসকলক আহ্বান কৰিম, যিসকলে আল্লাহৰ আদেশ লংঘন নকৰে আৰু যি কৰাৰ আদেশ পায় তাকেই কৰে। গতিকে সিহঁতে দেখা উচিত যে, উভয় পক্ষৰ কোন পক্ষই অধিক শক্তিশালী আৰু ক্ষমতাশালী।</p>"
        },
        "19": {
            "verses": {
                "96:19": {
                    "id": 19
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ঘটনা তেনেকুৱা নহয় যিদৰে অত্যাচাৰী সকলে ভাৱিছে যে, আপোনাক ক্ষতি কৰাত সফল হৈ যাব। আপুনি তাৰ কোনো আদেশ আৰু নিষেধ নামানিব। আল্লাহক ছাজদাহ কৰক আৰু ইবাদতৰ জৰিয়তে আল্লাহৰ নৈকট্য লাভ কৰক। কিয়নো ইবাদতৰ জৰিয়তে আল্লাহৰ নৈকট্য লাভ কৰা যায়।</p>"
        }
    }
}