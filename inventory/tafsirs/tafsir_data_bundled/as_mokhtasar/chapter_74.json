{
    "chapter": 74,
    "verses": {
        "1": {
            "verses": {
                "74:1": {
                    "id": 1
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে বস্ত্ৰাবৃত ব্যক্তি, অৰ্থাৎ হে নবী ছাল্লাল্লাহু আলাইহি অছাল্লাম।</p>"
        },
        "2": {
            "verses": {
                "74:2": {
                    "id": 2
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>উঠক আৰু আল্লাহৰ শাস্তিৰ পৰা সতৰ্ক কৰক।</h2>"
        },
        "3": {
            "verses": {
                "74:3": {
                    "id": 3
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু নিজ প্ৰতিপালকৰ শ্ৰেষ্ঠত্ব ঘোষনা কৰক।</h2>"
        },
        "4": {
            "verses": {
                "74:4": {
                    "id": 4
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু নিজকে পাপসমূহৰ পৰা পৱিত্ৰ কৰক, লগতে ময়লা-আৱৰ্জনাৰ পৰা কাপোৰ পৱিত্ৰ ৰাখক।</p>"
        },
        "5": {
            "verses": {
                "74:5": {
                    "id": 5
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু মূৰ্তিসমূহৰ পূজাৰ পৰা বিৰত থাকক।</h2>"
        },
        "6": {
            "verses": {
                "74:6": {
                    "id": 6
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু প্ৰতিপালকৰ ওচৰত এই বুলি অনুগ্ৰহ নিবিচাৰিব যে, আপুনি অধিক নেক আমল কৰিছে।</p>"
        },
        "7": {
            "verses": {
                "74:7": {
                    "id": 7
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>সমস্যাৰ সন্মুখীন হলে আল্লাহৰ বাবে ধৈৰ্য ধাৰণ কৰক।</h2>"
        },
        "8": {
            "verses": {
                "74:8": {
                    "id": 8
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>যেতিয়া শিঙাত দ্বিতীয়বাৰ ফুঁ দিয়া হ'ব।</h2>"
        },
        "9": {
            "verses": {
                "74:9": {
                    "id": 9
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>এতেকে সেইদিনটো হ'ব, বহুত কঠিন দিন।</h2>"
        },
        "10": {
            "verses": {
                "74:10": {
                    "id": 10
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আল্লাহ আৰু তেওঁৰ ৰাছুলসকলক অস্বীকাৰকাৰী বিলাকৰ বাবে সহজ নহয়।</p>"
        },
        "11": {
            "verses": {
                "74:11": {
                    "id": 11
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে ৰাছুল, মোক আৰু সেই ব্যক্তিক এৰি দিয়ক, যাক মই তাৰ মাকৰ গৰ্ভত অকলশৰীয়াকৈ সৃষ্টি কৰিছো। তেতিয়া তাৰ কোনো ধন নাছিল, সন্তানো নাছিল। (ইয়াত অলীদ বিন মুগীৰাক উদ্দেশ্য কৰা হৈছে।)</p>"
        },
        "12": {
            "verses": {
                "74:12": {
                    "id": 12
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু তাক অত্যাধিক ধন-সম্পদ প্ৰদান কৰিছো।</h2>"
        },
        "13": {
            "verses": {
                "74:13": {
                    "id": 13
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু তাক এনেকুৱা পুত্ৰ দিছো, যিসকল তাৰ লগত উপস্থিত থাকে আৰু সভাতো অংশগ্ৰহণ কৰে। তাক কোনো যাত্ৰাৰ বাবে অকলে নেৰে। কিয়নো তাৰ ওচৰত ধনৰ কোনো অভাৱ নাছিল।</p>"
        },
        "14": {
            "verses": {
                "74:14": {
                    "id": 14
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু তাক সুখময় জীৱন, প্ৰচুৰ পৰিমাণৰ জীৱিকা আৰু সন্তান প্ৰদান কৰিছো।</p>"
        },
        "15": {
            "verses": {
                "74:15": {
                    "id": 15
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সি মোৰ লগত কুফুৰী কৰাৰ পিছতো এই আশা কৰে যে, মই তাক আৰু অধিক প্ৰদান কৰিম। যদিও তাক মই বহুত দিছো।</p>"
        },
        "16": {
            "verses": {
                "74:16": {
                    "id": 16
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ঘটনাটো তেনেকুৱা নহয় যিদৰে ভাবিছে। সি আমাৰ ৰাছুলৰ প্ৰতি অৱতীৰ্ণ আমাৰ আয়াত সমূহৰ শত্ৰু আৰু সেইবোৰৰ অস্বীকাৰকাৰী।</p>"
        },
        "17": {
            "verses": {
                "74:17": {
                    "id": 17
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>শীঘ্ৰে মই তাক শাস্তিৰ এনেকুৱা বেদনাত নিক্ষেপ কৰিম। যিটো সি সহ্য কৰিব নোৱাৰিব।</p>"
        },
        "18": {
            "verses": {
                "74:18": {
                    "id": 18
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এই কাফিৰ, যাক মই সকলো ধৰণৰ নিয়ামত প্ৰদান কৰিছো, সি এই কোৰআনক ভুল প্ৰমান কৰিবলৈ কি কব লাগে সেয়া চিন্তা কৰিছে আকৌ অন্তৰত তাৰ নিৰ্ণয় কৰিছে।</p>"
        },
        "19": {
            "verses": {
                "74:19": {
                    "id": 19
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এতেকে তাৰ প্ৰতি অভিশাপ আৰু সি ধ্বংস হওক, সি কেনেকৈ এই সিদ্ধান্ত গ্ৰহণ কৰিলে?</p>"
        },
        "20": {
            "verses": {
                "74:20": {
                    "id": 20
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আকৌ তাৰ প্ৰতি অভিশাপ আৰু সি ধ্বংস হওক, সি কেনেকৈ এই সিদ্ধান্ত গ্ৰহণ কৰিলে?</p>"
        },
        "21": {
            "verses": {
                "74:21": {
                    "id": 21
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ পিছত সি পুনৰ বিচাৰ কৰিলে। আৰু সি কোৱা কথাবোৰ ভাৱি চিন্তি চালে।</p>"
        },
        "22": {
            "verses": {
                "74:22": {
                    "id": 22
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ পিছত যেতিয়া কোৰআনত কোনো ভুল ধৰিবলৈ কোনো উপায় নাপালে তেতিয়া তাৰ মুখ বিকৃত কৰিলে আৰু ভ্ৰুঁ কোচ খোৱালে।</p>"
        },
        "23": {
            "verses": {
                "74:23": {
                    "id": 23
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ পিছত সি ঈমানৰ পৰা উভতিলে আৰু নবী চাল্লাল্লাহু আলাইহি অছাল্লামৰ অনুসৰণৰ পৰা অহংকাৰ কৰিলে।</p>"
        },
        "24": {
            "verses": {
                "74:24": {
                    "id": 24
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ পিছত কলেঃ মুহাম্মদ চাল্লাল্লাহু আলাইহি অছাল্লামে যি আনিছে সেয়া আল্লাহৰ বাণী নহয়। বৰং এয়া এক যাদু যিটো আন কাৰোবাৰ পৰা নকল কৰিছে।</p>"
        },
        "25": {
            "verses": {
                "74:25": {
                    "id": 25
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>এয়া আল্লাহৰ বাণী নহয় বৰং এয়াতো মানুহৰ বাণী।</h2>"
        },
        "26": {
            "verses": {
                "74:26": {
                    "id": 26
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>মই অনতিপলমে তাক জাহান্নামৰ এটা স্থান অৰ্থাৎ ছাক্বাৰত প্ৰৱেশ কৰাম, য'ত সি জ্বলি থাকিব।</p>"
        },
        "27": {
            "verses": {
                "74:27": {
                    "id": 27
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>হে মুহাম্মদ, আপোনাক কিহে কব যে ছাক্বাৰ কি?</h2>"
        },
        "28": {
            "verses": {
                "74:28": {
                    "id": 28
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ ভিতৰত নিক্ষেপ কৰা কোনো বস্তুৰ একোৱে অৱশিষ্ট নাৰাখিব বৰং নিঃশেষ কৰি পেলাব। আকৌ সি পূৰ্বৰ দৰে হব, আকৌ তাক নিঃশেষ কৰা হ'ব। এই ধাৰাবাহিকতা চলি থাকিব।</p>"
        },
        "29": {
            "verses": {
                "74:29": {
                    "id": 29
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>ই ছাল একেবাৰে জ্বলাই পেলাব আৰু তাক পৰিৱৰ্তন কৰি পেলাব।</h2>"
        },
        "30": {
            "verses": {
                "74:30": {
                    "id": 30
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ইয়াৰ (ছাক্বাৰৰ) তত্ত্বাৱধানত আৰু সংৰক্ষণৰ বাবে ঊনৈশজন ফিৰিস্তা নিযুক্ত আছে।</p>"
        },
        "31": {
            "verses": {
                "74:31": {
                    "id": 31
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু আমি জাহান্নামৰ ৰক্ষক হিচাপে কেৱল ফিৰিস্তাসকলকেই নিযুক্ত কৰিছোঁ। যাৰ সৈতে প্ৰতিদ্বন্দিতা কৰাৰ ক্ষমতা মানুহৰ নাই। আৰু আমি তেওঁলোকৰ এই সংখ্যা কেৱল আল্লাহক অস্বীকাৰ কৰা লোকসকলক পৰীক্ষা কৰিবলৈহে নিৰ্ধাৰণ কৰিছোঁ। যাতে সিহঁতে এনেকুৱা কথা কৈ থাকে আৰু সিহঁতৰ শাস্তি বৃদ্ধি হৈ থাকে। আৰু ইহুদীসকল, যিসকলক তাওৰাত দিয়া হৈছিল আৰু খৃষ্টানসকল যিসকলক ইঞ্জিল দিয়া হৈছিল, কোৰআনৰ জৰিয়তে যাতে সিহঁতৰ কিতাপসমূহৰ সত্যতাৰ প্ৰতি বিশ্বাস আহে। আৰু ইহুদী, খৃষ্টানসকলৰ সহমতৰ পিছত মুমিনসকলৰ বিশ্বাস আৰু বৃদ্ধি হয়। আৰু ইহুদী, খৃষ্টান আৰু মুমিনসকলে যাতে কোনো সন্দেহত লিপ্ত নহয়। আৰু যাতে কাফিৰ আৰু মুৰতাদ বিলাকে কয়ঃ আল্লাহ এই বিচিত্ৰ সংখ্যাৰে ( ঊনৈশ) কি বুজাব বিচাৰিছে?। যিদৰে এই সংখ্যাৰে অস্বীকাৰকাৰী বিলাকক পথভ্ৰষ্ট কৰা হৈছে আৰু ইয়াৰ স্বীকাৰকাৰীসকলক হিদায়ত দিয়া হৈছে, তেনেদৰে আল্লাহে যাক পথভ্ৰষ্ট কৰিব বিচাৰে তাক পথভ্ৰষ্ট কৰে। আৰু যাক হিদায়ত দিব বিচাৰে তাক হিদায়ত দিয়ে। আৰু তোমাৰ প্ৰতিপালকৰ সৈন্যবাহিনীৰ সংখ্যা তেওঁৰ বাহিৰে আন কোনেও নাজানে। আৰু জাহান্নাম হৈছে মানুহৰ বাবে শিক্ষা-সামগ্ৰী বিষয়, যাৰ পৰা সিহঁতে আল্লাহৰ মহানতাৰ অনুমান কৰিব পাৰে।</p>"
        },
        "32": {
            "verses": {
                "74:32": {
                    "id": 32
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>কথা তেনেকুৱা নহয় যিদৰে কিছুমান মুশ্বৰিকে ভাবিছে যে সিহঁতে জাহান্নামৰ সংৰক্ষণৰ প্ৰতি নিযুক্ত ফিৰিস্তা সকলৰ বাবে যথেষ্ট হব। আল্লাহে চন্দ্ৰৰ শপত কৰি এই কথা কৈছে।</p>"
        },
        "33": {
            "verses": {
                "74:33": {
                    "id": 33
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু ৰাতিৰ শপত কৰিছে যেতিয়া ই গমন কৰে।</h2>"
        },
        "34": {
            "verses": {
                "74:34": {
                    "id": 34
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>প্ৰভাতৰ শপত কৰিছে যেতিয়া ই ভালদৰে আলোকোজ্জ্বল হয়।</h2>"
        },
        "35": {
            "verses": {
                "74:35": {
                    "id": 35
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>বহুত ডাঙৰ পৰীক্ষাসমূহৰ ভিতৰত জাহান্নামৰ অগ্নিৰ শাস্তি অন্যতম।</p>"
        },
        "36": {
            "verses": {
                "74:36": {
                    "id": 36
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>মানুহক ভয়- ভীতি দেখুৱাবলৈ।</h2>"
        },
        "37": {
            "verses": {
                "74:37": {
                    "id": 37
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে মানৱ, তোমালোকৰ মাজত সেই ব্যক্তিৰ বাবে যিয়ে ঈমান আৰু সত্কৰ্মৰ জৰিয়তে আগবাঢ়িব বিচাৰে বা কুফুৰী তথা অবাধ্য পাপৰ জৰিয়তে পিছুৱাব বিচাৰে।</p>"
        },
        "38": {
            "verses": {
                "74:38": {
                    "id": 38
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>প্ৰত্যেক প্ৰাণীৰ গ্ৰেফতাৰী তাৰ কৰ্ম অনুসাৰে হব। হয়তো তেওঁৰ কৰ্ম তাক ধ্বংস কৰি পেলাব অথবা তাক ধ্বংসৰ পৰা ৰক্ষা।</p>"
        },
        "39": {
            "verses": {
                "74:39": {
                    "id": 39
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>মুমিনসকলৰ বাহিৰে, কিয়নো পাপৰ বাবে সিহঁতক গ্ৰেফতাৰী কৰা নহ'ব। সিহঁতৰ সত্কৰ্মৰ বাবে সিহঁতক ৰেহাই দিয়া হ'ব।</p>"
        },
        "40": {
            "verses": {
                "74:40": {
                    "id": 40
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু জান্নাতত তেওঁলোকে এজনে আনজনক সুধিব।</h2>"
        },
        "41": {
            "verses": {
                "74:41": {
                    "id": 41
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সেই কাফিৰ বিলাকৰ বিষয়ে যিহঁতে নিজৰ পাপসমূহৰ কাৰণে নিজকে ধ্বংসত পেলাব।</p>"
        },
        "42": {
            "verses": {
                "74:42": {
                    "id": 42
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেওঁলোকো সিহঁতক সুধিবঃ কিহে তোমালোকক জাহান্নামত প্ৰৱেশ কৰিছে?</p>"
        },
        "43": {
            "verses": {
                "74:43": {
                    "id": 43
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এতেকে কাফিৰ বিলাকে তেওঁলোকক উত্তৰ দি কবঃ আমি তেওঁলোকৰ অন্তৰ্ভুক্ত নাছিলো যিসকলে পাৰ্থিৱ জীৱনত ফৰজ ছালাত সমূহ আদায় কৰি আছিল।</p>"
        },
        "44": {
            "verses": {
                "74:44": {
                    "id": 44
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু আমি দুখীয়াক আল্লাহে দিয়া আমাৰ ধন-সম্পদৰ পৰা আহাৰ কৰোৱা নাছিলো।</p>"
        },
        "45": {
            "verses": {
                "74:45": {
                    "id": 45
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু আমি সকলো ক্ষেত্ৰতে বাতিল পন্থীৰ লগত যোগ দিছিলো আৰু পথভ্ৰষ্ট তথা পথচ্যুত হোৱা লোকৰ সৈতে বেহুদা আলোচনাত মগ্ন আছিলো।</p>"
        },
        "46": {
            "verses": {
                "74:46": {
                    "id": 46
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু আমি পৰিণামৰ দিনক অস্বীকাৰ কৰিছিলো।</h2>"
        },
        "47": {
            "verses": {
                "74:47": {
                    "id": 47
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>মৃত্যুলৈকে অস্বীকাৰৰ এই ধাৰাবাহিকতা চলি আছিল আৰু আমি চিৰকালৰ বাবে তাওবাৰ পৰা বঞ্চিত হৈছিলো।</p>"
        },
        "48": {
            "verses": {
                "74:48": {
                    "id": 48
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এতেকে ক্বিয়ামতৰ দিনা ছুপাৰিছকাৰীসকল অৰ্থাৎ ফিৰিস্তা, নবী আৰু সদাচাৰীসকলৰ ছুপাৰিছে সিহঁতৰ কোনো উপকাৰ নকৰিব। কিয়নো আল্লাহৰ ওচৰত ছুপাৰিছ গ্ৰহণ হ'বলৈ হ'লে, আল্লাহে সেই বান্দাৰ প্ৰতি সন্তুষ্ট হ'ব লাগিব, যাৰ বাবে ছুপাৰিছ কৰা হৈছে।</p>"
        },
        "49": {
            "verses": {
                "74:49": {
                    "id": 49
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>এই কাফিৰ বিলাকক কিহে কোৰআনৰ পৰা বিমুখ কৰিছে?</h2>"
        },
        "50": {
            "verses": {
                "74:50": {
                    "id": 50
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিহঁতৰ কোৰআনৰ পৰা বিমুখতা আৰু পলায়ন এনেকুৱা লাগে যেনিবা ভীতিগ্ৰস্ত হৈ পলায়ন কৰা বনৰীয়া গাধ।</p>"
        },
        "51": {
            "verses": {
                "74:51": {
                    "id": 51
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>যিবোৰ সিংহৰ ভয়ত পলায়।</h2>"
        },
        "52": {
            "verses": {
                "74:52": {
                    "id": 52
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>বৰং এই মুশ্বৰিক বিলাকৰ মাজত প্ৰত্যেক ব্যক্তিয়ে বিচাৰে যে, তাৰ মূৰৰ ওচৰত এখন খোলা কিতাপ হওক যিয়ে সিহঁতক কব যে, মুহাম্মদ চাল্লাল্লাহু আলাইহি অছাল্লাম আল্লাহৰ ৰাছুল। আৰু এইটো প্ৰমাণ কম বা দলিল দুৰ্বল হোৱাৰ কাৰণ নহয় বৰং ইয়াৰ কাৰণ হৈছে বিদ্বেষ আৰু অহংকাৰ।</p>"
        },
        "53": {
            "verses": {
                "74:53": {
                    "id": 53
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ঘটনাটো তেনে নহয়। বৰং সিহঁতে পথভ্ৰষ্টৰ ফালে বিচলিত হোৱাৰ কাৰণ এইটো যে সিহঁতে পৰকালৰ শাস্তিৰ প্ৰতি ঈমান নাৰাখে। এই কাৰণে নিজৰ কুফুৰীৰ প্ৰতি অটুট আছিল।</p>"
        },
        "54": {
            "verses": {
                "74:54": {
                    "id": 54
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
