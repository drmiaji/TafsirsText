{
    "chapter": 86,
    "verses": {
        "1": {
            "verses": {
                "86:1": {
                    "id": 1
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আল্লাহ তাআলাই আকাশৰ শপত কৰিছে তথা ৰাতিত দেখা দিয়া তৰাৰ শপত কৰিছে।</p>"
        },
        "2": {
            "verses": {
                "86:2": {
                    "id": 2
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>হে ৰাছুল! আপুনি এই মহত্বপূৰ্ণ তৰাৰ বিষয়ে কি জানে?</h2>"
        },
        "3": {
            "verses": {
                "86:3": {
                    "id": 3
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>এইটো সেই তৰা যিটো নিজৰ তীব্ৰ কিৰণেৰে আকাশ আলোকিত কৰে।</h2>"
        },
        "4": {
            "verses": {
                "86:4": {
                    "id": 4
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>প্ৰত্যক প্ৰাণীৰ ওপৰত আল্লাহ তাআলাই এজনকৈ ফিৰিস্তা নিযুক্তি দিছে, যিয়ে তাৰ কৰ্মবোৰ পৰ্যবেক্ষণ কৰি থাকে। যাতে ক্বিয়ামতৰ দিনা তাৰ হিচাপ- নিকাচ হব পাৰে।</p>"
        },
        "5": {
            "verses": {
                "86:5": {
                    "id": 5
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>মানুহে চিন্তা কৰা উচিত যে, আল্লাহ তাআলাই তেওঁলোকক কি বস্তুৰে সৃষ্টি কৰিছে। যাতে সিহঁতৰ আগত আল্লাহৰ ক্ষমতা প্ৰকাশ কৰিব পাৰে আৰু মানুহৰ দূৰ্বলতা স্পষ্ট হৈ যায়।</p>"
        },
        "6": {
            "verses": {
                "86:6": {
                    "id": 6
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আল্লাহ তাআলাই মানুহক এনেকুৱা পানীৰে সৃষ্টি কৰিছে, যি পানী নিৰ্গত হৈ গৰ্ভাশয়ত প্ৰৱেশ কৰে।</p>"
        },
        "7": {
            "verses": {
                "86:7": {
                    "id": 7
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>এই পানী নিৰ্গত হয় মেৰুদণ্ড আৰু বুকুৰ হাড়ৰ মাজৰ পৰা।</h2>"
        },
        "8": {
            "verses": {
                "86:8": {
                    "id": 8
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যদি আল্লাহ তাআলাই মানুহক এই তুচ্ছ পানীৰ দ্বাৰা সৃষ্টি কৰিব পাৰে তেন্তে তাৰ মৃত্যুৰ পিছত হিচাপ- নিকাচৰ বাবে তাক পুনৰ জীৱিত কৰি উত্থিত কৰাৰো ক্ষমতা ৰাখে।</p>"
        },
        "9": {
            "verses": {
                "86:9": {
                    "id": 9
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যিদিনাখন মনৰ ভেদ পৰ্যবেক্ষণ কৰা হব সিদিনা অন্তৰৰ ভিতৰত থকা গোপন নিয়ত আৰু আস্থা বা আক্বীদাহবোৰ প্ৰকাশ কৰা হব আৰু এনেদৰে সৎ আৰু অসৎ চিনাক্ত হৈ যাব।</p>"
        },
        "10": {
            "verses": {
                "86:10": {
                    "id": 10
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিদিনা মানুহৰ ওচৰত কোনো শক্তি নাথাকিব যাৰ দ্বাৰা তেওঁ আল্লাহৰ শাস্তিৰ পৰা ৰক্ষা পাব পাৰিব আৰু কোনো সহায়কাৰীও নাথাকিব, যিয়ে তাৰ সহায় কৰিব পাৰিব।</p>"
        },
        "11": {
            "verses": {
                "86:11": {
                    "id": 11
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আল্লাহ তাআলাই বৰষুণযুক্ত আকাশৰ শপত কৰিছে, কিয়নো বৰষুণ আকাশৰ পৰাই বাৰে বাৰে বৰ্ষণ হয়।</p>"
        },
        "12": {
            "verses": {
                "86:12": {
                    "id": 12
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু পৃথিৱীৰ শপত কৰিছে যিটো ফাট মেলে আৰু তাৰ পৰা বনলতা, ফল আৰু গছ-বৃক্ষ গজে।</p>"
        },
        "13": {
            "verses": {
                "86:13": {
                    "id": 13
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>অৱশ্যে মুহাম্মদ চাল্লাল্লাহু আলাইহি অছাল্লামৰ প্ৰতি অৱতীৰ্ণ হোৱা কোৰআন এনেকুৱা বাণী যিয়ে হক আৰু বাতিল তথা সঁচা আৰু মিছাৰ মাজত পাৰ্থক্য কৰি দিয়ে।</p>"
        },
        "14": {
            "verses": {
                "86:14": {
                    "id": 14
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এয়া কোনো খেল- ধেমালি আৰু অযথা গল্প নহয় বৰঞ্চ বাস্তৱিকতা আৰু সত্য।</p>"
        },
        "15": {
            "verses": {
                "86:15": {
                    "id": 15
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>নিশ্চিতৰূপে ৰাছুলে লৈ অহা চৰীয়তক অস্বীকাৰকাৰী সকলে তেওঁৰ বিৰুদ্ধে ভীষণ ষড়যন্ত্ৰ কৰে, যাতে তেওঁৰ দাৱাত বন্ধ হয় আৰু এই চৰীয়তক বিনাশ কৰিব পাৰে।</p>"
        },
        "16": {
            "verses": {
                "86:16": {
                    "id": 16
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ময়ো ইছলাম প্ৰকাশ কৰিবলৈ আৰু মিথ্যাক বিতাড়িত কৰিবলৈ কৌশল কৰিছো।</p>"
        },
        "17": {
            "verses": {
                "86:17": {
                    "id": 17
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে ৰাছুল ! এতেকে এই কাফিৰসকলক কিছু সময় অৱকাশ দিয়ক আৰু সিহঁতৰ বাবে শীঘ্ৰে শাস্তি আৰু ধ্বংস নিবিচাৰিব।</p>"
        }
    }
}