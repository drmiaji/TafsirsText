{
    "chapter": 82,
    "verses": {
        "1": {
            "verses": {
                "82:1": {
                    "id": 1
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>যেতিয়া আকাশখন ফাঁটি যাব, যাতে তাৰ পৰা ফিৰিস্তাসকল নামি আহে।</h2>"
        },
        "2": {
            "verses": {
                "82:2": {
                    "id": 2
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু যেতিয়া নক্ষত্ৰবোৰ বিক্ষিপ্তভাৱে খহি পৰিব।</h2>"
        },
        "3": {
            "verses": {
                "82:3": {
                    "id": 3
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যেতিয়া সাগৰসমূহক এটাক আন এটাৰ বাবে খুলি দিয়া হব। আৰু সেইবোৰ পৰস্পৰে মিলিত হব।</p>"
        },
        "4": {
            "verses": {
                "82:4": {
                    "id": 4
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যেতিয়া কবৰবোৰৰ মাটি ওলোটাই দিয়া হব, তাৰ ভিতৰত থকা মৃত ব্যক্তিক পুনৰ্জীৱিত কৰাৰ বাবে।</p>"
        },
        "5": {
            "verses": {
                "82:5": {
                    "id": 5
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেতিয়া প্ৰত্যেক ব্যক্তিয়ে জানিব পাৰিব যে, তেওঁ কোনটো কাম কৰিছে আৰু কোনটো পিছফালে এৰি আহিছে অৰ্থাৎ কৰা নাই।</p>"
        },
        "6": {
            "verses": {
                "82:6": {
                    "id": 6
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে নিজ প্ৰতিপালকক অস্বীকাৰকাৰী সকল! কিহে তোমালোকক তোমালোকৰ প্ৰতিপালকৰ আদেশৰ অমান্য কৰিবলৈ উদগনি দিছে। যিহেতু তেওঁ তোমালোকক সুযোগ দিছে আৰু নিজ অনুগ্ৰহৰে শাস্তি প্ৰদানত খৰখেদা কৰা নাই।</p>"
        },
        "7": {
            "verses": {
                "82:7": {
                    "id": 7
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যিয়ে তোমাক অনস্থিত্বৰ পৰা অস্থিত্বলৈ আনিছে আৰু সঠিক অংগযুক্ত সন্তুলিত শৰীৰ প্ৰদান কৰিছে।</p>"
        },
        "8": {
            "verses": {
                "82:8": {
                    "id": 8
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যি ৰূপত তোমাক সৃষ্টি কৰিবলৈ ইচ্ছা কৰিছে সেই ৰূপতে সৃষ্টি কৰিছে। আৰু তোমাৰ প্ৰতি অনুগ্ৰহ কৰিছে যে, তোমাক গাধা, বান্দৰ আৰু কুকুৰ আদিৰ ৰূপত সৃষ্টি কৰা নাই।</p>"
        },
        "9": {
            "verses": {
                "82:9": {
                    "id": 9
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে প্ৰৱঞ্চিত সকল! ঘটনা তেনেকুৱা নহয় যিদৰে তোমালোকে বুজিছা। সত্যতা হৈছে এই যে, তোমালোকে প্ৰতিদান দিৱসক অস্বীকাৰ কৰা আৰু তাৰ বাবে কোনো প্ৰস্তুতি নকৰা।</p>"
        },
        "10": {
            "verses": {
                "82:10": {
                    "id": 10
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তোমালোকৰ প্ৰতি এনেকুৱা ফিৰিস্তা নিযুক্ত আছে যিসকলে তোমালোকৰ আমলসমূহ লিখি থাকে।</p>"
        },
        "11": {
            "verses": {
                "82:11": {
                    "id": 11
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আল্লাহৰ ওচৰত তেওঁলোক সন্মানিত, তোমালোকৰ আমল লিখি থাকে।</h2>"
        },
        "12": {
            "verses": {
                "82:12": {
                    "id": 12
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তেওঁলোকে তোমালোকৰ প্ৰত্যেক কৰ্মৰ বিষয়ে অৱগত আৰু সেয়া লিখি লয়।</p>"
        },
        "13": {
            "verses": {
                "82:13": {
                    "id": 13
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>নিশ্চয় অধিক অধিক ভাল কৰ্মকাৰী আৰু আনুগত্যকাৰী সকলে ক্বিয়ামতৰ দিনা এনেকুৱা নিয়ামতৰ মাজত থাকিব যিটো হব চিৰস্থায়ী।</p>"
        },
        "14": {
            "verses": {
                "82:14": {
                    "id": 14
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু দূৰাচাৰী লোকসকল এনেকুৱা জুইৰ মাজত থাকিব যিটো হব অত্যন্ত উত্তপ্ত।</p>"
        },
        "15": {
            "verses": {
                "82:15": {
                    "id": 15
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিহঁতে প্ৰতিদান দিৱসত তাৰ ভিতৰত প্ৰৱেশ কৰিব আৰু তাৰ উত্তাপৰ সন্মুখীন হব।</p>"
        },
        "16": {
            "verses": {
                "82:16": {
                    "id": 16
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু তেওঁলোকে তাৰ পৰা কেতিয়াওঁ অদৃশ্য হব নোৱাৰে। বৰঞ্চ তাৰ ভিতৰতে থাকিব।</p>"
        },
        "17": {
            "verses": {
                "82:17": {
                    "id": 17
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>হে ৰাছুল ! আপোনাক কিহে জনাব যে প্ৰতিদান দিৱস কি?</h2>"
        },
        "18": {
            "verses": {
                "82:18": {
                    "id": 18
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আকৌ কৈছো, কিহে তোমাক জনাব প্ৰতিদান দিৱস কি?</h2>"
        },
        "19": {
            "verses": {
                "82:19": {
                    "id": 19
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সিদিনাখন কোনেও কাৰো উপকাৰ কৰিব নোৱাৰিব আৰু সেই দিনা সকলো ক্ষমতা কেৱল আল্লাহৰ হাতত থাকিব। তেওঁ যি ইচ্ছা কৰিব সেইটোৱে কৰিব। আন কাৰো হাতত এনেকুৱা কোনো ক্ষমতা নাথাকিব।</p>"
        }
    }
}