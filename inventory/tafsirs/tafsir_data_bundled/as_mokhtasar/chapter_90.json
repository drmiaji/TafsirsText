{
    "chapter": 90,
    "verses": {
        "1": {
            "verses": {
                "90:1": {
                    "id": 1
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আল্লাহ তাআলাই সন্মানিত মক্কা নগৰৰ শপত কৰিছে।</h2>"
        },
        "2": {
            "verses": {
                "90:2": {
                    "id": 2
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু হে ৰাছুল! আপোনাৰ বাবে এই নগৰত হত্যাকাৰীক হত্যা কৰা আৰু গ্ৰেফতাৰ কৰিবলগীয়া ব্যক্তিক গ্ৰেফতাৰ কৰিবলৈ বৈধ কৰা হৈছে।</p>"
        },
        "3": {
            "verses": {
                "90:3": {
                    "id": 3
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আল্লাহে মানৱ জাতিৰ পিতা আৰু তাৰ বংশৰ পৰা জন্ম লাভ কৰা সন্তানৰ শপত কৰিছে।</p>"
        },
        "4": {
            "verses": {
                "90:4": {
                    "id": 4
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আমি মানুহক ক্লান্ত আৰু কঠিনতাৰে আৱদ্ধ কৰি সৃষ্টি কৰিছো। সেয়ে সিহঁতে পৃথিৱীত সদায় কঠিনতাৰ সন্মুখীন হৈ থাকে।</p>"
        },
        "5": {
            "verses": {
                "90:5": {
                    "id": 5
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>মানুহে ভাৱিছে নেকি যে, যদি সিহঁতে পাপ কৰে তেন্তে তাৰ ওপৰত কোনো ক্ষমতা নচলিব আৰু কোনেও তাক শাস্তি প্ৰদান নকৰিব, যদিও তাৰ প্ৰতিপালক হয়, যিজনে তাক সৃষ্টি কৰিছে?</p>"
        },
        "6": {
            "verses": {
                "90:6": {
                    "id": 6
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>সি কয় যে, মই বহুতো ধন খৰচ কৰিছোঁ, ইখনৰ পিছত ইখন।</h2>"
        },
        "7": {
            "verses": {
                "90:7": {
                    "id": 7
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>খৰচ কৰাৰ ক্ষেত্ৰত গৰ্বকাৰী ব্যক্তিয়ে ভাবিছে নেকি যে, আল্লাহ তাআলাই তাক দেখা নাই, আৰু সি ভাৱিছে নেকি যে, তাৰ সম্পদৰ হিচাপ লোৱা নহব, সেয়া কৰ পৰা অৰ্জন কৰিছে আৰু কত খৰচ কৰিছে?</p>"
        },
        "8": {
            "verses": {
                "90:8": {
                    "id": 8
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>দেখিবলৈ আমি তাক দুটা চকু দিয়া নাইনে?</h2>"
        },
        "9": {
            "verses": {
                "90:9": {
                    "id": 9
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু কথা কবলৈ এখন জিভা আৰু দুটা ওঠঁ দিয়া নাইনে?</h2>"
        },
        "10": {
            "verses": {
                "90:10": {
                    "id": 10
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু আমি তাক সত্য আৰু অসত্য পথৰ পৰিচয় দিয়া নাইনে?</h2>"
        },
        "11": {
            "verses": {
                "90:11": {
                    "id": 11
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সি এই কথাৰ অপেক্ষাত আছে যে, সেই দুৰ্গম গিৰিপথ পাৰ কৰিব যিটো তাক জান্নাতৰ পৰা পৃথক কৰে।</p>"
        },
        "12": {
            "verses": {
                "90:12": {
                    "id": 12
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু হে ৰাছুল! আপোনাক কিহে জনাব যে, দুৰ্গম গিৰিপথ কি যিটো সি জান্নাতত প্ৰৱেশ কৰিবলৈ পাৰ হব লাগিব?</p>"
        },
        "13": {
            "verses": {
                "90:13": {
                    "id": 13
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>সেয়া হৈছে দাসমুক্তি পুৰুষ হওঁক বা মহিলা।</h2>"
        },
        "14": {
            "verses": {
                "90:14": {
                    "id": 14
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>এয়া এক এনেকুৱা দুৰ্ভিক্ষৰ দিন যেতিয়া খাদ্য পোৱা কঠিন হয়।</h2>"
        },
        "15": {
            "verses": {
                "90:15": {
                    "id": 15
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এনেকুৱা দৰিদ্ৰ শিশু, যিয়ে তাৰ পিতৃৰ ছাঁৰ পৰা বঞ্চিত হৈছে আৰু কিন্তু তাৰ আত্মীয় আছে।</p>"
        },
        "16": {
            "verses": {
                "90:16": {
                    "id": 16
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>অথবা এনেকুৱা দৰিদ্ৰ যিয়ে কোনো বস্তুৰ গৰাকী নহয়।</h2>"
        },
        "17": {
            "verses": {
                "90:17": {
                    "id": 17
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ পিছত সি এনেকুৱা লোকৰ অন্তৰ্ভুক্ত হব যিয়ে আল্লাহৰ প্ৰতি ঈমান আনিছে আৰু এজনে আনজক সত্কৰ্মৰ প্ৰতি অটুট থাকিবলৈ আৰু পাপ কামৰ পৰা বিৰত থাকিবলৈ আৰু বিপদৰ সময়ত ধৈৰ্য ধাৰণ কৰিবলৈ গুৰুত্ব প্ৰদান কৰে তথা এজনে আনজনক আল্লাহৰ বান্দাৰ প্ৰতি দয়া কৰিবলৈ গুৰুত্ব প্ৰদান কৰে।</p>"
        },
        "18": {
            "verses": {
                "90:18": {
                    "id": 18
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>এই বৈশিষ্ট্যসমূহৰ অধিকাৰী ব্যক্তি সকলেই সোঁ ফালৰ গৰাকী।</h2>"
        },
        "19": {
            "verses": {
                "90:19": {
                    "id": 19
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু যিসকলে ৰাছুলৰ প্ৰতি অৱতীৰ্ণ আয়াতবোৰ অস্বীকাৰ কৰে সিহঁতেই বাওঁ হাতৰ গৰাকী।</p>"
        },
        "20": {
            "verses": {
                "90:20": {
                    "id": 20
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>এনেকুৱা লোকেই আৱদ্ধ অগ্নিৰে পৰিবেষ্টিত হব, যাৰ শাস্তি কেৱল সিহঁতকেই দিয়া হব।</p>"
        }
    }
}