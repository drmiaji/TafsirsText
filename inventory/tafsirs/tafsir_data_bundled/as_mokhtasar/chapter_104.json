{
    "chapter": 104,
    "verses": {
        "1": {
            "verses": {
                "104:1": {
                    "id": 1
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>বিনাশ আৰু কঠোৰ শাস্তি সেই সকল লোকৰ বাবে, যিসকলে মানুহৰ বহুত পৰিমাণে পৰচৰ্চা কৰে আৰু সিহঁতক গৰিহণা দি ফুৰে।</p>"
        },
        "2": {
            "verses": {
                "104:2": {
                    "id": 2
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>যাৰ একমাত্ৰ উদ্দেশ্য হৈছে ধন জমা কৰা আৰু সেয়া বাৰে বাৰে গণনা কৰি ৰখা। ইয়াৰ বাহিৰে তাৰ আৰু আন কোনো উদ্দেশ্য নাই।</p>"
        },
        "3": {
            "verses": {
                "104:3": {
                    "id": 3
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>সি ভাৱে যে, তাৰ ধন-সম্পদ, যিবোৰ সি জমা কৰিছে, সেইবোৰে তাক মৃত্যুৰ পৰা বচাব আৰু পৃথিৱীত অমৰ হৈ থাকিব।</p>"
        },
        "4": {
            "verses": {
                "104:4": {
                    "id": 4
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>বিষয়টো তেনেকুৱা নহয় যিদৰে এই মূৰ্খই ভাবিছে। নিশ্চয় তাক জাহান্নামৰ জুইত নিক্ষেপ কৰা হব। যি জুয়ে তাৰ মাজত নিক্ষেপ কৰা সকলো বস্তুকে ধূলি কণা বনাই দিয়ে।</p>"
        },
        "5": {
            "verses": {
                "104:5": {
                    "id": 5
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>হে ৰাছুল, আপোনাক কিহে জনাব যে সেই অগ্নি কি?</h2>"
        },
        "6": {
            "verses": {
                "104:6": {
                    "id": 6
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>সেয়া আল্লাহৰ অতি উত্তপ্ত অগ্নি।</h2>"
        },
        "7": {
            "verses": {
                "104:7": {
                    "id": 7
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>যিয়ে মানুহৰ শৰীৰ অতিক্ৰম কৰি তাৰ অন্তৰলৈ ঢুকি পাব।</h2>"
        },
        "8": {
            "verses": {
                "104:8": {
                    "id": 8
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>তাৰ ভিতৰত শাস্তি দিয়া ব্যক্তিসকলৰ কাৰণে সেইটো বন্ধ কৰি দিয়া হব।</p>"
        },
        "9": {
            "verses": {
                "104:9": {
                    "id": 9
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>দীঘল দীঘল স্তম্ভৰ সৈতে, যাতে ওলাব নোৱাৰে।</h2>"
        }
    }
}