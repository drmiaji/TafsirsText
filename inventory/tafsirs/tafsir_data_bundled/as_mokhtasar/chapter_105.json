            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>হে ৰাছুল, আপুনি নাজানে নেকি আপোনাৰ প্ৰতিপালকে আবৰাহা আৰু তাৰ হাতী অধিপতি সৈন্যৰ সৈতে কি কৰিছিল, যেতিয়া সিহঁতে কাবা ঘৰ ভাঙিবলৈ সংকল্প কৰিছিল।</p>"
        },
        "2": {
            "verses": {
                "105:2": {
                    "id": 2
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আল্লাহ তাআলাই সিহঁতৰ কাবা ধ্বংস কৰাৰ চক্ৰান্ত বিফল কৰি দিছিল। ফলত সিহঁতে মানুহক কাবাৰ পৰা বিমুখ কৰাৰ যি সংকল্প লৈছিল, তাত সিহঁতে সফলতা পোৱা নাছিল আৰু নিৰাশ হৈ উভতিছিল।</p>"
        },
        "3": {
            "verses": {
                "105:3": {
                    "id": 3
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>আৰু সিহঁতৰ প্ৰতি জাকে জাকে চৰাই পঠাইছিল।</h2>"
        },
        "4": {
            "verses": {
                "105:4": {
                    "id": 4
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>যিবোৰে সিহঁতৰ ওপৰত টান মাটিৰ শিলগুটি নিক্ষেপ কৰিছিল।</h2>"
        },
        "5": {
            "verses": {
                "105:5": {
                    "id": 5
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ফলত সিহঁতক সেই ভক্ষিত তৃণ সদৃশ কৰিছিল, যিবোৰ জন্তুয়ে খায় আৰু ভৰিৰে মোহাৰি চেপেটা কৰে।</p>"
        }
    }
