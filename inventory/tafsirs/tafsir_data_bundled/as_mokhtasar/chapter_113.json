            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>কষ্টদায়ক সৃষ্টিৰ অনিষ্টৰ পৰা।</h2>"
        },
        "3": {
            "verses": {
                "113:3": {
                    "id": 3
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু মই আল্লাহৰ আশ্ৰয় বিচাৰো সেইবোৰ কষ্টদায়ক বস্তুৰ পৰা যিবোৰ ৰাতিত ওলায়। যেনে- কীট- পতংগ, চোৰ আদি।</p>"
        },
        "4": {
            "verses": {
                "113:4": {
                    "id": 4
                }
            },
            "resource_id": 117,
            "resource_name": "Tafsir As Mokhtasar",
            "language_id": 38,
            "slug": "as_mokhtasar",
            "translated_name": {
                "name": "Tafsir As Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>আৰু আল্লাহৰ আশ্ৰয় বিচাৰিছো যাদুকৰ মহিলাৰ অনিষ্টৰ পৰা, যিসকলে গাঁঠিত ফুঁ দিয়ে।</p>"
        },
        "5": {
