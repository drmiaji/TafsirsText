            "translated_name": {
                "name": "Tafsir Ru Ibnkathir",
                "language_name": "english"
            },
            "text": "<h2>Разве Он не запутал их козни</h2>"
        },
        "3": {
            "verses": {
                "105:3": {
                    "id": 3
                }
            },
            "resource_id": 138,
            "resource_name": "Tafsir Ru Ibnkathir",
            "language_id": 38,
            "slug": "ru_ibnkathir",
            "translated_name": {
                "name": "Tafsir Ru Ibnkathir",
                "language_name": "english"
            },
            "text": "<h2>и не наслал на них птиц стаями? - значит группами ,</h2>"
        },
        "4": {
            "verses": {
                "105:4": {
                    "id": 4
                }
            },
            "resource_id": 138,
            "resource_name": "Tafsir Ru Ibnkathir",
