                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿كُوِّرَتۡ﴾: لُفَّتْ، وَذَهَبَ ضَوْءُها.</h2>"
        },
        "2": {
            "verses": {
                "81:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱنكَدَرَتۡ﴾: تَنَاثَرَتْ، فَذَهَبَ نُورُها.</h2>"
        },
        "3": {
            "verses": {
                "81:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿سُيِّرَتۡ﴾: سُيِّرَتْ عن وَجْهِ الأرْضِ فَصَارَتْ هَباءً.</h2>"
        },
        "4": {
            "verses": {
                "81:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡعِشَارُ﴾: النُوقُ الحوامِلُ.</h2>\n<h2>﴿عُطِّلَتۡ﴾: تُرِكَتْ وَأُهْمِلَتْ.</h2>"
        },
        "5": {
            "verses": {
                "81:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡوُحُوشُ﴾: الحيواناتُ الوَحْشِيَّةُ.</h2>\n<p>﴿حُشِرَتۡ﴾: جُمِعَتْ واخْتَلَطَتْ، لِيَقْتَصَّ اللهُ مِن بَعْضِها لِبَعْضٍ.</p>"
        },
        "6": {
            "verses": {
                "81:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿سُجِّرَتۡ﴾: أُوقِدَتْ.</h2>"
        },
        "7": {
            "verses": {
                "81:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿زُوِّجَتۡ﴾: قُرِنَتْ بأَمثالِها.</h2>"
        },
        "8": {
            "verses": {
                "81:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡمَوۡءُۥدَةُ﴾: الطِّفْلةُ المدفُونةُ حَيَّةً.</h2>\n<h2>﴿سُئِلَتۡ﴾: سُؤالَ تَطْيِيبٍ لها وَلَومٍ لِوائِدِها.</h2>"
        },
        "9": {
            "verses": {
                "81:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
