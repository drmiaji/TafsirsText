            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ذِكۡرٞ﴾: مَوعِظَةٌ.</h2>"
        },
        "28": {
            "verses": {
