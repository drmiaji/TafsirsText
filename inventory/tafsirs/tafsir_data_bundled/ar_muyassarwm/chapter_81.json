            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلصُّحُفُ﴾: صُحُفُ الأَعْمالِ.</h2>\n<h2>﴿نُشِرَتۡ﴾: عُرِضَتْ.</h2>"
        },
        "11": {
            "verses": {
                "81:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿كُشِطَتۡ﴾: أُزِيلَتْ مِن مَكانِها.</h2>"
        },
        "12": {
            "verses": {
                "81:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿سُعِّرَتۡ﴾: أُوقِدَتْ.</h2>"
        },
        "13": {
            "verses": {
                "81:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أُزۡلِفَتۡ﴾: قُرِّبَتْ مِنْ أهْلِها.</h2>"
        },
        "14": {
            "verses": {
                "81:14": {
                    "id": 14
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَحۡضَرَتۡ﴾: قَدَّمَتْ من خَيرٍ أو شَرٍّ.</h2>"
        },
        "15": {
            "verses": {
                "81:15": {
                    "id": 15
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿بِٱلۡخُنَّسِ﴾: بِالنُّجُومِ المُخْتَفِيَةِ أَنْوَارُها نهاراً.</p>"
        },
        "16": {
            "verses": {
                "81:16": {
                    "id": 16
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡجَوَارِ﴾: الجارِيةِ.</h2>\n<h2>﴿ٱلۡكُنَّسِ﴾: المسْتَتِرَةِ في أَبْراجِها.</h2>"
        },
        "17": {
            "verses": {
                "81:17": {
                    "id": 17
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿عَسۡعَسَ﴾: أَقْبَلَ بِظَلامِهِ.</h2>"
        },
        "18": {
            "verses": {
                "81:18": {
                    "id": 18
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿تَنَفَّسَ﴾: ظَهَرَ ضِياؤُه.</h2>"
        },
        "19": {
            "verses": {
                "81:19": {
                    "id": 19
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿إِنَّهُۥ﴾: إِنَّ القُرآنَ.</h2>\n<h2>﴿رَسُولٖ كَرِيمٖ﴾: هو جِبْرِيلُ، عَلَيه السَّلامُ.</h2>"
        },
        "20": {
            "verses": {
                "81:20": {
                    "id": 20
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ذِي ٱلۡعَرۡشِ﴾: صَاحِبِ العَرْشِ، وَهُوَ اللهُ.</h2>\n<h2>﴿مَكِينٖ﴾: صاحبِ مَكانَةٍ رَفِيعَةٍ.</h2>"
        },
        "21": {
            "verses": {
                "81:21": {
                    "id": 21
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ثَمَّ﴾: هُنَاكَ.</h2>\n<h2>﴿أَمِينٖ﴾: مُؤْتَمَنٍ على الوَحْيِ الَّذِي يَنْزِلُ بِه.</h2>"
        },
        "22": {
            "verses": {
                "81:22": {
                    "id": 22
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿صَاحِبُكُم﴾: مُحَمَّدٌ ﷺ الَّذِي تَعْرِفُونَهُ.</h2>"
        },
        "23": {
            "verses": {
                "81:23": {
                    "id": 23
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَلَقَدۡ رَءَاهُ﴾: وَلَقَدْ رَأَى مُحَمَّدٌ ﷺ جِبْرِيلَ.</h2>\n<h2>﴿بِٱلۡأُفُقِ ٱلۡمُبِينِ﴾: بالأُفُقِ العَظِيمِ.</h2>"
        },
        "24": {
            "verses": {
                "81:24": {
                    "id": 24
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿عَلَى ٱلۡغَيۡبِ﴾: بِتَبْلِيغ الوَحْيِ.</h2>\n<h2>﴿بِضَنِينٖ﴾: ببَخِيلٍ.</h2>"
        },
        "25": {
            "verses": {
                "81:25": {
                    "id": 25
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿رَجِيمٖ﴾: مَطْرُودٍ مِن رَحْمَةِ اللهِ.</h2>"
        },
        "26": {
            "verses": {
                "81:26": {
                    "id": 26
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿فَأَيۡنَ تَذۡهَبُونَ﴾: فَأَينَ تَذْهَبُ بِكُم عُقُولُكُم في التَّكْذِيبِ بالقُرآنِ بَعْدَ هذِه الحُجَجِ القاطِعَةِ؟</p>"
        },
        "27": {
            "verses": {
