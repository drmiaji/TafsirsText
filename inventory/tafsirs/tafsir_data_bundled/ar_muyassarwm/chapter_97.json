            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَآ أَدۡرَىٰكَ﴾: وأيُّ شَيءٍ أَعْلَمَكَ؟</h2>"
        },
        "3": {
            "verses": {
                "97:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿خَيۡرٞ مِّنۡ أَلۡفِ شَهۡرٖ﴾: فَضْلُها خَيرٌ مِن فَضْلِ أَلْفِ شَهْرٍ.</p>"
        },
        "4": {
            "verses": {
                "97:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿تَنَزَّلُ ٱلۡمَلَٰٓئِكَةُ وَٱلرُّوحُ فِيهَا﴾: يَكْثُرُ نُزُولُ الملائِكةِ وَجِبْريلَ عَلَيهِ السَّلامُ فِيها.</p>\n<h2>﴿بِإِذۡنِ رَبِّهِم﴾: أي: في النُّزُولِ.</h2>\n<p>﴿مِن كُلِّ أَمۡرٖ﴾: مِنْ أَجْلِ كُلِّ أَمْرٍ أرادَ اللهُ قَضاءَه في تِلْك السَّنةِ.</p>"
        },
        "5": {
            "verses": {
                "97:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
