                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَنزَلۡنَٰهُ﴾: أَنْزَلْنا القُرآنَ.</h2>\n<p>﴿لَيۡلَةِ ٱلۡقَدۡرِ﴾: لَيْلَةِ الشَّرَفِ والفَضْلِ، وهي إِحْدَى لَيالِي شَهْرِ رَمَضانَ.</p>"
        },
        "2": {
            "verses": {
                "97:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
