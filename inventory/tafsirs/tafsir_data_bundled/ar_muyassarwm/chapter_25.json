            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿صَرَّفۡنَٰهُ بَيۡنَهُمۡ﴾: أنْزَلْنا المَطَرَ على أَنْحاءٍ مُخْتَلِفَةٍ.</p>\n<h2>﴿كُفُورٗا﴾: جُحُوداً بالنِّعمَةِ.</h2>"
        },
        "51": {
            "verses": {
