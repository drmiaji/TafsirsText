            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلسِّرَّ﴾: هو كلُّ ما يَغِيبُ ويَخْفَى.</h2>"
        },
        "7": {
            "verses": {
