            },
            "text": "<h2>﴿جَنَّٰتٖ﴾: بَسَاتِينَ وحَدَائقَ.</h2>\n<h2>﴿قُصُورَۢا﴾: بُيُوتاً مُشَيَّدةً.</h2>"
        },
        "11": {
            "verses": {
                "25:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
