                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿تَغَيُّظٗا﴾: صَوْتَ غَلَيانٍ وفَوَرانٍ.</h2>\n<h2>﴿وَزَفِيرٗا﴾: النَّفَسَ الخارِجَ مِنَ الجَوفِ بِشِدَّةٍ.</h2>"
        },
        "13": {
            "verses": {
                "25:13": {
                    "id": 13
