            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿نُفُورٗا﴾: تَبَاعُداً عَنِ الإِيمانِ.</h2>"
        },
        "61": {
            "verses": {
                "25:61": {
                    "id": 61
                }
