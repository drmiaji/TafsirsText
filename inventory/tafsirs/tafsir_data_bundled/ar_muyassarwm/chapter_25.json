                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَأَعۡتَدۡنَا﴾: وجَعَلْناه مُعَدّاً لهم.</h2>\n<h2>﴿سَعِيرًا﴾: أي: ناراً مُشْتَعِلةً تُسَعَّر بهم.</h2>"
        },
        "12": {
            "verses": {
                "25:12": {
                    "id": 12
