                "language_name": "english"
            },
            "text": "<h2>﴿وَزِيرٗا﴾: مُعِيناً لِتَبْلِيغِ الرِّسالةِ.</h2>"
        },
        "36": {
            "verses": {
                "25:36": {
                    "id": 36
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
