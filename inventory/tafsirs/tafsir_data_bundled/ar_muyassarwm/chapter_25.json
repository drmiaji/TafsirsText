            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿هَوۡنٗا﴾: أي: بسَكِينَةٍ وتَوَاضُعٍ.</h2>\n<p>﴿قَالُواْ سَلَٰمٗا﴾: أي: قالُوا قَوْلاً سَدِيداً يَسْلَمُونَ بهِ مِنَ الأذَى.</p>"
        },
        "64": {
            "verses": {
                "25:64": {
                    "id": 64
                }
