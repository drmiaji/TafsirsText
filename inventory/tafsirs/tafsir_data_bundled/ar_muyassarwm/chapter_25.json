            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مَقِيلٗا﴾: مَكَاناً للرَّاحَةِ وقتَ القَيْلُولَةِ.</h2>"
        },
        "25": {
            "verses": {
