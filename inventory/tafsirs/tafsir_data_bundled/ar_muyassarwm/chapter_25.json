            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿إِن كَادَ﴾: إنَّه قارَبَ.</h2>"
        },
        "43": {
            "verses": {
                "25:43": {
                    "id": 43
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
