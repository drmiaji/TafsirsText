            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿هُزُوًا﴾: مُسْتَهْزَأً بِه.</h2>"
        },
        "42": {
            "verses": {
                "25:42": {
                    "id": 42
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
