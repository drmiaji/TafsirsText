            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلذِّكۡرِ﴾: أي: القرآنِ والإيمانِ به.</h2>\n<p>﴿خَذُولٗا﴾: كثيرَ الخِذْلَانِ لِمَنْ يُوالِيهِ، والخِذْلَانُ: التَّخَلِّي عَنِ النُّصْرَةِ.</p>"
        },
        "30": {
            "verses": {
                "25:30": {
                    "id": 30
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
