            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿خِلۡفَةٗ﴾: يَخْلُفُ أحدُهما الآخَرَ؛ فَيَتَعاقَبَانِ.</h2>\n<h2>﴿أَن يَذَّكَّرَ﴾: أن يَعْتَبرَ.</h2>"
        },
        "63": {
            "verses": {
                "25:63": {
                    "id": 63
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
