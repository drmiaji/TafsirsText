                "language_name": "english"
            },
            "text": "<h2>﴿خَلِيلٗا﴾: صَدِيقاً.</h2>"
        },
        "29": {
            "verses": {
                "25:29": {
                    "id": 29
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
