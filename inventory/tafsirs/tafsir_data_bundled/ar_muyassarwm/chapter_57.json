            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿جَعَلَكُم مُّسۡتَخۡلَفِينَ﴾: جَعَلَها في أَيْدِيكُم، واسْتَخْلَفَكُم عَلَيها.</p>"
        },
        "8": {
            "verses": {
