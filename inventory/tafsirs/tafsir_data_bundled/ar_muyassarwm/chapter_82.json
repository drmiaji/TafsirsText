{
    "chapter": 82,
    "verses": {
        "1": {
            "verses": {
                "82:1": {
                    "id": 1
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱنفَطَرَتۡ﴾: انْشَقَّتْ، واخْتَلَّ نِظامُها.</h2>"
        },
        "2": {
            "verses": {
                "82:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱنتَثَرَتۡ﴾: تَساقَطَتْ.</h2>"
        },
        "3": {
            "verses": {
                "82:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿فُجِّرَتۡ﴾: فَجَّرَ اللهُ بَعْضَها في بَعْضٍ، فَمَلأَ جَمِيعَها.</p>"
        },
        "4": {
            "verses": {
                "82:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بُعۡثِرَتۡ﴾: قُلِبتْ بِبَعْثِ مَن كانَ فِيها.</h2>"
        },
        "5": {
            "verses": {
                "82:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿نَفۡسٞ﴾: كلُّ نَفْسٍ.</h2>\n<p>﴿مَا قَدَّمَتۡ وَأَخَّرَتۡ﴾: ما تَقَدَّمَ مِنْ أَعْمالِها وَمَا تَأَخَّرَ.</p>"
        },
        "6": {
            "verses": {
                "82:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡإِنسَٰنُ﴾: المنْكِرُ لِلْبَعْثِ.</h2>\n<p>﴿مَا غَرَّكَ بِرَبِّكَ﴾: ما الَّذِي خَدَعَكَ حتَّى كَفَرْتَ بِرَبِّكَ؟</p>\n<h2>﴿ٱلۡكَرِيمِ﴾: الجَوَادِ الكَثِيرِ الخيرِ.</h2>"
        },
        "7": {
            "verses": {
                "82:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَسَوَّىٰكَ﴾: فَجَعَلَكَ قَوِيماً سَلِيماً.</h2>\n<p>﴿فَعَدَلَكَ﴾: فَجَعَلَكَ مُسْتَقِيمَ القامَةِ مُتَناسِبَ الأجْزَاءِ.</p>"
        },
        "8": {
            "verses": {
                "82:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿مَا شَآءَ رَكَّبَكَ﴾: رَكَّبكَ التَّرْكِيبَ الَّذِي شاءَهُ.</p>"
        },
        "9": {
            "verses": {
                "82:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿كَلَّا﴾: لَيسَ الأمرُ كَما تَقُولُونَ.</h2>\n<h2>﴿بِٱلدِّينِ﴾: بِيومِ الِحسابِ.</h2>"
        },
        "10": {
            "verses": {
                "82:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لَحَٰفِظِينَ﴾: لمَلائِكَةً رُقَبَاءَ.</h2>"
        },
        "11": {
            "verses": {
                "82:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿كِرَامٗا﴾: على اللهِ.</h2>\n<h2>﴿كَٰتِبِينَ﴾: لِمَا وُكِّلُوا بإحْصائِهِ.</h2>"
        },
        "12": {
            "verses": {
                "82:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "13": {
            "verses": {
                "82:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلۡأَبۡرَارَ﴾: القائِمينَ بِحُقُوقِ اللهِ وَحُقُوقِ عِبادِهِ.</p>\n<h2>﴿نَعِيمٖ﴾: التَّنَعُّمِ الدَّائِم في الجنَّةِ.</h2>"
        },
        "14": {
            "verses": {
                "82:14": {
                    "id": 14
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلۡفُجَّارَ﴾: الَّذِينَ قَصَّرُوا في حُقُوقِ اللهِ وحُقُوقِ عِبادِهِ.</p>"
        },
        "15": {
            "verses": {
                "82:15": {
                    "id": 15
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يَصۡلَوۡنَهَا﴾: يُصِيبُهُم لَهَبُهَا.</h2>\n<h2>﴿يَوۡمَ ٱلدِّينِ﴾: يوم الجزاءِ.</h2>"
        },
        "16": {
            "verses": {
                "82:16": {
                    "id": 16
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿عَنۡهَا﴾: عذابِ جَهَنَّمَ.</h2>\n<h2>﴿بِغَآئِبِينَ﴾: لا بِخُرُوج وَلَا بِمَوتٍ.</h2>"
        },
        "17": {
            "verses": {
                "82:17": {
                    "id": 17
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَآ أَدۡرَىٰكَ﴾: وَما أَعْلَمَكَ؟</h2>\n<h2>﴿مَا يَوۡمُ ٱلدِّينِ﴾: ما عَظَمَةُ يَومِ الحِسابِ.</h2>"
        },
        "18": {
            "verses": {
                "82:18": {
                    "id": 18
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "19": {
            "verses": {
                "82:19": {
                    "id": 19
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿لَا تَمۡلِكُ نَفۡسٞ لِّنَفۡسٖ شَيۡـٔٗا﴾: لَا يَقْدِرُ أَحدٌ على نَفْعِ أَحَدٍ.</p>"
        }
    }
}