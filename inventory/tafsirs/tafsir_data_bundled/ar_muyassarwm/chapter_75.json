            },
            "text": "<p>...</p>"
        },
        "22": {
            "verses": {
                "75:22": {
                    "id": 22
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وُجُوهٞ﴾: وُجُوهُ أهْلِ السَّعادةِ.</h2>\n<h2>﴿يَوۡمَئِذٖ﴾: يومَ القيامةِ.</h2>\n<h2>﴿نَاضِرَةٌ﴾: مُشْرِقَةٌ مُتَأَلِّقَةٌ.</h2>"
        },
        "23": {
            "verses": {
                "75:23": {
                    "id": 23
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿إِلَىٰ رَبِّهَا نَاظِرَةٞ﴾: تَنْظُرُ إلى خالِقِها فَتَتَمَتَّعُ بِذَلِكَ.</p>"
        },
        "24": {
            "verses": {
                "75:24": {
                    "id": 24
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَوُجُوهٞ﴾: وَوُجُوهُ الأشْقِياءِ.</h2>\n<h2>﴿يَوۡمَئِذِۭ﴾: يَومَ القِيامَةِ.</h2>\n<h2>﴿بَاسِرَةٞ﴾: عابِسَةٌ كالِحَةٌ.</h2>"
        },
        "25": {
            "verses": {
                "75:25": {
                    "id": 25
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿تَظُنُّ﴾: تَتَوقَّعُ.</h2>\n<h2>﴿فَاقِرَةٞ﴾: مُصِيبَةٌ عَظِيمَةٌ.</h2>"
        },
        "26": {
            "verses": {
                "75:26": {
                    "id": 26
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿كَلَّآ﴾: حَقّاً.</h2>\n<h2>﴿بَلَغَتِ ٱلتَّرَاقِيَ﴾: وَصَلَت الرُّوحُ إلى الحُلْقُومِ.</h2>"
        },
        "27": {
            "verses": {
                "75:27": {
                    "id": 27
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَقِيلَ﴾: وَقالَ بَعْضُ الحاضِرِينَ لِبَعْضٍ.</h2>\n<p>﴿مَنۡۜ رَاقٖ﴾: هَل مِن رَاقٍ يَرْقِيهِ ويَشْفيهِ بِرُقْيَتِهِ؟</p>"
        },
        "28": {
            "verses": {
                "75:28": {
                    "id": 28
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَظَنَّ﴾: وََأَيقَنَ المُحْتَضِرُ.</h2>\n<h2>﴿أَنَّهُ﴾: أي: الأمرَ الَّذِي نَزَلَ بِهِ.</h2>\n<p>﴿ٱلۡفِرَاقُ﴾: فراقُ الدُّنيا؛ لِمُعايَنَتِهِ مَلائِكَةَ الموْتِ.</p>"
        },
        "29": {
            "verses": {
                "75:29": {
                    "id": 29
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلۡتَفَّتِ ٱلسَّاقُ بِٱلسَّاقِ﴾: واتَّصَلَتْ شِدَّةُ آخِر الدُّنيا بِشِدَّةِ أوّلِ الآخِرَةِ.</p>"
        },
        "30": {
            "verses": {
                "75:30": {
                    "id": 30
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡمَسَاقُ﴾: المرْجِعُ.</h2>"
        },
        "31": {
            "verses": {
                "75:31": {
                    "id": 31
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَلَا صَدَّقَ﴾: فلا آمنَ الكَافِرُ بالرَّسُولِ ﷺ والقرآنِ.</h2>"
        },
        "32": {
            "verses": {
                "75:32": {
                    "id": 32
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿كَذَّبَ﴾: بالقرآنِ.</h2>\n<h2>﴿وَتَوَلَّىٰ﴾: وأَعْرَضَ عَنِ الإيمانِ.</h2>"
        },
        "33": {
            "verses": {
                "75:33": {
                    "id": 33
                }
            },
            "resource_id": 109,
