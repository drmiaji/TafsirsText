                "language_name": "english"
            },
            "text": "<h2>﴿وَلۡنَحۡمِلۡ﴾: ولْنَتَحَمَّلْ.</h2>"
        },
        "13": {
            "verses": {
                "29:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
