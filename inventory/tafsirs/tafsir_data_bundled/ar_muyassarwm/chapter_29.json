        },
        "19": {
            "verses": {
                "29:19": {
                    "id": 19
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَوَ لَمۡ يَرَوۡاْ﴾: أَوَلم يَعْلَمُوا.</h2>\n<h2>﴿يُبۡدِئُ﴾: يُنشِئُ ابتداءً.</h2>\n<h2>﴿يُعِيدُهُۥٓ﴾: يُعِيدُ الخَلْقَ مِن بَعْدِ فَنَائِهِ.</h2>"
        },
        "20": {
            "verses": {
                "29:20": {
                    "id": 20
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يُنشِئُ﴾: يَخلُقُ.</h2>\n<p>﴿ٱلنَّشۡأَةَ ٱلۡأٓخِرَةَ﴾: أي: نَشْأَةً ثانيةً عِنْدَ البعْثِ.</p>"
        },
        "21": {
            "verses": {
                "29:21": {
                    "id": 21
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿تُقۡلَبُونَ﴾: تُرجَعُونَ.</h2>"
        },
        "22": {
            "verses": {
                "29:22": {
                    "id": 22
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِمُعۡجِزِينَ﴾: بِسَابِقِينَ اللهَ.</h2>"
        },
        "23": {
            "verses": {
                "29:23": {
                    "id": 23
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِـَٔايَٰتِ ٱللَّهِ﴾: أي: بالقرآنِ.</h2>\n<h2>﴿وَلِقَآئِهِۦٓ﴾: أي: بالبعثِ بَعْدَ الموتِ.</h2>"
        },
        "24": {
            "verses": {
                "29:24": {
                    "id": 24
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لَأٓيَٰتٖ﴾: لَأَدِلَّةً واضِحَةً.</h2>"
        },
        "25": {
            "verses": {
                "29:25": {
                    "id": 25
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَوۡثَٰنٗا﴾: أصْناماً، أي: اتَّخذتُموها آلِهَةً.</h2>\n<p>﴿مَوَدَّةَ بَيۡنِكُمۡ﴾: أي: للتَّوادِّ والتَّواصُل بَيْنَكُم لاجْتِماعِكُم على عِبادَتِها.</p>\n<p>﴿يَكۡفُرُ بَعۡضُكُم بِبَعۡضٖ﴾: أي: يتبرَّأُ بعضُكُم مِن بَعْضٍ.</p>\n<p>﴿مَأۡوَىٰكُمُ﴾: مَنْزِلُكُم الذي تَأْوُونَ إليهِ وتَرْجِعُونَ.</p>"
        },
        "26": {
            "verses": {
                "29:26": {
                    "id": 26
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿فَـَٔامَنَ لَهُۥ﴾: أي: صَدَّقَ إبراهيمَ عَلَيهِ الصَّلاةُ والسَّلامُ.</p>"
        },
        "27": {
            "verses": {
                "29:27": {
                    "id": 27
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلۡكِتَٰبَ﴾: أي: الكُتُبَ المنزَّلةَ، مِنَ التَّورَاةِ والإنْجِيلِ والزَّبُورِ والقرآنِ.</p>\n<h2>﴿أَجۡرَهُۥ﴾: أي: ثَوَابَه.</h2>"
        },
        "28": {
            "verses": {
                "29:28": {
                    "id": 28
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡفَٰحِشَةَ﴾: هي إِتْيانُهم الرِّجالَ في أدْبارِهِم.</h2>"
        },
        "29": {
            "verses": {
                "29:29": {
                    "id": 29
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَتَقۡطَعُونَ ٱلسَّبِيلَ﴾: أي: الطَّريقَ على المارَّةِ والمسَافِرِينَ، بأخْذِ أمْوالِهِم، أو قَتْلِهِم، أو إِكْرَاهِهِم على الفاحِشَةِ.</p>\n<h2>﴿فِي نَادِيكُمُ﴾: في مَجْلِسِكُم.</h2>\n<p>﴿ٱلۡمُنكَرَ﴾: وهو كلُّ فِعْلٍ يُنكِره الشَّرْعُ أو العقْلُ كالسُّخْرِيَةِ مِنَ النَّاسِ وحَذْفِ المارّةِ.</p>"
        },
        "30": {
            "verses": {
                "29:30": {
                    "id": 30
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "31": {
            "verses": {
                "29:31": {
                    "id": 31
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿رُسُلُنَآ﴾: أي: مِنَ الَملاَئِكَةِ.</h2>\n<h2>﴿هَٰذِهِ ٱلۡقَرۡيَةِ﴾: هي «سَدُومُ» قَرْيَةُ قَوْمِ لُوطٍ.</h2>"
        },
        "32": {
            "verses": {
                "29:32": {
                    "id": 32
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿مِنَ ٱلۡغَٰبِرِينَ﴾: مِنَ الباقِينَ في العَذَابِ والهَلَاكِ.</p>"
        },
        "33": {
            "verses": {
                "29:33": {
                    "id": 33
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿سِيٓءَ بِهِمۡ﴾: اعْتَراهُ الغَمُّ بِمَجِيئِهِم خَوْفاً عَليهِم مِن قَومِهِ.</p>\n<p>﴿وَضَاقَ بِهِمۡ ذَرۡعٗا﴾: أي: عَجَزَ عَن تَدْبِيرِ خَلَاصِهِم.</p>"
        },
        "34": {
            "verses": {
                "29:34": {
                    "id": 34
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿رِجۡزٗا﴾: عَذَاباً شَدِيداً.</h2>"
        },
        "35": {
            "verses": {
                "29:35": {
                    "id": 35
                }
            },
            "resource_id": 109,
