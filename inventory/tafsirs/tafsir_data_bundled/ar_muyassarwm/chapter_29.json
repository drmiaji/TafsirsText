            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿لَهِيَ ٱلۡحَيَوَانُ﴾: لَهِيَ الحَيَاةُ الدَّائِمَةُ الَّتي لا يُنَغِّصُها شَيءٌ.</p>"
        },
