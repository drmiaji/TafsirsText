            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لَا يُفۡتَنُونَ﴾: لا يُبتَلَونَ.</h2>"
        },
        "3": {
            "verses": {
                "29:3": {
