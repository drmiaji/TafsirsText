            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿مِنۢ بَعۡدِ مَوۡتِهَا﴾: مِن بَعْدِ قَحْطِ الأرْضِ وَجَفافِها.</p>"
