                "language_name": "english"
            },
            "text": "<h2>﴿أَوۡثَٰنٗا﴾: أصْناماً.</h2>\n<h2>﴿تَخۡلُقُونَ إِفۡكًا﴾: تَفْتَرُونَ كَذِباً.</h2>\n<h2>﴿فَٱبۡتَغُواْ﴾: فالتَمِسُوا.</h2>"
        },
        "18": {
            "verses": {
                "29:18": {
                    "id": 18
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
