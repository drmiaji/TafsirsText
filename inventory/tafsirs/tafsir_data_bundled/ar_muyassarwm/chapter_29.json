            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَن يَسۡبِقُونَا﴾: أن يُعْجِزُونا ويَفُوتُونا.</h2>\n<h2>﴿سَآءَ﴾: بِئْسَ.</h2>"
        },
        "5": {
            "verses": {
                "29:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يَرۡجُواْ﴾: يَتَوَقَّعُ ويَطْمَعُ.</h2>\n<h2>﴿أَجَلَ ٱللَّهِ﴾: الوَقْتَ المُعَيَّنَ للبَعْثِ والجَزَاءِ.</h2>"
        },
        "6": {
            "verses": {
                "29:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿جَٰهَدَ﴾: أي: الكُفَّارَ ونَفْسَه الأَمَّارةَ بالسُّوءِ.</h2>"
        },
        "7": {
            "verses": {
                "29:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لَنُكَفِّرَنَّ﴾: لَنَمْحُوَنَّ.</h2>\n<h2>﴿وَلَنَجۡزِيَنَّهُمۡ﴾: لَنُثِيبَنَّهم.</h2>"
        },
        "8": {
            "verses": {
                "29:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَوَصَّيۡنَا﴾: أي: أَمَرْنا.</h2>\n<h2>﴿حُسۡنٗا﴾: أي: بِرّاً بِهِما وعَطْفاً عَلَيهِما.</h2>\n<h2>﴿جَٰهَدَاكَ﴾: ألْزَماكَ.</h2>"
        },
        "9": {
            "verses": {
