                "language_name": "english"
            },
            "text": "<h2>﴿وَٱرۡجُواْ﴾: تَوَقّعُوا، أَوِ اخْشَوا.</h2>\n<h2>﴿وَلَا تَعۡثَوۡاْ﴾: لا تُفْسدُوا أشدَّ الفَسَادِ.</h2>"
        },
        "37": {
            "verses": {
                "29:37": {
                    "id": 37
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
