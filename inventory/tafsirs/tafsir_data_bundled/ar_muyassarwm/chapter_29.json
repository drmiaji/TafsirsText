            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَثۡقَالَهُمۡ﴾: أي: أثْقَالَ ذُنُوبِهِم الْعَظِيمَةَ.</h2>\n<h2>﴿يَفۡتَرُونَ﴾: يَخْتَلِقُونَ.</h2>"
        },
        "14": {
            "verses": {
                "29:14": {
                    "id": 14
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَلَبِثَ﴾: مَكَثَ.</h2>\n<p>﴿ٱلطُّوفَانُ﴾: الماءُ الكَثِيرُ الذي غَمَرهُم مِن جَمِيعِ الجِهاتِ.</p>"
        },
        "15": {
            "verses": {
                "29:15": {
                    "id": 15
                }
            },
