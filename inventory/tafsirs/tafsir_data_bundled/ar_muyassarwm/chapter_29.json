            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلرَّجۡفَةُ﴾: الزَّلْزَلةُ الشَّدِيدَةُ.</h2>\n<h2>﴿جَٰثِمِينَ﴾: مَيِّتِينَ بارِكِينَ على رُكَبِهِم.</h2>"
        },
        "38": {
            "verses": {
                "29:38": {
                    "id": 38
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
