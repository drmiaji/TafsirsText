            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِـَٔايَٰتِنَا﴾: المُعْجزات.</h2>"
        },
        "16": {
            "verses": {
                "41:16": {
                    "id": 16
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
