            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿أَوَّلَ مَرَّةٖ﴾: الخَلْقَ الأَوَّلَ وَلَمْ تَكُونُوا شيئاً.</p>"
        },
        "22": {
            "verses": {
                "41:22": {
                    "id": 22
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿تَسۡتَتِرُونَ﴾: تَسْتَخْفُونَ عِنْدَ ارْتِكَابِكُم المعَاصِيَ في الدُّنيا.</p>\n<h2>﴿أَن يَشۡهَدَ﴾: مَخَافَةَ أَن يَشْهَدَ.</h2>"
        },
        "23": {
            "verses": {
                "41:23": {
                    "id": 23
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَرۡدَىٰكُمۡ﴾: أَهْلَكَكُم، فَأَوْرَدَكُم النَّارَ.</h2>\n<h2>﴿ٱلۡخَٰسِرِينَ﴾: الهالِكِينَ.</h2>"
        },
        "24": {
            "verses": {
                "41:24": {
                    "id": 24
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
