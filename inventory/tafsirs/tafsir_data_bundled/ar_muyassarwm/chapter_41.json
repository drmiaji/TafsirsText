                "language_name": "english"
            },
            "text": "<h2>﴿فُصِّلَتۡ﴾: بُيِّنتْ، أو نُوِّعَتْ.</h2>"
        },
        "4": {
            "verses": {
                "41:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
