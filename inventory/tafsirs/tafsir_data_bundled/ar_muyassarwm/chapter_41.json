            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مَا يُقَالُ لَكَ﴾: لَا يقُولُ لَكَ المشرِكُونَ.</h2>"
        },
        "44": {
            "verses": {
                "41:44": {
                    "id": 44
                }
