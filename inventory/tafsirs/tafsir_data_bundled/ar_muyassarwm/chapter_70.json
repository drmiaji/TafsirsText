            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿كَلَّآ﴾: لا افْتِدَاءَ وَلَا إِنْجَاءَ.</h2>"
        },
        "16": {
