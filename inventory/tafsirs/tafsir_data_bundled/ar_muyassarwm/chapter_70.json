            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡخَيۡرُ﴾: ما يَنفَعُ الإِنْسَانَ.</h2>\n<h2>﴿مَنُوعًا﴾: كَثِيرَ المنْعِ للخيرِ.</h2>"
        },
        "22": {
            "verses": {
