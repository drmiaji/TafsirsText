{
    "chapter": 70,
    "verses": {
        "1": {
            "verses": {
                "70:1": {
                    "id": 1
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿سَأَلَ سَآئِلُۢ﴾: دَعا دَاعٍ مِنَ المُشْرِكِينَ على نَفْسِهِ وَقَوْمِهِ.</p>\n<h2>﴿بِعَذَابٖ﴾: بِنُزُولِ العَذابِ عَلَيهِم.</h2>\n<h2>﴿وَاقِعٖ﴾: مُتَحَقِّقِ الوُقُوعِ.</h2>"
        },
        "2": {
            "verses": {
                "70:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿دَافِعٞ﴾: مانِعٌ يَمْنَعُهُ مِنَ اللهِ عَزَّ وَجَلَّ.</h2>"
        },
        "3": {
            "verses": {
                "70:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ذِي ٱلۡمَعَارِجِ﴾: صاحِبِ العُلُوِّ وَالفَوَاضِلِ.</h2>"
        },
        "4": {
            "verses": {
                "70:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿تَعۡرُجُ﴾: تَصْعَدُ.</h2>\n<h2>﴿وَٱلرُّوحُ﴾: جِبْرِيلُ.</h2>\n<p>﴿خَمۡسِينَ أَلۡفَ سَنَةٖ﴾: أي: مِن سَنَواتِ الدُّنيا عَلَى الكَافِرِ.</p>"
        },
        "5": {
            "verses": {
                "70:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "6": {
            "verses": {
                "70:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿يَرَوۡنَهُۥ بَعِيدٗا﴾: يَرَونَ وَقُوعَ العذابِ مُسْتَحِيلاً.</p>"
        },
        "7": {
            "verses": {
                "70:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "8": {
            "verses": {
                "70:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿كَٱلۡمُهۡلِ﴾: ما أُذِيب مِنَ النُّحاسِ وَغَيرِهِ.</h2>"
        },
        "9": {
            "verses": {
                "70:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿كَٱلۡعِهۡنِ﴾: كالصُّوفِ.</h2>"
        },
        "10": {
            "verses": {
                "70:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَلَا يَسۡـَٔلُ حَمِيمٌ حَمِيمٗا﴾: ولا يَتَفَرَّغُ قَرِيبٌ للسُّؤالِ عَنْ حالِ قَرِيبِهِ مِنَ الهَولِ والشُّغْلِ بِحالِ نَفْسِهِ.</p>"
        },
        "11": {
            "verses": {
                "70:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿يُبَصَّرُونَهُمۡ﴾: يَرَونَهُم ويَعْرِفُونَهُم، وَلَا يَسْتَطِيعُ أَحَدٌ أَن يَنفَعَ أَحَداً.</p>\n<h2>﴿يَوَدُّ﴾: يَتَمَنَّى.</h2>\n<h2>﴿لَوۡ يَفۡتَدِي﴾: لو يُخَلِّصُ نَفْسَهُ بِفِدْيَةٍ.</h2>"
        },
        "12": {
            "verses": {
                "70:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "13": {
            "verses": {
                "70:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَفَصِيلَتِهِ﴾: وَعَشِيرَتِهِ.</h2>\n<p>﴿تُـٔۡوِيهِ﴾: تَضُمُّهُ، وَيَنْتَمِي إِلَيها في القَرَابَةِ.</p>"
        },
        "14": {
            "verses": {
                "70:14": {
                    "id": 14
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يُنجِيهِ﴾: يُنجِيهِ الافْتِدَاءُ مِنَ العَذابِ.</h2>"
        },
        "15": {
            "verses": {
                "70:15": {
                    "id": 15
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
