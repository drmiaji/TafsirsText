                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿دَآئِمُونَ﴾: مُواظِبُونَ على أدائِها.</h2>"
        },
        "24": {
            "verses": {
                "70:24": {
                    "id": 24
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿حَقّٞ مَّعۡلُومٞ﴾: نَصِيبٌ مُعَيَّنٌ لِذَوِي الحاجاتِ.</h2>"
        },
        "25": {
            "verses": {
                "70:25": {
                    "id": 25
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلۡمَحۡرُومِ﴾: الَّذِي يَتَعَفَّفُ عَن سُؤالِ النَّاسِ مَعَ حاجَتِهِ؛ فَلَا يَتَفَطَّن لَهُ كَثِيرٌ مِنَ النَّاسِ.</p>"
        },
        "26": {
            "verses": {
                "70:26": {
                    "id": 26
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِيَوۡمِ ٱلدِّينِ﴾: بيومِ الجَزَاءِ.</h2>"
        },
        "27": {
            "verses": {
                "70:27": {
                    "id": 27
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مُشۡفِقُونَ﴾: خائِفُونَ.</h2>"
        },
        "28": {
            "verses": {
                "70:28": {
                    "id": 28
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿غَيۡرُ مَأۡمُونٖ﴾: لَا يَأمَنُه أَحَدٌ مِمَّنْ عَقَلَ عَنِ اللهِ أَمْرَهُ، إلا بِأَمانٍ مِنَ اللهِ تَبارَكَ وَتَعالى.</p>"
        },
        "29": {
            "verses": {
                "70:29": {
                    "id": 29
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿لِفُرُوجِهِمۡ حَٰفِظُونَ﴾: يَحْفظُونَ أَنْفُسَهُم مِنَ الحَرَامِ.</p>"
        },
        "30": {
            "verses": {
                "70:30": {
                    "id": 30
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَوۡ مَا مَلَكَتۡ أَيۡمَٰنُهُمۡ﴾: النِّساءِ الإِمَاءِ.</h2>\n<h2>﴿غَيۡرُ مَلُومِينَ﴾: غَيرُ مؤاخَذِينَ.</h2>"
        },
        "31": {
            "verses": {
                "70:31": {
                    "id": 31
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَرَآءَ ذَٰلِكَ﴾: غَيرَ الزَّوجاتِ والمملُوكاتِ.</h2>\n<p>﴿ٱلۡعَادُونَ﴾: المُجَاوِزُون مَا أحَلَّ اللهُ لَهُمْ إلَى ما حَرَّم عَلَيهم.</p>"
        },
        "32": {
            "verses": {
                "70:32": {
                    "id": 32
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿لِأَمَٰنَٰتِهِمۡ﴾: لأماناتِ اللهِ، وأماناتِ النَّاسِ الَّتِي اؤْتُمِنُوا عَلَيها.</p>\n<h2>﴿وَعَهۡدِهِمۡ﴾: عُهُودِهِم مَعَ اللهِ، وَمَعَ العِبادِ.</h2>\n<h2>﴿رَٰعُونَ﴾: حافِظُونَ.</h2>"
        },
        "33": {
            "verses": {
                "70:33": {
                    "id": 33
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿بِشَهَٰدَٰتِهِمۡ﴾: بِما عِنْدَهُم مِنَ الدَّلالةِ عَلى حَقٍّ لِغَيرِهِم.</p>\n<p>﴿قَآئِمُونَ﴾: يَهْتَمُّونَ بِها، وَيَحْفَظُونَها إلى أن تُؤَدَّى.</p>"
        },
        "34": {
            "verses": {
                "70:34": {
                    "id": 34
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿يُحَافِظُونَ﴾: يعتَنُونَ باسْتِكْمالِ أَرْكانِها وَشُرُوطِها وَأَوْقاتِها.</p>"
        },
        "35": {
            "verses": {
                "70:35": {
                    "id": 35
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿مُكۡرَمُونَ﴾: يُكْرَمُونَ بِحُسْنِ اللقاءِ، والثَّناءِ، وَأَنْواعِ اللذَّاتِ، والمَسارِّ.</p>"
        },
        "36": {
            "verses": {
                "70:36": {
                    "id": 36
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَمَالِ ٱلَّذِينَ كَفَرُواْ﴾: فأيُّ شَيءٍ ثَبَتَ لَهُم؟</h2>\n<h2>﴿قِبَلَكَ﴾: في حالِ كَونِهِم عِندَك.</h2>\n<p>﴿مُهۡطِعِينَ﴾: مُسْرِعِينَ، وَقَدْ مَدُّوا أَعْناقَهُم إِليكَ مُقْبِلِينَ عَلَيكَ.</p>"
        },
