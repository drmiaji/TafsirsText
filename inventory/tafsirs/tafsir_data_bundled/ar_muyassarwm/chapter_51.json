                "language_name": "english"
            },
            "text": "<h2>﴿تَرَكۡنَا﴾: أَبْقينَا.</h2>\n<h2>﴿ءَايَةٗ﴾: أَثَراً مِن العَذَابِ والخَرَابِ يُتَّعظُ بِه.</h2>"
        },
        "38": {
            "verses": {
                "51:38": {
                    "id": 38
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِسُلۡطَٰنٖ﴾: بِحُجَّةٍ.</h2>"
        },
        "39": {
            "verses": {
                "51:39": {
                    "id": 39
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
