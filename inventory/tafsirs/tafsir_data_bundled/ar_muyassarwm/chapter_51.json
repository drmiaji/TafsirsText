                "language_name": "english"
            },
            "text": "<h2>﴿وَٱلذَّٰرِيَٰتِ﴾: الرِّياحِ المُثِيرَاتِ للتُّرَابِ.</h2>"
        },
        "2": {
            "verses": {
                "51:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَٱلۡحَٰمِلَٰتِ﴾: فالسُّحُبِ الحامِلاتِ.</h2>\n<h2>﴿وِقۡرٗا﴾: ثِقَلاً عَظِيماً مِنَ الماءِ.</h2>"
        },
        "3": {
            "verses": {
                "51:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَٱلۡجَٰرِيَٰتِ﴾: فَالسُّفُنِ الجارِياتِ في البِحارِ.</h2>\n<h2>﴿يُسۡرٗا﴾: جَرْياً ذا يُسْرٍ وسُهُولةٍ.</h2>"
        },
        "4": {
            "verses": {
                "51:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَٱلۡمُقَسِّمَٰتِ﴾: فالملائِكةِ المُقَسِّماتِ.</h2>\n<h2>﴿أَمۡرًا﴾: أَمْرَ اللهِ في خَلْقِهِ.</h2>"
        },
        "5": {
            "verses": {
                "51:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لَصَادِقٞ﴾: لَكائِنٌ حقٌّ يَقِينٌ.</h2>"
        },
        "6": {
            "verses": {
                "51:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلدِّينَ﴾: الحِسابَ.</h2>\n<h2>﴿لَوَٰقِعٞ﴾: لَكَائِنٌ لَا مَحالةَ.</h2>"
        },
        "7": {
            "verses": {
                "51:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ذَاتِ ٱلۡحُبُكِ﴾: ذاتِ الخَلْقِ الحَسَنِ.</h2>"
        },
        "8": {
            "verses": {
                "51:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مُخۡتَلِفٖ﴾: مُضْطَرِبٍ.</h2>"
        },
        "9": {
            "verses": {
                "51:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يُؤۡفَكُ﴾: يُصْرَفُ.</h2>"
        },
        "10": {
            "verses": {
                "51:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿قُتِلَ﴾: لُعِنَ.</h2>\n<h2>﴿ٱلۡخَرَّٰصُونَ﴾: الكَذّابُونَ الظَّانُّونَ غيرَ الحقِّ.</h2>"
        },
        "11": {
            "verses": {
                "51:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿غَمۡرَةٖ﴾: لُجَّةٍ مِنَ الكُفْرِ.</h2>\n<h2>﴿سَاهُونَ﴾: غافِلُونَ.</h2>"
        },
        "12": {
            "verses": {
                "51:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَيَّانَ﴾: مَتَى.</h2>\n<h2>﴿يَوۡمُ ٱلدِّينِ﴾: يومُ الجَزَاءِ.</h2>"
        },
        "13": {
            "verses": {
                "51:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يُفۡتَنُونَ﴾: يُعَذَّبُونَ بالإحْرَاقِ بالنَّارِ.</h2>"
        },
        "14": {
            "verses": {
                "51:14": {
                    "id": 14
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فِتۡنَتَكُمۡ﴾: عَذَابَكُم</h2>"
        },
        "15": {
            "verses": {
                "51:15": {
                    "id": 15
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "16": {
            "verses": {
                "51:16": {
                    "id": 16
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ءَاخِذِينَ﴾: قابِلينَ على وَجْهِ الرِّضا.</h2>\n<h2>﴿ءَاتَىٰهُمۡ﴾: أعْطاهُم.</h2>\n<h2>﴿مُحۡسِنِينَ﴾: فاعِلِينَ الحَسَناتِ والطَّاعاتِ.</h2>"
        },
        "17": {
            "verses": {
                "51:17": {
                    "id": 17
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يَهۡجَعُونَ﴾: يَنامُونَ.</h2>"
        },
        "18": {
            "verses": {
                "51:18": {
                    "id": 18
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَبِٱلۡأَسۡحَارِ﴾: جَمْعُ سَحَر، وَهُو آخِرُ الليلِ.</h2>"
        },
        "19": {
            "verses": {
                "51:19": {
                    "id": 19
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿حَقّٞ﴾: واجِبٌ ثابِتٌ.</h2>\n<p>﴿لِلسَّآئِلِ﴾: الَّذِي يُظْهِرُ فَقْرَهُ، فَيسْأَلُ النَّاسَ.</p>\n<h2>﴿وَٱلۡمَحۡرُومِ﴾: الفَقِيرِ المُتَعَفِّفِ.</h2>"
        },
        "20": {
            "verses": {
                "51:20": {
                    "id": 20
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿لِلۡمُوقِنِينَ﴾: لِأَهْلِ اليقِينِ بِأنَّ اللهَ وَرَسُولَه حَقٌّ.</p>"
        },
        "21": {
            "verses": {
                "51:21": {
                    "id": 21
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَفِيٓ أَنفُسِكُمۡ﴾: وَفي خَلْقِ أَنْفُسِكُم دَلَائِلُ وَعِبَرٌ.</p>"
        },
        "22": {
            "verses": {
                "51:22": {
                    "id": 22
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿رِزۡقُكُمۡ﴾: مادَّةُ رِزْقِكُم، مِنَ الأمْطارِ، وصُنُوفِ الأقْدَارِ.</p>\n<h2>﴿وَمَا تُوعَدُونَ﴾: مِنَ الجَزاءِ في الدُّنيا والآخِرةِ.</h2>"
        },
        "23": {
            "verses": {
                "51:23": {
                    "id": 23
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿مِثۡلَ مَآ أَنَّكُمۡ تَنطِقُونَ﴾: فَتَحَقَّقَ الوعِيدُ مِثْلَ نُطْقِكُم الَّذِي لا تَشُكُّونَ فِيهِ.</p>"
        },
        "24": {
            "verses": {
                "51:24": {
                    "id": 24
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ضَيۡفِ إِبۡرَٰهِيمَ﴾: هُم مِن الملائِكةِ.</h2>"
        },
        "25": {
            "verses": {
                "51:25": {
                    "id": 25
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿سَلَٰمٗا﴾: سَلَّمنا سَلَاما.</h2>\n<h2>﴿سَلَٰمٞ﴾: أَمْرِي سَلامٌ لَكُم.</h2>\n<h2>﴿مُنكَرُونَ﴾: لا أَعْرِفُهُم.</h2>"
        },
        "26": {
            "verses": {
                "51:26": {
                    "id": 26
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَرَاغَ﴾: فَمَال خِفْيَةً.</h2>"
        },
        "27": {
            "verses": {
                "51:27": {
                    "id": 27
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "28": {
            "verses": {
                "51:28": {
                    "id": 28
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَأَوۡجَسَ﴾: أَحَسَّ في نَفْسِهِ.</h2>\n<h2>﴿بِغُلَٰمٍ عَلِيمٖ﴾: هو إسْحاقُ عَلَيهِ السَّلامُ.</h2>"
        },
        "29": {
            "verses": {
                "51:29": {
                    "id": 29
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿صَرَّةٖ﴾: صَيْحَةٍ.</h2>\n<h2>﴿فَصَكَّتۡ﴾: فَلَطَمَتْ.</h2>\n<h2>﴿عَقِيمٞ﴾: لا تَحْمِلُ.</h2>"
        },
        "30": {
            "verses": {
                "51:30": {
                    "id": 30
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
