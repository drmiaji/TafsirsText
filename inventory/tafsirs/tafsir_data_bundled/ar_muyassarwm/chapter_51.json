                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "31": {
            "verses": {
                "51:31": {
                    "id": 31
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَمَا خَطۡبُكُمۡ﴾: فَمَا شَأنُكُم؟</h2>"
        },
        "32": {
            "verses": {
                "51:32": {
                    "id": 32
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿قَوۡمٖ مُّجۡرِمِينَ﴾: هُم قَومُ لُوطٍ عَلَيهِ السَّلامُ.</h2>"
        },
        "33": {
            "verses": {
                "51:33": {
                    "id": 33
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
