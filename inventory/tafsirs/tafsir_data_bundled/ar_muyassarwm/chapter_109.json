                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿لَآ أَعۡبُدُ مَا تَعۡبُدُونَ﴾: لا تَحصُلُ منِّي عِبادَةُ ما تَعْبُدُونَ مِنَ الأصْنامِ والآلِهَةِ الزَّائِفَةِ.</p>"
        },
        "3": {
            "verses": {
                "109:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَلَآ أَنتُمۡ عَٰبِدُونَ مَآ أَعۡبُدُ﴾: وما أنتُم عابِدُونَ في المسْتَقْبَلِ ما أَعْبُدُ مِنْ إلهٍٍ واحدٍ، هُوَ اللهُ رَبُّ العالَمينَ المُسْتَحِقُّ وَحْدَهُ لِلعِبادةِ.</p>"
        },
        "4": {
            "verses": {
                "109:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَلَآ أَنَا۠ عَابِدٞ مَّا عَبَدتُّمۡ﴾: وَلا أَنا عابِدٌ ما عبدتُم مِنَ الأصْنامِ والآلِهَةِ الباطِلةِ فيما مَضَى مِنَ الأزْمانِ.</p>"
        },
        "5": {
            "verses": {
                "109:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَلَآ أَنتُمۡ عَٰبِدُونَ مَآ أَعۡبُدُ﴾: وَلَا أنتُم عابِدُونَ مُسْتَقْبلاً ما أَعْبُدُ.</p>"
        },
        "6": {
            "verses": {
