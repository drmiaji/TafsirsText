        "7": {
            "verses": {
                "30:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ظَٰهِرٗا مِّنَ ٱلۡحَيَوٰةِ ٱلدُّنۡيَا﴾: فَيَنْظُرُونَ إلى الأسْبابِ الظَّاهِرَةِ وَلَا يَنْظُرُونَ إلى مُسَبِّبِها المتَصَرِّفِ فِيها الَّذي هُوَ اللهُ تَعالى.</p>"
        },
        "8": {
            "verses": {
                "30:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿أَوَ لَمۡ يَتَفَكَّرُواْ﴾: أَوَلَمْ يَتَأَمَّلُوا وَيَتَدَبَّرُوا.</p>\n<h2>﴿أَجَلٖ مُّسَمّٗى﴾: وَقْتٍ مُقَدَّرٍ هُوَ يومُ القِيامَةِ.</h2>\n<p>﴿بِلِقَآيِٕ رَبِّهِمۡ﴾: المُرَادُ به البَعْثُ بَعْدَ الموتِ.</p>"
        },
        "9": {
            "verses": {
                "30:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿عَٰقِبَةُ ٱلَّذِينَ مِن قَبۡلِهِمۡ﴾: أي: مَصِيرُهُم الَّذي انْتهَوا إِليهِ.</p>\n<h2>﴿وَأَثَارُواْ ٱلۡأَرۡضَ﴾: حَرَثُوها للزِّرَاعَةِ.</h2>\n<h2>﴿وَعَمَرُوهَآ﴾: أي: بالبُنْيانِ والزِّراعَةِ.</h2>\n<p>﴿بِٱلۡبَيِّنَٰتِ﴾: بالبَراهِينِ الواضِحةِ، ومنها المُعْجِزَاتُ الحِسِّيةُ.</p>"
        },
        "10": {
            "verses": {
                "30:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلسُّوٓأَىٰٓ﴾: تَأْنِيثُ «الأسْوأ»، ومعناها: العُقُوبَةُ المتناهِيةُ في السُّوءِ، وهي نارُ جَهَنَّم.</p>"
        },
        "11": {
            "verses": {
                "30:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يَبۡدَؤُاْ﴾: يُنْشِئُ ابتِدَاءً.</h2>\n<h2>﴿يُعِيدُهُۥ﴾: يُعِيدُ الخَلْقَ مِن بَعْدِ فَنائِهِ.</h2>"
        },
        "12": {
            "verses": {
                "30:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿يُبۡلِسُ ٱلۡمُجۡرِمُونَ﴾: يَيْئَسُونَ بانْقِطاعِ حُجَّتِهِم.</p>"
        },
        "13": {
            "verses": {
                "30:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿مِن شُرَكَآئِهِمۡ﴾: أي: مِنْ آلهَتِهِم الَّتي كانُوا يَعْبُدُونَها مِن دُونِ اللهِ.</p>"
        },
        "14": {
            "verses": {
                "30:14": {
                    "id": 14
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿يَتَفَرَّقُونَ﴾: أي: فَرِيقٌ في الجنَّة، وفَرِيقٌ في السَّعِيرِ.</p>"
        },
        "15": {
            "verses": {
                "30:15": {
                    "id": 15
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿رَوۡضَةٖ﴾: المرادُ بِها هُنا «الجنَّةُ».</h2>\n<h2>﴿يُحۡبَرُونَ﴾: يُكَرَّمُونَ ويُنَعَّمُونَ.</h2>"
        },
        "16": {
            "verses": {
                "30:16": {
                    "id": 16
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَلِقَآيِٕ ٱلۡأٓخِرَةِ﴾: أي: البَعْثِ بَعْدَ الموتِ.</h2>\n<h2>﴿فِي ٱلۡعَذَابِ مُحۡضَرُونَ﴾: مُقيمُونَ فِيهِ.</h2>"
        },
        "17": {
            "verses": {
                "30:17": {
                    "id": 17
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَسُبۡحَٰنَ ٱللَّهِ﴾: أي: فنزِّهُوهُ عمَّا لا يَلِيقُ بِه.</h2>\n<h2>﴿حِينَ تُمۡسُونَ﴾: أي: وقْتَ دُخُولِكُم في المساءِ.</h2>\n<h2>﴿وَحِينَ تُصۡبِحُونَ﴾: أي: وقْتَ دُخُولِكُم في الصَّباحِ.</h2>"
        },
        "18": {
            "verses": {
                "30:18": {
                    "id": 18
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَعَشِيّٗا﴾: وقْتَ العَشِيِّ، أي: بَعْدَ زَوالِ الشَّمسِ.</h2>\n<h2>﴿وَحِينَ تُظۡهِرُونَ﴾: أي: وَقْتَ الظَّهِيرَةِ.</h2>"
        },
        "19": {
            "verses": {
                "30:19": {
                    "id": 19
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بَعۡدَ مَوۡتِهَا﴾: أي: قَحْطِها وجَفَافِها.</h2>\n<h2>﴿تُخۡرَجُونَ﴾: أي: تُبعثُونَ مِن قُبُورِكُم.</h2>"
        },
        "20": {
            "verses": {
                "30:20": {
                    "id": 20
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿تَنتَشِرُونَ﴾: تَتَفَرَّقُونَ.</h2>"
        },
        "21": {
            "verses": {
                "30:21": {
                    "id": 21
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مِنۡ أَنفُسِكُمۡ﴾: مِن جِنْسِكُم.</h2>\n<p>﴿لِتَسۡكُنُوٓاْ إِلَيۡهَا﴾: لِتألَفُوها وتَطْمئنُّوا إِلَيها.</p>\n<h2>﴿مَوَدَّةٗ وَرَحۡمَةً﴾: مَحَبَّةً وشَفَقَةً.</h2>\n<h2>﴿يَتَفَكَّرُونَ﴾: يَتَدَبَّرُونَ.</h2>"
        },
        "22": {
            "verses": {
                "30:22": {
                    "id": 22
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَلۡسِنَتِكُمۡ﴾: لُغَاتِكُم.</h2>"
        },
        "23": {
            "verses": {
                "30:23": {
                    "id": 23
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱبۡتِغَآؤُكُم﴾: طَلَبُكُم والْتِماسُكُم.</h2>\n<h2>﴿مِن فَضۡلِهِۦٓ﴾: مِن رِزْقِه.</h2>"
        },
        "24": {
            "verses": {
                "30:24": {
                    "id": 24
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿خَوۡفٗا وَطَمَعٗا﴾: أي: خَوْفاً مِنَ الصَّواعِقِ وَطَمعاً في الغَيثِ.</p>\n<h2>﴿بَعۡدَ مَوۡتِهَآ﴾: بَعْدَ قَحْطِها وَجَفافِها.</h2>"
        },
        "25": {
            "verses": {
                "30:25": {
                    "id": 25
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِأَمۡرِهِۦ﴾: بِإِرَادَتِه وَقُدْرَتِهِ.</h2>\n<h2>﴿تَخۡرُجُونَ﴾: أي: مِن قُبُورِكُم أحْيَاءً.</h2>"
        },
        "26": {
            "verses": {
                "30:26": {
                    "id": 26
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
