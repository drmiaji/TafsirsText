            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِضۡعِ سِنِينَ﴾: أي: ما بينَ الثَّلاثَةِ إلى العَشْرَةِ.</h2>"
        },
