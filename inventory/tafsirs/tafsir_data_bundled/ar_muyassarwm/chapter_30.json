            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لَهُۥ قَٰنِتُونَ﴾: مُنْقادُونَ لإرَادَتِه.</h2>"
        },
        "27": {
            "verses": {
                "30:27": {
                    "id": 27
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
