            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿فِي لَوۡحٖ مَّحۡفُوظِۭ﴾: لا ينالُه تَبْدِيلٌ ولا تَحْرِيفٌ.</p>"
        }
    }
