{
    "chapter": 85,
    "verses": {
        "1": {
            "verses": {
                "85:1": {
                    "id": 1
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ذَاتِ ٱلۡبُرُوجِ﴾: ذاتِ المنازِل الَّتِي تَسِيرُ فِيها الشَّمْسُ والقَمَرُ.</p>"
        },
        "2": {
            "verses": {
                "85:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلۡيَوۡمِ ٱلۡمَوۡعُودِ﴾: أَقَسَم اللهُ تَعالَى بِاليَومِ الَّذِي وَعَدَ الخلْقَ أَن يَجْمَعَهُم فِيهِ.</p>"
        },
        "3": {
            "verses": {
                "85:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَشَاهِدٖ﴾: الرائِي، أو المُخْبِرِ بِحَقٍّ.</h2>\n<h2>﴿وَمَشۡهُودٖ﴾: المَرئي، أو المشهود عليه بحق.</h2>"
        },
        "4": {
            "verses": {
                "85:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿قُتِلَ﴾: لُعِنَ.</h2>\n<p>﴿أَصۡحَٰبُ ٱلۡأُخۡدُودِ﴾: الَّذِين شَقُّوا في الأرضِ شَقّاً عَظِيماً؛ لِتَعذِيبِ المؤمِنِينَ.</p>"
        },
        "5": {
            "verses": {
                "85:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلۡوَقُودِ﴾: ما تُوقَدُ بِهِ النَّارُ مِنْ حَطَبٍ وَنَحوِهِ.</p>"
        },
        "6": {
            "verses": {
                "85:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿إِذۡ هُمۡ﴾: حِيْنَ هَؤُلاءِ الكُفَّارُ مِنْ أصحابِ الأُخْدُودِ.</p>\n<h2>﴿عَلَيۡهَا﴾: عَلى حافَةِ النَّارِ الَّتِي في الأُخْدُودِ.</h2>"
        },
        "7": {
            "verses": {
                "85:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿شُهُودٞ﴾: حُضُورٌ.</h2>"
        },
        "8": {
            "verses": {
                "85:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَا نَقَمُواْ﴾: وما أَنْكَرُوا عَلَيهِم.</h2>\n<p>﴿ٱلۡعَزِيزِ﴾: الشَّدِيدِ في انْتِقامِهِ مِمَّن انْتَقَمَ مِنْهُ.</p>\n<h2>﴿ٱلۡحَمِيدِ﴾: المَحْمودِ في أَقْوالِهِ وَأَفْعالِهِ.</h2>"
        },
        "9": {
            "verses": {
                "85:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿شَهِيدٌ﴾: مُطَّلِعٌ لا يَخْفَى عَلَيهِ شَيءٌ.</h2>"
        },
        "10": {
            "verses": {
                "85:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَتَنُواْ﴾: حَرَّقُوا.</h2>"
        },
        "11": {
            "verses": {
                "85:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مِن تَحۡتِهَا﴾: مِن تَحْتِ قُصُورِها وأَشْجارِها.</h2>"
        },
        "12": {
            "verses": {
                "85:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "13": {
            "verses": {
                "85:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يُبۡدِئُ﴾: يَبْدَأُ الخَلْقَ.</h2>\n<h2>﴿وَيُعِيدُ﴾: الخَلْقَ لِلْحِسابِ.</h2>"
        },
        "14": {
            "verses": {
                "85:14": {
                    "id": 14
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡغَفُورُ﴾: لمِن تابَ.</h2>\n<h2>﴿ٱلۡوَدُودُ﴾: كَثِيرُ المحَبَّةِ لأوليائِهِ.</h2>"
        },
        "15": {
            "verses": {
                "85:15": {
                    "id": 15
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ذُو ٱلۡعَرۡشِ﴾: صاحِبُ العرْشِ.</h2>\n<h2>﴿ٱلۡمَجِيدُ﴾: الَّذِي بَلَغَ المُنْتَهَى في الْفَضلِ.</h2>"
        },
        "16": {
            "verses": {
                "85:16": {
                    "id": 16
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿فَعَّالٞ لِّمَا يُرِيدُ﴾: لا يَمْتَنِعُ عَلَيهِ شَيءٌ يُريدُهُ.</p>"
        },
        "17": {
            "verses": {
                "85:17": {
                    "id": 17
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿حَدِيثُ ٱلۡجُنُودِ﴾: خَبَرُ الجُمُوعِ الكافِرةِ المُكَذِّبةِ لأَنْبِيائِها.</p>"
        },
