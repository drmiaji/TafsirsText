            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلۡعَٰدِيَٰتِ﴾: أَقْسَمَ اللهُ تَعالى بالخَيلِ الجارياتِ في سَبِيلِ اللهِ.</p>\n<h2>﴿ضَبۡحٗا﴾: حِينَ يَظْهَرُ صَوْتُها مِن سُرْعَةِ عَدْوِها.</h2>"
        },
        "2": {
            "verses": {
                "100:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿فَٱلۡمُورِيَٰتِ قَدۡحٗا﴾: فالخَيلِ اللاتِي تَنْقَدِحُ النَّارُ مِنْ حَوافِرِها؛ من شِدَّةِ عَدْوِها.</p>"
        },
        "3": {
            "verses": {
                "100:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَٱلۡمُغِيرَٰتِ﴾: فالمُغِيراتِ عَلى الأعداءِ.</h2>\n<h2>﴿صُبۡحٗا﴾: عِنْدَ الصُّبْحِ.</h2>"
        },
        "4": {
            "verses": {
                "100:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَأَثَرۡنَ بِهِۦ﴾: فهَيَّجْنَ بِهذا العَدْوِ.</h2>\n<h2>﴿نَقۡعٗا﴾: غُباراً.</h2>"
        },
        "5": {
            "verses": {
                "100:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَوَسَطۡنَ بِهِۦ﴾: فتوسَّطْنَ بِرُكْبانِهِنَّ.</h2>\n<h2>﴿جَمۡعًا﴾: جُموعَ الأعداءِ.</h2>"
        },
        "6": {
            "verses": {
                "100:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لِرَبِّهِۦ لَكَنُودٞ﴾: لِنِعَمِ رَبِّهِ لَجَحُودٌ.</h2>"
        },
        "7": {
            "verses": {
                "100:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿عَلَىٰ ذَٰلِكَ لَشَهِيدٞ﴾: مُقِرٌّ بِجُحُودِهِ.</h2>"
        },
        "8": {
            "verses": {
                "100:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡخَيۡرِ﴾: المالِ.</h2>"
        },
        "9": {
            "verses": {
                "100:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿بُعۡثِرَ مَا فِي ٱلۡقُبُورِ﴾: أَخْرَجَ اللهُ الأمواتَ مِنَ القُبُورِ لِلْحِسابِ؟</p>"
        },
        "10": {
            "verses": {
                "100:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَحُصِّلَ﴾: واسْتُخْرِجَ.</h2>\n<p>﴿مَا فِي ٱلصُّدُورِ﴾: ما اسْتَتَرَ في الصُّدُورِ مِنْ خَيْرٍ أو شَرٍّ.</p>"
        },
        "11": {
            "verses": {
                "100:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿لَخَبِيرُۢ﴾: لَمُطَّلِعٌ على باطِنِ أَمْرِهِم فلا يَخْفَى عَلَيهِ شيءٌ مِن ذَلِكَ.</p>"
        }
    }
}