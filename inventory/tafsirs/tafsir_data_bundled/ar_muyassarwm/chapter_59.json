                "language_name": "english"
            },
            "text": "<h2>﴿شَآقُّواْ﴾: خالفُوا.</h2>"
        },
        "5": {
            "verses": {
                "59:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
