                "language_name": "english"
            },
            "text": "<p>﴿ٱلۡبَيَانَ﴾: النُّطْقَ والتَّعْبِيرَ عَمَّا في الضَّمائِرِ.</p>"
        },
        "5": {
            "verses": {
                "55:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِحُسۡبَانٖ﴾: يَجْرِيانِ بِحِسابٍ مُتْقَنٍ.</h2>"
        },
        "6": {
            "verses": {
                "55:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "7": {
            "verses": {
                "55:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡمِيزَانَ﴾: العَدْلَ الَّذِي شَرَعَهُ لِعِبادِهِ.</h2>"
        },
        "8": {
            "verses": {
                "55:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَلَّا تَطۡغَوۡاْ﴾: لِئَلَّا تَعْتَدُوا.</h2>"
        },
        "9": {
            "verses": {
                "55:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِٱلۡقِسۡطِ﴾: بالعَدْلِ.</h2>\n<h2>﴿وَلَا تُخۡسِرُواْ﴾: ولا تُنْقِصُوا.</h2>"
        },
        "10": {
            "verses": {
                "55:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَضَعَهَا﴾: مَهَّدَها.</h2>\n<h2>﴿لِلۡأَنَامِ﴾: لِلْخَلْقِ.</h2>"
        },
        "11": {
            "verses": {
                "55:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡأَكۡمَامِ﴾: جَمْعُ «كِمٍّ» وهو وِعاءُ الثَّمرَةِ.</h2>"
        },
        "12": {
            "verses": {
                "55:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ذُو ٱلۡعَصۡفِ﴾: ذُو القِشْرِ.</h2>\n<h2>﴿وَٱلرَّيۡحَانُ﴾: كُلُّ نَبْتٍ طَيِّبِ الرَّائِحةِ.</h2>"
        },
        "13": {
            "verses": {
                "55:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ءَالَآءِ﴾: نِعَمِ.</h2>"
        },
        "14": {
            "verses": {
                "55:14": {
                    "id": 14
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡإِنسَٰنَ﴾: أي: أَباه، وهو آدَمُ عليه السَّلام.</h2>\n<h2>﴿مِن صَلۡصَٰلٖ﴾: مِن طِينٍ يابِسٍ.</h2>\n<h2>﴿كَٱلۡفَخَّارِ﴾: الطينِ الَّذِي طُبِخَ بالنَّارِ.</h2>"
        },
        "15": {
            "verses": {
                "55:15": {
                    "id": 15
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡجَآنَّ﴾: إِبْلِيسَ.</h2>\n<h2>﴿مَارِجٖ﴾: لَهَبِ النَّارِ المُخْتَلِطِ بَعْضُهُ بِبَعْضٍ.</h2>"
        },
        "16": {
            "verses": {
                "55:16": {
                    "id": 16
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "17": {
            "verses": {
                "55:17": {
                    "id": 17
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلۡمَشۡرِقَيۡنِ﴾: مَشْرِقَي الشَّمْسِ في الشِّتاءِ والصَّيفِ.</p>\n<p>﴿ٱلۡمَغۡرِبَيۡنِ﴾: مَغْرِبَيِ الشَّمسِ في الشِّتاءِ والصَّيفِ.</p>"
        },
        "18": {
            "verses": {
                "55:18": {
                    "id": 18
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
