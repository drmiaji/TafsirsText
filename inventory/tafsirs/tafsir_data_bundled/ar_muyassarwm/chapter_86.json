            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلطَّارِقِ﴾: أَقْسَمَ اللهُ سُبحانَهُ بالنَّجْمِ الَّذِي يَطْرُقُ ليلاً.</p>"
        },
        "2": {
            "verses": {
                "86:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَآ أَدۡرَىٰكَ﴾: وأيُّ شَيءٍ أَعْلَمَكَ؟</h2>\n<h2>﴿مَا ٱلطَّارِقُ﴾: ما عِظَمُ هذا النَّجمِ؟</h2>"
        },
        "3": {
            "verses": {
                "86:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلنَّجۡمُ ٱلثَّاقِبُ﴾: النَّجمُ المُضِيءُ المُتَوهِّجُ.</h2>"
        },
        "4": {
            "verses": {
                "86:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿إِن﴾: ما.</h2>\n<h2>﴿لَمَّا﴾: إلَّا.</h2>\n<p>﴿عَلَيۡهَا حَافِظٞ﴾: أُوْكِلَ بها مَلَكٌ رَقِيبٌ يَحْفَظُ عَلَيها أَعْمَالَها.</p>"
        },
        "5": {
            "verses": {
                "86:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "6": {
            "verses": {
                "86:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مَآءٖ دَافِقٖ﴾: مَنيٍّ مُنْصَبٍّ بِسُرعَةٍ في الرَّحِم.</h2>"
        },
        "7": {
            "verses": {
                "86:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلصُّلۡبِ﴾: العَمُودِ العَظْميِّ في وَسَطِ الظَّهْرِ، وهو ذُو الفِقْراتِ.</p>\n<p>﴿وَٱلتَّرَآئِبِ﴾: جَمْع ترِيبةٍ، وهي عظامُ الصَّدرِ الَّتِي بَينَ التَّرقُوَتَينِ والثَّديينِ.</p>"
        },
        "8": {
            "verses": {
                "86:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿رَجۡعِهِۦ﴾: إعادَتِهِ إلى الحياةِ بَعْدَ الموتِ.</h2>"
        },
        "9": {
            "verses": {
                "86:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿تُبۡلَى﴾: تُخْتَبرُ.</h2>\n<p>﴿ٱلسَّرَآئِرُ﴾: ما يُخْفيهِ الإِنسانُ مِنَ العقائِدِ والأعْمالِ.</p>"
        },
        "10": {
            "verses": {
                "86:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿قُوَّةٖ﴾: يدفعُ بِها عَن نَّفْسِهِ.</h2>"
        },
        "11": {
            "verses": {
                "86:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ذَاتِ ٱلرَّجۡعِ﴾: ذَاتِ المطَرِ الَّذِي يَرْجِعُ وَ يَتَكَرَّرُ.</p>"
        },
        "12": {
            "verses": {
                "86:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلصَّدۡعِ﴾: التَّشَقُّقِ بِما يَتَخلَّلُها مِن نَّباتٍ.</h2>"
        },
        "13": {
            "verses": {
                "86:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَصۡلٞ﴾: فاصِلٌ بَيْنَ الحقِّ والباطِلِ.</h2>"
        },
        "14": {
            "verses": {
                "86:14": {
                    "id": 14
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِٱلۡهَزۡلِ﴾: باللَّعِبِ والباطِل.</h2>"
        },
        "15": {
            "verses": {
                "86:15": {
                    "id": 15
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿يَكِيدُونَ كَيۡدٗا﴾: يُخْفونَ قَصْدَ الضُّرِّ ويُظْهِرُونَ خِلافَه.</p>"
        },
        "16": {
            "verses": {
                "86:16": {
                    "id": 16
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَأَكِيدُ كَيۡدٗا﴾: لإِظْهارِ الحقِّ.</h2>"
        },
        "17": {
            "verses": {
                "86:17": {
                    "id": 17
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَمَهِّلِ ٱلۡكَٰفِرِينَ﴾: فأنْظِرْهُم.</h2>\n<h2>﴿أَمۡهِلۡهُمۡ﴾: أنْظِرْهُم.</h2>\n<h2>﴿رُوَيۡدَۢا﴾: مُهلةً غيرَ طويلةٍ.</h2>"
        }
    }
}