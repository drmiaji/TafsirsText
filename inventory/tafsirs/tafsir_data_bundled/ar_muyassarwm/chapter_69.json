            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَإِنَّهُۥ﴾: أي: التَّكْذِيبَ.</h2>\n<h2>﴿لَحَسۡرَةٌ﴾: لَنَدامةٌ عَظِيمَةٌ.</h2>"
        },
        "51": {
            "verses": {
                "69:51": {
                    "id": 51
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
