                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "3": {
            "verses": {
                "69:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَآ أَدۡرَىٰكَ﴾: وأيُّ شَيءٍ عَرَّفَكَ حَقيقَةَ القيامَةِ؟</p>"
        },
        "4": {
            "verses": {
                "69:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿بِٱلۡقَارِعَةِ﴾: بالقِيامَةِ الَّتِي تَقْرَعُ القُلُوبَ بِأَهْوَالِهَا.</p>"
        },
        "5": {
            "verses": {
                "69:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿بِٱلطَّاغِيَةِ﴾: بالصَّيحَةِ العَظِيمَةِ؛ الَّتِي جاوزَتِ الحدَّ في شِدَّتِها.</p>"
        },
        "6": {
            "verses": {
                "69:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿صَرۡصَرٍ﴾: بارِدَةٍ.</h2>\n<h2>﴿عَاتِيَةٖ﴾: شَدِيدَةِ الهُبُوبِ.</h2>"
        },
        "7": {
            "verses": {
                "69:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿سَخَّرَهَا عَلَيۡهِمۡ﴾: سَلَّطَها اللهُ عَلَيهِم.</h2>\n<h2>﴿حُسُومٗا﴾: مُتَتَابِعَةً.</h2>\n<h2>﴿صَرۡعَىٰ﴾: مَوْتَى.</h2>\n<h2>﴿أَعۡجَازُ نَخۡلٍ﴾: أُصُولُ نَخْلٍ.</h2>\n<h2>﴿خَاوِيَةٖ﴾: خَرِبَةٍ مُتآكِلَةِ الأَجْوافِ.</h2>"
        },
        "8": {
            "verses": {
                "69:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بَاقِيَةٖ﴾: نَفْسٍ باقِيةٍ دُونَ هَلَاكٍ.</h2>"
        },
        "9": {
            "verses": {
                "69:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلۡمُؤۡتَفِكَٰتُ﴾: وَأَهلُ قُرَى قَوْمِ لُوطٍ؛ الَّذِينَ انْقَلَبَتْ بِهم دِيارُهُم.</p>\n<p>﴿بِٱلۡخَاطِئَةِ﴾: بِسَبَبِ الفَعْلَةِ المنكرَةِ مِنَ الكُفْرِ والفواحِشِ.</p>"
        },
        "10": {
            "verses": {
                "69:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَأَخَذَهُمۡ﴾: فَأَهْلَكَهُم.</h2>\n<h2>﴿رَابِيَةً﴾: بالِغةً في الشِّدَّةِ.</h2>"
        },
        "11": {
            "verses": {
                "69:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿طَغَا ٱلۡمَآءُ﴾: جاوَزَ حَدَّهُ، حتَّى عَلَا وارْتَفَعَ فَوْقَ كُلِّ شَيءٍ.</p>\n<p>﴿حَمَلۡنَٰكُمۡ﴾: حَمَلْناكُم وأنتُم في أَصْلابِ آبائِكُم وأُمَّهاتِكُم.</p>\n<p>﴿ٱلۡجَارِيَةِ﴾: السَّفِينَةِ الَّتِي تَجْرِي في الماءِ، والمراد: سفينة نوح عليه السلام.</p>"
        },
        "12": {
            "verses": {
                "69:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿لِنَجۡعَلَهَا﴾: لِنَجْعَلَ الواقِعةَ الَّتِي نَجا فِيها المُؤمِنُونَ، وأُغْرِقَ فِيها الكَافِرُونَ.</p>\n<h2>﴿تَذۡكِرَةٗ﴾: عِبْرةً وعِظَةً.</h2>\n<h2>﴿وَتَعِيَهَآ﴾: وَتَحْفَظَها.</h2>"
        },
        "13": {
            "verses": {
                "69:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلصُّورِ﴾: القَرْنِ الَّذِي يَنْفُخُ فيه المَلَكُ عِنْدَ قِيامِ السَّاعةِ.</p>"
        },
        "14": {
            "verses": {
                "69:14": {
                    "id": 14
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَحُمِلَتِ ٱلۡأَرۡضُ وَٱلۡجِبَالُ﴾: رُفِعَت عن أماكِنِها.</h2>\n<h2>﴿فَدُكَّتَا دَكَّةٗ وَٰحِدَةٗ﴾: دُقَّتا دَقَّةً واحِدَةً.</h2>"
        },
        "15": {
            "verses": {
                "69:15": {
                    "id": 15
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَقَعَتِ ٱلۡوَاقِعَةُ﴾: قامَتِ القِيامةُ.</h2>"
        },
        "16": {
            "verses": {
                "69:16": {
                    "id": 16
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَٱنشَقَّتِ﴾: انْصَدَعَتْ مُتَشَقِّقَةً.</h2>\n<h2>﴿وَاهِيَةٞ﴾: ضَعِيفَةٌ لَا تَماسُكَ فِيها.</h2>"
        },
        "17": {
            "verses": {
                "69:17": {
                    "id": 17
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلۡمَلَكُ عَلَىٰٓ أَرۡجَآئِهَا﴾: والملائِكَةُ على أَطْرَافِها.</p>\n<p>﴿عَرۡشَ رَبِّكَ﴾: وهو سَرِيرُ الملْكِ الَّذِي تَحْمِلُه الملائِكةُ، واسْتَوى عَلَيهِ الرحمنُ، وهو أَعْظَمُ المَخْلُوقاتِ، وهو سَقْفُ جَنَّةِ الفِرْدَوسِ.</p>\n<h2>﴿ثَمَٰنِيَةٞ﴾: أي: من الملائِكةِ العِظامِ.</h2>"
        },
        "18": {
            "verses": {
                "69:18": {
                    "id": 18
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿تُعۡرَضُونَ﴾: أي: عَلَى اللهِ.</h2>\n<p>﴿لَا تَخۡفَىٰ مِنكُمۡ خَافِيَةٞ﴾: لا تَخْفى عَلَى اللهِ نَفْسٌ خافِيةٌ مِنْكُم.</p>"
        },
        "19": {
            "verses": {
                "69:19": {
                    "id": 19
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿هَآؤُمُ﴾: تعالَوا.</h2>"
        },
        "20": {
            "verses": {
                "69:20": {
                    "id": 20
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
