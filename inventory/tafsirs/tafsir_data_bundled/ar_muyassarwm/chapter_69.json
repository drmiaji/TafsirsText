            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ظَنَنتُ﴾: أَيْقَنْتُ.</h2>\n<h2>﴿حِسَابِيَهۡ﴾: جَزائِي يومَ القيامةِ.</h2>"
        },
        "21": {
            "verses": {
                "69:21": {
                    "id": 21
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
