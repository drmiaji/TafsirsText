            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لَحَقُّ ٱلۡيَقِينِ﴾: الخبرُ الصِّدقُ.</h2>"
        },
        "52": {
            "verses": {
                "69:52": {
                    "id": 52
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
