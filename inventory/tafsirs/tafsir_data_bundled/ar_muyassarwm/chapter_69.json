                "language_name": "english"
            },
            "text": "<p>﴿ٱلۡحَآقَّةُ﴾: القِيامة الواقِعةُ حَقّاً؛ الَّتِي يَتَحَقَّقُ فِيها الوعْدُ والوَعِيدُ.</p>"
        },
        "2": {
            "verses": {
                "69:2": {
                    "id": 2
                }
            },
