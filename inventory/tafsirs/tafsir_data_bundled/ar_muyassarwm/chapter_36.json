            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَلَا يُنقِذُونِ﴾: لا يُنَجُّونَنِي مِمَّا أَنا فِيه.</h2>"
        },
        "24": {
            "verses": {
                "36:24": {
                    "id": 24
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
