                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "70": {
            "verses": {
                "36:70": {
                    "id": 70
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَيَحِقَّ ٱلۡقَوۡلُ﴾: أي: تَجِبَ كلمةُ العذابِ.</h2>"
        },
        "71": {
            "verses": {
                "36:71": {
                    "id": 71
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿مِمَّا عَمِلَتۡ أَيۡدِينَآ﴾: أي: مما أبْدَعْناهُ وَعَمِلْناهُ.</p>\n<p>﴿لَهَا مَٰلِكُونَ﴾: مَالِكُونَ أَمْرَها، يَتَصَرَّفُونَ بِها كيفَ شَاؤُوا.</p>"
        },
        "72": {
            "verses": {
                "36:72": {
                    "id": 72
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَذَلَّلۡنَٰهَا لَهُمۡ﴾: سَخَّرْناها لَهُم.</h2>\n<h2>﴿رَكُوبُهُمۡ﴾: مَرْكُوبُهم الّذي يَرْكَبُونَه.</h2>"
        },
