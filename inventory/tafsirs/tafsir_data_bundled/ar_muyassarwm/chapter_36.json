                "language_name": "english"
            },
            "text": "<h2>﴿تَطَيَّرۡنَا بِكُمۡ﴾: تَشَاءَمْنا بِكُم.</h2>\n<h2>﴿لَنَرۡجُمَنَّكُمۡ﴾: لَنَقْتُلَنَّكُم رَمْياً بالِحجارَةِ.</h2>"
        },
        "19": {
            "verses": {
                "36:19": {
                    "id": 19
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿طَٰٓئِرُكُم مَّعَكُمۡ﴾: شُؤْمُكُم مَعَكُم، الذي هو كُفْرُكُم وشِرْكُكُم.</p>"
        },
        "20": {
            "verses": {
                "36:20": {
                    "id": 20
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَقۡصَا ٱلۡمَدِينَةِ﴾: مِن مَكانٍ بَعِيدٍ فِيها.</h2>"
        },
        "21": {
            "verses": {
                "36:21": {
                    "id": 21
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
