            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ءَايَةٞ لَّهُمُ﴾: علامةٌ لَهُم.</h2>\n<h2>﴿نَسۡلَخُ مِنۡهُ﴾: نَنْزِعُ مِنْهُ.</h2>"
        },
        "38": {
            "verses": {
                "36:38": {
                    "id": 38
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿لِمُسۡتَقَرّٖ لَّهَا﴾: مُسْتَقَرُّهَا تَحْتَ العَرْشِ، كما جاء في الحديثِ المتَّفقِ عَلَيه.</p>"
        },
