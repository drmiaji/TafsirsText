            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ضَلَٰلٖ مُّبِينٍ﴾: خَطَأٍ ظاهِرٍ.</h2>"
        },
        "25": {
