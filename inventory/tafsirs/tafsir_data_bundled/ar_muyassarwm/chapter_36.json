            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡأَزۡوَٰجَ﴾: الأَصْنافَ والأَنْواعَ.</h2>"
        },
        "37": {
            "verses": {
                "36:37": {
                    "id": 37
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
