                "language_name": "english"
            },
            "text": "<h2>﴿ٱصۡلَوۡهَا﴾: ادخُلُوا جَهَنَّمَ وقاسُوا حَرَّها.</h2>"
        },
        "65": {
            "verses": {
                "36:65": {
