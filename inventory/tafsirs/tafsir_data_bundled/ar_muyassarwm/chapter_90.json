            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿لَآ أُقۡسِمُ بِهَٰذَا ٱلۡبَلَدِ﴾: أَقْسَمَ اللهُ بِهذَا البَلَدِ الحَرامِ، وهو «مَكَّةُ».</p>"
        },
        "2": {
            "verses": {
                "90:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿حِلُّۢ بِهَٰذَا ٱلۡبَلَدِ﴾: مُقِيمٌ في هذا البلدِ الحرامِ، أو حَلالٌ يَحِلُّ لَكَ القِتالُ فِيه ساعَةً من نَّهارٍ يَومَ فتحِ مَكَّةَ.</p>"
        },
        "3": {
            "verses": {
                "90:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَوَالِدٖ﴾: آدمَ عَلَيهِ السَّلامُ.</h2>\n<h2>﴿وَمَا وَلَدَ﴾: وَمَا تَنَاسَلَ مِنْهُ مِن وَلَدٍ.</h2>"
        },
        "4": {
            "verses": {
                "90:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فِي كَبَدٍ﴾: في شِدَّةٍ وعَنَاءٍ مِن مُكَابَدَةِ الدُّنيا.</h2>"
        },
        "5": {
            "verses": {
                "90:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَيَحۡسَبُ﴾: أَيَظُنُّ بِما جَمَعَهُ مِن مالٍ.</h2>"
        },
        "6": {
            "verses": {
                "90:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَهۡلَكۡتُ﴾: أَنفَقْتُ.</h2>\n<h2>﴿لُبَدًا﴾: كَثِيراً.</h2>"
        },
        "7": {
            "verses": {
                "90:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَيَحۡسَبُ﴾: أَيَظُنُّ في فِعْلِهِ هَذا.</h2>\n<p>﴿أَن لَّمۡ يَرَهُۥٓ أَحَدٌ﴾: أَنَّ اللهَ عَزَّ وَجَلَّ لا يراهُ، ولا يحاسِبُهُ على الصَّغِيرِ والكَبِيرِ.</p>"
        },
        "8": {
            "verses": {
                "90:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "9": {
            "verses": {
                "90:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "10": {
            "verses": {
                "90:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَهَدَيۡنَٰهُ ٱلنَّجۡدَيۡنِ﴾: وبيَّنَّا لَهُ سَبيلَي الخيرِ والشَّرِّ؟</p>"
        },
        "11": {
            "verses": {
                "90:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿فَلَا ٱقۡتَحَمَ ٱلۡعَقَبَةَ﴾: فَهَلَّا تَجاوَزَ مَشَقَّةَ الآخِرةِ بإنفاقِ مالِه، فَيأمَنَ.</p>"
        },
        "12": {
            "verses": {
                "90:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَآ أَدۡرَىٰكَ﴾: وأيُّ شَيءٍ أَعْلَمَكَ؟</h2>\n<p>﴿مَا ٱلۡعَقَبَةُ﴾: ما مَشَقَّةُ الآخِرَةِ، وما يُعِينُ عَلى تَجَاوُزِها؟</p>"
        },
        "13": {
            "verses": {
                "90:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿فَكُّ رَقَبَةٍ﴾: عِتْقُ رَقَبَةٍ مُؤْمِنَةٍ مِنْ أَسْرِ الرِّقِ.</p>"
        },
        "14": {
            "verses": {
                "90:14": {
                    "id": 14
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ذِي مَسۡغَبَةٖ﴾: صاحِبِ مجاعَةٍ شَدِيدَةٍ.</h2>"
        },
        "15": {
            "verses": {
                "90:15": {
                    "id": 15
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ذَا مَقۡرَبَةٍ﴾: مِن ذَويِ القرابةِ.</h2>"
        },
        "16": {
            "verses": {
                "90:16": {
                    "id": 16
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿أَوۡ مِسۡكِينٗا ذَا مَتۡرَبَةٖ﴾: أو فَقِيراً مُعْدِماً لا شَيءَ عِنْدَهُ.</p>"
        },
        "17": {
            "verses": {
                "90:17": {
                    "id": 17
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَتَوَاصَوۡاْ﴾: وأَوْصَى بعضُهُم بَعْضاً.</h2>\n<h2>﴿بِٱلۡمَرۡحَمَةِ﴾: بالرَّحْمَةِ بالخلقِ.</h2>"
        },
        "18": {
            "verses": {
                "90:18": {
                    "id": 18
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿أَصۡحَٰبُ ٱلۡمَيۡمَنَةِ﴾: هُمْ أصْحابُ اليمِينِ، الَّذِينَ يُؤخذُ بِهم يومَ القيامةِ ذاتَ اليمِينِ إلى الجنَّةِ.</p>"
        },
        "19": {
            "verses": {
                "90:19": {
                    "id": 19
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِـَٔايَٰتِنَا﴾: بالقُرْآنِ.</h2>\n<p>﴿أَصۡحَٰبُ ٱلۡمَشۡـَٔمَةِ﴾: الَّذِينَ يُؤخَذُ بِهم يومَ القيامِة ذاتَ الشِّمالِ إلى النَّار.</p>"
        },
        "20": {
            "verses": {
                "90:20": {
                    "id": 20
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مُؤۡصَدَةُۢ﴾: مُطْبَقةٌ مُغْلَقَةٌ عَلَيهِم.</h2>"
        }
    }
}