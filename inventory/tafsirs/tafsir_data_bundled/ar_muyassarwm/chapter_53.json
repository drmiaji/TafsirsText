            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿لَيۡسَ لَهَا مِن دُونِ ٱللَّهِ كَاشِفَةٌ﴾: لَا يَعْلَمُ بوَقْتِ وُقُوعِها إِلَّا اللهُ.</p>"
        },
