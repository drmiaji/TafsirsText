            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلشِّعۡرَىٰ﴾: نَجْمٍ مُضِيءٍ، كانَ يَعْبُدُهُ بَعْضُ أَهْل الجاهِلِيَّةِ.</p>"
        },
        "50": {
            "verses": {
