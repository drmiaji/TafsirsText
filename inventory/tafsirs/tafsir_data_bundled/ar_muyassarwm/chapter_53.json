            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَأَطۡغَىٰ﴾: أَشَدَّ طُغْياناً وَتَمَرُّداً على اللهِ.</h2>"
        },
        "53": {
            "verses": {
                "53:53": {
                    "id": 53
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
