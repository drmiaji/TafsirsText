            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَزِفَتِ﴾: قَرُبَتْ.</h2>\n<h2>﴿ٱلۡأٓزِفَةُ﴾: القِيامَةُ.</h2>"
        },
        "58": {
