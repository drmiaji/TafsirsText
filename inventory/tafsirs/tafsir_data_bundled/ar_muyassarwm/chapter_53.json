            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿سَعۡيَهُۥ﴾: عَمَلَه واكْتِسَابَه.</h2>\n<h2>﴿يُرَىٰ﴾: يُشاهَدُ عِنْدَ الحسابِ.</h2>"
        },
        "41": {
            "verses": {
                "53:41": {
                    "id": 41
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
