            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلۡمُنتَهَىٰ﴾: انْتِهَاءَ جَمِيعِ خَلْقِهِ وَرُجُوعَهُم إلى حُكْمِهِ في الآخِرةِ.</p>"
        },
        "43": {
            "verses": {
                "53:43": {
                    "id": 43
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿أَضۡحَكَ وَأَبۡكَىٰ﴾: خَلَقَ في الإنْسانِ قُوَّتَي الضَّحِكِ والبُكَاءِ، وأَسْبَابَهُما مِن سُرورٍ وحُزْنٍ.</p>"
        },
        "44": {
