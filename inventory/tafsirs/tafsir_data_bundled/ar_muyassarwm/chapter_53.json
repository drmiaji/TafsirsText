                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿سُلۡطَٰنٍ﴾: حُجَّةٍ.</h2>\n<h2>﴿وَمَا تَهۡوَى ٱلۡأَنفُسُ﴾: تَشْتَهِيهِ وتَمِيلُ إِلَيهِ.</h2>"
        },
        "24": {
            "verses": {
                "53:24": {
                    "id": 24
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
