            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَأَقۡنَىٰ﴾: أرضَى الَّذِي أَغْناهُ.</h2>"
        },
        "49": {
            "verses": {
                "53:49": {
                    "id": 49
                }
