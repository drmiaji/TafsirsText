                "language_name": "english"
            },
            "text": "<h2>﴿أَلَّا تَزِرُ﴾: أي لَا تَحْمِلُ وَلَا تُؤَاخَذُ.</h2>\n<h2>﴿وَازِرَةٞ﴾: حاملةُ إِثْمٍ.</h2>"
        },
        "39": {
            "verses": {
                "53:39": {
                    "id": 39
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿لَيۡسَ لِلۡإِنسَٰنِ إِلَّا مَا سَعَىٰ﴾: لا يَحْصُلُ للإنسانِ مِنَ الأجْرِ إلَّا ما كَسَبَ هُوَ لِنَفْسِهِ بِسَعْيِهِ.</p>"
        },
        "40": {
            "verses": {
                "53:40": {
                    "id": 40
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
