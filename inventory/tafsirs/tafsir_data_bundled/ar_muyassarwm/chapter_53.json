            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ءَالَآءِ﴾: نِعَمِ، جَمْعُ إِلًى.</h2>\n<h2>﴿تَتَمَارَىٰ﴾: تَتَشَكَّكُ.</h2>"
        },
        "56": {
            "verses": {
                "53:56": {
                    "id": 56
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
