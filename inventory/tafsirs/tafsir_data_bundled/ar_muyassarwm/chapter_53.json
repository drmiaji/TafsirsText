                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿شَدِيدُ ٱلۡقُوَىٰ﴾: مَلَكٌ شَدِيدُ القُوَّةِ.</h2>"
        },
        "6": {
            "verses": {
                "53:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مِرَّةٖ﴾: مَنْظَرٍ حَسَنٍ.</h2>\n<h2>﴿فَٱسۡتَوَىٰ﴾: عَلَى صُورَتِهِ الحقِيقِيَّةِ للرَّسولِ ﷺ.</h2>"
        },
        "7": {
            "verses": {
                "53:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿بِٱلۡأُفُقِ ٱلۡأَعۡلَىٰ﴾: أُفُقِ الشَّمسِ عِنْدَ مَطْلَعِها.</p>"
        },
        "8": {
            "verses": {
                "53:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَتَدَلَّىٰ﴾: فَزَادَ في القُرْبِ.</h2>"
        },
        "9": {
            "verses": {
                "53:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
