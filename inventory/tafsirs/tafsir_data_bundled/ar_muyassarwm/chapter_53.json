            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَأَكۡدَىٰٓ﴾: تَوَقَّفَ عَنِ العَطاءِ.</h2>"
        },
        "35": {
