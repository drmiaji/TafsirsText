            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿قَابَ قَوۡسَيۡنِ﴾: مِقْدَارَ قَوسَينِ.</h2>"
        },
        "10": {
            "verses": {
