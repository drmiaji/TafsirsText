            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يُجۡزَىٰهُ﴾: يُجزَى الإنسانُ عَلَى سَعْيِهِ.</h2>\n<h2>﴿ٱلۡأَوۡفَىٰ﴾: التامَّ الكامِلَ.</h2>"
        },
        "42": {
            "verses": {
                "53:42": {
                    "id": 42
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
