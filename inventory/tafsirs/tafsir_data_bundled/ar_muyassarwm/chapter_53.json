            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿صُحُفِ مُوسَىٰ﴾: هي أسْفارُ التَّوراةِ.</h2>"
        },
        "37": {
            "verses": {
                "53:37": {
                    "id": 37
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِبۡرَٰهِيمَ﴾: وصُحُفِ إبراهِيمَ التي سُجِّل فيها ما أَوْحَى اللهُ إليهِ.</p>\n<h2>﴿وَفَّىٰٓ﴾: بَلَّغَ ما أُرْسِلَ بِه.</h2>"
        },
