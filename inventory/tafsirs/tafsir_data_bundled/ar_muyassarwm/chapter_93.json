            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿سَجَىٰ﴾: اشْتَدَّ ظَلامُهُ.</h2>"
        },
        "3": {
            "verses": {
                "93:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
