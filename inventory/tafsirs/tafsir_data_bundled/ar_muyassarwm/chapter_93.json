            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَلَا تَقۡهَرۡ﴾: فلا تُسِئْ مُعامَلَتَهُ.</h2>"
        },
        "10": {
            "verses": {
