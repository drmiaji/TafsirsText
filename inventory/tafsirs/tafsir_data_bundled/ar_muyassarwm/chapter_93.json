            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "5": {
            "verses": {
                "93:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَلَسَوۡفَ يُعۡطِيكَ رَبُّكَ﴾: -أيُّها النَّبِيُّ- مِنْ أَنواعِ الإنْعام في الآخِرَةِ.</p>"
        },
        "6": {
            "verses": {
                "93:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَـَٔاوَىٰ﴾: فَآوَاكَ ورَعاكَ.</h2>"
        },
        "7": {
            "verses": {
                "93:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ضَآلّٗا﴾: لا تَدْرِي ما الكِتابُ ولا الإِيمانُ؟</h2>\n<h2>﴿فَهَدَىٰ﴾: فَعَلَّمكَ مالَمْ تَكُن تَعْلَمُ.</h2>"
        },
        "8": {
            "verses": {
                "93:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
