            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿عَآئِلٗا﴾: فقِيراً.</h2>\n<p>﴿فَأَغۡنَىٰ﴾: فَسَاقَ لَكَ رِزْقَكَ، وأَغْنَى نَفْسَكَ بالقناعَةِ والصَّبْرِ.</p>"
        },
        "9": {
            "verses": {
                "93:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
