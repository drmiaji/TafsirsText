            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مَا وَدَّعَكَ﴾: ما تَرَكَكَ.</h2>\n<p>﴿وَمَا قَلَىٰ﴾: وما أَبْغَضَكَ حِينَ أَبْطَأَ الوحْيُ عَنكَ.</p>"
        },
