            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "19": {
            "verses": {
                "32:19": {
                    "id": 19
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿نُزُلَۢا﴾: ما يُهيَّأُ للنَّزيلِ ضِيافَةً وإكْرَاماً.</h2>"
        },
        "20": {
            "verses": {
                "32:20": {
                    "id": 20
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَمَأۡوَىٰهُمُ﴾: المكَانُ الَّذي يَأْوُونَ إليه.</h2>"
        },
        "21": {
            "verses": {
                "32:21": {
                    "id": 21
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلۡعَذَابِ ٱلۡأَدۡنَىٰ﴾: وهو ما يُصِيبُهُم في الدُّنيا مِنَ البَلاءِ والِمحَنِ.</p>\n<p>﴿ٱلۡعَذَابِ ٱلۡأَكۡبَرِ﴾: وهو ما يُصِيبُهُم يومَ القِيامةِ مِنْ عَذَابِ جَهَنَّمَ.</p>"
        },
        "22": {
            "verses": {
                "32:22": {
                    "id": 22
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ذُكِّرَ﴾: وُعِظَ.</h2>"
        },
        "23": {
            "verses": {
                "32:23": {
                    "id": 23
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فِي مِرۡيَةٖ﴾: في شَكٍّ.</h2>\n<p>﴿مِن لِّقَآئِهِۦ﴾: أي: مِن لِقَاءِ مُوسَى عَلَيهِ الصَّلاةُ والسَّلامُ.</p>"
        },
        "24": {
            "verses": {
