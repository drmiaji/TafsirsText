            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَٱنتَظِرۡ﴾: أي: انْتَظِرْ ما اللهُ صانِعٌ بِهِم.</h2>"
        }
    }
