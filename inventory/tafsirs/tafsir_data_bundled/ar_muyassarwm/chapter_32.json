                "32:25": {
                    "id": 25
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يَفۡصِلُ﴾: يَقْضِي.</h2>"
        },
        "26": {
            "verses": {
                "32:26": {
                    "id": 26
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَوَ لَمۡ يَهۡدِ لَهُمۡ﴾: أَوَلم يُبَيِّنْ لَهُم.</h2>\n<h2>﴿مِنَ ٱلۡقُرُونِ﴾: مِنَ الأُمَمِ السَّابِقَةِ.</h2>\n<h2>﴿لَأٓيَٰتٍ﴾: لَعِبَراً وعِظاتٍ.</h2>"
        },
        "27": {
            "verses": {
                "32:27": {
                    "id": 27
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلۡجُرُزِ﴾: الأرْضِ اليابِسةِ الغَلِيظَةِ الجرْداءِ الَّتي لا نَباتَ فِيها.</p>"
        },
        "28": {
            "verses": {
                "32:28": {
                    "id": 28
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿هَٰذَا ٱلۡفَتۡحُ﴾: هذا القضاءُ بين العِبادِ.</h2>"
        },
        "29": {
            "verses": {
                "32:29": {
                    "id": 29
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يُنظَرُونَ﴾: يُمْهَلُونَ لِيؤْمِنُوا.</h2>"
        },
        "30": {
            "verses": {
                "32:30": {
                    "id": 30
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
