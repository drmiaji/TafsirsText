            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿هَلۡ﴾: قَدْ.</h2>\n<p>﴿ٱلۡغَٰشِيَةِ﴾: القِيامةِ الَّتِي تَغْشَى النَّاسَ بأهْوالِها.</p>"
        },
        "2": {
            "verses": {
                "88:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وُجُوهٞ﴾: وُجُوهُ الكُفَّارِ.</h2>\n<h2>﴿خَٰشِعَةٌ﴾: ذَلِيلةٌ بالعذابِ.</h2>"
        },
        "3": {
            "verses": {
                "88:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿عَامِلَةٞ﴾: مُجْهَدَةٌ بالعَمَلِ.</h2>\n<h2>﴿نَاصِبَةٞ﴾: مُتْعَبَةٌ.</h2>"
        },
        "4": {
            "verses": {
                "88:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿تَصۡلَىٰ﴾: تُقاسِي ناراً.</h2>\n<h2>﴿حَامِيَةٗ﴾: شَدِيدَة التَّوَهُّجِ.</h2>"
        },
        "5": {
            "verses": {
                "88:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ءَانِيَةٖ﴾: بَلَغَتْ مُنْتَهى الحرارةِ.</h2>"
        },
        "6": {
            "verses": {
                "88:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ضَرِيعٖ﴾: نَبْتٍ ذي شَوْكٍ لَاصِقٍ بالأرْضِ.</h2>"
        },
        "7": {
            "verses": {
                "88:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَلَا يُغۡنِي مِن جُوعٖ﴾: ولا يَسُدُّ جُوعَهُ.</h2>"
        },
        "8": {
            "verses": {
                "88:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وُجُوهٞ﴾: وُجُوهُ المؤمِنينَ.</h2>\n<h2>﴿نَاعِمَةٞ﴾: ذاتُ نِعْمَةٍ وَكَرَامةٍ.</h2>"
        },
        "9": {
            "verses": {
                "88:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لِسَعۡيِهَا﴾: لِعَمَلِها الَّذِي عَمِلَتْهُ في الدُّنيا.</h2>\n<p>﴿رَاضِيَةٞ﴾: في الآخِرَةِ حِينَ أُعْطِيَتِ الجنَّةَ بِعَمَلِها.</p>"
        },
        "10": {
            "verses": {
                "88:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿عَالِيَةٖ﴾: رَفِيعةِ المكانِ والمكانةِ.</h2>"
        },
        "11": {
            "verses": {
                "88:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لَٰغِيَةٗ﴾: كَلِمةَ لَغْوٍ.</h2>"
        },
        "12": {
            "verses": {
                "88:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿جَارِيَةٞ﴾: تَتَدَفَّقُ مِياهُها.</h2>"
        },
        "13": {
            "verses": {
                "88:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
