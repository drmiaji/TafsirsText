                "language_name": "english"
            },
            "text": "<h2>﴿كَيۡفَ رُفِعَتۡ﴾: عَنِ الأرْضِ بِلا عَمَدٍ؟</h2>"
        },
        "19": {
            "verses": {
                "88:19": {
                    "id": 19
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿نُصِبَتۡ﴾: رُفِعتْ حتَّى كانتْ بارزةً على وَجْهِ الأرضِ.</h2>"
        },
        "20": {
            "verses": {
                "88:20": {
                    "id": 20
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿سُطِحَتۡ﴾: بُسِطَتْ ومُهِّدتْ.</h2>"
        },
        "21": {
            "verses": {
                "88:21": {
                    "id": 21
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَذَكِّرۡ﴾: فَعِظْ.</h2>\n<h2>﴿مُذَكِّرٞ﴾: واعِظٌ.</h2>"
        },
        "22": {
            "verses": {
                "88:22": {
                    "id": 22
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِمُصَيۡطِرٍ﴾: بِمُسَلَّطٍ، فَتُكْرِهَهُم على الإيمانِ.</h2>"
        },
        "23": {
            "verses": {
                "88:23": {
                    "id": 23
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿تَوَلَّىٰ﴾: أَعْرَضَ وَأصَرَّ عَلى الكُفْرِ.</h2>"
        },
        "24": {
            "verses": {
                "88:24": {
                    "id": 24
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡعَذَابَ ٱلۡأَكۡبَرَ﴾: النَّارَ.</h2>"
        },
        "25": {
            "verses": {
                "88:25": {
                    "id": 25
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿إِيَابَهُمۡ﴾: مَرْجِعَهُم بَعْدَ الموتِ.</h2>"
        },
        "26": {
            "verses": {
                "88:26": {
                    "id": 26
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
