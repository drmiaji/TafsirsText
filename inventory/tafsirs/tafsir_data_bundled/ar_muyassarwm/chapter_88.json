            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مَوۡضُوعَةٞ﴾: مُعَدَّةٌ للشَّارِبِينَ.</h2>"
        },
        "15": {
            "verses": {
                "88:15": {
                    "id": 15
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَنَمَارِقُ﴾: وَوَسائِدُ ومَرافِقُ.</h2>\n<h2>﴿مَصۡفُوفَةٞ﴾: بَعضُها بِجَنبِ بَعْضٍ.</h2>"
        },
        "16": {
            "verses": {
                "88:16": {
                    "id": 16
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَزَرَابِيُّ﴾: وبُسُطٌ.</h2>\n<h2>﴿مَبۡثُوثَةٌ﴾: كَثِيرةٌ مَفْرُوشَةٌ.</h2>"
        },
        "17": {
            "verses": {
