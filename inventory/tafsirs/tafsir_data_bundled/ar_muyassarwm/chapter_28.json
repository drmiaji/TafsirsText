            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿مِنَ ٱلۡمَقۡبُوحِينَ﴾: مِنَ المذْمُومِينَ والمُبْعَدِينَ مِن كُلِّ خَيْرٍ.</p>"
        },
