            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أُوتِيتُهُۥ﴾: أُعْطِيتُ هَذا المالَ.</h2>\n<h2>﴿مِنَ ٱلۡقُرُونِ﴾: مِنَ الأُمَمِ.</h2>"
        },
        "79": {
            "verses": {
