            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡأُولَىٰ﴾: الحَيَاةِ الأُولَى هي الدُّنيا.</h2>\n<h2>﴿وَٱلۡأٓخِرَةِ﴾: الدَّارِ الآخرةِ.</h2>"
        },
        "71": {
            "verses": {
