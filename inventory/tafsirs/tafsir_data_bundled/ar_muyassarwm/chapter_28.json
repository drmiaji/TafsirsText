                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡقُرُونَ ٱلۡأُولَىٰ﴾: الأُمَمَ الماضِيَةَ.</h2>"
        },
        "44": {
            "verses": {
                "28:44": {
                    "id": 44
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
