            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلطُّورِ﴾: جَبَلِ طُورِ سَيناءَ.</h2>"
        },
        "47": {
            "verses": {
