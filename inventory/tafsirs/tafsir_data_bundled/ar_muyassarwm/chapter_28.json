            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَآ أُوتِيتُم﴾: وما أُعْطِيتُم.</h2>"
        },
        "61": {
            "verses": {
