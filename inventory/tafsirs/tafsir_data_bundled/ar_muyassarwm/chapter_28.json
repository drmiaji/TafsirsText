            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿تَسۡكُنُونَ فِيهِ﴾: تَسْتَقِرُّونَ فِيه مِنَ التَّعَبِ.</h2>"
        },
        "73": {
            "verses": {
                "28:73": {
                    "id": 73
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
