            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أُوتِيَ﴾: أُعطِيَ.</h2>\n<h2>﴿لَذُو حَظٍّ﴾: لَصَاحِبُ نَصِيبٍ.</h2>"
        },
        "80": {
            "verses": {
                "28:80": {
                    "id": 80
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
