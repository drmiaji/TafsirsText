            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَلَا يَصُدُّنَّكَ﴾: ولا يَصْرِفُنَّكَ.</h2>"
        },
        "88": {
            "verses": {
                "28:88": {
                    "id": 88
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
