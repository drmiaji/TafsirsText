            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لَا تَهۡدِي﴾: أي: هِدايةَ توفِيقٍ.</h2>"
        },
        "57": {
            "verses": {
                "28:57": {
                    "id": 57
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
