            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿قَدَّرُوهَا تَقۡدِيرٗا﴾: قدَّرها السُّقاةُ على مِقْدارِ ما يَشْتَهِي الشارِبُونَ لا تَزِيدُ ولَا تَنْقُصُ.</p>"
        },
        "17": {
