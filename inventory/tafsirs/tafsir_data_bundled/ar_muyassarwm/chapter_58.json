{
    "chapter": 58,
    "verses": {
        "1": {
            "verses": {
                "58:1": {
                    "id": 1
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿تُجَٰدِلُكَ﴾: تُرَاجِعُكَ الكَلامَ في زَوْجِها، وهي خَوْلَةُ بِنْتُ ثَعْلَبةَ وزَوْجُها أوسُ بنُ الصَّامتِ.</p>\n<p>﴿تَحَاوُرَكُمَآ﴾: تَخَاطُبَكُما وَمُرَاجَعَتَكُما الكَلامَ.</p>"
        },
        "2": {
            "verses": {
                "58:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿يُظَٰهِرُونَ﴾: يَقُولُ الرَّجُلُ مِنْهُم لِزوجَتِهِ: «أنْتِ عَليَّ كَظَهْرِ أُمِّي» أي: في حُرْمَةِ النِّكَاحِ.</p>"
        },
        "3": {
            "verses": {
                "58:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ يَعُودُونَ لِمَا قَالُواْ﴾: ثُمَّ يَرْجِعُونَ عَن قَوْلِهِم وَيَعْزِمُونَ على وَطْءِ نِسائِهِم.</p>\n<p>﴿يَتَمَآسَّا﴾: يَمَسَّ أَحَدُهُما الآخَرَ، وهي كِنايةٌ عَنِ الجِماعِ.</p>"
        },
        "4": {
            "verses": {
                "58:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿مِسۡكِينٗا﴾: هو الَّذِي لا يَمْلِكُ ما يَكْفِيهِ ويَسُدُّ حاجَتَهُ.</p>"
        },
        "5": {
            "verses": {
                "58:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يُحَآدُّونَ﴾: يُشاقُّونَ ويُخالِفُونَ.</h2>\n<h2>﴿كُبِتُواْ﴾: خُذِلُوا وَأُهِينُوا.</h2>\n<h2>﴿مُهِينٞ﴾: مُذِلٌّ.</h2>"
        },
        "6": {
            "verses": {
                "58:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿أَحۡصَىٰهُ ٱللَّهُ﴾: كَتَبهُ في اللَّوحِ المحْفُوظِ، وَحَفِظَهُ عَلَيهم في صحائفِ أَعْمالِهِم.</p>\n<p>﴿شَهِيدٌ﴾: شاهِدٌ يَعْلَمُهُ وَيُحِيطُ بِهِ، فلا يعْزُبُ عنه شَيءٌ مِنْهُ.</p>"
        },
        "7": {
            "verses": {
                "58:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿نَجۡوَىٰ﴾: مُناجاةٍ ومُسارَّةٍ وما يَكْتُمُهُ النَّاسُ مِنْ أحادِيثِهِم.</p>\n<p>﴿هُوَ رَابِعُهُمۡ﴾: مُشاهِدُهُم بِعِلْمِهِ، وهو عَلَى عَرْشِهِ.</p>\n<h2>﴿وَلَآ أَدۡنَىٰ مِن ذَٰلِكَ﴾: وَلَا أَقَلَّ مِن ذَلِكَ.</h2>\n<h2>﴿هُوَ مَعَهُمۡ﴾: وهُوَ فَوْقَ العَرْشِ وعلمه معهم.</h2>"
        },
        "8": {
            "verses": {
                "58:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلنَّجۡوَىٰ﴾: حَدِيثِ السِّرِّ الَّذِي يُثيرُ الشَّكَّ في نُفُوسِ المؤمِنينَ.</p>\n<h2>﴿وَيَتَنَٰجَوۡنَ﴾: يَتَحَدَّثُونَ سِرّاً.</h2>\n<h2>﴿حَيَّوۡكَ﴾: سَلَّمُوا عَلَيكَ.</h2>\n<h2>﴿حَسۡبُهُمۡ﴾: كافِيهِم مِنَ العَذابِ.</h2>\n<h2>﴿يَصۡلَوۡنَهَا﴾: يَدْخُلُونَها وَيُقاسُونَ حَرَّها.</h2>\n<h2>﴿فَبِئۡسَ ٱلۡمَصِيرُ﴾: فَسَاءَ المنْقَلَبُ والمرْجِعُ.</h2>"
        },
