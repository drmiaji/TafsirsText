            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿جُنَّةٗ﴾: وِقايَةً وسُتْرَةً.</h2>\n<h2>﴿مُهِينٞ﴾: مُذِلٌّ في النَّارِ.</h2>"
        },
        "17": {
            "verses": {
                "58:17": {
                    "id": 17
                }
            },
            "resource_id": 109,
