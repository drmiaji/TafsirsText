            },
            "text": "<h2>﴿ٱبۡتُلِيَ﴾: اخْتُبِر.</h2>\n<h2>﴿وَزُلۡزِلُواْ﴾: واضْطَرَبُوا.</h2>"
        },
        "12": {
            "verses": {
                "33:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
