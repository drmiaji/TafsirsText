            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِفَٰحِشَةٖ مُّبَيِّنَةٖ﴾: بمَعْصِيةٍ ظاهِرةِ القُبْحِ.</h2>\n<h2>﴿يَسِيرٗا﴾: هَيِّناً.</h2>"
        },
        "31": {
            "verses": {
                "33:31": {
                    "id": 31
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
