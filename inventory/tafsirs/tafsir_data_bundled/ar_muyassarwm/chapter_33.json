                "language_name": "english"
            },
            "text": "<h2>﴿لَمۡ تَطَـُٔوهَا﴾: لم تَدْخُلُوها.</h2>"
        },
        "28": {
            "verses": {
                "33:28": {
                    "id": 28
                }
