            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿لَا تُقَدِّمُواْ﴾: لا تَقْطَعُوا أَمْراً دُونَ اللهِ ورَسُولِهِ.</p>"
        },
        "2": {
            "verses": {
                "49:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَن تَحۡبَطَ﴾: خَشْيَة أَن تَبْطُلَ.</h2>\n<h2>﴿لَا تَشۡعُرُونَ﴾: لا تُحِسُّونَ.</h2>"
        },
        "3": {
            "verses": {
                "49:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يَغُضُّونَ﴾: يَخْفِضُونَ.</h2>\n<h2>﴿ٱمۡتَحَنَ﴾: اخْتَبَرَ.</h2>"
        },
        "4": {
            "verses": {
                "49:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡحُجُرَٰتِ﴾: غُرَفِ النَّبِيِّ ﷺ.</h2>"
        },
        "5": {
            "verses": {
                "49:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
