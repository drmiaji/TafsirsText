        },
        "11": {
            "verses": {
                "49:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يَسۡخَرۡ﴾: يَهْزَأْ.</h2>\n<p>﴿وَلَا تَلۡمِزُوٓاْ أَنفُسَكُمۡ﴾: وَلَا يَعِبْ بَّعْضُكُم بَعْضاً.</p>\n<h2>﴿وَلَا تَنَابَزُواْ﴾: ولا يَدْعُ بعضُكُم بَعْضاً.</h2>\n<h2>﴿بِٱلۡأَلۡقَٰبِ﴾: بِما يَكْرَهُ مِنَ الألقابِ.</h2>\n<h2>﴿ٱلِٱسۡمُ﴾: الذِّكْرُ والتَّسمِيَةُ.</h2>\n<p>﴿ٱلۡفُسُوقُ﴾: ما ذُكِرَ مِنَ السُّخْرِيَةِ واللَّمْزِ والتنابُزِ بالألقابِ.</p>"
        },
        "12": {
            "verses": {
                "49:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَلَا تَجَسَّسُواْ﴾: وَلَا تُفَتِّشُوا عَنْ عَوْرَاتِ المُسْلِمِينَ، وَتَبْحَثُوا عَنْ أَخْبارِهِم.</p>\n<p>﴿وَلَا يَغۡتَب بَّعۡضُكُم بَعۡضًا﴾: وَلَا يَذْكُرْ بَعْضُكُم بَعْضاً بِما يَكْرَهُ في غَيبَتِهِ.</p>"
        },
        "13": {
            "verses": {
                "49:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿شُعُوبٗا﴾: نَسَباً بَعِيداً، وهي أَكْثَرُ مِنَ القبائِل.</h2>\n<p>﴿وَقَبَآئِلَ﴾: نَسَباً قَرِيباً، وهي تَدْخُل تَحْتَ الشُّعوبِ.</p>\n<h2>﴿لِتَعَارَفُوٓاْ﴾: لِيَعْرِفَ بَعْضُكُم بَعْضاً.</h2>\n<h2>﴿أَكۡرَمَكُمۡ﴾: أَشْرَفَكُم.</h2>"
        },
        "14": {
            "verses": {
                "49:14": {
                    "id": 14
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلۡأَعۡرَابُ﴾: هُمْ في الأَصْلِ سُكَّانُ البادِيةِ مِنَ العَرَبِ، والمرادُ هُنا أَعْرابُ بَنِي أَسَدِ بن خُزَيْمَةَ.</p>\n<h2>﴿لَا يَلِتۡكُم﴾: لا يَنْقُصْكُم.</h2>"
        },
        "15": {
            "verses": {
                "49:15": {
                    "id": 15
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لَمۡ يَرۡتَابُواْ﴾: لَمْ يَشُكُّوا.</h2>"
        },
        "16": {
            "verses": {
                "49:16": {
                    "id": 16
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿أَتُعَلِّمُونَ ٱللَّهَ بِدِينِكُمۡ﴾: أَتُخْبِرُونَهُ بِطاعَتِكُم؟</p>"
        },
        "17": {
            "verses": {
                "49:17": {
                    "id": 17
                }
            },
