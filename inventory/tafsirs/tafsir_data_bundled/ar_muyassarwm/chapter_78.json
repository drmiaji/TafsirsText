            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿عَمَّ﴾: عَنْ أيِّ شَيءٍ.</h2>\n<h2>﴿يَتَسَآءَلُونَ﴾: يَسْأَلُ بعضُ كُفَّارِ قُريشٍ بَعْضاً.</h2>"
        },
        "2": {
            "verses": {
                "78:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلنَّبَإِ ٱلۡعَظِيمِ﴾: الخبرِ العَظِيمِ الشَّأنِ، وهو القُرآنُ العَظِيمُ الَّذي يُنْبِئُ عَنِ البَعْثِ.</p>"
        },
        "3": {
            "verses": {
                "78:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "4": {
            "verses": {
                "78:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿كَلَّا﴾: ليسَ الأمْرُ كَما يَزْعُمُ هَؤلاءِ المشْرِكُونَ.</h2>\n<h2>﴿سَيَعۡلَمُونَ﴾: أي: عاقبةَ تَكْذِيبِهِم.</h2>"
        },
        "5": {
            "verses": {
                "78:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
