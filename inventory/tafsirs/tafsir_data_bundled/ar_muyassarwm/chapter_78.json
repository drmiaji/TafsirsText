            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "6": {
            "verses": {
                "78:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مِهَٰدٗا﴾: مُمَهَّدَةً لَكُم كالفِراشِ.</h2>"
        },
        "7": {
            "verses": {
                "78:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَوۡتَادٗا﴾: رَواسِيَ.</h2>"
        },
        "8": {
            "verses": {
                "78:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَزۡوَٰجٗا﴾: أَصْنافاً ذَكَراً وَأُنْثَى.</h2>"
        },
        "9": {
            "verses": {
                "78:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿سُبَاتٗا﴾: راحةً لأبدانِكُم.</h2>"
        },
        "10": {
            "verses": {
                "78:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿لِبَاسٗا﴾: تَلْبَسُكُم ظُلْمَتُهُ، كَما يَسْتُرُ الثَّوبُ لَابِسَهُ.</p>"
        },
        "11": {
            "verses": {
                "78:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مَعَاشٗا﴾: تَنتَشِرُونَ فِيه لِمصَالِحِكُم.</h2>"
        },
        "12": {
            "verses": {
                "78:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿سَبۡعٗا﴾: سَبْعَ سَمَواتٍ.</h2>\n<p>﴿شِدَادٗا﴾: مَتِينَةَ البِناءِ، مُحْكَمةَ الخَلْقِ والإنْشَاءِ.</p>"
        },
        "13": {
            "verses": {
                "78:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿سِرَاجٗا﴾: شَمْساً.</h2>\n<h2>﴿وَهَّاجٗا﴾: وقَّاداً مُضِيئاً.</h2>"
        },
        "14": {
            "verses": {
                "78:14": {
                    "id": 14
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡمُعۡصِرَٰتِ﴾: السُّحُبِ المُمْطِرَةِ.</h2>\n<h2>﴿ثَجَّاجٗا﴾: منصَبّاً بِكَثْرَةٍ.</h2>"
        },
        "15": {
            "verses": {
                "78:15": {
                    "id": 15
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "16": {
            "verses": {
                "78:16": {
                    "id": 16
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَلۡفَافًا﴾: مُلْتَفَّةً بعْضُها بِبَعْضٍ.</h2>"
        },
        "17": {
            "verses": {
                "78:17": {
                    "id": 17
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿يَوۡمَ ٱلۡفَصۡلِ﴾: أي: القضاءِ بينَ الخلْقِ، وهوَ يومُ القِيامَةِ.</p>\n<p>﴿مِيقَٰتٗا﴾: وَقْتاً ومِيعاداً مُحَدَّداً للأوَّلِينَ والآخِرِينَ.</p>"
        },
        "18": {
            "verses": {
                "78:18": {
                    "id": 18
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿يُنفَخُ فِي ٱلصُّورِ﴾: يَنفُخُ المَلَكُ في «القَرْنِ» إيذانًا بالبَعْثِ.</p>\n<h2>﴿أَفۡوَاجٗا﴾: أُمَماً، كلُّ أُمَّةٍ مع إمامِهِم.</h2>"
        },
        "19": {
            "verses": {
                "78:19": {
                    "id": 19
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَفُتِحَتِ﴾: شُقِّقَتْ وصُدِّعتْ.</h2>\n<h2>﴿أَبۡوَٰبٗا﴾: ذاتَ أبوابٍ كَثِيرةٍ.</h2>"
        },
        "20": {
            "verses": {
                "78:20": {
                    "id": 20
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَسُيِّرَتِ ٱلۡجِبَالُ﴾: وَنُسِفَتِ الجِبالُ.</h2>\n<p>﴿سَرَابًا﴾: يَظُنُّ مَن يَراهُ مِن بُعْدٍ ماءً، وهو في الحقِيقَةِ هَبَاءٌ.</p>"
        },
        "21": {
            "verses": {
                "78:21": {
                    "id": 21
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مِرۡصَادٗا﴾: تَرْقُبُ مَنْ يجتازُها.</h2>"
        },
        "22": {
            "verses": {
                "78:22": {
                    "id": 22
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لِلطَّٰغِينَ﴾: للكافِرِينَ الَّذِينَ طَغَوا.</h2>\n<h2>﴿مَـَٔابٗا﴾: مَرْجِعاً.</h2>"
        },
        "23": {
            "verses": {
                "78:23": {
                    "id": 23
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لَٰبِثِينَ﴾: ماكِثِينَ.</h2>\n<h2>﴿أَحۡقَابٗا﴾: دُهُوراً مُتَعاقِبةً لا تَنْقَطِعُ.</h2>"
        },
        "24": {
            "verses": {
                "78:24": {
                    "id": 24
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لَا يَذُوقُونَ﴾: لا يُحِسُّونَ.</h2>\n<h2>﴿بَرۡدٗا﴾: نَسِيماً بارداً.</h2>\n<h2>﴿شَرَابًا﴾: ماءً يُرْوي.</h2>"
        },
        "25": {
            "verses": {
                "78:25": {
                    "id": 25
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿حَمِيمٗا﴾: ماءً حارّاً.</h2>\n<h2>﴿وَغَسَّاقٗا﴾: وَصَدِيدَ أَهْلِ النَّارِ.</h2>"
        },
        "26": {
            "verses": {
                "78:26": {
                    "id": 26
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وِفَاقًا﴾: مُوافِقاً لأَعْمالِهِم.</h2>"
        },
        "27": {
            "verses": {
                "78:27": {
                    "id": 27
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿لَا يَرۡجُونَ حِسَابٗا﴾: لا يَتَوَقَّعُونَ وُقُوعَ الجَزَاءِ يَومَ القِيامَةِ.</p>"
        },
        "28": {
            "verses": {
                "78:28": {
                    "id": 28
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِـَٔايَٰتِنَا﴾: بِما جاءَتْهُم بِهِ الرُّسُلُ.</h2>"
        },
        "29": {
            "verses": {
                "78:29": {
                    "id": 29
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿كِتَٰبٗا﴾: كَتَبْناهُ في اللَّوحِ المَحْفُوظِ.</h2>"
        },
        "30": {
            "verses": {
                "78:30": {
                    "id": 30
                }
            },
