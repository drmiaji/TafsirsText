            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مَفَازًا﴾: فَوْزاً بِدُخُولِهِم الجنَّةَ.</h2>"
        },
        "32": {
            "verses": {
                "78:32": {
                    "id": 32
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
