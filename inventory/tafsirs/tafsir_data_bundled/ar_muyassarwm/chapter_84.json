{
    "chapter": 84,
    "verses": {
        "1": {
            "verses": {
                "84:1": {
                    "id": 1
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱنشَقَّتۡ﴾: تَصَدَّعتْ يومَ القِيامَةِ.</h2>"
        },
        "2": {
            "verses": {
                "84:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَأَذِنَتۡ لِرَبِّهَا﴾: وَأَطاعَتْ أَمْرَ رَبِّها.</h2>\n<h2>﴿وَحُقَّتۡ﴾: وحُقَّ لَها أَن تَنقَادَ لِأَمْرِهِ.</h2>"
        },
        "3": {
            "verses": {
                "84:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مُدَّتۡ﴾: بُسِطَتْ وَوُسِّعَتْ.</h2>"
        },
        "4": {
            "verses": {
                "84:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَلۡقَتۡ مَا فِيهَا﴾: وَقَذَفَتْ ما في بَطْنِها مِنَ الأمْوَاتِ.</p>\n<h2>﴿وَتَخَلَّتۡ﴾: لم يَبْقَ شَيءٌ مِمَّا في بَطْنِها.</h2>"
        },
        "5": {
            "verses": {
                "84:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَذِنَتۡ لِرَبِّهَا﴾: وانْقادَتْ لِرَبِها فِيما أَمَرها بِهِ.</p>"
        },
        "6": {
            "verses": {
                "84:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿كَادِحٌ﴾: ساعٍ إلى اللهِ.</h2>\n<h2>﴿فَمُلَٰقِيهِ﴾: تُلاقِي الله يَومَ القِيامَةِ.</h2>"
        },
        "7": {
            "verses": {
                "84:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أُوتِيَ كِتَٰبَهُۥ﴾: أُعطِيَ صَحِيفةَ أعمالِهِ.</h2>"
        },
        "8": {
            "verses": {
                "84:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يَسِيرٗا﴾: سَهْلا.</h2>"
        },
        "9": {
            "verses": {
                "84:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَيَنقَلِبُ﴾: وَيَرْجِعُ.</h2>"
        },
        "10": {
            "verses": {
                "84:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿كِتَٰبَهُۥ﴾: صَحِيفةَ أَعْمالِهِ.</h2>"
        },
        "11": {
            "verses": {
                "84:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يَدۡعُواْ ثُبُورٗا﴾: أَيْ: بِالْهَلَاكِ.</h2>"
        },
        "12": {
            "verses": {
                "84:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَيَصۡلَىٰ سَعِيرًا﴾: وَيَدْخُلُ النَّارَ مُقاسِياً حَرَّها.</p>"
        },
        "13": {
            "verses": {
                "84:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مَسۡرُورًا﴾: مَغْرُوراً لا يُفَكِّرُ في العواقِبِ.</h2>"
        },
        "14": {
            "verses": {
                "84:14": {
                    "id": 14
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يَحُورَ﴾: يَرْجِعَ إلى خالِقِه لِلْحِسابِ.</h2>"
        },
        "15": {
            "verses": {
                "84:15": {
                    "id": 15
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "16": {
            "verses": {
                "84:16": {
                    "id": 16
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِٱلشَّفَقِ﴾: باحْمِرارِ الأُفُقِ عِنْدَ الغُرُوب.</h2>"
        },
        "17": {
            "verses": {
                "84:17": {
                    "id": 17
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَا وَسَقَ﴾: وما جَمَعَ من الدَّوابِّ والحَشراتِ والهَوَامِّ وَغَيرِ ذَلِكَ.</p>"
        },
        "18": {
            "verses": {
                "84:18": {
                    "id": 18
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱتَّسَقَ﴾: تَكَامَلَ نُورُهُ.</h2>"
        },
        "19": {
            "verses": {
                "84:19": {
                    "id": 19
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿طَبَقًا عَن طَبَقٖ﴾: أطواراً مُتَعَدِّدَةً وَأَحْوالاً مُتَبايِنَةً: مِنَ النُّطْفَةِ إلى العَلَقَةِ إلى المُضْغةِ إلى نَفْخِ الرُّوحِ، إلى الموتِ، إلى البعْثِ والنُّشُورِ.</p>"
        },
        "20": {
            "verses": {
                "84:20": {
                    "id": 20
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿فَمَا لَهُمۡ لَا يُؤۡمِنُونَ﴾: فأيُّ شَيءٍ يَمْنَعُهُم مِنَ الإيمانِ بَعْدَ ما وُضِّحَتْ لَهُمُ الآياتُ؟</p>"
        },
        "21": {
            "verses": {
                "84:21": {
                    "id": 21
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿لَا يَسۡجُدُونَ﴾: لا يَخْضَعُونَ للهِ، ولا يُسَلِّمُونَ بِما جاءَ في القُرآنِ.</p>"
        },
        "22": {
            "verses": {
                "84:22": {
                    "id": 22
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "23": {
            "verses": {
                "84:23": {
                    "id": 23
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿بِمَا يُوعُونَ﴾: بِما يَكْتُمُونَ مِن العِنادِ مَعَ عِلْمِهِم بأنَّ ما جاءَ بهِ القرآنُ حَقٌّ.</p>"
        },
        "24": {
            "verses": {
                "84:24": {
                    "id": 24
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَبَشِّرۡهُم﴾: أي: بَشِّرْ هَؤُلاءِ المكذِّبِينَ.</h2>"
        },
        "25": {
            "verses": {
                "84:25": {
                    "id": 25
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿غَيۡرُ مَمۡنُونِۭ﴾: غَيرُ مَقْطُوعٍ ولا مَنْقُوصٍ.</h2>"
        }
    }
}