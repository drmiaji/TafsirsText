                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿حمٓ﴾: سَبَقَ الكلامُ عَلى الحُرُوفِ المقَطَّعةِ أوَّلَ سُورَةِ البَقَرةِ.</p>"
        },
        "2": {
            "verses": {
                "44:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡمُبِينِ﴾: الواضِحِ لَفْظاً وَمَعْنىً.</h2>"
        },
        "3": {
            "verses": {
                "44:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مُبَٰرَكَةٍ﴾: كَثِيرَةِ الخَيراتِ، وهي لَيلةُ القَدْرِ.</h2>"
        },
        "4": {
            "verses": {
                "44:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿يُفۡرَقُ﴾: يُقضَىٰ ويُفْصَلُ مِنَ اللَّوْحِ المحْفُوظِ إلى الكَتَبةِ مِنَ الملائِكَةِ.</p>\n<h2>﴿حَكِيمٍ﴾: مُحْكَمٍ.</h2>"
        },
        "5": {
            "verses": {
