            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مِمَّا غَنِمۡتُمۡ﴾: مِنْ قِتالِ عَدُوِّكم وفِداءِ الأسرى.</h2>"
        },
        "70": {
            "verses": {
                "8:70": {
                    "id": 70
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
