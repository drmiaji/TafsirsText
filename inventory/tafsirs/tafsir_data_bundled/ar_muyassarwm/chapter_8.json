                "language_name": "english"
            },
            "text": "<h2>﴿إِن كَانَ هَٰذَا﴾: ما جاءَ به محمدٌ ﷺ .</h2>"
        },
        "33": {
            "verses": {
                "8:33": {
                    "id": 33
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
