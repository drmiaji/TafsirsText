            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلدَّوَآبِّ﴾: جَمْعُ دَابّة، وهي: ما دَبَّ على الأرضِ مِن خَلْقِ اللهِ.</p>\n<h2>﴿ٱلصُّمُّ﴾: مَنِ انسَدَّتْ آذانُهم عن سماعِ الحقِّ.</h2>\n<h2>﴿ٱلۡبُكۡمُ﴾: مَن خَرِسَتْ ألسنتُهم عن النُّطقِ به.</h2>"
        },
        "23": {
            "verses": {
                "8:23": {
                    "id": 23
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
