            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿مِمَّآ أُخِذَ مِنكُمۡ﴾: من المالِ بأن يُيَسِّرَ اللهُ لكم من فَضْلِه خيراً كثيراً.</p>"
        },
        "71": {
