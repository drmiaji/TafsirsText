            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿حَسۡرَةٗ﴾: ندامةً وأَسَفاً.</h2>"
        },
        "37": {
            "verses": {
                "8:37": {
                    "id": 37
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
