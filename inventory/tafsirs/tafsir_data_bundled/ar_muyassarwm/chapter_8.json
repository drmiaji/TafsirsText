            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فِتۡنَةٗ﴾: ابتلاءً ومِحْنَةً تنزِلُ بكم.</h2>"
        },
        "26": {
            "verses": {
                "8:26": {
                    "id": 26
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
