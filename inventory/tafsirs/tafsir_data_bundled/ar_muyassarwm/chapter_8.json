            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَٱللَّهُ مَعَ ٱلصَّـٰبِرِينَ﴾: بتأييدِه ونَصْرِه.</h2>"
        },
        "67": {
            "verses": {
                "8:67": {
                    "id": 67
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
