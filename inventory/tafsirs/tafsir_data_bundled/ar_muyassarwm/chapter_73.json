            },
            "text": "<h2>﴿ٱلۡمُزَّمِّلُ﴾: المتَغَطِّي بِثِيابِهِ.</h2>"
        },
        "2": {
            "verses": {
                "73:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
