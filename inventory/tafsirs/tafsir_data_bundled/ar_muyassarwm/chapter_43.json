                    "id": 48
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مِنۡ أُخۡتِهَا﴾: مِنَ الَّتِي قَبْلَها.</h2>"
        },
        "49": {
            "verses": {
                "43:49": {
                    "id": 49
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلسَّاحِرُ﴾: العالِمُ، وَلَمْ يَكُنِ السِّحْرُ صِفَةَ ذَمٍّ عِنْدَ فِرْعَونَ وَمَلَئِهِ.</p>"
        },
        "50": {
            "verses": {
                "43:50": {
                    "id": 50
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿يَنكُثُونَ﴾: يغْدِرُونَ ويَنْقُضُونَ ما عاهَدُوا عليهِ أَنْفُسَهُم.</p>"
        },
        "51": {
            "verses": {
                "43:51": {
                    "id": 51
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مِن تَحۡتِيٓ﴾: مِن تَحْتِ قُصُورِي.</h2>"
        },
        "52": {
            "verses": {
                "43:52": {
                    "id": 52
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَمۡ﴾: بَلْ.</h2>\n<h2>﴿مَهِينٞ﴾: ضَعِيفٌ حَقِيرٌ.</h2>\n<h2>﴿يُبِينُ﴾: أي: يُبِين الكَلَامَ.</h2>"
        },
        "53": {
            "verses": {
                "43:53": {
                    "id": 53
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَلَوۡلَآ﴾: فَهَلَّا.</h2>\n<h2>﴿مُقۡتَرِنِينَ﴾: مُتَتَابِعِينَ.</h2>"
        },
        "54": {
            "verses": {
                "43:54": {
                    "id": 54
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿فَٱسۡتَخَفَّ قَوۡمَهُۥ﴾: أَثار خِفَّةَ عُقُولِهِمْ بما أبْدَاهُ لَهُم مِنْ شُبَهٍ وحُجَجٍ باطِلَةٍ.</p>"
        },
        "55": {
            "verses": {
                "43:55": {
                    "id": 55
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ءَاسَفُونَا﴾: أَغْضَبُونا.</h2>\n<h2>﴿ٱنتَقَمۡنَا مِنۡهُمۡ﴾: عاقَبْناهُم عَلى ذُنُوبِهم.</h2>"
        },
        "56": {
            "verses": {
                "43:56": {
                    "id": 56
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿سَلَفٗا﴾: قَوْماً تَقَدَّمُوا لِيتَّعِظَ بِهِمُ الآخَرُونَ.</p>\n<h2>﴿وَمَثَلٗا﴾: عِبْرةً وَعِظَةً.</h2>"
        },
        "57": {
            "verses": {
                "43:57": {
                    "id": 57
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ضُرِبَ ٱبۡنُ مَرۡيَمَ مَثَلًا﴾: ضَرَبَ المشركُونَ نَبِيَّ اللهِ عِيسَى -عليه السلام- مَثَلاً لِآلِهَتِهِم وَشَبَّهُوهُ بِها في دُخُولِ النَّارِ.</p>\n<h2>﴿يَصِدُّونَ﴾: يَصِيحُونَ فَرَحاً وَسُرُوراً.</h2>"
        },
        "58": {
            "verses": {
                "43:58": {
                    "id": 58
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿خَصِمُونَ﴾: شِدِيدُو التَّمَسُّكِ بالخُصُومَةِ مَعَ ظُهُورِ الحقِّ عِنْدَهُم.</p>"
        },
        "59": {
            "verses": {
                "43:59": {
                    "id": 59
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿مَثَلٗا لِّبَنِيٓ إِسۡرَٰٓءِيلَ﴾: عِبْرةً لَهُم يَعْرِفُونَ بِهِ قُدْرَةَ اللهِ عَلَى ما يُرِيدُ؛ إِذْ خَلَقَهُ مِنْ غَيرِ أَبٍ.</p>"
        },
        "60": {
            "verses": {
                "43:60": {
                    "id": 60
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مِنكُم﴾: أَيْ: بَدَلاً مِنْكُم.</h2>\n<p>﴿يَخۡلُفُونَ﴾: يَخْلُفُ بَعْضُهُم بَعْضاً بَدَلاً مِن بنِي آدمَ.</p>"
        },
        "61": {
            "verses": {
                "43:61": {
                    "id": 61
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِنَّهُۥ﴾: وإنَّ نُزولَ عِيسَى عَلَيهِ السَّلامُ في آخِرِ الزَّمانِ.</p>\n<h2>﴿لَعِلۡمٞ﴾: لَدَلِيلٌ وَعَلاَمةٌ.</h2>\n<h2>﴿فَلَا تَمۡتَرُنَّ﴾: فَلَا تَشُكُّوا أنَّها واقِعةٌ.</h2>"
        },
        "62": {
            "verses": {
                "43:62": {
                    "id": 62
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مُبِينٞ﴾: بَيِّنُ العَدَاوَةِ.</h2>"
        },
        "63": {
            "verses": {
                "43:63": {
                    "id": 63
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
