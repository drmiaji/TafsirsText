            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يَخُوضُواْ﴾: يَتَحَدَّثُوا بالباطِل على غيرِ هُدىً.</h2>"
        },
        "84": {
            "verses": {
                "43:84": {
                    "id": 84
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿فِي ٱلسَّمَآءِ إِلَٰهٞ وَفِي ٱلۡأَرۡضِ إِلَٰهٞ﴾: مَعْبُودٌ في السَّماءِ وفي الأَرْضِ.</p>"
        },
        "85": {
            "verses": {
                "43:85": {
                    "id": 85
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
