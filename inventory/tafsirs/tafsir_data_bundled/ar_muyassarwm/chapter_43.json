            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿سَخَّرَ﴾: ذَلَّلَ وطَوَّعَ.</h2>\n<h2>﴿مُقۡرِنِينَ﴾: مُطِيقِينَ.</h2>"
        },
