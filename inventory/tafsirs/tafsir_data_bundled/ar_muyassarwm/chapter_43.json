            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَتَبَارَكَ﴾: كَثُرَ خَيْرُهُ.</h2>\n<h2>﴿تُرۡجَعُونَ﴾: تُرَدُّونَ بَعْدَ مَمَاتِكُم.</h2>"
        },
        "86": {
            "verses": {
                "43:86": {
                    "id": 86
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلشَّفَٰعَةَ﴾: طَلَبَ قَضاءِ حاجَةِ المشْفُوعِ لَهُ عِنْدَ المشْفُوعِ عِنْدَهُ مِنَ التَّجاوُزِ عَنِ السَّيئاتِ والزَّلَّاتِ وَغَيرِها.</p>"
        },
        "87": {
            "verses": {
                "43:87": {
                    "id": 87
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿فَأَنَّىٰ يُؤۡفَكُونَ﴾: كَيْفَ يُصْرَفُونَ عَنْ عِبادَةِ الله؟</p>"
        },
        "88": {
            "verses": {
                "43:88": {
                    "id": 88
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَقِيلِهِۦ﴾: وَعِنْدَ اللهِ عِلْمُ قولِ الرَّسُولِ ﷺ.</h2>"
        },
        "89": {
            "verses": {
                "43:89": {
                    "id": 89
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
