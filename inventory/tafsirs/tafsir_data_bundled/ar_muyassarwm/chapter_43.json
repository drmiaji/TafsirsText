                "language_name": "english"
            },
            "text": "<h2>﴿لَذِكۡرٞ﴾: لَشَرَفٌ.</h2>"
        },
        "45": {
            "verses": {
                "43:45": {
                    "id": 45
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿مَنۡ أَرۡسَلۡنَا﴾: أَتْباعَ مَنْ أرْسَلْنا، وَهُم مُؤمِنُو أَهْلِ الكِتابِ.</p>"
        },
        "46": {
            "verses": {
                "43:46": {
                    "id": 46
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِـَٔايَٰتِنَآ﴾: بِحُجَجِنا.</h2>\n<h2>﴿وَمَلَإِيْهِۦ﴾: عُظَماءِ قَومِهِ.</h2>"
        },
        "47": {
            "verses": {
