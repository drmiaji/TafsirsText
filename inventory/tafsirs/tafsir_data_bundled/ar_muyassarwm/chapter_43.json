            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلسَّبِيلِ﴾: طَرِيقِ الحقِّ.</h2>"
        },
        "38": {
            "verses": {
                "43:38": {
                    "id": 38
                }
            },
