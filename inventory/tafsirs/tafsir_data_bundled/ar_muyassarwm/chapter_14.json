            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "39": {
            "verses": {
                "14:39": {
                    "id": 39
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَهَبَ لِي﴾: أعطاني ورزقني.</h2>"
        },
        "40": {
            "verses": {
                "14:40": {
                    "id": 40
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿مُقِيمَ ٱلصَّلَوٰةِ﴾: مُحافِظاً عليها، مُداوماً على أدائِها على أتمِّ أحوالِها.</p>\n<h2>﴿وَتَقَبَّلۡ دُعَآءِ﴾: تقبَّلْ عبادتي، واستجِبْ دعائي.</h2>"
        },
        "41": {
            "verses": {
                "14:41": {
                    "id": 41
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَلِوَٰلِدَيَّ﴾: دعا لوالدِه بالمغفرةِ، قبلَ أنْ يَتبيَّنَ له عداوتُه للهِ.</p>"
        },
        "42": {
            "verses": {
                "14:42": {
                    "id": 42
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿تَشۡخَصُ فِيهِ ٱلۡأَبۡصَٰرُ﴾: تَرْتَفِعُ فيه عيونُ أهلِ الموقفِ، فتبقى مفتوحةً لا تتحرَّكُ؛ مِنْ هَوْلِ ما يَرَوْنه.</p>"
        },
        "43": {
            "verses": {
                "14:43": {
                    "id": 43
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مُهۡطِعِينَ﴾: مُسْرِعين إلى إجابةِ الداعي للحسابِ.</h2>\n<h2>﴿مُقۡنِعِي رُءُوسِهِمۡ﴾: رافِعيها من شدَّةِ الخوفِ.</h2>\n<p>﴿لَا يَرۡتَدُّ إِلَيۡهِمۡ طَرۡفُهُمۡ﴾: لا تَرْجِعُ إليهم أَجْفانُهم، بل تبقَى عيونُهم مفتوحةً على حالِها.</p>\n<p>﴿وَأَفۡـِٔدَتُهُمۡ هَوَآءٞ﴾: وقلوبُهم خاليةٌ لا تَعي شيئاً؛ من هَوْلِ ما تَرَىٰ، وشدَّةِ الدَّهْشةِ.</p>"
        },
        "44": {
            "verses": {
                "14:44": {
                    "id": 44
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَأَنذِرِ﴾: خَوِّف، أيُّها الرسولُ.</h2>\n<h2>﴿يَأۡتِيهِمُ ٱلۡعَذَابُ﴾: أي: عذابُ اللهِ يومَ القيامةِ.</h2>\n<h2>﴿أَجَلٖ قَرِيبٖ﴾: وقتٍ غيرِ بعيدٍ.</h2>\n<p>﴿مَا لَكُم مِّن زَوَالٖ﴾: لا زوالَ لكم عن الحياةِ الدُّنيا إلى الآخرةِ.</p>"
        },
        "45": {
            "verses": {
                "14:45": {
                    "id": 45
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَتَبَيَّنَ لَكُمۡ كَيۡفَ فَعَلۡنَا بِهِمۡ﴾: وعَلِمْتُم بما تشاهدُونه في منازلِهم، وبما أُخْبِرْتُم، ما أنزَلْناه بهم من أنواعِ العقوباتِ.</p>"
        },
        "46": {
            "verses": {
                "14:46": {
                    "id": 46
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَعِندَ ٱللَّهِ مَكۡرُهُمۡ﴾: عِلْمُه وجَزاؤُه.</h2>\n<p>﴿وَإِن كَانَ مَكۡرُهُمۡ لِتَزُولَ مِنۡهُ ٱلۡجِبَالُ﴾: وما كان تدبيرُهم -وإن عَظُمَ- مُعَدّاً لإزالةِ الجبالِ؛ لضَعْفِه.</p>"
        },
        "47": {
            "verses": {
                "14:47": {
                    "id": 47
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَعۡدِهِۦ رُسُلَهُۥٓ﴾: ما وَعَدَهم به من النصرِ والتمكينِ، وإهلاكِ أعدائِهم.</p>\n<h2>﴿عَزِيزٞ﴾: غالِبٌ لا يمتنعُ عليه شيءٌ.</h2>"
        },
        "48": {
            "verses": {
                "14:48": {
                    "id": 48
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَبَرَزُواْ﴾: خَرَجَ الخَلْقُ من قُبورِهم؛ للحسابِ.</h2>"
        },
        "49": {
            "verses": {
                "14:49": {
                    "id": 49
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مُقَرَّنِينَ﴾: مُقَيَّدين، أو مَقْروناً بعضُهم مع بعضٍ.</h2>\n<p>﴿ٱلۡأَصۡفَادِ﴾: جَمْعُ صَفَدٍ، وهو ما يُوثَقُ به من القُيودِ.</p>"
        },
        "50": {
            "verses": {
                "14:50": {
                    "id": 50
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿سَرَابِيلُهُم﴾: ثيابُهم، أو قُمْصانُهم.</h2>\n<p>﴿قَطِرَانٖ﴾: دُهْنٍ من عُصارةِ بعضِ الأشجارِ، أسودَ كالزِّفْتِ، وهو نَتِنٌ، حارٌّ، شديدُ الاشتعالِ.</p>\n<h2>﴿وَتَغۡشَىٰ﴾: تَعْلُو وتُحيطُ.</h2>"
        },
