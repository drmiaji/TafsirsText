            },
            "text": "<h2>﴿بِٱلۡبَيِّنَٰتِ﴾: بالبراهينِ الواضحاتِ على صِدْقِهم.</h2>\n<p>﴿فَرَدُّوٓاْ أَيۡدِيَهُمۡ فِيٓ أَفۡوَٰهِهِمۡ﴾: عَضَّتِ الأممُ على أيديها؛ غيظاً واستكباراً عن الإيمانِ.</p>\n<h2>﴿مُرِيبٖ﴾: مُوقعٍ في القَلَقِ وعَدَمِ الاطمئنانِ.</h2>"
        },
        "10": {
            "verses": {
                "14:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿فَاطِرِ ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضِ﴾: خالِقِهما ومُبْدِعِهما.</p>\n<p>﴿إِلَىٰٓ أَجَلٖ مُّسَمّٗى﴾: مُدَّةِ بقائِكم في الدنيا، فلا يُعَذِّبكُم فيها.</p>\n<p>﴿بِسُلۡطَٰنٖ مُّبِينٖ﴾: حُجَّةٍ ظاهرةٍ تَشْهَدُ على صِدْقِكم.</p>"
        },
        "11": {
            "verses": {
                "14:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿يَمُنُّ عَلَىٰ مَن يَشَآءُ﴾: يَتَفَضَّلُ عليه فيَصْطَفِيه للرِّسالةِ.</p>\n<h2>﴿بِإِذۡنِ ٱللَّهِ﴾: بأمْرِه ومشيئتِه.</h2>\n<p>﴿وَعَلَى ٱللَّهِ فَلۡيَتَوَكَّلِ﴾: فلْيَعْتَمِدْ عليه، ولْيُفَوِّضْ أمرَه إليه.</p>"
        },
        "12": {
            "verses": {
                "14:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿هَدَىٰنَا سُبُلَنَا﴾: أرْشَدَنا إلى طريقِ النَّجاة، ووَفَّقنا إلى اتِّباعِ شَرْعِه.</p>"
        },
        "13": {
            "verses": {
                "14:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مِلَّتِنَا﴾: دينِنا.</h2>"
        },
        "14": {
            "verses": {
                "14:14": {
                    "id": 14
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلۡأَرۡضَ مِنۢ بَعۡدِهِمۡ﴾: أي: أرضَ الكافرين وديارَهم مِنْ بَعْدِ إهلاكِهم.</p>\n<p>﴿مَقَامِي﴾: مَوْقِفَه بين يَدَي اللهِ للحسابِ، أو: قيامي عليه ومراقبتي له.</p>"
        },
        "15": {
            "verses": {
                "14:15": {
                    "id": 15
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱسۡتَفۡتَحُواْ﴾: سألَ الرُّسلُ ربَّهم النصرَ على أعدائِهم، أو طَلَبُوا منه الحُكْمَ بينَهم.</p>\n<h2>﴿وَخَابَ﴾: خَسِرَ وهَلَكَ.</h2>\n<p>﴿جَبَّارٍ﴾: مُتَعاظِمٍ في نفسِه، مُتَكَبِّرٍ على غيرِه وعن الحقِّ.</p>\n<h2>﴿عَنِيدٖ﴾: معاندٍ للحقِّ، مائلٍ عنه لا يَقْبَلُه.</h2>"
        },
        "16": {
            "verses": {
                "14:16": {
                    "id": 16
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿مِن وَرَآئِهِۦ جَهَنَّمُ﴾: أمامَ هذا الكافرِ ما أعَدَّ اللهُ من العذابِ في النار.</p>\n<h2>﴿صَدِيدٖ﴾: ما يَسِيلُ من أجسادِ أهلِ النَّارِ.</h2>"
        },
        "17": {
            "verses": {
                "14:17": {
                    "id": 17
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿يَتَجَرَّعُهُۥ﴾: يَتَكلَّفُ ابتلاعَه مرَّة بعدَ مرَّةٍ؛ لحرارتهِ مع غَلَبَةِ العَطَشِ عليه.</p>\n<p>﴿وَلَا يَكَادُ يُسِيغُهُۥ﴾: لا يَسْتطيعُ ابتلاعَه بسهولةٍ، بل يَشْرَبُه بعد عَناءٍ، فيُقَطِّعُ أمعاءَه.</p>\n<h2>﴿وَمِن وَرَآئِهِۦ﴾: وله بعدَ هذا العذابِ.</h2>\n<h2>﴿غَلِيظٞ﴾: شديدٌ مؤلمٌ.</h2>"
        },
        "18": {
            "verses": {
                "14:18": {
                    "id": 18
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿مَثَلُ ٱلَّذِينَ كَفَرُواْ﴾: صفةُ أعمالِ الكفارِ في الدنيا وبُطْلانِها عندَ اللهِ بسببِ كُفْرِهم.</p>\n<h2>﴿عَاصِفٖ﴾: شديدِ الريحِ.</h2>\n<p>﴿لَا يَقۡدِرُونَ مِمَّا كَسَبُواْ عَلَىٰ شَيۡءٖ﴾: لا يَجِدُون من أعمال البِرِّ ما يَنْفعُهم في الآخرةِ.</p>"
        },
        "19": {
            "verses": {
                "14:19": {
                    "id": 19
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿بِٱلۡحَقِّ﴾: على الوجهِ الصحيحِ الدَّالِّ على حكمتِه وكمالِ قدرتِه.</p>"
        },
        "20": {
            "verses": {
                "14:20": {
                    "id": 20
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
