        "9": {
            "verses": {
                "68:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَدُّواْ﴾: تَمَنَّوا وأحَبُّوا.</h2>\n<p>﴿لَوۡ تُدۡهِنُ﴾: لو تُلايِنُهُم وَتُصانِعُهُم عَلَى بَعْضِ ما هُم عَلَيهِ.</p>\n<h2>﴿فَيُدۡهِنُونَ﴾: فَيَلِينُونَ لَكَ.</h2>"
        },
        "10": {
            "verses": {
                "68:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿حَلَّافٖ﴾: كَثِيرِ الحَلْفِ.</h2>\n<h2>﴿مَهِينٍ﴾: حَقِيرٍ.</h2>"
        },
        "11": {
            "verses": {
                "68:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿هَمَّازٖ﴾: مُغْتابٍ للنَّاسِ.</h2>\n<p>﴿مَشَّآءِۭ بِنَمِيمٖ﴾: يَمْشِي بَينَ النَّاسِ وَيَنْقُلُ حَدِيثَ بَعْضِهِم إلى بَعْضٍ عَلى وَجْهِ الإفْسادِ بَيْنَهُم.</p>"
        },
        "12": {
            "verses": {
                "68:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مَنَّاعٖ لِّلۡخَيۡرِ﴾: شَدِيدِ المنْعِ لِلخَيْرِ.</h2>\n<p>﴿مُعۡتَدٍ﴾: مُتَجاوِزٍ حَدَّه في العُدْوانِ عَلَى النَّاسِ وَتَناوُلِ</p>\n<h2>(المُحَرَّماتِ) .</h2>\n<h2>﴿أَثِيمٍ﴾: كَثِيرِ الآثامِ.</h2>"
        },
        "13": {
            "verses": {
                "68:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿عُتُلِّۭ﴾: شَدِيدٍ في كُفْرِهِ، فاحِشٍ لَئِيمٍ.</h2>\n<h2>﴿زَنِيمٍ﴾: مَنْسُوبٍ إلى غَيرِ أَبِيهِ.</h2>"
        },
        "14": {
            "verses": {
                "68:14": {
                    "id": 14
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿أَن كَانَ ذَا مَالٖ وَبَنِينَ﴾: طَغَى وَتَكَبَّرَ لِأَجْلِ أَن رَزَقَهُ اللهُ مالاً وَبَنِينَ فَلَمْ يَشْكُرِ النِّعْمَةَ.</p>"
        },
        "15": {
            "verses": {
                "68:15": {
                    "id": 15
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿أَسَٰطِيرُ ٱلۡأَوَّلِينَ﴾: أَباطِيلُ الأوَّلِينَ وَخُرافاتُهُم.</p>"
        },
        "16": {
            "verses": {
                "68:16": {
                    "id": 16
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿سَنَسِمُهُۥ﴾: سَنَجْعلُ عَلامةً لَازِمةً لا تُفارِقُهُ.</h2>\n<h2>﴿عَلَى ٱلۡخُرۡطُومِ﴾: عَلَى أَنْفِهِ عُقُوبةً لَهُ.</h2>"
        },
        "17": {
            "verses": {
                "68:17": {
                    "id": 17
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿بَلَوۡنَٰهُمۡ﴾: اخْتَبَرْنا أَهْلَ مَكَّةَ بالجُوعِ والقَحْطِ.</p>\n<h2>﴿ٱلۡجَنَّةِ﴾: الحَدِيقَةِ.</h2>\n<h2>﴿لَيَصۡرِمُنَّهَا﴾: لَيَقْطَعُنَّ ثِمارَها.</h2>\n<h2>﴿مُصۡبِحِينَ﴾: مُبَكِّرِينَ في الصَّباحِ.</h2>"
        },
        "18": {
            "verses": {
                "68:18": {
                    "id": 18
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَلَا يَسۡتَثۡنُونَ﴾: وَلَمْ يَقُولُوا: إِن شَاءَ اللهُ.</h2>"
        },
        "19": {
            "verses": {
                "68:19": {
                    "id": 19
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿فَطَافَ عَلَيۡهَا طَآئِفٞ مِّن رَّبِّكَ﴾: فَأَنْزَلَ اللهُ عَلَيها ناراً أَحْرَقَتْها لَيلاً.</p>"
        },
        "20": {
            "verses": {
                "68:20": {
                    "id": 20
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿كَٱلصَّرِيمِ﴾: مُحْتَرِقَةً سَوْداءَ كالليلِ المُظْلمِ.</h2>"
        },
        "21": {
            "verses": {
                "68:21": {
                    "id": 21
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَتَنَادَوۡاْ﴾: فَنَادَى بَعْضُهُم بَعْضاً.</h2>\n<h2>﴿مُصۡبِحِينَ﴾: وَقْتَ الصَّباحِ.</h2>"
        },
        "22": {
            "verses": {
                "68:22": {
                    "id": 22
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱغۡدُواْ﴾: اذْهَبُوا مُبَكِّرِينَ.</h2>\n<h2>﴿حَرۡثِكُمۡ﴾: زَرْعِكُم.</h2>\n<h2>﴿صَٰرِمِينَ﴾: قاطِعِينَ ثِمارَكُم.</h2>"
        },
        "23": {
            "verses": {
                "68:23": {
                    "id": 23
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿يَتَخَٰفَتُونَ﴾: يُسِرُّ بَعْضُهُم إِلَى بَعْضٍ في الكَلامِ.</p>"
        },
        "24": {
            "verses": {
                "68:24": {
                    "id": 24
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "25": {
            "verses": {
                "68:25": {
                    "id": 25
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَغَدَوۡاْ﴾: سارُوا في أَوَّلِ النَّهارِ.</h2>\n<h2>﴿عَلَىٰ حَرۡدٖ﴾: على أَمْرٍ مُجْمَعٍ عَلَيهِ.</h2>"
        },
        "26": {
            "verses": {
                "68:26": {
                    "id": 26
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَلَمَّا رَأَوۡهَا﴾: أي مُحْتَرِقَةً.</h2>\n<h2>﴿لَضَآلُّونَ﴾: أَخْطأنا الطَّريقَ إلى حَدِيقَتِنا.</h2>"
        },
        "27": {
            "verses": {
                "68:27": {
                    "id": 27
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿مَحۡرُومُونَ﴾: حُرِمْنا خيرَها بِسَبَبِ مَنْعِنَا المَساكِينَ.</p>"
        },
        "28": {
            "verses": {
                "68:28": {
                    "id": 28
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَوۡسَطُهُمۡ﴾: أَعْدَلُهُم وَأَفْضَلُهُم.</h2>\n<h2>﴿لَوۡلَا﴾: هَلَّا.</h2>\n<h2>﴿تُسَبِّحُونَ﴾: تَقُولُونَ: إن شاء اللهُ.</h2>"
        },
        "29": {
            "verses": {
                "68:29": {
                    "id": 29
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿سُبۡحَٰنَ رَبِّنَآ﴾: نُنَزِّهُ رَبَّنا عَنِ الظُّلْمِ فِيما أَصَابَنا.</p>"
        },
        "30": {
            "verses": {
                "68:30": {
                    "id": 30
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يَتَلَٰوَمُونَ﴾: يَلُومُ بَعْضُهم بَعْضاً.</h2>"
        },
        "31": {
            "verses": {
                "68:31": {
                    "id": 31
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿يَٰوَيۡلَنَآ﴾: نادَوا عَلَى أَنْفُسِهِم بِالشَّرِّ وَالعَذابِ.</p>\n<h2>﴿طَٰغِينَ﴾: مُتَجاوِزِينَ الحدَّ في مَنْعِنَا الفُقَراءَ.</h2>"
        },
        "32": {
            "verses": {
                "68:32": {
                    "id": 32
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿رَٰغِبُونَ﴾: طالِبُونَ الخيرَ والعفوَ عَن سيِّئاتِنا.</h2>"
        },
        "33": {
            "verses": {
                "68:33": {
                    "id": 33
                }
            },
