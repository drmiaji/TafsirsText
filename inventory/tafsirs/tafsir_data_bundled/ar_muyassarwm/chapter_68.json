            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَٱجۡتَبَٰهُ﴾: فاخْتارَهُ لِرِسالتِهِ.</h2>"
        },
        "51": {
            "verses": {
                "68:51": {
                    "id": 51
                }
