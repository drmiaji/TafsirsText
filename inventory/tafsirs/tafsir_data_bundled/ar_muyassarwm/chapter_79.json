            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡمُقَدَّسِ﴾: المُطَهَّرِ المبارَكِ.</h2>\n<h2>﴿طُوًى﴾: وادٍ في جانِبِ جَبَلِ الطُّورِ.</h2>"
        },
        "17": {
            "verses": {
                "79:17": {
                    "id": 17
                }
