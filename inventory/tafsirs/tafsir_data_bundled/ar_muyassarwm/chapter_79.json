            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَدۡبَرَ﴾: وَلَّى مُعْرِضاً عَنِ الإِيمانِ.</h2>\n<h2>﴿يَسۡعَىٰ﴾: في مُعارَضَةِ مُوسى.</h2>"
        },
        "23": {
            "verses": {
                "79:23": {
                    "id": 23
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
