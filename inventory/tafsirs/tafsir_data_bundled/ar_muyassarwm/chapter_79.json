            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿طَغَىٰ﴾: أَفْرَطَ في العِصْيانِ.</h2>"
        },
        "18": {
            "verses": {
                "79:18": {
                    "id": 18
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
