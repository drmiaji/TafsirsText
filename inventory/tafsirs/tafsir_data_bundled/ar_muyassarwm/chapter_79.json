            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿هَل لَّكَ﴾: أَتَوَدُّ.</h2>\n<h2>﴿تَزَكَّىٰ﴾: تُطَهِّرَ نَفْسَكَ.</h2>"
        },
        "19": {
            "verses": {
