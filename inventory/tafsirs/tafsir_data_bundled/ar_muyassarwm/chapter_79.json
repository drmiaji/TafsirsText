{
    "chapter": 79,
    "verses": {
        "1": {
            "verses": {
                "79:1": {
                    "id": 1
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلنَّٰزِعَٰتِ﴾: أُقْسِمُ بالملائِكةِ الَّتِي تَنْزِعُ أَرْوَاحَ الكُفَّارِ.</p>\n<p>﴿غَرۡقٗا﴾: نَزْعاً غَرْقاً، أي مُغْرِقاً، أي: تَنْزِعُ الأرْوَاحَ من أَقاصِي الأَجْسادِ.</p>"
        },
        "2": {
            "verses": {
                "79:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلنَّٰشِطَٰتِ﴾: والملائِكَةِ الَّتِي تَقْبِضُ أرْوَاحَ المؤمِنِينَ.</p>\n<h2>﴿نَشۡطٗا﴾: بِنَشاطٍ وَرِفقٍ.</h2>"
        },
        "3": {
            "verses": {
                "79:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلسَّٰبِحَٰتِ﴾: والملائِكَةِ الَّتِي تَسْبَحُ في نُزُولِها مِنَ السَّماءِ وصُعُودِها إِليها.</p>"
        },
        "4": {
            "verses": {
                "79:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿فَٱلسَّٰبِقَٰتِ﴾: فالملائِكَةِ الَّتِي تُسارِعُ إلى تَنِفيذِ أَمْرِ اللهِ.</p>"
        },
        "5": {
            "verses": {
                "79:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿فَٱلۡمُدَبِّرَٰتِ أَمۡرٗا﴾: فالملائِكةِ المُنَفِّذاتِ أَمْرَ رَبِّها.</p>"
        },
        "6": {
            "verses": {
                "79:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿يَوۡمَ تَرۡجُفُ ٱلرَّاجِفَةُ﴾: يومَ تَضْطَرِبُ الأرضُ بالنَّفْخَةِ الأُولَى نَفْخَةِ الإِماتَةِ.</p>"
        },
        "7": {
            "verses": {
                "79:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿تَتۡبَعُهَا ٱلرَّادِفَةُ﴾: تَتْبَعُها نَفْخَةٌ أُخْرَى لِبَعْثِ الخَلْقِ.</p>"
        },
        "8": {
            "verses": {
                "79:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿قُلُوبٞ﴾: قُلُوبُ الكُفَّارِ.</h2>\n<h2>﴿وَاجِفَةٌ﴾: مُضْطَرِبَةٌ مِن شِدَّةِ الخوفِ.</h2>"
        },
        "9": {
            "verses": {
                "79:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿خَٰشِعَةٞ﴾: ذَلِيلَةٌ مِنْ هَوْلِ ما تَرَى.</h2>"
        },
        "10": {
            "verses": {
                "79:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَءِنَّا لَمَرۡدُودُونَ﴾: أنُرَدُّ بَعْدَ مَوتِنا؟</h2>\n<p>﴿ٱلۡحَافِرَةِ﴾: إلى أَوَّلِ حالِنا، فَنَصِيرُ أحياءً بَعْدَ مَوْتِنا.</p>"
        },
        "11": {
            "verses": {
                "79:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿أَءِذَا كُنَّا عِظَٰمٗا نَّخِرَةٗ﴾: أنُرَدُّ وَقَدْ صِرْنا عِظاماً بالِيةً؟</p>"
        },
        "12": {
            "verses": {
                "79:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿كَرَّةٌ خَاسِرَةٞ﴾: رَجْعَةٌ خائِبةٌ كاذِبةٌ.</h2>"
        },
        "13": {
            "verses": {
                "79:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿زَجۡرَةٞ وَٰحِدَةٞ﴾: نَفْخَةٌ وَاحِدَةٌ.</h2>"
        },
        "14": {
            "verses": {
                "79:14": {
                    "id": 14
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِٱلسَّاهِرَةِ﴾: على وَجْهِ الأَرْضِ.</h2>"
        },
        "15": {
            "verses": {
                "79:15": {
                    "id": 15
                }
            },
