            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مَقَٰمِعُ﴾: مَطارِقُ.</h2>"
        },
        "22": {
            "verses": {
