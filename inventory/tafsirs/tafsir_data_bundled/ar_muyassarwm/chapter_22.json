            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿شَعَٰٓئِرَ ٱللَّهِ﴾: هي معالمُ دِينِه، ومِنْها شَعِيرةُ الحَجِّ.</p>"
        },
        "33": {
            "verses": {
