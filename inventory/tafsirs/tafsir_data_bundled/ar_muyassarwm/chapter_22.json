            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلۡحَمِيدُ﴾: المحمودُ المُسْتَحِقُّ لِلْحمْدِ في كُلِّ حالٍ.</p>"
        },
        "65": {
