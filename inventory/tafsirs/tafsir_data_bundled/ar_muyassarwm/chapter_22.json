                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿إِلَىٰٓ أَجَلٖ مُّسَمّٗى﴾: وهو وقتُ ذَبْحِها.</h2>\n<h2>﴿ثُمَّ مَحِلُّهَآ﴾: أي: حيثُ يَحِلُّ ذَبْحُها.</h2>"
        },
        "34": {
            "verses": {
                "22:34": {
                    "id": 34
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
