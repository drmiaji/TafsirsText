            "text": "<h2>﴿يَبۡعَثُ مَن فِي ٱلۡقُبُورِ﴾: أي: يَبْعَثُهم أحْيَاءً.</h2>"
        },
        "8": {
            "verses": {
                "22:8": {
                    "id": 8
