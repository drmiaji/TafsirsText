            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مُهِينٞ﴾: مُخْزٍ ومُذِلٌّ.</h2>"
        },
        "58": {
            "verses": {
                "22:58": {
                    "id": 58
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
