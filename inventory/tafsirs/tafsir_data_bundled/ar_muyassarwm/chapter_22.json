            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿رِزۡقًا حَسَنٗا﴾: وهو الجنَّةُ.</h2>"
        },
        "59": {
            "verses": {
                "22:59": {
                    "id": 59
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
