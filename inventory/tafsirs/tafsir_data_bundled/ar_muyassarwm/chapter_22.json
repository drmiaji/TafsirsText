                "language_name": "english"
            },
            "text": "<h2>﴿مِن تَحۡتِهَا﴾: أي: مِنْ تَحْتِ قُصُورِها.</h2>"
        },
        "15": {
            "verses": {
                "22:15": {
                    "id": 15
                }
