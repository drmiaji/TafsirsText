            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مُدۡخَلٗا﴾: مكانَ دخولٍ، وهو الجنَّةُ.</h2>"
        },
        "60": {
            "verses": {
                "22:60": {
                    "id": 60
                }
