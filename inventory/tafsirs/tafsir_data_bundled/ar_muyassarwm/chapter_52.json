                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "18": {
            "verses": {
                "52:18": {
                    "id": 18
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿فَٰكِهِينَ﴾: طَيِّبَةً أَنْفُسُكُم، مُتَمَتِّعِينَ عَلَى وَجْهِ السُّرُورِ.</p>"
        },
        "19": {
            "verses": {
                "52:19": {
                    "id": 19
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿هَنِيٓـَٔۢا﴾: أَكْلاً وَشُرْباً هَنِيئاً أي: سائِغاً.</h2>"
        },
        "20": {
            "verses": {
                "52:20": {
                    "id": 20
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿مُتَّكِـِٔينَ﴾: جالِسِين عَلَى وَجْهِ التَّمَكُّن والرَّاحةِ.</p>\n<p>﴿سُرُرٖ﴾: جَمْعُ سَرِيرٍ وهو ما يُضْطَجَعُ عَلَيهِ؛ وهو مَجْلِسُ المنَعَّمِينَ.</p>\n<h2>﴿مَّصۡفُوفَةٖ﴾: مُتَقابِلَةٍ.</h2>\n<h2>﴿وَزَوَّجۡنَٰهُم﴾: قَرَنَّاهُم.</h2>\n<h2>﴿بِحُورٍ﴾: بِنِساءٍ شَدِيداتِ بَياضِ العَينِ وَسَوادها.</h2>\n<h2>﴿عِينٖ﴾: واسِعاتِ العُيونِ حِسانِهِنَّ.</h2>"
        },
        "21": {
            "verses": {
                "52:21": {
                    "id": 21
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَآ أَلَتۡنَٰهُم﴾: وما نَقَصْنَاهُم.</h2>\n<h2>﴿رَهِينٞ﴾: مَحْبُوسٌ مقْرُونٌ.</h2>"
        },
        "22": {
            "verses": {
                "52:22": {
                    "id": 22
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَأَمۡدَدۡنَٰهُم﴾: وَزِدْناهُم.</h2>"
        },
        "23": {
            "verses": {
                "52:23": {
                    "id": 23
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يَتَنَٰزَعُونَ﴾: يَتَعاطَونَ، وَيُناوِلُ بعضُهم بَعْضاً.</h2>\n<h2>﴿كَأۡسٗا﴾: إِناءً مَمْلُوءاً مِنَ الخَمْرِ.</h2>\n<h2>﴿لَغۡوٞ﴾: كَلَامٌ لا فَائِدةَ فِيهِ.</h2>\n<h2>﴿تَأۡثِيمٞ﴾: إِثْمٌ ومَعْصِيَةٌ.</h2>"
        },
        "24": {
            "verses": {
                "52:24": {
                    "id": 24
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مَكۡنُونٞ﴾: مَصُونٌ في أَصْدَافِهِ.</h2>"
        },
        "25": {
            "verses": {
                "52:25": {
                    "id": 25
                }
