                "language_name": "english"
            },
            "text": "<h2>﴿ٱصۡلَوۡهَا﴾: ادْخُلُوها واحْتَرِقُوا بِنارِها.</h2>"
        },
        "17": {
            "verses": {
                "52:17": {
                    "id": 17
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
