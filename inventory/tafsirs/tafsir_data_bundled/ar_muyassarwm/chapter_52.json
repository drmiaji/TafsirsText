            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلطُّورِ﴾: هُوَ الجَبَلُ الَّذِي كَلَّمَ اللهُ عَلَيهِ مُوسَى عَلَيهِ السَّلامُ.</p>"
        },
        "2": {
            "verses": {
                "52:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مَسۡطُورٖ﴾: مَكْتُوبٍ، وَهُو القُرآنُ.</h2>"
        },
        "3": {
            "verses": {
                "52:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فِي رَقّٖ مَّنشُورٖ﴾: مَكْتُوبٍ في صَحِيفةٍ مَبْسُوطَةٍ.</h2>"
        },
        "4": {
            "verses": {
                "52:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلۡبَيۡتِ ٱلۡمَعۡمُورِ﴾: هو فَوْقَ السَّماءِ السَّابِعةِ، تَطُوفُ بِه الملائِكةُ دائِماً.</p>"
        },
        "5": {
            "verses": {
                "52:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱلسَّقۡفِ ٱلۡمَرۡفُوعِ﴾: هو السَّماءُ الدُّنيا، جَعَلَها اللهُ سَقْفاً للأرْضِ.</p>"
        },
        "6": {
            "verses": {
                "52:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡمَسۡجُورِ﴾: الممْلُوءِ بالمياهِ.</h2>"
        },
        "7": {
            "verses": {
                "52:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "8": {
            "verses": {
                "52:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿دَافِعٖ﴾: مانِعٍ يَمْنَعُه حِينَ وقُوعِهِ.</h2>"
        },
        "9": {
            "verses": {
                "52:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿تَمُورُ﴾: تَتَحرَّكُ وتَضْطَرِبُ.</h2>"
        },
        "10": {
            "verses": {
                "52:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَتَسِيرُ﴾: تَزُولُ عَنْ أماكِنِها، وَتَسيرُ كَسَيرِ السَّحابِ.</p>"
        },
        "11": {
            "verses": {
                "52:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَوَيۡلٞ﴾: فَهَلَاكٌ.</h2>"
        },
        "12": {
            "verses": {
                "52:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فِي خَوۡضٖ﴾: في انْدِفاعٍ في الكَلَامِ الباطِلِ.</h2>\n<h2>﴿يَلۡعَبُونَ﴾: يَسْتَهْزِئُونَ.</h2>"
        },
        "13": {
            "verses": {
                "52:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يُدَعُّونَ﴾: يُدْفَعُونَ.</h2>\n<h2>﴿دَعًّا﴾: دَفْعاً بِعُنْفٍ وَمهانَةٍ.</h2>"
        },
        "14": {
            "verses": {
