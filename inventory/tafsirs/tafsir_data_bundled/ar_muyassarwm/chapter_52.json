            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مُشۡفِقِينَ﴾: خائِفِينَ مِنْ عَذابِ رَبِّنا.</h2>"
        },
        "27": {
            "verses": {
                "52:27": {
                    "id": 27
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلسَّمُومِ﴾: نَارِ جَهَنَّمَ وَحَرَارَتِها.</h2>"
        },
        "28": {
            "verses": {
                "52:28": {
                    "id": 28
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡبَرُّ﴾: المُحْسِنُ.</h2>"
        },
        "29": {
            "verses": {
                "52:29": {
                    "id": 29
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِنِعۡمَتِ رَبِّكَ﴾: بمَنِّهِ وَلُطْفِهِ.</h2>\n<h2>﴿بِكَاهِنٖ﴾: يُخْبِرُ بالغَيبِ دُونَ عِلْمٍ.</h2>"
        },
        "30": {
            "verses": {
                "52:30": {
                    "id": 30
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿نَتَرَبَّصُ﴾: نَنْتَظِرُ.</h2>\n<h2>﴿رَيۡبَ ٱلۡمَنُونِ﴾: حوادِثَ الدَّهرِ فَيَمُوتُ.</h2>"
        },
        "31": {
