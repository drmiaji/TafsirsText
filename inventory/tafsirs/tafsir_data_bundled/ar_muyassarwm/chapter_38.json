            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلۡقَهَّارُ﴾: الَّذي قَهَرَ كُلَّ شَيءٍ وَغَلَبَهُ، فَكُلُّ شَيءٍ لَهُ مُتَذَلِّلٌ خاضِعٌ.</p>"
        },
