            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿فَٱمۡنُنۡ أَوۡ أَمۡسِكۡ﴾: فأعْطِ مَن شِئْتَ، وامنَعْ مَن شِئْتَ.</p>"
        },
        "40": {
            "verses": {
