                "language_name": "english"
            },
            "text": "<h2>﴿أَوَّابٌ﴾: توَّابٌ كثيرُ الرُّجُوعِ إلى اللهِ.</h2>"
        },
        "31": {
            "verses": {
                "38:31": {
                    "id": 31
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
