            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِٱلۡعَشِيِّ﴾: بآخِرِ النَّهارِ.</h2>\n<p>﴿ٱلصَّٰفِنَٰتُ﴾: الخُيُولُ الأصِيلةُ الواقِفَةُ على ثَلاثِ قَوائِمَ وطرفِ حافِرِ الرَّابِعَةِ.</p>\n<h2>﴿ٱلۡجِيَادُ﴾: السَّريعَةُ في الجَرْي.</h2>"
        },
        "32": {
            "verses": {
                "38:32": {
                    "id": 32
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
