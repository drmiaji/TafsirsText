            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِنُصۡبٖ﴾: بِتَعَبٍ ومَشَقَّةٍ.</h2>\n<h2>﴿وَعَذَابٍ﴾: أَلَمٍ وضُرٍّ.</h2>"
        },
        "42": {
