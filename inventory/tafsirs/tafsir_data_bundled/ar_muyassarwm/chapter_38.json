            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿فَطَفِقَ مَسۡحَۢا بِٱلسُّوقِ وَٱلۡأَعۡنَاقِ﴾: فَشَرَعَ يَقْطَعُ سُوقَها وأعْناقَها بالسَّيفِ.</p>"
        },
        "34": {
            "verses": {
