            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَحۡبَبۡتُ حُبَّ ٱلۡخَيۡرِ﴾: آثَرْتُ حُبَّ الخيلِ.</h2>\n<h2>﴿تَوَارَتۡ بِٱلۡحِجَابِ﴾: غَرَبَتِ الشَّمسُ.</h2>"
        },
        "33": {
            "verses": {
                "38:33": {
                    "id": 33
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
