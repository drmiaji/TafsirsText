            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿مُقَرَّنِينَ فِي ٱلۡأَصۡفَادِ﴾: مُقَيَّدين في الأغْلالِ والسَّلاسِلِ.</p>"
        },
        "39": {
            "verses": {
                "38:39": {
