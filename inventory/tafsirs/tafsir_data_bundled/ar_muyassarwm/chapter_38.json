            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱرۡكُضۡ بِرِجۡلِكَ﴾: اضْرِبْ بِها الأرْضَ.</h2>"
        },
        "43": {
            "verses": {
