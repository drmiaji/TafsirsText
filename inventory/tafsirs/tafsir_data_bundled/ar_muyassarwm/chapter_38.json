            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بَنَّآءٖ﴾: يَبْنِي لَهُ ما يشاءُ.</h2>\n<h2>﴿وَغَوَّاصٖ﴾: يَغُوصُ في البحْرِ لاسْتِخْراجِ نَفَائِسِه.</h2>"
        },
        "38": {
