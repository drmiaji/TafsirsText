            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يَظُنُّ﴾: يَعْتَقِدُ.</h2>"
        },
        "5": {
            "verses": {
