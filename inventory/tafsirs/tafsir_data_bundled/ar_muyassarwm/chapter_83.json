            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿حَٰفِظِينَ﴾: رُقَباءَ عَلَى أصْحابِ مُحَمَّدٍ ﷺ.</h2>"
        },
