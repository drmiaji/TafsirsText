                "language_name": "english"
            },
            "text": "<h2>﴿وَيۡلٞ﴾: عذابٌ شَدِيدٌ.</h2>"
        },
        "11": {
            "verses": {
                "83:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
