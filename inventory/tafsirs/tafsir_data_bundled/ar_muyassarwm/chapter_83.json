            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿كَلَّآ﴾: ليسَ الأَمْرُ كَما يَظُنُّ هَؤُلاءِ الكُفَّارُ، أنَّهم غَيرُ مَبْعُوثِينَ.</p>\n<h2>﴿كِتَٰبَ ٱلۡفُجَّارِ﴾: صَحِيفةَ أَعْمالِ المُشْرِكِينَ.</h2>\n<h2>﴿لَفِي سِجِّينٖ﴾: أَسْفَلِ الأرْضِ السَّابِعَةِ.</h2>"
        },
        "8": {
            "verses": {
                "83:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَآ أَدۡرَىٰكَ﴾: وأيُّ شَيءٍ أعْلَمكَ؟</h2>"
        },
        "9": {
            "verses": {
                "83:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مَرۡقُومٞ﴾: مَكْتُوبٌ كِتابَةً بَيِّنةً.</h2>"
        },
        "10": {
            "verses": {
                "83:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
