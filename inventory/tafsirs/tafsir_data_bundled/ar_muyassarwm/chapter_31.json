                "language_name": "english"
            },
            "text": "<h2>﴿يُؤۡتُونَ﴾: يُعْطُونَ.</h2>\n<h2>﴿يُوقِنُونَ﴾: يُؤْمِنُونَ.</h2>"
        },
        "5": {
            "verses": {
                "31:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡمُفۡلِحُونَ﴾: الفائِزُونَ.</h2>"
        },
        "6": {
            "verses": {
                "31:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لَهۡوَ ٱلۡحَدِيثِ﴾: هُوَ كلُّ ما يُلْهِي عَن طَاعةِ اللهِ.</h2>\n<h2>﴿بِغَيۡرِ عِلۡمٖ﴾: جَهْلاً بِعاقِبَةِ ذَلِكَ.</h2>\n<h2>﴿وَيَتَّخِذَهَا﴾: وَيَتَّخِذَ سَبيلَ اللهِ وآياتِ كِتابِه.</h2>\n<h2>﴿هُزُوًا﴾: مُسْتهْزَأً بِها.</h2>"
        },
        "7": {
            "verses": {
                "31:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَلَّىٰ﴾: أَعْرَضَ وأَدْبَرَ.</h2>\n<h2>﴿مُسۡتَكۡبِرٗا﴾: مُتَكبِّراً.</h2>\n<h2>﴿وَقۡرٗا﴾: ثِقَلاً أو صَمَماً فلا يَنْتَفِعُ بِما يَسْمَعُ.</h2>"
        },
        "8": {
            "verses": {
                "31:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "9": {
            "verses": {
                "31:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿حَقّٗا﴾: أي: وَعْداً حَقّاً ثابِتاً لا شَكَّ فيه ولا خُلْفَ له.</p>"
        },
        "10": {
            "verses": {
                "31:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿عَمَدٖ﴾: دَعائِمَ، مُفْرَدُه: عِمادٌ.</h2>\n<h2>﴿رَوَٰسِيَ﴾: أي: جِبالاً ثَوَابِتَ.</h2>\n<p>﴿أَن تَمِيدَ بِكُمۡ﴾: أي: لِئلا تَتَحَرَّكَ الأرْضُ وتَضْطَرِبَ بِكم.</p>\n<h2>﴿بَثَّ﴾: نَشَر وفَرَّقَ.</h2>\n<h2>﴿زَوۡجٖ كَرِيمٍ﴾: صِنْفٍ حَسَنٍ كَثِيرِ المَنْفَعَةِ.</h2>"
        },
        "11": {
            "verses": {
                "31:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ضَلَٰلٖ مُّبِينٖ﴾: عُدُولٍ واضِحٍ عَنِ الطَّرِيقِ المُسْتَقِيمِ.</p>"
        },
        "12": {
            "verses": {
                "31:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿لُقۡمَٰنَ﴾: هو رَجُلٌ صالِحٌ، كَانَ مِنْ حُكَماءِ بني إسْرائِيلَ.</p>\n<h2>﴿ٱلۡحِكۡمَةَ﴾: العقلَ والفهمَ وإصابةَ القولِ.</h2>\n<h2>﴿كَفَرَ﴾: أي: جَحَدَ نِعَمَ اللهِ بِعَدَمِ شُكْرِها.</h2>"
        },
        "13": {
            "verses": {
                "31:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "14": {
            "verses": {
                "31:14": {
                    "id": 14
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَصَّيۡنَا﴾: أمَرْنا.</h2>\n<h2>﴿وَهۡنًا﴾: ضَعْفاً.</h2>\n<h2>﴿وَفِصَٰلُهُۥ﴾: تمامُ فِطامِه عَنِ الرَّضاعَةِ.</h2>\n<h2>﴿ٱلۡمَصِيرُ﴾: المَرْجِعُ.</h2>"
        },
        "15": {
            "verses": {
                "31:15": {
                    "id": 15
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿جَٰهَدَاكَ﴾: بَذَلا الجُهْدَ وحاوَلَا أن يُجْبِرَاكَ.</h2>\n<h2>﴿وَصَاحِبۡهُمَا﴾: عاشِرْهُما.</h2>\n<h2>﴿أَنَابَ إِلَيَّ﴾: رَجَع إليّ بالإخْلاصِ والتَّوبة.</h2>\n<h2>﴿مَرۡجِعُكُمۡ﴾: مَصِيرُكُم.</h2>\n<h2>﴿فَأُنَبِّئُكُم﴾: فَأُخْبِرُكُم.</h2>"
        },
        "16": {
            "verses": {
                "31:16": {
                    "id": 16
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿إِنَّهَآ﴾: أي: السَّيِّئةَ أو الحَسَنَةَ.</h2>\n<h2>﴿مِثۡقَالَ حَبَّةٖ﴾: وَزْنَ حَبَّةٍ.</h2>\n<h2>﴿خَرۡدَلٖ﴾: وَهُوَ أصْغَرُ الحُبُوبِ، والمرادُ أصغرُ شيءٍ.</h2>\n<h2>﴿فِي صَخۡرَةٍ﴾: في باطِنِ جَبَلٍ.</h2>"
        },
        "17": {
            "verses": {
                "31:17": {
                    "id": 17
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿بِٱلۡمَعۡرُوفِ﴾: المعْرُوفُ كُلُّ فِعْلٍ يُعْرَفُ حُسْنُه بالشَّرْعِ أو العَقْلِ.</p>\n<p>﴿ٱلۡمُنكَرِ﴾: وَهُوَ كُلُّ فِعْلٍ يُنكِرُه الشَّرعُ أوِ العَقْلُ.</p>\n<p>﴿مِنۡ عَزۡمِ ٱلۡأُمُورِ﴾: أي: مِنَ الأمُورِ الَّتي يَنْبَغِي العَزْمُ والحِرْصُ عليها.</p>"
        },
        "18": {
            "verses": {
                "31:18": {
                    "id": 18
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَلَا تُصَعِّرۡ خَدَّكَ﴾: أي: لا تُمِلْه عُجْباً واسْتِكْباراً.</p>\n<h2>﴿مَرَحًا﴾: فَرَحاً وبَطَراً.</h2>\n<h2>﴿مُخۡتَالٖ﴾: مُتَكَبِّرٍ.</h2>\n<h2>﴿فَخُورٖ﴾: مُتَباهٍ بنفسه.</h2>"
        },
        "19": {
            "verses": {
                "31:19": {
                    "id": 19
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱقۡصِدۡ فِي مَشۡيِكَ﴾: أي: تَوَسَّطْ فِيه مَعَ تَوَاضُعٍ وَسَكِينَةٍ.</p>\n<h2>﴿وَٱغۡضُضۡ﴾: واخْفِضْ.</h2>\n<h2>﴿أَنكَرَ ٱلۡأَصۡوَٰتِ﴾: أي: أقبَحَها.</h2>"
        },
        "20": {
            "verses": {
                "31:20": {
                    "id": 20
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿سَخَّرَ لَكُم﴾: ذَلَّلَ لَكُم.</h2>\n<h2>﴿وَأَسۡبَغَ﴾: عَمَّ وأَتَمَّ.</h2>\n<h2>﴿يُجَٰدِلُ﴾: يُخاصِمُ.</h2>\n<h2>﴿فِي ٱللَّهِ﴾: أي: في تَوحِيدِه وإخْلاصِ العِبادَةِ لَهُ.</h2>"
        },
        "21": {
            "verses": {
                "31:21": {
                    "id": 21
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿عَذَابِ ٱلسَّعِيرِ﴾: عَذَابِ جَهَنَّمَ المُسْتَعِرَةِ.</h2>"
        },
        "22": {
            "verses": {
                "31:22": {
                    "id": 22
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿يُسۡلِمۡ وَجۡهَهُۥٓ إِلَى ٱللَّهِ﴾: يُفوِّضْ إِلِيهِ أَمْرَهُ، ويُخلِصْ لَهُ عِبادَتَه.</p>\n<h2>﴿مُحۡسِنٞ﴾: مُطِيعٌ للهِ في أَمْرِهِ وَنَهْيِهِ.</h2>\n<h2>﴿ٱسۡتَمۡسَكَ﴾: تمسَّكَ واعْتَصَمَ.</h2>\n<p>﴿بِٱلۡعُرۡوَةِ ٱلۡوُثۡقَىٰ﴾: العَهْدِ الأوْثَقِ، والسَّبَبِ الأقْوَى.</p>\n<h2>﴿عَٰقِبَةُ ٱلۡأُمُورِ﴾: مَرْجِعُها.</h2>"
        },
        "23": {
            "verses": {
                "31:23": {
                    "id": 23
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَنُنَبِّئُهُم﴾: فَنُخْبِرُهُم.</h2>"
        },
        "24": {
            "verses": {
                "31:24": {
                    "id": 24
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
