            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿كَنَفۡسٖ وَٰحِدَةٍ﴾: أي: كَخَلْقِ نَفْسٍ وَاحِدَةٍ وبَعْثِها.</p>"
        },
        "29": {
            "verses": {
