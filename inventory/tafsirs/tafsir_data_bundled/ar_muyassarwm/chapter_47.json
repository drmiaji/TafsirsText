            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿عَزَمَ ٱلۡأَمۡرُ﴾: جَدَّ وعُزِمَ عَلَيهِ.</h2>"
        },
        "22": {
            "verses": {
                "47:22": {
                    "id": 22
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
