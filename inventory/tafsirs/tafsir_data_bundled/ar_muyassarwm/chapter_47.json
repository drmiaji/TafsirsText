                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مَثَلُ﴾: صِفَةُ.</h2>\n<h2>﴿ءَاسِنٖ﴾: مُتَغَيِّرٍ.</h2>\n<h2>﴿لَذَّةٖ﴾: ذَاتِ لَذّةٍ.</h2>\n<h2>﴿حَمِيمٗا﴾: تَنَاهَى في شِدَّةِ حَرِّهِ.</h2>"
        },
        "16": {
            "verses": {
                "47:16": {
                    "id": 16
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ءَانِفًا﴾: الآنَ، أي: أوَّلَ وَقْتٍ يَقْرُبُ مِنَّا.</h2>\n<h2>﴿طَبَعَ﴾: خَتَمَ.</h2>"
        },
        "17": {
            "verses": {
