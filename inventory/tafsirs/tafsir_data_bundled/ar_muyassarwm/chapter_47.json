            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿أَمۡثَٰلُهَا﴾: أَمْثالُ عاقِبةِ تَكْذِيبِ الأُمَمِ السَّابِقةِ مِنَ التَّدْمِيرِ وَالهَلَاكِ.</p>"
        },
        "11": {
            "verses": {
                "47:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
