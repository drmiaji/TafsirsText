            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَهَلۡ عَسَيۡتُمۡ﴾: فَلَعَلَّكُم.</h2>\n<h2>﴿تَوَلَّيۡتُمۡ﴾: أَعْرَضْتُم.</h2>"
        },
        "23": {
            "verses": {
