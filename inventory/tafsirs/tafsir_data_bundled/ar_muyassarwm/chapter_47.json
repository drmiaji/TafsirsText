            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لَعَنَهُمُ﴾: أَبْعَدَهُم.</h2>"
        },
        "24": {
            "verses": {
