            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مَوۡلَىٰ﴾: وَلِيٌّ وَناصِرٌ.</h2>"
        },
        "12": {
            "verses": {
                "47:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
