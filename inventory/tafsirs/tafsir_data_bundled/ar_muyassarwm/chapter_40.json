                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلدِّينَ﴾: العِبادَةَ والدُّعاءَ.</h2>"
        },
        "15": {
            "verses": {
                "40:15": {
