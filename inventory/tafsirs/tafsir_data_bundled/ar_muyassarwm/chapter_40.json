                "language_name": "english"
            },
            "text": "<h2>﴿عُذۡتُ﴾: لَجَأْتُ واسْتَجَرْتُ.</h2>"
        },
        "28": {
            "verses": {
                "40:28": {
                    "id": 28
                }
            },
