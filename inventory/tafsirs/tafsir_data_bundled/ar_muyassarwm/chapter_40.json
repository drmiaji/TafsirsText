            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلۡعَلِيِّ﴾: العاِلي عَلَى خَلْقِهِ ذَاتاً وَقَدْراً وَقَهْراً.</p>"
        },
        "13": {
            "verses": {
