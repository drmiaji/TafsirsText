            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡبَيِّنَٰتُ﴾: دَلَائلُ التَّوحِيدِ.</h2>\n<h2>﴿أُسۡلِمَ﴾: أخْضَعَ وأنقادَ بالطَّاعةِ التامَّةِ.</h2>"
        },
