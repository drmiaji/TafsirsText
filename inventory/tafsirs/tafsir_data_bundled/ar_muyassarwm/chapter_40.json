            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَأُفَوِّضُ أَمۡرِيٓ إِلَى ٱللَّهِ﴾: وَأَتَوَكَّلُ عَلَى اللهِ وأَلْجَأُ إِلَيهِ وَأَعْتَصِمُ بِهِ.</p>"
        },
        "45": {
            "verses": {
