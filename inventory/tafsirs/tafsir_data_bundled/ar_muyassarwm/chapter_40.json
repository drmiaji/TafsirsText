            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿فَأَنَّىٰ تُؤۡفَكُونَ﴾: فَكَيفَ تُصْرَفُونَ عَنِ الحقِّ والصَّوابِ فَتَعْدِلُونَ عَنِ الإيمانِ باللهِ، وتَعْبُدُونَ غَيرَه؟</p>"
        },
        "63": {
            "verses": {
                "40:63": {
                    "id": 63
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
