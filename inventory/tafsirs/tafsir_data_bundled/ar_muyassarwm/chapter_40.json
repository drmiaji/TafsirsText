            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿سَيِّـَٔاتِ مَا مَكَرُواْ﴾: عُقُوباتِ مَكْرِ فِرْعَونَ وآلِهِ.</p>\n<h2>﴿وَحَاقَ﴾: وَحَلَّ.</h2>"
        },
        "46": {
