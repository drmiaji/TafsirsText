                "language_name": "english"
            },
            "text": "<p>﴿وَقِهِمُ ٱلسَّيِّـَٔاتِ﴾: واصْرِفْ عَنْهُم سُوءَ عاقِبَةِ سيِّئاتِهِم.</p>"
        },
        "10": {
