            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿حُطَٰمٗا﴾: يابِساً هَشِيماً لا يُنْتَفعُ بِهِ.</h2>\n<h2>﴿فَظَلۡتُمۡ﴾: فصِرْتُمْ.</h2>\n<h2>﴿تَفَكَّهُونَ﴾: تَعْجَبُونَ مِن يُبْسِهِ بَعْدَ خُضْرَتِهِ.</h2>"
        },
        "66": {
            "verses": {
                "56:66": {
                    "id": 66
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّا لَمُغۡرَمُونَ﴾: لَمُلْزَمُونَ غَرَامَةَ ما أنْفَقْنا.</p>"
        },
        "67": {
            "verses": {
                "56:67": {
                    "id": 67
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مَحۡرُومُونَ﴾: من الرِّزقِ.</h2>"
        },
        "68": {
            "verses": {
                "56:68": {
                    "id": 68
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
