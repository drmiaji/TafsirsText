            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَحُورٌ﴾: نِساءٌ ذَواتُ حَوَرٍ، أي: نِساءٌ شَدِيداتُ بياضِ العَينِ وسَوَادِها.</p>\n<h2>﴿عِينٞ﴾: وَاسِعاتُ العُيُونِ.</h2>"
        },
        "23": {
            "verses": {
                "56:23": {
                    "id": 23
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
