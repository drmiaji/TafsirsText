            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿تُمۡنُونَ﴾: ما يَكُونُ مِنْكُم مِن المَنِيِّ.</h2>"
        },
        "59": {
            "verses": {
                "56:59": {
                    "id": 59
                }
            },
