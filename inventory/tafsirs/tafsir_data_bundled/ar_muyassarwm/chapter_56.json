                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡوَاقِعَةُ﴾: القِيامَةُ.</h2>"
        },
        "2": {
            "verses": {
                "56:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿كَاذِبَةٌ﴾: لَا يَكُونُ عِنْدَ وُقُوعِها تَكْذِيبٌ.</h2>"
        },
        "3": {
            "verses": {
                "56:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿خَافِضَةٞ رَّافِعَةٌ﴾: هي خافِضَةٌ يَحْصُلُ عِنْدَها خَفْضُ أَقْوامٍ كانُوا مُرْتَفِعِينَ، وَرَفْعُ أَقْوَامٍ كانُوا مُنْخَفِضِينَ، وَخافِضَةُ جِهاتٍ كانَتْ مُرْتَفِعَةً كالجِبالِ والصَّوامِعِ، رافِعَةٌ ما كانَ مُنْخَفِضاً بِسَبَبِ ما يَحْدُثُ في الكَونِ.</p>"
        },
        "4": {
            "verses": {
                "56:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿رُجَّتِ﴾: اضْطَرَبَتْ، بِسَبَبِ الزَّلَازِلِ، والخَسْفِ، ونَحْوِ ذَلِكَ.</p>"
        },
        "5": {
            "verses": {
                "56:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَبُسَّتِ﴾: فُتِّتَتِ الجبالُ ونُسِفَتْ.</h2>"
        },
        "6": {
            "verses": {
                "56:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿هَبَآءٗ﴾: ما يَلُوحُ في خُيُوطِ شُعاعِ الشَّمسِ مِن دَقِيقِ الغُبارِ.</p>\n<h2>﴿مُنۢبَثّٗا﴾: مُتَفَرِّقاً.</h2>"
        },
        "7": {
            "verses": {
                "56:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَزۡوَٰجٗا﴾: أَصْنافاً.</h2>"
        },
        "8": {
            "verses": {
                "56:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿أَصۡحَٰبُ ٱلۡمَيۡمَنَةِ﴾: هُمُ الَّذِينَ يُجْعَلُونَ في الجِهَةِ اليُمْنَى فِي الجَنَّةِ، أَوْ فِي الْمَحْشَرِ.</p>"
        },
        "9": {
            "verses": {
                "56:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿أَصۡحَٰبُ ٱلۡمَشۡـَٔمَةِ﴾: أَصْحابُ الشَّقاوَةِ الَّذِينَ يُؤْخَذُ بِهِم ذَاتَ الشِّمال إِلى النَّارِ.</p>"
        },
        "10": {
            "verses": {
                "56:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَٱلسَّٰبِقُونَ﴾: إِلى الخَيْرَاتِ.</h2>\n<h2>﴿ٱلسَّٰبِقُونَ﴾: إِلى مُنْتَهَى الفَضْلِ والرِّفْعَةِ.</h2>"
        },
        "11": {
