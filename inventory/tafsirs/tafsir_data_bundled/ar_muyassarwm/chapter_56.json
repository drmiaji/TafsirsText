                "language_name": "english"
            },
            "text": "<h2>﴿شَجَرَتَهَآ﴾: الَّتِي تُقْدَحُ مِنْها النَّارُ.</h2>\n<h2>﴿ٱلۡمُنشِـُٔونَ﴾: الخالِقُونَ.</h2>"
        },
        "73": {
            "verses": {
                "56:73": {
                    "id": 73
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
