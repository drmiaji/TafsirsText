            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡمُزۡنِ﴾: السَّحابِ.</h2>"
        },
        "70": {
            "verses": {
                "56:70": {
                    "id": 70
                }
