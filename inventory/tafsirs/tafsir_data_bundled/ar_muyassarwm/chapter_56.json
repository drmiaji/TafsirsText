            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلنَّشۡأَةَ ٱلۡأُولَىٰ﴾: خَلْقَ اللهِ إياكُم وَلَمْ تكُونُوا شَيئاً مَذْكُوراً.</p>"
        },
        "63": {
