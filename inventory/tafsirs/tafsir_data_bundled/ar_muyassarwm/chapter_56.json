            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿تُورُونَ﴾: تُوقِدُونَ.</h2>"
        },
        "72": {
            "verses": {
                "56:72": {
                    "id": 72
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
