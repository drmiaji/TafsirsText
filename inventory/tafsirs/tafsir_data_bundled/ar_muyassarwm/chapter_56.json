                "language_name": "english"
            },
            "text": "<h2>﴿يَحۡمُومٖ﴾: الدُّخانِ الأَسْوَدِ.</h2>"
        },
        "44": {
            "verses": {
                "56:44": {
                    "id": 44
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
