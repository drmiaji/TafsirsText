            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿تَزۡرَعُونَهُۥٓ﴾: تُنْبِتُونَهُ.</h2>"
        },
        "65": {
            "verses": {
