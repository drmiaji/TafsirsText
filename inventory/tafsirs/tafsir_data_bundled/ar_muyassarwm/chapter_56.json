            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَظِلّٖ مَّمۡدُودٖ﴾: لا يَتَقَلَّصُ كَظِلِّ الدُّنيا.</h2>"
        },
        "31": {
            "verses": {
