                "language_name": "english"
            },
            "text": "<h2>﴿أُجَاجٗا﴾: شَدِيدَ المُلُوحَةِ.</h2>"
        },
        "71": {
            "verses": {
                "56:71": {
                    "id": 71
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
