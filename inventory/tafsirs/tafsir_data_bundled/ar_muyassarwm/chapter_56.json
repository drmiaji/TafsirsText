            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مُتۡرَفِينَ﴾: ذوي نِعْمَةٍ واسِعةٍ.</h2>"
        },
        "46": {
            "verses": {
                "56:46": {
                    "id": 46
                }
