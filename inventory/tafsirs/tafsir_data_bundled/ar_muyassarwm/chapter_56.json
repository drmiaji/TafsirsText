            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡحَمِيمِ﴾: هُوَ الماءُ الشَّدِيدُ الغَلَيانِ.</h2>"
        },
        "55": {
            "verses": {
                "56:55": {
                    "id": 55
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلۡهِيمِ﴾: جَمْعُ أَهْيَمَ، وَهُوَ البَعِيرُ الَّذِي أصابَهُ الهُيَامُ، وهو دَاءٌ يُصِيبُ الإِبِلَ فلا تَزَالُ تَشْرَبُ وَلَا تَرْوَى.</p>"
        },
        "56": {
            "verses": {
                "56:56": {
                    "id": 56
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿نُزُلُهُمۡ﴾: النُّزُلُ هو ما يُقَدَّمُ للضَّيفِ مِن طَعَامٍ.</p>"
        },
        "57": {
            "verses": {
