                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يَوۡمِ ٱلدِّينِ﴾: يومِ القيامةِ الذي يكونُ فيه الجزاءُ.</h2>"
        },
        "5": {
            "verses": {
                "1:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
