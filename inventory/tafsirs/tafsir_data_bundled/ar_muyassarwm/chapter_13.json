                "language_name": "english"
            },
            "text": "<h2>﴿خَوۡفٗا﴾: من الصواعقِ المُحْرِقَةِ.</h2>\n<h2>﴿وَطَمَعٗا﴾: في نزولِ المَطَرِ.</h2>\n<h2>﴿وَيُنشِئُ﴾: يُوجِدُ.</h2>\n<p>﴿ٱلسَّحَابَ ٱلثِّقَالَ﴾: المُحَمَّلَةَ بالماءِ، فتَثْقُلُ لكثرةِ مائِها.</p>"
        },
        "13": {
            "verses": {
                "13:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
