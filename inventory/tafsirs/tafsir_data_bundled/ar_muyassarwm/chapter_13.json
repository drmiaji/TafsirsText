            },
            "text": "<p>...</p>"
        },
        "41": {
            "verses": {
                "13:41": {
                    "id": 41
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿نَنقُصُهَا مِنۡ أَطۡرَافِهَا﴾: نَفْتحُ أرضَ المشركين من جوانبِها، ونُلْحِقُها ببلادِ المسلمين.</p>\n<p>﴿لَا مُعَقِّبَ لِحُكۡمِهِۦ﴾: لا رادَّ ولا مُبْطِلَ لحُكْمِه وقضائِه.</p>"
        },
        "42": {
            "verses": {
                "13:42": {
                    "id": 42
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿مَكَرَ ٱلَّذِينَ مِن قَبۡلِهِمۡ﴾: احتالُوا في خُفْيةٍ؛ للكيدِ مِنْ رُسُلِهم.</p>\n<p>﴿فَلِلَّهِ ٱلۡمَكۡرُ جَمِيعٗا﴾: لا يَلْتفِتُ إلى تدبيرِ غيرِه، فهو المُبطِلُ لمكْرِهم.</p>\n<h2>﴿عُقۡبَى ٱلدَّارِ﴾: العاقبةُ المحمودةُ في الآخرةِ.</h2>"
        },
        "43": {
            "verses": {
                "13:43": {
                    "id": 43
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَنۡ عِندَهُۥ عِلۡمُ ٱلۡكِتَٰبِ﴾: وكَفَتْ شهادةُ علماءِ اليهودِ والنصارى ممَّن آمَنَ برسالتي.</p>"
        }
