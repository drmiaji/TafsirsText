                "language_name": "english"
            },
            "text": "<h2>﴿أَعُوذُ بِرَبِّ ٱلنَّاسِ﴾: أَعْتَصِمُ بِرَبِّ النَّاسِ.</h2>"
        },
        "2": {
            "verses": {
                "114:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿مَلِكِ ٱلنَّاسِ﴾: المُتَصرِّفِ في كُلِّ شُؤُونِهِم، الغَنِيِّ عَنْهُم.</p>"
        },
        "3": {
            "verses": {
                "114:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿إِلَٰهِ ٱلنَّاسِ﴾: الَّذِي لا مَعْبُودَ بِحَقٍّ سِوَاهُ.</h2>"
        },
        "4": {
            "verses": {
                "114:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿مِن شَرِّ ٱلۡوَسۡوَاسِ﴾: مِن أَذَى الشَّيطانِ الَّذِي يُوسْوِسُ عِنْدَ الغَفْلةِ.</p>\n<h2>﴿ٱلۡخَنَّاسِ﴾: الَّذِي يَخْتفِي عِنْدَ ذِكْرِ اللهِ.</h2>"
        },
        "5": {
            "verses": {
                "114:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿يُوَسۡوِسُ فِي صُدُورِ ٱلنَّاسِ﴾: يَبُثُّ الشَّرَّ والشُّكُوكَ في صُدُورِ النَّاسِ.</p>"
        },
        "6": {
            "verses": {
                "114:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿مِنَ ٱلۡجِنَّةِ وَٱلنَّاسِ﴾: مِن شياطِينِ الجِنِّ والإِنْسِ.</p>"
        }
    }
