                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَجَلٖ مُّسَمّٗى﴾: وتَعْيِينِ ساعَةٍ مُحَدَّدَةٍ لِبَقائِهِما.</p>"
        },
        "4": {
            "verses": {
                "46:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
