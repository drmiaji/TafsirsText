            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لِتَأۡفِكَنَا﴾: لِتَصْرِفَنا.</h2>"
        },
        "23": {
            "verses": {
