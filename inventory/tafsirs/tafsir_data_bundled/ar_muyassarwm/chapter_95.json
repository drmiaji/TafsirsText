                "language_name": "english"
            },
            "text": "<h2>﴿أَجۡرٌ غَيۡرُ مَمۡنُونٖ﴾: أَجْرٌ عظِيمٌ غَيرُ مَقْطُوعٍ.</h2>"
        },
        "7": {
            "verses": {
                "95:7": {
                    "id": 7
