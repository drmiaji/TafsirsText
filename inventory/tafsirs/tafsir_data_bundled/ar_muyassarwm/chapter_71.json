        "7": {
            "verses": {
                "71:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿جَعَلُوٓاْ أَصَٰبِعَهُمۡ فِيٓ ءَاذَانِهِمۡ﴾: أي: لِئَلَّا يَسْمَعُوا دَعْوةَ الحقِّ.</p>\n<p>﴿وَٱسۡتَغۡشَوۡاْ ثِيَابَهُمۡ﴾: تَغَطَّوا بِثيابِهِم عَلى أَعْيُنِهِم كَي لَا يَرَونِي.</p>\n<h2>﴿وَأَصَرُّواْ﴾: أي: عَلَى ما هُم فِيهِ مِنَ الكُفْرِ.</h2>"
        },
        "8": {
            "verses": {
                "71:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿جِهَارٗا﴾: ظاهِراً عَلَناً.</h2>"
        },
        "9": {
            "verses": {
                "71:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿أَعۡلَنتُ لَهُمۡ﴾: دَعَوتُهم بكَلَامٍ ظاهِرٍ وصَوْتٍ مرتَفِع.</p>"
        },
        "10": {
            "verses": {
                "71:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "11": {
            "verses": {
                "71:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يُرۡسِلِ ٱلسَّمَآءَ﴾: يُنْزِلِ اللهُ المَطَرَ.</h2>\n<h2>﴿مِدۡرَارٗا﴾: كَثِيرَ الدَّرِّ والصَّبِّ.</h2>"
        },
        "12": {
            "verses": {
                "71:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَيُمۡدِدۡكُم﴾: ويُعْطِكُم.</h2>"
        },
        "13": {
            "verses": {
                "71:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿لَا تَرۡجُونَ لِلَّهِ وَقَارٗا﴾: لا تَخافُونَ عَظَمَةَ اللهِ وَسُلْطَانَهُ.</p>"
        },
        "14": {
            "verses": {
                "71:14": {
                    "id": 14
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَقَدۡ خَلَقَكُمۡ أَطۡوَارًا﴾: أطواراً مُتَدَرِّجَةً: نُطْفَةً، ثم عَلَقَةً، ثم مُضْغَةً، ثم عِظاماً ولحماً.</p>"
        },
        "15": {
            "verses": {
                "71:15": {
                    "id": 15
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿طِبَاقٗا﴾: مُتَطابِقَةً بعضُها فَوقَ بَعْضٍ.</h2>"
        },
        "16": {
            "verses": {
                "71:16": {
                    "id": 16
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿سِرَاجٗا﴾: مُضِيئاً.</h2>"
        },
        "17": {
            "verses": {
                "71:17": {
                    "id": 17
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَٱللَّهُ أَنۢبَتَكُم﴾: أَنْشأَ أَصْلَكُم.</h2>\n<h2>﴿نَبَاتٗا﴾: إِنْشاءً.</h2>"
        },
        "18": {
            "verses": {
                "71:18": {
                    "id": 18
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَيُخۡرِجُكُمۡ﴾: يَومَ البَعْثِ.</h2>"
        },
        "19": {
            "verses": {
                "71:19": {
                    "id": 19
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِسَاطٗا﴾: مُمهَّدةً كالبِساطِ.</h2>"
        },
        "20": {
            "verses": {
                "71:20": {
                    "id": 20
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿سُبُلٗا﴾: طُرُقًا.</h2>\n<h2>﴿فِجَاجٗا﴾: واسِعةً.</h2>"
        },
        "21": {
            "verses": {
                "71:21": {
                    "id": 21
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "22": {
            "verses": {
                "71:22": {
                    "id": 22
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿كُبَّارٗا﴾: عَظِيماً.</h2>"
        },
        "23": {
            "verses": {
                "71:23": {
                    "id": 23
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿لَا تَذَرُنَّ ءَالِهَتَكُمۡ﴾: لا تَترُكُوا عِبادةَ آلهتِكُم.</p>\n<p>﴿وَلَا تَذَرُنَّ وَدّٗا وَلَا سُوَاعٗا وَلَا يَغُوثَ وَيَعُوقَ وَنَسۡرٗا﴾: وَلَا تَتْرُكُوا عِبادةَ هَذِهِ الأصْنامِ الَّتِي هي تَماثِيلُ رجالٍ صالِحِينَ.</p>"
        },
        "24": {
            "verses": {
                "71:24": {
                    "id": 24
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿كَثِيرٗا﴾: مِنَ النَّاسِ.</h2>\n<h2>﴿ٱلظَّٰلِمِينَ﴾: لِأَنفُسِهِم بالكُفْرِ والعِنادِ.</h2>\n<h2>﴿ضَلَٰلٗا﴾: بُعْداً عَن الحقِّ.</h2>"
        },
        "25": {
            "verses": {
                "71:25": {
                    "id": 25
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿مِمَّا خَطِيٓـَٰٔتِهِمۡ﴾: بِسَبَبِ ذُنُوبِهِم وَإِصْرارِهِم عَلَى الكُفْرِ والطُّغْيانِ.</p>\n<h2>﴿أُغۡرِقُواْ﴾: بالطُّوفانِ.</h2>\n<p>﴿أَنصَارٗا﴾: مَن يَنْصُرُهُم، أو يَدْفَعُ عَنْهُم عَذابَ اللهِ.</p>"
        },
        "26": {
            "verses": {
                "71:26": {
                    "id": 26
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لَا تَذَرۡ﴾: لا تَتْرُكْ.</h2>\n<p>﴿دَيَّارًا﴾: أَحَداً حَيّاً عَلَى الأرْضِ، يَدُورُ وَيَتَحَرَّكُ.</p>"
        },
        "27": {
            "verses": {
                "71:27": {
                    "id": 27
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿إِن تَذَرۡهُمۡ﴾: إن تَتْرُكْهُم دُونَ إِهْلاكٍ.</h2>\n<h2>﴿إِلَّا فَاجِرٗا﴾: إلا مائِلاً عَنِ الحقِّ.</h2>\n<h2>﴿كَفَّارٗا﴾: شَدِيدَ الكُفْرِ بِكَ والعِصْيانِ لَك.</h2>"
        },
        "28": {
            "verses": {
                "71:28": {
                    "id": 28
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿تَبَارَۢا﴾: هَلَاكاً وَخُسْراناً في الدُّنيا والآخِرَةِ.</h2>"
        }
    }
}