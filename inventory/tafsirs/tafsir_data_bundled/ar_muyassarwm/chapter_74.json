                "language_name": "english"
            },
            "text": "<h2>﴿إِذۡ أَدۡبَرَ﴾: حِينَ وَلَّى وَذَهَبَ.</h2>"
        },
        "34": {
            "verses": {
                "74:34": {
                    "id": 34
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَسۡفَرَ﴾: أَضَاءَ.</h2>"
        },
        "35": {
            "verses": {
                "74:35": {
                    "id": 35
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿إِنَّهَا﴾: إِنَّ النَّارَ.</h2>\n<h2>﴿ٱلۡكُبَرِ﴾: العَظائِمِ.</h2>"
        },
        "36": {
            "verses": {
                "74:36": {
                    "id": 36
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿نَذِيرٗا﴾: إِنْذاراً وَتَخْوِيفاً.</h2>"
        },
        "37": {
            "verses": {
                "74:37": {
                    "id": 37
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يَتَقَدَّمَ﴾: يَتَقَرَّبَ إلى رَبِّهِ بِفِعْلِ الطَّاعاتِ.</h2>\n<h2>﴿أَوۡ يَتَأَخَّرَ﴾: بِفِعْلِ المعاصِي.</h2>"
        },
        "38": {
            "verses": {
                "74:38": {
                    "id": 38
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِمَا كَسَبَتۡ﴾: مِنْ أَعْمالِ الخيرِ والشَّرِ.</h2>\n<h2>﴿رَهِينَةٌ﴾: مَحْبُوسَةٌ مَرْهُونَةٌ بِكَسْبِها.</h2>"
        },
        "39": {
            "verses": {
                "74:39": {
                    "id": 39
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿إِلَّآ أَصۡحَٰبَ ٱلۡيَمِينِ﴾: وهم المسْلِمُونَ المخلِصُونَ.</p>"
        },
        "40": {
            "verses": {
                "74:40": {
                    "id": 40
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يَتَسَآءَلُونَ﴾: يَسْأَلُ بَعْضُهُم بَعْضاً.</h2>"
        },
        "41": {
            "verses": {
                "74:41": {
                    "id": 41
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿عَنِ ٱلۡمُجۡرِمِينَ﴾: عَنِ الكافِرِينَ الَّذينَ أَجْرمُوا في حَقِّ أَنْفُسِهِم.</p>"
        },
        "42": {
            "verses": {
                "74:42": {
                    "id": 42
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مَا سَلَكَكُمۡ﴾: ما الَّذِي أَدْخَلَكُم.</h2>\n<h2>﴿سَقَرَ﴾: جَهَنَّمَ.</h2>"
        },
        "43": {
            "verses": {
                "74:43": {
                    "id": 43
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "44": {
            "verses": {
                "74:44": {
                    "id": 44
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
