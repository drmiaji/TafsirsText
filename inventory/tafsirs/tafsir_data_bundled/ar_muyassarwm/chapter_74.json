            },
            "text": "<p>...</p>"
        },
        "45": {
            "verses": {
                "74:45": {
                    "id": 45
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿نَخُوضُ﴾: نَتَحَدَّثُ بالباطِلِ.</h2>\n<h2>﴿مَعَ ٱلۡخَآئِضِينَ﴾: مَعَ أَهْلِ الضَّلالةِ.</h2>"
        },
        "46": {
            "verses": {
                "74:46": {
                    "id": 46
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِيَوۡمِ ٱلدِّينِ﴾: بِيومِ الحِسابِ والجزَاءِ.</h2>"
        },
        "47": {
            "verses": {
                "74:47": {
                    "id": 47
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡيَقِينُ﴾: الموتُ.</h2>"
        },
        "48": {
            "verses": {
                "74:48": {
                    "id": 48
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿شَفَٰعَةُ﴾: طَلَبُ قَضَاءِ حاجَةِ المشْفُوعِ لَهُ عِنْدَ المَشْفُوعِ عنْدَهُ.</p>\n<h2>﴿ٱلشَّٰفِعِينَ﴾: الملائِكَةِ والنَّبِيِّينَ وَغَيرِهِم.</h2>"
        },
        "49": {
            "verses": {
                "74:49": {
                    "id": 49
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَمَا لَهُمۡ﴾: فما لِهؤُلَاءِ المشْرِكِينَ.</h2>\n<p>﴿عَنِ ٱلتَّذۡكِرَةِ﴾: عَنِ القُرآنِ وما فِيهِ مِنَ الموَاعِظِ.</p>\n<h2>﴿مُعۡرِضِينَ﴾: مُنْصَرِفِينَ.</h2>"
        },
        "50": {
            "verses": {
                "74:50": {
                    "id": 50
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿حُمُرٞ﴾: حُمُرٌ وَحْشِيَّةٌ.</h2>\n<h2>﴿مُسۡتَنفِرَةٞ﴾: شَدِيدَةُ النِّفارِ.</h2>"
        },
        "51": {
            "verses": {
                "74:51": {
                    "id": 51
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿قَسۡوَرَةِۭ﴾: أَسَدٍ كَاسِرٍ.</h2>"
        },
        "52": {
            "verses": {
                "74:52": {
                    "id": 52
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿صُحُفٗا﴾: كُتُباً.</h2>\n<h2>﴿مُنَشَّرَةٗ﴾: مَفْتُوحَةً مَقْرُوءَةً.</h2>"
        },
        "53": {
            "verses": {
                "74:53": {
                    "id": 53
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿كَلَّا﴾: ليسَ الأمرُ كَما زَعَمُوا.</h2>\n<p>﴿لَا يَخَافُونَ ٱلۡأٓخِرَةَ﴾: لا يُصَدِّقُونَ بالبَعْثِ والجزَاءِ.</p>"
        },
        "54": {
            "verses": {
                "74:54": {
                    "id": 54
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿كَلَّآ﴾: حَقّاً.</h2>\n<h2>﴿إِنَّهُۥ﴾: إِنَّ القُرآنَ.</h2>\n<h2>﴿تَذۡكِرَةٞ﴾: مَوْعِظَةٌ بَلِيغَةٌ كافِيَةٌ لِاتِّعاظِهِم.</h2>"
        },
        "55": {
            "verses": {
                "74:55": {
                    "id": 55
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ذَكَرَهُۥ﴾: اتَّعظَ بِما فِيهِ وانْتَفَعَ بِهُدَاهُ.</h2>"
        },
        "56": {
            "verses": {
                "74:56": {
                    "id": 56
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَا يَذۡكُرُونَ﴾: وَما يَتَّعِظُونَ بِه.</h2>\n<p>﴿هُوَ أَهۡلُ ٱلتَّقۡوَىٰ﴾: المُسْتَحِقُّ لِأَن يُتَّقَى وَيُطاعَ.</p>\n<p>﴿وَأَهۡلُ ٱلۡمَغۡفِرَةِ﴾: والجديرُ بأن يَغْفِرَ لِمَنْ آمنَ بِهِ وَأطاعَهُ.</p>"
        }
    }
}