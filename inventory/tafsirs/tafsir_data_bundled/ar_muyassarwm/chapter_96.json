            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِٱلۡقَلَمِ﴾: الكِتابة بالقَلَمِ.</h2>"
        },
        "5": {
            "verses": {
