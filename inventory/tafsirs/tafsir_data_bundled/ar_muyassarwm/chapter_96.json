                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱقۡرَأۡ﴾: اقْرَأْ -أيُّها النَّبِيُّ- ما أُنِزلَ إلَيكَ مِن القُرآنِ.</p>\n<h2>﴿بِٱسۡمِ رَبِّكَ﴾: مُفْتَتِحاً باسْمِ رَبِّكَ.</h2>\n<h2>﴿ٱلَّذِي خَلَقَ﴾: المُتَفَرِّدِ بالخَلْقِ.</h2>"
        },
        "2": {
            "verses": {
                "96:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿عَلَقٍ﴾: قِطْعَةِ دَمٍ غَلِيظٍ أَحْمَرَ.</h2>"
        },
        "3": {
            "verses": {
                "96:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
