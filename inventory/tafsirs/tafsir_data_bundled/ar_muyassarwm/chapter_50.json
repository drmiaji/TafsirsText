                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿عَجِيبٌ﴾: مُسْتَغْرَبٌ يُتَعَجَّبُ مِنْهُ.</h2>"
        },
        "3": {
            "verses": {
