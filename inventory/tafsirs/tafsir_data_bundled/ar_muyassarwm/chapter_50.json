            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿تَنقُصُ ٱلۡأَرۡضُ مِنۡهُمۡ﴾: تُفْنِي مِنْ أَجْسامِهِم.</h2>\n<h2>﴿حَفِيظُۢ﴾: مَحفُوظٌ.</h2>"
        },
        "5": {
            "verses": {
                "50:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مَرِيجٍ﴾: مُخْتَلِطٍ مُضْطَرِبٍ.</h2>"
        },
        "6": {
            "verses": {
                "50:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
