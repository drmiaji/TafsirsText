                "language_name": "english"
            },
            "text": "<h2>﴿ٱلسَّاعَةُ﴾: القِيامَةُ.</h2>\n<h2>﴿وَٱنشَقَّ﴾: انْفَلَقَ فِلْقَتَينِ.</h2>"
        },
        "2": {
            "verses": {
                "54:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ءَايَةٗ﴾: بُرْهاناً عَلَى صِدْقِ الرَّسُولِ مُحَمَّدٍ ﷺ.</h2>\n<h2>﴿مُسۡتَمِرّٞ﴾: ذاهِبٌ مُضْمَحِلٌّ لَا دَوامَ لَهُ.</h2>"
        },
        "3": {
            "verses": {
                "54:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿أَهۡوَآءَهُمۡ﴾: ما تُحِبُّهُ أَنفُسُهُم مِنَ الضَّلالِ والتَّكْذِيبِ.</p>\n<h2>﴿أَمۡرٖ﴾: مِنْ خَيرٍ أَوْ شَرٍّ.</h2>\n<h2>﴿مُسۡتَقِرّٞ﴾: واقِعٌ بأَهْلِهِ يَوْمَ القِيامَةِ.</h2>"
        },
        "4": {
            "verses": {
                "54:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مُزۡدَجَرٌ﴾: كِفايَةٌ لِرَدْعِهم.</h2>"
        },
        "5": {
            "verses": {
                "54:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿حِكۡمَةُۢ﴾: هَذا القُرْآنُ فِيهِ حِكْمَةٌ عَظِيمةٌ.</h2>\n<h2>﴿بَٰلِغَةٞ﴾: بالِغَةٌ غايَتَها.</h2>\n<h2>﴿فَمَا﴾: فأيُّ شَيءٍ.</h2>\n<h2>﴿تُغۡنِ﴾: تَدْفَعُ أَوْ تَنْفَعُ.</h2>\n<h2>﴿ٱلنُّذُرُ﴾: الإِنْذاراتُ.</h2>"
        },
        "6": {
            "verses": {
                "54:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَتَوَلَّ﴾: فَأَعْرِضْ.</h2>\n<h2>﴿ٱلدَّاعِ﴾: المَلَكُ بنَفْخِهِ في «القَرْنِ».</h2>\n<h2>﴿نُكُرٍ﴾: فَظِيعٍ مُنْكَرٍ، وهو موقِفُ الحِسابِ.</h2>"
        },
        "7": {
            "verses": {
                "54:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿خُشَّعًا﴾: ذَلِيلَةً.</h2>\n<h2>﴿ٱلۡأَجۡدَاثِ﴾: القُبُورِ.</h2>\n<h2>﴿مُنتَشِرٞ﴾: مُنْبَثٌّ عَلَى وَجْهِ الأرْضِ.</h2>"
        },
        "8": {
            "verses": {
                "54:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مُهۡطِعِينَ﴾: مُسْرِعِينَ مادِّينَ أَعْناقَهُم.</h2>\n<h2>﴿ٱلدَّاعِ﴾: صوتِ المَلَكِ.</h2>\n<h2>﴿عَسِرٞ﴾: شَدِيدُ الْهَوْلِ.</h2>"
        },
        "9": {
            "verses": {
                "54:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَٱزۡدُجِرَ﴾: وانْتَهَرُوا نوحاً -عليه السلام- مُتَوَعِّدِينَ إِيَّاهُ بأنْواعِ الأَذَى.</p>"
        },
        "10": {
            "verses": {
                "54:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مَغۡلُوبٞ﴾: ضَعِيفٌ عَن مُقاوَمةِ هَؤُلَاءِ.</h2>\n<h2>﴿فَٱنتَصِرۡ﴾: لِي بِعِقابٍ مِنْ عِنْدِكَ.</h2>"
        },
        "11": {
            "verses": {
                "54:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مُنۡهَمِرٖ﴾: كَثِيرٍ مُتَدَفِّقٍ.</h2>"
        },
        "12": {
            "verses": {
                "54:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَفَجَّرۡنَا﴾: وَشَقَقْنا.</h2>\n<h2>﴿عُيُونٗا﴾: مِنْ عُيُونٍ مُتَفَجِّرَةٍ بالماءِ.</h2>\n<p>﴿فَٱلۡتَقَى ٱلۡمَآءُ﴾: فَالْتَقَى ماءُ السَّماءِ وماءُ الأرْضِ.</p>\n<p>﴿عَلَىٰٓ أَمۡرٖ قَدۡ قُدِرَ﴾: عَلَى إِهْلَاكِهِم الَّذِي قَدَّرَهُ اللهُ لَهُم.</p>"
        },
        "13": {
            "verses": {
                "54:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ذَاتِ أَلۡوَٰحٖ﴾: سَفِينَةٍ ذاتِ ألْوَاحٍ.</h2>\n<h2>﴿وَدُسُرٖ﴾: وَمَسامِيرَ شُدَّتْ بِها.</h2>"
        },
        "14": {
            "verses": {
                "54:14": {
                    "id": 14
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
