            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِأَعۡيُنِنَا﴾: بِمَرْأىً مِنَّا وحِفْظٍ.</h2>"
        },
        "15": {
            "verses": {
                "54:15": {
                    "id": 15
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
