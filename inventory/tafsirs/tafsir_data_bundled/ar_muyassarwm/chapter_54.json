            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿نَجۡزِي﴾: نُثِيبُ.</h2>\n<h2>﴿مَن شَكَرَ﴾: مَنْ آمَنَ بِاللهِ وَوَحّدَهُ.</h2>"
        },
        "36": {
            "verses": {
                "54:36": {
                    "id": 36
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
