            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلزُّبُرِ﴾: الكُتُبِ الَّتِي كَتَبَتْهَا الحَفَظَةُ.</h2>"
        },
        "53": {
            "verses": {
