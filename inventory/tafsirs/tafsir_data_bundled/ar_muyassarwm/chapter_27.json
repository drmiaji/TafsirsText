            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿رَهۡطٖ﴾: رِجَالٍ مِنْ أبْنَاءِ الأشْرَافِ.</h2>"
        },
        "49": {
