            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَلَا يُنَبِّئُكَ﴾: وَلَا يُخْبِرُكَ.</h2>"
        },
