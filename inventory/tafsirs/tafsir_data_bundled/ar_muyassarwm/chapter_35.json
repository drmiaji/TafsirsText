            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡحَزَنَ﴾: أي: كُلَّ ما يُحْزِنُ ويَغُمُّ.</h2>"
        },
        "35": {
            "verses": {
                "35:35": {
                    "id": 35
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
