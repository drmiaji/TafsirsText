                "language_name": "english"
            },
            "text": "<h2>﴿فَاطِرِ﴾: مُبْدِعٍ عَلى غَيرِ مِثالٍ سَبَقَ.</h2>\n<h2>﴿أُوْلِيٓ أَجۡنِحَةٖ﴾: أَصْحابَ أجْنِحَةٍ.</h2>"
        },
        "2": {
            "verses": {
                "35:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مَا يَفۡتَحِ﴾: أي: ما يُرسِلْ ويُعْطِ.</h2>\n<h2>﴿رَحۡمَةٖ﴾: نِعْمَةٍ.</h2>\n<h2>﴿مُمۡسِكَ﴾: مانِعَ.</h2>\n<h2>﴿مُرۡسِلَ﴾: مُعْطِيَ.</h2>"
        },
        "3": {
            "verses": {
                "35:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿فَأَنَّىٰ تُؤۡفَكُونَ﴾: فَكَيفَ تُصْرَفُونَ عَن تَوحِيدِهِ؟.</p>"
        },
        "4": {
            "verses": {
                "35:4": {
                    "id": 4
                }
            },
