            },
            "text": "<h2>﴿نَذِيرٌ﴾: رَسُولٌ مُنْذِرٌ مِنْ عَذَابِ اللهِ.</h2>"
        },
        "24": {
            "verses": {
                "35:24": {
                    "id": 24
                }
