                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يَٰٓأُوْلِي ٱلۡأَلۡبَٰبِ﴾: أَصْحابَ العُقُولِ.</h2>\n<h2>﴿ذِكۡرٗا﴾: قُرآناً.</h2>"
        },
        "11": {
            "verses": {
