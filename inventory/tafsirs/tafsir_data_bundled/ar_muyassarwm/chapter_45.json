            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿جَاثِيَةٗ﴾: بارِكَةً عَلَى الرُّكَبِ مُسْتَوفِزَةً.</h2>\n<h2>﴿كِتَٰبِهَا﴾: كِتابِ أعْمَالِهَا.</h2>"
        },
        "29": {
            "verses": {
                "45:29": {
                    "id": 29
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
