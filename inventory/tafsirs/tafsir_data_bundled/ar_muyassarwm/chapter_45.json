            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَبَدَا﴾: وَظَهَرَ.</h2>\n<h2>﴿وَحَاقَ﴾: وَنَزَلَ وَأَحَاطَ.</h2>"
        },
        "34": {
            "verses": {
                "45:34": {
                    "id": 34
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿نَنسَىٰكُمۡ﴾: نَتْرُكُكُم في عَذابِ جَهَنَّمَ.</h2>\n<h2>﴿وَمَأۡوَىٰكُمُ﴾: ومَسْكَنُكُم.</h2>"
        },
        "35": {
            "verses": {
