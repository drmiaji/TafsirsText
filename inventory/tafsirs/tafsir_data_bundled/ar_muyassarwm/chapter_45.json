            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلۡمُبۡطِلُونَ﴾: الَّذِينَ أَبْطَلُوا الحَقَّ بِسَبَب دَعْواهُم للهِ شَرِيكاً.</p>"
        },
        "28": {
            "verses": {
