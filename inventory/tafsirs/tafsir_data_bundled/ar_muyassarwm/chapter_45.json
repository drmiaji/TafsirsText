            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿هُزُوًا﴾: مَوْضِعَ سُخْرِيةٍ واسْتِخْفافٍ.</h2>"
        },
        "10": {
            "verses": {
                "45:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مِن وَرَآئِهِمۡ﴾: من أمَامِهم.</h2>\n<h2>﴿وَلَا يُغۡنِي عَنۡهُم﴾: ولا يَنْفَعُهُم.</h2>\n<h2>﴿أَوۡلِيَآءَ﴾: نُصَراءَ.</h2>"
        },
        "11": {
            "verses": {
                "45:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
