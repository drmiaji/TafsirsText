            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "7": {
            "verses": {
                "45:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَيۡلٞ﴾: هَلَاكٌ شَدِيدٌ.</h2>\n<h2>﴿أَفَّاكٍ﴾: كَذَّابٍ.</h2>\n<h2>﴿أَثِيمٖ﴾: كَثِيرِ الآثامِ.</h2>"
        },
        "8": {
            "verses": {
                "45:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
