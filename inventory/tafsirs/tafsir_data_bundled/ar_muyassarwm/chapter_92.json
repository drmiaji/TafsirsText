{
    "chapter": 92,
    "verses": {
        "1": {
            "verses": {
                "92:1": {
                    "id": 1
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يَغۡشَىٰ﴾: يُغَطِّي بِظلامِهِ الأَرْضَ وَمَا عَلَيها.</h2>"
        },
        "2": {
            "verses": {
                "92:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿تَجَلَّىٰ﴾: انكَشَفَ عَن ظَلام الليلِ بضِيائِهِ.</h2>"
        },
        "3": {
            "verses": {
                "92:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَا خَلَقَ ٱلذَّكَرَ وَٱلۡأُنثَىٰٓ﴾: أَقْسَمَ اللهُ بِخَلْقِ الزَّوجينِ.</p>"
        },
        "4": {
            "verses": {
                "92:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّ سَعۡيَكُمۡ لَشَتَّىٰ﴾: عَمَلَكُم لَمُخْتَلِفٌ بَينَ عامِلٍ للدُّنيا وعامِلٍ للآخِرَةِ.</p>"
        },
        "5": {
            "verses": {
                "92:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَعۡطَىٰ﴾: بَذَلَ مِن مَّالِهِ.</h2>"
        },
        "6": {
            "verses": {
                "92:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿بِٱلۡحُسۡنَىٰ﴾: بـ «لَا إِلَه إلا اللهُ» وما دَلَّتْ عَلَيهِ، وما تَرتَّبَ عَلَيها مِنَ الجَزاءِ.</p>"
        },
        "7": {
            "verses": {
                "92:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَسَنُيَسِّرُهُۥ﴾: فَسَنُوَفِّقُهُ.</h2>\n<h2>﴿لِلۡيُسۡرَىٰ﴾: لِعَمَلِ الخيرِ والشَّرِيعةِ السَّهْلَةِ.</h2>"
        },
        "8": {
            "verses": {
                "92:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بَخِلَ﴾: بِمالِهِ.</h2>\n<h2>﴿وَٱسۡتَغۡنَىٰ﴾: عَن جزاءِ اللهِ.</h2>"
        },
        "9": {
            "verses": {
                "92:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿بِٱلۡحُسۡنَىٰ﴾: بِالْعِوَضِ مِنَ اللهِ.</h2>"
        },
        "10": {
            "verses": {
                "92:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَسَنُيَسِّرُهُۥ﴾: فسَنُهَيِّئُهُ في الدُّنيا.</h2>\n<p>﴿لِلۡعُسۡرَىٰ﴾: للْخَصْلَةِ العُسْرى، فَتَتَعَسَّرُ عَلَيه أسبابُ الخيرِ.</p>"
        },
        "11": {
            "verses": {
                "92:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَا يُغۡنِي عَنۡهُ﴾: ولا يَنفَعُهُ.</h2>\n<h2>﴿تَرَدَّىٰٓ﴾: وَقَعَ في النَّارِ.</h2>"
        },
        "12": {
            "verses": {
                "92:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لَلۡهُدَىٰ﴾: بيانَ طَرِيقِ الهُدَى المُوصِلِ إلى اللهِ.</h2>"
        },
        "13": {
            "verses": {
                "92:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِنَّ لَنَا لَلۡأٓخِرَةَ﴾: وإِنَّ لَنا مُلْكَ الحياةِ الآخِرَةِ.</p>\n<h2>﴿وَٱلۡأُولَىٰ﴾: والحياةَ الدُّنيا.</h2>"
        },
        "14": {
            "verses": {
                "92:14": {
                    "id": 14
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَأَنذَرۡتُكُمۡ﴾: فَحَذَّرْتُكُم.</h2>\n<h2>﴿نَارٗا تَلَظَّىٰ﴾: ناراً تَتَوهَّجُ، وهي نَارُ جَهَنَّمَ.</h2>"
        },
        "15": {
            "verses": {
                "92:15": {
                    "id": 15
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لَا يَصۡلَىٰهَآ﴾: لا يُقاسِي حَرَّها.</h2>"
        },
        "16": {
            "verses": {
                "92:16": {
                    "id": 16
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿كَذَّبَ﴾: أي: نبيَّ اللهِ محمدًا ﷺ.</h2>\n<p>﴿وَتَوَلَّىٰ﴾: وَأَعْرَضَ عَنِ الإيمانِ باللهِ ورسولِه، وطاعَتِهِما.</p>"
        },
        "17": {
            "verses": {
                "92:17": {
                    "id": 17
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَسَيُجَنَّبُهَا﴾: وَسَيُزَحْزَحُ عَنْها.</h2>"
        },
        "18": {
            "verses": {
                "92:18": {
                    "id": 18
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يُؤۡتِي مَالَهُۥ﴾: يَبْذُلُ مالَهُ.</h2>\n<h2>﴿يَتَزَكَّىٰ﴾: يَطلبُ المزيدَ مِنَ الخيرِ.</h2>"
        },
        "19": {
            "verses": {
                "92:19": {
                    "id": 19
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعۡمَةٖ تُجۡزَىٰٓ﴾: وَلَيسَ إِنفَاقُه ذَاكَ مُكَافأةً لِمنْ أَسْدَى إِلَيهِ معرُوفاً.</p>"
        },
        "20": {
            "verses": {
                "92:20": {
                    "id": 20
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿إِلَّا﴾: لَكِنَّهُ.</h2>"
        },
        "21": {
            "verses": {
                "92:21": {
