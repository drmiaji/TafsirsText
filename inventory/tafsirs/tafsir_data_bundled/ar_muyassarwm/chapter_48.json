            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿حَرَجٞ﴾: إِثْمٌ في تَخَلُّفِهِ عَنِ الجِهادِ.</h2>"
        },
        "18": {
            "verses": {
                "48:18": {
                    "id": 18
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
