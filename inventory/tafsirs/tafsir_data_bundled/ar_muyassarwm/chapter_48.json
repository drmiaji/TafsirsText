            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أُوْلِي بَأۡسٖ﴾: أَصْحابِ قُوَّةٍ.</h2>\n<h2>﴿وَإِن تَتَوَلَّوۡاْ﴾: تُعْرِضُوا.</h2>"
        },
        "17": {
            "verses": {
                "48:17": {
                    "id": 17
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
