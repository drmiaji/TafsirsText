            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلۡمُخَلَّفُونَ﴾: الَّذِينَ تَخَلَّفُوا عَنِ الخُروجِ مَعَكَ إلى مكَّةَ.</p>"
        },
        "12": {
            "verses": {
