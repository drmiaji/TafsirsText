            },
            "text": "<h2>﴿هَٰذِهِۦ﴾: أَيْ: غَنائِمَ خَيبرَ.</h2>\n<h2>﴿وَكَفَّ﴾: وَمَنَعَ.</h2>"
        },
        "21": {
            "verses": {
                "48:21": {
                    "id": 21
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَأُخۡرَىٰ﴾: وَعَدَكُم رَبُّكُم فَتْحَ بَلْدَةٍ أُخْرَى، وهي مكَّةُ.</p>"
        },
        "22": {
            "verses": {
