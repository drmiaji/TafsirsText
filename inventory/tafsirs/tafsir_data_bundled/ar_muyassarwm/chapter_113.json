            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿غَاسِقٍ﴾: لَيلٍ شَدِيدِ الظُّلْمَةِ.</h2>\n<h2>﴿إِذَا وَقَبَ﴾: دَخَلَ ظَلامُهُ في كُلِّ شَيءٍ.</h2>"
        },
        "4": {
            "verses": {
                "113:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلنَّفَّٰثَٰتِ فِي ٱلۡعُقَدِ﴾: السَّاحِراتِ اللاتِي يَنفُخْنَ فِيما يَعْقِدْنَ مِنْ عُقَدٍ بِقَصْدِ السِّحْرِ.</p>"
        },
        "5": {
            "verses": {
                "113:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ﴾: وَمِن شَرِّ حاسِدٍ مُبْغِضٍ للنَّاسِ، إذا حَسَدَهُم عَلَى ما وَهَبَهُم اللهُ مِنَ النِّعَمِ.</p>"
        }
