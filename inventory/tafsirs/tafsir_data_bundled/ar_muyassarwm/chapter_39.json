                "language_name": "english"
            },
            "text": "<h2>﴿غَيۡرَ ذِي عِوَجٖ﴾: لَا لَبْسَ فِيهِ ولا اخْتِلافَ.</h2>"
        },
        "29": {
            "verses": {
                "39:29": {
                    "id": 29
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
