{
    "chapter": 104,
    "verses": {
        "1": {
            "verses": {
                "104:1": {
                    "id": 1
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَيۡلٞ﴾: شَرٌّ وَهَلاكٌ.</h2>\n<h2>﴿لِكُلِّ هُمَزَةٖ﴾: لِكُلِّ مُغْتابٍ للنَّاسِ.</h2>\n<h2>﴿لُمَزَةٍ﴾: طَعَّانٍ فِيهِم.</h2>"
        },
        "2": {
            "verses": {
                "104:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿جَمَعَ مَالٗا وَعَدَّدَهُۥ﴾: كانَ هَمُّه جَمْعَ المالِ وتَعْدَادَهُ.</p>"
        },
        "3": {
            "verses": {
                "104:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَخۡلَدَهُۥ﴾: جَعَلَه خالِداً في الدُّنيا.</h2>"
        },
        "4": {
            "verses": {
                "104:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لَيُنۢبَذَنَّ﴾: ليُطْرَحَنَّ.</h2>\n<p>﴿فِي ٱلۡحُطَمَةِ﴾: في النَّارِ الَّتِي تُحَطِّم كُلَّ ما يُلْقى فِيها.</p>"
        },
        "5": {
            "verses": {
                "104:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَآ أَدۡرَىٰكَ﴾: وأيُّ شيءٍ أَعْلَمَكَ؟</h2>"
        },
        "6": {
            "verses": {
                "104:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡمُوقَدَةُ﴾: المسْتَعِرَةُ الَّتِي لا يزُولُ لَهِيبُها.</h2>"
        },
        "7": {
            "verses": {
                "104:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿تَطَّلِعُ عَلَى ٱلۡأَفۡـِٔدَةِ﴾: من شِدَّتِها تَنفُذُ مِنَ الأجْسام إِلى القُلُوبِ.</p>"
        },
        "8": {
            "verses": {
                "104:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿مُؤۡصَدَةٞ﴾: مُغْلَقةٌ غَلْقاً مُطْبِقاً.</h2>"
        },
        "9": {
            "verses": {
                "104:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فِي عَمَدٖ﴾: مُوْثَقِينَ في سَلاسِلَ وأغلالٍ.</h2>\n<h2>﴿مُمَدَّدَةِۭ﴾: مُطَوَّلَةٍ؛ لئلَّا يَخرُجُوا مِنها.</h2>"
        }
    }
}