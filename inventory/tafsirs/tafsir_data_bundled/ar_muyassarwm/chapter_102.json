                "language_name": "english"
            },
            "text": "<p>...</p>"
        },
        "5": {
            "verses": {
                "102:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿لَوۡ تَعۡلَمُونَ عِلۡمَ ٱلۡيَقِينِ﴾: لو تَعْلَمُونَ حَقَّ العِلْمِ لانْزَجَرْتُم، وَلَبادَرْتُم إلى إنقاذِ أَنفُسِكُم مِنَ الهَلاكِ.</p>"
        },
        "6": {
            "verses": {
                "102:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لَتَرَوُنَّ ٱلۡجَحِيمَ﴾: لَتُبصِرُنَّ الجحِيمَ.</h2>"
        },
        "7": {
            "verses": {
                "102:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ لَتَرَوُنَّهَا عَيۡنَ ٱلۡيَقِينِ﴾: ثُمَّ لَتُبْصِرُنَّها دُونَ رَيبٍ.</p>"
        },
        "8": {
            "verses": {
