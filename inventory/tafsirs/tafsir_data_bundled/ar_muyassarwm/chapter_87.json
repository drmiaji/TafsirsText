{
    "chapter": 87,
    "verses": {
        "1": {
            "verses": {
                "87:1": {
                    "id": 1
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿سَبِّحِ ٱسۡمَ رَبِّكَ﴾: نَزِّه اسمَ رَبِّكَ عَن كُلِّ ما لا يَليقُ بِهِ.</p>"
        },
        "2": {
            "verses": {
                "87:2": {
                    "id": 2
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَسَوَّىٰ﴾: فَأَتْقَنَ خَلْقَ الإنسانِ.</h2>"
        },
        "3": {
            "verses": {
                "87:3": {
                    "id": 3
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿فَهَدَىٰ﴾: الإنسانَ لِسبيلِ الخَيْرِ والشَّرِّ، وهَدَى الأَنْعَامَ لِمَراتِعِهَا.</p>"
        },
        "4": {
            "verses": {
                "87:4": {
                    "id": 4
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿ٱلۡمَرۡعَىٰ﴾: الكَلَأَ الأَخْضَرَ.</h2>"
        },
        "5": {
            "verses": {
                "87:5": {
                    "id": 5
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿غُثَآءً﴾: هَشِيماً جافّاً.</h2>\n<h2>﴿أَحۡوَىٰ﴾: مُتَغَيِّراً إلى السَّوادِ بَعْدَ الخُضْرَةِ.</h2>"
        },
        "6": {
            "verses": {
                "87:6": {
                    "id": 6
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿سَنُقۡرِئُكَ﴾: سنُعْلِمُكَ بِقراءةِ جِبريلَ عَلَيكَ.</h2>"
        },
        "7": {
            "verses": {
                "87:7": {
                    "id": 7
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿إِلَّا مَا شَآءَ ٱللَّهُ﴾: أَن تَنْساهُ وما نَسَخَ اللهُ تِلاوتَهُ.</p>"
        },
        "8": {
            "verses": {
                "87:8": {
                    "id": 8
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿وَنُيَسِّرُكَ﴾: وُنَهوِّنُ عَلَيكَ.</h2>\n<h2>﴿لِلۡيُسۡرَىٰ﴾: عَمَلِ أَهْلِ الجنَّةِ.</h2>"
        },
        "9": {
            "verses": {
                "87:9": {
                    "id": 9
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿فَذَكِّرۡ﴾: فَعِظْ بالقرآنِ.</h2>\n<h2>﴿إِن نَّفَعَتِ ٱلذِّكۡرَىٰ﴾: إن رُجِيَ مِنهُ التَّذَكُّرُ.</h2>"
        },
        "10": {
            "verses": {
                "87:10": {
                    "id": 10
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿سَيَذَّكَّرُ﴾: سيَتَّعِظُ.</h2>"
        },
        "11": {
            "verses": {
                "87:11": {
                    "id": 11
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<p>﴿ٱلۡأَشۡقَى﴾: الَّذِي لا يَخْشَى رَبَّهُ، وَشَقِيَ فِي عِلْمِ اللهِ.</p>"
        },
        "12": {
            "verses": {
                "87:12": {
                    "id": 12
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿يَصۡلَى﴾: يُقاسِي حرَّها.</h2>\n<h2>﴿ٱلنَّارَ ٱلۡكُبۡرَىٰ﴾: نارَ جَهَنَّمَ العُظْمَى.</h2>"
        },
        "13": {
            "verses": {
                "87:13": {
                    "id": 13
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿لَا يَمُوتُ فِيهَا﴾: فَيَسْتَرِيحَ.</h2>\n<h2>﴿وَلَا يَحۡيَىٰ﴾: حياةً تَنفَعُهُ.</h2>"
        },
        "14": {
            "verses": {
                "87:14": {
                    "id": 14
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
            "language_id": 38,
            "slug": "ar_muyassarwm",
            "translated_name": {
                "name": "Tafsir Ar Muyassarwm",
                "language_name": "english"
            },
            "text": "<h2>﴿أَفۡلَحَ﴾: فَازَ.</h2>\n<h2>﴿تَزَكَّىٰ﴾: طَهَّرَ نَفسَهُ مِنَ الأخْلَاقِ السَّيِّئةِ.</h2>"
        },
        "15": {
            "verses": {
                "87:15": {
                    "id": 15
                }
            },
            "resource_id": 109,
            "resource_name": "Tafsir Ar Muyassarwm",
