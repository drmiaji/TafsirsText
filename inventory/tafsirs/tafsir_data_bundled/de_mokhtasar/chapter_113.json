        "1": {
            "verses": {
                "113:1": {
                    "id": 1
                }
            },
            "resource_id": 123,
            "resource_name": "Tafsir De Mokhtasar",
            "language_id": 38,
            "slug": "de_mokhtasar",
            "translated_name": {
                "name": "Tafsir De Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Sag - o Gesandter -: „Ich halte fest an dem Herrn des Morgens, und suche Schutz bei Ihm.</p>"
        },
        "2": {
            "verses": {
                "113:2": {
                    "id": 2
                }
            },
            "resource_id": 123,
            "resource_name": "Tafsir De Mokhtasar",
            "language_id": 38,
            "slug": "de_mokhtasar",
            "translated_name": {
                "name": "Tafsir De Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>(Und ich suche Schutz) vor dem Übel der Geschöpfe, die einen schaden.</p>"
        },
        "3": {
            "verses": {
                "113:3": {
                    "id": 3
                }
            },
            "resource_id": 123,
            "resource_name": "Tafsir De Mokhtasar",
            "language_id": 38,
            "slug": "de_mokhtasar",
            "translated_name": {
                "name": "Tafsir De Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Ich halte an Allah fest, gegen alle bösen Dinge, die in der Nacht erscheinen, wie Tiere und Einbrecher.</p>"
        },
        "4": {
            "verses": {
                "113:4": {
                    "id": 4
                }
            },
            "resource_id": 123,
            "resource_name": "Tafsir De Mokhtasar",
            "language_id": 38,
            "slug": "de_mokhtasar",
            "translated_name": {
                "name": "Tafsir De Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Und ich halte an Allah fest, gegen das Böse der Zauberinnen, die in Knoten pusten.</p>"
        },
        "5": {
            "verses": {
                "113:5": {
                    "id": 5
                }
            },
            "resource_id": 123,
            "resource_name": "Tafsir De Mokhtasar",
            "language_id": 38,
            "slug": "de_mokhtasar",
            "translated_name": {
                "name": "Tafsir De Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Und ich halte an Allah fest, gegen das Übel eines Neiders, wenn er das tut, was ihn zu seinem Neid bewegt.“</p>"
        }
    }
}