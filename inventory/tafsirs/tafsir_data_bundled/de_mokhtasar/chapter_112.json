            "resource_id": 123,
            "resource_name": "Tafsir De Mokhtasar",
            "language_id": 38,
            "slug": "de_mokhtasar",
            "translated_name": {
                "name": "Tafsir De Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Sag - o Gesandter -: „Er ist Allah, Dem die alleinige Göttlichkeit zusteht, und sonst keinem außer Ihm.</p>"
        },
        "2": {
            "verses": {
                "112:2": {
                    "id": 2
                }
            },
            "resource_id": 123,
            "resource_name": "Tafsir De Mokhtasar",
            "language_id": 38,
            "slug": "de_mokhtasar",
            "translated_name": {
                "name": "Tafsir De Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Er ist Der Herr, Der die höchste Form der Vollkommenheit und Schönheit innehat. Derjenige, den alle Geschöpfe aufsuchen.</p>"
        },
        "3": {
            "verses": {
                "112:3": {
                    "id": 3
                }
            },
            "resource_id": 123,
            "resource_name": "Tafsir De Mokhtasar",
            "language_id": 38,
            "slug": "de_mokhtasar",
            "translated_name": {
                "name": "Tafsir De Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Er hat niemanden gezeugt und wurde nie gezeugt. Denn Er - gepriesen sei Er - hat weder Kind noch ein Elternteil.</p>"
        },
        "4": {
            "verses": {
                "112:4": {
                    "id": 4
                }
            },
            "resource_id": 123,
            "resource_name": "Tafsir De Mokhtasar",
            "language_id": 38,
            "slug": "de_mokhtasar",
            "translated_name": {
                "name": "Tafsir De Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>Keiner unter Seiner Schöpfung ist Ihm gleich.“</h2>"
        }
    }
}