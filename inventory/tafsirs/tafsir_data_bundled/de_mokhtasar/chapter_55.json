            "slug": "de_mokhtasar",
            "translated_name": {
                "name": "Tafsir De Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Welche der vielen Wohltaten Allahs an euch - o ihr Gesellschaft der Jinn und der Menschen - wollt ihr beide denn verleugnen?!</p>"
        },
        "50": {
            "verses": {
                "55:50": {
                    "id": 50
                }
            },
            "resource_id": 123,
            "resource_name": "Tafsir De Mokhtasar",
            "language_id": 38,
            "slug": "de_mokhtasar",
            "translated_name": {
                "name": "Tafsir De Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>In diesen beiden Paradiesgärten gibt es zwei Quellen, aus denen Wasser fließt.</p>"
        },
        "51": {
            "verses": {
                "55:51": {
                    "id": 51
                }
            },
            "resource_id": 123,
            "resource_name": "Tafsir De Mokhtasar",
