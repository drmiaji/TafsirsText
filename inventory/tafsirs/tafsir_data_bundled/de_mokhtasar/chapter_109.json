            "translated_name": {
                "name": "Tafsir De Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Weder heute noch in Zukunft werde ich das anbeten, was ihr an Götzen anbetet.</p>"
        },
        "3": {
            "verses": {
                "109:3": {
                    "id": 3
                }
            },
            "resource_id": 123,
            "resource_name": "Tafsir De Mokhtasar",
            "language_id": 38,
            "slug": "de_mokhtasar",
            "translated_name": {
                "name": "Tafsir De Mokhtasar",
                "language_name": "english"
            },
            "text": "<h2>Und ihr werdet nicht anbeten, Wen ich anbete; Allah allein!</h2>"
        },
