{
    "chapter": 101,
    "verses": {
        "1": {
            "verses": {
                "101:1": {
                    "id": 1
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿الْقَارِعَةُ﴾ من أسماء يوم القيامة، سميت بذلك، لأنها تقرع الناس وتزعجهم بأهوالها، ولهذا عظم أمرها وفخمه.</p>"
        },
        "2": {
            "verses": {
                "101:2": {
                    "id": 2
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>مَا الْقَارِعَةُ</h2>"
        },
        "3": {
            "verses": {
                "101:3": {
                    "id": 3
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>وَمَا أَدْرَاكَ مَا الْقَارِعَةُ</h2>"
        },
        "4": {
            "verses": {
                "101:4": {
                    "id": 4
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿يَوْمَ يَكُونُ النَّاسُ﴾ من شدة الفزع والهول، ﴿كَالْفَرَاشِ الْمَبْثُوث﴾ أي: كالجراد المنتشر، الذي يموج بعضه في بعض، والفراش: هي الحيوانات التي تكون في الليل، يموج بعضها ببعض لا تدري أين توجه، فإذا أوقد لها نار تهافتت إليها لضعف إدراكها، فهذه حال الناس أهل العقول،</p>"
        },
        "5": {
            "verses": {
                "101:5": {
                    "id": 5
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>وأما الجبال الصم الصلاب، فتكون ﴿كَالْعِهْنِ الْمَنْفُوشِ﴾ أي: كالصوف المنفوش، الذي بقي ضعيفًا جدًا، تطير به أدنى ريح، قال تعالى: ﴿وَتَرَى الْجِبَالَ تَحْسَبُهَا جَامِدَةً وَهِيَ تَمُرُّ مَرَّ السَّحَابِ﴾ ثم بعد ذلك، تكون هباء منثورًا، فتضمحل ولا يبقى منها شيء يشاهد، فحينئذ تنصب الموازين، وينقسم الناس قسمين: سعداء وأشقياء،</p>"
        },
        "6": {
            "verses": {
                "101:6": {
                    "id": 6
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿فَأَمَّا مَنْ ثَقُلَتْ مَوَازِينُهُ﴾ أي: رجحت حسناته على سيئاته</p>"
        },
        "7": {
            "verses": {
                "101:7": {
                    "id": 7
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>﴿فَهُوَ فِي عِيشَةٍ رَاضِيَةٍ﴾ في جنات النعيم.</h2>"
        },
        "8": {
            "verses": {
                "101:8": {
                    "id": 8
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَمَّا مَنْ خَفَّتْ مَوَازِينُهُ﴾ بأن لم تكن له حسنات تقاوم سيئاته.</p>"
        },
        "9": {
            "verses": {
                "101:9": {
                    "id": 9
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿فَأُمُّهُ هَاوِيَةٌ﴾ أي: مأواه ومسكنه النار، التي من أسمائها الهاوية، تكون له بمنزلة الأم الملازمة كما قال تعالى: ﴿إِنَّ عَذَابَهَا كَانَ غَرَامًا﴾.</p>\n<p>وقيل: إن معنى ذلك، فأم دماغه هاوية في النار، أي: يلقى في النار على رأسه.</p>"
        },
        "10": {
            "verses": {
                "101:10": {
                    "id": 10
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَا أَدْرَاكَ مَاهِيَهْ﴾ وهذا تعظيم لأمرها،</h2>"
        },
        "11": {
            "verses": {
                "101:11": {
                    "id": 11
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿نَارٌ حَامِيَةٌ﴾ أي: شديدة الحرارة، قد زادت حرارتها على حرارة نار الدنيا سبعين ضعفًا. نستجير بالله منها.</p>"
        }
    }
}