        "4": {
            "verses": {
                "78:4": {
                    "id": 4
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>5677</p>"
        },
        "5": {
            "verses": {
                "78:5": {
                    "id": 5
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>أي: عن أيِّ شيءٍ يتساءل المكذِّبون بآيات الله؟ ثم بيَّن ما يتساءلون عنه فقال: ﴿عَنِ النَّبَإِ العَظيمِ ۝ الّذي هُم فيهِ مُختَلِفونَ﴾ أي: عن الخبر العظيم الذي طال فيه نزاعُهم، وانتشر فيه خلافُهم على وجه التّكذيب والاستبعاد، وهو النبأ الذي لا يقبل الشكَّ ولا يدخُلُه الريبُ، ولكن المكذِّبون بلقاء ربهم لا يؤمنون، ولو جاءتهم كلُّ آيةٍ حتى يروا العذاب الأليم، ولهذا قال: ﴿كَلّا سَيَعلَمونَ ثُمَّ كَلّا سَيَعلَمونَ﴾ أي: سيعلمون إذا نزل بهم العذاب ما كانوا به يكذبون حين ﴿يُدَعُّون إلى نار جَهَنَّمَ دَعًّا﴾، ويقال لهم: ﴿هَذِهِ النّارُ الَّتي كُنتُم بِها تُكَذِّبونَ﴾.</p>"
        },
        "6": {
            "verses": {
                "78:6": {
                    "id": 6
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>أي: أما أنعمنا عليكم بنعم جليلة، فجعلنا لكم ﴿الْأَرْضَ مِهَادًا﴾ أي: ممهدة مهيأة لكم ولمصالحكم، من الحروث والمساكن والسبل.</p>"
        },
        "7": {
            "verses": {
                "78:7": {
                    "id": 7
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>﴿وَالْجِبَالَ أَوْتَادًا﴾ تمسك الأرض لئلا تضطرب بكم وتميد.</h2>"
        },
        "8": {
            "verses": {
                "78:8": {
                    "id": 8
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَخَلَقْنَاكُمْ أَزْوَاجًا﴾ أي: ذكورا وإناثا من جنس واحد، ليسكن كل منهما إلى الآخر، فتكون المودة والرحمة، وتنشأ عنهما الذرية، وفي ضمن هذا الامتنان، بلذة المنكح.</p>"
        },
        "9": {
            "verses": {
                "78:9": {
                    "id": 9
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَجَعَلْنَا نَوْمَكُمْ سُبَاتًا﴾ أي: راحة لكم، وقطعا لأشغالكم، التي متى تمادت بكم أضرت بأبدانكم،</p>"
        },
        "10": {
            "verses": {
                "78:10": {
                    "id": 10
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>فجعل الله الليل والنوم يغشى الناس لتنقطع حركاتهم الضارة، وتحصل راحتهم النافعة.</p>"
        },
        "11": {
            "verses": {
                "78:11": {
                    "id": 11
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>وَجَعَلْنَا النَّهَارَ مَعَاشًا</h2>"
        },
        "12": {
            "verses": {
                "78:12": {
                    "id": 12
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَبَنَيْنَا فَوْقَكُمْ سَبْعًا شِدَادًا﴾ أي: سبع سموات، في غاية القوة، والصلابة والشدة، وقد أمسكها الله بقدرته، وجعلها سقفا للأرض، فيها عدة منافع لهم، ولهذا ذكر من منافعها الشمس فقال: ﴿وَجَعَلْنَا سِرَاجًا وَهَّاجًا﴾</p>"
        },
        "13": {
            "verses": {
                "78:13": {
                    "id": 13
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>نبه بالسراج على النعمة بنورها، الذي صار كالضرورة للخلق، وبالوهاج الذي فيه الحرارة على حرارتها وما فيها من المصالح</p>"
        },
        "14": {
            "verses": {
                "78:14": {
                    "id": 14
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَنْزَلْنَا مِنَ الْمُعْصِرَاتِ﴾ أي: السحاب ﴿مَاءً ثَجَّاجًا﴾ أي: كثيرا جدا.</p>"
        },
        "15": {
            "verses": {
                "78:15": {
                    "id": 15
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿لِنُخْرِجَ بِهِ حَبًّا﴾ من بر وشعير وذرة وأرز، وغير ذلك مما يأكله الآدميون.</p>\n<p>﴿وَنَبَاتًا﴾ يشمل سائر النبات، الذي جعله الله قوتا لمواشيهم.</p>"
        },
        "16": {
            "verses": {
                "78:16": {
                    "id": 16
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَجَنَّاتٍ أَلْفَافًا﴾ أي: بساتين ملتفة، فيها من جميع أصناف الفواكه اللذيذة.</p>\n<p>فالذي أنعم عليكم بهذه النعم العظيمة ، التي لا يقدر قدرها، ولا يحصى عددها، كيف [تكفرون به و] تكذبون ما أخبركم به من البعث والنشور؟! أم كيف تستعينون بنعمه على معاصيه وتجحدونها؟\"</p>"
        },
        "17": {
            "verses": {
                "78:17": {
                    "id": 17
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>ذكر تعالى ما يكون في يوم القيامة الذي يتساءل عنه المكذبون، ويجحده المعاندون، أنه يوم عظيم، وأن الله جعله ﴿مِيقَاتًا﴾ للخلق.</p>"
        },
        "18": {
            "verses": {
                "78:18": {
                    "id": 18
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿يُنْفَخُ فِي الصُّورِ فَتَأْتُونَ أَفْوَاجًا﴾ ويجري فيه من الزعازع والقلاقل ما يشيب له الوليد، وتنزعج له القلوب،</p>"
        },
        "19": {
            "verses": {
                "78:19": {
                    "id": 19
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>5692</p>"
        },
        "20": {
            "verses": {
                "78:20": {
                    "id": 20
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>فتسير الجبال حتى تكون كالهباء المبثوث، وتنشقّ السماء حتى تكون أبوابًا، ويفصل الله بين الخلائق بحكمه الذي لا يجور.</p>"
        },
        "21": {
            "verses": {
                "78:21": {
                    "id": 21
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>5694</p>"
        },
        "22": {
            "verses": {
                "78:22": {
                    "id": 22
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>وتوقد نار جهنم التي أرصدها الله وأعدها للطاغين، وجعلها مثوى لهم ومآبًا،</p>"
        },
        "23": {
            "verses": {
                "78:23": {
                    "id": 23
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>وأنهم يلبثون فيها أحقابًا كثيرة، والحقبُ على ما قاله كثير من المفسرين: ثمانون سنة.</p>"
        },
        "24": {
            "verses": {
                "78:24": {
                    "id": 24
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>وهم إذا وردوها ﴿لَا يَذُوقُونَ فِيهَا بَرْدًا وَلَا شَرَابًا﴾ أي: لا ما يبرد جلودهم، ولا ما يدفع ظمأهم.</p>"
        },
        "25": {
            "verses": {
                "78:25": {
                    "id": 25
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿إِلَّا حَمِيمًا﴾ أي: ماء حارا، يشوي وجوههم، ويقطع أمعاءهم، ﴿وَغَسَّاقًا﴾ وهو: صديد أهل النار، الذي هو في غاية النتن، وكراهة المذاق،</p>"
        },
        "26": {
            "verses": {
                "78:26": {
                    "id": 26
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>استحقوا هذه العقوبات الفظيعة جزاء لهم ووفاقا على ما عملوا من الأعمال الموصلة إليها، لم يظلمهم الله، ولكن ظلموا أنفسهم،</p>"
        },
        "27": {
            "verses": {
                "78:27": {
                    "id": 27
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>وذكر أعمالهم، التي استحقوا بها هذا الجزاء، فقال: ﴿إِنَّهُمْ كَانُوا لَا يَرْجُونَ حِسَابًا﴾ أي: لا يؤمنون بالبعث، ولا أن الله يجازي الخلق بالخير والشر، فلذلك أهملوا العمل للآخرة.</p>"
        },
        "28": {
            "verses": {
                "78:28": {
                    "id": 28
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَكَذَّبُوا بِآيَاتِنَا كِذَّابًا﴾ أي: كذبوا بها تكذيبا واضحا صريحا وجاءتهم البينات فعاندوها.</p>"
        },
        "29": {
            "verses": {
                "78:29": {
                    "id": 29
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَكُلَّ شَيْءٍ﴾ من قليل وكثير، وخير وشر ﴿أَحْصَيْنَاهُ كِتَابًا﴾ أي: كتبناه في اللوح المحفوظ، فلا يخشى المجرمون أنا عذبناهم بذنوب لم يعملوها، ولا يحسبوا أنه يضيع من أعمالهم شيء، أو ينسى منها مثقال ذرة، كما قال تعالى: ﴿وَوُضِعَ الْكِتَابُ فَتَرَى الْمُجْرِمِينَ مُشْفِقِينَ مِمَّا فِيهِ وَيَقُولُونَ يَا وَيْلَتَنَا مَالِ هَذَا الْكِتَابِ لَا يُغَادِرُ صَغِيرَةً وَلَا كَبِيرَةً إِلَّا أَحْصَاهَا وَوَجَدُوا مَا عَمِلُوا حَاضِرًا وَلَا يَظْلِمُ رَبُّكَ أَحَدًا﴾</p>"
        },
        "30": {
            "verses": {
                "78:30": {
                    "id": 30
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿فَذُوقُوا﴾ أيها المكذبون هذا العذاب الأليم والخزي الدائم ﴿فَلَنْ نَزِيدَكُمْ إِلَّا عَذَابًا﴾ وكل وقت وحين يزداد عذابهم [وهذه الآية أشد الآيات في شدة عذاب أهل النار أجارنا الله منها].</p>"
        },
        "31": {
            "verses": {
                "78:31": {
                    "id": 31
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>لما ذكر حال المجرمين ذكر مآل المتقين فقال: ﴿إِنَّ لِلْمُتَّقِينَ مَفَازًا﴾ أي: الذين اتقوا سخط ربهم، بالتمسك بطاعته، والانكفاف عما يكرهه فلهم مفاز ومنجي، وبعد عن النار.</p>"
        },
        "32": {
            "verses": {
                "78:32": {
                    "id": 32
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>وفي ذلك المفاز لهم ﴿حَدَائِقَ﴾ وهي البساتين الجامعة لأصناف الأشجار الزاهية، في الثمار التي تتفجر بين خلالها الأنهار، وخص الأعناب لشرفها وكثرتها في تلك الحدائق.</p>"
        },
        "33": {
            "verses": {
                "78:33": {
                    "id": 33
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>ولهم فيها زوجات على مطالب النفوس ﴿كَوَاعِبَ﴾ وهي: النواهد اللاتي لم تتكسر ثديهن من شبابهن، وقوتهن ونضارتهن .</p>\n<p>﴿والأَتْرَاب﴾ اللاتي على سن واحد متقارب، ومن عادة الأتراب أن يكن متآلفات متعاشرات، وذلك السن الذي هن فيه ثلاث وثلاثون سنة، في أعدل سن الشباب .</p>"
        },
        "34": {
            "verses": {
                "78:34": {
                    "id": 34
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>﴿وَكَأْسًا دِهَاقًا﴾ أي: مملوءة من رحيق، لذة للشاربين،</h2>"
        },
        "35": {
            "verses": {
                "78:35": {
                    "id": 35
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿لَا يَسْمَعُونَ فِيهَا لَغْوًا﴾ أي: كلاما لا فائدة فيه ﴿وَلَا كِذَّابًا﴾ أي: إثما.</p>\n<p>كما قال تعالى: ﴿لَا يَسْمَعُونَ فِيهَا لَغْوًا وَلَا تَأْثِيمًا إِلَّا قِيلًا سَلَامًا سَلَامًا﴾</p>"
        },
        "36": {
            "verses": {
                "78:36": {
                    "id": 36
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>وإنما أعطاهم الله هذا الثواب الجزيل [من فضله وإحسانه]. ﴿جَزَاءً مِنْ رَبِّكَ﴾ لهم ﴿عَطَاءً حِسَابًا﴾ أي: بسبب أعمالهم التي وفقهم الله لها، وجعلها ثمنا لجنته ونعيمها .</p>"
        },
        "37": {
            "verses": {
                "78:37": {
                    "id": 37
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>أي: الذي أعطاهم هذه العطايا هو ربهم ﴿رَبِّ السَّمَاوَاتِ وَالْأَرْضِ﴾ الذي خلقها ودبرها ﴿الرَّحْمَنِ﴾ الذي رحمته وسعت كل شيء، فرباهم ورحمهم، ولطف بهم، حتى أدركوا ما أدركوا.</p>\n<p>ثم ذكر عظمته وملكه العظيم يوم القيامة، وأن جميع الخلق كلهم ذلك اليوم ساكتون لا يتكلمون و ﴿لَا يَمْلِكُونَ مِنْهُ خِطَابًا﴾ إلا من أذن له الرحمن وقال صوابا، فلا يتكلم أحد إلا بهذين الشرطين: أن يأذن الله له في الكلام، وأن يكون ما تكلم به صوابا، لأن ﴿ذَلِكَ الْيَوْمُ﴾ هو ﴿الْحَقُّ﴾ الذي لا يروج فيه الباطل، ولا ينفع فيه الكذب</p>"
        },
        "38": {
            "verses": {
                "78:38": {
                    "id": 38
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>وفي ذلك اليوم ﴿يَقُومُ الرُّوحُ﴾ وهو جبريل عليه السلام، الذي هو أشرف الملائكة ﴿وَالْمَلَائِكَةِ﴾ [أيضا يقوم الجميع] ﴿صَفًّا﴾ خاضعين لله ﴿لَا يَتَكَلَّمُونَ﴾ إلا بما أذن لهم الله به .</p>"
        },
        "39": {
            "verses": {
                "78:39": {
                    "id": 39
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>فلما رغب ورهب، وبشر وأنذر، قال: ﴿فَمَنْ شَاءَ اتَّخَذَ إِلَى رَبِّهِ مَآبًا﴾ أي: عملا، وقدم صدق يرجع إليه يوم القيامة.</p>"
        },
        "40": {
            "verses": {
                "78:40": {
                    "id": 40
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّا أَنْذَرْنَاكُمْ عَذَابًا قَرِيبًا﴾ لأنه قد أزف مقبلا، وكل ما هو آت فهو قريب.</p>\n<p>﴿يَوْمَ يَنْظُرُ الْمَرْءُ مَا قَدَّمَتْ يَدَاهُ﴾ أي: هذا الذي يهمه ويفزع إليه، فلينظر في هذه الدنيا إليه ، كما قال تعالى: ﴿يَا أَيُّهَا الَّذِينَ آمَنُوا اتَّقُوا اللهَ وَلْتَنْظُرْ نَفْسٌ مَا قَدَّمَتْ لِغَدٍ وَاتَّقُوا اللهَ إِنَّ اللهَ خَبِيرٌ بِمَا تَعْمَلُونَ﴾ الآيات.</p>\n<p>فإن وجد خيرا فليحمد الله، وإن وجد غير ذلك فلا يلومن إلا نفسه، ولهذا كان الكفار يتمنون الموت من شدة الحسرة والندم.</p>\n<h2>نسأل الله أن يعافينا من الكفر والشر كله، إنه جواد كريم.</h2>\n<h2>تم تفسير سورة عم، والحمد لله رب العالمين</h2>"
        }
    }
}