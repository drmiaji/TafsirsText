{
    "chapter": 104,
    "verses": {
        "1": {
            "verses": {
                "104:1": {
                    "id": 1
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَيْلٌ﴾ أي: وعيد، ووبال، وشدة عذاب ﴿لِكُلِّ هُمَزَةٍ لُمَزَةٍ﴾ الذي يهمز الناس بفعله، ويلمزهم بقوله، فالهماز: الذي يعيب الناس، ويطعن عليهم بالإشارة والفعل، واللماز: الذي يعيبهم بقوله.</p>"
        },
        "2": {
            "verses": {
                "104:2": {
                    "id": 2
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>ومن صفة هذا الهماز اللماز، أنه لا هم له سوى جمع المال وتعديده والغبطة به، وليس له رغبة في إنفاقه في طرق الخيرات وصلة الأرحام، ونحو ذلك،</p>"
        },
        "3": {
            "verses": {
                "104:3": {
                    "id": 3
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿يَحْسَبُ﴾ بجهله ﴿أَنَّ مَالَهُ أَخْلَدَهُ﴾ في الدنيا، فلذلك كان كده وسعيه كله في تنمية ماله، الذي يظن أنه ينمي عمره، ولم يدر أن البخل يقصف الأعمار، ويخرب الديار، وأن البر يزيد في العمر.</p>"
        },
        "4": {
            "verses": {
                "104:4": {
                    "id": 4
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>﴿كَلَّا لَيُنْبَذَنَّ﴾ أي: ليطرحن ﴿فِي الْحُطَمَةِ﴾</h2>"
        },
        "5": {
            "verses": {
                "104:5": {
                    "id": 5
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَا أَدْرَاكَ مَا الْحُطَمَةُ﴾ تعظيم لها وتهويل لشأنها.</h2>"
        },
        "6": {
            "verses": {
                "104:6": {
                    "id": 6
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>﴿نَارُ اللهِ الْمُوقَدَةُ﴾ التي وقودها الناس والحجارة</h2>"
        },
        "7": {
            "verses": {
                "104:7": {
                    "id": 7
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿الَّتِي﴾ من شدتها ﴿تَطَّلِعُ عَلَى الْأَفْئِدَةِ﴾ أي: تنفذ من الأجسام إلى القلوب.</p>"
        },
        "8": {
            "verses": {
                "104:8": {
                    "id": 8
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>ومع هذه الحرارة البليغة هم محبوسون فيها، قد أيسوا من الخروج منها، ولهذا قال: ﴿إِنَّهَا عَلَيْهِمْ مُؤْصَدَةٌ﴾ أي: مغلقة</p>"
        },
        "9": {
            "verses": {
                "104:9": {
                    "id": 9
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿فِي عَمَدٍ﴾ من خلف الأبواب ﴿مُمَدَّدَةٍ﴾ لئلا يخرجوا منها ﴿كُلَّمَا أَرَادُوا أَنْ يَخْرُجُوا مِنْهَا أُعِيدُوا فِيهَا﴾.</p>\n<h2>[نعوذ بالله من ذلك، ونسأله العفو والعافية].</h2>"
        }
    }
}