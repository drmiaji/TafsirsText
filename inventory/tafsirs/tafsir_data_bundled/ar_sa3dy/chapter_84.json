{
    "chapter": 84,
    "verses": {
        "1": {
            "verses": {
                "84:1": {
                    "id": 1
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>يقول تعالى مبينًا لما يكون في يوم القيامة من تغير الأجرام العظام: ﴿إِذَا السَّمَاءُ انْشَقَّتْ﴾ أي: انفطرت وتمايز بعضها من بعض، وانتثرت نجومها، وخسف بشمسها وقمرها.</p>"
        },
        "2": {
            "verses": {
                "84:2": {
                    "id": 2
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَذِنَتْ لِرَبِّهَا﴾ أي: استمعت لأمره، وألقت سمعها، وأصاخت لخطابه، وحق لها ذلك، فإنها مسخرة مدبرة تحت مسخر ملك عظيم، لا يعصى أمره، ولا يخالف حكمه.</p>"
        },
        "3": {
            "verses": {
                "84:3": {
                    "id": 3
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِذَا الْأَرْضُ مُدَّتْ﴾ أي: رجفت وارتجت، ونسفت عليها جبالها، ودك ما عليها من بناء ومعلم، فسويت، ومدها الله تعالى مد الأديم، حتى صارت واسعة جدًا، تسع أهل الموقف على كثرتهم، فتصير قاعًا صفصفًا لا ترى فيها عوجًا ولا أمتا.</p>"
        },
        "4": {
            "verses": {
                "84:4": {
                    "id": 4
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>﴿وَأَلْقَتْ مَا فِيهَا﴾ من الأموات والكنوز.</h2>\n<p>﴿وَتَخَلَّتْ﴾ منهم، فإنه ينفخ في الصور، فتخرج الأموات من الأجداث إلى وجه الأرض، وتخرج الأرض كنوزها، حتى تكون كالأسطوان العظيم، يشاهده الخلق، ويتحسرون على ما هم فيه يتنافسون.</p>"
        },
        "5": {
            "verses": {
                "84:5": {
                    "id": 5
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>﴿وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ﴾</h2>"
        },
        "6": {
            "verses": {
                "84:6": {
                    "id": 6
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿يَا أَيُّهَاالْإِنْسَانُ إِنَّكَ كَادِحٌ إِلَى رَبِّكَ كَدْحًا فَمُلَاقِيهِ﴾ أي: إنك ساع إلى الله، وعامل بأوامره ونواهيه، ومتقرب إليه إما بالخير وإما بالشر، ثم تلاقي الله يوم القيامة، فلا تعدم منه جزاء بالفضل إن كنت سعيدًا، أو بالعدل إن كنت شقيًا.</p>"
        },
        "7": {
            "verses": {
                "84:7": {
                    "id": 7
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>ولهذا ذكر تفضيل الجزاء، فقال: ﴿فَأَمَّا مَنْ أُوتِيَ كِتَابَهُ بِيَمِينِهِ﴾ وهم أهل السعادة.</p>"
        },
        "8": {
            "verses": {
                "84:8": {
                    "id": 8
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿فَسَوْفَ يُحَاسَبُ حِسَابًا يَسِيرًا﴾ وهو العرض اليسير على الله، فيقرره الله بذنوبه، حتى إذا ظن العبد أنه قد هلك، قال الله [تعالى] له: \" إني قد سترتها عليك في الدنيا، فأنا أسترها لك اليوم \".</p>"
        },
        "9": {
            "verses": {
                "84:9": {
                    "id": 9
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَيَنْقَلِبُ إِلَى أَهْلِهِ﴾ في الجنة ﴿مَسْرُورًا﴾ لأنه نجا من العذاب وفاز بالثواب.</p>"
        },
        "10": {
            "verses": {
                "84:10": {
                    "id": 10
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَمَّا مَنْ أُوتِيَ كِتَابَهُ وَرَاءَ ظَهْرِهِ﴾ أي: بشماله من خلفه.</p>"
        },
        "11": {
            "verses": {
                "84:11": {
                    "id": 11
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿فَسَوْفَ يَدْعُو ثُبُورًا﴾ من الخزي والفضيحة، وما يجد في كتابه من الأعمال التي قدمها ولم يتب منها.</p>"
        },
        "12": {
            "verses": {
                "84:12": {
                    "id": 12
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَيَصْلَى سَعِيرًا﴾ أي: تحيط به السعير من كل جانب، ويقلب على عذابها، وذلك لأنه في الدنيا</p>"
        },
        "13": {
            "verses": {
                "84:13": {
                    "id": 13
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿كَانَ فِي أَهْلِهِ مَسْرُورًا﴾ لا يخطر البعث على باله، وقد أساء.</p>"
        },
        "14": {
            "verses": {
                "84:14": {
                    "id": 14
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>ولم يظن أنه راجع إلى ربه وموقوف بين يديه.</h2>"
        },
        "15": {
            "verses": {
                "84:15": {
                    "id": 15
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿بَلَى إِنَّ رَبَّهُ كَانَ بِهِ بَصِيرًا﴾ فلا يحسن أن يتركه سدى، لا يؤمر ولا ينهى، ولا يثاب ولا يعاقب.</p>"
        },
        "16": {
            "verses": {
                "84:16": {
                    "id": 16
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>أقسم في هذا الموضع بآيات الليل، فأقسم بالشفق الذي هو بقية نور الشمس، الذي هو مفتتح الليل.</p>"
        },
        "17": {
            "verses": {
                "84:17": {
                    "id": 17
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَاللَّيْلِ وَمَا وَسَقَ﴾ أي: احتوى عليه من حيوانات وغيرها.</p>"
        },
        "18": {
            "verses": {
                "84:18": {
                    "id": 18
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَالْقَمَرِ إِذَا اتَّسَقَ﴾ أي: امتلأ نورًا بإبداره، وذلك أحسن ما يكون وأكثر منافع.</p>"
        },
        "19": {
            "verses": {
                "84:19": {
                    "id": 19
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>والمقسم عليه قوله: ﴿لَتَرْكَبُنَّ﴾ [أي:] أيها الناس ﴿طَبَقًا عَنْ طَبَقٍ﴾ أي: أطوارا متعددة وأحوالا متباينة، من النطفة إلى العلقة، إلى المضغة، إلى نفخ الروح، ثم يكون وليدًا وطفلًا، ثم مميزًا، ثم يجري عليه قلم التكليف، والأمر والنهي، ثم يموت بعد ذلك، ثم يبعث ويجازى بأعماله، فهذه الطبقات المختلفة الجارية على العبد، دالة على أن الله وحده هو المعبود، الموحد، المدبر لعباده بحكمته ورحمته، وأن العبد فقير عاجز، تحت تدبير العزيز الرحيم.</p>"
        },
        "20": {
            "verses": {
                "84:20": {
                    "id": 20
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>ومع هذا، فكثير من الناس لا يؤمنون.</h2>"
        },
        "21": {
            "verses": {
                "84:21": {
                    "id": 21
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِذَا قُرِئَ عَلَيْهِمُ الْقُرْآنُ لَا يَسْجُدُونَ﴾ أي: لا يخضعون للقرآن، ولا ينقادون لأوامره ونواهيه،</p>"
        },
        "22": {
            "verses": {
                "84:22": {
                    "id": 22
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿بَلِ الَّذِينَ كَفَرُوا يُكَذِّبُونَ﴾ أي: يعاندون الحق بعدما تبين، فلا يستغرب عدم إيمانهم وعدم انقيادهم للقرآن، فإن المكذب بالحق عنادًا، لا حيلة فيه.</p>"
        },
        "23": {
            "verses": {
                "84:23": {
                    "id": 23
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَاللهُ أَعْلَمُ بِمَا يُوعُونَ﴾ أي: بما يعملونه وينوونه سرًا، فالله يعلم سرهم وجهرهم، وسيجازيهم بأعمالهم.</p>"
        },
        "24": {
            "verses": {
                "84:24": {
                    "id": 24
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿فَبَشِّرْهُمْ بِعَذَابٍ أَلِيمٍ﴾ وسميت البشارة بشارة، لأنها تؤثر في البشرة سرورًا أو غمًا.</p>\n<h2>فهذه حال أكثر الناس، التكذيب بالقرآن، وعدم الإيمان [به].</h2>"
        },
        "25": {
            "verses": {
                "84:25": {
                    "id": 25
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>ومن الناس فريق هداهم الله، فآمنوا بالله، وقبلوا ما جاءتهم به الرسل، فآمنوا وعملوا الصالحات.</p>\n<p>فهؤلاء لهم أجر غير ممنون أي: غير مقطوع بل هو أجر دائم مما لا عين رأت، ولا أذن سمعت، ولا خطر على قلب بشر.</p>\n<h2>تم تفسير السورة ولله الحمد.</h2>"
        }
    }
}