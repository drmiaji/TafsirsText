{
    "chapter": 87,
    "verses": {
        "1": {
            "verses": {
                "87:1": {
                    "id": 1
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>يأمر تعالى بتسبيحه المتضمن لذكره وعبادته، والخضوع لجلاله، والاستكانة لعظمته، وأن يكون تسبيحا، يليق بعظمة الله تعالى، بأن تذكر أسماؤه الحسنى العالية على كل اسم بمعناها الحسن العظيم .</p>"
        },
        "2": {
            "verses": {
                "87:2": {
                    "id": 2
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>وتذكر أفعاله التي منها أنه خلق المخلوقات فسواها، أي: أتقنها وأحسن خلقها.</p>"
        },
        "3": {
            "verses": {
                "87:3": {
                    "id": 3
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَالَّذِي قَدَّرَ﴾ تقديرًا، تتبعه جميع المقدرات ﴿فَهَدَى﴾ إلى ذلك جميع المخلوقات.</p>"
        },
        "4": {
            "verses": {
                "87:4": {
                    "id": 4
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>وهذه الهداية العامة، التي مضمونها أنه هدى كل مخلوق لمصلحته، وتذكر فيها نعمه الدنيوية، ولهذا قال فيها: ﴿وَالَّذِي أَخْرَجَ الْمَرْعَى﴾ أي: أنزل من السماء ماء فأنبت به أنواع النبات والعشب الكثير، فرتع فيها الناس والبهائم وكل حيوان ، ثم بعد أن استكمل ما قدر له من الشباب، ألوى نباته، وصوح عشبه.</p>"
        },
        "5": {
            "verses": {
                "87:5": {
                    "id": 5
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿فَجَعَلَهُ غُثَاءً أَحْوَى﴾ أي: أسود أي: جعله هشيمًا رميمًا، ويذكر فيها نعمه الدينية.</p>"
        },
        "6": {
            "verses": {
                "87:6": {
                    "id": 6
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿سَنُقْرِئُكَ فَلَا تَنْسَى﴾ أي: سنحفظ ما أوحينا إليك من الكتاب، ونوعيه قلبك، فلا تنسى منه شيئًا، وهذه بشارة كبيرة من الله لعبده ورسوله محمد صلى الله عليه وسلم، أن الله سيعلمه علمًا لا ينساه.</p>"
        },
        "7": {
            "verses": {
                "87:7": {
                    "id": 7
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿إِلَّا مَا شَاءَ اللهُ﴾ مما اقتضت حكمته أن ينسيكه لمصلحة بالغة، ﴿إِنَّهُ يَعْلَمُ الْجَهْرَ وَمَا يَخْفَى﴾ ومن ذلك أنه يعلم ما يصلح عباده أي: فلذلك يشرع ما أراد، ويحكم بما يريد .</p>"
        },
        "8": {
            "verses": {
                "87:8": {
                    "id": 8
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَنُيَسِّرُكَ لِلْيُسْرَى﴾ وهذه أيضًا بشارة كبيرة ، أن الله ييسر رسوله صلى الله عليه وسلم لليسرى في جميع أموره، ويجعل شرعه ودينه يسرا .</p>"
        },
        "9": {
            "verses": {
                "87:9": {
                    "id": 9
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿فَذَكِّرْ﴾ بشرع الله وآياته ﴿إِنْ نَفَعَتِ الذِّكْرَى﴾ أي: ما دامت الذكرى مقبولة، والموعظة مسموعة، سواء حصل من الذكرى جميع المقصود أو بعضه.</p>\n<p>ومفهوم الآية أنه إن لم تنفع الذكرى، بأن كان التذكير يزيد في الشر، أو ينقص من الخير، لم تكن الذكرى مأمورًا بها، بل منهيًا عنها، فالذكرى ينقسم الناس فيها قسمين: منتفعون وغير منتفعين.</p>"
        },
        "10": {
            "verses": {
                "87:10": {
                    "id": 10
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>فأما المنتفعون، فقد ذكرهم بقوله: ﴿سَيَذَّكَّرُ مَنْ يَخْشَى﴾ الله تعالى، فإن خشية الله تعالى، وعلمه بأن سيجازيه على أعماله ، توجب للعبد الانكفاف عن المعاصي والسعي في الخيرات.</p>"
        },
        "11": {
            "verses": {
                "87:11": {
                    "id": 11
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>5960</p>"
        },
        "12": {
            "verses": {
                "87:12": {
                    "id": 12
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>وأما غير المنتفعين، فذكرهم بقوله: ﴿وَيَتَجَنَّبُهَا الْأَشْقَى الَّذِي يَصْلَى النَّارَ الْكُبْرَى﴾ وهي النار الموقدة، التي تطلع على الأفئدة.</p>"
        },
        "13": {
            "verses": {
                "87:13": {
                    "id": 13
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَا﴾ أي: يعذب عذابًا أليمًا، من غير راحة ولا استراحة، حتى إنهم يتمنون الموت فلا يحصل لهم، كما قال تعالى: ﴿لَا يُقْضَى عَلَيْهِمْ فَيَمُوتُوا وَلَا يُخَفَّفُ عَنْهُمْ مِنْ عَذَابِهَا﴾.</p>"
        },
        "14": {
            "verses": {
                "87:14": {
                    "id": 14
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿قَدْ أَفْلَحَ مَنْ تَزَكَّى﴾ أي: قد فاز وربح من طهر نفسه ونقاها من الشرك والظلم ومساوئ الأخلاق.</p>"
        },
        "15": {
            "verses": {
                "87:15": {
                    "id": 15
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَذَكَرَ اسْمَ رَبِّهِ فَصَلَّى﴾ أي: اتصف بذكر الله، وانصبغ به قلبه، فأوجب له ذلك العمل بما يرضي الله، خصوصًا الصلاة، التي هي ميزان الإيمان، فهذا معنى الآية الكريمة، وأما من فسر قوله ﴿تزكى﴾ بمعني أخرج زكاة الفطر، وذكر اسم ربه فصلى، أنه صلاة العيد، فإنه وإن كان داخلًا في اللفظ وبعض جزئياته، فليس هو المعنى وحده.</p>"
        },
        "16": {
            "verses": {
                "87:16": {
                    "id": 16
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿بَلْ تُؤْثِرُونَ الْحَيَاةَ الدُّنْيَا﴾ أي: تقدمونها على الآخرة، وتختارون نعيمها المنغص المكدر الزائل على الآخرة.</p>"
        },
        "17": {
            "verses": {
                "87:17": {
                    "id": 17
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَالْآخِرَةُ خَيْرٌ وَأَبْقَى﴾ وللآخرة خير من الدنيا في كل وصف مطلوب، وأبقى لكونها دار خلد وبقاء وصفاء، والدنيا دار فناء، فالمؤمن العاقل لا يختار الأردأ على الأجود، ولا يبيع لذة ساعة، بترحة الأبد، فحب الدنيا وإيثارها على الآخرة رأس كل خطيئة.</p>"
        },
        "18": {
            "verses": {
                "87:18": {
                    "id": 18
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّ هَذَا﴾ المذكور لكم في هذه السورة المباركة، من الأوامر الحسنة، والأخبار المستحسنة ﴿لَفِي الصُّحُفِ الْأُولَى﴾</p>"
        },
        "19": {
            "verses": {
                "87:19": {
                    "id": 19
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿صُحُفِ إِبْرَاهِيمَ وَمُوسَى﴾ اللذين هما أشرف المرسلين، سوى النبي محمد صلى الله وسلم عليه وسلم.</p>\n<p>فهذه أوامر في كل شريعة؛ لكونها عائدة إلى مصالح الدارين، وهي مصالح في كل زمان ومكان.</p>"
        }
    }
}