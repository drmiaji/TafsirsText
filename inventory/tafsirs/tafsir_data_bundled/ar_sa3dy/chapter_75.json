{
    "chapter": 75,
    "verses": {
        "1": {
            "verses": {
                "75:1": {
                    "id": 1
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>ليست ﴿لا﴾ [ها] هنا نافية، [ولا زائدة] وإنما أتي بها للاستفتاح والاهتمام بما بعدها، ولكثرة الإتيان بها مع اليمين، لا يستغرب الاستفتاح بها، وإن لم تكن في الأصل موضوعة للاستفتاح.</p>\n<p>فالمقسم به في هذا الموضع، هو المقسم عليه، وهو البعث بعد الموت، وقيام الناس من قبورهم، ثم وقوفهم ينتظرون ما يحكم به الرب عليهم.</p>"
        },
        "2": {
            "verses": {
                "75:2": {
                    "id": 2
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَلَا أُقْسِمُ بِالنَّفْسِ اللَّوَّامَةِ﴾ وهي جميع النفوس الخيرة والفاجرة، سميت ﴿لوامة﴾ لكثرة ترددها وتلومها وعدم ثبوتها على حالة من أحوالها، ولأنها عند الموت تلوم صاحبها على ما عملت ، بل نفس المؤمن تلوم صاحبها في الدنيا على ما حصل منه، من تفريط أو تقصير في حق من الحقوق، أو غفلة، فجمع بين الإقسام بالجزاء، وعلى الجزاء، وبين مستحق الجزاء.</p>"
        },
        "3": {
            "verses": {
                "75:3": {
                    "id": 3
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>ثم أخبر مع هذا، أن بعض المعاندين يكذب بيوم القيامة، فقال: ﴿أَيَحْسَبُ الْإِنْسَانُ أن لَّنْ نَجْمَعَ عِظَامَهُ﴾ بعد الموت، كما قال في الآية الأخرى: ﴿قَالَ مَنْ يُحْيِي الْعِظَامَ وَهِيَ رَمِيمٌ﴾ ؟ فاستبعد من جهله وعدوانه قدرة الله على خلق عظامه التي هي عماد البدن.</p>"
        },
        "4": {
            "verses": {
                "75:4": {
                    "id": 4
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>فرد عليه بقوله: ﴿بَلَى قَادِرِينَ عَلَى أَنْ نُسَوِّيَ بَنَانَهُ﴾ أي: أطراف أصابعه وعظامه، المستلزم ذلك لخلق جميع أجزاء البدن، لأنها إذا وجدت الأنامل والبنان، فقد تمت خلقة الجسد، وليس إنكاره لقدرة الله تعالى قصورا بالدليل الدال على ذلك، وإنما [وقع] ذلك منه أن قصده وإرادته أن يكذب بما أمامه من البعث. والفجور: الكذب مع التعمد.</p>"
        },
        "5": {
            "verses": {
                "75:5": {
                    "id": 5
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>وإنما [ وقع ] ذلك منه أن قصده وإرادته أن يكذب بما أمامه من البعث. والفجور: الكذب مع التعمد.</p>\n<h2>ثم ذكر أحوال القيامة فقال:</h2>"
        },
        "6": {
            "verses": {
                "75:6": {
                    "id": 6
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>5558</p>"
        },
        "7": {
            "verses": {
                "75:7": {
                    "id": 7
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>أي: إذا كانت القيامة برقت الأبصار من الهول العظيم، وشخصت فلا تطرف كما قال تعالى: ﴿إِنَّمَا يُؤَخِّرُهُمْ لِيَوْمٍ تَشْخَصُ فِيهِ الْأَبْصَارُ مُهْطِعِينَ مُقْنِعِي رُءُوسِهِمْ لَا يَرْتَدُّ إِلَيْهِمْ طَرْفُهُمْ وَأَفْئِدَتُهُمْ هَوَاءٌ﴾</p>"
        },
        "8": {
            "verses": {
                "75:8": {
                    "id": 8
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>﴿وَخَسَفَ الْقَمَرُ﴾ أي: ذهب نوره وسلطانه،</h2>"
        },
        "9": {
            "verses": {
                "75:9": {
                    "id": 9
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَجُمِعَ الشَّمْسُ وَالْقَمَرُ﴾ وهما لم يجتمعا منذ خلقهما الله تعالى، فيجمع الله بينهما يوم القيامة، ويخسف القمر، وتكور الشمس، ثم يقذفان في النار، ليرى العباد أنهما عبدان مسخران، وليرى من عبدهما أنهم كانوا كاذبين.</p>"
        },
        "10": {
            "verses": {
                "75:10": {
                    "id": 10
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿يَقُولُ الْإِنْسَانُ﴾ حين يرى تلك القلاقل المزعجات: ﴿أَيْنَ الْمَفَرُّ﴾ أي: أين الخلاص والفكاك مما طرقنا وأصابنا ?</p>"
        },
        "11": {
            "verses": {
                "75:11": {
                    "id": 11
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>﴿كَلَّا لَا وَزَرَ﴾ أي: لا ملجأ لأحد دون الله،</h2>"
        },
        "12": {
            "verses": {
                "75:12": {
                    "id": 12
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿إِلَى رَبِّكَ يَوْمَئِذٍ الْمُسْتَقَرُّ﴾ لسائر العباد فليس في إمكان أحد أن يستتر أو يهرب عن ذلك الموضع، بل لا بد من إيقافه ليجزى بعمله،</p>"
        },
        "13": {
            "verses": {
                "75:13": {
                    "id": 13
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿يُنَبَّأُ الْإِنْسَانُ يَوْمَئِذٍ بِمَا قَدَّمَ وَأَخَّرَ﴾ أي: بجميع عمله الحسن والسيء، في أول وقته وآخره، وينبأ بخبر لا ينكره.</p>"
        },
        "14": {
            "verses": {
                "75:14": {
                    "id": 14
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿بَلِ الْإِنْسَانُ عَلَى نَفْسِهِ بَصِيرَةٌ﴾ أي: شاهد ومحاسب،</p>"
        },
        "15": {
            "verses": {
                "75:15": {
                    "id": 15
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَلَوْ أَلْقَى مَعَاذِيرَهُ﴾ فإنها معاذير لا تقبل، ولا تقابل ما يقرر به العبد ، فيقر به، كما قال تعالى: ﴿اقْرَأْ كِتَابَكَ كَفَى بِنَفْسِكَ الْيَوْمَ عَلَيْكَ حَسِيبًا﴾.</p>\n<p>فالعبد وإن أنكر، أو اعتذر عما عمله، فإنكاره واعتذاره لا يفيدانه شيئا، لأنه يشهد عليه سمعه وبصره، وجميع جوارحه بما كان يعمل، ولأن استعتابه قد ذهب وقته وزال نفعه: ﴿فَيَوْمَئِذٍ لَا يَنْفَعُ الَّذِينَ ظَلَمُوا مَعْذِرَتُهُمْ وَلَا هُمْ يُسْتَعْتَبُونَ﴾</p>"
        },
        "16": {
            "verses": {
                "75:16": {
                    "id": 16
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>كان النبي صلى الله عليه وسلم إذا جاءه جبريل بالوحي، وشرع في تلاوته عليه، بادره النبي صلى الله عليه وسلم من الحرص قبل أن يفرغ، وتلاه مع تلاوة جبريل إياه، فنهاه الله عن هذا، وقال: ﴿وَلَا تَعْجَلْ بِالْقُرْآنِ مِنْ قَبْلِ أَنْ يُقْضَى إِلَيْكَ وَحْيُهُ﴾</p>\n<p>وقال هنا: ﴿لَا تُحَرِّكْ بِهِ لِسَانَكَ لِتَعْجَلَ بِهِ﴾ ثم ضمن له تعالى أنه لا بد أن يحفظه ويقرأه، ويجمعه الله في صدره،</p>"
        },
        "17": {
            "verses": {
                "75:17": {
                    "id": 17
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿إِنَّ عَلَيْنَا جَمْعَهُ وَقُرْآنَهُ﴾ فالحرص الذي في خاطرك، إنما الداعي له حذر الفوات والنسيان، فإذا ضمنه الله لك فلا موجب لذلك.</p>"
        },
        "18": {
            "verses": {
                "75:18": {
                    "id": 18
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿فَإِذَا قَرَأْنَاهُ فَاتَّبِعْ قُرْآنَهُ﴾ أي: إذا كمل جبريل قراءة ما أوحى الله إليك، فحينئذ اتبع ما قرأه وأقرأه.</p>"
        },
        "19": {
            "verses": {
                "75:19": {
                    "id": 19
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ إِنَّ عَلَيْنَا بَيَانَهُ﴾ أي: بيان معانيه، فوعده بحفظ لفظه وحفظ معانيه، وهذا أعلى ما يكون، فامتثل صلى الله عليه وسلم لأدب ربه، فكان إذا تلا عليه جبريل القرآن بعد هذا، أنصت له، فإذا فرغ قرأه.</p>\n<p>وفي هذه الآية أدب لأخذ العلم، أن لا يبادر المتعلم المعلم قبل أن يفرغ من المسألة التي شرع فيها، فإذا فرغ منها سأله عما أشكل عليه، وكذلك إذا كان في أول الكلام ما يوجب الرد أو الاستحسان، أن لا يبادر برده أو قبوله، حتى يفرغ من ذلك الكلام، ليتبين ما فيه من حق أو باطل، وليفهمه فهما يتمكن به من الكلام عليه، وفيها: أن النبي صلى الله عليه وسلم كما بين للأمة ألفاظ الوحي، فإنه قد بين لهم معانيه.</p>"
        },
        "20": {
            "verses": {
                "75:20": {
                    "id": 20
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>5572</p>"
        },
        "21": {
            "verses": {
                "75:21": {
                    "id": 21
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>أي: هذا الذي أوجب لكم الغفلة والإعراض عن وعظ الله وتذكيره أنكم ﴿تُحِبُّونَ الْعَاجِلَةَ﴾ وتسعون فيما يحصلها، وفي لذاتها وشهواتها، وتؤثرونها على الآخرة، فتذرون العمل لها، لأن الدنيا نعيمها ولذاتها عاجلة، والإنسان مولع بحب العاجل، والآخرة متأخر ما فيها من النعيم المقيم، فلذلك غفلتم عنها وتركتموها، كأنكم لم تخلقوا لها، وكأن هذه الدار هي دار القرار، التي تبذل فيها نفائس الأعمار، ويسعى لها آناء الليل والنهار، وبهذا انقلبت عليكم الحقيقة، وحصل من الخسار ما حصل. فلو آثرتم الآخرة على الدنيا، ونظرتم للعواقب نظر البصير العاقل لأنجحتم، وربحتم ربحا لا خسار معه، وفزتم فوزا لا شقاء يصحبه.</p>"
        },
        "22": {
            "verses": {
                "75:22": {
                    "id": 22
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>ثم ذكر ما يدعو إلى إيثار الآخرة، ببيان حال أهلها وتفاوتهم فيها، فقال في جزاء المؤثرين للآخرة على الدنيا: ﴿وُجُوهٌ يَوْمَئِذٍ نَاضِرَةٌ﴾ أي: حسنة بهية، لها رونق ونور، مما هم فيه من نعيم القلوب، وبهجة النفوس، ولذة الأرواح،</p>"
        },
        "23": {
            "verses": {
                "75:23": {
                    "id": 23
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿إِلَى رَبِّهَا نَاظِرَةٌ﴾ أي: تنظر إلى ربها على حسب مراتبهم: منهم من ينظره كل يوم بكرة وعشيا، ومنهم من ينظره كل جمعة مرة واحدة، فيتمتعون بالنظر إلى وجهه الكريم، وجماله الباهر، الذي ليس كمثله شيء، فإذا رأوه نسوا ما هم فيه من النعيم وحصل لهم من اللذة والسرور ما لا يمكن التعبير عنه، ونضرت وجوههم فازدادوا جمالا إلى جمالهم، فنسأل الله الكريم أن يجعلنا معهم.</p>"
        },
        "24": {
            "verses": {
                "75:24": {
                    "id": 24
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>وقال في المؤثرين العاجلة على الآجلة: ﴿وَوُجُوهٌ يَوْمَئِذٍ بَاسِرَةٌ﴾ أي: معبسة ومكدرة ، خاشعة ذليلة.</p>"
        },
        "25": {
            "verses": {
                "75:25": {
                    "id": 25
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿تَظُنُّ أَنْ يُفْعَلَ بِهَا فَاقِرَةٌ﴾ أي: عقوبة شديدة، وعذاب أليم، فلذلك تغيرت وجوههم وعبست.</p>"
        },
        "26": {
            "verses": {
                "75:26": {
                    "id": 26
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>يعظ تعالى عباده بذكر حال المحتضر عند السياق ، وأنه إذا بلغت روحه التراقي، وهي العظام المكتنفة لثغرة النحر، فحينئذ يشتد الكرب، ويطلب كل وسيلة وسبب، يظن أن يحصل به الشفاء والراحة،</p>"
        },
        "27": {
            "verses": {
                "75:27": {
                    "id": 27
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَقِيلَ مَنْ رَاقٍ﴾ أي: من يرقيه من الرقية لأنهم انقطعت آمالهم من الأسباب العادية، فلم يبق إلا الأسباب الإلهية . ولكن القضاء والقدر، إذا حتم وجاء فلا مرد له،</p>"
        },
        "28": {
            "verses": {
                "75:28": {
                    "id": 28
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>﴿وَظَنَّ أَنَّهُ الْفِرَاقُ﴾ للدنيا.</h2>"
        },
        "29": {
            "verses": {
                "75:29": {
                    "id": 29
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَالْتَفَّتِ السَّاقُ بِالسَّاقِ﴾ أي: اجتمعت الشدائد والتفت، وعظم الأمر وصعب الكرب، وأريد أن تخرج الروح التي ألفت البدن ولم تزل معه،</p>"
        },
        "30": {
            "verses": {
                "75:30": {
                    "id": 30
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>فتساق إلى الله تعالى، حتى يجازيها بأعمالها، ويقررها بفعالها.</p>\n<p>فهذا الزجر، [الذي ذكره الله] يسوق القلوب إلى ما فيه نجاتها، ويزجرها عما فيه هلاكها. ولكن المعاند الذي لا تنفع فيه الآيات، لا يزال مستمرا على بغيه وكفره وعناده.</p>"
        },
        "31": {
            "verses": {
                "75:31": {
                    "id": 31
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿فَلَا صَدَّقَ﴾ أي: لا آمن بالله وملائكته وكتبه ورسله واليوم الآخر والقدر خيره وشره ﴿وَلَا صَلَّى﴾</p>"
        },
        "32": {
            "verses": {
                "75:32": {
                    "id": 32
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَلَكِنْ كَذَّبَ﴾ بالحق في مقابلة التصديق، ﴿وَتَوَلَّى﴾ عن الأمر والنهي، هذا وهو مطمئن قلبه، غير خائف من ربه.</p>"
        },
        "33": {
            "verses": {
                "75:33": {
                    "id": 33
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>بل يذهب ﴿إِلَى أَهْلِهِ يَتَمَطَّى﴾ أي: ليس على باله شيء،</h2>"
        },
        "34": {
            "verses": {
                "75:34": {
                    "id": 34
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>5586</p>"
        },
        "35": {
            "verses": {
                "75:35": {
                    "id": 35
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>توعده بقوله: ﴿أَوْلَى لَكَ فَأَوْلَى ثُمَّ أَوْلَى لَكَ فَأَوْلَى﴾ وهذه كلمات وعيد، كررها لتكرير وعيده، ثم ذكر الإنسان بخلقه الأول</p>"
        },
        "36": {
            "verses": {
                "75:36": {
                    "id": 36
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿أَيَحْسَبُ الْإِنْسَانُ أَنْ يُتْرَكَ سُدًى﴾ أي: معطلا ، لا يؤمر ولا ينهى، ولا يثاب ولا يعاقب؟ هذا حسبان باطل وظن بالله بغير ما يليق بحكمته.</p>"
        },
        "37": {
            "verses": {
                "75:37": {
                    "id": 37
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>﴿أَلَمْ يَكُ نُطْفَةً مِنْ مَنِيٍّ يُمْنَى﴾</h2>"
        },
        "38": {
            "verses": {
                "75:38": {
                    "id": 38
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ كَانَ﴾ بعد المني ﴿عَلَقَةً﴾ أي: دمًا، ﴿فَخَلَقَ﴾ الله منها الحيوان وسواه أي: أتقنه وأحكمه.</p>"
        },
        "39": {
            "verses": {
                "75:39": {
                    "id": 39
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>5591</p>"
        },
        "40": {
            "verses": {
                "75:40": {
                    "id": 40
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿أَلَيْسَ ذَلِكَ﴾ الذي خلق الإنسان وطوَّره إلى هذه الأطوار المختلفة ﴿بِقَادِرٍ عَلَى أَنْ يُحْيِيَ الْمَوْتَى﴾؟ بلى إنه على كل شيء قدير.</p>"
        }
    }
}