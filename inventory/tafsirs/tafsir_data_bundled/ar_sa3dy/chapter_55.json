            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>تقدم تفسيرها</h2>"
        },
        "58": {
            "verses": {
                "55:58": {
                    "id": 58
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿كَأَنَّهُنَّ الْيَاقُوتُ وَالْمَرْجَانُ﴾ وذلك لصفائهن وجمال منظرهن وبهائهن.</p>"
        },
        "59": {
            "verses": {
                "55:59": {
                    "id": 59
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>تقدم تفسيرها</h2>"
        },
        "60": {
            "verses": {
                "55:60": {
                    "id": 60
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿هَلْ جَزَاءُ الْإِحْسَانِ إِلَّا الْإِحْسَانُ﴾ أي: هل جزاء من أحسن في عبادة الخالق ونفع عبيده، إلا أن يحسن إليه بالثواب الجزيل، والفوز الكبير، والنعيم المقيم، والعيش السليم، فهاتان الجنتان العاليتان للمقربين.</p>"
        },
        "61": {
            "verses": {
                "55:61": {
                    "id": 61
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>تقدم تفسيرها</h2>"
        },
        "62": {
            "verses": {
                "55:62": {
                    "id": 62
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَمِنْ دُونِهِمَا جَنَّتَانِ﴾ من فضة بنيانهما وآنيتهما وحليتهما وما فيهما لأصحاب اليمين.</p>"
        },
        "63": {
            "verses": {
                "55:63": {
                    "id": 63
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>تقدم تفسيرها</h2>"
        },
        "64": {
            "verses": {
                "55:64": {
                    "id": 64
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>وتلك الجنتان ﴿مُدْهَامَّتَانِ﴾ أي: سوداوان من شدة الخضرة التي هي أثر الري.</p>"
        },
        "65": {
            "verses": {
                "55:65": {
                    "id": 65
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>تقدم تفسيرها</h2>"
        },
        "66": {
            "verses": {
                "55:66": {
                    "id": 66
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
