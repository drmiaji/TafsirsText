{
    "chapter": 90,
    "verses": {
        "1": {
            "verses": {
                "90:1": {
                    "id": 1
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>يقسم تعالى ﴿بِهَذَا الْبَلَدِ﴾ الأمين، الذي هو مكة المكرمة، أفضل البلدان على الإطلاق، خصوصًا وقت حلول الرسول صلى الله عليه وسلم فيها.</p>"
        },
        "2": {
            "verses": {
                "90:2": {
                    "id": 2
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>وَأَنتَ حِلٌّ بِهَٰذَا الْبَلَدِ</h2>"
        },
        "3": {
            "verses": {
                "90:3": {
                    "id": 3
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>﴿وَوَالِدٍ وَمَا وَلَدَ﴾ أي: آدم وذريته.</h2>"
        },
        "4": {
            "verses": {
                "90:4": {
                    "id": 4
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>والمقسم عليه قوله: ﴿لَقَدْ خَلَقْنَا الْإِنْسَانَ فِي كَبَدٍ﴾ يحتمل أن المراد بذلك ما يكابده ويقاسيه من الشدائد في الدنيا، وفي البرزخ، ويوم يقوم الأشهاد، وأنه ينبغي له أن يسعى في عمل يريحه من هذه الشدائد، ويوجب له الفرح والسرور الدائم.</p>\n<h2>وإن لم يفعل، فإنه لا يزال يكابد العذاب الشديد أبد الآباد.</h2>\n<p>ويحتمل أن المعنى: لقد خلقنا الإنسان في أحسن تقويم، وأقوم خلقة، مقدر على التصرف والأعمال الشديدة، ومع ذلك، [فإنه] لم يشكر الله على هذه النعمة [العظيمة]، بل بطر بالعافية وتجبر على خالقه، فحسب بجهله وظلمه أن هذه الحال ستدوم له، وأن سلطان تصرفه لا ينعزل،</p>"
        },
        "5": {
            "verses": {
                "90:5": {
                    "id": 5
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿أَيَحْسَبُ أَنْ لَنْ يَقْدِرَ عَلَيْهِ أَحَدٌ﴾ ويطغى ويفتخر بما أنفق من الأموال على شهوات نفسه.</p>"
        },
        "6": {
            "verses": {
                "90:6": {
                    "id": 6
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>فـ ﴿يَقُولُ أَهْلَكْتُ مَالًا لُبَدًا﴾ أي: كثيًرا، بعضه فوق بعض.</p>\n<p>وسمى الله تعالى الإنفاق في الشهوات والمعاصي إهلاكًا، لأنه لا ينتفع المنفق بما أنفق، ولا يعود عليه من إنفاقه إلا الندم والخسار والتعب والقلة، لا كمن أنفق في مرضاة الله في سبيل الخير، فإن هذا قد تاجر مع الله، وربح أضعاف أضعاف ما أنفق.</p>"
        },
        "7": {
            "verses": {
                "90:7": {
                    "id": 7
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>قال الله متوعدًا هذا الذي يفتخر بما أنفق في الشهوات: ﴿أَيَحْسَبُ أَنْ لَمْ يَرَهُ أَحَدٌ﴾ أي: أيحسب في فعله هذا، أن الله لا يراه ويحاسبه على الصغير والكبير؟</p>\n<p>بل قد رآه الله، وحفظ عليه أعماله، ووكل به الكرام الكاتبين، لكل ما عمله من خير وشر.</p>"
        },
        "8": {
            "verses": {
                "90:8": {
                    "id": 8
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>6032</p>"
        },
        "9": {
            "verses": {
                "90:9": {
                    "id": 9
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>ثم قرره بنعمه، فقال: ﴿أَلَمْ نَجْعَلْ لَهُ عَيْنَيْنِ وَلِسَانًا وَشَفَتَيْنِ﴾ للجمال والبصر والنطق، وغير ذلك من المنافع الضرورية فيها، فهذه نعم الدنيا.</p>"
        },
        "10": {
            "verses": {
                "90:10": {
                    "id": 10
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>ثم قال في نعم الدين: ﴿وَهَدَيْنَاهُ النَّجْدَيْن﴾ أي: طريقي الخير والشر، بينا له الهدى من الضلال، والرشد من الغي.</p>\n<p>فهذه المنن الجزيلة، تقتضي من العبد أن يقوم بحقوق الله، ويشكر الله على نعمه، وأن لا يستعين بها على معاصيه ، ولكن هذا الإنسان لم يفعل ذلك.</p>"
        },
        "11": {
            "verses": {
                "90:11": {
                    "id": 11
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿فَلَا اقْتَحَمَ الْعَقَبَةَ﴾ أي: لم يقتحمها ويعبر عليها، لأنه متبع لشهواته .</p>"
        },
        "12": {
            "verses": {
                "90:12": {
                    "id": 12
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>وَمَا أَدْرَاكَ مَا الْعَقَبَةُ</h2>"
        },
        "13": {
            "verses": {
                "90:13": {
                    "id": 13
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>وهذه العقبة شديدة عليه، ثم فسر [هذه] العقبة ﴿فَكُّ رَقَبَةٍ﴾ أي: فكها من الرق، بعتقها أو مساعدتها على أداء كتابتها، ومن باب أولى فكاك الأسير المسلم عند الكفار.</p>"
        },
        "14": {
            "verses": {
                "90:14": {
                    "id": 14
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿أَوْ إِطْعَامٌ فِي يَوْمٍ ذِي مَسْغَبَةٍ﴾ أي: مجاعة شديدة، بأن يطعم وقت الحاجة أشد الناس حاجة.</p>"
        },
        "15": {
            "verses": {
                "90:15": {
                    "id": 15
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿يَتِيمًا ذَا مَقْرَبَةٍ﴾ أي: جامعًا بين كونه يتيمًا، فقيرًا ذا قرابة.</p>"
        },
        "16": {
            "verses": {
                "90:16": {
                    "id": 16
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿أَوْ مِسْكِينًا ذَا مَتْرَبَةٍ﴾ أي: قد لزق بالتراب من الحاجة والضرورة.</p>"
        },
        "17": {
            "verses": {
                "90:17": {
                    "id": 17
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ كَانَ مِنَ الَّذِينَ آمَنُوا﴾ أي: آمنوا بقلوبهم بما يجب الإيمان به، وعملوا الصالحات بجوارحهم. من كل قول وفعل واجب أو مستحب. ﴿وَتَوَاصَوْا بِالصَّبْرِ﴾ على طاعة الله وعن معصيته، وعلى أقدار المؤلمة بأن يحث بعضهم بعضًا على الانقياد لذلك، والإتيان به كاملًا منشرحًا به الصدر، مطمئنة به النفس.</p>\n<p>﴿وَتَوَاصَوْا بِالْمَرْحَمَةِ﴾ للخلق، من إعطاء محتاجهم، وتعليم جاهلهم، والقيام بما يحتاجون إليه من جميع الوجوه، ومساعدتهم على المصالح الدينية والدنيوية، وأن يحب لهم ما يحب لنفسه، ويكره لهم ما يكره لنفسه.</p>"
        },
        "18": {
            "verses": {
                "90:18": {
                    "id": 18
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>أولئك الذين قاموا بهذه الأوصاف، الذين وفقهم الله لاقتحام هذه العقبة ﴿أُولَئِكَ أَصْحَابُ الْمَيْمَنَةِ﴾ لأنهم أدوا ما أمر الله به من حقوقه وحقوق عباده، وتركوا ما نهوا عنه، وهذا عنوان السعادة وعلامتها.</p>"
        },
        "19": {
            "verses": {
                "90:19": {
                    "id": 19
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَالَّذِينَ كَفَرُوا بِآيَاتِنَا﴾ بأن نبذوا هذه الأمور وراء ظهورهم، فلم يصدقوا بالله، [ولا آمنوا به]، ولا عملوا صالحًا، ولا رحموا عباد الله، ﴿والذين كفروا بآياتنا همْ أَصْحَابُ الْمَشْئَمَة﴾</p>"
        },
        "20": {
            "verses": {
                "90:20": {
                    "id": 20
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿عَلَيْهِمْ نَارٌ مُؤْصَدَةٌ﴾ أي: مغلقة، في عمد ممددة، قد مدت من ورائها، لئلا تنفتح أبوابها، حتى يكونوا في ضيق وهم وشدة.</p>"
        }
    }
}