{
    "chapter": 82,
    "verses": {
        "1": {
            "verses": {
                "82:1": {
                    "id": 1
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>أي: إذا انشقت السماء وانفطرت،</h2>"
        },
        "2": {
            "verses": {
                "82:2": {
                    "id": 2
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>وانتثرت نجومها، وزال جمالها،</h2>"
        },
        "3": {
            "verses": {
                "82:3": {
                    "id": 3
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>وفجرت البحار فصارت بحرا واحدا،</h2>"
        },
        "4": {
            "verses": {
                "82:4": {
                    "id": 4
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>وبعثرت القبور بأن أخرجت ما فيها من الأموات،</h2>"
        },
        "5": {
            "verses": {
                "82:5": {
                    "id": 5
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>وحشروا للموقف بين يدي الله للجزاء على الأعمال. فحينئذ ينكشف الغطاء، ويزول ما كان خفيا، وتعلم كل نفس ما معها من الأرباح والخسران، هنالك يعض الظالم على يديه إذا رأى أعماله باطلة، وميزانه قد خف، والمظالم قد تداعت إليه، والسيئات قد حضرت لديه، وأيقن بالشقاء الأبدي والعذاب السرمدي .</p>\n<p>و [هنالك] يفوز المتقون المقدمون لصالح الأعمال بالفوز العظيم، والنعيم المقيم والسلامة من عذاب الجحيم.</p>"
        },
        "6": {
            "verses": {
                "82:6": {
                    "id": 6
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>يقول تعالى معاتبا للإنسان المقصر في حق ربه، المتجرئ على مساخطه: ﴿يَا أَيُّهَا الْإِنْسَانُ مَا غَرَّكَ بِرَبِّكَ الْكَرِيمِ﴾ أتهاونا منك في حقوقه؟ أم احتقارا منك لعذابه؟ أم عدم إيمان منك بجزائه؟</p>"
        },
        "7": {
            "verses": {
                "82:7": {
                    "id": 7
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>أليس هو ﴿الَّذِي خَلَقَكَ فَسَوَّاكَ﴾ في أحسن تقويم؟ ﴿فَعَدَلَكَ﴾ وركبك تركيبا قويما معتدلا، في أحسن الأشكال، وأجمل الهيئات، فهل يليق بك أن تكفر نعمة المنعم، أو تجحد إحسان المحسن؟</p>"
        },
        "8": {
            "verses": {
                "82:8": {
                    "id": 8
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>إن هذا إلا من جهلك وظلمك وعنادك وغشمك، فاحمد الله أن لم يجعل صورتك صورة كلب أو حمار، أو نحوهما من الحيوانات؛ فلهذا قال تعالى: ﴿فِي أَيِّ صُورَةٍ مَا شَاءَ رَكَّبَكَ﴾</p>"
        },
        "9": {
            "verses": {
                "82:9": {
                    "id": 9
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿كَلَّا بَلْ تُكَذِّبُونَ بِالدِّينِ﴾ أي: مع هذا الوعظ والتذكير، لا تزالون مستمرين على التكذيب بالجزاء.</p>"
        },
        "10": {
            "verses": {
                "82:10": {
                    "id": 10
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>5840</p>"
        },
        "11": {
            "verses": {
                "82:11": {
                    "id": 11
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>وأنتم لا بد أن تحاسبوا على ما عملتم، وقد أقام الله عليكم ملائكة كراما يكتبون أقوالكم وأفعالكم ويعلمون أفعالكم، ودخل في هذا أفعال القلوب، وأفعال الجوارح، فاللائق بكم أن تكرموهم وتجلوهم وتحترموهم.</p>"
        },
        "12": {
            "verses": {
                "82:12": {
                    "id": 12
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>5842</p>"
        },
        "13": {
            "verses": {
                "82:13": {
                    "id": 13
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>المراد بالأبرار، القائمون بحقوق الله وحقوق عباده، الملازمون للبر، في أعمال القلوب وأعمال الجوارح، فهؤلاء جزاؤهم النعيم في القلب والروح والبدن، في دار الدنيا [وفي دار] البرزخ و [في] دار القرار.</p>"
        },
        "14": {
            "verses": {
                "82:14": {
                    "id": 14
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِنَّ الْفُجَّارَ﴾ الذين قصروا في حقوق الله وحقوق عباده، الذين فجرت قلوبهم ففجرت أعمالهم ﴿لَفِي جَحِيمٍ﴾ أي: عذاب أليم، في دار الدنيا و [دار] البرزخ وفي دار القرار.</p>"
        },
        "15": {
            "verses": {
                "82:15": {
                    "id": 15
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿يَصْلَوْنَهَا﴾ ويعذبون [بها] أشد العذاب ﴿يَوْمِ الدِّينِ﴾ أي: يوم الجزاء على الأعمال.</p>"
        },
        "16": {
            "verses": {
                "82:16": {
                    "id": 16
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَا هُمْ عَنْهَا بِغَائِبِينَ﴾ أي: بل هم ملازمون لها، لا يخرجون منها.</p>"
        },
        "17": {
            "verses": {
                "82:17": {
                    "id": 17
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>5847</p>"
        },
        "18": {
            "verses": {
                "82:18": {
                    "id": 18
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَا أَدْرَاكَ مَا يَوْمُ الدِّينِ ثُمَّ مَا أَدْرَاكَ مَا يَوْمُ الدِّينِ﴾ ففي هذا تهويل لذلك اليوم الشديد الذي يحير الأذهان.</p>"
        },
        "19": {
            "verses": {
                "82:19": {
                    "id": 19
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿يَوْمَ لَا تَمْلِكُ نَفْسٌ لِنَفْسٍ شَيْئًا﴾ ولو كانت لها قريبة [أو حبيبة] مصافية، فكل مشتغل بنفسه لا يطلب الفكاك لغيرها. ﴿وَالْأَمْرُ يَوْمَئِذٍ لِلَّهِ﴾ فهو الذي يفصل بين العباد، ويأخذ للمظلوم حقه من ظالمه [والله أعلم]</p>"
        }
    }
}