                "language_name": "english"
            },
            "text": "<p>5523</p>"
        },
        "27": {
            "verses": {
                "74:27": {
                    "id": 27
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>5523</p>"
        },
        "28": {
            "verses": {
                "74:28": {
                    "id": 28
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>فما حقه إلا العذاب الشديد والنكال، ولهذا قال تعالى:</h2>\n<p>﴿سَأُصْلِيهِ سَقَرَ وَمَا أَدْرَاكَ مَا سَقَرُ لَا تُبْقِي وَلَا تَذَرُ﴾ أي: لا تبقي من الشدة، ولا على المعذب شيئا إلا وبلغته.</p>"
        },
        "29": {
            "verses": {
                "74:29": {
                    "id": 29
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿لَوَّاحَةٌ لِلْبَشَرِ﴾ أي: تلوحهم [وتصليهم] في عذابها، وتقلقهم بشدة حرها وقرها.</p>"
        },
        "30": {
            "verses": {
