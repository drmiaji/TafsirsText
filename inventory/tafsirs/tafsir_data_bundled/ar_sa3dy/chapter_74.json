                "language_name": "english"
            },
            "text": "<p>﴿عَلَيْهَا تِسْعَةَ عَشَرَ﴾ من الملائكة، خزنة لها، غلاظ شداد، لا يعصون الله ما أمرهم، ويفعلون ما يؤمرون.</p>"
        },
        "31": {
            "verses": {
                "74:31": {
                    "id": 31
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>﴿وَمَا جَعَلْنَا أَصْحَابَ النَّارِ إِلَّا مَلَائِكَةً﴾ وذلك لشدتهم وقوتهم. ﴿وَمَا جَعَلْنَا عِدَّتَهُمْ إِلَّا فِتْنَةً لِلَّذِينَ كَفَرُوا﴾ يحتمل أن المراد: إلا لعذابهم وعقابهم في الآخرة، ولزيادة نكالهم فيها، والعذاب يسمى فتنة، [كما قال تعالى: ﴿يَوْمَ هُمْ عَلَى النَّارِ يُفْتَنُونَ﴾ ] ويحتمل أن المراد: أنا ما أخبرناكم بعدتهم، إلا لنعلم من يصدق ومن يكذب، ويدل على هذا ما ذكر بعده في قوله: ﴿لِيَسْتَيْقِنَ الَّذِينَ أُوتُوا الْكِتَابَ وَيَزْدَادَ الَّذِينَ آمَنُوا إِيمَانًا﴾ فإن أهل الكتاب، إذا وافق ما عندهم وطابقه، ازداد يقينهم بالحق، والمؤمنون كلما أنزل الله آية، فآمنوا بها وصدقوا، ازداد إيمانهم، ﴿وَلَا يَرْتَابَ الَّذِينَ أُوتُوا الْكِتَابَ وَالْمُؤْمِنُونَ﴾ أي: ليزول عنهم الريب والشك، وهذه مقاصد جليلة، يعتني بها أولو الألباب، وهي السعي في اليقين، وزيادة الإيمان في كل وقت، وكل مسألة من مسائل الدين، ودفع الشكوك والأوهام التي تعرض في مقابلة الحق، فجعل ما أنزله الله على رسوله محصلا لهذه الفوائد الجليلة، ومميزا للكاذبين من الصادقين، ولهذا قال: ﴿وَلِيَقُولَ الَّذِينَ فِي قُلُوبِهِمْ مَرَضٌ﴾ أي: شك وشبهة ونفاق. ﴿وَالْكَافِرُونَ مَاذَا أَرَادَ اللهُ بِهَذَا مَثَلًا﴾ وهذا على وجه الحيرة والشك، والكفر منهم بآيات الله، وهذا وذاك من هداية الله لمن يهديه، وإضلاله لمن يضل ولهذا قال:</h2>\n<p>﴿كَذَلِكَ يُضِلُّ اللهُ مَنْ يَشَاءُ وَيَهْدِي مَنْ يَشَاءُ﴾ فمن هداه الله، جعل ما أنزله الله على رسوله رحمة في حقه، وزيادة في إيمانه ودينه، ومن أضله، جعل ما أنزله على رسوله زيادة شقاء عليه وحيرة، وظلمة في حقه، والواجب أن يتلقى ما أخبر الله به ورسوله بالتسليم، فإنه لا يعلم جنود ربك من الملائكة وغيرهم ﴿إلَّا هُوَ﴾ فإذا كنتم جاهلين بجنوده، وأخبركم بها العليم الخبير، فعليكم أن تصدقوا خبره، من غير شك ولا ارتياب، ﴿وَمَا هِيَ إِلَّا ذِكْرَى لِلْبَشَرِ﴾ أي: وما هذه الموعظة والتذكار مقصودا به العبث واللعب، وإنما المقصود به أن يتذكر [به] البشر ما ينفعهم فيفعلونه، وما يضرهم فيتركونه.</p>"
        },
        "32": {
            "verses": {
                "74:32": {
                    "id": 32
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿كَلَّا﴾ هنا بمعنى: حقا، أو بمعنى ﴿ألا﴾ الاستفتاحية، فأقسم تعالى بالقمر.</p>"
        },
        "33": {
            "verses": {
                "74:33": {
                    "id": 33
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>وبالليل وقت إدباره.</h2>"
        },
        "34": {
            "verses": {
                "74:34": {
                    "id": 34
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>والنهار وقت إسفاره، لاشتمال المذكورات على آيات الله العظيمة، الدالة على كمال قدرة الله وحكمته، وسعة سلطانه، وعموم رحمته، وإحاطة علمه.</p>"
        },
        "35": {
            "verses": {
                "74:35": {
                    "id": 35
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>والمقسم عليه قوله: ﴿إِنَّهَا﴾ أي النار ﴿لَإِحْدَى الْكُبَرِ﴾ أي: لإحدى العظائم الطامة والأمور الهامة، فإذا أعلمناكم بها، وكنتم على بصيرة من أمرها.</p>"
        },
        "36": {
            "verses": {
                "74:36": {
                    "id": 36
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>5532</p>"
        },
        "37": {
            "verses": {
                "74:37": {
                    "id": 37
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>فمن شاء منكم أن يتقدم، فيعمل بما يقربه من ربه، ويدنيه من رضاه، ويزلفه من دار كرامته، أو يتأخر [عما خلق له و] عما يحبه الله [ويرضاه]، فيعمل بالمعاصي، ويتقرب إلى نار جهنم، كما قال تعالى: ﴿وَقُلِ الْحَقُّ مِنْ رَبِّكُمْ فَمَنْ شَاءَ فَلْيُؤْمِنْ وَمَنْ شَاءَ فَلْيَكْفُرْ﴾ الآية.</p>"
        },
        "38": {
            "verses": {
                "74:38": {
                    "id": 38
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿كُلُّ نَفْسٍ بِمَا كَسَبَتْ﴾ من أعمال السوء وأفعال الشر ﴿رَهِينَةٌ﴾ بها موثقة بسعيها، قد ألزم عنقها، وغل في رقبتها، واستوجبت به العذاب،</p>"
        },
        "39": {
            "verses": {
                "74:39": {
                    "id": 39
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿إِلَّا أَصْحَابَ الْيَمِينِ﴾ فإنهم لم يرتهنوا، بل أطلقوا وفرحوا</p>"
        },
        "40": {
            "verses": {
                "74:40": {
                    "id": 40
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>5536</p>"
        },
        "41": {
            "verses": {
                "74:41": {
                    "id": 41
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>﴿فِي جَنَّاتٍ يَتَسَاءَلُونَ عَنِ الْمُجْرِمِينَ﴾</h2>\n<p>أي: في جنات قد حصل لهم بها جميع مطلوباتهم، وتمت لهم الراحة والطمأنينة، حتى أقبلوا يتساءلون، فأفضت بهم المحادثة، أن سألوا عن المجرمين، أي: حال وصلوا إليها، وهل وجدوا ما وعدهم الله تعالى؟ فقال بعضهم لبعض: \" هل أنتم مطلعون عليهم \" فاطلعوا عليهم في وسط الجحيم يعذبون</p>"
        },
        "42": {
            "verses": {
                "74:42": {
                    "id": 42
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>فقالوا لهم: ﴿مَا سَلَكَكُمْ فِي سَقَرَ﴾ أي: أي شيء أدخلكم فيها؟ وبأي: ذنب استحققتموها؟</p>"
        },
        "43": {
            "verses": {
                "74:43": {
                    "id": 43
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>5539</p>"
        },
        "44": {
            "verses": {
                "74:44": {
                    "id": 44
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>فـ ﴿قَالُوا لَمْ نَكُ مِنَ الْمُصَلِّينَ وَلَمْ نَكُ نُطْعِمُ الْمِسْكِينَ﴾ فلا إخلاص للمعبود، [ولا إحسان] ولا نفع للخلق المحتاجين.</p>"
        },
        "45": {
            "verses": {
                "74:45": {
                    "id": 45
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَكُنَّا نَخُوضُ مَعَ الْخَائِضِينَ﴾ أي: نخوض بالباطل، ونجادل به الحق،</p>"
        },
        "46": {
            "verses": {
                "74:46": {
                    "id": 46
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَكُنَّا نُكَذِّبُ بِيَوْمِ الدِّينِ﴾ هذا آثار الخوض بالباطل، [وهو] التكذيب بالحق، ومن أحق الحق، يوم الدين، الذي هو محل الجزاء على الأعمال، وظهور ملك الله وحكمه العدل لسائر الخلق.</p>"
        },
        "47": {
            "verses": {
                "74:47": {
                    "id": 47
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>فاستمرينا على هذا المذهب الفاسد ﴿حَتَّى أَتَانَا الْيَقِينُ﴾ أي: الموت، فلما ماتوا على الكفر تعذرت حينئذ عليهم الحيل، وانسد في وجوههم باب الأمل.</p>"
        },
        "48": {
            "verses": {
                "74:48": {
                    "id": 48
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿فَمَا تَنْفَعُهُمْ شَفَاعَةُ الشَّافِعِينَ﴾ لأنهم لا يشفعون إلا لمن ارتضى، وهؤلاء لا يرضى الله أعمالهم . فلما بين الله مآل المخالفين، ورهب مما يفعل بهم، عطف على الموجودين بالعتاب واللوم.</p>"
        },
        "49": {
            "verses": {
                "74:49": {
                    "id": 49
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿فَمَا لَهُمْ عَنِ التَّذْكِرَةِ مُعْرِضِينَ﴾ أي: صادين غافلين عنها.</p>"
        },
        "50": {
            "verses": {
                "74:50": {
                    "id": 50
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿كَأَنَّهُمْ﴾ في نفرتهم الشديدة منها ﴿حُمُرٌ مُسْتَنْفِرَةٌ﴾ أي: كأنهم حمر وحش نفرت فنفر بعضها بعضا، فزاد عدوها،</p>"
        },
        "51": {
            "verses": {
                "74:51": {
                    "id": 51
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿فَرَّتْ مِنْ قَسْوَرَةٍ﴾ أي: من صائد ورام يريدها، أو من أسد ونحوه، وهذا من أعظم ما يكون من النفور عن الحق، ومع هذا الإعراض وهذا النفور، يدعون الدعاوى الكبار.</p>"
        },
        "52": {
            "verses": {
                "74:52": {
                    "id": 52
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>فـ ﴿يُرِيدُ كُلُّ امْرِئٍ مِنْهُمْ أَنْ يُؤْتَى صُحُفًا مُنَشَّرَةً﴾ نازلة عليه من السماء، يزعم أنه لا ينقاد للحق إلا بذلك، وقد كذبوا، فإنهم لو جاءتهم كل آية لم يؤمنوا حتى يروا العذاب الأليم، فإنهم جاءتهم الآيات البينات التي تبين الحق وتوضحه، فلو كان فيهم خير لآمنوا.</p>"
        },
        "53": {
            "verses": {
                "74:53": {
                    "id": 53
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿كَلَّا﴾ أن نعطيهم ما طلبوا، وهم ما قصدوا بذلك إلا التعجيز، ﴿بَلْ لَا يَخَافُونَ الْآخِرَةَ﴾ فلو كانوا يخافونها لما جرى منهم ما جرى.</p>"
        },
        "54": {
            "verses": {
                "74:54": {
                    "id": 54
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿كَلَّا إِنَّهُ تَذْكِرَةٌ﴾ الضمير إما أن يعود على هذه السورة، أو على ما اشتملت عليه [من] هذه الموعظة،</p>"
        },
        "55": {
            "verses": {
                "74:55": {
                    "id": 55
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿فَمَنْ شَاءَ ذَكَرَهُ﴾ لأنه قد بين له السبيل، ووضح له الدليل.</p>"
        },
        "56": {
            "verses": {
                "74:56": {
                    "id": 56
                }
            },
