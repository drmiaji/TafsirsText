        },
        "21": {
            "verses": {
                "92:21": {
                    "id": 21
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿إِلَّا ابْتِغَاءَ وَجْهِ رَبِّهِ الْأَعْلَى وَلَسَوْفَ يَرْضَى﴾ هذا الأتقى بما يعطيه الله من أنواع الكرامات والمثوبات، والحمد لله رب العالمين.</p>"
        }
    }
}