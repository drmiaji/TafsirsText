{
    "chapter": 99,
    "verses": {
        "1": {
            "verses": {
                "99:1": {
                    "id": 1
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>يخبر تعالى عما يكون يوم القيامة، وأن الأرض تتزلزل وترجف وترتج، حتى يسقط ما عليها من بناء وعلم .</p>\n<p>فتندك جبالها، وتسوى تلالها، وتكون قاعًا صفصفًا لا عوج فيه ولا أمت.</p>"
        },
        "2": {
            "verses": {
                "99:2": {
                    "id": 2
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَأَخْرَجَتِ الْأَرْضُ أَثْقَالَهَا﴾ أي: ما في بطنها، من الأموات والكنوز.</p>"
        },
        "3": {
            "verses": {
                "99:3": {
                    "id": 3
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَقَالَ الْإِنْسَانُ﴾ إذا رأى ما عراها من الأمر العظيم مستعظمًا لذلك: ﴿مَا لَهَا﴾ ؟ أي: أي شيء عرض لها؟.</p>"
        },
        "4": {
            "verses": {
                "99:4": {
                    "id": 4
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿يَوْمَئِذٍ تُحَدِّثُ﴾ الأرض ﴿أَخْبَارَهَا﴾ أي: تشهد على العاملين بما عملوا على ظهرها من خير وشر، فإن الأرض من جملة الشهود الذين يشهدون على العباد بأعمالهم.</p>"
        },
        "5": {
            "verses": {
                "99:5": {
                    "id": 5
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>ذلك ﴿بِأَنَّ رَبَّكَ أَوْحَى لَهَا﴾ [أي] وأمرها أن تخبر بما عمل عليها، فلا تعصى لأمره .</p>"
        },
        "6": {
            "verses": {
                "99:6": {
                    "id": 6
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿يَوْمَئِذٍ يَصْدُرُ النَّاسُ﴾ من موقف القيامة، حين يقضي الله بينهم ﴿أَشْتَاتًا﴾ أي: فرقًا متفاوتين. ﴿لِيُرَوْا أَعْمَالَهُمْ﴾ أي: ليريهم الله ما عملوا من الحسنات والسيئات، ويريهم جزاءه موفرًا.</p>"
        },
        "7": {
            "verses": {
                "99:7": {
                    "id": 7
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>6146</p>"
        },
        "8": {
            "verses": {
                "99:8": {
                    "id": 8
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿فَمَنْ يَعْمَلْ مِثْقَالَ ذَرَّةٍ خَيْرًا يَرَهُ وَمَنْ يَعْمَلْ مِثْقَالَ ذَرَّةٍ شَرًّا يَرَهُ﴾ وهذا شامل عام للخير والشر كله، لأنه إذا رأى مثقال الذرة، التي هي أحقر الأشياء، [وجوزي عليها] فما فوق ذلك من باب أولى وأحرى، كما قال تعالى: ﴿يَوْمَ تَجِدُ كُلُّ نَفْسٍ مَا عَمِلَتْ مِنْ خَيْرٍ مُحْضَرًا وَمَا عَمِلَتْ مِنْ سُوءٍ تَوَدُّ لَوْ أَنَّ بَيْنَهَا وَبَيْنَهُ أَمَدًا بَعِيدًا﴾ ﴿وَوَجَدُوا مَا عَمِلُوا حَاضِرًا﴾</p>\n<p>وهذه الآية فيها غاية الترغيب في فعل الخير ولو قليلًا، والترهيب من فعل الشر ولو حقيرًا.</p>"
        }
    }
}