{
    "chapter": 83,
    "verses": {
        "1": {
            "verses": {
                "83:1": {
                    "id": 1
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>﴿وَيْلٌ﴾ كلمة عذاب، ووعيد ﴿لِلْمُطَفِّفِينَ﴾</h2>"
        },
        "2": {
            "verses": {
                "83:2": {
                    "id": 2
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>وفسر الله المطففين بقوله ﴿الَّذِينَ إِذَا اكْتَالُوا عَلَى النَّاسِ﴾ أي: أخذوا منهم وفاء عما ثبت لهم قبلهم ﴿يَسْتَوْفُونَ﴾ يستوفونه كاملا من غير نقص.</p>"
        },
        "3": {
            "verses": {
                "83:3": {
                    "id": 3
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِذَا كَالُوهُمْ أَوْ وَزَنُوهُمْ﴾ أي: إذا أعطوا الناس حقهم، الذي للناس عليهم بكيل أو وزن، ﴿يُخْسِرُونَ﴾ أي: ينقصونهم ذلك، إما بمكيال وميزان ناقصين، أو بعدم ملء المكيال والميزان، أو نحو ذلك. فهذا سرقة [لأموال] الناس ، وعدم إنصاف [لهم] منهم.</p>\n<p>وإذا كان هذا الوعيد على الذين يبخسون الناس بالمكيال والميزان، فالذي يأخذ أموالهم قهرًا أو سرقة، أولى بهذا الوعيد من المطففين.</p>\n<p>ودلت الآية الكريمة، على أن الإنسان كما يأخذ من الناس الذي له، يجب عليه أن يعطيهم كل ما لهم من الأموال والمعاملات، بل يدخل في [عموم هذا] الحجج والمقالات، فإنه كما أن المتناظرين قد جرت العادة أن كل واحد [منهما] يحرص على ماله من الحجج، فيجب عليه أيضًا أن يبين ما لخصمه من الحجج [التي لا يعلمها]، وأن ينظر في أدلة خصمه كما ينظر في أدلته هو، وفي هذا الموضع يعرف إنصاف الإنسان من تعصبه واعتسافه، وتواضعه من كبره، وعقله من سفهه، نسأل الله التوفيق لكل خير.</p>"
        },
        "4": {
            "verses": {
                "83:4": {
                    "id": 4
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>5854</p>"
        },
        "5": {
            "verses": {
                "83:5": {
                    "id": 5
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>5854</p>"
        },
        "6": {
            "verses": {
                "83:6": {
                    "id": 6
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>ثم توعد تعالى المطففين، وتعجب من حالهم وإقامتهم على ما هم عليه، فقال: ﴿أَلَا يَظُنُّ أُولَئِكَ أَنَّهُمْ مَبْعُوثُونَ لِيَوْمٍ عَظِيمٍ يَوْمَ يَقُومُ النَّاسُ لِرَبِّ الْعَالَمِينَ﴾ فالذي جرأهم على التطفيف عدم إيمانهم باليوم الآخر، وإلا فلو آمنوا به، وعرفوا أنهم يقومون بين يدى الله، يحاسبهم على القليل والكثير، لأقلعوا عن ذلك وتابوا منه.</p>"
        },
        "7": {
            "verses": {
                "83:7": {
                    "id": 7
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>يقول تعالى: ﴿كَلَّا إِنَّ كِتَابَ الْفُجَّارِ﴾ [وهذا شامل لكل فاجر] من أنواع الكفرة والمنافقين، والفاسقين ﴿لَفِي سِجِّينٍ﴾</p>"
        },
        "8": {
            "verses": {
                "83:8": {
                    "id": 8
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>5857</p>"
        },
        "9": {
            "verses": {
                "83:9": {
                    "id": 9
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَا أَدْرَاكَ مَا سِجِّينٌ كِتَابٌ مَرْقُومٌ﴾ أي: كتاب مذكور فيه أعمالهم الخبيثة، والسجين: المحل الضيق الضنك، و ﴿سجين﴾ ضد ﴿عليين﴾ الذي هو محل كتاب الأبرار، كما سيأتي.</p>\n<p>وقد قيل: إن ﴿سجين﴾ هو أسفل الأرض السابعة، مأوى الفجار ومستقرهم في معادهم.</p>"
        },
        "10": {
            "verses": {
                "83:10": {
                    "id": 10
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>﴿وَيْلٌ يَوْمَئِذٍ لِلْمُكَذِّبِينَ﴾</h2>"
        },
        "11": {
            "verses": {
                "83:11": {
                    "id": 11
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>ثم بين المكذبين بأنهم ﴿الَّذِينَ يُكَذِّبُونَ بِيَوْمِ الدِّينِ﴾ أي: يوم الجزاء، يوم يدين الله فيه الناس بأعمالهم.</p>"
        },
        "12": {
            "verses": {
                "83:12": {
                    "id": 12
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَا يُكَذِّبُ بِهِ إِلَّا كُلُّ مُعْتَدٍ﴾ على محارم الله، متعد من الحلال إلى الحرام.</p>\n<p>﴿أَثِيمٍ﴾ أي كثير الإثم، فهذا الذي يحمله عدوانه على التكذيب، ويحمله [عدوانه على التكذيب ويوجب له] كبره رد الحق،</p>"
        },
        "13": {
            "verses": {
                "83:13": {
                    "id": 13
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>ولهذا ﴿إِذَا تُتْلَى عَلَيْهِ آيَاتُنَا﴾ الدالة على الحق، و[على] صدق ما جاءت به رسله، كذبها وعاندها، و ﴿قَالَ﴾ هذه ﴿أَسَاطِيرُ الْأَوَّلِينَ﴾ أي: من ترهات المتقدمين، وأخبار الأمم الغابرين، ليس من عند الله تكبرا وعنادا.</p>"
        },
        "14": {
            "verses": {
                "83:14": {
                    "id": 14
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>وأما من أنصف، وكان مقصوده الحق المبين، فإنه لا يكذب بيوم الدين، لأن الله قد أقام عليه من الأدلة القاطعة، والبراهين الساطعة، ما يجعله حق اليقين، وصار لقلوبهم مثل الشمس للأبصار ، بخلاف من ران على قلبه كسبه، وغطته معاصيه،</p>"
        },
        "15": {
            "verses": {
                "83:15": {
                    "id": 15
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>فإنه محجوب عن الحق، ولهذا جوزي على ذلك، بأن حجب عن الله، كما حجب قلبه في الدنيا عن آيات الله،</p>"
        },
        "16": {
            "verses": {
                "83:16": {
                    "id": 16
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿ثُمَّ إِنَّهُمْ﴾ مع هذه العقوبة البليغة ﴿لَصَالُوا الْجَحِيمِ﴾</p>"
        },
        "17": {
            "verses": {
                "83:17": {
                    "id": 17
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>ثم يقال لهم توبيخا وتقريعًا: ﴿هَذَا الَّذِي كُنْتُمْ بِهِ تُكَذِّبُونَ﴾ فذكر لهم ثلاثة أنواع من العذاب: عذاب الجحيم، وعذاب التوبيخ، واللوم.</p>\n<p>وعذاب الحجاب من رب العالمين، المتضمن لسخطه وغضبه عليهم، وهو أعظم عليهم من عذاب النار، ودل مفهوم الآية، على أن المؤمنين يرون ربهم يوم القيامة وفي الجنة، ويتلذذون بالنظر إليه أعظم من سائر اللذات، ويبتهجون بخطابه، ويفرحون بقربه، كما ذكر الله ذلك في عدة آيات من القرآن، وتواتر فيه النقل عن رسول الله.</p>\n<p>وفي هذه الآيات، التحذير من الذنوب، فإنها ترين على القلب وتغطيه شيئا فشيئا، حتى ينطمس نوره، وتموت بصيرته، فتنقلب عليه الحقائق، فيرى الباطل حقًا، والحق باطلًا، وهذا من بعض عقوبات الذنوب.</p>"
        },
        "18": {
            "verses": {
                "83:18": {
                    "id": 18
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>لما ذكر أن كتاب الفجار في أسفل الأمكنة وأضيقها، ذكر أن كتاب الأبرار في أعلاها وأوسعها، وأفسحها</p>"
        },
        "19": {
            "verses": {
                "83:19": {
                    "id": 19
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>وَمَا أَدْرَاكَ مَا عِلِّيُّونَ</h2>"
        },
        "20": {
            "verses": {
                "83:20": {
                    "id": 20
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>5869</p>"
        },
        "21": {
            "verses": {
                "83:21": {
                    "id": 21
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>وأن كتابهم المرقوم ﴿يَشْهَدُهُ الْمُقَرَّبُونَ﴾ من الملائكة الكرام، وأرواح الأنبياء، والصديقين والشهداء، وينوه الله بذكرهم في الملأ الأعلى، و ﴿عليون﴾ اسم لأعلى الجنة،</p>"
        },
        "22": {
            "verses": {
                "83:22": {
                    "id": 22
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>فلما ذكر كتابهم، ذكر أنهم في نعيم، وهو اسم جامع لنعيم القلب والروح والبدن،</p>"
        },
        "23": {
            "verses": {
                "83:23": {
                    "id": 23
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>﴿عَلَى الْأَرَائِكِ﴾ أي: [على] السرر المزينة بالفرش الحسان.</h2>\n<p>﴿يُنْظَرُونَ﴾ إلى ما أعد الله لهم من النعيم، وينظرون إلى وجه ربهم الكريم،</p>"
        },
        "24": {
            "verses": {
                "83:24": {
                    "id": 24
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿تَعْرِفُ﴾ أيها الناظر إليهم ﴿فِي وُجُوهِهِمْ نَضْرَةَ النَّعِيمِ﴾ أي: بهاء النعيم ونضارته ورونقه، فإن توالي اللذة والسرور يكسب الوجه نورًا وحسنًا وبهجة.</p>"
        },
        "25": {
            "verses": {
                "83:25": {
                    "id": 25
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿يُسْقَوْنَ مِنْ رَحِيقٍ﴾ وهو من أطيب ما يكون من الأشربة وألذها، ﴿مَخْتُومٍ﴾</p>"
        },
        "26": {
            "verses": {
                "83:26": {
                    "id": 26
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>ذلك الشراب ﴿خِتَامُهُ مِسْكٌ﴾ يحتمل أن المراد مختوم عن أن يداخله شيء ينقص لذته، أو يفسد طعمه، وذلك الختام، الذي ختم به، مسك.</p>\n<p>ويحتمل أن المراد أنه [الذي] يكون في آخر الإناء، الذي يشربون منه الرحيق حثالة، وهي المسك الأذفر، فهذا الكدر منه، الذي جرت العادة في الدنيا أنه يراق، يكون في الجنة بهذه المثابة، ﴿وَفِي ذَلِكَ﴾ النعيم المقيم، الذي لا يعلم حسنه ومقداره إلا الله، ﴿فَلْيَتَنَافَسِ الْمُتَنَافِسُونَ﴾ أي: يتسابقوا في المبادرة إليه بالأعمال الموصلة إليه، فهذا أولى ما بذلت فيه نفائس الأنفاس، وأحرى ما تزاحمت للوصول إليه فحول الرجال.</p>"
        },
        "27": {
            "verses": {
                "83:27": {
                    "id": 27
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<h2>ومزاج هذا الشراب من تسنيم،</h2>"
        },
        "28": {
            "verses": {
                "83:28": {
                    "id": 28
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>وهي عين ﴿يَشْرَبُ بِهَا الْمُقَرَّبُونَ﴾ صرفا، وهي أعلى أشربة الجنة على الإطلاق، فلذلك كانت خالصة للمقربين، الذين هم أعلى الخلق منزلة، وممزوجة لأصحاب اليمين أي: مخلوطة بالرحيق وغيره من الأشربة اللذيذة.</p>"
        },
        "29": {
            "verses": {
                "83:29": {
                    "id": 29
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>لما ذكر تعالى جزاء المجرمين وجزاء المؤمنين و [ذكر] ما بينهما من التفاوت العظيم، أخبر أن المجرمين كانوا في الدنيا يسخرون بالمؤمنين، ويستهزئون بهم، ويضحكون منهم،</p>"
        },
        "30": {
            "verses": {
                "83:30": {
                    "id": 30
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>ويتغامزون بهم عند مرورهم عليهم، احتقارا لهم وازدراء، ومع هذا تراهم مطمئنين، لا يخطر الخوف على بالهم،</p>"
        },
        "31": {
            "verses": {
                "83:31": {
                    "id": 31
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَإِذَا انْقَلَبُوا إِلَى أَهْلِهِمُ﴾ صباحًا أو مساء ﴿انْقَلَبُوا فَكِهِينَ﴾ أي: مسرورين مغتبطين ،</p>"
        },
        "32": {
            "verses": {
                "83:32": {
                    "id": 32
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>وهذا من أعظم ما يكون من الاغترار، أنهم جمعوا بين غاية الإساءة والأمن في الدنيا، حتى كأنهم قد جاءهم كتاب من الله وعهد، أنهم من أهل السعادة، وقد حكموا لأنفسهم أنهم أهل الهدى، وأن المؤمنين ضالون، افتراء على الله، وتجرأوا على القول عليه بلا علم.</p>"
        },
        "33": {
            "verses": {
                "83:33": {
                    "id": 33
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿وَمَا أُرْسِلُوا عَلَيْهِمْ حَافِظِينَ﴾ أي: وما أرسلوا وكلاء على المؤمنين ملزمين بحفظ أعمالهم، حتى يحرصوا على رميهم بالضلال، وما هذا منهم إلا تعنت وعناد وتلاعب، ليس له مستند ولا برهان،</p>"
        },
        "34": {
            "verses": {
                "83:34": {
                    "id": 34
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>ولهذا كان جزاؤهم في الآخرة من جنس عملهم، قال تعالى: ﴿فَالْيَوْمَ﴾ أي: يوم القيامة، ﴿الَّذِينَ آمَنُوا مِنَ الْكُفَّارِ يَضْحَكُونَ﴾ حين يرونهم في غمرات العذاب يتقلبون، وقد ذهب عنهم ما كانوا يفترون، والمؤمنون في غاية الراحة والطمأنينة</p>"
        },
        "35": {
            "verses": {
                "83:35": {
                    "id": 35
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿عَلَى الْأَرَائِكِ﴾ وهي السرر المزينة، ﴿يُنْظَرُونَ﴾ إلى ما أعد الله لهم من النعيم، وينظرون إلى وجه ربهم الكريم.</p>"
        },
        "36": {
            "verses": {
                "83:36": {
                    "id": 36
                }
            },
            "resource_id": 110,
            "resource_name": "Tafsir Ar Sa3Dy",
            "language_id": 38,
            "slug": "ar_sa3dy",
            "translated_name": {
                "name": "Tafsir Ar Sa3Dy",
                "language_name": "english"
            },
            "text": "<p>﴿هَلْ ثُوِّبَ الْكُفَّارُ مَا كَانُوا يَفْعَلُونَ﴾ أي: هل جوزوا من جنس عملهم؟</p>\n<p>فكما ضحكوا في الدنيا من المؤمنين ورموهم بالضلال، ضحك المؤمنون منهم في الآخرة، ورأوهم في العذاب والنكال، الذي هو عقوبة الغي والضلال.</p>\n<p>نعم، ثوبوا ما كانوا يفعلون، عدلًا من الله وحكمة، والله عليم حكيم.</p>"
        }
    }
}