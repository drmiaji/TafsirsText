            "translated_name": {
                "name": "Tafsir Vi Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Trong hai ngôi vườn có vô số loại trái cây, mỗi loại trái được chia thành hai nhóm.</p>"
        },
        "53": {
