            "slug": "vi_mokhtasar",
            "translated_name": {
                "name": "Tafsir Vi Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>Hai Ngôi Vườn đó có rất nhiều cây với tán xòe rộng cùng hoa quả.</p>"
        },
