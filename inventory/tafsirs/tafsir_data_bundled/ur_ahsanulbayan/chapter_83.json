            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<p>اور جب انہیں دیکھتے تو کہتے یقیناً یہ لوگ گمراہ (بے راہ) ہیں۔</p>"
        },
