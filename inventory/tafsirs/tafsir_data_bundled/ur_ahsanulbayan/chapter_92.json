{
    "chapter": 92,
    "verses": {
        "1": {
            "verses": {
                "92:1": {
                    "id": 1
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<p>شروع کرتا ہوں میں اللہ تعالٰی کے نام سے جو بڑا مہربان نہایت رحم والا ہے</p>\n<h2>قسم ہے رات کی جب چھا جائے، (۱)</h2>\n<p>۱۔۱یعنی افق پر چھا جائے جس سے دن کی روشنی ختم اور اندھیرا ہو جائے۔</p>"
        },
        "2": {
            "verses": {
                "92:2": {
                    "id": 2
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور قسم ہے دن کی جب روشن ہو۔</h2>\n<p>۲۔۱۔ یعنی رات کا اندھیرا ختم ہو جائے اور دن کو اجالا پھیل جائے۔</p>"
        },
        "3": {
            "verses": {
                "92:3": {
                    "id": 3
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور قسم ہے اس ذات کی جس نے نر مادہ کو پیدا کیا (١)</h2>\n<p>٣۔١ یہ اللہ نے اپنی قسم کھائی ہے، کیونکہ مرد و عورت دونوں کا خالق اللہ ہی ہے</p>"
        },
        "4": {
            "verses": {
                "92:4": {
                    "id": 4
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>یقیناً تمہاری کوشش مختلف قسم کی ہے (١)</h2>\n<p>٤۔١ یعنی کوئی اچھے عمل کرتا ہے، جس کا صلہ جنت ہے اور کوئی برے عمل کرتا ہے جس کا بدلہ جہنم ہے۔ یہ جواب قسم ہے۔</p>"
        },
        "5": {
            "verses": {
                "92:5": {
                    "id": 5
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>جس نے دیا (اللہ کی راہ میں) اور ڈرا (اپنے رب سے)۔ (۱)</h2>\n<h2>۵۔۱یعنی خیر کے کاموں میں خرچ کرے گا اور محارم سے بچے گا۔</h2>"
        },
        "6": {
            "verses": {
                "92:6": {
                    "id": 6
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور نیک بات کی تصدیق کرتا رہے گا۔ (۱)</h2>\n<p>٦۔۱یا اچھے صلے کی تصدیق کرے گا، یعنی اس بات پر یقین رکھے گا کہ انفاق اور تقوی اللہ کی طرف سے عمدہ صلہ ملے گا۔</p>"
        },
        "7": {
            "verses": {
                "92:7": {
                    "id": 7
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>تو ہم بھی اسکو آسان راستے کی سہولت دیں گے۔</h2>\n<p>۷۔۲یعنی ہم بھی اس کو اس سے نیکی اور اطاعت کی توفیق دیتے اور ان کو اس کے لیے آسان کر دیتے ہیں۔ مفسرین کہتے ہیں کہ یہ آیت حضرت ابو بکر کے بارے میں نازل ہوئی ہے جنہوں نے چھ غلام آزاد کیے، جنہیں اہل مکہ مسلمان ہونے کی وجہ سے سخت اذیت دیتے تھے۔ (فتح القدیر)</p>"
        },
        "8": {
            "verses": {
                "92:8": {
                    "id": 8
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>لیکن جس نے بخیلی کی اور بےپرواہی برتی۔ (۱)</h2>\n<p>۸۔۱یعنی اللہ کے راہ میں خرچ نہیں کرے گا اور اللہ کے حکم سے بےپرواہی کرے گا۔</p>"
        },
        "9": {
            "verses": {
                "92:9": {
                    "id": 9
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور نیک بات کو جھٹلایا۔ (۱)</h2>\n<h2>۹۔۱یا آخرت کی جزاء وسزا اور حساب وکتاب کا انکار کرے گا۔</h2>"
        },
        "10": {
            "verses": {
                "92:10": {
                    "id": 10
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>تو ہم بھی اس کی تنگی و مشکل کے سامان میسر کر دیں گے۔ (۱)</h2>\n<p>۱۰۔۱تنگی سے مراد کفر ومعصیت اور طریق شر ہے، یعنی ہم اس کے لیے نافرمانی کا راستہ آسان کر دیں گے، جس سے اس کے لیے خیر وسعادت کے راستے مشکل ہو جائیں گے، قرآن مجید میں یہ مضمون کئی جگہ بیان کیا گیا ہے کہ جو خیر و رشد کا راستہ اپناتا ہے اس کے صلے میں اللہ اسے خیر و توفیق سے نوازتا ہے اور جو شر و معصیت کو اختیار کرتا ہے اللہ اس کو اس کے حال پر چھوڑتا ہے یہ اس کی تقدیر کے مطابق ہوتا ہے جو اللہ نے اپنے علم سے لکھ رکھی ہے۔ (ابن کثیر)</p>"
        },
        "11": {
            "verses": {
                "92:11": {
                    "id": 11
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اس کا مال اسے (اوندھا) کرنے کے وقت کچھ کام نہ آئے گا۔ (۱)</h2>\n<p>۱۱۔۱یعنی جب جہنم میں گرے گا تو یہ مال جسے وہ خرچ نہیں کرتا تھا، کچھ کام نہ آئے گا۔</p>"
        },
        "12": {
            "verses": {
                "92:12": {
                    "id": 12
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>بیشک راہ دکھا دینا ہمارا ذمہ ہے۔ (۱)</h2>\n<p>۱۲۔۱یعنی حلال اور حرام، خیر و شر، ہدایت وضلالت کو واضح اور بیان کرنا ہمارے ذمے ہے۔ (جو کہ ہم نے کر دیا)</p>"
        },
        "13": {
            "verses": {
                "92:13": {
                    "id": 13
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور ہمارے ہی ہاتھ آخرت اور دنیا ہے (١)۔</h2>\n<p>١٣۔١ یعنی دونوں کے مالک ہم ہی ہیں، ان میں جس طرح چاہیں تصرف کریں اس لئے ان دونوں کے یا ان میں سے کسی ایک کے طالب ہم سے ہی مانگیں کیونکہ ہر طالب کو ہم اپنی مشیت کے مطابق دیتے ہیں۔</p>"
        },
        "14": {
            "verses": {
                "92:14": {
                    "id": 14
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>میں نے تو تمہیں شعلہ مارتی ہوئی آگ سے ڈرا دیا ہے۔</h2>"
        },
        "15": {
            "verses": {
                "92:15": {
                    "id": 15
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>جس میں صرف وہی بد بخت داخل ہوگا۔</h2>"
        },
        "16": {
            "verses": {
                "92:16": {
                    "id": 16
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>جس نے جھٹلایا اور (اس کی پیروی سے) منہ پھیر لیا۔</h2>"
        },
        "17": {
            "verses": {
                "92:17": {
                    "id": 17
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<p>اور اس سے ایسا شخص دور رکھا جائے گا جو بڑا پرہیزگار ہوگا۔ (۱)</p>\n<h2>۱۷۔۱یعنی جہنم سے دور رہے گا اور جنت میں داخل ہوگا۔</h2>"
        },
        "18": {
            "verses": {
                "92:18": {
                    "id": 18
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>جو پاکی حاصل کرنے کے لئے اپنا مال دیتا ہے (١)</h2>\n<p>١٨۔١ یعنی جو اپنا مال اللہ کے حکم کے مطابق خرچ کرتا ہے تاکہ اس کا نفس بھی اور اس کا مال بھی پاک ہو جائے۔</p>"
        },
        "19": {
            "verses": {
                "92:19": {
                    "id": 19
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>کسی کا اس پر کوئی احسان نہیں کہ جس کا بدلہ دیا جا رہا ہو۔</h2>"
        },
        "20": {
            "verses": {
                "92:20": {
                    "id": 20
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>بلکہ صرف اپنے پروردگار بزرگ و بلند کی رضا چاہنے کے لیے۔</h2>\n<p>٢٠۔١ بلکہ اخلاص سے اللہ کی رضا اور جنت میں اس کے دیدار کے لئے خرچ کرتا ہے۔</p>"
        },
        "21": {
            "verses": {
                "92:21": {
                    "id": 21
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>یقیناً وہ (اللہ بھی) عنقریب رضامند ہو جائے گا (١)</h2>\n<p>٢١۔١ یعنی جو شخص ان صفات کا حامل ہوگا، اللہ تعالٰی اسے جنت کی نعمتیں اور عزت و شرف عطا فرمائے گا۔ جس سے وہ راضی ہو جائے گا، اکثر مفسرین نے کہا ہے بلکہ بعض نے اجماع تک نقل کیا ہے کہ یہ آیات حضرت ابو بکر کی شان میں نازل ہوئی ہیں۔ تاہم معنی ومفہوم کے اعتبار سے عام ہیں جو بھی ان صفات عالیہ سے متصف ہوگا، وہ بارگاہ الہی میں ان کا مصداق قرار پائے گا۔</p>"
        }
    }
}