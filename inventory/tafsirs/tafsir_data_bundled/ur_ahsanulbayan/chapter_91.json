            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<p>شروع کرتا ہوں میں اللہ تعالٰی کے نام سے جو بڑا مہربان نہایت رحم والا ہے</p>\n<h2>قسم ہے سورج کی اور اس کی دھوپ کی۔ (۱)</h2>\n<p>۱۔۱یا اس کی روشنی کی، یا مطلب ضحیٰ سے دن ہے، یعنی سورج کی اور دن کی۔</p>"
        },
        "2": {
            "verses": {
                "91:2": {
                    "id": 2
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>قسم ہے چاند کی جب اس کے پیچھے آئے۔ (۱)</h2>\n<p>۲۔۱۔ یعنی جب سورج غروب ہونے کے بعد وہ طلوع ہو، جیسا کہ پہلے نصف مہینہ میں ایسا ہوتا ہے۔</p>"
        },
        "3": {
            "verses": {
                "91:3": {
                    "id": 3
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>قسم ہے دن کی جب سورج کو نمایاں کرے۔ (۱)</h2>\n<p>۳۔۱یا تاریکی کو دور کرے،ظلمت کا پہلے ذکر تو نہیں ہے لیکن سیاق اس پر دلالت کرتا ہے۔ (فتح القدیر)</p>"
        },
        "4": {
            "verses": {
                "91:4": {
                    "id": 4
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>قسم ہے رات کی جب اسے ڈھانپ لے۔ (۱)</h2>\n<h2>٤۔۱۔ یعنی سورج کو ڈھانپ لے اور ہر سمت اندھیرا چھا جائے۔</h2>"
        },
        "5": {
            "verses": {
                "91:5": {
                    "id": 5
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>قسم ہے آسمان کی اور اس کے بنانے کی۔ (۱)</h2>\n<h2>۵۔۱یا اس ذات کی جسے اس نے بنایا۔</h2>"
        },
        "6": {
            "verses": {
                "91:6": {
                    "id": 6
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>قسم ہے زمین کی اور اسے ہموار کرنے کی۔ (۱)</h2>\n<h2>٦۔۱یا جس نے اسے ہموار کیا۔</h2>"
        },
        "7": {
            "verses": {
                "91:7": {
                    "id": 7
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>قسم ہے نفس کی اور اسے درست بنانے کی (١)</h2>\n<p>٧۔١ یا جس نے اس درست کیا۔ درست کرنے کا مطلب اسے مناسب الا عضاء بنایا بےڈھنگا نہیں بنایا۔</p>"
        },
        "8": {
            "verses": {
                "91:8": {
                    "id": 8
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>پھر سمجھ دی اسکو بدکاری سے اور بچ کر چلنے کی۔ (۱)</h2>\n<p>۸۔۱الہام کا مطلب یا تو یہ ہے کہ انہیں اچھی طرح سمجھایا اور انہیں انبیاء اور آسمانی کتابوں کے ذریعے سے خیر وشر کی پہچان کروا دی، یا مطلب یہ ہے کہ ان کی عقل اور فطرت میں خیر اور شر، نیکی اور بدکاری کا شور ودیعت کر دیا، تاکہ وہ نیکی کو اپنائیں اور بدی سے اجتناب کریں۔</p>"
        },
        "9": {
            "verses": {
                "91:9": {
                    "id": 9
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>جس نے اسے پاک کیا وہ کامیاب ہوا (١)۔</h2>\n<p>٩۔١ شرک سے، معصیت سے اور اخلاقی آلائشوں سے پاک کیا، وہ اخروی فوز و فلاح سے ہمکنار ہوگا۔</p>"
        },
        "10": {
            "verses": {
                "91:10": {
                    "id": 10
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور جس نے اسے خاک میں ملا دیا وہ ناکام ہوگا (١)</h2>\n<p>١٠۔١ یعنی جس نے اسے گمراہ کر لیا وہ خسارے میں رہا جس کے معنی ہیں ایک چیز کو دوسری چیز میں چھپا دینا، جس نے اپنے نفس کا چھپا دیا اور اسے بےکار چھوڑ دیا اسے اللہ کی اطاعت اور عمل صالح کے ساتھ مشہور نہیں کیا۔</p>"
        },
        "11": {
            "verses": {
                "91:11": {
                    "id": 11
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>(قوم) ثمود نے اپنی سرکشی کی باعث جھٹلایا۔ (۱)</h2>\n<p>۱۱۔۱طغیان، وہ سرکشی جو حد سے تجاوز کر جائے اسی طغیان نے انہیں تکذیب پر آمادہ کیا۔</p>"
        },
        "12": {
            "verses": {
                "91:12": {
                    "id": 12
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>جب ان میں ایک بد بخت کھڑا ہوا (١)۔</h2>\n<p>١٢۔١ جس کا نام مفسرین قدار بن سالف بتلاتے ہیں سب سے بڑا شقی اور بد بخت۔</p>"
        },
        "13": {
            "verses": {
                "91:13": {
                    "id": 13
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اس کے پینے کی باری کی حفاظت کرو (١)</h2>\n<p>١٣۔١ یعنی اس اونٹنی کو کوئی نقصان نہ پہنچائے، اسی طرح اس کے لئے پانی پینے کا جو دن ہو، اس میں بھی گڑ بڑ نہ کی جائے، اونٹنی اور قوم ثمود دونوں کے لیے پانی کا ایک دن مقرر کر دیا گیا تھا اس کی حفاظت کی تاکید کی گئی لیکن ان ظالموں نے اس کی پروا نہ کی۔</p>"
        },
        "14": {
            "verses": {
                "91:14": {
                    "id": 14
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<p>ان لوگوں نے اپنے پیغمبر کو جھوٹا سمجھ کر اس اونٹنی کی کوچیں کاٹ دیں (۱)، پس ان کے رب نے ان کے گناہوں کے باعث ان پر ہلاکت ڈالی پھر (۲) ہلاکت کو عام کر دیا اور اس بستی کو برابر کر دیا۔ (۳)</p>\n<p>۱٤۔۱یہ کام ایک شخص قدار نے کیا تھا لیکن چوں کہ اس شرارت میں قوم بھی اس کے ساتھ تھی اس لیے اس میں سب کو برابر کا مجرم قرار دیا گیا، اور تکذیب اور اونٹنی کی کوچیں کاٹنے کی نسبت پوری قوم کی طرف کی گئی، جس سے یہ اصول معلوم ہوا کہ ایک برائی پر نکیر کرنے کے بجائے اسے پسند کرتی ہو تو اللہ کے ہاں پوری قوم اس برائی کی مرتکب قرار پائے گی اور اس جرم یا برائی میں برابر کی شریک سمجھی جائے گی۔</p>\n<h2>۱٤۔۲ان کو ہلاک کر دیا اور ان پر سخت عذاب نازل کیا۔</h2>\n<p>۱٤۔۳۔ یعنی اس عذاب میں سب کو برابر کر دیا، کسی کو نہیں چھوڑا،چھوٹا بڑا، سب کو نیست ونابود کر دیا گیا یا زمین کو ان پر برابر کر دیا یعنی سب کو تہ خاک کر دیا۔</p>"
        },
        "15": {
            "verses": {
                "91:15": {
                    "id": 15
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>وہ نہیں ڈرتا اس کے تباہ کن انجام سے۔</h2>"
        }
    }
}