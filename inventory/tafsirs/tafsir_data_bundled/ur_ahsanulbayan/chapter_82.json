{
    "chapter": 82,
    "verses": {
        "1": {
            "verses": {
                "82:1": {
                    "id": 1
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<p>شروع کرتا ہوں میں اللہ تعالٰی کے نام سے جو بڑا مہربان نہایت رحم والا ہے</p>\n<h2>جب آسمان پھٹ جائے گا (١)</h2>\n<p>١۔١ یعنی اللہ کے حکم اور اس کی ہیبت سے پھٹ جائے گا اور فرشتے نیچے اتر آئیں گے۔</p>"
        },
        "2": {
            "verses": {
                "82:2": {
                    "id": 2
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>جب ستارے جھڑ جائیں گے۔</h2>"
        },
        "3": {
            "verses": {
                "82:3": {
                    "id": 3
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>سمندر بہہ نکلیں گے</h2>"
        },
        "4": {
            "verses": {
                "82:4": {
                    "id": 4
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور جب قبریں (شق کر کے) اکھاڑ دی جائیں گی (١)</h2>\n<p>٤۔١ یعنی قبروں سے مردے زندہ ہو کر نکل آئیں گے یا ان کی مٹی پلٹ دی جائے گی۔</p>"
        },
        "5": {
            "verses": {
                "82:5": {
                    "id": 5
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<p>(اس وقت) ہر شخص اپنے آگے بھیجے ہوئے اور پیچھے چھوڑے ہوئے (یعنی اگلے پچھلے اعمال) کو معلوم کر لے گا۔</p>"
        },
        "6": {
            "verses": {
                "82:6": {
                    "id": 6
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اے انسان! تجھے اپنے رب کریم سے کس چیز نے بہکایا؟</h2>"
        },
        "7": {
            "verses": {
                "82:7": {
                    "id": 7
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<p>جس (رب نے) تجھے پیدا کیا (١) پھر ٹھیک ٹھاک کیا (٢) اور پھر درست اور برابر بنایا</p>\n<h2>٧۔١ یعنی حقیر نطفے سے، جب کہ اس کے پہلے تیرا وجود نہیں تھا۔</h2>\n<p>٧۔٢ یعنی تجھے ایک کامل انسان بنا دیا، تو سنتا ہے، دیکھتا ہے اور عقل فہم رکھتا ہے۔</p>"
        },
        "8": {
            "verses": {
                "82:8": {
                    "id": 8
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>جس صورت میں چاہا تجھے جوڑ دیا۔</h2>"
        },
        "9": {
            "verses": {
                "82:9": {
                    "id": 9
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>ہرگز نہیں بلکہ تم تو جزا و سزا کے دن کو جھٹلاتے ہو۔</h2>"
        },
        "10": {
            "verses": {
                "82:10": {
                    "id": 10
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>یقیناً تم پر نگہبان عزت والے۔</h2>"
        },
        "11": {
            "verses": {
                "82:11": {
                    "id": 11
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>لکھنے والے مقرر ہیں۔</h2>"
        },
        "12": {
            "verses": {
                "82:12": {
                    "id": 12
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>جو کچھ تم کرتے ہو وہ جانتے ہیں۔</h2>"
        },
        "13": {
            "verses": {
                "82:13": {
                    "id": 13
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>یقیناً نیک لوگ (جنت کے عیش آرام اور) نعمتوں میں ہونگے۔</h2>"
        },
        "14": {
            "verses": {
                "82:14": {
                    "id": 14
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور یقیناً بدکار لوگ دوزخ میں ہونگے۔</h2>"
        },
        "15": {
            "verses": {
                "82:15": {
                    "id": 15
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>بدلے والے دن اس میں جائیں گے (١)</h2>\n<p>١٥۔١ یعنی جس دن جزا و سزا کے دن کا وہ انکار کرتے تھے اسی دن جہنم میں اپنے اعمال کی پاداش میں داخل ہونگے،</p>"
        },
        "16": {
            "verses": {
                "82:16": {
                    "id": 16
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>وہ اس سے کبھی غائب نہ ہونے پائیں گے۔</h2>"
        },
        "17": {
            "verses": {
                "82:17": {
                    "id": 17
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>تجھے کچھ خبر بھی ہے کہ بدلے کا دن کیا ہے۔</h2>"
        },
        "18": {
            "verses": {
                "82:18": {
                    "id": 18
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<p>پھر میں (کہتا ہوں) تجھے کیا معلوم کہ جزا و سزا کا دن کیا ہے۔</p>"
        },
        "19": {
            "verses": {
                "82:19": {
                    "id": 19
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<p>(وہ ہے) جس دن کوئی شخص کسی شخص کے لئے کسی چیز کا مختار نہ ہوگا، اور (تمام تر) احکام اس روز اللہ کے ہی ہوں گے (١)</p>\n<p>١٩۔١ یعنی دنیا میں تو اللہ نے عارضی طور پر، آزمانے کے لئے، انسانوں کو کم و بیش کے کچھ فرق کے ساتھ اختیارات دے رکھے ہیں۔ لیکن قیامت والے دن تمام اختیارات صرف اور صرف اللہ کے پاس ہوں گے۔</p>"
        }
    }
}