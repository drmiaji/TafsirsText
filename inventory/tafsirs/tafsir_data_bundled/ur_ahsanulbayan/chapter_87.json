            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>یہ باتیں پہلی کتابوں میں بھی ہیں۔</h2>"
        },
        "19": {
            "verses": {
                "87:19": {
                    "id": 19
                }
            },
