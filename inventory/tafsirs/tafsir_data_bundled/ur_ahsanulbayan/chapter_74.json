            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>گویا کہ وہ بہکے ہوئے گدھے ہیں۔</h2>"
        },
        "51": {
            "verses": {
                "74:51": {
                    "id": 51
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
