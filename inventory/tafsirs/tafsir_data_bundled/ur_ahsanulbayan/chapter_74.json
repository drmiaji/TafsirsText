                "language_name": "english"
            },
            "text": "<h2>وہ جواب دیں گے ہم نمازی نہ تھے۔</h2>"
        },
        "44": {
            "verses": {
                "74:44": {
                    "id": 44
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
