{
    "chapter": 86,
    "verses": {
        "1": {
            "verses": {
                "86:1": {
                    "id": 1
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<p>شروع کرتا ہوں میں اللہ تعالٰی کے نام سے جو بڑا مہربان نہایت رحم والا ہے</p>\n<h2>قسم ہے آسمان کی اور اندھیرے میں روشن ہونے والے کی۔</h2>"
        },
        "2": {
            "verses": {
                "86:2": {
                    "id": 2
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>تجھے معلوم بھی ہے کہ وہ رات کو نمودار ہونے والی چیز کیا ہے؟</h2>"
        },
        "3": {
            "verses": {
                "86:3": {
                    "id": 3
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>وہ روشن ستارہ ہے (١)</h2>\n<p>٣۔١ طارق سے مراد؟ خود قرآن نے واضح کر دیا۔ روشن ستارہ طارق ہے جس کے لغوی معنی کھٹکھٹانے کے ہیں، لیکن طارق رات کو آنے والے کے لئے استعمال ہوتا ہے۔ ستاروں کو بھی طارق اسی لئے کہا گیا ہے کہ یہ دن کو چھپ جاتے ہیں اور رات کو نمودار ہوتے ہیں۔</p>"
        },
        "4": {
            "verses": {
                "86:4": {
                    "id": 4
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>کوئی ایسا نہیں جس پر نہگبان فرشتہ نہ ہو (١)</h2>\n<p>٤۔١ یعنی ہر نفس پر اللہ کی طرف سے فرشتے مقرر ہیں جو اس کے اچھے یا برے سارے اعمال لکھتے ہیں۔ بعض کہتے ہیں کہ یہ انسانوں کی حفاطت کرنے والے فرشتے ہیں۔</p>"
        },
        "5": {
            "verses": {
                "86:5": {
                    "id": 5
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>انسان کو دیکھنا چاہیے کہ وہ کس چیز سے پیدا کیا گیا ہے۔ (۱)</h2>\n<p>۵۔۱یعنی منی سے جو قضائے شہوت کے بعد زور سے نکلتی ہے۔ یہی قطرہ آب رحم عورت میں جر اللہ کے حکم سے حمل کا باعث بنتا ہے۔</p>"
        },
        "6": {
            "verses": {
                "86:6": {
                    "id": 6
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>وہ ایک اچھلتے ہوئے پانی سے پیدا کیا گیا ہے۔</h2>"
        },
        "7": {
            "verses": {
                "86:7": {
                    "id": 7
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>جو پیٹھ اور سینے کے درمیان سے نکلتا ہے۔ (۱)</h2>\n<p>۷۔۱کہا جاتا ہے کہ پیٹھ مرد کی اور سینہ عورت کا، ان دونوں کے پانی سے انسان کی تخلیق ہوتی ہے۔ لیکن اسے ایک پانی اس لیے کہا کہ یہ دونوں مل کر ایک ہی بن جاتا ہے۔</p>"
        },
        "8": {
            "verses": {
                "86:8": {
                    "id": 8
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>بیشک وہ اسے پھیر لانے پر یقیناً قدرت رکھنے والا ہے (١)</h2>\n<p>٨۔١ یعنی انسان کے مرنے کے بعد، اسے دوبارہ زندہ کرنے پر قادر ہے۔ بعض کے نزدیک اس کا مطلب ہے کہ وہ اس قطرہ آب کو دوبارہ شرمگاہ کے اندر لوٹانے کی قدرت رکھتا ہے جہاں سے وہ نکلا تھا پہلے مفہوم کو امام شوکانی اور امام ابن جریر طبری نے زیادہ صحییح قرار دیا ہے۔</p>"
        },
        "9": {
            "verses": {
                "86:9": {
                    "id": 9
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>جس دن پوشیدہ باتوں کی جانچ پڑتال ہوگی۔ (۱)</h2>\n<p>۹۔۱یعنی ظاہر ہو جائیں گے کیونکہ ان پر جزا و سزا ہوگی بلکہ حدیث میں آتا ہے کہ ہر غدر (بدعہدی) کرنے والے کے سرین کے پاس جھنڈا گاڑ دیا جائے گا اور اعلان کر دیا جائے گا کہ یہ فلاں بن فلاں کی غداری ہے۔ (صحیح بخاری)</p>"
        },
        "10": {
            "verses": {
                "86:10": {
                    "id": 10
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>تو نہ ہوگا اس کے پاس کچھ زور نہ مددگار۔ (۱)</h2>\n<p>۱۰۔۱یعنی خود انسان کے پاس اتنی قوت نہ ہوگی کہ وہ خدا کے عذاب سے بچ جائے نہ کسی اور طرف اس کو کوئی ایسا مددگار مل سکے گا جو اس کو اللہ کے عذاب سے بچا دے۔</p>"
        },
        "11": {
            "verses": {
                "86:11": {
                    "id": 11
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>بارش والے آسمان کی قسم (١)</h2>\n<p>١١۔١ عرب بارش کو رجع کہتے ہیں اس لئے بارش کو رَجْع کہا اور بطور شگون عرب بارش کو کہتے تھے تاکہ وہ بار بار ہوتی رہے۔</p>"
        },
        "12": {
            "verses": {
                "86:12": {
                    "id": 12
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور پھٹنے والی زمین کی قسم (١)</h2>\n<p>١٢۔١ یعنی زمین پھٹتی ہے تو اس سے پودا باہر نکلتا ہے، زمین پھٹتی ہے تو اس سے چشمہ جاری ہوتا ہے اور اسی طرح ایک دن آئے گا کہ زمین پھٹے گی، سارے مردے زندہ ہو کر باہر نکل آئیں گے۔ اس لیے زمین کو پھٹنے والی اور شگاف والی کہا۔</p>"
        },
        "13": {
            "verses": {
                "86:13": {
                    "id": 13
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>بیشک یہ (قرآن) البتہ دو ٹوک فیصلہ کرنے والا کلام ہے۔ (۱)</h2>\n<p>۱۳۔۱یہ جواب قسم ہے، یعنی کھول کر بیان کرنے والا ہے جس سے حق اور باطل دونوں واضح ہو جاتے ہیں۔</p>"
        },
        "14": {
            "verses": {
                "86:14": {
                    "id": 14
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>یہ ہنسی کی (اور بےفائدہ) بات نہیں (١)</h2>\n<p>١٤۔١ یعنی کھیل کود اور مذاق والی چیز نہیں ہے (قصد اور ارادہ) کی ضد ہے، یعنی ایک واضح مقصد کی حامل کتاب ہے، لہو و لعب کی طرح بےمقصد نہیں۔</p>"
        },
        "15": {
            "verses": {
                "86:15": {
                    "id": 15
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>البتہ کافر داؤ گھات میں ہیں (١)</h2>\n<p>١٥۔١ یعنی نبی صلی اللہ علیہ وسلم جو دین حق لے کر آئے ہیں، اس کو ناکام کرنے کے لئے سازشیں کرتے ہیں، یا نبی صلی اللہ علیہ وسلم کو دھوکا اور فریب دیتے ہیں اور منہ پر ایسی باتیں کرتے ہیں کہ دل میں اس کے برعکس ہوتا ہے۔</p>"
        },
        "16": {
            "verses": {
                "86:16": {
                    "id": 16
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور میں بھی ایک چال چل رہا ہوں (١)</h2>\n<p>١٦۔١ یعنی میں ان کی چالوں اور سازشوں سے غافل نہیں ہوں، میں بھی ان کے خلاف تدبیر کر رہا ہوں یا ان کی چالوں کا توڑ کر رہا ہوں، جو برے مقصد کے لئے ہو تو بری اور مقصد نیک تو بری نہیں۔</p>"
        },
        "17": {
            "verses": {
                "86:17": {
                    "id": 17
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>تو کافروں کو مہلت دے (١) انہیں تھوڑے دن چھوڑ دے۔</h2>\n<p>١٧۔١ یعنی ان کے لئے جلدی عذاب کا سوال نہ کر بلکہ انہیں کچھ مہلت دے دے۔</p>"
        }
    }
}