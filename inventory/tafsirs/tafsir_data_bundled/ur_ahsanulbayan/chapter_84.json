{
    "chapter": 84,
    "verses": {
        "1": {
            "verses": {
                "84:1": {
                    "id": 1
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<p>شروع کرتا ہوں میں اللہ تعالٰی کے نام سے جو بڑا مہربان نہایت رحم والا ہے</p>\n<h2>جب آسمان پھٹ جائے گا (١)</h2>\n<h2>١۔١ یعنی جب قیامت برپا ہوگی۔</h2>"
        },
        "2": {
            "verses": {
                "84:2": {
                    "id": 2
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور اپنے رب کے حکم پر کان لگائے گا اسی کے لائق وہ ہے (١)</h2>\n<p>٢۔١ یعنی اس کے یہ لائق ہے کہ سنے اطاعت کرے، اس لئے کہ وہ سب پر غالب ہے اور سب اس کے ماتحت ہیں اس کے حکم سے سرتابی کرنے کی کس کو مجال ہے؟</p>"
        },
        "3": {
            "verses": {
                "84:3": {
                    "id": 3
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور جب زمین کھینچ کر پھیلا دی جائے گی (١)</h2>\n<p>٣۔١ یعنی اس کے طول و عرض میں مزید وسعت کر دی جائے گی۔ یا یہ مطلب ہے کہ اس پر جو پہاڑ وغیرہ ہیں، سب کو ریزہ ریزہ کر کے زمین کو ہموار کر کے بچھایا جائے گا۔ اس میں میں کوئی اونچ نیچ نہیں رہے گی۔</p>"
        },
        "4": {
            "verses": {
                "84:4": {
                    "id": 4
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور اس میں جو ہے اسے وہ اگل دے گی اور خالی ہو جائے گی (١)</h2>\n<p>٤۔١ یعنی اس میں جو مردے دفن ہیں، سب زندہ ہو کر باہر نکل آئیں گے جو خزانے اس کے بطن میں موجود ہیں وہ انہیں ظاہر کر دے گی، اور خود بالکل خالی ہو جائے گی۔</p>"
        },
        "5": {
            "verses": {
                "84:5": {
                    "id": 5
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور اپنے رب پر کان لگائے گی اور اسی لائق وہ ہے۔</h2>"
        },
        "6": {
            "verses": {
                "84:6": {
                    "id": 6
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<p>اے انسان! تو نے اپنے رب سے ملنے تک یہ کوشش اور تمام کام اور محنتیں کر کے اس سے ملاقات کرنے والا ہے۔</p>"
        },
        "7": {
            "verses": {
                "84:7": {
                    "id": 7
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>تو (اسوقت) جس شخص کے داہنے ہاتھ میں اعمال نامہ دیا جائے گا۔</h2>"
        },
        "8": {
            "verses": {
                "84:8": {
                    "id": 8
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اس کا حساب تو بڑی آسانی سے لیا جائے گا</h2>"
        },
        "9": {
            "verses": {
                "84:9": {
                    "id": 9
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور وہ اپنے اہل کی طرف ہنسی خوشی لوٹ آئے گا (١)۔</h2>\n<p>٩۔١ یعنی جو اس کے گھر والوں میں سے جنتی ہونگے۔ یا مراد وہ حور عین اور دلدان ہیں جو جنتیوں کو ملیں گے۔</p>"
        },
        "10": {
            "verses": {
                "84:10": {
                    "id": 10
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>ہاں جس شخص کا اعمال نامہ اس کی پیٹھ پیچھے سے دیا جائے گا۔</h2>"
        },
        "11": {
            "verses": {
                "84:11": {
                    "id": 11
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>تو وہ موت کو بلانے لگے گا۔</h2>"
        },
        "12": {
            "verses": {
                "84:12": {
                    "id": 12
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور بھڑکتی ہوئی جہنم میں داخل ہوگا۔</h2>"
        },
        "13": {
            "verses": {
                "84:13": {
                    "id": 13
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>یہ شخص اپنے متعلقین میں (دنیا میں) خوش تھا (١)</h2>\n<p>١٣۔١ یعنی دنیا میں اپنی خواہشات میں مگن اور اپنے گھر والوں کے درمیان بڑا خوش تھا،</p>"
        },
        "14": {
            "verses": {
                "84:14": {
                    "id": 14
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اس کا خیال تھا کہ اللہ کی طرف لوٹ کر ہی نہ جائے گا۔</h2>"
        },
        "15": {
            "verses": {
                "84:15": {
                    "id": 15
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>کیوں نہیں حالانکہ اس کا رب اسے بخوبی دیکھ رہا تھا (١)</h2>\n<h2>١٥۔١ یعنی اس سے اس کا کوئی عمل چھپا ہوا نہیں تھا۔</h2>"
        },
        "16": {
            "verses": {
                "84:16": {
                    "id": 16
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>مجھے شفق کی قسم (١) اور رات کی!</h2>\n<p>١٦۔ ١ شفق جو سورج غروب ہونے پر ظاہر ہوتی ہے اور عشا کا وقت شروع ہونے تک رہتی ہے۔</p>"
        },
        "17": {
            "verses": {
                "84:17": {
                    "id": 17
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور اس کی جمع کردہ (١) چیزوں کی قسم۔</h2>\n<p>١٧۔١ اندھیرا ہوتے ہی ہرچیز اپنے مسکن کی طرف جمع اور سمٹ آتی ہے یعنی رات کا اندھیرا جن چیزوں کو اپنے دامن میں سمیٹ لیتا ہے۔</p>"
        },
        "18": {
            "verses": {
                "84:18": {
                    "id": 18
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور چاند کو جب وہ کامل ہو جاتا ہے۔</h2>"
        },
        "19": {
            "verses": {
                "84:19": {
                    "id": 19
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>یقیناً تم ایک حالت سے دوسری حالت میں پہنچوگے (١)</h2>\n<p>١٩۔١ یہاں مراد شدائد ہیں جو قیامت والے دن واقع ہونگے۔ یعنی اس روز ایک سے بڑھ کر ایک حالت طاری ہوگی (یہ جواب قسم ہے)</p>"
        },
        "20": {
            "verses": {
                "84:20": {
                    "id": 20
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>انہیں کیا ہوگیا ہے کہ ایمان نہیں لاتے۔</h2>"
        },
        "21": {
            "verses": {
                "84:21": {
                    "id": 21
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور جب ان کے پاس قرآن پڑھا جاتا ہے تو سجدہ نہیں کرتے (١)</h2>\n<p>٢١۔١ احادیث سے یہاں نبی صلی اللہ علیہ وسلم اور صحابہ کرام کا سجدہ کرنا ثابت ہے۔</p>"
        },
        "22": {
            "verses": {
                "84:22": {
                    "id": 22
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>بلکہ جنہوں نے کفر کیا وہ جھٹلا رہے ہیں (١)</h2>\n<h2>٢٢۔١ یعنی ایمان لانے کی بجائے جھٹلا رہے ہیں۔</h2>"
        },
        "23": {
            "verses": {
                "84:23": {
                    "id": 23
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور اللہ تعالٰی خوب جانتا ہے جو کچھ یہ دلوں میں رکھتے ہیں۔</h2>"
        },
        "24": {
            "verses": {
                "84:24": {
                    "id": 24
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>انہیں المناک عذابوں کی خوشخبری سنا دو۔</h2>"
        },
        "25": {
            "verses": {
                "84:25": {
                    "id": 25
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<p>ہاں ایمان والوں اور نیک اعمال والوں کو بیشمار اور نہ ختم ہونے والا اجر ہے۔</p>"
        }
    }
}