{
    "chapter": 93,
    "verses": {
        "1": {
            "verses": {
                "93:1": {
                    "id": 1
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<p>شروع کرتا ہوں میں اللہ تعالٰی کے نام سے جو بڑا مہربان نہایت رحم والا ہے</p>\n<h2>قسم ہے چاشت کے وقت کی (١)</h2>\n<p>١۔١ چاشت اس وقت کو کہتے ہیں، جب سورج بلند ہوتا ہے۔ یہاں مراد پورا دن ہے۔</p>"
        },
        "2": {
            "verses": {
                "93:2": {
                    "id": 2
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور قسم ہے رات کی جب چھا جائے۔ (۱)</h2>\n<p>۲۔۱جب ساکن ہو جائے، یعنی جب اندھیرا مکمل چھا جائے، کیونکہ اس وقت ہرچیز ساکن ہو جاتی ہے۔</p>"
        },
        "3": {
            "verses": {
                "93:3": {
                    "id": 3
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<p>نہ تو تیرے رب نے تجھے چھوڑا ہے اور نہ وہ بیزار ہوگیا ہے۔ (۱)</p>\n<h2>۳۔۱جیسا کہ کافر سمجھ رہے ہیں۔</h2>"
        },
        "4": {
            "verses": {
                "93:4": {
                    "id": 4
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>یقیناً تیرے لئے انجام آغاز سے بہتر ہوگا (١)</h2>\n<p>٤۔١ یا آخرت دنیا سے بہتر ہے، دونوں مفہوم معانی کے اعتبار سے صحیح ہیں۔</p>"
        },
        "5": {
            "verses": {
                "93:5": {
                    "id": 5
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<p>تجھے تیرا رب بہت جلد (انعام) دے گا اور تو راضی و خوش ہو جائے گا (١)</p>\n<p>٥۔١ اس سے دنیا کی فتوحات اور آخرت کا اجر و ثواب مراد ہے، اس میں وہ حق شفاعت بھی داخل ہے جو آپ صلی اللہ علیہ وسلم کو اپنی امت کے گناہ گاروں کے لئے ملے گا۔</p>"
        },
        "6": {
            "verses": {
                "93:6": {
                    "id": 6
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>کیا اس نے یتیم پا کر جگہ نہیں دی (١)</h2>\n<p>٦۔١ یعنی باپ کے سہارے سے بھی محروم تھا، ہم نے تیری دست گیری اور چارہ سازی کی۔</p>"
        },
        "7": {
            "verses": {
                "93:7": {
                    "id": 7
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور تجھے راہ بھولا پا کر ہدایت نہیں دی (١)</h2>\n<p>٧۔١ یعنی تجھے دین شریعت اور ایمان کا پتہ نہیں تھا، ہم نے تجھے راہ یاب کیا، نبوت سے نوازا اور کتاب نازل کی، ورنہ اس سے قبل تو ہدایت کے لئے سرگرداں تھا۔</p>"
        },
        "8": {
            "verses": {
                "93:8": {
                    "id": 8
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور تجھے نادار پا کر تونگر نہیں بنا دیا۔ (۱)</h2>\n<p>۸۔۱تونگر کا مطلب ہے کہ اپنے سوا تجھ کو ہر ایک سے بےنیاز کر دیا، پس تو فقر میں صابر اور غنا میں شاکر رہا ہے۔ جیسے خود نبی صلی اللہ علیہ وسلم نے فرمایا کہ تونگری کثرت ساز و سامان کا نام نہیں اصل تونگری تو دل کی تونگری ہے۔ (صحیح مسلم)</p>"
        },
        "9": {
            "verses": {
                "93:9": {
                    "id": 9
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>پس یتیم پر تو بھی سختی نہ کیا کر۔ (۱)</h2>\n<p>۹۔۱بلکہ اس کے ساتھ نرمی واحسان کا معاملہ کر۔۹۔۱بلکہ اس کے ساتھ نرمی واحسان کا معاملہ کر۔</p>"
        },
        "10": {
            "verses": {
                "93:10": {
                    "id": 10
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور نہ سوال کرنے والے کو ڈانٹ ڈپٹ۔ (۱)</h2>\n<p>۱۰۔۱یعنی اس سے سختی اور تکبر نہ کر، نہ درشت اور تلخ لہجہ اختیار کر، بلکہ جواب بھی دینا ہو تو پیار اور محبت سے دو۔</p>"
        },
        "11": {
            "verses": {
                "93:11": {
                    "id": 11
                }
            },
            "resource_id": 146,
            "resource_name": "Tafsir Ur Ahsanulbayan",
            "language_id": 38,
            "slug": "ur_ahsanulbayan",
            "translated_name": {
                "name": "Tafsir Ur Ahsanulbayan",
                "language_name": "english"
            },
            "text": "<h2>اور اپنے رب کی نعمتوں کو بیان کرتا رہ۔ (۱)</h2>\n<p>۱۱۔۱یعنی اللہ نے تجھ پر جو احسانات کیے ہیں، مثلا ہدایت اور رسالت و نبوت سے نوازا، یتیمی کے باوجود تیری کفالت و سرپرستی کا انتظام کیا، تجھے قناعت وتونگری عطا کی وغیرہ۔</p>"
        }
    }
}