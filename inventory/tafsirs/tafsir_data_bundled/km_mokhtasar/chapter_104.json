            "slug": "km_mokhtasar",
            "translated_name": {
                "name": "Tafsir Km Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ដែលវានឹងឆាបឆេះរោលរាលពេញខ្លួនប្រាណរបស់មនុស្ស រហូតដល់បេះដូងរបស់ពួកគេ។</p>"
        },
