            "slug": "km_mokhtasar",
            "translated_name": {
                "name": "Tafsir Km Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>តើអ្វីដែលធ្វើឱ្យអ្នក(ឱអ្នកនាំសារមូហាំម៉ាត់)ដឹងថា ភ្លើងនរកដែលបំផ្លាញរាល់អ្វីទាំងអស់ដែលគេបោះចូលទៅក្នុងវានោះជាអ្វី?</p>"
        },
        "6": {
            "verses": {
                "104:6": {
                    "id": 6
                }
