            "slug": "km_mokhtasar",
            "translated_name": {
                "name": "Tafsir Km Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>គឺជាភ្លើងរបស់អល់ឡោះដែលត្រូវបានគេបង្កាត់ឆេះយ៉ាងសន្ធោសន្ធៅ</p>"
        },
        "7": {
