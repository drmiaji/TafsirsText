                    "id": 2
                }
            },
            "resource_id": 134,
            "resource_name": "Tafsir Km Mokhtasar",
            "language_id": 38,
            "slug": "km_mokhtasar",
            "translated_name": {
                "name": "Tafsir Km Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ជាអ្នកដែលគោលបំណងសំខាន់របស់គេ គឺការប្រមូលទ្រព្យសម្បត្ដិនិងរាប់ចំនួនរបស់វា។ គេគ្មានគោលបំណងអ្វីផ្សេងពីនោះឡើយ</p>"
        },
        "3": {
            "verses": {
                "104:3": {
                    "id": 3
                }
            },
            "resource_id": 134,
            "resource_name": "Tafsir Km Mokhtasar",
            "language_id": 38,
            "slug": "km_mokhtasar",
            "translated_name": {
                "name": "Tafsir Km Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ដោយគេគិតស្មានថា ទ្រព្យសម្បត្ដិរបស់គេដែលគេខំប្រមូលនោះ នឹងអាចធ្វើឱ្យរូបគេគេចផុតពីសេចក្តីស្លាប់បាន។ ដូច្នេះ គេនឹងអាចរស់នៅជាអមតៈនៅលើលោកិយនេះ។</p>"
        },
        "4": {
            "verses": {
                "104:4": {
                    "id": 4
                }
            },
            "resource_id": 134,
            "resource_name": "Tafsir Km Mokhtasar",
            "language_id": 38,
            "slug": "km_mokhtasar",
            "translated_name": {
                "name": "Tafsir Km Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>រឿងនោះមិនដូចអ្វីដែលជនល្ងង់ខ្លៅនេះគិតនោះទេ។ តាមពិត រូបគេនឹងត្រូវគេបោះទៅក្នុងភ្លើងនរកជើហាន់ណាំដែលវានឹងបំផ្លាញ និងកម្ទេចទាំងអស់រាល់អ្វីដែលគេបោះចូលទៅក្នុងវា ដោយសារតែកម្តៅដ៏សែនក្តៅបំផុតរបស់វា។</p>"
        },
        "5": {
            "verses": {
                "104:5": {
                    "id": 5
                }
            },
            "resource_id": 134,
            "resource_name": "Tafsir Km Mokhtasar",
