            "slug": "km_mokhtasar",
            "translated_name": {
                "name": "Tafsir Km Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ជាការពិតណាស់ នរកនោះត្រូវបានបិទជិតដើម្បីកុំឱ្យពួកត្រូវទណ្ឌកម្មរត់ចេញ។</p>"
        },
