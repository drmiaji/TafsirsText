                "name": "Tafsir Km Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>និងនៅពេលដែលសមុទ្រទាំងឡាយផ្ទុះឡើងព្រមគ្នា ហើយរលាយចូលគ្នាតែមួយ។</p>"
        },
        "4": {
            "verses": {
                "82:4": {
                    "id": 4
                }
            },
            "resource_id": 134,
            "resource_name": "Tafsir Km Mokhtasar",
            "language_id": 38,
            "slug": "km_mokhtasar",
            "translated_name": {
                "name": "Tafsir Km Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>និងនៅពេលដែលផ្នូរទាំងឡាយត្រូវបានគេក្រឡាប់ ដើម្បីពង្រស់សាកសពដែលនៅក្នុងនោះ(ឲ្យក្រោកចេញពីផ្នូរ)។</p>"
        },
        "5": {
            "verses": {
                "82:5": {
                    "id": 5
                }
            },
            "resource_id": 134,
            "resource_name": "Tafsir Km Mokhtasar",
            "language_id": 38,
            "slug": "km_mokhtasar",
            "translated_name": {
                "name": "Tafsir Km Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>នៅពេលនោះ មនុស្សម្នាក់ៗនឹងដឹងពីទង្វើដែលខ្លួនបានសាងកន្លងមក និងទង្វើទាំងឡាយដែលគេពន្យារពេលមិនទាន់បានសាង។</p>"
        },
        "6": {
            "verses": {
                "82:6": {
                    "id": 6
                }
            },
            "resource_id": 134,
            "resource_name": "Tafsir Km Mokhtasar",
            "language_id": 38,
            "slug": "km_mokhtasar",
            "translated_name": {
                "name": "Tafsir Km Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ឱមនុស្សដែលប្រឆាំងនឹងម្ចាស់របស់អ្នក! តើអ្វីដែលធ្វើឱ្យអ្នកហ៊ានប្រឆាំងនឹងបទបញ្ជាម្ចាស់របស់អ្នក ខណៈដែលទ្រង់បានពន្យារពេលដល់អ្នកដោយទ្រង់មិនដាក់ទោសអ្នកភ្លាមៗ(ពេលអ្នកធ្វើខុស) ជាក្តីសណ្តោសមួយអំពីទ្រង់នោះ?</p>"
        },
        "7": {
            "verses": {
                "82:7": {
                    "id": 7
                }
            },
            "resource_id": 134,
            "resource_name": "Tafsir Km Mokhtasar",
            "language_id": 38,
            "slug": "km_mokhtasar",
            "translated_name": {
                "name": "Tafsir Km Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ជាអ្នកដែលបានធ្វើឲ្យអ្នកមានវត្តមានដែលពីមុនមកអ្នកគ្មានវត្តមានសោះ ហើយទ្រង់ធ្វើឱ្យអ្នកមានកាយសម្បទា និងអវយវៈសមសួននឹងដងខ្លួន។</p>"
        },
        "8": {
            "verses": {
