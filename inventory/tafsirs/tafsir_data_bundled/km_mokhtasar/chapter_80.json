            "translated_name": {
                "name": "Tafsir Km Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>តែអ្នកបែរជាយកចិត្តទុកដាក់ចំពោះគេទៅវិញ។</p>"
        },
