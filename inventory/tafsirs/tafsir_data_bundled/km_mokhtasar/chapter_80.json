            "language_id": 38,
            "slug": "km_mokhtasar",
            "translated_name": {
                "name": "Tafsir Km Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ព្រោះមានជនពិការភ្នែកម្នាក់ដែលមានឈ្មោះថា អាប់ទុលឡោះ ពិន អុំមូមឹកទូម បានមកសុំការណែនាំពីគាត់ក្នុងពេលដែលគាត់កំពុងតែជាប់រវល់អំពាវនាវពួកមេដឹកនាំដែលជាអ្នកមានមុខមាត់នៃពួកមុស្ហរីគីន ដោយគាត់សង្ឃឹមថា ពួកទាំងនោះនឹងទទួលបានការចង្អុលបង្ហាញ។</p>"
        },
        "3": {
            "verses": {
                "80:3": {
                    "id": 3
                }
            },
            "resource_id": 134,
            "resource_name": "Tafsir Km Mokhtasar",
            "language_id": 38,
            "slug": "km_mokhtasar",
            "translated_name": {
                "name": "Tafsir Km Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>តើអ្នក(ឱអ្នកនាំសារមូហាំម៉ាត់)អាចដឹងបានយ៉ាងដូមេ្ដចទៅ? ជួនកាលជនពិការភ្នែកម្នាក់នេះអាចមកសម្អាតខ្លួនរបស់គេពីបាបកម្មក៏ថាបាន។</p>"
        },
        "4": {
            "verses": {
                "80:4": {
                    "id": 4
                }
            },
            "resource_id": 134,
            "resource_name": "Tafsir Km Mokhtasar",
            "language_id": 38,
            "slug": "km_mokhtasar",
            "translated_name": {
                "name": "Tafsir Km Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ឬក៏គេចង់ស្តាប់នូវការទូន្មានពីអ្នក ហើយវាអាចផ្ដល់ផលប្រយោជន៍ដល់គេក៏ថាបាន។</p>"
        },
        "5": {
            "verses": {
                "80:5": {
                    "id": 5
                }
            },
            "resource_id": 134,
            "resource_name": "Tafsir Km Mokhtasar",
