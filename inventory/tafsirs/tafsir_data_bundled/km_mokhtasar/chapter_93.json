            "translated_name": {
                "name": "Tafsir Km Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ម្ចាស់របស់អ្នក(ឱអ្នកនាំាសារមូហាំម៉ាត់)មិនបានបោះបង់អ្នកចោល និងមិនបានខឹងសម្បារនឹងអ្នកដូចដែលពួកមុស្ហរីគីនបាននិយាយនោះទេ នៅពេលដែលវ៉ាហ៊ីបានផ្អាកមួយរយៈនោះ។</p>"
        },
        "4": {
            "verses": {
                "93:4": {
                    "id": 4
                }
            },
            "resource_id": 134,
            "resource_name": "Tafsir Km Mokhtasar",
            "language_id": 38,
            "slug": "km_mokhtasar",
            "translated_name": {
                "name": "Tafsir Km Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ជាការពិតណាស់ ឋានបរលោក គឺវាល្អប្រសើរសម្រាប់អ្នកជាងលោកិយនេះទៅទៀត ដោយសារនៅឋានបរលោកនោះ គឺមានឧបការគុណជាច្រើនដែលមិនសាបសូន្យឡើយ។</p>"
        },
        "5": {
