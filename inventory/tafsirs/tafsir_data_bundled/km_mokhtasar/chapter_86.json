            "slug": "km_mokhtasar",
            "translated_name": {
                "name": "Tafsir Km Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>អល់ឡោះបានបង្កើតរូបគេពីទឹកកាមដែលបាញ់បញ្ចូលទៅក្នុងស្បូនមនុស្សស្រី។</p>"
        },
