            "slug": "km_mokhtasar",
            "translated_name": {
                "name": "Tafsir Km Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>តើអ្វីដែលធ្វើឱ្យអ្នក(ឱអ្នកនាំសារមូហាំម៉ាត់)ដឹងថា អាត់តរិក ជាអ្វីនោះ?</p>"
        },
        "3": {
            "verses": {
                "86:3": {
                    "id": 3
                }
            },
            "resource_id": 134,
            "resource_name": "Tafsir Km Mokhtasar",
            "language_id": 38,
            "slug": "km_mokhtasar",
            "translated_name": {
                "name": "Tafsir Km Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>វាគឺជាផ្កាយមួយដួងដែលបញ្ចេញរស្មីយ៉ាងចិញ្ចែងចិញ្ចាចនៅលើមេឃ។</p>"
        },
        "4": {
            "verses": {
                "86:4": {
                    "id": 4
                }
            },
            "resource_id": 134,
            "resource_name": "Tafsir Km Mokhtasar",
            "language_id": 38,
            "slug": "km_mokhtasar",
            "translated_name": {
                "name": "Tafsir Km Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ហើយជីវិតគ្រប់រូបសុទ្ធតែត្រូវបានអល់ឡោះឱ្យម៉ាឡាអ៊ីកាត់មួយរូបទទួលខុសត្រូវចំពោះវា ដោយថែរក្សា(កត់ត្រាទុក)ទង្វើរបស់គេដើម្បីជំនុំជម្រះនៅថ្ងៃបរលោក។</p>"
        },
        "5": {
            "verses": {
                "86:5": {
                    "id": 5
                }
            },
            "resource_id": 134,
            "resource_name": "Tafsir Km Mokhtasar",
            "language_id": 38,
            "slug": "km_mokhtasar",
            "translated_name": {
                "name": "Tafsir Km Mokhtasar",
                "language_name": "english"
            },
            "text": "<p>ដូចេ្នះ ចូរឱ្យមនុស្សលោកពិចារណាមើលចុះ ថាតើអល់ឡោះបានបង្កើតរូបគេមកពីអ្វី ដើម្បីឱ្យគេបានដឹងច្បាស់ពីសមត្ថភាពដ៏អស្ចារ្យរបស់អល់ឡោះ និងការអសមត្ថភាពរបស់មនុស្សលោក។</p>"
        },
        "6": {
            "verses": {
