                "language_name": "english"
            },
            "text": "<h2>ទឹកនេះ គឺចេញពីឆ្អឹងខ្នងរបស់បុរស និងឆ្អឹងជំនីស្ត្រី។</h2>"
        },
        "8": {
            "verses": {
